{
  "baseUrl": "https://quickbee.store/blogs",
  "routes": {
    "home": {
      "path": "/blogs",
      "file": "index.md",
      "title": "QuickBee Blog Home"
    },
    "categories": {
      "brownies": {
        "path": "/blogs/brownies",
        "file": "categories/brownies.md",
        "title": "Brownies Guide",
        "subRoutes": {
          "recipes": "/blogs/brownies/recipes",
          "reviews": "/blogs/brownies/reviews",
          "guides": "/blogs/brownies/guides",
          "special-occasions": "/blogs/brownies/special-occasions"
        }
      },
      "bubble-tea": {
        "path": "/blogs/bubble-tea",
        "file": "categories/bubble-tea.md",
        "title": "Bubble Tea Hub",
        "subRoutes": {
          "flavors": "/blogs/bubble-tea/flavors",
          "recipes": "/blogs/bubble-tea/recipes",
          "health": "/blogs/bubble-tea/health",
          "trends": "/blogs/bubble-tea/trends"
        }
      },
      "baby-care": {
        "path": "/blogs/baby-care",
        "file": "categories/baby-care.md",
        "title": "Baby Care Center",
        "subRoutes": {
          "products": "/blogs/baby-care/products",
          "newborn": "/blogs/baby-care/newborn",
          "feeding": "/blogs/baby-care/feeding",
          "health": "/blogs/baby-care/health"
        }
      },
      "pet-care": {
        "path": "/blogs/pet-care",
        "file": "categories/pet-care.md",
        "title": "Pet Care Guide",
        "subRoutes": {
          "dogs": "/blogs/pet-care/dogs",
          "cats": "/blogs/pet-care/cats",
          "small-pets": "/blogs/pet-care/small-pets",
          "nutrition": "/blogs/pet-care/nutrition"
        }
      },
      "delivery-tips": {
        "path": "/blogs/delivery-tips",
        "file": "categories/delivery-tips.md",
        "title": "Delivery Tips",
        "subRoutes": {
          "ordering": "/blogs/delivery-tips/ordering",
          "tracking": "/blogs/delivery-tips/tracking",
          "discounts": "/blogs/delivery-tips/discounts",
          "seasonal": "/blogs/delivery-tips/seasonal"
        }
      },
      "food-reviews": {
        "path": "/blogs/food-reviews",
        "file": "categories/food-reviews.md",
        "title": "Food Reviews",
        "subRoutes": {
          "reviews": "/blogs/food-reviews/reviews",
          "trending": "/blogs/food-reviews/trending",
          "healthy": "/blogs/food-reviews/healthy",
          "local": "/blogs/food-reviews/local"
        }
      }
    },
    "archive": {
      "all": {
        "path": "/blogs/all",
        "file": "all.md",
        "title": "All Articles"
      },
      "about": {
        "path": "/blogs/about",
        "file": "about.md",
        "title": "About Blog"
      }
    },
    "articles": {
      "path": "/blogs/[category]/[slug]",
      "pattern": "/blog/(.*?)/(.*)\\.md"
    }
  },
  "siteMap": {
    "priority": {
      "home": 1.0,
      "category": 0.9,
      "subCategory": 0.8,
      "article": 0.7
    },
    "changefreq": {
      "home": "daily",
      "category": "weekly",
      "article": "monthly"
    }
  },
  "redirects": [
    {
      "from": "/blog",
      "to": "/blogs"
    },
    {
      "from": "/articles",
      "to": "/blogs/all"
    }
  ]
}
