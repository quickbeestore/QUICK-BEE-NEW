{% # Product FAQs Section %}

<div class="faqs-section">
  <h3 class="section-title">Frequently Asked Questions</h3>

  <div class="faqs-container">
    <!-- FAQ Item 1: Delivery -->
    <div class="faq-item">
      <button class="faq-header" data-toggle="faq-1">
        <span class="faq-question">How long does delivery take?</span>
        <span class="faq-icon">▼</span>
      </button>
      <div class="faq-content" id="faq-1">
        <p>We deliver within 15-30 minutes in your area. Our fast delivery ensures your fresh products arrive at your doorstep quickly and safely.</p>
      </div>
    </div>

    <!-- FAQ Item 2: Quality -->
    <div class="faq-item">
      <button class="faq-header" data-toggle="faq-2">
        <span class="faq-question">Are the products fresh and high quality?</span>
        <span class="faq-icon">▼</span>
      </button>
      <div class="faq-content" id="faq-2">
        <p>Yes! We source directly from trusted local suppliers and ensure all products meet our strict quality standards. Every product is fresh and verified before delivery.</p>
      </div>
    </div>

    <!-- FAQ Item 3: Return/Refund -->
    <div class="faq-item">
      <button class="faq-header" data-toggle="faq-3">
        <span class="faq-question">What is your return and refund policy?</span>
        <span class="faq-icon">▼</span>
      </button>
      <div class="faq-content" id="faq-3">
        <p>We offer hassle-free returns and refunds within 24 hours of delivery if you're not satisfied with your purchase. Simply contact our customer support and we'll process your request immediately.</p>
      </div>
    </div>

    <!-- FAQ Item 4: Payment -->
    <div class="faq-item">
      <button class="faq-header" data-toggle="faq-4">
        <span class="faq-question">What payment methods do you accept?</span>
        <span class="faq-icon">▼</span>
      </button>
      <div class="faq-content" id="faq-4">
        <p>We accept all major payment methods including credit cards, debit cards, digital wallets, and cash on delivery. Your payment is secure and encrypted.</p>
      </div>
    </div>

    <!-- FAQ Item 5: Variants -->
    <div class="faq-item">
      <button class="faq-header" data-toggle="faq-5">
        <span class="faq-question">Can I choose specific variants or sizes?</span>
        <span class="faq-icon">▼</span>
      </button>
      <div class="faq-content" id="faq-5">
        <p>Yes! You can select your preferred variant or size from the dropdown menu above. Our team will ensure you receive exactly what you selected.</p>
      </div>
    </div>
  </div>
</div>

<style>
  .faqs-section {
    padding: 24px 16px;
    background: white;
    border-top: 2px solid #DAA520;
    margin-top: 24px;
  }

  .section-title {
    margin: 0 0 20px 0;
    font-size: 18px;
    font-weight: 700;
    color: #8B0000;
  }

  .faqs-container {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border: 1px solid #DAA520;
    border-top: none;
  }

  .faq-item:first-child {
    border-top: 1px solid #DAA520;
    border-radius: 8px 8px 0 0;
  }

  .faq-item:last-child {
    border-radius: 0 0 8px 8px;
  }

  .faq-header {
    width: 100%;
    padding: 16px;
    background: white;
    border: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 15px;
    font-weight: 600;
    color: #000;
    transition: background 0.2s;
    text-align: left;
  }

  .faq-header:hover {
    background: #fff8e1;
  }

  .faq-icon {
    font-size: 12px;
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 12px;
    color: #8B0000;
  }

  .faq-header.open .faq-icon {
    transform: rotate(180deg);
  }

  .faq-content {
    padding: 0 16px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    background: white;
  }

  .faq-content.open {
    padding: 16px;
    max-height: 500px;
  }

  .faq-content p {
    margin: 0;
    font-size: 14px;
    color: #333;
    line-height: 1.6;
  }

  /* Mobile optimizations */
  @media (max-width: 480px) {
    .faqs-section {
      padding: 16px 12px;
      margin-top: 16px;
    }

    .section-title {
      font-size: 16px;
      margin-bottom: 12px;
    }

    .faq-header {
      padding: 12px;
      font-size: 13px;
      gap: 8px;
    }

    .faq-icon {
      font-size: 11px;
    }

    .faq-content {
      padding: 0 12px;
    }

    .faq-content.open {
      padding: 12px;
    }

    .faq-content p {
      font-size: 12px;
      line-height: 1.5;
    }
  }

  /* Tablet & Desktop */
  @media (min-width: 769px) {
    .faqs-section {
      padding: 24px;
    }

    .section-title {
      font-size: 20px;
      margin-bottom: 24px;
    }

    .faq-header {
      padding: 16px 20px;
      font-size: 16px;
    }

    .faq-content {
      padding: 0 20px;
    }

    .faq-content.open {
      padding: 16px 20px;
    }

    .faq-content p {
      font-size: 15px;
    }
  }

  @media (prefers-color-scheme: dark) {
    .faqs-section {
      background: #ffffff !important;
      color-scheme: light !important;
    }

    .section-title {
      color: #8B0000 !important;
      color-scheme: light !important;
    }

    .faq-item {
      border-color: #DAA520 !important;
      color-scheme: light !important;
    }

    .faq-header {
      background: #ffffff !important;
      color: #000 !important;
      color-scheme: light !important;
    }

    .faq-header:hover {
      background: #fff8e1 !important;
    }

    .faq-content {
      background: #ffffff !important;
      color-scheme: light !important;
    }

    .faq-content p {
      color: #333 !important;
      color-scheme: light !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqHeaders = document.querySelectorAll('.faq-header');

    faqHeaders.forEach(header => {
      header.addEventListener('click', function() {
        const contentId = this.getAttribute('data-toggle');
        const content = document.getElementById(contentId);

        // Close all other FAQs
        document.querySelectorAll('.faq-content.open').forEach(openContent => {
          if (openContent.id !== contentId) {
            openContent.classList.remove('open');
            document.querySelector(`[data-toggle="${openContent.id}"]`).classList.remove('open');
          }
        });

        // Toggle current FAQ
        this.classList.toggle('open');
        content.classList.toggle('open');
      });
    });
  });
</script>
