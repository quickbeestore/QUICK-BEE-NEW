{% # Free Delivery Countdown Timer %}

<div
  class="delivery-countdown"
  id="delivery-countdown"
  data-zone-api="{{ section.settings.zone_validation_endpoint }}"
  aria-live="polite"
  aria-label="Free delivery offer countdown timer"
>
  <span class="countdown-icon">🎁</span>
  <span class="countdown-text"></span>
</div>

<style>
  .delivery-countdown {
    padding: 12px 16px;
    margin: 8px 0;
    background: #fef3c7;
    border: 1px solid #fcd34d;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    color: #b45309;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .delivery-countdown.expiring-soon {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #991b1b;
  }

  .delivery-countdown.expired {
    display: none;
  }

  .countdown-icon {
    font-size: 18px;
  }

  .countdown-text {
    flex: 1;
  }
</style>

<script>
  (function() {
    const countdownEl = document.getElementById('delivery-countdown');
    const textEl = countdownEl.querySelector('.countdown-text');
    const zoneApiEndpoint = countdownEl.dataset.zoneApi;

    // Sample offer data (replace with actual API call if needed)
    const offerEndTime = new Date(Date.now() + 2.25 * 60 * 60 * 1000); // 2h 15m from now

    async function validateDeliveryZone() {
      try {
        const response = await fetch(zoneApiEndpoint, {
          method: 'GET',
          headers: { 'Content-Type': 'application/json' }
        });

        if (response.ok) {
          const data = await response.json();
          return data.in_zone !== false;
        }
        return true;
      } catch (error) {
        console.warn('Zone validation failed:', error);
        return true;
      }
    }

    async function initCountdown() {
      const inZone = await validateDeliveryZone();

      if (!inZone) {
        countdownEl.classList.add('expired');
        return;
      }

      updateCountdown();
      setInterval(updateCountdown, 60000);
    }

    function updateCountdown() {
      const now = new Date();
      const timeLeft = offerEndTime - now;

      if (timeLeft <= 0) {
        countdownEl.classList.add('expired');
        return;
      }

      const hours = Math.floor(timeLeft / (1000 * 60 * 60));
      const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));

      let text = `Free delivery expires in ${hours}h ${minutes}m`;
      textEl.textContent = text;

      if (timeLeft < 5 * 60 * 1000 && !countdownEl.dataset.announced5min) {
        countdownEl.dataset.announced5min = 'true';
      } else if (timeLeft < 30 * 60 * 1000 && !countdownEl.dataset.announced30min) {
        countdownEl.dataset.announced30min = 'true';
      }

      if (timeLeft < 30 * 60 * 1000) {
        countdownEl.classList.add('expiring-soon');
      } else {
        countdownEl.classList.remove('expiring-soon');
      }
    }

    initCountdown();
  })();
</script>
