{% # Quantity Selector Modal %}

<div
  class="quantity-modal"
  id="quantity-selector-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <div class="modal-overlay"></div>
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="modal-title">Select Quantity</h2>
      <button class="modal-close" aria-label="Close modal">×</button>
    </div>

    <form id="quantity-form" action="/cart/add" method="post">
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      <div class="quantity-selector">
        <label for="quantity">Quantity:</label>
        <div class="quantity-input-group">
          <button type="button" class="qty-btn qty-minus">−</button>
          <input
            type="number"
            id="quantity"
            name="quantity"
            value="1"
            min="1"
            max="{{ section.settings.max_quantity | default: 99 }}"
            aria-label="Quantity input"
          >
          <button type="button" class="qty-btn qty-plus">+</button>
        </div>
        <span class="qty-limit">Max {{ section.settings.max_quantity | default: 99 }} per order</span>
      </div>

      <button type="submit" class="modal-add-to-cart">Add {{ product.title }} to Cart</button>
    </form>
  </div>
</div>

<style>
  .quantity-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
  }

  .quantity-modal.active {
    display: flex;
  }

  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
  }

  .modal-content {
    position: relative;
    z-index: 1001;
    background: white;
    margin: auto;
    padding: 24px;
    border-radius: 12px;
    max-width: 400px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .modal-header h2 {
    margin: 0;
    font-size: 20px;
  }

  .modal-close {
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: #666;
  }

  .quantity-selector {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  .quantity-input-group {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .qty-btn {
    width: 40px;
    height: 40px;
    border: 1px solid #ddd;
    background: white;
    cursor: pointer;
    font-size: 18px;
    border-radius: 4px;
  }

  .qty-btn:hover {
    background: #f5f5f5;
  }

  #quantity {
    width: 60px;
    height: 40px;
    border: 1px solid #ddd;
    text-align: center;
    font-size: 16px;
    border-radius: 4px;
  }

  .qty-limit {
    font-size: 12px;
    color: #666;
  }

  .modal-add-to-cart {
    width: 100%;
    height: 48px;
    background: linear-gradient(135deg, #ff6b35, #ff8c5a);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
  }

  .modal-add-to-cart:hover {
    background: linear-gradient(135deg, #ff5722, #ff7540);
  }

  /* ── DARK MODE OVERRIDES ── */
  [data-theme="dark"] .modal-content {
    background-color: #1E1E1E !important;
    border: 1px solid #2A2A2A !important;
    color: #FFFFFF !important;
  }

  [data-theme="dark"] .modal-header h2 {
    color: #F9FAFB !important;
  }

  [data-theme="dark"] .modal-close {
    color: #9CA3AF !important;
  }

  [data-theme="dark"] .quantity-selector label {
    color: #F9FAFB !important;
  }

  [data-theme="dark"] .qty-btn {
    background-color: #2A2A2A !important;
    color: #FFFFFF !important;
    border-color: #374151 !important;
  }

  [data-theme="dark"] #quantity {
    background-color: #1E1E1E !important;
    color: #FFFFFF !important;
    border-color: #374151 !important;
  }

  [data-theme="dark"] .qty-limit {
    color: #9CA3AF !important;
  }

  [data-theme="dark"] .modal-add-to-cart {
    background: linear-gradient(135deg, #C2185B, #AD1457) !important;
    color: #FFFFFF !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('quantity-selector-modal');
    const closeBtn = modal.querySelector('.modal-close');
    const overlay = modal.querySelector('.modal-overlay');
    const minusBtn = modal.querySelector('.qty-minus');
    const plusBtn = modal.querySelector('.qty-plus');
    const quantityInput = document.getElementById('quantity');
    const maxQty = parseInt(quantityInput.max);

    const closeModal = () => modal.classList.remove('active');

    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', closeModal);

    // Close modal on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeModal();
      }
    });

    minusBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (quantityInput.value > 1) quantityInput.value--;
    });

    plusBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (quantityInput.value < maxQty) quantityInput.value++;
    });

    // Handle form submission
    const form = document.getElementById('quantity-form');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const button = form.querySelector('button[type="submit"]');
      button.disabled = true;
      button.textContent = 'Adding...';

      try {
        // Use FormData for proper Shopify API format
        const formData = new FormData();
        formData.append('id', form.querySelector('input[name="id"]').value);
        formData.append('quantity', quantityInput.value);

        const response = await fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        });

        if (response.ok) {
          // Show toast notification
          showToast('✓ Added to cart');
          closeModal();
          quantityInput.value = 1;
        } else {
          showToast('✗ Failed to add to cart. Please try again.', 'error');
        }
      } catch (error) {
        showToast('✗ Failed to add to cart. Please try again.', 'error');
      } finally {
        button.disabled = false;
        button.textContent = 'Add to Cart';
      }
    });
  });

  function showToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.className = 'toast-notification';
    toast.textContent = message;
    const bgColor = type === 'error' ? '#ef4444' : '#22c55e';
    toast.style.cssText = `
      position: fixed;
      bottom: 80px;
      left: 50%;
      transform: translateX(-50%);
      background: ${bgColor};
      color: white;
      padding: 12px 24px;
      border-radius: 8px;
      font-size: 14px;
      z-index: 999;
      animation: slideUp 0.3s ease;
    `;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
  }
</script>
