<script>
(function () {
  'use strict';

  /* ═══════════════════════════════════════════
     STORAGE HELPERS
  ═══════════════════════════════════════════ */
  function loadFromStorage() {
    // Check both keys — GPS auto-refresh writes to qb_location_detail too
    const rawA = localStorage.getItem('qb_selected_location');
    const rawB = localStorage.getItem('qb_location_detail');
    const raw  = rawA || rawB;
    if (!raw) return null;
    try {
      const p = JSON.parse(raw);
      if (!p || typeof p !== 'object') return null;

      // ── New format (has type field) ──
      if (p.type) return p;

      // ── Old manual-entry format (has mode field) ──
      if (p.mode) {
        return {
          type:     p.mode === 'someone_else' ? 'other' : 'self',
          location: p.mode === 'someone_else'
            ? (p.landmark_link || '')
            : (p.street || p.address || ''),
          name:  p.recipient_name  || '',
          mode: p.mode, address: p.address || p.street || '',
          street: p.street || '', recipient_name: p.recipient_name || '',
          landmark_link: p.landmark_link || '',
          latitude: p.latitude || p.lat || '',
          longitude: p.longitude || p.lng || ''
        };
      }

      // ── GPS auto-refresh format (has lat/lng but no type/mode) ──
      if (p.lat !== undefined || p.formatted_address || p.street || p.address || p.name) {
        return {
          type:      'self',
          mode:      'self',
          location:  p.street || p.address || p.formatted_address || p.name || '',
          address:   p.street || p.address || p.formatted_address || '',
          street:    p.street || '',
          name:      p.name  || '',
          latitude:  p.lat   || p.latitude  || '',
          longitude: p.lng   || p.longitude || '',
          formatted_address: p.formatted_address || '',
          _auto: p._auto || false
        };
      }
    } catch (_) {}
    return null;
  }

  function saveToLocalStorage(rawData) {
    const normalized = {
      type:     rawData.mode === 'someone_else' ? 'other' : 'self',
      location: rawData.mode === 'someone_else'
        ? (rawData.landmark_link || '')
        : (rawData.street || rawData.address || ''),
      name:  rawData.recipient_name  || '',
      // Legacy fields — keeps header & cart page working
      mode:            rawData.mode,
      address:         rawData.address || rawData.street || rawData.landmark_link || '',
      street:          rawData.street || '',
      recipient_name:  rawData.recipient_name  || '',
      landmark_link:   rawData.landmark_link   || '',
      latitude:        rawData.latitude  || '',
      longitude:       rawData.longitude || '',
      timestamp: new Date().toISOString()
    };
    try {
      localStorage.setItem('qb_selected_location', JSON.stringify(normalized));
      window.QB_SELECTED_LOCATION = normalized;
    } catch (e) {
      console.error('[QB] saveToLocalStorage failed:', e);
    }
    return normalized;
  }

  /* ═══════════════════════════════════════════
     SHOPIFY INTEGRATION
  ═══════════════════════════════════════════ */

  // ─────────────────────────────────────────────────────────────────
  // sendToShopify — uses Web3Forms (free, unlimited, no rate limits)
  //
  // WHY NOT Shopify /contact:
  //   Shopify throttles contact form POSTs to ~2 per session to block
  //   spam. There is no way to bypass this without a backend server.
  //
  // SETUP (one-time, 60 seconds):
  //   1. Go to https://web3forms.com
  //   2. Enter your admin email → click "Create Access Key"
  //   3. Copy the key and paste it below replacing WEB3FORMS_KEY
  // ─────────────────────────────────────────────────────────────────
  var WEB3FORMS_KEY = 'WEB3FORMS_KEY'; // ← paste your key here

  function sendToShopify(data, attempt) {
    attempt = attempt || 0;

    var lat      = data.latitude  || '';
    var lng      = data.longitude || '';
    var mapsLink = data.landmark_link
      ? data.landmark_link
      : (lat && lng ? 'https://www.google.com/maps?q=' + lat + ',' + lng : 'N/A');

    var payload = {
      access_key:  WEB3FORMS_KEY,
      subject:     'New QuickBee Delivery Location',
      from_name:   'QuickBee Location Bot',
      'Type':      data.type     || 'N/A',
      'Location':  data.location || 'N/A',
      'Maps Link': mapsLink,
      'Name':      data.name     || 'N/A',
      'Timestamp': new Date().toLocaleString()
    };

    return fetch('https://api.web3forms.com/submit', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body:    JSON.stringify(payload)
    })
    .then(function (r) { return r.json(); })
    .then(function (res) {
      if (res.success) {
        console.log('[QB] Email sent via Web3Forms ✅');
      } else {
        throw new Error(res.message || 'Web3Forms error');
      }
    })
    .catch(function (err) {
      if (attempt < 1) {
        return new Promise(function (r) {
          setTimeout(function () { r(sendToShopify(data, 1)); }, 1000);
        });
      }
      console.warn('[QB] sendToShopify failed after retry:', err);
    });
  }

  // Attach delivery details as Shopify cart order note
  function updateCartNote(data) {
    const note = [
      'Delivery Details:',
      'Type: '     + (data.type     || 'N/A'),
      'Location: ' + (data.location || 'N/A'),
      'Name: '     + (data.name     || 'N/A')
    ].join('\n');

    return fetch('/cart/update.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ note: note })
    }).catch(function (err) {
      console.warn('[QB] updateCartNote failed:', err);
    });
  }

  /* ═══════════════════════════════════════════
     MODAL INIT
  ═══════════════════════════════════════════ */
  function initLocationModal() {

    // ── DOM refs ──
    const backdrop        = document.getElementById('qbLocationBackdrop');
    const modal           = document.getElementById('qbLocationModal');
    const closeBtn        = document.getElementById('qbLocationClose');
    const cancelBtn       = document.getElementById('qbLocationCancel');
    const selectBtn       = document.getElementById('qbLocationSelect');
    const detectAutoBtn   = document.getElementById('qbDetectAutoBtn');
    const someoneElseBtn  = document.getElementById('qbSomeoneElseBtn');
    const landmarkHelpBtn = document.getElementById('qbLandmarkHelpBtn');
    const guideOverlay    = document.getElementById('qbLocationGuideOverlay');
    const guideCloseBtn   = document.getElementById('qbLocationGuideClose');

    const steps = {
      method:    document.getElementById('qbLocationStep1'),
      detecting: document.getElementById('qbLocationStep2'),
      form:      document.getElementById('qbLocationStep3'),
      success:   document.getElementById('qbLocationStep4')
    };

    const formInputs = {
      street:       document.getElementById('qbLocationStreet'),
      receiverName: document.getElementById('qbReceiverName'),
      landmarkLink: document.getElementById('qbLandmarkLink'),
      lat:          document.getElementById('qbLocationLat'),
      lng:          document.getElementById('qbLocationLng')
    };

    const formGroups = {
      street:       null,  // hidden input — no wrapper group
      receiverName: document.getElementById('qbReceiverNameGroup'),
      landmarkLink: document.getElementById('qbLandmarkGroup'),
      lat:          document.getElementById('qbLatGroup'),
      lng:          document.getElementById('qbLngGroup')
    };

    const errorEl        = document.getElementById('qbLocationError');
    const deliveryInfoEl = document.getElementById('qbDeliveryInfo');
    const deliveryTimeEl = document.getElementById('qbDeliveryTime');
    const successAddrEl  = document.getElementById('qbSuccessAddress');

    let currentStep    = 'method';
    let detectionMode  = null;   // 'auto' | 'someone_else'
    let selectedCoords = null;
    let isForcedOpen   = false;

    /* ── Helpers ── */
    function isGoogleMapsLink(v) {
      const s = String(v || '').trim().toLowerCase();
      return /(^https?:\/\/)?(www\.)?(google\.[^\/]+\/maps|maps\.app\.goo\.gl|goo\.gl\/maps)/.test(s);
    }

    function showGroup(group, visible) {
      if (group) group.style.display = visible ? 'flex' : 'none';
    }

    function syncFormForMode() {
      const isSE = detectionMode === 'someone_else';
      const statusCard = document.getElementById('qbDetectedStatus');

      // Self mode: show status card; hide raw fields + lat/lng always
      if (statusCard) statusCard.style.display = isSE ? 'none' : 'flex';
      showGroup(formGroups.street,        false);  // always hidden — value kept in hidden input
      showGroup(formGroups.lat,           false);  // never shown to user
      showGroup(formGroups.lng,           false);  // never shown to user
      showGroup(formGroups.receiverName,   isSE);
      showGroup(formGroups.landmarkLink,   isSE);

      // Show "ordering for yourself instead?" chip only in someone-else mode
      var switchRow = document.getElementById('qbSwitchToSelfRow');
      if (switchRow) switchRow.style.display = isSE ? 'block' : 'none';

      if (isSE) {
        deliveryInfoEl.style.display = 'none';
        var mapsRow = document.getElementById('qbViewOnMapsRow');
        if (mapsRow) mapsRow.style.display = 'none';
      }

      formInputs.street.required        = false;  // hidden input — validated manually
      formInputs.receiverName.required  =  isSE;
      formInputs.landmarkLink.required  =  isSE;
    }

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.add('show');
      setTimeout(function () { errorEl.classList.remove('show'); }, 5000);
    }

    function updateViewOnMapsLink(lat, lng) {
      const row  = document.getElementById('qbViewOnMapsRow');
      const link = document.getElementById('qbViewOnMapsLink');
      if (row && link) {
        link.href = 'https://www.google.com/maps?q=' + lat + ',' + lng;
        row.style.display = 'block';
      }
    }

    /* ── Button / footer state ── */
    function updateButtonState() {
      const isSE = detectionMode === 'someone_else';
      const valid = isSE
        ? !!(formInputs.receiverName.value.trim() &&
             isGoogleMapsLink(formInputs.landmarkLink.value))
        : !!(formInputs.street.value.trim());

      selectBtn.disabled = currentStep === 'form' && !valid;

      // Go Back only shows on the form step — no "back" from method/detecting/success
      if (currentStep === 'method' || currentStep === 'detecting') {
        selectBtn.style.display = 'none';
        cancelBtn.style.display = 'none';
      } else if (currentStep === 'success') {
        selectBtn.style.display = 'none';
        cancelBtn.style.display = 'none';
      } else {
        // form step
        selectBtn.style.display = 'block';
        cancelBtn.style.display = 'block';
      }
    }

    /* ── Step navigation ── */
    function goToStep(stepName) {
      Object.values(steps).forEach(function (s) { s.classList.remove('active'); });
      steps[stepName].classList.add('active');
      currentStep = stepName;
      updateButtonState();
    }

    /* ── Modal open / close ── */
    function showModal(forced) {
      isForcedOpen = !!forced;
      modal.classList.add('active');
      backdrop.classList.add('active');
      document.body.style.overflow = 'hidden';
      // In forced mode: hide X and Cancel so user must complete
      closeBtn.style.display = isForcedOpen ? 'none' : '';
      updateButtonState();
    }

    function _doClose() {
      backdrop.classList.remove('active');
      modal.classList.remove('active');
      document.body.style.overflow = '';
      resetForm();
    }

    function hideModal() {
      if (isForcedOpen) return; // block — must pick a location
      _doClose();
    }

    function forceClose() {
      isForcedOpen = false;
      _doClose();
    }

    function showGuide() { if (guideOverlay) guideOverlay.classList.add('active'); }
    function hideGuide() { if (guideOverlay) guideOverlay.classList.remove('active'); }

    /* ── Delivery time estimation ── */
    function calcDeliveryTime(lat, lng) {
      const wLat = 27.7172, wLng = 85.3240;
      const toRad = function (x) { return x * Math.PI / 180; };
      const dLatR = toRad(lat - wLat);
      const dLonR = toRad(lng - wLng);
      const a = Math.sin(dLatR / 2) * Math.sin(dLatR / 2) +
                Math.cos(toRad(wLat)) * Math.cos(toRad(lat)) *
                Math.sin(dLonR / 2) * Math.sin(dLonR / 2);
      const km  = 6371 * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      const est = Math.min(Math.round(10 + km * 1.5), 60);
      const mn  = Math.max(est - 4, 5);
      const mx  = Math.min(est + 4, 60);
      return {
        minTime: mn, maxTime: mx,
        range: mn + '-' + mx + ' mins',
        distanceKm: km, estimatedMins: est,
        updatedAt: new Date().toISOString()
      };
    }

    function estimateDeliveryTime() {
      let data;
      if (formInputs.lat.value && formInputs.lng.value) {
        data = calcDeliveryTime(
          parseFloat(formInputs.lat.value),
          parseFloat(formInputs.lng.value)
        );
      } else {
        data = { minTime: 18, maxTime: 22, range: '18-22 mins', updatedAt: new Date().toISOString() };
      }
      window.QB_DELIVERY_TIME = data;
      try { localStorage.setItem('qb_delivery_time', JSON.stringify(data)); } catch (_) {}
      deliveryTimeEl.textContent       = data.range;
      deliveryInfoEl.style.display     = 'block';
      updateProductDeliveryBadges();
    }

    function updateProductDeliveryBadges() {
      const range = (window.QB_DELIVERY_TIME && window.QB_DELIVERY_TIME.range) || '18-22 mins';
      document.querySelectorAll(
        '.qb-delivery-badge, .qb-delivery-time-text, .qbp2-delivery-sync, .qb-delivery-sync'
      ).forEach(function (el) { el.textContent = range; });
    }

    /* ── Reverse geocode ── */
    function fallbackLabel(lat, lng) {
      return 'Detected near ' + lat.toFixed(5) + ', ' + lng.toFixed(5);
    }

    function buildStreetAddress(place) {
      const addr = (place && place.address) || {};
      const streetParts = [
        addr.house_number,
        addr.road || addr.pedestrian || addr.footway || addr.cycleway
      ].filter(Boolean);
      if (streetParts.length) return streetParts.join(' ');
      const localParts = [
        addr.neighbourhood, addr.suburb, addr.residential, addr.hamlet,
        addr.quarter, addr.city_district, addr.village, addr.town, addr.city
      ].filter(Boolean);
      if (localParts.length) return localParts.slice(0, 2).join(', ');
      if (place && place.display_name) {
        return place.display_name.split(',').slice(0, 2).join(', ').trim();
      }
      return '';
    }

    function setDetectedAddr(text) {
      var addrEl = document.getElementById('qbDetectedAddrText');
      if (addrEl) addrEl.textContent = text || 'Location confirmed';
    }

    function reverseGeocode(lat, lng) {
      const fb = fallbackLabel(lat, lng);
      formInputs.street.value = fb;
      setDetectedAddr('Fetching address…');
      updateButtonState();

      fetch(
        'https://nominatim.openstreetmap.org/reverse?format=jsonv2' +
        '&lat=' + encodeURIComponent(lat) +
        '&lon=' + encodeURIComponent(lng) +
        '&addressdetails=1'
      )
        .then(function (r) { return r.json(); })
        .then(function (place) {
          var addr = buildStreetAddress(place) || fb;
          formInputs.street.value = addr;
          setDetectedAddr(addr);
          syncFormForMode();
          updateButtonState();
          estimateDeliveryTime();
          goToStep('form');
        })
        .catch(function () {
          formInputs.street.value = fb;
          setDetectedAddr(fb);
          syncFormForMode();
          updateButtonState();
          estimateDeliveryTime();
          goToStep('form');
        });
    }

    /* ── GPS detection ── */
    function detectLocation() {
      goToStep('detecting');
      detectionMode = 'auto';
      syncFormForMode();

      if (!navigator.geolocation) {
        showError('Geolocation not supported by your browser');
        goToStep('method');
        return;
      }

      navigator.geolocation.getCurrentPosition(
        function (pos) {
          const lat = pos.coords.latitude;
          const lng = pos.coords.longitude;
          selectedCoords = { latitude: lat, longitude: lng };
          formInputs.lat.value = lat.toFixed(6);
          formInputs.lng.value = lng.toFixed(6);
          updateViewOnMapsLink(lat, lng);
          reverseGeocode(lat, lng);
        },
        function (err) {
          const msgs = {
            1: 'Location access denied. Please enable it in settings.',
            2: 'Location service unavailable.',
            3: 'Location request timed out.'
          };
          showError(msgs[err.code] || 'Unable to detect location');
          goToStep('method');
        },
        { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
      );
    }

    function orderForSomeoneElse() {
      detectionMode  = 'someone_else';
      selectedCoords = null;
      formInputs.street.value = '';
      formInputs.lat.value    = '';
      formInputs.lng.value    = '';
      syncFormForMode();
      goToStep('form');
    }

    /* ══════════════════════════════════════════
       handleSubmit — main action on "Select Location"
    ══════════════════════════════════════════ */
    function handleSubmit() {
      if (currentStep !== 'form') return;

      const isSE = detectionMode === 'someone_else';

      // ── Validation ──
      if (isSE) {
        if (!formInputs.receiverName.value.trim()) {
          showError("Please enter receiver's name"); return;
        }
        if (!isGoogleMapsLink(formInputs.landmarkLink.value)) {
          showError('Only Google Maps links are accepted for landmark'); return;
        }
      } else {
        if (!formInputs.street.value.trim()) {
          showError('Location not detected yet. Please try again.'); return;
        }
      }

      // ── Loading state ──
      const origText = selectBtn.textContent;
      selectBtn.disabled    = true;
      selectBtn.textContent = '\u23F3 Saving...';

      // ── Build raw data object ──
      const rawData = isSE
        ? {
            mode:            'someone_else',
            recipient_name:  formInputs.receiverName.value.trim(),
            landmark_link:   formInputs.landmarkLink.value.trim()
          }
        : {
            mode:      'auto',
            address:   formInputs.street.value.trim(),
            street:    formInputs.street.value.trim(),
            latitude:  formInputs.lat.value,
            longitude: formInputs.lng.value
          };

      // ── saveToLocalStorage ──
      const normalized = saveToLocalStorage(rawData);

      // ── Persist delivery time for self-orders ──
      if (!isSE && formInputs.lat.value && formInputs.lng.value) {
        const dData = calcDeliveryTime(
          parseFloat(formInputs.lat.value),
          parseFloat(formInputs.lng.value)
        );
        window.QB_DELIVERY_TIME = dData;
        try { localStorage.setItem('qb_delivery_time', JSON.stringify(dData)); } catch (_) {}
      }

      // ── sendToShopify + updateCartNote (fire-and-forget, parallel) ──
      sendToShopify(normalized);
      updateCartNote(normalized);

      // ── Success UI ──
      successAddrEl.textContent = isSE
        ? (normalized.name)
        : normalized.location;
      goToStep('success');

      // Restore button
      selectBtn.disabled    = false;
      selectBtn.textContent = origText;

      // Update delivery badges on page
      updateProductDeliveryBadges();

      // Dispatch event for header location widget
      window.dispatchEvent(new CustomEvent('locationSelected', { detail: normalized }));
      if (typeof window.QB_LOCATION_CALLBACK === 'function') {
        window.QB_LOCATION_CALLBACK(normalized);
      }

      // Auto-close after success animation completes
      setTimeout(forceClose, 1600);
    }

    /* ── Reset ── */
    function resetForm() {
      Object.values(formInputs).forEach(function (inp) { inp.value = ''; });
      deliveryInfoEl.style.display = 'none';
      errorEl.classList.remove('show');
      currentStep   = null;
      detectionMode = null;
      selectedCoords= null;
      syncFormForMode();
      goToStep('method');
    }

    /* ── Event listeners ── */
    closeBtn.addEventListener('click',   hideModal);
    cancelBtn.addEventListener('click',  function () { goToStep('method'); });
    backdrop.addEventListener('click',   function (e) {
      if (e.target === backdrop) hideModal();
    });
    modal.addEventListener('click', function (e) { e.stopPropagation(); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.classList.contains('active')) hideModal();
    });

    if (landmarkHelpBtn) landmarkHelpBtn.addEventListener('click', showGuide);
    if (guideCloseBtn)   guideCloseBtn.addEventListener('click',   hideGuide);
    if (guideOverlay) {
      guideOverlay.addEventListener('click', function (e) {
        if (e.target === guideOverlay) hideGuide();
      });
    }

    detectAutoBtn.addEventListener('click',  detectLocation);
    someoneElseBtn.addEventListener('click', orderForSomeoneElse);

    // "Ordering for yourself instead?" — switch from someone-else form to GPS detect
    var switchToSelfBtn = document.getElementById('qbSwitchToSelfBtn');
    if (switchToSelfBtn) {
      switchToSelfBtn.addEventListener('click', function () {
        // Clear someone-else fields
        formInputs.receiverName.value = '';
        formInputs.landmarkLink.value = '';
        // Jump straight to GPS detection
        detectLocation();
      });
    }
    selectBtn.addEventListener('click',      handleSubmit);

    [formInputs.street,
     formInputs.receiverName,
     formInputs.landmarkLink].forEach(function (inp) {
      inp.addEventListener('input', updateButtonState);
    });
    formInputs.lat.addEventListener('change', estimateDeliveryTime);
    formInputs.lng.addEventListener('change', estimateDeliveryTime);

    /* ══════════════════════════════════════════
       PAGE-LOAD LOGIC
       — Force modal if no location saved
       — Sync cart note silently on every visit
    ══════════════════════════════════════════ */
    function onPageLoad() {
      const saved = loadFromStorage();

      // Hard safety net: if ANY location key has data at all, never auto-show
      const hasAnyData = !!(
        localStorage.getItem('qb_selected_location') ||
        localStorage.getItem('qb_location_detail')
      );

      if (!saved && !hasAnyData) {
        // Truly first-time visitor — force modal, block everything behind
        setTimeout(function () { showModal(true); }, 150);
      } else {
        // Returning visitor — restore delivery time badges
        try {
          const dt = JSON.parse(localStorage.getItem('qb_delivery_time') || 'null');
          if (dt) {
            window.QB_DELIVERY_TIME = dt;
            updateProductDeliveryBadges();
          }
        } catch (_) {}
        // Always keep cart note in sync with latest delivery info
        setTimeout(function () { updateCartNote(saved); }, 600);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', onPageLoad);
    } else {
      onPageLoad();
    }

    /* ── Public API ── */
    window.showLocationModal   = function () { showModal(false); };
    window.hideLocationModal   = hideModal;
    window.getSelectedLocation = function () { return window.QB_SELECTED_LOCATION; };
  }

  /* ── Boot ── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLocationModal);
  } else {
    initLocationModal();
  }

})();
</script>
