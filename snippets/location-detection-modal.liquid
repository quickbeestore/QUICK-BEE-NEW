{% comment %}
QuickBEE Location Detection Modal
Provides GPS auto-detection with delivery time estimation based on location
{% endcomment %}

<style>
/* ══════════════════════════════════════
   QB LOCATION MODAL — Premium Redesign
══════════════════════════════════════ */

.qb-location-backdrop {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.75);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 99999;
  align-items: center;
  justify-content: center;
  padding: 16px;
}
.qb-location-backdrop.active {
  display: flex;
  animation: qbBackdropIn 0.3s ease forwards;
}
@keyframes qbBackdropIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.qb-location-modal {
  display: none;
  position: relative;
  background: #fff;
  border-radius: 24px;
  width: 92%;
  max-width: 420px;
  max-height: calc(100dvh - 40px);
  overflow: hidden;
  overflow-y: auto;
  box-shadow: 0 32px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.04);
  flex-direction: column;
}
.qb-location-modal.active {
  display: flex;
  animation: qbModalIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}
@keyframes qbModalIn {
  from { opacity: 0; transform: translateY(32px) scale(0.91); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* ── Hero Header ── */
.qblm-hero {
  position: relative;
  background: linear-gradient(135deg, #0d0d0d 0%, #1a0830 55%, #060c18 100%);
  padding: 28px 24px 22px;
  overflow: hidden;
  min-height: 118px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.qblm-hero::before {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(244,180,0,0.16) 0%, transparent 68%);
  border-radius: 50%;
  pointer-events: none;
}
.qblm-hero::after {
  content: '';
  position: absolute;
  bottom: -30px; left: -30px;
  width: 140px; height: 140px;
  background: radial-gradient(circle, rgba(122,20,172,0.14) 0%, transparent 68%);
  border-radius: 50%;
  pointer-events: none;
}

/* ── Animated Bee+Scooter ── */
.qblm-bee-rider {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 88px;
  height: 54px;
  z-index: 2;
  filter: drop-shadow(0 0 8px rgba(244,180,0,0.65)) drop-shadow(0 0 18px rgba(244,180,0,0.25));
  animation: qbBeeRide 7s ease-in-out infinite;
}
@keyframes qbBeeRide {
  0%   { transform: translateX(120px); opacity: 0; }
  8%   { opacity: 1; }
  25%  { transform: translateX(20px) translateY(-5px); }
  50%  { transform: translateX(-70px) translateY(4px); }
  75%  { transform: translateX(-160px) translateY(-3px); }
  92%  { opacity: 1; }
  100% { transform: translateX(-280px); opacity: 0; }
}
.qblm-bee-rider svg {
  animation: qbBeeBob 0.45s ease-in-out infinite alternate;
  transform-origin: center center;
}
@keyframes qbBeeBob {
  from { transform: translateY(0) rotate(-3deg); }
  to   { transform: translateY(-4px) rotate(2.5deg); }
}

/* Speed lines / glow trail */
.qblm-hero-glow {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 60%, rgba(244,180,0,0.04) 100%);
  pointer-events: none;
  z-index: 1;
}

.qblm-close {
  position: absolute;
  top: 14px; right: 14px;
  width: 30px; height: 30px;
  background: rgba(255,255,255,0.1);
  border: none;
  border-radius: 50%;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.65);
  font-size: 16px;
  transition: all 0.2s;
  z-index: 10;
}
.qblm-close:hover {
  background: rgba(255,255,255,0.2);
  color: #fff;
  transform: scale(1.1);
}

.qblm-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(244,180,0,0.14);
  border: 1px solid rgba(244,180,0,0.28);
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 10px;
  font-weight: 700;
  color: #F4B400;
  letter-spacing: 0.6px;
  text-transform: uppercase;
  margin-bottom: 7px;
  width: fit-content;
  position: relative;
  z-index: 3;
}
.qblm-hero-title {
  font-size: 21px;
  font-weight: 800;
  color: #fff;
  margin: 0;
  letter-spacing: -0.4px;
  line-height: 1.22;
  position: relative;
  z-index: 3;
}
.qblm-hero-sub {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  margin: 4px 0 0;
  position: relative;
  z-index: 3;
}

/* ── Body ── */
.qb-location-body {
  padding: 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #fff;
}

/* ── Error ── */
.qb-location-error {
  display: none;
  background: #fff1f1;
  border: 1.5px solid rgba(239,68,68,0.38);
  color: #dc2626;
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 14px;
}
.qb-location-error.show {
  display: block;
  animation: qbErrShake 0.38s ease;
}
@keyframes qbErrShake {
  0%,100% { transform: translateX(0); }
  25% { transform: translateX(-6px); }
  75% { transform: translateX(6px); }
}

/* ── Steps ── */
.qb-location-step { display: none; }
.qb-location-step.active {
  display: block;
  animation: qbStepIn 0.28s cubic-bezier(0.4,0,0.2,1) forwards;
}
@keyframes qbStepIn {
  from { opacity: 0; transform: translateX(10px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* ── Step 1: Method Cards ── */
.qb-location-methods {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.qb-location-method-btn {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0;
  border-radius: 16px;
  background: #fff;
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
  text-align: left;
  overflow: hidden;
  position: relative;
  border: 2px solid #ebebeb;
}
.qb-location-method-btn:active { transform: scale(0.97); }

/* GPS card */
#qbDetectAutoBtn { border-color: rgba(0,180,216,0.3); }
#qbDetectAutoBtn:hover {
  border-color: #00B4D8;
  box-shadow: 0 4px 20px rgba(0,180,216,0.18);
  transform: translateY(-1px);
}
#qbDetectAutoBtn .qblm-card-icon-wrap {
  background: linear-gradient(135deg, #00B4D8, #0077B6);
}

/* Switch-to-self inline chip */
.qblm-switch-self-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  width: 100%;
  padding: 10px 16px;
  background: rgba(0,180,216,0.07);
  border: 1.5px dashed rgba(0,180,216,0.40);
  border-radius: 12px;
  color: #0077B6;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.18s, border-color 0.18s;
  text-align: left;
}
.qblm-switch-self-btn:hover {
  background: rgba(0,180,216,0.14);
  border-color: rgba(0,180,216,0.70);
}
[data-theme="dark"] .qblm-switch-self-btn,
body.dark-theme .qblm-switch-self-btn {
  background: rgba(0,180,216,0.08);
  border-color: rgba(0,180,216,0.30);
  color: #00B4D8;
}
[data-theme="dark"] .qblm-switch-self-btn:hover,
body.dark-theme .qblm-switch-self-btn:hover {
  background: rgba(0,180,216,0.16);
  border-color: rgba(0,180,216,0.60);
}

/* Someone else card */
#qbSomeoneElseBtn { border-color: rgba(255,107,53,0.3); }
#qbSomeoneElseBtn:hover {
  border-color: #FF6B35;
  box-shadow: 0 4px 20px rgba(255,107,53,0.18);
  transform: translateY(-1px);
}
#qbSomeoneElseBtn .qblm-card-icon-wrap {
  background: linear-gradient(135deg, #FF6B35, #c73b1a);
}

.qblm-card-icon-wrap {
  width: 60px;
  min-width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 12px;
  border-radius: 14px;
  position: relative;
}

/* GPS pulse rings inside icon */
#qbDetectAutoBtn .qblm-card-icon-wrap::before,
#qbDetectAutoBtn .qblm-card-icon-wrap::after {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 16px;
  border: 1.5px solid rgba(0,180,216,0.35);
  animation: qbGpsRingPulse 2s ease-out infinite;
}
#qbDetectAutoBtn .qblm-card-icon-wrap::after { animation-delay: 1s; }
@keyframes qbGpsRingPulse {
  0%   { opacity: 0.8; transform: scale(1); }
  100% { opacity: 0; transform: scale(1.4); }
}

.qblm-card-text {
  flex: 1;
  padding: 14px 12px 14px 4px;
}
.qblm-card-title {
  font-size: 14px;
  font-weight: 700;
  color: #111;
  margin: 0 0 3px;
  letter-spacing: -0.2px;
}
.qblm-card-desc {
  font-size: 12px;
  color: #888;
  margin: 0;
  line-height: 1.4;
}
.qblm-card-arrow {
  width: 26px; height: 26px;
  background: #f4f4f4;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #bbb;
  font-size: 15px;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: 14px;
  transition: all 0.2s;
}
.qb-location-method-btn:hover .qblm-card-arrow {
  background: #F4B400;
  color: #000;
}

/* ── Step 2: Detecting ── */
.qb-location-detecting {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14px;
  padding: 38px 20px;
  text-align: center;
}
.qblm-scan-ring {
  width: 70px; height: 70px;
  position: relative;
  display: flex; align-items: center; justify-content: center;
}
.qblm-scan-ring::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 3px solid transparent;
  border-top-color: #F4B400;
  border-right-color: rgba(244,180,0,0.35);
  animation: spin 0.85s linear infinite;
}
.qblm-scan-ring::after {
  content: '';
  position: absolute;
  inset: 9px;
  border-radius: 50%;
  border: 2px solid transparent;
  border-bottom-color: rgba(244,180,0,0.55);
  animation: spin 0.55s linear infinite reverse;
}
@keyframes spin { to { transform: rotate(360deg); } }
.qblm-scan-icon {
  font-size: 24px;
  animation: qbScanPulse 1.1s ease-in-out infinite;
}
@keyframes qbScanPulse {
  0%,100% { transform: scale(1); }
  50% { transform: scale(1.18); }
}
.qb-location-spinner { display: none; }
.qb-location-detecting-text {
  font-size: 15px;
  font-weight: 600;
  color: #222;
  margin: 0;
}
.qblm-detecting-sub {
  font-size: 12px;
  color: #aaa;
  margin: -8px 0 0;
}

/* ── Step 3: Form ── */
.qb-location-form {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.qb-location-form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.qb-location-form-label {
  font-size: 11px;
  font-weight: 700;
  color: #666;
  letter-spacing: 0.4px;
  text-transform: uppercase;
}
.qb-location-form-input {
  width: 100%;
  padding: 12px 14px;
  border: 2px solid #ebebeb;
  border-radius: 12px;
  font-size: 14px;
  color: #111;
  background: #fff;
  transition: all 0.2s;
  outline: none;
  box-sizing: border-box;
  font-family: inherit;
}
.qb-location-form-input:focus {
  border-color: #F4B400;
  box-shadow: 0 0 0 4px rgba(244,180,0,0.1);
}
.qb-location-form-input::placeholder { color: #ccc; }

.qb-location-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.qb-location-help-btn {
  font-size: 11px;
  font-weight: 700;
  color: #F4B400;
  background: rgba(244,180,0,0.1);
  border: none;
  border-radius: 6px;
  padding: 3px 9px;
  cursor: pointer;
  transition: all 0.2s;
}
.qb-location-help-btn:hover { background: rgba(244,180,0,0.2); }

.qb-detected-status {
  display: flex;
  align-items: center;
  gap: 12px;
  background: rgba(34,197,94,0.06);
  border: 2px solid rgba(34,197,94,0.22);
  border-radius: 12px;
  padding: 12px 14px;
  position: relative;
  overflow: hidden;
}
.qb-detected-pulse {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(34,197,94,0.06) 50%, transparent 100%);
  animation: qbPulseSlide 2.5s ease-in-out infinite;
  pointer-events: none;
}
@keyframes qbPulseSlide {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}
.qb-detected-text { flex: 1; min-width: 0; }
.qb-detected-title {
  font-size: 11px;
  font-weight: 800;
  color: #16a34a;
  letter-spacing: 0.4px;
  text-transform: uppercase;
}
.qb-detected-addr {
  font-size: 13px;
  color: #333;
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 500;
}
.qb-detected-check {
  flex-shrink: 0;
  width: 28px; height: 28px;
  background: #16a34a;
  color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  font-weight: 900;
  box-shadow: 0 2px 8px rgba(34,197,94,0.4);
}
.qb-location-form-input[readonly] {
  background: #f8f8f8 !important;
  color: #888 !important;
  cursor: not-allowed !important;
  user-select: none;
  pointer-events: none;
  border-color: #f0f0f0 !important;
}

.qb-location-delivery-info {
  background: linear-gradient(135deg, rgba(244,180,0,0.07), rgba(244,180,0,0.03));
  border: 1.5px solid rgba(244,180,0,0.28);
  border-radius: 12px;
  padding: 14px 16px;
}
.qb-location-delivery-title {
  font-size: 11px;
  font-weight: 800;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 3px;
}
.qb-location-delivery-time {
  font-size: 26px;
  font-weight: 900;
  color: #F4B400;
  margin: 0;
  letter-spacing: -0.5px;
  line-height: 1.1;
}
.qb-location-delivery-subtext {
  font-size: 12px;
  color: #aaa;
  margin: 3px 0 0;
}

/* ── Step 4: Success ── */
.qb-location-success {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 36px 20px;
  text-align: center;
}
.qb-location-success-icon {
  width: 66px; height: 66px;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 30px;
  font-weight: 900;
  box-shadow: 0 8px 28px rgba(34,197,94,0.4);
  animation: qbSuccessBounce 0.5s cubic-bezier(0.175,0.885,0.32,1.275) both;
}
@keyframes qbSuccessBounce {
  from { transform: scale(0); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}
.qb-location-success-title {
  font-size: 18px;
  font-weight: 800;
  color: #111;
  margin: 4px 0 0;
  letter-spacing: -0.3px;
}
.qb-location-success-text {
  font-size: 13px;
  color: #777;
  margin: 0;
  max-width: 260px;
  line-height: 1.5;
}

/* ── Footer ── */
.qb-location-footer {
  padding: 14px 20px 18px;
  border-top: 1px solid #f2f2f2;
  display: flex;
  flex-direction: column;
  gap: 8px;
  background: #fff;
}
.qb-location-btn {
  width: 100%;
  padding: 14px 20px;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  border: none;
  transition: all 0.2s cubic-bezier(0.4,0,0.2,1);
  letter-spacing: -0.2px;
  font-family: inherit;
}
.qb-location-btn:active { transform: scale(0.97); }
.qb-location-btn-primary {
  background: linear-gradient(135deg, #F4B400, #e0a500);
  color: #000;
  box-shadow: 0 4px 16px rgba(244,180,0,0.32);
}
.qb-location-btn-primary:hover {
  background: linear-gradient(135deg, #FFD000, #F4B400);
  box-shadow: 0 6px 22px rgba(244,180,0,0.42);
  transform: translateY(-1px);
}
.qb-location-btn-primary:disabled {
  background: #ebebeb !important;
  color: #bbb !important;
  box-shadow: none !important;
  transform: none !important;
  cursor: not-allowed;
}
.qb-location-btn-back {
  background: #f5f5f5;
  color: #666;
  font-size: 14px;
  font-weight: 600;
}
.qb-location-btn-back:hover {
  background: #eeeeee;
  color: #333;
}

/* ── Guide Overlay ── */
.qb-location-guide-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.72);
  backdrop-filter: blur(5px);
  z-index: 100000;
  align-items: center;
  justify-content: center;
  padding: 24px;
}
.qb-location-guide-overlay.active {
  display: flex;
  animation: qbBackdropIn 0.2s ease forwards;
}
.qb-location-guide-card {
  background: #fff;
  border-radius: 20px;
  max-width: 360px;
  width: 100%;
  padding: 24px;
  box-shadow: 0 24px 70px rgba(0,0,0,0.42);
}
.qb-location-guide-title {
  font-size: 16px;
  font-weight: 800;
  color: #111;
  margin: 0 0 8px;
}
.qb-location-guide-text {
  font-size: 13px;
  color: #666;
  line-height: 1.6;
  margin: 0 0 16px;
}
.qb-location-guide-image-wrap {
  border-radius: 12px;
  overflow: hidden;
  border: 1.5px solid #ebebeb;
  margin-bottom: 16px;
  background: #fafafa;
}
.qb-location-guide-image-wrap img { width: 100%; display: block; }
.qb-location-guide-actions { display: flex; gap: 10px; }
.qb-location-guide-link {
  flex: 1;
  padding: 11px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  color: #1a73e8;
  background: rgba(26,115,232,0.08);
  text-align: center;
  text-decoration: none;
  transition: all 0.2s;
}
.qb-location-guide-link:hover { background: rgba(26,115,232,0.14); }
.qb-location-guide-dismiss {
  flex: 1;
  padding: 11px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  background: #111;
  border: none;
  cursor: pointer;
  transition: all 0.2s;
  font-family: inherit;
}
.qb-location-guide-dismiss:hover { background: #333; }
.qb-location-guide-close { display: none; }

/* View on maps */
#qbViewOnMapsRow a {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 13px;
  font-weight: 600;
  color: #1a73e8;
  text-decoration: none;
  padding: 4px 0;
}

/* ══════════════════════════════════════
   DARK MODE
══════════════════════════════════════ */
[data-theme="dark"] .qb-location-modal,
body.dark-theme .qb-location-modal { background: #111 !important; }
[data-theme="dark"] .qb-location-body,
body.dark-theme .qb-location-body { background: #111 !important; }
[data-theme="dark"] .qblm-hero,
body.dark-theme .qblm-hero {
  background: linear-gradient(135deg, #080808 0%, #180728 55%, #040810 100%);
}
[data-theme="dark"] .qblm-close,
body.dark-theme .qblm-close { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.55); }
[data-theme="dark"] .qblm-close:hover,
body.dark-theme .qblm-close:hover { background: rgba(255,255,255,0.14); color: #fff; }
[data-theme="dark"] .qb-location-error,
body.dark-theme .qb-location-error {
  background: rgba(127,29,29,0.22);
  border-color: rgba(248,113,113,0.38);
  color: #fca5a5;
}
[data-theme="dark"] .qb-location-method-btn,
body.dark-theme .qb-location-method-btn { background: #1a1a1a; border-color: #252525; }
[data-theme="dark"] #qbDetectAutoBtn,
body.dark-theme #qbDetectAutoBtn { border-color: rgba(0,180,216,0.22); }
[data-theme="dark"] #qbDetectAutoBtn:hover,
