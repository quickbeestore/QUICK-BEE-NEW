{% comment %}
QuickBEE Location Detection Modal
Provides GPS auto-detection with delivery time estimation based on location
{% endcomment %}

<style>
  /* Modal Backdrop — acts as the centering flex container */
  .qb-location-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: 99999;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  .qb-location-backdrop.active {
    display: flex;
    animation: qbBackdropIn 0.22s ease forwards;
  }

  @keyframes qbBackdropIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Modal Container — child of backdrop flex container */
  .qb-location-modal {
    display: none;
    position: relative;
    background: white;
    border-radius: 16px;
    width: 92%;
    max-width: 420px;
    max-height: calc(100dvh - 40px);
    overflow-y: auto;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.35);
  }

  .qb-location-modal.active {
    display: flex;
    flex-direction: column;
    animation: qbModalIn 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes qbModalIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Button animations in location modal */
  .qb-location-btn {
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .qb-location-btn:active {
    transform: scale(0.96);
  }

  /* Backdrop fade in */
  .qb-location-backdrop.active {
    animation: qbBackdropFadeIn 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes qbBackdropFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Modal Header */
  .qb-location-header {
    padding: 24px;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .qb-location-title {
    font-size: 20px;
    font-weight: 700;
    color: #222;
    margin: 0;
  }

  .qb-location-close {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 24px;
    color: #999;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .qb-location-close:hover {
    color: #222;
    transform: scale(1.1);
  }

  /* Modal Body */
  .qb-location-body {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Step Indicator */
  .qb-location-step {
    display: none;
  }

  .qb-location-step.active {
    display: block;
    animation: fadeIn 0.2s ease-in-out;
  }

  /* Step 1: Choose Detection Method */
  .qb-location-methods {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .qb-location-method-btn {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border: 2px solid #e8e8e8;
    border-radius: 8px;
    background: white;
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
  }

  .qb-location-method-btn:hover {
    border-color: #7a14ac;
    background: rgba(122, 20, 172, 0.05);
  }

  .qb-location-method-btn:active {
    transform: scale(0.98);
  }

  .qb-location-method-icon {
    font-size: 32px;
    flex-shrink: 0;
  }

  .qb-location-method-text {
    flex: 1;
  }

  .qb-location-method-title {
    font-size: 16px;
    font-weight: 600;
    color: #222;
    margin: 0 0 4px;
  }

  .qb-location-method-desc {
    font-size: 13px;
    color: #666;
    margin: 0;
  }

  /* Step 2: Auto Detection */
  .qb-location-detecting {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 40px 20px;
    text-align: center;
  }

  .qb-location-spinner {
    width: 48px;
    height: 48px;
    border: 4px solid #f0f0f0;
    border-top-color: #7a14ac;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .qb-location-detecting-text {
    font-size: 14px;
    color: #666;
    margin: 0;
  }

  /* Step 3: Form */
  .qb-location-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .qb-location-form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .qb-location-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .qb-location-form-label {
    font-size: 13px;
    font-weight: 600;
    color: #222;
  }

  .qb-location-help-btn {
    border: none;
    background: rgba(122, 20, 172, 0.08);
    color: #7a14ac;
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.18s ease, background-color 0.18s ease;
  }

  .qb-location-help-btn:hover {
    background: rgba(122, 20, 172, 0.14);
    transform: translateY(-1px);
  }

  .qb-location-form-input {
    padding: 10px 12px;
    border: 1.5px solid #e0e0e0;
    border-radius: 6px;
    font-size: 14px;
    font-family: inherit;
    background: white;
    color: #222;
    transition: all 0.2s;
  }

  .qb-location-form-input:focus {
    outline: none;
    border-color: #7a14ac;
    box-shadow: 0 0 0 3px rgba(122, 20, 172, 0.1);
  }

  .qb-location-form-input::placeholder {
    color: #999;
  }

  .qb-location-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  /* Delivery Info */
  .qb-location-delivery-info {
    padding: 12px;
    background: #f8f9fa;
    border-radius: 8px;
    border-left: 4px solid #7a14ac;
  }

  .qb-location-delivery-title {
    font-size: 12px;
    font-weight: 600;
    color: #666;
    margin: 0 0 6px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .qb-location-delivery-time {
    font-size: 18px;
    font-weight: 700;
    color: #7a14ac;
    margin: 0;
  }

  .qb-location-delivery-subtext {
    font-size: 12px;
    color: #999;
    margin: 4px 0 0;
  }

  /* Error Message */
  .qb-location-error {
    padding: 12px;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    border-radius: 6px;
    color: #dc2626;
    font-size: 13px;
    display: none;
  }

  .qb-location-error.show {
    display: block;
  }

  /* Modal Footer */
  .qb-location-footer {
    padding: 12px 24px 16px;
    border-top: 1px solid #f0f0f0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .qb-location-btn {
    width: 100%;
    padding: 13px 16px;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  /* Go Back button — subtle ghost style */
  .qb-location-btn-back {
    background: transparent;
    color: #888;
    font-size: 13px;
    font-weight: 500;
    padding: 8px 16px;
  }

  .qb-location-btn-back:hover {
    color: #444;
    background: #f5f5f5;
    border-radius: 8px;
  }

  [data-theme="dark"] .qb-location-btn-back,
  body.dark-theme .qb-location-btn-back {
    color: #666;
  }

  [data-theme="dark"] .qb-location-btn-back:hover,
  body.dark-theme .qb-location-btn-back:hover {
    color: #aaa;
    background: #2a2a2a;
  }

  .qb-location-btn-cancel {
    background: #f5f5f5;
    color: #222;
  }

  .qb-location-btn-cancel:hover {
    background: #efefef;
  }

  .qb-location-btn-primary {
    background: #7a14ac;
    color: white;
  }

  .qb-location-btn-primary:hover {
    background: #5a0d8c;
  }

  .qb-location-btn-primary:disabled {
    background: #ddd;
    cursor: not-allowed;
  }

  /* Success State */
  .qb-location-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 40px 20px;
    text-align: center;
  }

  .qb-location-success-icon {
    font-size: 48px;
    animation: scaleIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes scaleIn {
    from { transform: scale(0); }
    to { transform: scale(1); }
  }

  .qb-location-success-title {
    font-size: 18px;
    font-weight: 700;
    color: #222;
    margin: 0;
  }

  .qb-location-success-text {
    font-size: 13px;
    color: #666;
    margin: 0;
  }

  .qb-location-guide-overlay {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(15, 23, 42, 0.72);
    backdrop-filter: blur(8px);
    z-index: 9999999;
    padding: 20px;
  }

  .qb-location-guide-overlay.active {
    display: flex;
  }

  .qb-location-guide-card {
    width: min(100%, 300px);
    background: #ffffff;
    border-radius: 20px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.18);
    padding: 16px;
    position: relative;
  }

  .qb-location-guide-close {
    display: none;
  }

  .qb-location-guide-title {
    font-size: 15px;
    font-weight: 800;
    color: #111827;
    margin: 0 0 4px;
    text-align: center;
  }

  .qb-location-guide-text {
    font-size: 12px;
    line-height: 1.4;
    color: #64748b;
    margin: 0 0 12px;
    text-align: center;
  }

  .qb-location-guide-image-wrap {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: #f8fafc;
    margin-bottom: 12px;
  }

  .qb-location-guide-image-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  .qb-location-guide-actions {
    display: grid;
    gap: 8px;
  }

  .qb-location-guide-link,
  .qb-location-guide-dismiss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    min-height: 42px;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
    border: none;
  }

  .qb-location-guide-link {
    background: #4285f4;
    color: #ffffff;
  }

  .qb-location-guide-dismiss {
    background: #eef2f7;
    color: #334155;
  }

  /* Dark Theme */
  [data-theme="dark"] .qb-location-backdrop,
  body.dark-theme .qb-location-backdrop {
    background: rgba(2, 6, 23, 0.72);
  }

  [data-theme="dark"] .qb-location-modal,
  body.dark-theme .qb-location-modal {
    background: #1a1a1a !important;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.6);
  }

  [data-theme="dark"] .qb-location-header,
  [data-theme="dark"] .qb-location-footer,
  body.dark-theme .qb-location-header,
  body.dark-theme .qb-location-footer {
    border-color: rgba(255, 255, 255, 0.08);
  }

  [data-theme="dark"] .qb-location-title,
  [data-theme="dark"] .qb-location-method-title,
  [data-theme="dark"] .qb-location-form-label,
  [data-theme="dark"] .qb-location-success-title,
  body.dark-theme .qb-location-title,
  body.dark-theme .qb-location-method-title,
  body.dark-theme .qb-location-form-label,
  body.dark-theme .qb-location-success-title {
    color: #f8fafc !important;
  }

  [data-theme="dark"] .qb-location-close,
  body.dark-theme .qb-location-close {
    color: #cbd5e1 !important;
  }

  [data-theme="dark"] .qb-location-close:hover,
  body.dark-theme .qb-location-close:hover {
    color: #ffffff !important;
  }

  [data-theme="dark"] .qb-location-method-btn,
  body.dark-theme .qb-location-method-btn {
    background: #242424 !important;
    border-color: rgba(255, 255, 255, 0.1) !important;
  }

  [data-theme="dark"] .qb-location-method-btn:hover,
  body.dark-theme .qb-location-method-btn:hover {
    background: rgba(122, 20, 172, 0.12) !important;
    border-color: #a855f7 !important;
  }

  [data-theme="dark"] .qb-location-method-desc,
  [data-theme="dark"] .qb-location-detecting-text,
  [data-theme="dark"] .qb-location-delivery-title,
  [data-theme="dark"] .qb-location-delivery-subtext,
  [data-theme="dark"] .qb-location-success-text,
  body.dark-theme .qb-location-method-desc,
  body.dark-theme .qb-location-detecting-text,
  body.dark-theme .qb-location-delivery-title,
  body.dark-theme .qb-location-delivery-subtext,
  body.dark-theme .qb-location-success-text {
    color: #94a3b8 !important;
  }

  [data-theme="dark"] .qb-location-spinner,
  body.dark-theme .qb-location-spinner {
    border-color: rgba(148, 163, 184, 0.2);
    border-top-color: #a855f7;
  }

  [data-theme="dark"] .qb-location-form-input,
  body.dark-theme .qb-location-form-input {
    background: #242424 !important;
    color: #f8fafc !important;
    border-color: rgba(255, 255, 255, 0.1) !important;
  }

  [data-theme="dark"] .qb-location-form-input::placeholder,
  body.dark-theme .qb-location-form-input::placeholder {
    color: #64748b !important;
  }

  [data-theme="dark"] .qb-location-form-input:focus,
  body.dark-theme .qb-location-form-input:focus {
    border-color: #a855f7 !important;
    box-shadow: 0 0 0 3px rgba(168, 85, 247, 0.16) !important;
  }

  .qb-location-form-input[readonly] {
    background: #f0f0f0 !important;
    color: #555 !important;
    cursor: not-allowed !important;
    user-select: none;
    pointer-events: none;
  }

  [data-theme="dark"] .qb-location-form-input[readonly],
  body.dark-theme .qb-location-form-input[readonly] {
    background: #1a1a1a !important;
    color: #94a3b8 !important;
    cursor: not-allowed !important;
    user-select: none;
    pointer-events: none;
  }

  [data-theme="dark"] .qb-location-help-btn,
  body.dark-theme .qb-location-help-btn {
    background: rgba(244, 180, 0, 0.14);
    color: #f5c84c;
  }

  [data-theme="dark"] .qb-location-delivery-info,
  body.dark-theme .qb-location-delivery-info {
    background: #242424 !important;
    border-left-color: #a855f7;
  }

  [data-theme="dark"] .qb-location-delivery-time,
  body.dark-theme .qb-location-delivery-time {
    color: #c084fc !important;
  }

  [data-theme="dark"] .qb-location-error,
  body.dark-theme .qb-location-error {
    background: rgba(127, 29, 29, 0.25);
    border-color: rgba(248, 113, 113, 0.45);
    color: #fecaca !important;
  }

  [data-theme="dark"] .qb-location-btn-cancel,
  body.dark-theme .qb-location-btn-cancel {
    background: #2a2a2a !important;
    color: #f8fafc !important;
  }

  [data-theme="dark"] .qb-location-btn-cancel:hover,
  body.dark-theme .qb-location-btn-cancel:hover {
    background: #333333 !important;
  }

  [data-theme="dark"] .qb-location-btn-primary,
  body.dark-theme .qb-location-btn-primary {
    background: #9333ea !important;
    color: #ffffff !important;
  }

  [data-theme="dark"] .qb-location-btn-primary:hover,
  body.dark-theme .qb-location-btn-primary:hover {
    background: #7e22ce !important;
  }

  [data-theme="dark"] .qb-location-btn-primary:disabled,
  body.dark-theme .qb-location-btn-primary:disabled {
    background: #374151 !important;
    color: #94a3b8 !important;
  }

  [data-theme="dark"] .qb-location-guide-overlay,
  body.dark-theme .qb-location-guide-overlay {
    background: rgba(2, 6, 23, 0.82);
  }

  [data-theme="dark"] .qb-location-guide-card,
  body.dark-theme .qb-location-guide-card {
    background: #0f172a;
    border-color: rgba(148, 163, 184, 0.16);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.55);
  }

  [data-theme="dark"] .qb-location-guide-close,
  [data-theme="dark"] .qb-location-guide-dismiss,
  body.dark-theme .qb-location-guide-close,
  body.dark-theme .qb-location-guide-dismiss {
    background: #1e293b;
    color: #e2e8f0;
  }

  [data-theme="dark"] .qb-location-guide-title,
  body.dark-theme .qb-location-guide-title {
    color: #f8fafc;
  }

  [data-theme="dark"] .qb-location-guide-text,
  body.dark-theme .qb-location-guide-text {
    color: #94a3b8;
  }

  [data-theme="dark"] .qb-location-guide-image-wrap,
  body.dark-theme .qb-location-guide-image-wrap {
    border-color: rgba(148, 163, 184, 0.16);
    background: #111827;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .qb-location-backdrop {
      align-items: center;
      padding: 16px;
    }
    .qb-location-modal {
      width: 100%;
      border-radius: 16px;
      max-height: calc(100dvh - 32px);
    }

    .qb-location-form-row {
      grid-template-columns: 1fr;
    }

    .qb-location-header {
      padding: 16px;
    }

    .qb-location-body {
      padding: 16px;
    }

    .qb-location-footer {
      padding: 12px 16px;
    }
  }
</style>

<!-- Location Modal -->
<div class="qb-location-backdrop" id="qbLocationBackdrop">
<div class="qb-location-modal" id="qbLocationModal">

  <!-- Header -->
  <div class="qb-location-header">
    <h2 class="qb-location-title">📍 Select Location</h2>
    <button class="qb-location-close" id="qbLocationClose" aria-label="Close">&times;</button>
  </div>

  <!-- Body -->
  <div class="qb-location-body">

    <!-- Error Message -->
    <div class="qb-location-error" id="qbLocationError"></div>

    <!-- Step 1: Choose Method -->
    <div class="qb-location-step active" id="qbLocationStep1">
      <div class="qb-location-methods">
        <button type="button" class="qb-location-method-btn" id="qbDetectAutoBtn">
          <div class="qb-location-method-icon">📡</div>
          <div class="qb-location-method-text">
            <h3 class="qb-location-method-title">Detect Automatically</h3>
            <p class="qb-location-method-desc">Ordering for myself</p>
          </div>
        </button>
        <button type="button" class="qb-location-method-btn" id="qbSomeoneElseBtn">
          <div class="qb-location-method-icon">🎁</div>
          <div class="qb-location-method-text">
            <h3 class="qb-location-method-title">Order for Someone Else</h3>
            <p class="qb-location-method-desc">Receiver name, phone, and Google Maps landmark</p>
          </div>
        </button>
      </div>
    </div>

    <!-- Step 2: Detecting GPS -->
    <div class="qb-location-step" id="qbLocationStep2">
      <div class="qb-location-detecting">
        <div class="qb-location-spinner"></div>
        <p class="qb-location-detecting-text">Finding your location...</p>
      </div>
    </div>

    <!-- Step 3: Address Form -->
    <div class="qb-location-step" id="qbLocationStep3">
      <form class="qb-location-form" id="qbLocationForm">
        <div class="qb-location-form-group" id="qbStreetGroup">
          <label class="qb-location-form-label">📍 Detected Address</label>
          <input
            type="text"
            class="qb-location-form-input"
            id="qbLocationStreet"
            placeholder="Detecting your location…"
            required
            readonly
          >
        </div>

        <div class="qb-location-form-group" id="qbSelfPhoneGroup" style="display: none;">
          <label class="qb-location-form-label">
            Your Contact Number
            <span style="font-weight:400; color:#999; font-size:11px;"> (optional)</span>
          </label>
          <input
            type="tel"
            class="qb-location-form-input"
            id="qbSelfPhone"
            placeholder="98XXXXXXXX"
            inputmode="tel"
          >
        </div>

        <div class="qb-location-form-group" id="qbReceiverNameGroup" style="display: none;">
          <label class="qb-location-form-label">Receiver's Name *</label>
          <input
            type="text"
            class="qb-location-form-input"
            id="qbReceiverName"
            placeholder="Enter receiver name"
          >
        </div>

        <div class="qb-location-form-group" id="qbReceiverPhoneGroup" style="display: none;">
          <label class="qb-location-form-label">Contact Number *</label>
          <input
            type="tel"
            class="qb-location-form-input"
            id="qbReceiverPhone"
            placeholder="98XXXXXXXX"
            inputmode="tel"
          >
        </div>

        <div class="qb-location-form-group" id="qbLandmarkGroup" style="display: none;">
          <div class="qb-location-label-row">
            <label class="qb-location-form-label" for="qbLandmarkLink">Google Maps Landmark Link *</label>
            <button type="button" class="qb-location-help-btn" id="qbLandmarkHelpBtn">Help</button>
          </div>
          <input
            type="url"
            class="qb-location-form-input"
            id="qbLandmarkLink"
            placeholder="Paste Google Maps link"
          >
        </div>

        <div class="qb-location-form-group" id="qbLatGroup">
          <label class="qb-location-form-label">Latitude</label>
          <input
            type="number"
            class="qb-location-form-input"
            id="qbLocationLat"
            placeholder="Latitude"
            step="0.0001"
            readonly
          >
        </div>

        <div class="qb-location-form-group" id="qbLngGroup">
          <label class="qb-location-form-label">Longitude</label>
          <input
            type="number"
            class="qb-location-form-input"
            id="qbLocationLng"
            placeholder="Longitude"
            step="0.0001"
            readonly
          >
        </div>

        <!-- View on Maps link -->
        <div id="qbViewOnMapsRow" style="display:none; margin-bottom:4px;">
          <a id="qbViewOnMapsLink" href="#" target="_blank" rel="noopener"
            style="display:inline-flex;align-items:center;gap:5px;font-size:13px;font-weight:600;color:#1a73e8;text-decoration:none;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            View on Maps
          </a>
        </div>

        <!-- Delivery Info -->
        <div class="qb-location-delivery-info" id="qbDeliveryInfo" style="display: none;">
          <div class="qb-location-delivery-title">Estimated Delivery</div>
          <p class="qb-location-delivery-time" id="qbDeliveryTime">—</p>
          <p class="qb-location-delivery-subtext">Get it faster with QuickBEE ⚡</p>
        </div>
      </form>
    </div>

    <!-- Step 4: Success -->
    <div class="qb-location-step" id="qbLocationStep4">
      <div class="qb-location-success">
        <div class="qb-location-success-icon">✓</div>
        <h3 class="qb-location-success-title">Location Selected</h3>
        <p class="qb-location-success-text" id="qbSuccessAddress">Redirecting...</p>
      </div>
    </div>

  </div>

  <!-- Footer -->
  <div class="qb-location-footer">
    <button type="button" class="qb-location-btn qb-location-btn-primary" id="qbLocationSelect">Select Location</button>
    <button type="button" class="qb-location-btn qb-location-btn-back" id="qbLocationCancel">← Go Back</button>
  </div>

</div>
</div>

<div class="qb-location-guide-overlay" id="qbLocationGuideOverlay">
  <div class="qb-location-guide-card">
    <h3 class="qb-location-guide-title">How to copy the Google Maps link</h3>
    <p class="qb-location-guide-text">Open Google Maps, choose the exact landmark, copy the share link, and paste it here.</p>
    <div class="qb-location-guide-image-wrap">
      <img src="{{ 'assets-share-google-maps-location.png' | asset_url }}" alt="How to copy Google Maps location link">
    </div>
    <div class="qb-location-guide-actions">
      <a href="https://www.google.com/maps" target="_blank" rel="noopener" class="qb-location-guide-link">Open Google Maps</a>
      <button type="button" class="qb-location-guide-dismiss" id="qbLocationGuideClose" aria-label="Close">Okay</button>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict';

  /* ═══════════════════════════════════════════
     STORAGE HELPERS
  ═══════════════════════════════════════════ */
  function loadFromStorage() {
    try {
      const raw = localStorage.getItem('qb_selected_location');
      if (!raw) return null;
      const p = JSON.parse(raw);
      if (!p || typeof p !== 'object') return null;
      // Already new format
      if (p.type) return p;
      // Migrate old format → new format
      if (p.mode) {
        return {
          type:     p.mode === 'someone_else' ? 'other' : 'self',
          location: p.mode === 'someone_else'
            ? (p.landmark_link || '')
            : (p.street || p.address || ''),
          name:  p.recipient_name  || '',
          phone: p.recipient_phone || '',
          // legacy fields kept for header widget
          mode: p.mode, address: p.address || p.street || '',
          street: p.street || '', recipient_name: p.recipient_name || '',
          recipient_phone: p.recipient_phone || '',
          landmark_link: p.landmark_link || '',
          latitude: p.latitude || '', longitude: p.longitude || ''
        };
      }
    } catch (_) {}
    return null;
  }

  function saveToLocalStorage(rawData) {
    const normalized = {
      type:     rawData.mode === 'someone_else' ? 'other' : 'self',
      location: rawData.mode === 'someone_else'
        ? (rawData.landmark_link || '')
        : (rawData.street || rawData.address || ''),
      name:  rawData.recipient_name  || '',
      phone: rawData.recipient_phone || rawData.phone || '',
      // Legacy fields — keeps header & cart page working
      mode:            rawData.mode,
      address:         rawData.address || rawData.street || rawData.landmark_link || '',
      street:          rawData.street || '',
      recipient_name:  rawData.recipient_name  || '',
      recipient_phone: rawData.recipient_phone || '',
      landmark_link:   rawData.landmark_link   || '',
      latitude:        rawData.latitude  || '',
      longitude:       rawData.longitude || '',
      timestamp: new Date().toISOString()
    };
    try {
      localStorage.setItem('qb_selected_location', JSON.stringify(normalized));
      window.QB_SELECTED_LOCATION = normalized;
    } catch (e) {
      console.error('[QB] saveToLocalStorage failed:', e);
    }
    return normalized;
  }

  /* ═══════════════════════════════════════════
     SHOPIFY INTEGRATION
  ═══════════════════════════════════════════ */

  // Send delivery info to Shopify admin via contact form (with CSRF token)
  function sendToShopify(data, attempt) {
    attempt = attempt || 0;

    // Build Google Maps link — use coordinates for self, landmark link for someone else
    var lat      = data.latitude  || '';
    var lng      = data.longitude || '';
    var mapsLink = data.landmark_link
      ? data.landmark_link
      : (lat && lng ? 'https://www.google.com/maps?q=' + lat + ',' + lng : 'N/A');

    var msgBody = [
      'New User Location:',
      'Type: '     + (data.type     || 'N/A'),
      'Location: ' + (data.location || 'N/A'),
      'Maps: '     + mapsLink,
      'Name: '     + (data.name     || 'N/A'),
      'Phone: '    + (data.phone    || 'N/A')
    ].join('\n');

    function doPost(token) {
      var payload = new URLSearchParams({
        form_type:           'contact',
        utf8:                '\u2713',
        authenticity_token:  token || '',
        'contact[email]':    'delivery@quickbee.app',
        'contact[name]':     'QuickBee Location Bot',
        'contact[body]':     msgBody
      });
      return fetch('/contact', {
        method:  'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body:    payload.toString(),
        redirect:'follow'
      }).then(function (resp) {
        if (!resp.ok && attempt < 1) {
          return new Promise(function (r) { setTimeout(function () { r(sendToShopify(data, 1)); }, 900); });
        }
        console.log('[QB] Location email sent ✅');
      });
    }

    // GET /contact first to grab a fresh CSRF token
    return fetch('/contact')
      .then(function (r) { return r.text(); })
      .then(function (html) {
        var m = html.match(/name="authenticity_token"[^>]*value="([^"]+)"/)
             || html.match(/value="([^"]+)"[^>]*name="authenticity_token"/);
        return doPost(m ? m[1] : '');
      })
      .catch(function (err) {
        console.warn('[QB] CSRF fetch failed, trying direct POST:', err);
        return doPost('').catch(function (e) {
          if (attempt < 1) {
            return new Promise(function (r) { setTimeout(function () { r(sendToShopify(data, 1)); }, 900); });
          }
          console.warn('[QB] sendToShopify failed after retry:', e);
        });
      });
  }

  // Attach delivery details as Shopify cart order note
  function updateCartNote(data) {
    const note = [
      'Delivery Details:',
      'Type: '     + (data.type     || 'N/A'),
      'Location: ' + (data.location || 'N/A'),
      'Name: '     + (data.name     || 'N/A'),
      'Phone: '    + (data.phone    || 'N/A')
    ].join('\n');

    return fetch('/cart/update.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ note: note })
    }).catch(function (err) {
      console.warn('[QB] updateCartNote failed:', err);
    });
  }

  /* ═══════════════════════════════════════════
     MODAL INIT
  ═══════════════════════════════════════════ */
  function initLocationModal() {

    // ── DOM refs ──
    const backdrop        = document.getElementById('qbLocationBackdrop');
    const modal           = document.getElementById('qbLocationModal');
    const closeBtn        = document.getElementById('qbLocationClose');
    const cancelBtn       = document.getElementById('qbLocationCancel');
    const selectBtn       = document.getElementById('qbLocationSelect');
    const detectAutoBtn   = document.getElementById('qbDetectAutoBtn');
    const someoneElseBtn  = document.getElementById('qbSomeoneElseBtn');
    const landmarkHelpBtn = document.getElementById('qbLandmarkHelpBtn');
    const guideOverlay    = document.getElementById('qbLocationGuideOverlay');
    const guideCloseBtn   = document.getElementById('qbLocationGuideClose');

    const steps = {
      method:    document.getElementById('qbLocationStep1'),
      detecting: document.getElementById('qbLocationStep2'),
      form:      document.getElementById('qbLocationStep3'),
      success:   document.getElementById('qbLocationStep4')
    };

    const formInputs = {
      street:       document.getElementById('qbLocationStreet'),
      selfPhone:    document.getElementById('qbSelfPhone'),
      receiverName: document.getElementById('qbReceiverName'),
      receiverPhone:document.getElementById('qbReceiverPhone'),
      landmarkLink: document.getElementById('qbLandmarkLink'),
      lat:          document.getElementById('qbLocationLat'),
      lng:          document.getElementById('qbLocationLng')
    };

    const formGroups = {
      street:       document.getElementById('qbStreetGroup'),
      selfPhone:    document.getElementById('qbSelfPhoneGroup'),
      receiverName: document.getElementById('qbReceiverNameGroup'),
      receiverPhone:document.getElementById('qbReceiverPhoneGroup'),
      landmarkLink: document.getElementById('qbLandmarkGroup'),
      lat:          document.getElementById('qbLatGroup'),
      lng:          document.getElementById('qbLngGroup')
    };

    const errorEl        = document.getElementById('qbLocationError');
    const deliveryInfoEl = document.getElementById('qbDeliveryInfo');
    const deliveryTimeEl = document.getElementById('qbDeliveryTime');
    const successAddrEl  = document.getElementById('qbSuccessAddress');

    let currentStep    = 'method';
    let detectionMode  = null;   // 'auto' | 'someone_else'
    let selectedCoords = null;
    let isForcedOpen   = false;

    /* ── Helpers ── */
    function isGoogleMapsLink(v) {
      const s = String(v || '').trim().toLowerCase();
      return /(^https?:\/\/)?(www\.)?(google\.[^\/]+\/maps|maps\.app\.goo\.gl|goo\.gl\/maps)/.test(s);
    }

    function showGroup(group, visible) {
      if (group) group.style.display = visible ? 'flex' : 'none';
    }

    function syncFormForMode() {
      const isSE = detectionMode === 'someone_else';
      showGroup(formGroups.street,        !isSE);
      showGroup(formGroups.selfPhone,     !isSE);  // optional — shown only in self mode
      showGroup(formGroups.lat,           !isSE);
      showGroup(formGroups.lng,           !isSE);
      showGroup(formGroups.receiverName,   isSE);
      showGroup(formGroups.receiverPhone,  isSE);
      showGroup(formGroups.landmarkLink,   isSE);
      if (isSE) {
        deliveryInfoEl.style.display = 'none';
        var mapsRow = document.getElementById('qbViewOnMapsRow');
        if (mapsRow) mapsRow.style.display = 'none';
      }
      formInputs.street.required        = !isSE;
      formInputs.selfPhone.required     = false;   // always optional
      formInputs.receiverName.required  =  isSE;
      formInputs.receiverPhone.required =  isSE;
      formInputs.landmarkLink.required  =  isSE;
    }

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.add('show');
      setTimeout(function () { errorEl.classList.remove('show'); }, 5000);
    }

    function updateViewOnMapsLink(lat, lng) {
      const row  = document.getElementById('qbViewOnMapsRow');
      const link = document.getElementById('qbViewOnMapsLink');
      if (row && link) {
        link.href = 'https://www.google.com/maps?q=' + lat + ',' + lng;
        row.style.display = 'block';
      }
    }

    /* ── Button / footer state ── */
    function updateButtonState() {
      const isSE = detectionMode === 'someone_else';
      const valid = isSE
        ? !!(formInputs.receiverName.value.trim() &&
             formInputs.receiverPhone.value.trim() &&
             isGoogleMapsLink(formInputs.landmarkLink.value))
        : !!formInputs.street.value.trim();

      selectBtn.disabled = currentStep === 'form' && !valid;

      // Go Back only shows on the form step — no "back" from method/detecting/success
      if (currentStep === 'method' || currentStep === 'detecting') {
        selectBtn.style.display = 'none';
        cancelBtn.style.display = 'none';
      } else if (currentStep === 'success') {
        selectBtn.style.display = 'none';
        cancelBtn.style.display = 'none';
      } else {
        // form step
        selectBtn.style.display = 'block';
        cancelBtn.style.display = 'block';
      }
    }

    /* ── Step navigation ── */
    function goToStep(stepName) {
      Object.values(steps).forEach(function (s) { s.classList.remove('active'); });
      steps[stepName].classList.add('active');
      currentStep = stepName;
      updateButtonState();
    }

    /* ── Modal open / close ── */
    function showModal(forced) {
      isForcedOpen = !!forced;
      modal.classList.add('active');
      backdrop.classList.add('active');
      document.body.style.overflow = 'hidden';
      // In forced mode: hide X and Cancel so user must complete
      closeBtn.style.display = isForcedOpen ? 'none' : '';
      updateButtonState();
    }

    function _doClose() {
      backdrop.classList.remove('active');
      modal.classList.remove('active');
      document.body.style.overflow = '';
      resetForm();
    }

    function hideModal() {
      if (isForcedOpen) return; // block — must pick a location
      _doClose();
    }

    function forceClose() {
      isForcedOpen = false;
      _doClose();
    }

    function showGuide() { if (guideOverlay) guideOverlay.classList.add('active'); }
    function hideGuide() { if (guideOverlay) guideOverlay.classList.remove('active'); }

    /* ── Delivery time estimation ── */
    function calcDeliveryTime(lat, lng) {
      const wLat = 27.7172, wLng = 85.3240;
      const toRad = function (x) { return x * Math.PI / 180; };
      const dLatR = toRad(lat - wLat);
      const dLonR = toRad(lng - wLng);
      const a = Math.sin(dLatR / 2) * Math.sin(dLatR / 2) +
                Math.cos(toRad(wLat)) * Math.cos(toRad(lat)) *
                Math.sin(dLonR / 2) * Math.sin(dLonR / 2);
      const km  = 6371 * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      const est = Math.min(Math.round(10 + km * 1.5), 60);
      const mn  = Math.max(est - 4, 5);
      const mx  = Math.min(est + 4, 60);
      return {
        minTime: mn, maxTime: mx,
        range: mn + '-' + mx + ' mins',
        distanceKm: km, estimatedMins: est,
        updatedAt: new Date().toISOString()
      };
    }

    function estimateDeliveryTime() {
      let data;
      if (formInputs.lat.value && formInputs.lng.value) {
        data = calcDeliveryTime(
          parseFloat(formInputs.lat.value),
          parseFloat(formInputs.lng.value)
        );
      } else {
        data = { minTime: 18, maxTime: 22, range: '18-22 mins', updatedAt: new Date().toISOString() };
      }
      window.QB_DELIVERY_TIME = data;
      try { localStorage.setItem('qb_delivery_time', JSON.stringify(data)); } catch (_) {}
      deliveryTimeEl.textContent       = data.range;
      deliveryInfoEl.style.display     = 'block';
      updateProductDeliveryBadges();
    }

    function updateProductDeliveryBadges() {
      const range = (window.QB_DELIVERY_TIME && window.QB_DELIVERY_TIME.range) || '18-22 mins';
      document.querySelectorAll(
        '.qb-delivery-badge, .qb-delivery-time-text, .qbp2-delivery-sync, .qb-delivery-sync'
      ).forEach(function (el) { el.textContent = range; });
    }

    /* ── Reverse geocode ── */
    function fallbackLabel(lat, lng) {
      return 'Detected near ' + lat.toFixed(5) + ', ' + lng.toFixed(5);
    }

    function buildStreetAddress(place) {
      const addr = (place && place.address) || {};
      const streetParts = [
        addr.house_number,
        addr.road || addr.pedestrian || addr.footway || addr.cycleway
      ].filter(Boolean);
      if (streetParts.length) return streetParts.join(' ');
      const localParts = [
        addr.neighbourhood, addr.suburb, addr.residential, addr.hamlet,
        addr.quarter, addr.city_district, addr.village, addr.town, addr.city
      ].filter(Boolean);
      if (localParts.length) return localParts.slice(0, 2).join(', ');
      if (place && place.display_name) {
        return place.display_name.split(',').slice(0, 2).join(', ').trim();
      }
      return '';
    }

    function reverseGeocode(lat, lng) {
      const fb = fallbackLabel(lat, lng);
      formInputs.street.value = fb;
      updateButtonState();

      fetch(
        'https://nominatim.openstreetmap.org/reverse?format=jsonv2' +
        '&lat=' + encodeURIComponent(lat) +
        '&lon=' + encodeURIComponent(lng) +
        '&addressdetails=1'
      )
        .then(function (r) { return r.json(); })
        .then(function (place) {
          formInputs.street.value = buildStreetAddress(place) || fb;
          syncFormForMode();
          updateButtonState();
          estimateDeliveryTime();
          goToStep('form');
        })
        .catch(function () {
          syncFormForMode();
          updateButtonState();
          estimateDeliveryTime();
          goToStep('form');
        });
    }

    /* ── GPS detection ── */
    function detectLocation() {
      goToStep('detecting');
      detectionMode = 'auto';
      syncFormForMode();

      if (!navigator.geolocation) {
        showError('Geolocation not supported by your browser');
        goToStep('method');
        return;
      }

      navigator.geolocation.getCurrentPosition(
        function (pos) {
          const lat = pos.coords.latitude;
          const lng = pos.coords.longitude;
          selectedCoords = { latitude: lat, longitude: lng };
          formInputs.lat.value = lat.toFixed(6);
          formInputs.lng.value = lng.toFixed(6);
          updateViewOnMapsLink(lat, lng);
          reverseGeocode(lat, lng);
        },
        function (err) {
          const msgs = {
            1: 'Location access denied. Please enable it in settings.',
            2: 'Location service unavailable.',
            3: 'Location request timed out.'
          };
          showError(msgs[err.code] || 'Unable to detect location');
          goToStep('method');
        },
        { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
      );
    }

    function orderForSomeoneElse() {
      detectionMode  = 'someone_else';
      selectedCoords = null;
      formInputs.street.value = '';
      formInputs.lat.value    = '';
      formInputs.lng.value    = '';
      syncFormForMode();
      goToStep('form');
    }

    /* ══════════════════════════════════════════
       handleSubmit — main action on "Select Location"
    ══════════════════════════════════════════ */
    function handleSubmit() {
      if (currentStep !== 'form') return;

      const isSE = detectionMode === 'someone_else';

      // ── Validation ──
      if (isSE) {
        if (!formInputs.receiverName.value.trim()) {
          showError("Please enter receiver's name"); return;
        }
        if (!formInputs.receiverPhone.value.trim()) {
          showError('Please enter contact number'); return;
        }
        if (!isGoogleMapsLink(formInputs.landmarkLink.value)) {
          showError('Only Google Maps links are accepted for landmark'); return;
        }
      } else {
        if (!formInputs.street.value.trim()) {
          showError('Please enter your street address'); return;
        }
      }

      // ── Loading state ──
      const origText = selectBtn.textContent;
      selectBtn.disabled    = true;
      selectBtn.textContent = '\u23F3 Saving...';

      // ── Build raw data object ──
      const rawData = isSE
        ? {
            mode:            'someone_else',
            recipient_name:  formInputs.receiverName.value.trim(),
            recipient_phone: formInputs.receiverPhone.value.trim(),
            landmark_link:   formInputs.landmarkLink.value.trim()
          }
        : {
            mode:      'auto',
            address:   formInputs.street.value.trim(),
            street:    formInputs.street.value.trim(),
            phone:     formInputs.selfPhone.value.trim(),
            latitude:  formInputs.lat.value,
            longitude: formInputs.lng.value
          };

      // ── saveToLocalStorage ──
      const normalized = saveToLocalStorage(rawData);

      // ── Persist delivery time for self-orders ──
      if (!isSE && formInputs.lat.value && formInputs.lng.value) {
        const dData = calcDeliveryTime(
          parseFloat(formInputs.lat.value),
          parseFloat(formInputs.lng.value)
        );
        window.QB_DELIVERY_TIME = dData;
        try { localStorage.setItem('qb_delivery_time', JSON.stringify(dData)); } catch (_) {}
      }

      // ── sendToShopify + updateCartNote (fire-and-forget, parallel) ──
      sendToShopify(normalized);
      updateCartNote(normalized);

      // ── Success UI ──
      successAddrEl.textContent = isSE
        ? (normalized.name + ' \u2022 ' + normalized.phone)
        : normalized.location;
      goToStep('success');

      // Restore button
      selectBtn.disabled    = false;
      selectBtn.textContent = origText;

      // Update delivery badges on page
      updateProductDeliveryBadges();

      // Dispatch event for header location widget
      window.dispatchEvent(new CustomEvent('locationSelected', { detail: normalized }));
      if (typeof window.QB_LOCATION_CALLBACK === 'function') {
        window.QB_LOCATION_CALLBACK(normalized);
      }

      // Auto-close after success animation completes
      setTimeout(forceClose, 1600);
    }

    /* ── Reset ── */
    function resetForm() {
      Object.values(formInputs).forEach(function (inp) { inp.value = ''; });
      deliveryInfoEl.style.display = 'none';
      errorEl.classList.remove('show');
      currentStep   = null;
      detectionMode = null;
      selectedCoords= null;
      syncFormForMode();
      goToStep('method');
    }

    /* ── Event listeners ── */
    closeBtn.addEventListener('click',   hideModal);
    cancelBtn.addEventListener('click',  function () { goToStep('method'); });
    backdrop.addEventListener('click',   function (e) {
      if (e.target === backdrop) hideModal();
    });
    modal.addEventListener('click', function (e) { e.stopPropagation(); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.classList.contains('active')) hideModal();
    });

    if (landmarkHelpBtn) landmarkHelpBtn.addEventListener('click', showGuide);
    if (guideCloseBtn)   guideCloseBtn.addEventListener('click',   hideGuide);
    if (guideOverlay) {
      guideOverlay.addEventListener('click', function (e) {
        if (e.target === guideOverlay) hideGuide();
      });
    }

    detectAutoBtn.addEventListener('click',  detectLocation);
    someoneElseBtn.addEventListener('click', orderForSomeoneElse);
    selectBtn.addEventListener('click',      handleSubmit);

    [formInputs.street, formInputs.selfPhone,
     formInputs.receiverName, formInputs.receiverPhone,
     formInputs.landmarkLink].forEach(function (inp) {
      inp.addEventListener('input', updateButtonState);
    });
    formInputs.lat.addEventListener('change', estimateDeliveryTime);
    formInputs.lng.addEventListener('change', estimateDeliveryTime);

    /* ══════════════════════════════════════════
       PAGE-LOAD LOGIC
       — Force modal if no location saved
       — Sync cart note silently on every visit
    ══════════════════════════════════════════ */
    function onPageLoad() {
      const saved = loadFromStorage();

      if (!saved) {
        // First-time visitor — force modal, block everything behind
        setTimeout(function () { showModal(true); }, 150);
      } else {
        // Returning visitor — restore delivery time badges
        try {
          const dt = JSON.parse(localStorage.getItem('qb_delivery_time') || 'null');
          if (dt) {
            window.QB_DELIVERY_TIME = dt;
            updateProductDeliveryBadges();
          }
        } catch (_) {}
        // Always keep cart note in sync with latest delivery info
        setTimeout(function () { updateCartNote(saved); }, 600);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', onPageLoad);
    } else {
      onPageLoad();
    }

    /* ── Public API ── */
    window.showLocationModal   = function () { showModal(false); };
    window.hideLocationModal   = hideModal;
    window.getSelectedLocation = function () { return window.QB_SELECTED_LOCATION; };
  }

  /* ── Boot ── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLocationModal);
  } else {
    initLocationModal();
  }

})();
</script>
