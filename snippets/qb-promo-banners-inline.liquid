  </div>
  <div class="qbpb-progress" id="qbpbProgress"></div>
</div>
<div class="qbpb-dots" id="qbpbDots"></div>

<script>
(function(){
  var track=document.getElementById('qbpbTrack');
  var dotsW=document.getElementById('qbpbDots');
  var prog =document.getElementById('qbpbProgress');
  if(!track)return;
  var slides=track.querySelectorAll('.qbpb-slide');
  var total=slides.length, cur=0, timer;
  slides.forEach(function(_,i){
    var d=document.createElement('div');
    d.className='qbpb-dot'+(i===0?' act':'');
    d.addEventListener('click',function(){goTo(i);reset();});
    dotsW.appendChild(d);
  });
  function goTo(i){
    cur=(i+total)%total;
    track.style.transform='translateX(-'+cur+'00%)';
    dotsW.querySelectorAll('.qbpb-dot').forEach(function(d,j){d.classList.toggle('act',j===cur);});
    if(prog){prog.classList.remove('running');prog.style.width='0';void prog.offsetWidth;prog.classList.add('running');}
  }
  function reset(){clearInterval(timer);timer=setInterval(function(){goTo(cur+1);},4200);}
  var sx=0;
  track.addEventListener('touchstart',function(e){sx=e.touches[0].clientX;},{passive:true});
  track.addEventListener('touchend',function(e){
    var dx=e.changedTouches[0].clientX-sx;
    if(Math.abs(dx)>40){dx<0?goTo(cur+1):goTo(cur-1);reset();}
  },{passive:true});
  goTo(0);reset();
})();
</script>
