{%- doc -%}
  This snippet renders a modern quantity selector used for products and cart items.
  @param {object} product - the product to render the quantity selector for
  @param {object} [variant] - the specific variant to use
  @param {number} [in_cart_quantity] - the quantity in the cart
  @param {number} [line_index] - the index if in a cart loop
  @param {string} [class] - custom class
  @param {number} [min] - minimum quantity override
{%- enddoc -%}

{% liquid
  assign variant = variant | default: product.selected_or_first_available_variant
  assign min_quantity = min | default: variant.quantity_rule.min | default: 1
  assign current_quantity = in_cart_quantity | default: variant.quantity_rule.min | default: 1
%}

<div class="product-form__quantity flex items-center {{ class }}" data-variant-id="{{ variant.id }}">
  <button type="button" class="quantity__button" name="minus" aria-label="Decrease quantity">-</button>
  
  <input 
    class="quantity__input" 
    type="number" 
    name="{% if line_index %}updates[]{% else %}quantity{% endif %}" 
    min="{{ min_quantity }}" 
    value="{{ current_quantity }}"
    {% if variant.quantity_rule.max %}max="{{ variant.quantity_rule.max }}"{% endif %}
    step="{{ variant.quantity_rule.increment | default: 1 }}"
    aria-label="Quantity"
    id="Quantity-{{ section.id }}-{{ product.id }}"
  >
  
  <button type="button" class="quantity__button" name="plus" aria-label="Increase quantity">+</button>
</div>

<script>
  (function() {
    function initQuantitySelectors() {
      document.querySelectorAll('.product-form__quantity:not([data-initialized])').forEach(function(container) {
        var input = container.querySelector('.quantity__input');
        var minusBtn = container.querySelector('button[name="minus"]');
        var plusBtn = container.querySelector('button[name="plus"]');
        
        if (!input || !minusBtn || !plusBtn) return;

        minusBtn.addEventListener('click', function() {
          var value = parseInt(input.value) || 0;
          var min = parseInt(input.min) || 1;
          var step = parseInt(input.step) || 1;
          if (value > min) {
            input.value = value - step;
            input.dispatchEvent(new Event('change', { bubbles: true }));
          }
        });

        plusBtn.addEventListener('click', function() {
          var value = parseInt(input.value) || 0;
          var max = parseInt(input.max) || Infinity;
          var step = parseInt(input.step) || 1;
          if (value < max) {
            input.value = value + step;
            input.dispatchEvent(new Event('change', { bubbles: true }));
          }
        });

        container.setAttribute('data-initialized', 'true');
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initQuantitySelectors);
    } else {
      initQuantitySelectors();
    }
    
    // Re-init on Shopify theme editor events
    document.addEventListener('shopify:section:load', initQuantitySelectors);
  })();
</script>
