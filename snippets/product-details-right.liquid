{% # Product Details - Right Column %}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
%}

<div class="product-right-column">
  <!-- Quick Product Info -->
  {% render 'quick-product-info', product: product %}

  <!-- Price + Delivery Banner -->
  {% render 'price-delivery-banner', product: product, variant: current_variant %}

  <!-- Variant Selector (if multi-variant) -->
  {% if product.variants.size > 1 %}
    {% render 'variant-selector', product: product %}
  {% endif %}

  <!-- Add to Cart Button -->
  {% render 'add-to-cart-button', product: product, variant: current_variant %}

  <!-- Collapsible Sections -->
  <div class="collapsible-sections">
    {% render 'collapsible-reviews', product: product %}
    {% render 'collapsible-product-details', product: product %}
  </div>
</div>
