{%- comment -%}
  QuickBee Promo Card Snippet
  Usage: {% render 'promo-card', card: block %}
{%- endcomment -%}

<div class="qb-promo-card">
  {% if card.settings.icon %}
    <div class="qb-promo-icon" aria-hidden="true">{{ card.settings.icon }}</div>
  {% endif %}

  {% if card.settings.title %}
    <h3 class="qb-promo-title">{{ card.settings.title }}</h3>
  {% endif %}

  {% if card.settings.description %}
    <p class="qb-promo-desc">{{ card.settings.description }}</p>
  {% endif %}

  {% if card.settings.cta_text and card.settings.cta_link %}
    <a href="{{ card.settings.cta_link }}" class="qb-cta-btn">
      {{ card.settings.cta_text }}
    </a>
  {% endif %}
</div>
