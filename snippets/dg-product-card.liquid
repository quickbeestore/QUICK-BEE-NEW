{%- comment -%}
  Dhido & Grills — Product Card v3
  Usage: {% render 'dg-product-card', product: product %}
{%- endcomment -%}

{%- liquid
  assign variant   = product.variants.first
  assign is_sale   = false
  assign disc_pct  = 0
  if product.compare_at_price > product.price
    assign is_sale  = true
    assign disc_sav = product.compare_at_price | minus: product.price
    assign disc_pct = disc_sav | times: 100 | divided_by: product.compare_at_price
  endif

  assign tags_lc  = product.tags | join: ',' | downcase
  assign is_pop   = false
  assign is_new   = false
  assign is_fresh = false
  if tags_lc contains 'popular' or tags_lc contains 'bestseller'
    assign is_pop = true
  endif
  if tags_lc contains 'new' or tags_lc contains 'new arrival'
    assign is_new = true
  endif
  if tags_lc contains 'fresh' or tags_lc contains 'daily'
    assign is_fresh = true
  endif

  assign title_lc = product.title | downcase
  assign food_ico = '🍽️'
  if title_lc contains 'dhido'
    assign food_ico = '🫙'
  elsif title_lc contains 'sekuwa' or title_lc contains 'grill' or title_lc contains 'bbq'
    assign food_ico = '🔥'
  elsif title_lc contains 'momo' or title_lc contains 'dumpling'
    assign food_ico = '🥟'
  elsif title_lc contains 'noodle' or title_lc contains 'chow' or title_lc contains 'thukpa'
    assign food_ico = '🍜'
  elsif title_lc contains 'burger'
    assign food_ico = '🍔'
  elsif title_lc contains 'chicken'
    assign food_ico = '🍗'
  elsif title_lc contains 'buff' or title_lc contains 'mutton'
    assign food_ico = '🥩'
  elsif title_lc contains 'lassi'
    assign food_ico = '🥛'
  elsif title_lc contains 'juice' or title_lc contains 'drink' or title_lc contains 'soda'
    assign food_ico = '🥤'
  elsif title_lc contains 'tea' or title_lc contains 'coffee'
    assign food_ico = '☕'
  elsif title_lc contains 'ice cream' or title_lc contains 'gelato'
    assign food_ico = '🍦'
  elsif title_lc contains 'fries' or title_lc contains 'chips'
    assign food_ico = '🍟'
  elsif title_lc contains 'dal' or title_lc contains 'bhat'
    assign food_ico = '🍚'
  endif
-%}

<div class="dg-card"
     data-v="{{ variant.id }}"
     data-n="{{ product.title | escape }}">

  <!-- Image -->
  <a href="{{ product.url }}" class="dg-card-img" tabindex="-1">
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 480 }}" alt="{{ product.title | escape }}" loading="lazy">
    {%- else -%}
      {{ food_ico }}
    {%- endif -%}
    {%- if is_sale -%}
      <div class="dg-card-off">{{ disc_pct }}% OFF</div>
    {%- endif -%}
    <div class="dg-card-badge">⚡ 18-22 mins</div>
    {%- unless product.available -%}
      <div style="position:absolute;inset:0;background:rgba(0,0,0,0.55);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:rgba(255,255,255,0.7);letter-spacing:1px;text-transform:uppercase;">Sold Out</div>
    {%- endunless -%}
  </a>

  <!-- Body -->
  <div class="dg-card-body">

    {%- if is_pop or is_new or is_fresh -%}
    <div class="dg-card-tags">
      {%- if is_pop   -%}<span class="dg-ctag dg-ctag-pop">🔥 Popular</span>{%- endif -%}
      {%- if is_new   -%}<span class="dg-ctag dg-ctag-new">✨ New</span>{%- endif -%}
      {%- if is_fresh -%}<span class="dg-ctag dg-ctag-fresh">🌿 Fresh</span>{%- endif -%}
    </div>
    {%- endif -%}

    <a href="{{ product.url }}" style="text-decoration:none">
      <div class="dg-card-name">{{ product.title }}</div>
    </a>

    {%- if product.description != blank -%}
      <div class="dg-card-desc">{{ product.description | strip_html | truncate: 55 }}</div>
    {%- endif -%}

    <div class="dg-card-footer">
      <div>
        <span class="dg-card-price">Rs {{ product.price | money_without_currency }}</span>
        {%- if is_sale -%}
          <span class="dg-card-old">Rs {{ product.compare_at_price | money_without_currency }}</span>
        {%- endif -%}
      </div>

      {%- if product.available -%}
        <button class="dg-add" aria-label="Add to cart">+</button>
        <div class="dg-stepper">
          <button class="dg-s-btn" data-a="minus" aria-label="Remove one">−</button>
          <span class="dg-s-val">1</span>
          <button class="dg-s-btn" data-a="plus" aria-label="Add one">+</button>
        </div>
      {%- else -%}
        <button class="dg-add" disabled>✕</button>
      {%- endif -%}
    </div>

  </div>
</div>
