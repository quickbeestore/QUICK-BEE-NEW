{% # Also Purchased Frequently Section %}

{% if product.related_products.size > 0 or product.variants.size > 1 %}
<div class="also-purchased-section">
  <h3 class="section-title">Also Purchased Frequently</h3>

  <div class="products-grid">
    {% for related_product in product.related_products limit: 4 %}
      <div class="product-card">
        <div class="product-card-image">
          {% if related_product.featured_image %}
            <img
              src="{{ related_product.featured_image | image_url: width: 250 }}"
              alt="{{ related_product.featured_image.alt }}"
              loading="lazy"
            >
          {% endif %}
        </div>

        <div class="product-card-content">
          <h4 class="product-card-title">{{ related_product.title }}</h4>

          <div class="product-card-price">
            <span class="price">Rs {{ related_product.price | divided_by: 100 | floor }}</span>
          </div>

          <a
            href="{{ related_product.url }}"
            class="product-card-link"
            aria-label="View {{ related_product.title }}"
          >
            View Details →
          </a>
        </div>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<style>
  .also-purchased-section {
    padding: 24px 16px;
    background: white;
    border-top: 2px solid #DAA520;
    margin-top: 24px;
  }

  .section-title {
    margin: 0 0 20px 0;
    font-size: 18px;
    font-weight: 700;
    color: #8B0000;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .product-card {
    background: white;
    border: 1px solid #DAA520;
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    box-shadow: 0 4px 12px rgba(139, 0, 0, 0.1);
    border-color: #8B0000;
  }

  .product-card-image {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-card-image img {
    transform: scale(1.05);
  }

  .product-card-content {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .product-card-title {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    color: #000;
    line-height: 1.3;
    min-height: 26px;
  }

  .product-card-price {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .price {
    font-size: 15px;
    font-weight: 700;
    color: #8B0000;
  }

  .product-card-link {
    font-size: 12px;
    font-weight: 600;
    color: #8B0000;
    text-decoration: none;
    padding: 8px 0;
    transition: color 0.2s;
    margin-top: auto;
  }

  .product-card-link:hover {
    color: #600000;
  }

  /* Small Mobile */
  @media (max-width: 480px) {
    .also-purchased-section {
      padding: 16px 12px;
      margin-top: 16px;
    }

    .section-title {
      font-size: 16px;
      margin-bottom: 12px;
    }

    .products-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .product-card-title {
      font-size: 12px;
    }

    .product-card-content {
      padding: 10px;
      gap: 6px;
    }

    .product-card-price {
      gap: 6px;
    }

    .price {
      font-size: 13px;
    }

    .product-card-link {
      font-size: 11px;
      padding: 6px 0;
    }
  }

  /* Tablet & Desktop */
  @media (min-width: 769px) {
    .also-purchased-section {
      padding: 24px;
    }

    .section-title {
      font-size: 20px;
      margin-bottom: 24px;
    }

    .products-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }

    .product-card-title {
      font-size: 14px;
    }

    .product-card-content {
      padding: 14px;
    }
  }

  @media (prefers-color-scheme: dark) {
    .also-purchased-section {
      background: #ffffff !important;
      color-scheme: light !important;
    }

    .section-title {
      color: #8B0000 !important;
      color-scheme: light !important;
    }

    .product-card {
      background: #ffffff !important;
      border-color: #DAA520 !important;
      color-scheme: light !important;
    }

    .product-card-title {
      color: #000 !important;
      color-scheme: light !important;
    }

    .product-card-image {
      background: #f5f5f5 !important;
      color-scheme: light !important;
    }
  }
</style>
