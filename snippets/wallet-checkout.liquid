{%- doc -%}
  Wallet Checkout Handler
  Auto-applies wallet discount and shows balance deduction at checkout
  Add this to cart/checkout pages
{%- enddoc -%}

{% if customer %}
  <script type="module">
    document.addEventListener('DOMContentLoaded', async () => {
      try {
        const customerId = `gid://shopify/Customer/{{ customer.id }}`;
        const email = "{{ customer.email | escape_javascript }}";

        // Fetch wallet balance
        const response = await fetch(
          `https://quick-pay-beta-production.up.railway.app/api/wallet/${encodeURIComponent(customerId)}`,
          { method: 'GET', headers: { 'Content-Type': 'application/json' } }
        );

        if (!response.ok) {
          console.warn('[Wallet Checkout] API error:', response.status);
          return;
        }

        const data = await response.json();
        if (!data.success || data.balance <= 0) {
          console.log('[Wallet Checkout] No balance available');
          return;
        }

        // Store wallet data
        sessionStorage.setItem('wallet-checkout-data', JSON.stringify({
          customerId,
          email,
          balance: data.balance,
          lastUpdated: data.lastUpdated,
        }));

        // Show wallet info on checkout page
        displayWalletCheckoutInfo(data.balance);
        console.log('[Wallet Checkout] Wallet available for checkout:', data.balance);
      } catch (error) {
        console.error('[Wallet Checkout] Failed:', error.message);
      }
    });

    function displayWalletCheckoutInfo(balance) {
      const formatted = new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        minimumFractionDigits: 0,
      }).format(balance);

      // Try to insert wallet info near order summary
      const orderSummary = document.querySelector('[data-testid="order-summary"]')
        || document.querySelector('.order-summary')
        || document.querySelector('[data-cart-summary]')
        || document.querySelector('.cart-summary');

      if (orderSummary) {
        const walletInfo = document.createElement('div');
        walletInfo.className = 'wallet-checkout-info';
        walletInfo.innerHTML = `
          <div style="padding: 12px 16px; background: #e8f5e9; border-radius: 4px; margin: 12px 0;">
            <div style="font-weight: 500; color: #2e7d32; margin-bottom: 4px;">
              💰 Wallet Available
            </div>
            <div style="font-size: 18px; color: #1b5e20; font-weight: bold;">
              ${formatted}
            </div>
            <div style="font-size: 12px; color: #558b2f; margin-top: 4px;">
              Available to use at checkout
            </div>
          </div>
        `;
        orderSummary.insertBefore(walletInfo, orderSummary.firstChild);
      }
    }
  </script>

  <style>
    .wallet-checkout-info {
      animation: slideIn 0.3s ease-out;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
{% endif %}
