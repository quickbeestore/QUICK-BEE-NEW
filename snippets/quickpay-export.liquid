{%- doc -%}
  QuickPay Export Section
  Allows customers to download transaction history in various formats
{%- enddoc -%}

<div class="quickpay-export-section">
  <h2>📥 Export & Reports</h2>

  <div class="export-options">
    <div class="export-card">
      <div class="export-icon">📊</div>
      <h3>CSV Export</h3>
      <p>Download all transactions as a spreadsheet</p>
      <button class="export-action-btn csv">
        Export as CSV
      </button>
    </div>

    <div class="export-card">
      <div class="export-icon">📄</div>
      <h3>PDF Report</h3>
      <p>Generate a detailed transaction report</p>
      <button class="export-action-btn pdf">
        Generate PDF
      </button>
    </div>

    <div class="export-card">
      <div class="export-icon">📧</div>
      <h3>Email Statement</h3>
      <p>Get monthly statement emailed to you</p>
      <button class="export-action-btn email">
        Send to Email
      </button>
    </div>
  </div>
</div>

<script type="module">
  import { exportTransactionsToCSV } from './quickpay-utils.js';

  document.querySelector('.export-action-btn.csv').addEventListener('click', async () => {
    try {
      const customerId = window.quickPayCustomer.id;
      const response = await fetch(
        `https://quick-pay-beta-production.up.railway.app/api/wallet/${encodeURIComponent(customerId)}/transactions?limit=1000`,
        {
          method: 'GET',
          headers: { 'Content-Type': 'application/json' },
        }
      );

      if (!response.ok) throw new Error('Failed to fetch transactions');

      const data = await response.json();
      if (data.transactions) {
        const filename = `quickpay-transactions-${new Date().toISOString().split('T')[0]}.csv`;
        exportTransactionsToCSV(data.transactions, filename);
      }
    } catch (error) {
      console.error('[QuickPay] CSV export failed:', error);
      alert('Failed to export CSV. Please try again.');
    }
  });

  document.querySelector('.export-action-btn.pdf').addEventListener('click', async () => {
    try {
      const customerId = window.quickPayCustomer.id;
      const response = await fetch(`/api/quickpay/generate-pdf`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customerId }),
      });

      if (!response.ok) throw new Error('Failed to generate PDF');

      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `quickpay-report-${new Date().toISOString().split('T')[0]}.pdf`;
      document.body.appendChild(a);
      a.click();
      window.URL.revokeObjectURL(url);
      document.body.removeChild(a);

      console.log('[QuickPay] PDF generated and downloaded');
    } catch (error) {
      console.error('[QuickPay] PDF generation failed:', error);
      alert('Failed to generate PDF. Please try again.');
    }
  });

  document.querySelector('.export-action-btn.email').addEventListener('click', async () => {
    try {
      const customerId = window.quickPayCustomer.id;
      const email = window.quickPayCustomer.email;

      const response = await fetch(`/api/quickpay/email-statement`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customerId, email }),
      });

      if (!response.ok) throw new Error('Failed to send email');

      alert('✅ Statement sent to your email!');
      console.log('[QuickPay] Email statement sent');
    } catch (error) {
      console.error('[QuickPay] Email send failed:', error);
      alert('Failed to send email. Please try again.');
    }
  });
</script>

{% stylesheet %}
  .quickpay-export-section {
    background: var(--color-background-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 24px;
    margin: 40px 0;
  }

  .quickpay-export-section h2 {
    margin: 0 0 24px 0;
    font-size: 20px;
    color: var(--color-foreground);
  }

  .export-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
  }

  .export-card {
    padding: 20px;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-align: center;
    transition: all 0.2s;
  }

  .export-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.1);
    transform: translateY(-2px);
  }

  .export-icon {
    font-size: 32px;
    margin-bottom: 12px;
  }

  .export-card h3 {
    margin: 0 0 8px 0;
    font-size: 16px;
    color: var(--color-foreground);
  }

  .export-card p {
    margin: 0 0 16px 0;
    font-size: 12px;
    color: var(--color-foreground-muted);
    line-height: 1.4;
  }

  .export-action-btn {
    padding: 10px 16px;
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .export-action-btn:hover {
    background: var(--color-primary-dark);
    transform: scale(1.05);
  }

  @media (max-width: 749px) {
    .export-options {
      grid-template-columns: 1fr;
    }

    .export-card {
      padding: 16px;
    }

    .export-icon {
      font-size: 28px;
    }
  }
{% endstylesheet %}
