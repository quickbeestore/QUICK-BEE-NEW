{% comment %}
QuickBEE Location Button - Clean, Simple, No JSON Display
{% endcomment %}

<style>
  .qb-location-btn-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: #f8f9fa;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    color: #222;
    transition: all 0.2s;
  }

  .qb-location-btn-header:hover {
    background: #f0f1f3;
    border-color: #7a14ac;
    color: #7a14ac;
  }

  .qb-location-icon {
    font-size: 18px;
  }

  .qb-location-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    max-width: 150px;
  }

  .qb-location-name {
    max-width: 150px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 600;
  }

  .qb-location-time {
    font-size: 11px;
    color: #666;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .qb-location-info {
      display: none;
    }
  }
</style>

<button class="qb-location-btn-header" id="qbLocationBtn" title="Change delivery location">
  <span class="qb-location-icon">📍</span>
  <div class="qb-location-info">
    <div class="qb-location-name">Select Location</div>
    <div class="qb-location-time">—</div>
  </div>
</button>

<script>
(function() {
  const btn = document.getElementById('qbLocationBtn');
  const nameEl = btn.querySelector('.qb-location-name');
  const timeEl = btn.querySelector('.qb-location-time');

  function updateDisplay() {
    // Get location
    const locStr = localStorage.getItem('qb_selected_location');
    if (locStr) {
      try {
        const loc = JSON.parse(locStr);
        nameEl.textContent = (loc.city || 'Select Location').substring(0, 20);
      } catch (e) {
        nameEl.textContent = 'Select Location';
      }
    } else {
      nameEl.textContent = 'Select Location';
    }

    // Get delivery time - ONLY THE RANGE VALUE
    const delStr = localStorage.getItem('qb_delivery_time');
    if (delStr) {
      try {
        const del = JSON.parse(delStr);
        // CRITICAL: Only set the range value, NEVER the entire object
        const rangeValue = del.range || '';
        // Clean it to remove any quotes or extra characters
        timeEl.textContent = String(rangeValue).replace(/"/g, '').trim();
      } catch (e) {
        timeEl.textContent = '—';
      }
    } else {
      timeEl.textContent = '—';
    }
  }

  // Click to open modal
  btn.addEventListener('click', e => {
    e.preventDefault();
    if (window.showLocationModal) window.showLocationModal();
  });

  // Update on location selected
  window.addEventListener('locationSelected', () => {
    setTimeout(updateDisplay, 50);
  });

  // Initial update
  updateDisplay();
})();
</script>
