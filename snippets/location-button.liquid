{% comment %}
QuickBEE Location Button - Triggers Location Detection Modal
Add this to your header for easy access to location selection
{% endcomment %}

<style>
  .qb-location-btn-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: #f8f9fa;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    color: #222;
    transition: all 0.2s;
    text-decoration: none;
  }

  .qb-location-btn-header:hover {
    background: #f0f1f3;
    border-color: #7a14ac;
    color: #7a14ac;
  }

  .qb-location-btn-header:active {
    transform: scale(0.95);
  }

  .qb-location-icon {
    font-size: 18px;
  }

  .qb-location-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    max-width: 140px;
  }

  .qb-location-name {
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 600;
    font-size: 13px;
  }

  .qb-location-time {
    font-size: 11px;
    color: #666;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .qb-location-btn-header {
      padding: 6px 10px;
      font-size: 12px;
    }

    .qb-location-info {
      display: none;
    }

    .qb-location-btn-header {
      width: 40px;
      height: 40px;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>

<button class="qb-location-btn-header" id="qbLocationHeaderBtn" title="Change delivery location">
  <span class="qb-location-icon">📍</span>
  <div class="qb-location-info">
    <div class="qb-location-name" id="qbLocationName">Select Location</div>
    <div class="qb-location-time" id="qbLocationTime"></div>
  </div>
</button>

<script>
(function() {
  const btn = document.getElementById('qbLocationHeaderBtn');
  const nameDisplay = document.getElementById('qbLocationName');
  const timeDisplay = document.getElementById('qbLocationTime');

  // Update button display with location and delivery time
  function updateLocationDisplay() {
    try {
      // Get saved location
      const savedLocationStr = localStorage.getItem('qb_selected_location');
      const savedDeliveryStr = localStorage.getItem('qb_delivery_time');

      // Update location name
      if (savedLocationStr) {
        try {
          const location = JSON.parse(savedLocationStr);
          if (location && location.city) {
            const cityName = location.city.substring(0, 20);
            nameDisplay.textContent = cityName;
          }
        } catch (e) {
          nameDisplay.textContent = 'Select Location';
        }
      } else {
        nameDisplay.textContent = 'Select Location';
      }

      // Update delivery time - extract ONLY the range value
      if (savedDeliveryStr) {
        try {
          const deliveryObj = JSON.parse(savedDeliveryStr);
          if (deliveryObj && deliveryObj.range) {
            // Only display the range value, nothing else
            timeDisplay.textContent = deliveryObj.range;
          } else {
            timeDisplay.textContent = '';
          }
        } catch (e) {
          // If parsing fails, clear the time display
          timeDisplay.textContent = '';
        }
      } else {
        timeDisplay.textContent = '';
      }
    } catch (e) {
      console.error('Error updating location display:', e);
      nameDisplay.textContent = 'Select Location';
      timeDisplay.textContent = '';
    }
  }

  // Click handler
  btn.addEventListener('click', (e) => {
    e.preventDefault();
    if (window.showLocationModal) {
      window.showLocationModal();
    }
  });

  // Listen for location changes
  window.addEventListener('locationSelected', () => {
    setTimeout(updateLocationDisplay, 100);
  });

  // Initial update
  updateLocationDisplay();

  // Periodic check to ensure display stays correct
  setInterval(updateLocationDisplay, 2000);
})();
</script>
