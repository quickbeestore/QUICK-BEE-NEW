{% # Collapsible Product Details Section %}

<div class="collapsible-section details-section">
  <button class="collapsible-header" aria-expanded="false">
    <span class="header-text">📋 Product Details</span>
    <span class="toggle-icon">▼</span>
  </button>

  <div class="collapsible-content details-content" style="display: none;">
    {% if product.description %}
      <div class="detail-group">
        <h3>Description</h3>
        <p>{{ product.description }}</p>
      </div>
    {% endif %}

    {% if product.metafields.custom.ingredients.value %}
      <div class="detail-group">
        <h3>Ingredients</h3>
        <p>{{ product.metafields.custom.ingredients.value }}</p>
      </div>
    {% endif %}

    {% if product.metafields.custom.origin.value %}
      <div class="detail-group">
        <h3>Origin</h3>
        <p>{{ product.metafields.custom.origin.value }}</p>
      </div>
    {% endif %}

    {% if product.metafields.custom.freshness_guarantee.value %}
      <div class="detail-group freshness-badge">
        <h3>✓ Freshness Guarantee</h3>
        <p>{{ product.metafields.custom.freshness_guarantee.value }}</p>
      </div>
    {% endif %}

    <div class="detail-group">
      <h3>Product Info</h3>
      <ul>
        <li><strong>SKU:</strong> {{ product.variants.first.barcode }}</li>
        <li><strong>Weight:</strong> {{ product.metafields.custom.weight.value | default: 'N/A' }}</li>
        <li><strong>Stock:</strong> {{ product.variants.first.inventory_quantity }} available</li>
      </ul>
    </div>
  </div>
</div>

<style>
  .details-content {
    padding: 16px;
    background: white;
    font-size: 14px;
    line-height: 1.6;
  }

  @media (prefers-color-scheme: dark) {
    .details-content {
      background: #1a1a1a;
    }
  }

  .detail-group {
    margin-bottom: 16px;
  }

  .detail-group:last-child {
    margin-bottom: 0;
  }

  .detail-group h3 {
    margin: 0 0 8px 0;
    font-size: 15px;
    font-weight: 600;
    color: #000;
  }

  @media (prefers-color-scheme: dark) {
    .detail-group h3 {
      color: #fff;
    }
  }

  .detail-group p,
  .detail-group ul {
    margin: 0;
    color: #333;
  }

  @media (prefers-color-scheme: dark) {
    .detail-group p,
    .detail-group ul {
      color: #ccc;
    }
  }

  .detail-group ul {
    padding-left: 16px;
  }

  .detail-group li {
    margin-bottom: 6px;
  }

  .freshness-badge {
    padding: 12px;
    background: #f0f9f0;
    border-left: 3px solid #22c55e;
    border-radius: 4px;
  }

  @media (prefers-color-scheme: dark) {
    .freshness-badge {
      background: #1b5e20;
      border-left-color: #81c784;
    }
  }

  .freshness-badge h3 {
    color: #15803d;
  }

  @media (prefers-color-scheme: dark) {
    .freshness-badge h3 {
      color: #81c784;
    }
  }

  .freshness-badge p {
    color: #166534;
  }

  @media (prefers-color-scheme: dark) {
    .freshness-badge p {
      color: #a5d6a7;
    }
  }
</style>
