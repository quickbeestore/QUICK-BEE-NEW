{% # Price + Status Badges Section %}

<div class="price-section">
  <span class="price-badge">Rs {{ variant.price | divided_by: 100 | floor }}</span>
</div>

<div class="status-badges">
  {% if section.settings.show_free_delivery_countdown %}
    <div class="status-badge countdown-badge" aria-label="Free delivery countdown">
      🎁 Free delivery
    </div>
  {% endif %}

  <div class="status-badge riders-badge" aria-label="Riders availability">
    ✓ <span id="riders-count">Riders active</span>
  </div>
</div>

<style>
  .price-section {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 16px;
    padding: 16px;
    background: white;
    border-radius: 8px;
    border: 2px solid #DAA520;
  }

  .price-badge {
    background: linear-gradient(135deg, #8B0000, #C41E3A);
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 28px;
    font-weight: 700;
    min-width: fit-content;
    box-shadow: 0 4px 12px rgba(139, 0, 0, 0.2);
    letter-spacing: -0.5px;
  }

  .status-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    padding: 16px;
    background: white;
    border-radius: 8px;
    border: 1px solid #DAA520;
    margin-top: 12px;
  }

  .status-badge {
    padding: 10px 16px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 0 1 auto;
  }

  .riders-badge {
    background: #fff8e1;
    color: #8B0000;
    border: 1px solid #DAA520;
  }

  .countdown-badge {
    background: #fff8e1;
    color: #8B0000;
    border: 1px solid #DAA520;
  }

  @media (prefers-color-scheme: dark) {
    .status-badges {
      border-color: #333;
    }

    .riders-badge {
      background: #1b5e20;
      color: #81c784;
    }

    .countdown-badge {
      background: #e65100;
      color: #ffb74d;
    }
  }
</style>
