{% # Add to Cart Button (Sticky) %}

<div class="add-to-cart-wrapper" id="add-to-cart-wrapper">
  <button
    class="add-to-cart-button"
    id="add-to-cart-button"
    data-product-id="{{ product.id }}"
    aria-label="Add product to cart"
  >
    <span class="button-text">Add to Cart</span>
    <span class="loading-spinner" style="display: none;">
      <span class="spinner"></span> Adding...
    </span>
  </button>

  {% if product.variants.size > 1 %}
    <div class="quantity-limit-info">
      {% if section.settings.max_quantity %}
        Max {{ section.settings.max_quantity }} per order
      {% endif %}
    </div>
  {% endif %}
</div>

<!-- Quantity Selector Modal -->
{% render 'quantity-selector-modal', product: product %}

<style>
  .add-to-cart-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
    background: white;
    border-top: 1px solid #f0f0f0;
    margin-top: 12px;
    position: relative;
    width: 100%;
  }

  .add-to-cart-button {
    width: 100%;
    padding: 14px 20px;
    background: #8B0000;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .add-to-cart-button:hover:not(:disabled) {
    background: #600000;
  }

  .add-to-cart-button:active:not(:disabled) {
    transform: scale(0.98);
  }

  .add-to-cart-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .loading-spinner {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top: 2px solid white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .quantity-limit-info {
    text-align: center;
    font-size: 12px;
    color: #666;
  }

  /* Mobile: fixed at bottom */
  @media (max-width: 768px) {
    .add-to-cart-wrapper {
      position: fixed;
      bottom: max(12px, env(safe-area-inset-bottom));
      left: 12px;
      right: 12px;
      z-index: 99;
      margin: 0;
      padding: 12px;
      border-radius: 8px;
      box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
    }

    .add-to-cart-button {
      padding: 12px 16px;
      font-size: 14px;
    }
    }

    /* ── DARK MODE OVERRIDES ── */
    [data-theme="dark"] .add-to-cart-wrapper {
    background-color: #121212 !important;
    border-top-color: #2A2A2A !important;
    box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.4) !important;
    }

    [data-theme="dark"] .add-to-cart-button {
    background: #C2185B !important;
    color: #FFFFFF !important;
    }

    [data-theme="dark"] .quantity-limit-info {
    color: #9CA3AF !important;
    }
    </style>
  /* Desktop: integrated into layout */
  @media (min-width: 769px) {
    .add-to-cart-wrapper {
      position: relative;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const button = document.getElementById('add-to-cart-button');
    const spinner = button.querySelector('.loading-spinner');
    const buttonText = button.querySelector('.button-text');

    button.addEventListener('click', function(e) {
      e.preventDefault();

      // Show modal instead of directly adding (will be handled by modal)
      const modal = document.getElementById('quantity-selector-modal');
      modal.classList.add('active');
    });
  });
</script>
