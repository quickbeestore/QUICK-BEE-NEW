      "type": "custom-liquid",
      "settings": {
        "liquid": "<div style=\"background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 60px 20px; color: white; text-align: center;\"><h2 style=\"font-size: 32px; margin-bottom: 40px; margin-top: 0; font-weight: 700;\">Our Repair Guarantee</h2><div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px; max-width: 1000px; margin: 0 auto;\"><div><h3 style=\"font-size: 18px; margin-bottom: 12px; margin-top: 0; font-weight: 700;\">✓ Quality Parts</h3><p style=\"margin: 0; opacity: 0.9;\">Only genuine and high-quality parts used in all repairs. No knock-offs or counterfeit components</p></div><div><h3 style=\"font-size: 18px; margin-bottom: 12px; margin-top: 0; font-weight: 700;\">✓ 6-Month Warranty</h3><p style=\"margin: 0; opacity: 0.9;\">All repairs include 6-month parts warranty. Free re-repair if same issue occurs</p></div><div><h3 style=\"font-size: 18px; margin-bottom: 12px; margin-top: 0; font-weight: 700;\">✓ Certified Technicians</h3><p style=\"margin: 0; opacity: 0.9;\">All technicians are certified and trained in handling various appliances and electronics</p></div><div><h3 style=\"font-size: 18px; margin-bottom: 12px; margin-top: 0; font-weight: 700;\">✓ Transparent Pricing</h3><p style=\"margin: 0; opacity: 0.9;\">Get a free diagnosis and estimate. No hidden charges or surprise costs</p></div><div><h3 style=\"font-size: 18px; margin-bottom: 12px; margin-top: 0; font-weight: 700;\">✓ Fast Turnaround</h3><p style=\"margin: 0; opacity: 0.9;\">Most repairs completed within 24-48 hours. Express service available</p></div><div><h3 style=\"font-size: 18px; margin-bottom: 12px; margin-top: 0; font-weight: 700;\">✓ Home Service</h3><p style=\"margin: 0; opacity: 0.9;\">On-site repairs available. We come to you and fix items at your home or office</p></div></div></div>"
      }
    },
