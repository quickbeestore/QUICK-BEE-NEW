<script>
(function(){
  /* ── REPLACE THIS after deploying to Render.com ── */
  var API='https://quickbee-print-api.onrender.com/generate';
  /* ────────────────────────────────────────────── */
  var files=[];

  /* scroll reveal */
  var ob=new IntersectionObserver(function(e){
    e.forEach(function(x){if(x.isIntersecting){x.target.classList.add('vis');ob.unobserve(x.target);}});
  },{threshold:.12});
  document.querySelectorAll('.rv').forEach(function(el){ob.observe(el);});

  window.openModal=function(t){
    var titles={magazine:'Create Your Love Magazine',prints:'Order Photo Prints',card:'Design a Custom Card'};
    document.getElementById('pt').value=t;
    document.getElementById('mt').textContent=titles[t]||'Place Your Order';
    show('sf');
    document.getElementById('emsg').style.display='none';
    document.getElementById('overlay').classList.add('open');
    document.body.style.overflow='hidden';
  };
  window.closeModal=function(){
    document.getElementById('overlay').classList.remove('open');
    document.body.style.overflow='';
  };

  function show(id){
    ['sf','ld','sc'].forEach(function(s){
      var s_el=document.getElementById(s);
      if(s_el)s_el.className='st'+(s===id?' on':'');
    });
  }

  document.getElementById('pi').addEventListener('change',function(e){
    files=Array.from(e.target.files).slice(0,10);render();
  });
  var uz=document.getElementById('uz');
  uz.addEventListener('dragover',function(e){e.preventDefault();uz.classList.add('drag');});
  uz.addEventListener('dragleave',function(){uz.classList.remove('drag');});
  uz.addEventListener('drop',function(e){
    e.preventDefault();uz.classList.remove('drag');
    files=Array.from(e.dataTransfer.files).filter(function(f){return f.type.startsWith('image/');}).slice(0,10);
    render();
  });
  function render(){
    var c=document.getElementById('th');c.innerHTML='';
    files.forEach(function(f,i){
      var img=document.createElement('img');
      img.src=URL.createObjectURL(f);img.className='thumb';img.alt='Photo '+(i+1);c.appendChild(img);
    });
    if(files.length){var d=document.createElement('div');d.className='tcnt';d.textContent=files.length+'/10';c.appendChild(d);}
  }

  var msgs=['Placing your photos on the canvas\u2026','Crafting chapter layouts\u2026','Writing your love story\u2026','Adding finishing touches\u2026','Almost there \u2014 polishing every page\u2026'];

  document.getElementById('of').addEventListener('submit',function(e){
    e.preventDefault();
    var er=document.getElementById('emsg');er.style.display='none';
    if(files.length<2){er.textContent='Please upload at least 2 photos to create your magazine.';er.style.display='block';return;}
    var fd=new FormData(this);
    files.forEach(function(f){fd.append('images',f);});
    show('ld');
    var mi=0,t=setInterval(function(){
      mi=(mi+1)%msgs.length;
      var el=document.getElementById('lm');if(el)el.textContent=msgs[mi];
    },5000);
    fetch(API,{method:'POST',body:fd})
      .then(function(r){
        clearInterval(t);
        if(!r.ok)return r.json().then(function(j){throw new Error(j.error||'Generation failed. Please try again.');});
        return r.blob();
      })
      .then(function(blob){
        var url=URL.createObjectURL(blob);
        var a=document.createElement('a');
        a.href=url;
        a.download=((fd.get('name1')||'Our')+'_'+(fd.get('name2')||'Story')+'_Magazine.pdf').replace(/\s+/g,'_');
        document.body.appendChild(a);a.click();document.body.removeChild(a);
        document.getElementById('dl').href=url;
        show('sc');
      })
      .catch(function(ex){
        clearInterval(t);show('sf');
        var e2=document.getElementById('emsg');e2.textContent=ex.message;e2.style.display='block';
      });
  });
})();
</script>
</body>
</html>
