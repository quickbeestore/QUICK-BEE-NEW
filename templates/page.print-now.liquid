{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Print Now — QuickBee Premium Printing</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ── PRESETS & VARIABLES ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --black:#0A0A0A; --deep:#141414; --wine:#2D0C1F;
  --rose:#B76E79; --gold:#C9A84C; --gold-lt:#E8D5A0;
  --cream:#F5EDD6; --white:#FFFFFF;
  --gray:rgba(255,255,255,0.6); --border:rgba(201,168,76,0.2);
  --r:16px;
  --serif:'Cormorant Garamond',Georgia,serif;
  --sans:'Montserrat','Helvetica Neue',sans-serif;
  --glass:rgba(255,255,255,0.03);
}
html{scroll-behavior:smooth}
body{background:var(--black);color:var(--white);font-family:var(--sans);overflow-x:hidden;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--black)}::-webkit-scrollbar-thumb{background:var(--gold);border-radius:2px}

/* ── LAYOUT ── */
.container{max-width:1100px;margin:0 auto;padding:0 24px}
section{padding:120px 0}

/* ── HERO ── */
#hero{position:relative;min-height:90vh;display:flex;align-items:center;justify-content:center;overflow:hidden;
  background:radial-gradient(ellipse at 50% 100%, #3D0C1F 0%, var(--black) 70%)}
.orb{position:absolute;border-radius:50%;filter:blur(100px);pointer-events:none;opacity:0.4}
.o1{width:600px;height:600px;background:var(--wine);top:-10%;left:-10%}
.o2{width:500px;height:500px;background:var(--gold);bottom:0;right:-5%}
.hero-in{position:relative;z-index:2;text-align:center;max-width:850px;animation:fIn 1.4s ease-out}
@keyframes fIn{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.eyebrow{font-size:11px;font-weight:700;letter-spacing:5px;text-transform:uppercase;color:var(--gold);margin-bottom:24px;display:block}
h1.ht{font-family:var(--serif);font-size:clamp(64px,12vw,110px);font-weight:300;line-height:0.9;margin-bottom:20px}
h1.ht em{font-style:italic;background:linear-gradient(135deg, var(--gold-lt), var(--rose));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hsub{font-size:16px;font-weight:300;line-height:1.8;color:var(--gray);max-width:500px;margin:0 auto 48px}
.hbtn{display:inline-flex;align-items:center;gap:12px;background:var(--gold);color:var(--black);padding:18px 44px;border-radius:60px;
  font-size:12px;font-weight:800;letter-spacing:3px;text-transform:uppercase;text-decoration:none;transition:0.3s}
.hbtn:hover{transform:translateY(-3px);box-shadow:0 15px 40px rgba(201,168,76,0.3)}

/* ── PRODUCTS GRID ── */
.sec-head{text-align:center;margin-bottom:80px}
.sec-head h2{font-family:var(--serif);font-size:clamp(40px,6vw,64px);font-weight:300}
.sec-head p{color:var(--gold);font-size:10px;letter-spacing:4px;text-transform:uppercase;margin-bottom:12px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:32px}
.card{background:var(--glass);border:1px solid var(--border);border-radius:var(--r);padding:48px 40px;position:relative;overflow:hidden;transition:0.4s;cursor:pointer}
.card:hover{border-color:var(--gold);background:rgba(201,168,76,0.05);transform:translateY(-10px)}
.card i{font-size:40px;margin-bottom:32px;display:block}
.card h3{font-size:14px;font-weight:800;letter-spacing:3px;text-transform:uppercase;margin-bottom:12px}
.card p{font-size:14px;color:var(--gray);line-height:1.7;margin-bottom:32px}
.price{font-family:var(--serif);font-size:32px;margin-bottom:32px;display:block}
.card .btn{width:100%;padding:16px;border-radius:8px;border:1px solid var(--gold);color:var(--gold);background:transparent;
  font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:0.3s}
.card:hover .btn{background:var(--gold);color:var(--black)}

/* ── OPTIONS OVERLAY ── */
#overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.9);backdrop-filter:blur(10px);z-index:1000;padding:40px 20px;overflow-y:auto}
#overlay.active{display:flex;justify-content:center}
.modal{background:var(--deep);width:100%;max-width:800px;border-radius:24px;border:1px solid var(--border);position:relative;padding:60px;margin:auto}
.m-close{position:absolute;top:30px;right:30px;background:none;border:none;color:var(--white);font-size:24px;cursor:pointer}
.m-head{margin-bottom:48px}
.m-head h2{font-family:var(--serif);font-size:48px;font-weight:300;margin-bottom:8px}
.m-head p{color:var(--gray);font-size:14px}

/* ── FORM ── */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.field{margin-bottom:24px}
.field.full{grid-column:span 2}
label{display:block;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;font-weight:700}
input,select,textarea{width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);padding:16px;border-radius:8px;color:white;font-family:inherit;font-size:14px;outline:none;transition:0.3s}
input:focus,select:focus{border-color:var(--gold);background:rgba(255,255,255,0.08)}

/* ── IMAGE UPLOAD GRID ── */
.upload-zone{background:rgba(201,168,76,0.03);border:2px dashed var(--border);border-radius:16px;padding:40px;text-align:center;cursor:pointer;margin-bottom:32px}
.upload-zone:hover{border-color:var(--gold)}
.thumbs-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-top:20px}
.thumb-slot{aspect-ratio:1;background:rgba(255,255,255,0.05);border-radius:8px;overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center;font-size:10px;color:rgba(255,255,255,0.2)}
.thumb-slot img{width:100%;height:100%;object-fit:cover}

/* ── STEPPER ── */
.steps-nav{display:flex;gap:20px;margin-bottom:40px;border-bottom:1px solid rgba(255,255,255,0.05);padding-bottom:10px}
.step-item{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--gray);cursor:pointer;opacity:0.5}
.step-item.active{color:var(--gold);opacity:1;font-weight:700}

/* ── SUBMIT ── */
.submit-btn{width:100%;padding:20px;background:var(--gold);border:none;border-radius:12px;color:var(--black);font-size:12px;font-weight:900;letter-spacing:4px;text-transform:uppercase;cursor:pointer;margin-top:20px}
.submit-btn:disabled{opacity:0.3;cursor:not-allowed}

/* ── LOADING ── */
#loader{display:none;text-align:center;padding:60px 0}
.spinner{width:50px;height:50px;border:3px solid rgba(201,168,76,0.1);border-top-color:var(--gold);border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 24px}
@keyframes spin{to{transform:rotate(360deg)}}

@media(max-width:768px){
  .form-grid{grid-template-columns:1fr}
  .field.full{grid-column:span 1}
  .modal{padding:40px 24px}
  .thumbs-grid{grid-template-columns:repeat(4,1fr)}
}
</style>
</head>
<body>

<section id="hero">
  <div class="orb o1"></div>
  <div class="orb o2"></div>
  <div class="container">
    <div class="hero-in">
      <span class="eyebrow">QuickBee Premium Printing</span>
      <h1 class="ht">Your Stories, <em>Properly</em> Printed.</h1>
      <p class="hsub">Upload your memories. We handle the design, high-end editorial layouts, and premium production.</p>
      <a href="#products" class="hbtn">View Collections</a>
    </div>
  </div>
</section>

<section id="products">
  <div class="container">
    <div class="sec-head">
      <p>The Collection</p>
      <h2>Choose Your Canvas</h2>
    </div>
    <div class="grid">
      <!-- Magazine -->
      <div class="card" onclick="openModal('magazine')">
        <i>📖</i>
        <h3>Premium Magazine</h3>
        <p>A 24-page editorial masterpiece. Perfect for love stories, weddings, or travel logs.</p>
        <span class="price">Rs 1,999</span>
        <button class="btn">Customize Now</button>
      </div>
      <!-- Prints -->
      <div class="card" onclick="openModal('prints')">
        <i>🖼️</i>
        <h3>Gallery Prints</h3>
        <p>Set of 12 professional photo prints on 300gsm silk cardstock.</p>
        <span class="price">Rs 599</span>
        <button class="btn">Select Photos</button>
      </div>
      <!-- Cards -->
      <div class="card" onclick="openModal('cards')">
        <i>💌</i>
        <h3>Bespoke Cards</h3>
        <p>Hand-designed greeting cards with your photo and a custom layout.</p>
        <span class="price">Rs 299</span>
        <button class="btn">Design Card</button>
      </div>
    </div>
  </div>
</section>

<div id="overlay" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <button class="m-close" onclick="closeModal()">✕</button>
    
    <div id="form-container">
      <div class="m-head">
        <h2 id="modal-title">Customize Your Order</h2>
        <p id="modal-desc">Fill in the details below to start your design.</p>
      </div>

      <div class="steps-nav">
        <span class="step-item active" id="s1" onclick="setStep(1)">1. Details</span>
        <span class="step-item" id="s2" onclick="setStep(2)">2. Style</span>
        <span class="step-item" id="s3" onclick="setStep(3)">3. Photos</span>
      </div>

      <form id="print-form">
        <input type="hidden" name="product" id="prod-type">
        
        <!-- Step 1: Details -->
        <div class="form-step" id="step1">
          <div class="form-grid">
            <div class="field"><label>Person 1 Name</label><input type="text" name="name1" placeholder="e.g. Salina" required></div>
            <div class="field"><label>Person 2 Name</label><input type="text" name="name2" placeholder="e.g. Arjun" required></div>
            <div class="field full"><label>Main Title</label><input type="text" name="title" placeholder="e.g. Forever Ours / Our 2026 Journey"></div>
            <div class="field"><label>Phone / WhatsApp</label><input type="tel" name="phone" placeholder="98XXXXXXXX" required></div>
            <div class="field"><label>Delivery Address</label><input type="text" name="address" placeholder="Kathmandu, Nepal" required></div>
          </div>
          <button type="button" class="submit-btn" onclick="setStep(2)">Next: Style Options</button>
        </div>

        <!-- Step 2: Options -->
        <div class="form-step" id="step2" style="display:none">
          <div class="form-grid">
            <div class="field">
              <label>Magazine Type</label>
              <select name="tone" id="mag-tone">
                <option value="romantic">Love Story (Romantic)</option>
                <option value="elegant">Wedding (Elegant)</option>
                <option value="bold">Travel (Adventurous)</option>
                <option value="warm">Family (Warm)</option>
              </select>
            </div>
            <div class="field">
              <label>Paper Quality</label>
              <select name="paper">
                <option value="standard">Gloss Art Paper (170gsm)</option>
                <option value="premium">Matte Silk Premium (200gsm) [+Rs 300]</option>
              </select>
            </div>
            <div class="field full">
                <label>Add a Special Quote</label>
                <textarea name="quote" rows="2" placeholder="A short poem or memory..."></textarea>
            </div>
          </div>
          <button type="button" class="submit-btn" onclick="setStep(3)">Next: Upload Photos</button>
        </div>

        <!-- Step 3: Photos -->
        <div class="form-step" id="step3" style="display:none">
          <div class="upload-zone" id="drop-zone">
            <input type="file" id="file-input" multiple accept="image/*" style="display:none">
            <i>📸</i>
            <p><strong>Click to upload</strong> or drag photos here</p>
            <small>Upload exactly 10 photos for the best layout</small>
          </div>
          <div class="thumbs-grid" id="thumbs">
            <div class="thumb-slot">1</div><div class="thumb-slot">2</div><div class="thumb-slot">3</div><div class="thumb-slot">4</div><div class="thumb-slot">5</div>
            <div class="thumb-slot">6</div><div class="thumb-slot">7</div><div class="thumb-slot">8</div><div class="thumb-slot">9</div><div class="thumb-slot">10</div>
          </div>
          <button type="submit" id="submit-btn" class="submit-btn" disabled>Generate My Print Now</button>
        </div>
      </form>
    </div>

    <div id="loader">
      <div class="spinner"></div>
      <h3>Designing Your Masterpiece</h3>
      <p id="load-msg">Analyzing your photos and crafting layouts...</p>
    </div>

    <div id="success" style="display:none; text-align:center">
      <i style="font-size:60px">✨</i>
      <h2 style="font-family:var(--serif); margin:20px 0">It's Ready!</h2>
      <p style="color:var(--gray); margin-bottom:30px">Your digital proof is downloading. We'll contact you on WhatsApp for delivery.</p>
      <button class="hbtn" onclick="location.reload()">Create Another</button>
    </div>
  </div>
</div>

<script>
const API = 'https://quickbee-print-api.onrender.com/generate';
let files = [];

function openModal(type) {
  document.getElementById('prod-type').value = type;
  document.getElementById('overlay').classList.add('active');
  document.body.style.overflow = 'hidden';
  setStep(1);
}

function closeModal() {
  document.getElementById('overlay').classList.remove('active');
  document.body.style.overflow = '';
}

function setStep(n) {
  document.querySelectorAll('.form-step').forEach(s => s.style.display = 'none');
  document.querySelectorAll('.step-item').forEach(s => s.classList.remove('active'));
  document.getElementById('step' + n).style.display = 'block';
  document.getElementById('s' + n).classList.add('active');
}

const dropZone = document.getElementById('drop-zone');
const fileInput = document.getElementById('file-input');

dropZone.onclick = () => fileInput.click();
fileInput.onchange = e => handleFiles(e.target.files);

function handleFiles(newFiles) {
  files = [...files, ...Array.from(newFiles)].slice(0, 10);
  renderThumbs();
  document.getElementById('submit-btn').disabled = files.length < 2;
}

function renderThumbs() {
  const slots = document.querySelectorAll('.thumb-slot');
  slots.forEach((slot, i) => {
    slot.innerHTML = (i + 1);
    if (files[i]) {
      const img = document.createElement('img');
      img.src = URL.createObjectURL(files[i]);
      slot.innerHTML = '';
      slot.appendChild(img);
    }
  });
}

const msgs = [
  "Curating your photo spreads...",
  "Applying premium typography...",
  "Balancing editorial white space...",
  "Finalizing high-res print output..."
];

document.getElementById('print-form').onsubmit = async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  files.forEach(f => fd.append('images', f));

  document.getElementById('form-container').style.display = 'none';
  document.getElementById('loader').style.display = 'block';

  let mIdx = 0;
  const interval = setInterval(() => {
    document.getElementById('load-msg').innerText = msgs[mIdx % msgs.length];
    mIdx++;
  }, 4000);

  try {
    const res = await fetch(API, { method: 'POST', body: fd });
    if (!res.ok) throw new Error('Generation failed');
    
    const blob = await res.blob();
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'QuickBee_Print_Now_Order.pdf';
    a.click();

    clearInterval(interval);
    document.getElementById('loader').style.display = 'none';
    document.getElementById('success').style.display = 'block';
  } catch (err) {
    alert(err.message);
    document.getElementById('form-container').style.display = 'block';
    document.getElementById('loader').style.display = 'none';
    clearInterval(interval);
  }
};
</script>

</body>
</html>
