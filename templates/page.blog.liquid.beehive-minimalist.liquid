{% style %}
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  background: #ffffff;
  color: #1a1a1a;
  line-height: 1.6;
}

.blog-wrapper {
  min-height: 100vh;
  background: linear-gradient(135deg, #ffffff 0%, #f4f4f4 100%);
}

/* Header Section */
.blog-header {
  background: linear-gradient(135deg, #ffffff 0%, #fafaf8 100%);
  border-bottom: 3px solid #d4a500;
  padding: 50px 20px;
  text-align: center;
}

.blog-header h1 {
  font-size: 3em;
  color: #1a1a1a;
  margin-bottom: 10px;
  font-weight: 700;
  letter-spacing: -1px;
}

.blog-header p {
  font-size: 1.2em;
  color: #666;
  font-weight: 300;
}

/* Sticky Navigation */
.blog-nav {
  background: #ffffff;
  border-bottom: 1px solid #f0f0f0;
  padding: 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.nav-container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  overflow-x: auto;
  scroll-behavior: smooth;
}

.nav-container::-webkit-scrollbar {
  height: 4px;
}

.nav-container::-webkit-scrollbar-track {
  background: #f5f5f5;
}

.nav-container::-webkit-scrollbar-thumb {
  background: #d4a500;
  border-radius: 2px;
}

.nav-item {
  padding: 16px 24px;
  cursor: pointer;
  color: #666;
  font-weight: 500;
  font-size: 0.95em;
  border: none;
  background: none;
  white-space: nowrap;
  transition: all 0.3s ease;
  position: relative;
}

.nav-item:hover {
  color: #d4a500;
  background: #f9f9f9;
}

.nav-item.active {
  color: #d4a500;
}

.nav-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: #d4a500;
}

/* Welcome Section */
.welcome-section {
  max-width: 1000px;
  margin: 60px auto;
  padding: 40px;
  background: #ffffff;
  border-radius: 12px;
  text-align: center;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
}

.welcome-section h2 {
  font-size: 2em;
  color: #1a1a1a;
  margin-bottom: 20px;
  font-weight: 600;
}

.welcome-section p {
  font-size: 1.05em;
  color: #555;
  line-height: 1.8;
}

/* Content Container */
.blog-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 40px 20px;
}

/* Category Section */
.category-section {
  display: none;
  animation: fadeIn 0.5s ease-in;
}

.category-section.active {
  display: block;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.category-header {
  margin-bottom: 50px;
}

.category-header h2 {
  font-size: 2.2em;
  color: #1a1a1a;
  margin-bottom: 15px;
  font-weight: 700;
}

.category-header p {
  font-size: 1.05em;
  color: #666;
  line-height: 1.7;
}

/* Articles Grid */
.articles-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  margin: 40px 0;
}

.article-card {
  background: #ffffff;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  border-top: 4px solid #d4a500;
  display: flex;
  flex-direction: column;
}

.article-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 8px 24px rgba(212, 165, 0, 0.15);
}

.article-card-content {
  padding: 28px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.article-card h3 {
  font-size: 1.35em;
  color: #1a1a1a;
  margin-bottom: 12px;
  margin-top: 0;
  font-weight: 600;
  line-height: 1.4;
}

.article-meta {
  font-size: 0.85em;
  color: #999;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.article-card p {
  color: #555;
  margin-bottom: 20px;
  flex: 1;
  line-height: 1.7;
  font-size: 0.95em;
}

.article-link {
  display: inline-block;
  color: #d4a500;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.95em;
  transition: all 0.2s ease;
  margin-top: auto;
}

.article-link:hover {
  color: #1a1a1a;
  text-decoration: underline;
}

.article-link::after {
  content: ' →';
  margin-left: 6px;
  transition: margin-left 0.2s ease;
}

.article-link:hover::after {
  margin-left: 12px;
}

/* CTA Section */
.cta-section {
  background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
  color: #ffffff;
  padding: 60px 40px;
  border-radius: 12px;
  text-align: center;
  margin: 60px 0 40px;
  position: relative;
  overflow: hidden;
}

.cta-section::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200px;
  height: 200px;
  background: rgba(212, 165, 0, 0.1);
  border-radius: 50%;
  transform: translate(50%, -50%);
}

.cta-content {
  position: relative;
  z-index: 1;
}

.cta-section h3 {
  font-size: 2em;
  margin-bottom: 15px;
  font-weight: 700;
}

.cta-section p {
  font-size: 1.1em;
  margin-bottom: 25px;
  opacity: 0.95;
}

.cta-button {
  display: inline-block;
  background: #d4a500;
  color: #1a1a1a;
  padding: 14px 40px;
  border-radius: 6px;
  text-decoration: none;
  font-weight: 700;
  font-size: 1em;
  transition: all 0.3s ease;
  border: 2px solid #d4a500;
}

.cta-button:hover {
  background: #1a1a1a;
  color: #d4a500;
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(212, 165, 0, 0.3);
}

/* Footer */
.footer-section {
  border-top: 1px solid #e8e8e8;
  padding: 40px 20px;
  text-align: center;
  color: #999;
  font-size: 0.95em;
}

.footer-section p {
  margin: 0;
}

/* Responsive Design */
@media (max-width: 768px) {
  .blog-header h1 {
    font-size: 2em;
  }

  .blog-header p {
    font-size: 1em;
  }

  .welcome-section {
    padding: 25px;
    margin: 30px 20px;
  }

  .welcome-section h2 {
    font-size: 1.5em;
  }

  .articles-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .cta-section {
    padding: 40px 20px;
    margin: 40px 0 30px;
  }

  .cta-section h3 {
    font-size: 1.5em;
  }

  .category-header h2 {
    font-size: 1.6em;
  }

  .nav-item {
    padding: 14px 16px;
    font-size: 0.9em;
  }
}

@media (max-width: 480px) {
  .blog-header {
    padding: 30px 15px;
  }

  .blog-header h1 {
    font-size: 1.5em;
  }

  .article-card-content {
    padding: 20px;
  }

  .article-card h3 {
    font-size: 1.15em;
  }

  .nav-item {
    padding: 12px 12px;
  }
}
{% endstyle %}

