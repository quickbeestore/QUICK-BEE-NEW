{% style %}
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8f9fa;
    color: #333;
  }

  .blog-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 60px 20px;
    text-align: center;
  }

  .blog-header h1 {
    font-size: 2.5em;
    margin-bottom: 15px;
    font-weight: 700;
  }

  .blog-header p {
    font-size: 1.2em;
    opacity: 0.95;
  }

  .blog-nav {
    background: white;
    padding: 0;
    border-bottom: 2px solid #e0e0e0;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
  }

  .blog-nav button {
    background: none;
    border: none;
    color: #667eea;
    font-weight: 600;
    font-size: 0.95em;
    padding: 15px 20px;
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: all 0.3s ease;
  }

  .blog-nav button:hover {
    background-color: #f0f0f0;
  }

  .blog-nav button.active {
    color: #764ba2;
    border-bottom-color: #764ba2;
  }

  .blog-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  .section-title {
    font-size: 2em;
    color: #333;
    margin-bottom: 30px;
    font-weight: 700;
    border-bottom: 3px solid #667eea;
    padding-bottom: 10px;
    display: inline-block;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    margin: 40px 0 60px 0;
  }

  .category-card {
    background: white;
    padding: 30px;
    border-radius: 8px;
    border-left: 5px solid #667eea;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .category-card h3 {
    color: #667eea;
    margin-bottom: 12px;
    margin-top: 0;
    font-size: 1.5em;
  }

  .category-card p {
    color: #666;
    margin-bottom: 20px;
    line-height: 1.6;
    font-size: 0.95em;
  }

  .category-card button {
    color: white;
    background-color: #667eea;
    border: none;
    font-weight: 600;
    padding: 12px 20px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .category-card button:hover {
    background-color: #764ba2;
  }

  .category-content {
    display: none;
  }

  .category-content.active {
    display: block;
  }

  .content-header {
    background: #f8f9fa;
    padding: 40px 20px;
    border-radius: 8px;
    margin-bottom: 40px;
  }

  .content-header h2 {
    color: #667eea;
    font-size: 2em;
    margin-bottom: 10px;
  }

  .content-header p {
    color: #666;
    font-size: 1.1em;
    line-height: 1.6;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    margin: 40px 0;
  }

  .article-card {
    background: white;
    padding: 25px;
    border-radius: 8px;
    border-left: 5px solid #667eea;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .article-card h4 {
    color: #333;
    margin-top: 0;
    margin-bottom: 10px;
  }

  .article-card p {
    color: #666;
    margin-bottom: 0;
    font-size: 0.9em;
    line-height: 1.5;
  }

  .cta-section {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 60px 40px;
    border-radius: 12px;
    text-align: center;
    margin: 60px 0;
  }

  .cta-section h3 {
    margin-top: 0;
    margin-bottom: 15px;
    font-size: 1.8em;
  }

  .cta-section p {
    font-size: 1.1em;
    margin-bottom: 25px;
  }

  .cta-section a {
    color: white;
    text-decoration: none;
    font-weight: 700;
    padding: 15px 40px;
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    display: inline-block;
    border: 2px solid white;
  }

  .cta-section a:hover {
    background-color: white;
    color: #667eea;
  }

  .blog-footer {
    margin-top: 60px;
    padding-top: 30px;
    border-top: 2px solid #e0e0e0;
    text-align: center;
    color: #999;
    font-size: 0.9em;
  }

  @media (max-width: 768px) {
    .blog-header h1 {
      font-size: 2em;
    }
    .blog-nav button {
      padding: 12px 10px;
      font-size: 0.8em;
    }
    .blog-container {
      padding: 30px 15px;
    }
    .category-grid {
      grid-template-columns: 1fr;
    }
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

