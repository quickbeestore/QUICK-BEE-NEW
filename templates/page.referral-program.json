      "settings": {
        "liquid": "<div style=\"background: white; border: 1px solid #e5e5e5; border-radius: 12px; padding: 40px 20px; margin: 40px 0;\">\n  <h2 style=\"text-align: center; font-size: 24px; color: #222; margin-bottom: 40px;\">How It Works</h2>\n  <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px; max-width: 1200px; margin: 0 auto;\">\n    <div style=\"text-align: center;\">\n      <div style=\"font-size: 48px; font-weight: 700; color: #2563eb; margin-bottom: 12px;\">1</div>\n      <div style=\"font-size: 16px; font-weight: 700; color: #222; margin-bottom: 8px;\">Share Your Link</div>\n      <p style=\"font-size: 13px; color: #666; margin: 0;\">Copy your unique referral link and share it with friends via email, social media, or chat</p>\n    </div>\n    <div style=\"text-align: center;\">\n      <div style=\"font-size: 48px; font-weight: 700; color: #2563eb; margin-bottom: 12px;\">2</div>\n      <div style=\"font-size: 16px; font-weight: 700; color: #222; margin-bottom: 8px;\">They Sign Up & Shop</div>\n      <p style=\"font-size: 13px; color: #666; margin: 0;\">Your friend creates an account using your link and places their first order</p>\n    </div>\n    <div style=\"text-align: center;\">\n      <div style=\"font-size: 48px; font-weight: 700; color: #2563eb; margin-bottom: 12px;\">3</div>\n      <div style=\"font-size: 16px; font-weight: 700; color: #222; margin-bottom: 8px;\">You Both Earn</div>\n      <p style=\"font-size: 13px; color: #666; margin: 0;\">You get Rs 500 credit + they get Rs 300 discount on their first purchase</p>\n    </div>\n  </div>\n</div>"
      }
    },
