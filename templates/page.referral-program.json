      },
      "blocks": {
        "block_1": {
          "type": "faq-item",
          "settings": {
            "question": "Is the referral program free?",
            "answer": "Yes, 100% free! There are no fees, no commitments, and no limits to how many friends you can refer. You just share your link and earn rewards."
          }
        },
        "block_2": {
          "type": "faq-item",
          "settings": {
            "question": "How long does it take to get my reward?",
            "answer": "Credits are typically added within 24 hours after your friend completes their first purchase. You can use them immediately on your next order or save them for later."
          }
        },
        "block_3": {
          "type": "faq-item",
          "settings": {
            "question": "Can I withdraw my earned credits as cash?",
            "answer": "Credits can be used for purchases on QuickBee or converted to QuickPay wallet balance for other uses. We don't currently offer direct cash withdrawals, but you can use credits for anything you buy."
          }
        },
        "block_4": {
          "type": "faq-item",
          "settings": {
            "question": "What if my friend doesn't make a purchase?",
            "answer": "The referral bonus only activates when your friend completes a purchase using your referral link within 30 days of signing up. No purchase = no reward."
          }
        },
        "block_5": {
          "type": "faq-item",
          "settings": {
            "question": "Are there any limits to referrals?",
            "answer": "No limits! You can refer as many friends as you want and earn unlimited rewards. The more you refer, the higher your tier and better benefits."
          }
        },
        "block_6": {
          "type": "faq-item",
          "settings": {
            "question": "Can I share my link on social media?",
            "answer": "Absolutely! You can share your referral link anywhere - social media, email, messaging apps, blogs, etc. Just make sure it's authentic and you're not misleading people."
          }
        }
      }
