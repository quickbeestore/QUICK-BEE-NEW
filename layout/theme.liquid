<!doctype html>
<!-- Live check: 2026-03-08 -->
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
  style="color-scheme: light dark;"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    <!-- Support both light and dark modes -->
    <meta name="color-scheme" content="light dark">
    <meta name="theme-color" content="#ffffff">

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}
    <link rel="preload" as="image" href="{{ 'POPUP.png' | asset_url }}" fetchpriority="high">

    <style>
      /* ============================================
         QUICKBEE GLOBAL DARK THEME FOUNDATION
         ============================================ */
      :root,
      html,
      .color-scheme-1,
      [class*="color-scheme"] {
        --color-background: 9, 9, 9 !important;
        --color-foreground: 240, 240, 240 !important;
        --color-background-rgb: 9, 9, 9 !important;
        --color-foreground-rgb: 240, 240, 240 !important;
        --color-foreground-heading: 255, 255, 255 !important;
        --color-border: 255, 255, 255 !important;
      }

      html, body {
        background: #090909 !important;
        background-color: #090909 !important;
        color: #F0F0F0 !important;
      }

      /* Global page wrapper dark */
      #shopify-section-quickbee-header,
      .shopify-section,
      main,
      #MainContent {
        background: #090909 !important;
      }

      /* Dark scrollbars globally */
      ::-webkit-scrollbar-track { background: #111 !important; }
      ::-webkit-scrollbar-thumb { background: rgba(244,180,0,0.35) !important; border-radius: 10px !important; }
      ::-webkit-scrollbar-thumb:hover { background: #F4B400 !important; }

      /* ============================================
         PREMIUM TOUCH & ANIMATION OPTIMIZATION
         ============================================ */
      :root {
        --qb-ease: cubic-bezier(0.4, 0, 0.2, 1);
        --qb-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      /* Fluid scrolling for all touch devices */
      * {
        -webkit-overflow-scrolling: touch;
        scroll-behavior: smooth;
      }

      /* Remove ugly mobile tap highlight */
      a, button, select, input, .qb-clickable {
        -webkit-tap-highlight-color: transparent;
        outline: none !important;
      }

      /* Prevent text selection on purely interactive elements for app-like feel */
      button, .qb-nick-btn, .qb-chip, .qb-qty-act, .qb-qty-btn {
        user-select: none;
        touch-action: manipulation;
      }

      /* Responsive Touch Feedback */
      .qb-btn-primary:active, 
      .qb-checkout-submit:active, 
      .qb-add-btn:active,
      .qb-main-checkout-btn:active {
        transform: scale(0.96) !important;
        transition: transform 0.1s var(--qb-ease);
      }

      /* Optimize animations for GPU */
      .animate-fade-in, 
      .animate-slide-up, 
      .animate-fade-in-up,
      .qb-modal-container,
      .qb-popup-content {
        will-change: transform, opacity;
        backface-visibility: hidden;
      }

      /* Custom scrollbar for a premium look */
      ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: #e0e0e0;
        border-radius: 10px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #ccc;
      }

      /* ============================================
         MOBILE-FIRST RESPONSIVE DESIGN SYSTEM
         ============================================ */

      /* GLOBAL MOBILE-FIRST BASE STYLES */
      * {
        box-sizing: border-box;
      }

      html {
        width: 100%;
        height: 100vh;
        margin: 0;
        padding: 0;
        overflow: hidden;
        background-color: var(--color-background);
        color: var(--color-foreground);
      }

      body {
        width: 100%;
        height: 100vh;
        margin: 0;
        padding: 0;
        font-size: 14px;
        line-height: 1.6;
        background-color: var(--color-background);
        color: var(--color-foreground);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }

      /* Main content container - mobile first */
      .page-width-100,
      .page-width-85,
      .page-width-80 {
        width: 100%;
        max-width: 100vw;
        margin: 0 auto;
        padding: 0;
        overflow-x: hidden;
      }

      /* Ensure main content respects viewport */
      main {
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
      }

      /* Section wrapper - mobile first */
      .shopify-section {
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
      }

      /* Container for grid/flex layouts */
      .container,
      [class*="container"] {
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
        padding: 0 12px;
        overflow-x: hidden;
      }

      /* Flex containers - ensure proper wrapping on mobile */
      .flex,
      [class*="flex"],
      [style*="display: flex"] {
        flex-wrap: wrap;
        width: 100%;
        overflow-x: hidden;
      }

      /* Sidebar/navigation - mobile horizontal scroll */
      .sidebar,
      [class*="sidebar"],
      nav {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
      }

      /* Product grid - mobile 2 columns (ONLY product grids) */
      .product-grid {
        width: 100%;
        max-width: 100%;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
        padding: 10px;
        overflow-x: hidden;
      }

      /* Product card - mobile first */
      .product-card,
      [class*="product-card"],
      .card {
        width: 100%;
        overflow: hidden;
        border-radius: 4px;
      }

      /* Images - responsive */
      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      /* Buttons and form elements - touch-friendly on mobile */
      button, input, select, textarea {
        font-size: 16px;
        width: 100%;
        max-width: 100%;
      }

      button {
        min-height: 44px;
        padding: 10px 12px;
      }

      /* Variant pills - should NOT be 100% width */
      .variant-pill,
      .variant-pills-container button {
        width: auto !important;
        max-width: none !important;
        min-width: 90px;
      }

      /* ── QuickBee Cart & Homepage — fix global button/flex overrides ── */
      .qb-qty-act,
      .qb-qty-btn,
      .qb-item-remove,
      .qb-mini-guide-btn,
      .qb-mini-modal-close,
      .qb-popup-close {
        width: auto !important;
        max-width: none !important;
        min-height: unset !important;
        padding: 0 !important;
      }

      .qb-qty-form,
      .qb-qty-pill,
      .qb-qty-selector {
        flex-wrap: nowrap !important;
        overflow: hidden !important;
      }

      /* Scrollbars in dark mode */
      ::-webkit-scrollbar-track { background: #111 !important; }
      ::-webkit-scrollbar-thumb { background: rgba(244,180,0,0.4) !important; }
      ::-webkit-scrollbar-thumb:hover { background: #F4B400 !important; }

      /* TABLET LAYOUT - 600px and up */
      @media (min-width: 600px) {
        body {
          font-size: 15px;
        }

        .page-width-100,
        .page-width-85,
        .page-width-80 {
          max-width: calc(100% - 24px);
          padding: 0 12px;
        }

        .container,
        [class*="container"] {
          padding: 0 16px;
        }

        .product-grid,
        [class*="product-grid"] {
          grid-template-columns: repeat(3, 1fr);
          gap: 12px;
          padding: 12px;
        }

        button {
          font-size: 15px;
        }
      }

      /* DESKTOP LAYOUT - 768px and up */
      @media (min-width: 768px) {
        body {
          font-size: 16px;
        }

        .page-width-100 {
          max-width: 100%;
          padding: 0;
        }

        .page-width-85 {
          max-width: calc(85% + 24px);
          padding: 0 12px;
        }

        .page-width-80 {
          max-width: calc(80% + 24px);
          padding: 0 12px;
        }

        .container,
        [class*="container"] {
          padding: 0 20px;
        }

        .product-grid,
        [class*="product-grid"] {
          grid-template-columns: repeat(4, 1fr);
          gap: 16px;
          padding: 16px;
        }

        button {
          font-size: 16px;
        }
      }

      /* LARGE DESKTOP - 1024px and up */
      @media (min-width: 1024px) {
        .container,
        [class*="container"] {
          padding: 0 24px;
        }

        .product-grid,
        [class*="product-grid"] {
          grid-template-columns: repeat(4, 1fr);
          gap: 20px;
          padding: 20px;
        }
      }

      /* ============================================
         HIDE PREVIEW BUTTONS AND OVERLAYS GLOBALLY
         ============================================ */
      [class*="preview"],
      [id*="preview"],
      [class*="quick-view"],
      [id*="quick-view"],
      .shopify-section__overlay,
      .button-preview,
      .product-preview,
      [data-testid*="preview"],
      [role="tooltip"],
      .tooltip-preview,
      button[aria-label*="preview"],
      button[aria-label*="quick"],
      .preview-button,
      .quick-view-button,
      .shopify-product-preview,
      .product__preview,
      .product__modal,
      .product__drawer {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
        pointer-events: none !important;
        z-index: -9999 !important;
      }

      /* Hide pseudo-elements that might show preview */
      [class*="preview"]::before,
      [class*="preview"]::after,
      [class*="quick"]::before,
      [class*="quick"]::after,
      button[aria-label*="preview"]::before,
      button[aria-label*="preview"]::after {
        display: none !important;
      }

      /* ============================================
         HIDE LOADING SPINNERS AND INDICATORS
         ============================================ */
      .loading-spinner,
      .spinner,
      [class*="loader"],
      [class*="loading"],
      [class*="progress"],
      .loader,
      .progress-bar,
      [aria-busy="true"],
      .add-to-cart-button .spinner,
      button .loading-spinner,
      button .spinner {
        display: none !important;
        visibility: hidden !important;
        height: 0 !important;
        width: 0 !important;
        margin: 0 !important;
        padding: 0 !important;
        border: none !important;
        clip: rect(0, 0, 0, 0) !important;
        clip-path: inset(50%) !important;
        overflow: hidden !important;
        white-space: nowrap !important;
        animation: none !important;
      }

      /* Stop all animations on loading elements */
      .loading-spinner *,
      .spinner *,
      .add-to-cart-button.loading *,
      button.loading * {
        animation: none !important;
      }

      /* Hide loading text */
      .loading-spinner::after,
      .loading-spinner::before,
      .spinner::after,
      .spinner::before {
        display: none !important;
        content: '' !important;
        animation: none !important;
      }

      /* Hide button loading state */
      .add-to-cart-button.loading {
        opacity: 1 !important;
        cursor: auto !important;
      }

      /* Hide all product card loading states and spinners */
      .product-card__loading,
      .product-card .loading-spinner,
      .card__loading,
      [class*="product-card"] .spinner,
      [class*="product-card"] .loading-spinner,
      .product-card__overlay,
      .card__overlay {
        display: none !important;
      }

      /* Hide all modals/dialogs by default - they show when opened */
      dialog,
      [role="dialog"],
      [class*="modal"],
      [class*="drawer"] {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
        pointer-events: none !important;
      }

      /* ============================================
         MODAL AND DIALOG STYLING - ONLY WHEN OPEN
         ============================================ */
      /* Modal backdrops - ensure they're visible when dialog is open */
      dialog[open]::backdrop {
        background-color: rgba(0, 0, 0, 0.5) !important;
        opacity: 1 !important;
        display: block !important;
      }

      /* Dialog elements - only style when open */
      dialog[open] {
        background-color: white !important;
        opacity: 1 !important;
        display: flex !important;
        visibility: visible !important;
        pointer-events: auto !important;
        z-index: 9999 !important;
        border: none !important;
        border-radius: 8px !important;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3) !important;
      }

      /* Style dialogs with role and active state */
      [role="dialog"].active,
      [role="dialog"][open] {
        background-color: white !important;
        opacity: 1 !important;
        display: flex !important;
        visibility: visible !important;
        pointer-events: auto !important;
        z-index: 9999 !important;
      }

      /* Modal containers when active */
      [class*="modal-container"].active,
      [class*="dialog-container"].active,
      [class*="modal-content"].active,
      [class*="dialog-content"].active {
        background-color: white !important;
        opacity: 1 !important;
        display: block !important;
        visibility: visible !important;
        pointer-events: auto !important;
        z-index: 9998 !important;
      }

      /* Location modal - allow reopening */
      #qbLocModal[style*="display: flex"] {
        display: flex !important;
        visibility: visible !important;
        opacity: 1 !important;
        pointer-events: auto !important;
      }
    </style>

    <link
      rel="stylesheet"
      href="{{ 'quickbee-shared-animations.css' | asset_url }}"
    >

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
