    <!-- Global Delivery Time System -->
    <script>
      (function() {
        // Initialize global delivery time from localStorage or page location display
        function initGlobalDeliveryTime() {
          const stored = localStorage.getItem('qb_delivery_time');

          if (stored) {
            try {
              window.QB_DELIVERY_TIME = JSON.parse(stored);
            } catch (e) {
              window.QB_DELIVERY_TIME = getDefaultDeliveryTime();
            }
          } else {
            // Try to get delivery time from location display on page
            window.QB_DELIVERY_TIME = extractDeliveryTimeFromPage() || getDefaultDeliveryTime();
          }

          updateAllDeliveryBadges();
        }

        function extractDeliveryTimeFromPage() {
          // Look for location time display in various formats
          const locationBtn = document.querySelector('[data-location-time]');
          if (locationBtn) {
            const timeStr = locationBtn.getAttribute('data-location-time');
            if (timeStr) {
              const timeMatch = timeStr.match(/(\d+)-?(\d+)?/);
              if (timeMatch) {
                const minTime = parseInt(timeMatch[1]);
                const maxTime = parseInt(timeMatch[2]) || minTime + 4;
                return {
                  minTime,
                  maxTime,
                  range: `${minTime}-${maxTime} mins`,
                  updatedAt: new Date().toISOString()
                };
              }
            }
          }
          return null;
        }

        function getDefaultDeliveryTime() {
          return {
            minTime: 18,
            maxTime: 22,
            range: '18-22 mins',
            updatedAt: new Date().toISOString()
          };
        }

        function updateAllDeliveryBadges() {
          const range = window.QB_DELIVERY_TIME?.range || '18-22 mins';
          const badges = document.querySelectorAll('.qb-delivery-badge');
          badges.forEach(badge => {
            badge.textContent = `⚡ ${range}`;
          });
        }

        function saveDeliveryTimeToStorage() {
          try {
            localStorage.setItem('qb_delivery_time', JSON.stringify(window.QB_DELIVERY_TIME));
          } catch (e) {
            console.warn('Failed to save delivery time:', e);
          }
        }

        // Listen for location changes globally
        window.addEventListener('locationSelected', (event) => {
          // Delivery time will be updated by location modal
          setTimeout(() => {
            saveDeliveryTimeToStorage();
            updateAllDeliveryBadges();
          }, 100);
        });

        // Force update ALL product badges on page
        function forceUpdateAllBadges() {
          const range = window.QB_DELIVERY_TIME?.range || '18-22 mins';
          // Update all badge classes (.qb-delivery-badge, .qb-product-delivery, .qb-sync-badge)
          const badges = document.querySelectorAll('.qb-delivery-badge, .qb-product-delivery, .qb-sync-badge');
          badges.forEach(badge => {
            badge.textContent = `⚡ ${range}`;
          });
        }

        // Initialize on page load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initGlobalDeliveryTime);
        } else {
          initGlobalDeliveryTime();
        }

        // Force update badges immediately after init
        setTimeout(forceUpdateAllBadges, 100);

        // Listen for location changes
        window.addEventListener('locationSelected', () => {
          setTimeout(forceUpdateAllBadges, 100);
        });

        // Expose functions globally
        window.updateDeliveryBadges = updateAllDeliveryBadges;
        window.saveDeliveryTime = saveDeliveryTimeToStorage;
      })();
    </script>


    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const checkoutButtons = document.querySelectorAll('button[name="checkout"], input[name="checkout"], a[href="/checkout"]');
        
        checkoutButtons.forEach(button => {
            button.addEventListener('click', function(e) {
                // Only intercept if we are on the cart page or a cart drawer/popup
                e.preventDefault();
                const checkoutTarget = this;
                
                try {
                    // 1. Grab the raw data from local storage using QuickBee keys
                    const rawLocation = localStorage.getItem('qb_selected_location');
                    const nickname = localStorage.getItem('qb_active_nickname') || 'Unspecified';
                    const mapsLink = localStorage.getItem('qb_landmark_' + nickname) || localStorage.getItem('qb_landmark_Current') || '';
                    
                    if (rawLocation) {
                        // 2. Parse the JSON string safely
                        const locData = JSON.parse(rawLocation);
                        const streetName = locData.street || rawLocation; // Fallback to raw string if 'street' key is missing
                        
                        // 3. Format a beautiful, readable note for the delivery rider
                        let formattedNote = `📍 Delivery Address: ${streetName}\n`;
                        formattedNote += `🏠 Type: ${nickname}\n`;
                        
                        if (mapsLink) {
                            formattedNote += `🗺️ Maps Link: ${mapsLink}\n`;
                        }
                        
                        // 4. Send the formatted note to Shopify's Cart API
                        fetch(window.Shopify.routes.root + 'cart/update.js', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ note: formattedNote })
                        })
                        .then(() => {
                            goToCheckout(checkoutTarget);
                        })
                        .catch((error) => {
                            console.error('QuickBee: Error saving location note:', error);
                            goToCheckout(checkoutTarget); // Don't block checkout on failure
                        });
                    } else {
                        // No location data found, proceed normally
                        goToCheckout(checkoutTarget);
                    }
                } catch (err) {
                    console.error('QuickBee: Error processing local storage data:', err);
                    goToCheckout(checkoutTarget); // Proceed to checkout even if JSON parsing fails
                }
            });
        });

        function goToCheckout(button) {
            const form = button.closest('form[action="/cart"]');
            if (form) {
                form.submit();
            } else {
                window.location.href = '/checkout';
            }
        }
      });
    </script>
  </body>
</html>
