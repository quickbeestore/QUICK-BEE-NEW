<!doctype html>
<!-- Live check: 2026-03-08 -->
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
  style="color-scheme: light dark;"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    <!-- Support both light and dark modes -->
    <meta name="color-scheme" content="dark">
    <meta name="theme-color" content="#0A0A0A">

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    <script>
      /* QuickBEE Theme Management */
      (function() {
        // 1. Immediate Theme Application (Prevent Flash)
        const savedTheme = localStorage.getItem('quickbee-theme');
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const initialTheme = savedTheme || 'dark';
        document.documentElement.setAttribute('data-theme', initialTheme);

        // 2. Event Listener (on DOMContentLoaded)
        document.addEventListener('DOMContentLoaded', () => {
          const toggleBtn = document.getElementById('theme-toggle');
          if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
              const currentTheme = document.documentElement.getAttribute('data-theme');
              const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
              document.documentElement.setAttribute('data-theme', newTheme);
              localStorage.setItem('quickbee-theme', newTheme);
            });
          }
        });
      })();
    </script>

    <style>
      /* ═══════════════════════════════════════════════════════════
         APP-LIKE SCROLL ARCHITECTURE
         - html + body = fixed viewport (NO body scroll)
         - #header-group = fixed top (no scroll)
         - #MainContent = the ONLY scroll container
         - Scrollbar appears BELOW header, not over it
         ═══════════════════════════════════════════════════════════ */

      * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

      /* ═══════════════════════════════════════════════════════════
         GLOBAL ANIMATION SYSTEM
         ═══════════════════════════════════════════════════════════ */
      :root {
        --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-smooth: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-modal: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      }

      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      @keyframes slideInUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes slideInDown {
        from { opacity: 0; transform: translateY(-12px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes modalBackdropFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      @keyframes modalSlideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
      }

      html {
        height: 100%;
        /* do NOT set overflow:hidden on html — breaks iOS touch scroll */
      }

      body {
        height: 100dvh; /* dynamic viewport height — handles mobile browser chrome */
        overflow: hidden; /* body itself doesn't scroll */
        display: flex;
        flex-direction: column;
        margin: 0;
        padding: 0 !important;
        width: 100% !important;
        max-width: 100% !important;
        justify-content: flex-start;
        align-items: stretch;
      }

      /* Fallback for browsers without dvh support */
      @supports not (height: 100dvh) {
        body { height: 100vh; }
      }

      /* Header stays at top, never scrolls */
      #header-group {
        flex-shrink: 0;
        width: 100% !important;
        max-width: 100% !important;
        position: relative;
        z-index: 1000;
        margin: 0 !important;
        padding: 0 !important;
        /* Clip any overflow that could create phantom gap below header */
        overflow: hidden;
      }

      /* Shopify wraps sections — ensure no gap from wrapper */
      #header-group > .shopify-section {
        margin: 0 !important;
        padding: 0 !important;
      }

      /* Sticky wrapper inside header — no extra space */
      .qb-sticky-header-wrapper {
        margin: 0 !important;
        padding: 0 !important;
        display: block;
      }

      /* Main content is the ONLY scroll container */
      #MainContent {
        flex: 1 1 auto;
        overflow-y: scroll;            /* scroll (not auto) — required for iOS Safari */
        overflow-x: hidden;
        -webkit-overflow-scrolling: touch; /* momentum scrolling on iOS */
        overscroll-behavior-y: contain;   /* prevent body scroll bleed-through */
        min-height: 0;                 /* critical for flexbox scroll to work */
        position: relative;
        touch-action: pan-y;           /* allow vertical touch scrolling */
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        /* Space above fixed mobile footer */
        padding-bottom: calc(65px + env(safe-area-inset-bottom) + 16px);
        background: var(--qb-black, #0A0A0A);
      }

      @media (min-width: 769px) {
        #MainContent {
          padding-bottom: 32px;
        }
      }
      
      /* QB page-width helpers — safe, only QuickBee classes */
      .page-width-100, .page-width-85, .page-width-80 {
        width: 100%; max-width: 100vw; margin: 0 auto; overflow-x: hidden;
      }

      /* ═══════════════════════════════════════════════════════════
         INTERACTIVE ELEMENT ANIMATIONS
         ═══════════════════════════════════════════════════════════ */

      /* All buttons get smooth transition */
      button, [role="button"], .button, a.btn, input[type="button"],
      input[type="submit"], input[type="reset"] {
        transition: all var(--transition-fast);
      }

      /* Button click feedback — subtle scale down */
      button:active, [role="button"]:active, .button:active,
      a.btn:active, input[type="button"]:active,
      input[type="submit"]:active, input[type="reset"]:active {
        transform: scale(0.96);
      }

      /* Modal & overlay animations */
      dialog, [role="dialog"], .modal, .modal-backdrop,
      .qb-location-backdrop, .qb-location-modal,
      .kw-maps-guide {
        animation: fadeIn var(--transition-modal);
      }

      /* Modal dialog slide up animation */
      dialog, [role="dialog"], .modal,
      .qb-location-modal, .kw-maps-guide-inner {
        animation: modalSlideUp var(--transition-modal);
      }

      /* Modal backdrop fade in */
      .modal-backdrop, .qb-location-backdrop, .kw-maps-guide {
        animation: modalBackdropFadeIn var(--transition-modal);
      }

      /* Generic card/element hover smoothness */
      .card, [class*="card"], .item, [class*="tile"] {
        transition: all var(--transition-smooth);
      }

      /* Price & quantity transitions */
      .price, [class*="price"], .qty, [class*="quantity"] {
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* Link smoothness */
      a, [role="link"] {
        transition: color var(--transition-fast), opacity var(--transition-fast);
      }

      /* Form input focus transitions */
      input, textarea, select, [class*="input"], [class*="form"] {
        transition: border-color var(--transition-fast), background-color var(--transition-fast), box-shadow var(--transition-fast);
      }

      /* ── QuickBee Overrides for Global Broad Rules ── */
      /* These prevent global theme CSS from breaking QB components */
      .qb-qty-act, .qb-qty-btn, .qb-item-remove, .qb-mini-guide-btn,
      .qb-mini-modal-close, .qb-popup-close {
        width: auto !important; max-width: none !important; min-height: unset !important; padding: 0 !important;
      }

      .qb-qty-form, .qb-qty-pill, .qb-qty-selector {
        flex-wrap: nowrap !important; display: flex !important; overflow: hidden !important;
      }

      /* Optimize animations */
      .animate-fade-in, .animate-slide-up, .qb-modal-container, .qb-popup-content {
        will-change: transform, opacity;
        backface-visibility: hidden;
      }
      
      /* Global Image Handle */
      img { max-width: 100%; height: auto; display: block; }

      /* Responsive Grids */
      .product-grid {
        display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; padding: 10px;
      }

      @media (min-width: 600px) {
        body { font-size: 15px; }
        .product-grid { grid-template-columns: repeat(3, 1fr); gap: 12px; }
      }

      @media (min-width: 768px) {
        body { font-size: 16px; }
        .product-grid { grid-template-columns: repeat(4, 1fr); gap: 16px; }
      }

      @media (min-width: 1024px) {
        .container, [class*="container"] { padding: 0 24px; }
        .product-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; padding: 20px; }
      }

      /* ============================================
         PREMIUM UI REFINEMENTS & PRIVACY
         ============================================ */
      [class*="preview"], [id*="preview"], [class*="quick-view"], 
      .shopify-section__overlay, .button-preview, .product-preview,
      [role="tooltip"], .tooltip-preview, .product__modal, .product__drawer {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
        pointer-events: none !important;
      }

      /* Hide loading spinners - they break the premium feel */
      .loading-spinner, .spinner, [class*="loader"], [class*="loading"] {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
      }

      /* ============================================
         MODAL AND DIALOG STYLING - DARK THEME
         ============================================ */
      dialog[open]::backdrop {
        background-color: rgba(0, 0, 0, 0.85) !important;
        backdrop-filter: blur(8px) !important;
      }

      [data-theme="dark"] dialog[open], 
      [data-theme="dark"] [role="dialog"].active, 
      [data-theme="dark"] [class*="modal-container"].active {
        background-color: #111 !important;
        color: #F0F0F0 !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
        border-radius: 20px !important;
        box-shadow: 0 20px 50px rgba(0,0,0,0.6) !important;
      }

      /* Location modal specific fix */
      #qbLocModal[style*="display: flex"] {
        display: flex !important;
        visibility: visible !important;
        opacity: 1 !important;
        pointer-events: auto !important;
      }

      /* ═══════════════════════════════════════════
         DEBUG MODE: Identify width-constrained elements
         Remove when fixed
         ═══════════════════════════════════════════ */
      /*
      * {
        outline: 1px solid red !important;
      }
      */
    </style>

