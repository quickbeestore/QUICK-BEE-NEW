{% schema %}
{
  "name": "Products Showcase",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Flash Deals"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Limited-time offers you should not miss"
    },
    {
      "type": "select",
      "id": "product_source",
      "label": "Product Source",
      "options": [
        {
          "value": "latest",
          "label": "Latest Products"
        },
        {
          "value": "collection",
          "label": "From Collection"
        },
        {
          "value": "featured",
          "label": "Featured Products"
        }
      ],
      "default": "latest"
    },
    {
      "type": "collection",
      "id": "selected_collection",
      "label": "Select Collection (if applicable)"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to Show",
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color_start",
      "label": "Background Gradient Start",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "bg_color_end",
      "label": "Background Gradient End",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_discount",
      "label": "Show Discount Badge",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Products Showcase"
    }
  ]
}
{% endschema %}

<style>
.qb-section {
  padding: 40px 16px;
}
@media(min-width:1024px) {
  .qb-section {
    padding: 60px 48px;
  }
}
.qb-section h2 {
  font-size: 24px;
  font-weight: 900;
  margin: 0 0 24px 0;
  color: #111111;
}
@media(min-width:1024px) {
  .qb-section h2 {
    font-size: 32px;
    margin-bottom: 32px;
  }
}
.qb-section p {
  font-size: 14px;
  color: #666;
  margin: 8px 0 0 0;
}
.qb-products {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-top: 20px;
}
@media(min-width:768px) {
  .qb-products {
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
}
@media(min-width:1024px) {
  .qb-products {
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
}
.qb-product {
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 12px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
}
.qb-product:hover {
  border-color: #F4B400;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  transform: translateY(-4px);
}
.qb-product-img {
  width: 100%;
  aspect-ratio: 1;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  overflow: hidden;
}
.qb-product-img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  padding: 8px;
}
.qb-product-info {
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.qb-product-title {
  font-size: 13px;
  font-weight: 600;
  color: #111111;
  line-height: 1.3;
  min-height: 26px;
}
.qb-product-delivery {
  font-size: 11px;
  color: #16A34A;
  font-weight: 600;
}
.qb-product-price {
  font-size: 16px;
  font-weight: 800;
  color: #111111;
}
.qb-product-btn {
  background: #F4B400;
  border: none;
  padding: 10px;
  border-radius: 8px;
  font-weight: 700;
  font-size: 13px;
  color: #111111;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-top: auto;
}
.qb-product-btn:hover {
  background: #E8A500;
  transform: scale(1.02);
}
.qb-badge {
  display: inline-block;
  background: #F4B400;
  color: #111111;
  padding: 3px 8px;
  border-radius: 6px;
  font-size: 10px;
  font-weight: 700;
  margin-top: 6px;
}
</style>

<!-- Products Showcase -->
<section class="qb-section" style="background: linear-gradient(135deg, {{ section.settings.bg_color_start }} 0%, {{ section.settings.bg_color_end }} 100%);">
  <h2>{{ section.settings.section_title }}</h2>
  <p>{{ section.settings.section_subtitle }}</p>

  <div class="qb-products">
    {% if section.settings.product_source == 'collection' and section.settings.selected_collection %}
      {% assign products = section.settings.selected_collection.products | limit: section.settings.products_limit %}
    {% elsif section.settings.product_source == 'featured' %}
      {% assign products = shop.products | sort: "created_at" | limit: section.settings.products_limit %}
    {% else %}
      {% assign products = shop.products | sort: "created_at" | reverse | limit: section.settings.products_limit %}
    {% endif %}

    {% for product in products %}
      <a href="{{ product.url }}" class="qb-product">
        <div class="qb-product-img">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
          {% else %}
            {{ product.title | slice: 0, 1 }}
          {% endif %}
        </div>
        <div class="qb-product-info">
          <div class="qb-product-title">{{ product.title | truncatewords: 3 }}</div>
          <div class="qb-product-delivery qb-delivery-badge" data-delivery-badge="true">⚡ 18-22 mins</div>

          <div style="display: flex; align-items: center; gap: 6px;">
            <strong class="qb-product-price">
              {% if product.price %}
                Rs {{ product.price | money_without_currency | remove: "Rs" | remove: "," }}
              {% endif %}
            </strong>
            {% if section.settings.show_discount and product.compare_at_price %}
              <s style="font-size: 12px; color: #666;">
                Rs {{ product.compare_at_price | money_without_currency | remove: "Rs" | remove: "," }}
              </s>
              <span class="qb-badge">
                {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round %}
                {{ discount }}% OFF
              </span>
            {% endif %}
          </div>

          <button class="qb-product-btn"
            onclick="fetch('{{ routes.cart_add_url }}', {
              method: 'POST',
              body: new FormData(Object.assign(document.createElement('form'), {
                innerHTML: '<input name=id value={{ product.variants.first.id }}><input name=quantity value=1>'
              }))
            }).then(() => window.location.href = '{{ routes.cart_url }}')">
            Add to Cart
          </button>
        </div>
      </a>
    {% endfor %}
  </div>
</section>
