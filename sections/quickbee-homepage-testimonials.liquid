<style>
  .qb-testimonials-section {
    padding: 40px 16px;
    background: #0A0A0A !important;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  @media (min-width: 1024px) {
    .qb-testimonials-section {
      padding: 60px 48px;
    }
  }

  .qb-testimonials-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .qb-testimonials-title {
    font-size: 24px;
    font-weight: 900;
    color: #F0F0F0;
    margin: 0;
  }

  @media (min-width: 1024px) {
    .qb-testimonials-title {
      font-size: 32px;
    }
  }

  .qb-testimonials-nav {
    display: flex;
    gap: 12px;
  }

  .qb-testimonials-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.1);
    background: #111;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    transition: all 0.3s ease;
    color: #F4B400;
  }

  .qb-testimonials-btn:hover {
    border-color: #F4B400;
    background: #181818;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(244,180,0,0.2);
  }

  .qb-testimonials-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 24px;
  }

  @media (min-width: 768px) {
    .qb-testimonials-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  @media (min-width: 1024px) {
    .qb-testimonials-container {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  .qb-testimonial-card {
    background: #111;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: all 0.3s ease;
    cursor: default;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .qb-testimonial-card:hover {
    border-color: rgba(244,180,0,0.4);
    box-shadow: 0 15px 35px rgba(0,0,0,0.5), 0 0 20px rgba(244,180,0,0.1);
    transform: translateY(-6px);
  }

  .qb-testimonials-rating {
    font-size: 18px;
    letter-spacing: 3px;
    color: #F4B400;
    filter: drop-shadow(0 0 8px rgba(244,180,0,0.3));
  }

  .qb-testimonials-text {
    font-size: 15px;
    line-height: 1.7;
    color: #BBB;
    font-weight: 500;
    margin: 0;
  }

  .qb-testimonials-footer {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .qb-testimonials-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #F4B400 0%, #FFD700 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 800;
    color: #000;
    flex-shrink: 0;
    box-shadow: 0 4px 10px rgba(244,180,0,0.3);
  }

  .qb-testimonials-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .qb-testimonials-name {
    font-size: 14px;
    font-weight: 700;
    color: #F0F0F0;
  }

  .qb-testimonials-badge {
    font-size: 10px;
    font-weight: 700;
    color: #4ADE80;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .qb-testimonials-badge::before {
    content: "✓";
    font-size: 12px;
  }
</style>

