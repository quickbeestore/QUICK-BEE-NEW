<style>
  .qb-testimonials-section {
    padding: 40px 16px;
    background: #fff;
  }

  @media (min-width: 1024px) {
    .qb-testimonials-section {
      padding: 60px 48px;
    }
  }

  .qb-testimonials-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .qb-testimonials-title {
    font-size: 24px;
    font-weight: 900;
    color: #111111;
    margin: 0;
  }

  @media (min-width: 1024px) {
    .qb-testimonials-title {
      font-size: 32px;
    }
  }

  .qb-testimonials-nav {
    display: flex;
    gap: 8px;
  }

  .qb-testimonials-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid #e8e8e8;
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    transition: all 0.3s ease;
    color: #111111;
  }

  .qb-testimonials-btn:hover {
    border-color: #F4B400;
    background: #FFF8E8;
    transform: translateY(-2px);
  }

  .qb-testimonials-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 24px;
  }

  @media (min-width: 768px) {
    .qb-testimonials-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  @media (min-width: 1024px) {
    .qb-testimonials-container {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  .qb-testimonial-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.3s ease;
    cursor: default;
  }

  .qb-testimonial-card:hover {
    border-color: #F4B400;
    box-shadow: 0 8px 24px rgba(244, 180, 0, 0.12);
    transform: translateY(-4px);
  }

  .qb-testimonials-rating {
    font-size: 18px;
    letter-spacing: 2px;
    color: #F4B400;
  }

  .qb-testimonials-text {
    font-size: 14px;
    line-height: 1.6;
    color: #666;
    font-weight: 500;
  }

  .qb-testimonials-footer {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
  }

  .qb-testimonials-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #F4B400 0%, #E8A500 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: #111111;
    flex-shrink: 0;
  }

  .qb-testimonials-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .qb-testimonials-name {
    font-size: 13px;
    font-weight: 700;
    color: #111111;
  }

  .qb-testimonials-badge {
    font-size: 10px;
    font-weight: 600;
    color: #16A34A;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .carousel-active {
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<div class="qb-testimonials-section">
