  </div>
</div>

<script>
// Carousel functionality for testimonials
(function() {
  function initCarousel() {
    const container = document.querySelector('[data-carousel]');
    const items = document.querySelectorAll('[data-carousel-item]');
    const nextBtn = document.querySelector('[data-carousel-next]');
    const prevBtn = document.querySelector('[data-carousel-prev]');
    
    if (!container || items.length === 0) return;
    
    let currentIndex = 0;
    const itemsPerPage = window.innerWidth >= 1024 ? 3 : (window.innerWidth >= 768 ? 2 : 1);
    
    function updateDisplay() {
      items.forEach((item, index) => {
        item.style.display = (index >= currentIndex && index < currentIndex + itemsPerPage) ? 'flex' : 'none';
        if (item.style.display === 'flex') {
          item.classList.add('carousel-active');
        } else {
          item.classList.remove('carousel-active');
        }
      });
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        if (currentIndex + itemsPerPage < items.length) {
          currentIndex += 1;
        } else {
          currentIndex = 0; // Loop back
        }
        updateDisplay();
      });
    }
    
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        if (currentIndex > 0) {
          currentIndex -= 1;
        } else {
          currentIndex = Math.max(0, items.length - itemsPerPage); // Loop to end
        }
        updateDisplay();
      });
    }
    
    // Initial display
    updateDisplay();
    
    // Update on resize
    window.addEventListener('resize', () => {
      updateDisplay();
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousel);
  } else {
    initCarousel();
  }
})();
</script>

