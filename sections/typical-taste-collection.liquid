  <!-- Toast -->
  <div class="tt-toast" id="ttToast">Added ✓</div>

</div>

<!-- Product data for upsell/combos -->
<script type="application/json" id="ttProductData">
[
  {%- for p in all_products limit: 20 -%}
  {
    "id": {{ p.variants.first.id }},
    "title": {{ p.title | json }},
    "price": {{ p.price }},
    "img": {{ p.featured_image | img_url: '200x200', crop: 'center' | json }},
    "type": {{ p.type | downcase | json }}
  }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
</script>

<script>
(function () {
  'use strict';

  /* ── Cart state ─────────────────────────────────── */
  var ttCart  = {};   // { vid: qty }
  var ttPrices = {};  // { vid: price_in_paisa }
  var ttTitles = {};  // { vid: title }
  var ttImgs   = {};  // { vid: img_url }
  var allProducts = [];
  var toastTimer  = null;

  /* ── Parse product data ─────────────────────────── */
  try {
    allProducts = JSON.parse(document.getElementById('ttProductData').textContent);
    allProducts.forEach(function (p) {
      ttPrices[p.id] = p.price;
      ttTitles[p.id] = p.title;
      ttImgs[p.id]   = p.img;
    });
  } catch(e) {}

  /* ── Restore cart from Shopify ──────────────────── */
  fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function (r) { return r.json(); })
    .then(function (cart) {
      cart.items.forEach(function (item) {
        ttCart[item.variant_id] = item.quantity;
        if (!ttPrices[item.variant_id]) ttPrices[item.variant_id] = item.price;
        if (!ttTitles[item.variant_id]) ttTitles[item.variant_id] = item.title;
        if (!ttImgs[item.variant_id])   ttImgs[item.variant_id]   = item.image;
      });
      renderAll();
    })
    .catch(function () {});

  /* ── Render ALL cards ───────────────────────────── */
  function renderAll() {
    Object.keys(ttPrices).forEach(function (vid) { renderVid(parseInt(vid, 10)); });
    updateBar();
    renderDrawerItems();
  }

  /* ── Render single vid ──────────────────────────── */
  function renderVid(vid) {
    var qty = ttCart[vid] || 0;
    document.querySelectorAll('.tt-add-btn[data-vid="' + vid + '"]').forEach(function (btn) {
      if (qty > 0) {
        btn.style.display = 'none';
      } else {
        btn.style.display = '';
        btn.classList.remove('loading', 'success');
        btn.removeAttribute('disabled');
        btn.textContent = 'ADD +';
      }
    });
    document.querySelectorAll('.tt-stepper[data-vid="' + vid + '"]').forEach(function (s) {
      if (qty > 0) { s.classList.add('visible'); } else { s.classList.remove('visible'); }
    });
    document.querySelectorAll('.tt-stepper-qty[data-vid="' + vid + '"]').forEach(function (c) {
      c.textContent = qty;
    });
  }

  /* ── AJAX: Add to cart ──────────────────────────── */
  function ttAdd(vid, qty, btn) {
    if (btn) {
      btn.classList.add('loading');
      btn.setAttribute('disabled', true);
    }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: qty })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      ttCart[vid] = (ttCart[vid] || 0) + qty;
      if (btn) {
        btn.classList.remove('loading');
        btn.classList.add('success');
        btn.textContent = '✓';
        setTimeout(function () { renderVid(vid); updateBar(); renderDrawerItems(); showToast('Added to cart ✓'); }, 300);
      } else {
        renderVid(vid);
        updateBar();
        renderDrawerItems();
        showToast('Added ✓');
      }
    })
    .catch(function () {
      if (btn) { btn.classList.remove('loading'); btn.removeAttribute('disabled'); btn.textContent = 'ADD +'; }
    });
  }

  /* ── AJAX: Change qty ───────────────────────────── */
  function ttChange(vid, newQty, btn) {
    if (btn) btn.classList.add('busy');
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: newQty })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      if (newQty <= 0) { delete ttCart[vid]; } else { ttCart[vid] = newQty; }
      if (btn) btn.classList.remove('busy');
      renderVid(vid);
      updateBar();
      renderDrawerItems();
    })
    .catch(function () { if (btn) btn.classList.remove('busy'); });
  }

  /* ── Cart bar ────────────────────────────────────── */
  function updateBar() {
    var totalQty = 0, totalPrice = 0;
    Object.keys(ttCart).forEach(function (v) {
      totalQty   += ttCart[v];
      totalPrice += (ttPrices[v] || 0) * ttCart[v];
    });
    var bar   = document.getElementById('ttMobileBar');
    var count = document.getElementById('ttCartIconCount');
    var barCnt = document.getElementById('ttBarCount');
    var barTot = document.getElementById('ttBarTotal');
    if (bar) {
      if (totalQty > 0) { bar.classList.add('visible'); } else { bar.classList.remove('visible'); }
    }
    if (count) {
      count.textContent = totalQty;
      if (totalQty > 0) { count.classList.add('visible'); } else { count.classList.remove('visible'); }
    }
    if (barCnt) barCnt.textContent = totalQty + ' item' + (totalQty === 1 ? '' : 's');
    if (barTot) barTot.textContent = 'Rs ' + Math.round(totalPrice / 100);
  }

  /* ── Drawer items ────────────────────────────────── */
  function renderDrawerItems() {
    var container = document.getElementById('ttDrawerItems');
    var empty     = document.getElementById('ttDrawerEmpty');
    var footer    = document.getElementById('ttDrawerFooter');
    var totalEl   = document.getElementById('ttDrawerTotal');
    var combosWrap= document.getElementById('ttCombosWrap');
    var upsellWrap= document.getElementById('ttUpsellWrap');
    if (!container) return;

    var vids = Object.keys(ttCart).filter(function (v) { return ttCart[v] > 0; });

    if (vids.length === 0) {
      container.innerHTML = '';
      if (empty)  empty.style.display  = '';
      if (footer) footer.style.display = 'none';
      if (combosWrap) combosWrap.style.display = 'none';
      if (upsellWrap) upsellWrap.style.display = 'none';
      return;
    }

    if (empty)  empty.style.display  = 'none';
    if (footer) footer.style.display = '';
    if (combosWrap) combosWrap.style.display = '';
    if (upsellWrap) upsellWrap.style.display = '';

    var html = '';
    var total = 0;
    vids.forEach(function (v) {
      var qty   = ttCart[v];
      var price = (ttPrices[v] || 0) * qty;
      total += price;
      var img   = ttImgs[v] || '';
      var title = ttTitles[v] || 'Item';
      html += '<div class="tt-drawer-item">';
      if (img) {
        html += '<img class="tt-ditem-img" src="' + img + '" alt="' + title + '" loading="lazy">';
      } else {
        html += '<div class="tt-ditem-img" style="display:flex;align-items:center;justify-content:center;font-size:24px;">🍽️</div>';
      }
      html += '<div class="tt-ditem-info"><div class="tt-ditem-name">' + title + '</div><div class="tt-ditem-price">Rs ' + Math.round((ttPrices[v] || 0) / 100) + '</div></div>';
      html += '<div class="tt-ditem-stepper">';
      html += '<button class="tt-ditem-btn" data-vid="' + v + '" data-action="minus">−</button>';
      html += '<span class="tt-ditem-qty">' + qty + '</span>';
      html += '<button class="tt-ditem-btn" data-vid="' + v + '" data-action="plus">+</button>';
      html += '</div></div>';
    });
    container.innerHTML = html;

    if (totalEl) totalEl.textContent = 'Rs ' + Math.round(total / 100);

    renderCombos(vids);
    renderUpsell(vids);
  }

  /* ── Combo deals ─────────────────────────────────── */
  function renderCombos(cartVids) {
    var list = document.getElementById('ttCombosList');
    if (!list) return;
    var notInCart = allProducts.filter(function (p) {
      return !cartVids.includes(String(p.id)) && p.price < 20000;
    }).slice(0, 4);
    if (notInCart.length === 0) { if (list.parentElement) list.parentElement.style.display = 'none'; return; }
    var html = '';
    notInCart.forEach(function (p) {
      html += '<div class="tt-combo-pill" data-vid="' + p.id + '">';
      html += '<span class="tt-combo-text">+ ' + p.title.split(' ').slice(0,3).join(' ') + '</span>';
      html += '<span class="tt-combo-price">Rs ' + Math.round(p.price / 100) + '</span>';
      html += '<span class="tt-combo-add">＋</span>';
      html += '</div>';
    });
    list.innerHTML = html;
    list.querySelectorAll('.tt-combo-pill').forEach(function (pill) {
      pill.addEventListener('click', function () {
        var vid = parseInt(pill.getAttribute('data-vid'), 10);
        ttAdd(vid, 1, null);
        pill.style.opacity = '0.5';
        pill.style.pointerEvents = 'none';
      });
    });
  }

  /* ── Upsell ──────────────────────────────────────── */
  function renderUpsell(cartVids) {
    var list = document.getElementById('ttUpsellList');
    if (!list) return;
    var suggestions = allProducts.filter(function (p) {
      return !cartVids.includes(String(p.id));
    });
    // Shuffle
    for (var i = suggestions.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = suggestions[i]; suggestions[i] = suggestions[j]; suggestions[j] = tmp;
    }
    suggestions = suggestions.slice(0, 5);
    if (suggestions.length === 0) { if (list.parentElement) list.parentElement.style.display = 'none'; return; }
    var html = '';
    suggestions.forEach(function (p) {
      html += '<div class="tt-upsell-card" data-vid="' + p.id + '">';
      html += '<div class="tt-upsell-img">';
      if (p.img) { html += '<img src="' + p.img + '" alt="' + p.title + '" loading="lazy">'; }
      else        { html += '🍽️'; }
      html += '</div>';
      html += '<div class="tt-upsell-info"><div class="tt-upsell-name">' + p.title.slice(0, 20) + '</div><div class="tt-upsell-price">Rs ' + Math.round(p.price/100) + '</div></div>';
      html += '</div>';
    });
    list.innerHTML = html;
    list.querySelectorAll('.tt-upsell-card').forEach(function (card) {
      card.addEventListener('click', function () {
        var vid = parseInt(card.getAttribute('data-vid'), 10);
        ttAdd(vid, 1, null);
      });
    });
  }

  /* ── Toast ───────────────────────────────────────── */
  function showToast(msg) {
    var t = document.getElementById('ttToast');
    if (!t) return;
    t.textContent = msg;
    t.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(function () { t.classList.remove('show'); }, 1800);
  }

  /* ── Drawer open/close ───────────────────────────── */
  function openDrawer() {
    document.getElementById('ttDrawer').classList.add('open');
    document.getElementById('ttOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    document.getElementById('ttDrawer').classList.remove('open');
    document.getElementById('ttOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.getElementById('ttDrawerClose').addEventListener('click', closeDrawer);
  document.getElementById('ttOverlay').addEventListener('click', closeDrawer);
  document.getElementById('ttCartIconBtn').addEventListener('click', openDrawer);
  document.getElementById('ttMobileBar').addEventListener('click', openDrawer);

  /* ── Drawer item buttons (event delegation) ─────── */
  document.getElementById('ttDrawerItems').addEventListener('click', function (e) {
    var btn = e.target.closest('.tt-ditem-btn');
    if (!btn) return;
    var vid = parseInt(btn.getAttribute('data-vid'), 10);
    var action = btn.getAttribute('data-action');
    var cur = ttCart[vid] || 0;
    if (action === 'plus') { ttChange(vid, cur + 1, btn); }
    else if (action === 'minus') { ttChange(vid, Math.max(0, cur - 1), btn); }
  });

  /* ── Card ADD / Stepper (event delegation) ──────── */
  document.getElementById('ttContent').addEventListener('click', function (e) {
    var target = e.target;
    if (target.classList.contains('tt-add-btn') && !target.classList.contains('loading') && !target.classList.contains('success')) {
      var vid = parseInt(target.getAttribute('data-vid'), 10);
      ttAdd(vid, 1, target);
    }
    if (target.classList.contains('tt-stepper-minus') && !target.classList.contains('busy')) {
      var vid2 = parseInt(target.getAttribute('data-vid'), 10);
      ttChange(vid2, Math.max(0, (ttCart[vid2] || 0) - 1), target);
    }
    if (target.classList.contains('tt-stepper-plus') && !target.classList.contains('busy')) {
      var vid3 = parseInt(target.getAttribute('data-vid'), 10);
      ttChange(vid3, (ttCart[vid3] || 0) + 1, target);
    }
  });

  /* ── Category pills ──────────────────────────────── */
  document.getElementById('ttPills').addEventListener('click', function (e) {
    var pill = e.target.closest('.tt-pill');
    if (!pill) return;
    document.querySelectorAll('.tt-pill').forEach(function (p) { p.classList.remove('active'); });
    pill.classList.add('active');
    var target = pill.getAttribute('data-target');
    if (target === 'all') {
      document.querySelectorAll('.tt-sec').forEach(function (s) { s.style.display = ''; });
    } else {
      document.querySelectorAll('.tt-sec').forEach(function (s) { s.style.display = 'none'; });
      var sec = document.getElementById('tt-sec-' + target);
      if (sec) {
        sec.style.display = '';
        setTimeout(function () { sec.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 50);
      }
    }
  });

  /* ── Search ──────────────────────────────────────── */
  document.getElementById('ttSearch').addEventListener('input', function () {
    var q = this.value.toLowerCase().trim();
    document.querySelectorAll('.tt-card').forEach(function (card) {
      var title = (card.getAttribute('data-title') || '').toLowerCase();
      if (!q || title.includes(q)) {
        card.classList.remove('tt-hidden');
      } else {
        card.classList.add('tt-hidden');
      }
    });
    // Show all sections when searching
    document.querySelectorAll('.tt-sec').forEach(function (s) { s.style.display = ''; });
    document.querySelectorAll('.tt-pill').forEach(function (p) { p.classList.remove('active'); });
    var allPill = document.querySelector('.tt-pill[data-target="all"]');
    if (allPill) allPill.classList.add('active');
  });

  /* ── IntersectionObserver: scroll-spy pills ─────── */
  if ('IntersectionObserver' in window) {
    var secMap = { 'tt-sec-drinks': 'drinks', 'tt-sec-biryani': 'biryani', 'tt-sec-snacks': 'snacks', 'tt-sec-mains': 'mains', 'tt-sec-specials': 'specials', 'tt-sec-desserts': 'desserts', 'tt-sec-others': 'others' };
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var secId  = entry.target.id;
          var target = secMap[secId];
          if (target) {
            document.querySelectorAll('.tt-pill').forEach(function (p) { p.classList.remove('active'); });
            var activePill = document.querySelector('.tt-pill[data-target="' + target + '"]');
            if (activePill) {
              activePill.classList.add('active');
              activePill.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
            }
          }
        }
      });
    }, { rootMargin: '-30% 0px -60% 0px', threshold: 0 });
    document.querySelectorAll('.tt-sec').forEach(function (s) { observer.observe(s); });
  }

})();
</script>

