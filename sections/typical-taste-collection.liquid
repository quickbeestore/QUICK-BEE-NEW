        {%- for p in all_products -%}
          {%- assign pt = p.type | downcase | strip -%}
          {%- unless pt contains 'drink' or pt contains 'tea' or pt contains 'coffee' or pt contains 'juice' or pt contains 'shake' or pt contains 'smoothie' or pt contains 'water' or pt contains 'soda' or pt contains 'lemon' or pt contains 'beverage' or pt contains 'lassi' or pt contains 'mocktail' or pt contains 'milk' or pt contains 'biryani' or pt contains 'rice' or pt contains 'pulao' or pt contains 'snack' or pt contains 'fries' or pt contains 'chips' or pt contains 'momo' or pt contains 'roll' or pt contains 'pakora' or pt contains 'samosa' or pt contains 'sandwich' or pt contains 'wrap' or pt contains 'special' or pt contains 'combo' or pt contains 'deal' or pt contains 'set' or pt contains 'main' or pt contains 'curry' or pt contains 'dal' or pt contains 'thali' or pt contains 'plate' or pt contains 'meal' or pt contains 'chicken' or pt contains 'mutton' or pt contains 'dessert' or pt contains 'sweet' or pt contains 'cake' or pt contains 'ice' or pt contains 'pudding' or pt contains 'brownie' -%}
            {%- assign vid = p.variants.first.id -%}
            {%- assign pcp = p.compare_at_price_min -%}
            {%- assign pp  = p.price -%}
            {%- assign _ptl = p.title | downcase -%}
