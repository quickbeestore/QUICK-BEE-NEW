    <div class="tt-pills" id="ttPills">
      <button class="tt-pill active" data-target="all">🍽️ All</button>
      {%- if has_drinks -%}
      <button class="tt-pill" data-target="drinks">☕ Drinks <small>({{ drink_count }})</small></button>
      {%- endif -%}
      {%- if has_biryani -%}
      <button class="tt-pill" data-target="biryani">🍛 Biryani <small>({{ biryani_count }})</small></button>
      {%- endif -%}
      {%- if has_snacks -%}
      <button class="tt-pill" data-target="snacks">🍟 Snacks <small>({{ snack_count }})</small></button>
      {%- endif -%}
      {%- if has_mains -%}
      <button class="tt-pill" data-target="mains">🍖 Mains <small>({{ main_count }})</small></button>
      {%- endif -%}
      {%- if has_specials -%}
      <button class="tt-pill" data-target="specials">🌟 Specials <small>({{ special_count }})</small></button>
      {%- endif -%}
      {%- if has_desserts -%}
      <button class="tt-pill" data-target="desserts">🍰 Desserts <small>({{ dessert_count }})</small></button>
      {%- endif -%}
      {%- if has_others -%}
      <button class="tt-pill" data-target="others">🍽️ More <small>({{ other_count }})</small></button>
      {%- endif -%}
    </div>
  </div>

  <!-- ── Products ─────────────────────────────────── -->
  <div class="tt-content" id="ttContent">

    {%- if all_products.size == 0 -%}
    <div class="tt-empty">
      <div class="tt-empty-icon">🍗</div>
      <h3>Menu coming soon!</h3>
      <p>We're cooking up something delicious. Check back soon!</p>
    </div>
    {%- else -%}

    {%- comment -%} DRINKS {%- endcomment -%}
    {%- if has_drinks -%}
    <div class="tt-sec" id="tt-sec-drinks">
      <div class="tt-sec-head">☕ Drinks <span class="tt-sec-count">{{ drink_count }}</span></div>
      <div class="tt-grid">
        {%- for p in all_products -%}
          {%- assign pt = p.type | downcase | strip -%}
          {%- if pt contains 'drink' or pt contains 'tea' or pt contains 'coffee' or pt contains 'juice' or pt contains 'shake' or pt contains 'smoothie' or pt contains 'water' or pt contains 'soda' or pt contains 'lemon' or pt contains 'beverage' or pt contains 'lassi' or pt contains 'mocktail' or pt contains 'milk' -%}
            {%- assign vid = p.variants.first.id -%}
            {%- assign pcp = p.compare_at_price_min -%}
            {%- assign pp  = p.price -%}
            {%- assign _ptl = p.title | downcase -%}
            {%- assign _tags = p.tags | join: ',' | downcase -%}
            <div class="tt-card" data-vid="{{ vid }}" data-sec="drinks" data-title="{{ p.title | downcase }}">
              <div class="tt-card-img-wrap">
                {%- if p.featured_image -%}
                  <img class="tt-card-img" src="{{ p.featured_image | img_url: '400x400', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
                {%- else -%}
                  <div class="tt-no-img">☕</div>
                {%- endif -%}
                <div class="tt-badges">
                  {%- if p.tags contains 'best-seller' or p.tags contains 'Best Seller' or p.tags contains 'Popular' -%}<span class="tt-badge tt-badge--bestseller">🔥 Best Seller</span>{%- endif -%}
                  {%- if p.tags contains 'new' or p.tags contains 'New' -%}<span class="tt-badge tt-badge--new">✨ New</span>{%- endif -%}
                  {%- if p.tags contains 'fast' or p.tags contains 'Fast Delivery' -%}<span class="tt-badge tt-badge--fast">⚡ Fast</span>{%- endif -%}
