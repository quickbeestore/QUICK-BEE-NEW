{% comment %}Typical Taste Mulpani — Compact Restaurant App Style{% endcomment %}

<style>
.ttm {
  --red:    #c0392b;
  --red2:   #e74c3c;
  --gold:   var(--theme-gold, #d4a017);
  --bg:     var(--theme-bg-primary);
  --bg2:    var(--theme-bg-secondary);
  --text:   var(--theme-text-main);
  --muted:  var(--theme-text-muted);
  --border: var(--theme-border);
  --ease:   cubic-bezier(.4,0,.2,1);
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* ── COMPACT HEADER CARD ── */
.ttm-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
}
.ttm-header-logo {
  width: 56px; height: 56px;
  border-radius: 12px;
  overflow: hidden;
  flex-shrink: 0;
  background: #111;
  border: 1px solid var(--border);
}
.ttm-header-logo img {
  width: 100%; height: 100%;
  object-fit: cover;
  mix-blend-mode: screen;
}
html:not([data-theme="dark"]) .ttm-header-logo { background: #f5e6c8; }
html:not([data-theme="dark"]) .ttm-header-logo img { mix-blend-mode: multiply; }

.ttm-header-info { flex: 1; min-width: 0; }
.ttm-header-name {
  font-size: 16px; font-weight: 800; color: var(--text);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.ttm-header-sub {
  font-size: 11px; color: var(--muted); margin-top: 2px;
}
.ttm-header-badges {
  display: flex; gap: 6px; margin-top: 5px; flex-wrap: wrap;
}
.ttm-header-badge {
  font-size: 9px; font-weight: 800; letter-spacing: 0.5px;
  padding: 2px 8px; border-radius: 100px;
  border: 1px solid var(--border);
  color: var(--muted);
  background: var(--bg);
}
.ttm-header-badge--open {
  color: #16a34a;
  border-color: rgba(22,163,74,0.3);
  background: rgba(22,163,74,0.08);
}

.ttm-header-right { flex-shrink: 0; text-align: right; }
.ttm-header-rating {
  font-size: 13px; font-weight: 800; color: var(--text);
}
.ttm-header-rating-sub { font-size: 9px; color: var(--muted); margin-top: 1px; }

/* ── STICKY TABS ── */
.ttm-tabs-wrap {
  position: sticky; top: 0; z-index: 50;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}
.ttm-tabs {
  display: flex; overflow-x: auto; gap: 0;
  scrollbar-width: none;
}
.ttm-tabs::-webkit-scrollbar { display: none; }
.ttm-tab {
  flex-shrink: 0; padding: 11px 14px;
  font-size: 12px; font-weight: 700;
  color: var(--muted);
  border: none; background: none; cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: color .18s, border-color .18s;
  white-space: nowrap;
}
.ttm-tab.active { color: var(--red); border-bottom-color: var(--red); }

/* ── CATEGORY SECTION ── */
.ttm-cat { padding-bottom: 8px; }
.ttm-cat-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 16px 10px;
}
.ttm-cat-title { font-size: 14px; font-weight: 800; color: var(--text); }
.ttm-cat-count  { font-size: 10px; color: var(--muted); }

/* ── PRODUCT LIST (single col, restaurant style) ── */
.ttm-list { display: flex; flex-direction: column; gap: 0; }

.ttm-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  text-decoration: none; color: var(--text);
  background: var(--bg);
  transition: background .15s;
  -webkit-tap-highlight-color: transparent;
  position: relative;
}
.ttm-item:active { background: var(--bg2); }

/* left: info */
.ttm-item-info { flex: 1; min-width: 0; }
.ttm-item-badge {
  display: inline-block;
  font-size: 8px; font-weight: 900; letter-spacing: 0.8px; text-transform: uppercase;
  padding: 2px 7px; border-radius: 100px; margin-bottom: 4px;
}
.ttm-item-badge--best { background: linear-gradient(90deg,var(--gold),color-mix(in srgb,var(--gold) 70%,#fff)); color: #1a0800; }
.ttm-item-badge--hot  { background: var(--red); color: #fff; }
.ttm-item-badge--new  { background: color-mix(in srgb,var(--gold) 15%,var(--bg2)); border: 1px solid color-mix(in srgb,var(--gold) 35%,transparent); color: var(--gold); }

.ttm-item-name {
  font-size: 13px; font-weight: 700; line-height: 1.3;
  color: var(--text);
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  margin-bottom: 4px;
}
.ttm-item-desc {
  font-size: 11px; color: var(--muted); line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;
  margin-bottom: 6px;
}
.ttm-item-price-row { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.ttm-item-price   { font-size: 14px; font-weight: 900; color: var(--text); }
.ttm-item-compare { font-size: 11px; color: var(--muted); text-decoration: line-through; }
.ttm-item-save    { font-size: 9px; font-weight: 800; color: var(--red); }

/* right: image + add button */
.ttm-item-right { flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 6px; }
.ttm-item-img {
  width: 80px; height: 80px;
  border-radius: 10px; overflow: hidden;
  background: var(--bg2);
  border: 1px solid var(--border);
  flex-shrink: 0;
  position: relative;
}
.ttm-item-img img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  display: block;
}
.ttm-item-img-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; opacity: .35;
}

.ttm-add-btn {
  width: 72px;
  padding: 6px 0;
  background: var(--bg);
  border: 1.5px solid var(--red);
  border-radius: 7px;
  font-size: 11px; font-weight: 800; color: var(--red);
  cursor: pointer; text-align: center;
  transition: background .15s, color .15s;
  -webkit-tap-highlight-color: transparent;
}
.ttm-add-btn:active,
.ttm-add-btn:hover { background: var(--red); color: #fff; }
.ttm-add-btn[data-loading] { opacity: 0.5; pointer-events: none; }

.ttm-sold-tag {
  width: 72px; padding: 6px 0;
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 7px; font-size: 10px; font-weight: 700;
  color: var(--muted); text-align: center;
}

/* sold out dim */
.ttm-item.ttm-sold .ttm-item-img { opacity: 0.5; }
.ttm-item.ttm-sold .ttm-item-name { opacity: 0.5; }

/* ── EMPTY ── */
.ttm-empty { text-align: center; padding: 60px 20px; color: var(--muted); }
.ttm-empty-icon { font-size: 48px; margin-bottom: 12px; }
.ttm-empty-text { font-size: 16px; font-weight: 700; color: var(--text); }

/* ── STEPPER ── */
.ttm-stepper {
  display: flex; align-items: center;
  width: 72px; height: 28px;
  border: 1.5px solid var(--red);
  border-radius: 7px; overflow: hidden;
  background: var(--red);
}
.ttm-stepper__btn {
  flex: 0 0 24px; height: 100%;
  border: none; background: none;
  color: #fff; font-size: 16px; font-weight: 900;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  -webkit-tap-highlight-color: transparent;
  transition: background .1s;
}
.ttm-stepper__btn:active { background: rgba(0,0,0,.15); }
.ttm-stepper__val {
  flex: 1; text-align: center;
  font-size: 13px; font-weight: 900; color: #fff;
  pointer-events: none;
}
.ttm-stepper[data-loading] { opacity: 0.6; pointer-events: none; }

/* ── TOAST ── */
.ttm-toast {
  position: fixed; bottom: 80px; left: 50%;
  transform: translateX(-50%) translateY(12px);
  z-index: 9999; pointer-events: none;
  background: var(--bg2);
  border: 1px solid color-mix(in srgb, var(--gold) 35%, var(--border));
  border-radius: 10px; padding: 10px 16px;
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; font-weight: 700; color: var(--text);
  box-shadow: 0 4px 24px rgba(0,0,0,0.15);
  white-space: nowrap; max-width: calc(100vw - 32px);
  opacity: 0; transition: opacity .25s, transform .25s;
}
.ttm-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

.ttm-end { height: 40px; }
</style>

<div class="ttm">

  <!-- COMPACT HEADER -->
  <div class="ttm-header">
    <div class="ttm-header-logo">
      {%- if collection.image -%}
        <img src="{{ collection.image | img_url: '120x120', crop: 'center' }}" alt="{{ collection.title | escape }}" loading="eager">
      {%- else -%}
        <img src="{{ 'Typical taste mulpani logo.png' | asset_url }}" alt="{{ collection.title | escape }}" loading="eager">
      {%- endif -%}
    </div>
    <div class="ttm-header-info">
      <div class="ttm-header-name">{{ collection.title }}</div>
      <div class="ttm-header-sub">
        {%- assign desc_text = collection.description | strip_html | strip | truncate: 60 -%}
        {%- if desc_text != blank -%}{{ desc_text }}{%- else -%}Premium Food · Order Online{%- endif -%}
      </div>
      <div class="ttm-header-badges">
        <span class="ttm-header-badge ttm-header-badge--open">● Open Now</span>
        <span class="ttm-header-badge">⚡ 18-22 min</span>
        <span class="ttm-header-badge">🚚 Free Delivery</span>
      </div>
    </div>
    <div class="ttm-header-right">
      <div class="ttm-header-rating">⭐ 4.8</div>
      <div class="ttm-header-rating-sub">{{ collection.products_count }} items</div>
    </div>
  </div>

  <!-- STICKY CATEGORY TABS -->
  <div class="ttm-tabs-wrap">
    <div class="ttm-tabs" id="ttmTabs">
      <button class="ttm-tab active" data-cat="all">All</button>
      {%- assign tab_keys   = 'biryani,combo,chicken,lollipop,snacks,drinks' | split: ',' -%}
      {%- assign tab_labels = '🍛 Biryani,🎁 Combos,🍗 Chicken,🍖 Lollipop,🍟 Snacks,🥤 Drinks' | split: ',' -%}
      {%- for ti in (0..5) -%}
        {%- assign tkey = tab_keys[ti] -%}
        {%- assign tcount = 0 -%}
        {%- for p in collection.products -%}
          {%- if tkey == 'biryani' and p.tags contains 'biryani' or tkey == 'biryani' and p.title contains 'Biryani' or tkey == 'biryani' and p.title contains 'biryani' -%}{%- assign tcount = tcount | plus: 1 -%}
          {%- elsif tkey == 'combo' and p.tags contains 'combo' or tkey == 'combo' and p.title contains 'Combo' -%}{%- assign tcount = tcount | plus: 1 -%}
          {%- elsif tkey == 'chicken' and p.tags contains 'chicken' or tkey == 'chicken' and p.title contains 'Chicken' -%}{%- assign tcount = tcount | plus: 1 -%}
          {%- elsif tkey == 'lollipop' and p.tags contains 'lollipop' or tkey == 'lollipop' and p.title contains 'Lollipop' or tkey == 'lollipop' and p.tags contains 'bbq' -%}{%- assign tcount = tcount | plus: 1 -%}
          {%- elsif tkey == 'snacks' and p.tags contains 'snack' or tkey == 'snacks' and p.tags contains 'starter' -%}{%- assign tcount = tcount | plus: 1 -%}
          {%- elsif tkey == 'drinks' and p.tags contains 'drink' or tkey == 'drinks' and p.tags contains 'beverage' -%}{%- assign tcount = tcount | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if tcount > 0 -%}
          <button class="ttm-tab" data-cat="{{ tkey }}">{{ tab_labels[ti] }}</button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- PRODUCTS -->
  <div id="ttmProducts">
  {%- if collection.products.size > 0 -%}

    {%- assign cat_keys   = 'biryani,combo,chicken,lollipop,snacks,drinks,other' | split: ',' -%}
    {%- assign cat_labels = '🍛 Biryani,🎁 Combo Deals,🍗 Chicken,🍖 Lollipop & BBQ,🍟 Snacks,🥤 Drinks,🍽️ More' | split: ',' -%}

    {%- for ci in (0..6) -%}
      {%- assign ckey   = cat_keys[ci] -%}
      {%- assign clabel = cat_labels[ci] -%}
      {%- assign ccount = 0 -%}
      {%- for p in collection.products -%}
        {%- assign m = false -%}
        {%- if ckey == 'biryani' and p.tags contains 'biryani' or ckey == 'biryani' and p.title contains 'Biryani' or ckey == 'biryani' and p.title contains 'biryani' -%}{%- assign m = true -%}
        {%- elsif ckey == 'combo' and p.tags contains 'combo' or ckey == 'combo' and p.title contains 'Combo' -%}{%- assign m = true -%}
        {%- elsif ckey == 'chicken' and p.tags contains 'chicken' or ckey == 'chicken' and p.title contains 'Chicken' -%}
          {%- unless p.tags contains 'lollipop' or p.title contains 'Lollipop' -%}{%- assign m = true -%}{%- endunless -%}
        {%- elsif ckey == 'lollipop' and p.tags contains 'lollipop' or ckey == 'lollipop' and p.title contains 'Lollipop' or ckey == 'lollipop' and p.tags contains 'bbq' -%}{%- assign m = true -%}
        {%- elsif ckey == 'snacks' and p.tags contains 'snack' or ckey == 'snacks' and p.tags contains 'starter' -%}{%- assign m = true -%}
        {%- elsif ckey == 'drinks' and p.tags contains 'drink' or ckey == 'drinks' and p.tags contains 'beverage' -%}{%- assign m = true -%}
        {%- elsif ckey == 'other' -%}
          {%- assign already = false -%}
          {%- if p.tags contains 'biryani' or p.title contains 'Biryani' or p.title contains 'biryani' -%}{%- assign already = true -%}{%- endif -%}
          {%- if p.tags contains 'combo' or p.title contains 'Combo' -%}{%- assign already = true -%}{%- endif -%}
          {%- if p.tags contains 'chicken' or p.title contains 'Chicken' -%}{%- assign already = true -%}{%- endif -%}
          {%- if p.tags contains 'lollipop' or p.title contains 'Lollipop' or p.tags contains 'bbq' -%}{%- assign already = true -%}{%- endif -%}
          {%- if p.tags contains 'snack' or p.tags contains 'starter' -%}{%- assign already = true -%}{%- endif -%}
          {%- if p.tags contains 'drink' or p.tags contains 'beverage' -%}{%- assign already = true -%}{%- endif -%}
          {%- unless already -%}{%- assign m = true -%}{%- endunless -%}
        {%- endif -%}
        {%- if m -%}{%- assign ccount = ccount | plus: 1 -%}{%- endif -%}
      {%- endfor -%}

      {%- if ccount > 0 -%}
      <div class="ttm-cat" data-section="{{ ckey }}">
        <div class="ttm-cat-header">
          <div class="ttm-cat-title">{{ clabel }}</div>
          <div class="ttm-cat-count">{{ ccount }} items</div>
        </div>
        <div class="ttm-list">
          {%- for p in collection.products -%}
            {%- assign m = false -%}
            {%- if ckey == 'biryani' and p.tags contains 'biryani' or ckey == 'biryani' and p.title contains 'Biryani' or ckey == 'biryani' and p.title contains 'biryani' -%}{%- assign m = true -%}
            {%- elsif ckey == 'combo' and p.tags contains 'combo' or ckey == 'combo' and p.title contains 'Combo' -%}{%- assign m = true -%}
            {%- elsif ckey == 'chicken' and p.tags contains 'chicken' or ckey == 'chicken' and p.title contains 'Chicken' -%}
              {%- unless p.tags contains 'lollipop' or p.title contains 'Lollipop' -%}{%- assign m = true -%}{%- endunless -%}
            {%- elsif ckey == 'lollipop' and p.tags contains 'lollipop' or ckey == 'lollipop' and p.title contains 'Lollipop' or ckey == 'lollipop' and p.tags contains 'bbq' -%}{%- assign m = true -%}
            {%- elsif ckey == 'snacks' and p.tags contains 'snack' or ckey == 'snacks' and p.tags contains 'starter' -%}{%- assign m = true -%}
            {%- elsif ckey == 'drinks' and p.tags contains 'drink' or ckey == 'drinks' and p.tags contains 'beverage' -%}{%- assign m = true -%}
            {%- elsif ckey == 'other' -%}
              {%- assign already = false -%}
              {%- if p.tags contains 'biryani' or p.title contains 'Biryani' or p.title contains 'biryani' -%}{%- assign already = true -%}{%- endif -%}
              {%- if p.tags contains 'combo' or p.title contains 'Combo' -%}{%- assign already = true -%}{%- endif -%}
              {%- if p.tags contains 'chicken' or p.title contains 'Chicken' -%}{%- assign already = true -%}{%- endif -%}
              {%- if p.tags contains 'lollipop' or p.title contains 'Lollipop' or p.tags contains 'bbq' -%}{%- assign already = true -%}{%- endif -%}
              {%- if p.tags contains 'snack' or p.tags contains 'starter' -%}{%- assign already = true -%}{%- endif -%}
              {%- if p.tags contains 'drink' or p.tags contains 'beverage' -%}{%- assign already = true -%}{%- endif -%}
              {%- unless already -%}{%- assign m = true -%}{%- endunless -%}
            {%- endif -%}
            {%- if m -%}
              {%- assign sold = false -%}
              {%- unless p.available -%}{%- assign sold = true -%}{%- endunless -%}
              {%- assign disc = false -%}
              {%- if p.compare_at_price > p.price -%}
                {%- assign disc = true -%}
                {%- assign sv = p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price -%}
              {%- endif -%}
              {%- assign badge = '' -%}
              {%- if p.tags contains 'best-seller' -%}{%- assign badge = 'best' -%}
              {%- elsif p.tags contains 'hot' -%}{%- assign badge = 'hot' -%}
              {%- elsif p.tags contains 'new' -%}{%- assign badge = 'new' -%}
              {%- endif -%}

              <a href="{{ p.url }}" class="ttm-item{% if sold %} ttm-sold{% endif %}">
                <div class="ttm-item-info">
                  {%- if badge == 'best' -%}<div class="ttm-item-badge ttm-item-badge--best">⭐ Best Seller</div>
                  {%- elsif badge == 'hot' -%}<div class="ttm-item-badge ttm-item-badge--hot">🔥 Hot</div>
                  {%- elsif badge == 'new' -%}<div class="ttm-item-badge ttm-item-badge--new">New</div>
                  {%- endif -%}
                  <div class="ttm-item-name">{{ p.title }}</div>
                  {%- if p.description != blank -%}
                    <div class="ttm-item-desc">{{ p.description | strip_html | truncate: 60 }}</div>
                  {%- endif -%}
                  <div class="ttm-item-price-row">
                    <span class="ttm-item-price">Rs {{ p.price | divided_by: 100 }}</span>
                    {%- if disc -%}
                      <span class="ttm-item-compare">Rs {{ p.compare_at_price | divided_by: 100 }}</span>
                      <span class="ttm-item-save">{{ sv }}% off</span>
                    {%- endif -%}
                  </div>
                </div>
                <div class="ttm-item-right">
                  <div class="ttm-item-img">
                    {%- if p.featured_image -%}
                      <img src="{{ p.featured_image | img_url: '160x160', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
                    {%- else -%}
                      <div class="ttm-item-img-placeholder">🍛</div>
                    {%- endif -%}
                  </div>
                  {%- if sold -%}
                    <div class="ttm-sold-tag">Sold Out</div>
                  {%- else -%}
                    <div data-btn-vid="{{ p.first_available_variant.id }}">
                      <button class="ttm-add-btn" onclick="ttmAdd(event,'{{ p.first_available_variant.id }}',this)">+ ADD</button>
                    </div>
                  {%- endif -%}
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      {%- endif -%}
    {%- endfor -%}

  {%- else -%}
    <div class="ttm-empty">
      <div class="ttm-empty-icon">🍛</div>
      <div class="ttm-empty-text">Menu coming soon</div>
    </div>
  {%- endif -%}
  </div>

  <div class="ttm-end"></div>

  <div class="ttm-toast" id="ttmToast">
    <span id="ttmToastIcon">✅</span>
    <span id="ttmToastMsg">Added!</span>
  </div>

</div>

<script>
(function(){
  /* ── cart state: variantId (string) → quantity ── */
  var ttmCart = {};

  /* ── dispatch cart:update with proper itemCount detail ── */
  function dispatchCartUpdate(itemCount){
    var ev = new Event('cart:update', { bubbles: true });
    ev.detail = { data: { itemCount: itemCount } };
    document.dispatchEvent(ev);
  }

  /* ── fetch /cart.js and sync all stepper buttons ── */
  function syncCart(cb){
    fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r){ return r.json(); })
      .then(function(cart){
        ttmCart = {};
        cart.items.forEach(function(item){
          ttmCart[String(item.variant_id)] = item.quantity;
        });
        updateAllBtns();
        dispatchCartUpdate(cart.item_count);
        if(cb) cb(cart);
      });
  }

  /* ── render a single add-btn container for a variantId ── */
  function renderBtnFor(variantId, container){
    var qty = ttmCart[String(variantId)] || 0;
    if(qty > 0){
      container.innerHTML =
        '<div class="ttm-stepper" data-vid="'+variantId+'">' +
          '<button class="ttm-stepper__btn" onclick="ttmStep(event,\''+variantId+'\',-1,this.closest(\'.ttm-stepper\'))">−</button>' +
          '<span class="ttm-stepper__val">'+qty+'</span>' +
          '<button class="ttm-stepper__btn" onclick="ttmStep(event,\''+variantId+'\',1,this.closest(\'.ttm-stepper\'))">+</button>' +
        '</div>';
    } else {
      container.innerHTML =
        '<button class="ttm-add-btn" onclick="ttmAdd(event,\''+variantId+'\',this)">+ ADD</button>';
    }
  }

  /* ── update all button containers on the page ── */
  function updateAllBtns(){
    document.querySelectorAll('[data-btn-vid]').forEach(function(el){
      renderBtnFor(el.getAttribute('data-btn-vid'), el);
    });
  }

  /* ── tabs ── */
  var tabs     = document.querySelectorAll('.ttm-tab');
  var sections = document.querySelectorAll('[data-section]');
  tabs.forEach(function(tab){
    tab.addEventListener('click', function(){
      tabs.forEach(function(t){ t.classList.remove('active'); });
      tab.classList.add('active');
      var cat = tab.getAttribute('data-cat');
      sections.forEach(function(s){
        s.style.display = (cat === 'all' || s.getAttribute('data-section') === cat) ? '' : 'none';
      });
      var target = cat === 'all' ? document.getElementById('ttmProducts') : document.querySelector('[data-section="'+cat+'"]');
      if(target){ var y = target.getBoundingClientRect().top + window.scrollY - 90; window.scrollTo({ top: y, behavior: 'smooth' }); }
    });
  });

  /* ── toast ── */
  var toast = document.getElementById('ttmToast');
  var toastMsg = document.getElementById('ttmToastMsg');
  var toastIcon = document.getElementById('ttmToastIcon');
  var toastT;
  function showToast(icon, msg){
    toastIcon.textContent = icon; toastMsg.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastT);
    toastT = setTimeout(function(){ toast.classList.remove('show'); }, 2400);
  }

  /* ── add to cart ── */
  window.ttmAdd = function(e, variantId, btn){
    e.preventDefault(); e.stopPropagation();
    if(btn.hasAttribute('data-loading')) return;
    btn.setAttribute('data-loading','1');
    btn.textContent = '…';
    fetch('/cart/add.js',{
      method:'POST',
      headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r){ return r.json(); })
    .then(function(d){
      if(d.status){ showToast('⚠️', d.description || 'Error'); btn.removeAttribute('data-loading'); btn.textContent = '+ ADD'; return; }
      showToast('✅', d.product_title + ' added!');
      ttmCart[String(variantId)] = (ttmCart[String(variantId)] || 0) + 1;
      /* update the button container immediately, then sync full cart */
      var container = btn.closest('[data-btn-vid]');
      if(container) renderBtnFor(variantId, container);
      syncCart(function(cart){
        var drawer = document.querySelector('cart-drawer-component');
        if(drawer && typeof drawer.open === 'function') drawer.open();
      });
    })
    .catch(function(){ showToast('❌','Try again'); btn.removeAttribute('data-loading'); btn.textContent = '+ ADD'; });
  };

  /* ── stepper +/- ── */
  window.ttmStep = function(e, variantId, delta, stepper){
    e.preventDefault(); e.stopPropagation();
    if(stepper.hasAttribute('data-loading')) return;
    var current = ttmCart[String(variantId)] || 0;
    var newQty = Math.max(0, current + delta);
    stepper.setAttribute('data-loading','1');
    /* optimistic UI */
    ttmCart[String(variantId)] = newQty;
    var valEl = stepper.querySelector('.ttm-stepper__val');
    if(valEl) valEl.textContent = newQty;
    fetch('/cart/change.js',{
      method:'POST',
      headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
      body: JSON.stringify({ id: variantId, quantity: newQty })
    })
    .then(function(r){ return r.json(); })
    .then(function(){
      syncCart();
    })
    .catch(function(){
      showToast('❌','Try again');
      /* revert */
      ttmCart[String(variantId)] = current;
      syncCart();
    });
  };

  /* ── init: load cart state on page load ── */
  syncCart();
})();
</script>

