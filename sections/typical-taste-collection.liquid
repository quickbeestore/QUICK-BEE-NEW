              <div class="tt-card-body">
                <div class="tt-veg-row">
                  {%- if _ptl contains 'chicken' or _ptl contains 'mutton' or _ptl contains 'beef' or _ptl contains 'egg' or _ptl contains 'fish' or _tags contains 'non-veg' -%}
