{%- comment -%}
  Typical Taste Collection — Swiggy / Zomato / Uber Eats inspired
  sections/typical-taste-collection.liquid
{%- endcomment -%}

{%- liquid
  assign all_products = collection.products

  assign has_drinks   = false | append: '' | split: ','
  assign drink_count  = 0
  assign has_biryani  = false
  assign biryani_count = 0
  assign has_snacks   = false
  assign snack_count  = 0
  assign has_specials = false
  assign special_count = 0
  assign has_mains    = false
  assign main_count   = 0
  assign has_desserts = false
  assign dessert_count = 0
  assign has_others   = false
  assign other_count  = 0

  assign has_drinks   = false

  for p in all_products
    assign pt = p.type | downcase | strip
    if pt contains 'drink' or pt contains 'tea' or pt contains 'coffee' or pt contains 'juice' or pt contains 'shake' or pt contains 'smoothie' or pt contains 'water' or pt contains 'soda' or pt contains 'lemon' or pt contains 'beverage' or pt contains 'lassi' or pt contains 'mocktail' or pt contains 'milk'
      assign has_drinks = true
      assign drink_count = drink_count | plus: 1
    elsif pt contains 'biryani' or pt contains 'rice' or pt contains 'pulao'
      assign has_biryani = true
      assign biryani_count = biryani_count | plus: 1
    elsif pt contains 'snack' or pt contains 'fries' or pt contains 'chips' or pt contains 'momo' or pt contains 'roll' or pt contains 'pakora' or pt contains 'samosa' or pt contains 'sandwich' or pt contains 'wrap'
      assign has_snacks = true
      assign snack_count = snack_count | plus: 1
    elsif pt contains 'special' or pt contains 'combo' or pt contains 'deal' or pt contains 'set'
      assign has_specials = true
      assign special_count = special_count | plus: 1
    elsif pt contains 'main' or pt contains 'curry' or pt contains 'dal' or pt contains 'thali' or pt contains 'plate' or pt contains 'meal' or pt contains 'chicken' or pt contains 'mutton'
      assign has_mains = true
      assign main_count = main_count | plus: 1
    elsif pt contains 'dessert' or pt contains 'sweet' or pt contains 'cake' or pt contains 'ice' or pt contains 'pudding' or pt contains 'brownie'
      assign has_desserts = true
      assign dessert_count = dessert_count | plus: 1
    else
      assign has_others = true
      assign other_count = other_count | plus: 1
    endif
  endfor
-%}

<style>
/* ============================================================
   TYPICAL TASTE — Food Delivery UI
   Swiggy × Zomato × Uber Eats inspired
   ============================================================ */

:root {
  --tt-bg:       #fafafa;
  --tt-card:     #ffffff;
  --tt-border:   #efefef;
  --tt-text:     #1a1a1a;
  --tt-text2:    #666666;
  --tt-text3:    #999999;
  --tt-acc:      #FF7A00;
  --tt-acc-fg:   #ffffff;
  --tt-acc2:     #e86e00;
  --tt-green:    #22c55e;
  --tt-red:      #ef4444;
  --tt-shadow:   0 2px 12px rgba(0,0,0,0.08);
  --tt-shadow-lg:0 8px 32px rgba(0,0,0,0.12);
  --tt-topbar:   #ffffff;
  --tt-pill-bg:  #f2f2f2;
  --tt-pill-fg:  #444444;
  --tt-pill-act: #FF7A00;
  --tt-pill-act-fg: #ffffff;
  --tt-drawer-bg:#ffffff;
  --tt-upsell-bg:#fff8f2;
}
[data-theme="dark"] {
  --tt-bg:       #0B0B0B;
  --tt-card:     #161616;
  --tt-border:   #252525;
  --tt-text:     #f2f2f2;
  --tt-text2:    #909090;
  --tt-text3:    #555555;
  --tt-acc:      #FF7A00;
  --tt-acc-fg:   #ffffff;
  --tt-acc2:     #e86e00;
  --tt-green:    #22c55e;
  --tt-red:      #f87171;
  --tt-shadow:   0 2px 12px rgba(0,0,0,0.45);
  --tt-shadow-lg:0 8px 32px rgba(0,0,0,0.55);
  --tt-topbar:   #111111;
  --tt-pill-bg:  #1e1e1e;
  --tt-pill-fg:  #cccccc;
  --tt-pill-act: #FF7A00;
  --tt-pill-act-fg: #ffffff;
  --tt-drawer-bg:#111111;
  --tt-upsell-bg:#1a1200;
}

/* ── Reset ─────────────────────────────────────────── */
.tt-wrap *, .tt-wrap *::before, .tt-wrap *::after { box-sizing: border-box; }
.tt-wrap { background: var(--tt-bg); min-height: 100vh; font-family: inherit; }

/* ── Keyframes ─────────────────────────────────────── */
@keyframes tt-fadein  { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
@keyframes tt-pop     { 0%{transform:scale(0.8);opacity:0} 70%{transform:scale(1.06)} 100%{transform:scale(1);opacity:1} }
@keyframes tt-spin    { to{transform:rotate(360deg)} }
@keyframes tt-bounce  { 0%{transform:scale(1)} 35%{transform:scale(0.87)} 65%{transform:scale(1.07)} 100%{transform:scale(1)} }
@keyframes tt-drawer-in { from{transform:translateX(100%)} to{transform:translateX(0)} }
@keyframes tt-overlay-in { from{opacity:0} to{opacity:1} }
@keyframes tt-slide-right { from{transform:translateX(-20px);opacity:0} to{transform:translateX(0);opacity:1} }

/* ── Sticky Top Bar ────────────────────────────────── */
.tt-topbar {
  position: sticky;
  top: 0;
  z-index: 500;
  background: var(--tt-topbar);
  border-bottom: 1px solid var(--tt-border);
  padding: 10px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.tt-topbar-brand {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}
.tt-topbar-name {
  font-size: 15px;
  font-weight: 800;
  color: var(--tt-text);
  line-height: 1.1;
}
.tt-topbar-loc {
  font-size: 11px;
  color: var(--tt-acc);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 3px;
}
.tt-search-wrap {
  flex: 1;
  position: relative;
}
.tt-search-wrap svg {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--tt-text3);
  pointer-events: none;
}
.tt-search {
  width: 100%;
  padding: 9px 14px 9px 36px;
  background: var(--tt-pill-bg);
  border: 1.5px solid var(--tt-border);
  border-radius: 24px;
  font-size: 14px;
  color: var(--tt-text);
  transition: border-color 0.2s, box-shadow 0.2s;
}
.tt-search::placeholder { color: var(--tt-text3); }
.tt-search:focus { outline: none; border-color: var(--tt-acc); box-shadow: 0 0 0 3px rgba(255,122,0,0.12); }
.tt-cart-icon-btn {
  position: relative;
  width: 40px;
  height: 40px;
  background: var(--tt-acc);
  border: none;
  border-radius: 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.2s, background 0.2s;
}
.tt-cart-icon-btn:hover { background: var(--tt-acc2); transform: scale(1.05); }
.tt-cart-icon-btn svg { color: #fff; }
.tt-cart-icon-count {
  position: absolute;
  top: -5px;
  right: -5px;
  background: var(--tt-red);
  color: #fff;
  font-size: 9px;
  font-weight: 800;
  width: 17px;
  height: 17px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--tt-topbar);
  opacity: 0;
  transform: scale(0);
  transition: all 0.22s cubic-bezier(0.34,1.56,0.64,1);
}
.tt-cart-icon-count.visible { opacity: 1; transform: scale(1); }

/* ── Category Pills ────────────────────────────────── */
.tt-pills-outer {
  position: sticky;
  top: 61px;
  z-index: 400;
  background: var(--tt-topbar);
  border-bottom: 1px solid var(--tt-border);
}
.tt-pills {
  display: flex;
  gap: 8px;
  padding: 10px 16px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.tt-pills::-webkit-scrollbar { display: none; }
.tt-pill {
  flex-shrink: 0;
  padding: 7px 16px;
  background: var(--tt-pill-bg);
  color: var(--tt-pill-fg);
  border: 1.5px solid transparent;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}
.tt-pill:hover { border-color: var(--tt-acc); color: var(--tt-acc); }
.tt-pill.active {
  background: var(--tt-acc);
  color: var(--tt-pill-act-fg);
  border-color: var(--tt-acc);
  box-shadow: 0 3px 10px rgba(255,122,0,0.3);
}

/* ── Content ───────────────────────────────────────── */
.tt-content { padding: 8px 12px 160px; }

/* ── Section head ──────────────────────────────────── */
.tt-sec {
  margin-bottom: 6px;
}
.tt-sec-head {
  position: sticky;
  top: 109px;
  z-index: 300;
  background: var(--tt-bg);
  padding: 14px 4px 10px;
  font-size: 17px;
  font-weight: 800;
  color: var(--tt-text);
  display: flex;
  align-items: center;
  gap: 8px;
}
.tt-sec-head::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--tt-border);
  margin-left: 8px;
}
.tt-sec-count {
  font-size: 12px;
  font-weight: 600;
  color: var(--tt-text3);
  background: var(--tt-pill-bg);
  padding: 2px 8px;
  border-radius: 10px;
}

/* ── Product Grid ──────────────────────────────────── */
.tt-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding-bottom: 8px;
}
@media(min-width: 600px) { .tt-grid { grid-template-columns: repeat(3, 1fr); gap: 14px; } }
@media(min-width: 1024px){ .tt-grid { grid-template-columns: repeat(4, 1fr); gap: 16px; } }

/* ── Product Card ──────────────────────────────────── */
.tt-card {
  background: var(--tt-card);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: var(--tt-shadow);
  border: 1px solid var(--tt-border);
  transition: transform 0.22s ease, box-shadow 0.22s ease;
  animation: tt-fadein 0.4s ease both;
  display: flex;
  flex-direction: column;
}
.tt-card:hover { transform: translateY(-3px); box-shadow: var(--tt-shadow-lg); }
.tt-card-img-wrap {
  position: relative;
  aspect-ratio: 4/3;
  overflow: hidden;
  background: var(--tt-pill-bg);
}
.tt-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s ease;
}
.tt-card:hover .tt-card-img { transform: scale(1.06); }
.tt-no-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44px;
  background: linear-gradient(135deg, var(--tt-pill-bg) 0%, var(--tt-border) 100%);
}
.tt-delivery-badge {
  position: absolute;
  bottom: 8px;
  left: 8px;
  background: rgba(0,0,0,0.72);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 10px;
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  gap: 3px;
}
.tt-badges {
  position: absolute;
  top: 8px;
  left: 8px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.tt-badge {
  font-size: 9px;
  font-weight: 800;
  padding: 2px 7px;
  border-radius: 6px;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  display: inline-flex;
  align-items: center;
  gap: 3px;
}
.tt-badge--bestseller { background: var(--tt-acc); color: #fff; }
.tt-badge--new        { background: var(--tt-green); color: #fff; }
.tt-badge--fast       { background: rgba(0,0,0,0.7); color: #fff; backdrop-filter:blur(4px); }
.tt-badge--deal       { background: var(--tt-red); color: #fff; }

.tt-card-body {
  padding: 10px 10px 10px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.tt-veg-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 5px;
}
.tt-veg-dot, .tt-nonveg-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.tt-veg-dot    { background: var(--tt-green); }
.tt-nonveg-dot { background: var(--tt-red); }
.tt-card-name {
  font-size: 13px;
  font-weight: 800;
  color: var(--tt-text);
  margin: 0 0 3px;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.tt-card-desc {
  font-size: 11px;
  color: var(--tt-text2);
  margin: 0 0 8px;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.tt-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  margin-top: auto;
}
.tt-price-wrap { display: flex; flex-direction: column; }
.tt-price {
  font-size: 14px;
  font-weight: 800;
  color: var(--tt-text);
}
.tt-price-compare {
  font-size: 11px;
  color: var(--tt-text3);
  text-decoration: line-through;
  line-height: 1;
}
.tt-add-btn {
  flex-shrink: 0;
  padding: 6px 14px;
  background: transparent;
  border: 2px solid var(--tt-acc);
  color: var(--tt-acc);
  border-radius: 10px;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.18s ease;
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}
.tt-add-btn:hover { background: var(--tt-acc); color: var(--tt-acc-fg); transform: scale(1.05); }
.tt-add-btn:active { transform: scale(0.95); }
.tt-add-btn.loading {
  color: transparent !important;
  pointer-events: none;
  background: var(--tt-acc) !important;
}
.tt-add-btn.loading::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 14px; height: 14px;
  margin: -7px 0 0 -7px;
  border: 2.5px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: tt-spin 0.5s linear infinite;
}
.tt-add-btn.success {
  background: var(--tt-green) !important;
  border-color: var(--tt-green) !important;
  color: #fff !important;
  pointer-events: none;
  animation: tt-bounce 0.35s cubic-bezier(0.34,1.56,0.64,1) forwards;
}

/* Stepper */
.tt-stepper {
  display: none;
  align-items: center;
  background: var(--tt-acc);
  border-radius: 10px;
  overflow: hidden;
  flex-shrink: 0;
}
.tt-stepper.visible { display: flex; animation: tt-pop 0.28s cubic-bezier(0.34,1.56,0.64,1); }
.tt-stepper-btn {
  width: 28px;
  height: 28px;
  background: none;
  border: none;
  color: #fff;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
}
.tt-stepper-btn:hover { background: rgba(0,0,0,0.15); }
.tt-stepper-btn:active { background: rgba(0,0,0,0.25); }
.tt-stepper-btn.busy { opacity: 0.4; pointer-events: none; }
.tt-stepper-qty {
  min-width: 22px;
  text-align: center;
  font-size: 13px;
  font-weight: 800;
  color: #fff;
}

/* ── Empty state ───────────────────────────────────── */
.tt-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 24px;
  text-align: center;
}
.tt-empty-icon { font-size: 64px; margin-bottom: 16px; animation: tt-pop 0.5s cubic-bezier(0.34,1.56,0.64,1); }
.tt-empty h3 { font-size: 20px; font-weight: 800; color: var(--tt-text); margin: 0 0 8px; }
.tt-empty p  { font-size: 14px; color: var(--tt-text2); margin: 0; }

/* ── Cart Drawer Overlay ───────────────────────────── */
.tt-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(2px);
}
.tt-overlay.open { opacity: 1; pointer-events: all; animation: tt-overlay-in 0.3s ease; }

/* ── Cart Drawer ───────────────────────────────────── */
.tt-drawer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: min(400px, 100vw);
  background: var(--tt-drawer-bg);
  z-index: 1001;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.38s cubic-bezier(0.25,0.46,0.45,0.94);
  box-shadow: -8px 0 40px rgba(0,0,0,0.3);
}
.tt-drawer.open { transform: translateX(0); animation: tt-drawer-in 0.38s cubic-bezier(0.25,0.46,0.45,0.94); }

.tt-drawer-head {
  padding: 18px 18px 14px;
  border-bottom: 1px solid var(--tt-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}
.tt-drawer-title {
  font-size: 18px;
  font-weight: 800;
  color: var(--tt-text);
}
.tt-drawer-close {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--tt-pill-bg);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--tt-text2);
  font-size: 18px;
  transition: all 0.2s;
}
.tt-drawer-close:hover { background: var(--tt-acc); color: #fff; }

.tt-drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: 12px 0;
  scrollbar-width: thin;
  scrollbar-color: var(--tt-border) transparent;
}

/* Cart items */
.tt-drawer-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 18px;
  transition: background 0.15s;
  animation: tt-slide-right 0.25s ease;
}
.tt-drawer-item:hover { background: rgba(255,122,0,0.04); }
.tt-ditem-img {
  width: 52px;
  height: 52px;
  border-radius: 10px;
  object-fit: cover;
  flex-shrink: 0;
  background: var(--tt-pill-bg);
}
.tt-ditem-info { flex: 1; min-width: 0; }
.tt-ditem-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--tt-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 3px;
}
.tt-ditem-price {
  font-size: 13px;
  font-weight: 800;
  color: var(--tt-acc);
}
.tt-ditem-stepper {
  display: flex;
  align-items: center;
  background: var(--tt-acc);
  border-radius: 8px;
  overflow: hidden;
  flex-shrink: 0;
}
.tt-ditem-btn {
  width: 26px;
  height: 26px;
  background: none;
  border: none;
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
}
.tt-ditem-btn:hover { background: rgba(0,0,0,0.2); }
.tt-ditem-qty {
  min-width: 20px;
  text-align: center;
  font-size: 12px;
  font-weight: 800;
  color: #fff;
}

/* Drawer empty */
.tt-drawer-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  text-align: center;
  padding: 32px;
  color: var(--tt-text2);
}
.tt-drawer-empty-icon { font-size: 56px; margin-bottom: 12px; }
.tt-drawer-empty-msg  { font-size: 15px; font-weight: 700; color: var(--tt-text); margin-bottom: 6px; }
.tt-drawer-empty-sub  { font-size: 13px; }

/* Divider */
.tt-drawer-divider {
  height: 1px;
  background: var(--tt-border);
  margin: 8px 18px;
}

/* Combos */
.tt-combos-wrap {
  padding: 12px 18px;
  border-top: 1px solid var(--tt-border);
  flex-shrink: 0;
}
.tt-combos-title {
  font-size: 12px;
  font-weight: 700;
  color: var(--tt-text3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}
.tt-combos-list {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 4px;
  scrollbar-width: none;
}
.tt-combos-list::-webkit-scrollbar { display: none; }
.tt-combo-pill {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 12px;
  background: var(--tt-upsell-bg);
  border: 1.5px solid var(--tt-acc);
  border-radius: 24px;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}
.tt-combo-pill:hover { background: var(--tt-acc); }
.tt-combo-pill:hover .tt-combo-text,
.tt-combo-pill:hover .tt-combo-price { color: #fff; }
.tt-combo-text { font-size: 12px; font-weight: 700; color: var(--tt-text); }
.tt-combo-price { font-size: 12px; font-weight: 800; color: var(--tt-acc); }
.tt-combo-add {
  font-size: 14px;
  font-weight: 800;
  color: var(--tt-acc);
  transition: color 0.2s;
}

/* Upsell */
.tt-upsell-wrap {
  padding: 12px 18px;
  border-top: 1px solid var(--tt-border);
  flex-shrink: 0;
}
.tt-upsell-title {
  font-size: 12px;
  font-weight: 700;
  color: var(--tt-text3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.tt-upsell-list {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  scrollbar-width: none;
}
.tt-upsell-list::-webkit-scrollbar { display: none; }
.tt-upsell-card {
  flex-shrink: 0;
  width: 110px;
  background: var(--tt-card);
  border: 1px solid var(--tt-border);
  border-radius: 12px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}
.tt-upsell-card:hover { transform: translateY(-2px); box-shadow: var(--tt-shadow); }
.tt-upsell-img {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  background: var(--tt-pill-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
}
.tt-upsell-img img { width: 100%; height: 100%; object-fit: cover; }
.tt-upsell-info { padding: 6px 8px; }
.tt-upsell-name {
  font-size: 10px;
  font-weight: 700;
  color: var(--tt-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 2px;
}
.tt-upsell-price {
  font-size: 10px;
  font-weight: 800;
  color: var(--tt-acc);
}

/* Drawer footer */
.tt-drawer-footer {
  padding: 14px 18px;
  border-top: 1px solid var(--tt-border);
  flex-shrink: 0;
  background: var(--tt-drawer-bg);
}
.tt-drawer-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}
.tt-drawer-total-label { font-size: 14px; font-weight: 600; color: var(--tt-text2); }
.tt-drawer-total-val   { font-size: 18px; font-weight: 800; color: var(--tt-text); }
.tt-checkout-btn {
  width: 100%;
  padding: 15px;
  background: var(--tt-acc);
  color: var(--tt-acc-fg);
  border: none;
  border-radius: 14px;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.22s cubic-bezier(0.34,1.56,0.64,1);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.tt-checkout-btn:hover { background: var(--tt-acc2); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255,122,0,0.4); }
.tt-checkout-btn:active { transform: scale(0.97); }

/* ── Mobile bottom bar ─────────────────────────────── */
.tt-mobile-bar {
  position: fixed;
  bottom: calc(65px + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%) translateY(calc(100% + 80px + env(safe-area-inset-bottom)));
  z-index: 900;
  width: calc(100% - 32px);
  max-width: 460px;
  background: var(--tt-acc);
  color: #fff;
  border-radius: 16px;
  padding: 14px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8px 28px rgba(255,122,0,0.45);
  cursor: pointer;
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
  -webkit-tap-highlight-color: transparent;
}
.tt-mobile-bar.visible {
  transform: translateX(-50%) translateY(0);
}
.tt-mobile-bar-left { display: flex; align-items: center; gap: 10px; }
.tt-mobile-bar-count {
  background: rgba(0,0,0,0.25);
  padding: 3px 10px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 800;
}
.tt-mobile-bar-info { display: flex; flex-direction: column; }
.tt-mobile-bar-sub  { font-size: 10px; font-weight: 600; opacity: 0.8; }
.tt-mobile-bar-total{ font-size: 15px; font-weight: 800; }
.tt-mobile-bar-cta  { font-size: 14px; font-weight: 800; display: flex; align-items: center; gap: 4px; }

/* ── Toast ─────────────────────────────────────────── */
.tt-toast {
  position: fixed;
  bottom: calc(145px + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%) translateY(0);
  background: #22c55e;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  padding: 10px 20px;
  border-radius: 24px;
  z-index: 9999;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.2s;
  white-space: nowrap;
  box-shadow: 0 4px 16px rgba(34,197,94,0.4);
}
.tt-toast.show { opacity: 1; }

/* ── Search hidden ─────────────────────────────────── */
.tt-card.tt-hidden { display: none !important; }
</style>

