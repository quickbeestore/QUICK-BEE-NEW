                {%- else -%}
                  <div class="tt-no-img">🍽️</div>
                {%- endif -%}
                <div class="tt-badges">
                  {%- if p.tags contains 'best-seller' or p.tags contains 'Popular' -%}<span class="tt-badge tt-badge--bestseller">🔥 Best Seller</span>{%- endif -%}
                  {%- if p.tags contains 'new' or p.tags contains 'New' -%}<span class="tt-badge tt-badge--new">✨ New</span>{%- endif -%}
