    {%- endif -%}
  </div>

  <!-- ── Cart Drawer ───────────────────────────────── -->
  <div class="tt-drawer" id="ttDrawer" role="dialog" aria-label="Your cart">
    <div class="tt-drawer-head">
      <span class="tt-drawer-title">🛒 Your Order</span>
      <button class="tt-drawer-close" id="ttDrawerClose" aria-label="Close cart">✕</button>
    </div>

    <div class="tt-drawer-body" id="ttDrawerBody">
      <div class="tt-drawer-empty" id="ttDrawerEmpty">
        <div class="tt-drawer-empty-icon">🍗</div>
        <p class="tt-drawer-empty-msg">Your cart is empty</p>
        <p class="tt-drawer-empty-sub">Start adding delicious food!</p>
