  <!-- ── Mobile Bottom Bar ─────────────────────────── -->
  <div class="tt-mobile-bar" id="ttMobileBar">
    <div class="tt-mobile-bar-left">
      <span class="tt-mobile-bar-count" id="ttBarCount">0</span>
      <div class="tt-mobile-bar-info">
        <span class="tt-mobile-bar-sub">items in cart</span>
        <span class="tt-mobile-bar-total" id="ttBarTotal">Rs 0</span>
      </div>
    </div>
    <span class="tt-mobile-bar-cta">View Cart →</span>
