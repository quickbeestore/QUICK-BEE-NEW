                {%- endif -%}
                <div class="tt-badges">
                  {%- if p.tags contains 'best-seller' or p.tags contains 'Popular' -%}<span class="tt-badge tt-badge--bestseller">🔥 Best Seller</span>{%- endif -%}
                </div>
                <div class="tt-delivery-badge">⚡ 15–20 mins</div>
              </div>
              <div class="tt-card-body">
                <h3 class="tt-card-name">{{ p.title }}</h3>
                {%- unless p.description == blank -%}
                  <p class="tt-card-desc">{{ p.description | strip_html | truncate: 55 }}</p>
                {%- endunless -%}
                <div class="tt-card-footer">
                  <div class="tt-price-wrap">
                    <span class="tt-price">Rs {{ pp | divided_by: 100 }}</span>
                    {%- if pcp > pp -%}<span class="tt-price-compare">Rs {{ pcp | divided_by: 100 }}</span>{%- endif -%}
                  </div>
                  <button class="tt-add-btn" data-vid="{{ vid }}">ADD +</button>
                  <div class="tt-stepper" data-vid="{{ vid }}">
                    <button class="tt-stepper-btn tt-stepper-minus" data-vid="{{ vid }}">−</button>
                    <span class="tt-stepper-qty" data-vid="{{ vid }}">1</span>
