<style>
/* ═══════════════════════════════════════════
   RAFTAAR SPEED — HOMEPAGE SECTION
═══════════════════════════════════════════ */
.rfs-root {
  background: #000;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  overflow: hidden;
  position: relative;
}

/* animated background */
.rfs-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 80% at 0% 50%, rgba(255,215,0,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 60% 60% at 100% 50%, rgba(255,106,0,0.05) 0%, transparent 55%),
    #000;
  pointer-events: none;
}

/* speed line streaks */
.rfs-lines {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.rfs-line {
  position: absolute;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,215,0,0.5), transparent);
  border-radius: 99px;
}
.rfs-line:nth-child(1) { top: 20%; width: 120px; animation: rfs-streak 2.0s 0.0s linear infinite; }
.rfs-line:nth-child(2) { top: 40%; width: 180px; animation: rfs-streak 1.7s 0.5s linear infinite; }
.rfs-line:nth-child(3) { top: 60%; width: 100px; animation: rfs-streak 2.3s 1.0s linear infinite; }
.rfs-line:nth-child(4) { top: 78%; width: 150px; animation: rfs-streak 1.9s 0.3s linear infinite; background: linear-gradient(90deg, transparent, rgba(255,106,0,0.5), transparent); }

@keyframes rfs-streak {
  0%   { transform: translateX(-100%) skewX(-10deg); opacity: 0; }
  15%  { opacity: 1; }
  100% { transform: translateX(110vw) skewX(-10deg); opacity: 0; }
}
@keyframes rfs-float {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-8px); }
}
@keyframes rfs-glow-pulse {
  0%,100% { box-shadow: 0 0 30px rgba(255,215,0,0.25), 0 0 80px rgba(255,106,0,0.1); }
  50%      { box-shadow: 0 0 50px rgba(255,215,0,0.5), 0 0 120px rgba(255,106,0,0.25); }
}
@keyframes rfs-btn-shine {
  0%   { left: -80%; }
  60%,100% { left: 120%; }
}
@keyframes rfs-ticker-scroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ── LAYOUT ── */
.rfs-inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 60px;
  max-width: 1140px;
  margin: 0 auto;
  padding: 90px 40px;
}

/* ── LEFT: TEXT ── */
.rfs-left {}

.rfs-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #FFD700;
  background: rgba(255,215,0,0.08);
  border: 1px solid rgba(255,215,0,0.2);
  padding: 6px 16px;
  border-radius: 99px;
  margin-bottom: 24px;
}

.rfs-title {
  font-size: clamp(40px, 7vw, 72px);
  font-weight: 900;
  letter-spacing: -2px;
  line-height: 0.95;
  text-transform: uppercase;
  background: linear-gradient(135deg, #FFD700, #FF6A00);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 14px;
  filter: drop-shadow(0 0 30px rgba(255,215,0,0.3));
}

.rfs-subtitle {
  font-size: clamp(13px, 2vw, 16px);
  font-weight: 700;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.45);
  margin-bottom: 20px;
}

.rfs-desc {
  font-size: clamp(16px, 2vw, 19px);
  font-weight: 600;
  color: rgba(255,255,255,0.8);
  line-height: 1.6;
  margin-bottom: 40px;
  max-width: 380px;
}

.rfs-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 40px;
}
.rfs-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 700;
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 7px 14px;
  border-radius: 99px;
  transition: border-color 0.2s, color 0.2s;
}
.rfs-pill:hover {
  border-color: rgba(255,215,0,0.35);
  color: #FFD700;
}

.rfs-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: linear-gradient(135deg, #FFD700, #FF6A00);
  color: #000;
  font-size: 15px;
  font-weight: 900;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 17px 44px;
  border-radius: 99px;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, filter 0.2s ease;
  animation: rfs-glow-pulse 3s ease-in-out infinite;
}
.rfs-cta::after {
  content: '';
  position: absolute;
  top: 0; left: -80%;
  width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: rfs-btn-shine 2.8s ease-in-out infinite;
}
.rfs-cta:hover {
  transform: scale(1.04) translateY(-2px);
  filter: brightness(1.08);
}

/* ── RIGHT: VISUAL ── */
.rfs-right {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.rfs-visual-card {
  background: #111;
  border: 1px solid rgba(255,215,0,0.1);
  border-radius: 20px;
  padding: 24px 28px;
  display: flex;
  align-items: center;
  gap: 20px;
  position: relative;
  overflow: hidden;
  transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}
.rfs-visual-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 60% at 0% 50%, rgba(255,215,0,0.05), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}
.rfs-visual-card:hover {
  transform: translateX(8px);
  border-color: rgba(255,215,0,0.3);
  box-shadow: 0 8px 30px rgba(255,215,0,0.08);
}
.rfs-visual-card:hover::before { opacity: 1; }

.rfs-vc-icon {
  font-size: 32px;
  flex-shrink: 0;
  animation: rfs-float 3s ease-in-out infinite;
}
.rfs-visual-card:nth-child(2) .rfs-vc-icon { animation-delay: 0.5s; }
.rfs-visual-card:nth-child(3) .rfs-vc-icon { animation-delay: 1s; }
.rfs-visual-card:nth-child(4) .rfs-vc-icon { animation-delay: 1.5s; }

.rfs-vc-body { flex: 1; min-width: 0; }
.rfs-vc-title {
  font-size: 16px;
  font-weight: 800;
  color: #fff;
  margin-bottom: 2px;
}
.rfs-vc-sub {
  font-size: 12px;
  color: rgba(255,255,255,0.4);
}

.rfs-vc-badge {
  font-size: 12px;
  font-weight: 900;
  background: linear-gradient(135deg, #FFD700, #FF6A00);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  white-space: nowrap;
  flex-shrink: 0;
}

/* progress bar on first card */
.rfs-visual-card:first-child .rfs-vc-progress {
  display: block;
}
.rfs-vc-progress {
  display: none;
  height: 3px;
  background: rgba(255,255,255,0.06);
  border-radius: 99px;
  margin-top: 10px;
  overflow: hidden;
  width: 100%;
}
.rfs-vc-progress-fill {
  height: 100%;
  width: 72%;
  background: linear-gradient(90deg, #FFD700, #FF6A00);
  border-radius: 99px;
  animation: rfs-streak 2s ease-in-out infinite alternate;
}

/* ── BOTTOM TICKER ── */
.rfs-ticker {
  position: relative;
  z-index: 2;
  border-top: 1px solid rgba(255,215,0,0.1);
  background: rgba(255,215,0,0.03);
  overflow: hidden;
  padding: 14px 0;
}
.rfs-ticker-track {
  display: flex;
  white-space: nowrap;
  width: max-content;
  animation: rfs-ticker-scroll 16s linear infinite;
}
.rfs-ticker-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0 36px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,215,0,0.7);
}
.rfs-ticker-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: #FF6A00;
  flex-shrink: 0;
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .rfs-inner {
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 64px 20px 48px;
  }
  .rfs-right { order: -1; }
  .rfs-visual-card { padding: 18px 20px; }
  .rfs-visual-card:hover { transform: none; }
  .rfs-title { letter-spacing: -1px; }
}
</style>

<section class="rfs-root">
  <div class="rfs-bg"></div>
  <div class="rfs-lines">
    <div class="rfs-line"></div>
    <div class="rfs-line"></div>
    <div class="rfs-line"></div>
    <div class="rfs-line"></div>
  </div>

  <div class="rfs-inner">

    <!-- LEFT: TEXT CONTENT -->
    <div class="rfs-left">
      <div class="rfs-chip">⚡ Introducing</div>
      <h2 class="rfs-title">{{ section.settings.title | default: 'Experience RAFTAAR ⚡' }}</h2>
      <div class="rfs-subtitle">{{ section.settings.subtitle | default: 'Speed of Quickbee' }}</div>
      <p class="rfs-desc">{{ section.settings.description | default: 'Delivered in minutes. No waiting. No excuses.' }}</p>

      <div class="rfs-pills">
        <span class="rfs-pill">⚡ 20-Min Delivery</span>
        <span class="rfs-pill">🚀 Instant Dispatch</span>
        <span class="rfs-pill">📍 Live Tracking</span>
        <span class="rfs-pill">🔥 24 / 7</span>
      </div>

      <a href="{{ section.settings.cta_link | default: '/pages/raftaar' }}" class="rfs-cta">
        <span>⚡</span> {{ section.settings.cta_text | default: 'Try Raftaar' }}
      </a>
    </div>

    <!-- RIGHT: SPEED VISUAL CARDS -->
    <div class="rfs-right">
      <div class="rfs-visual-card">
        <span class="rfs-vc-icon">🏍</span>
        <div class="rfs-vc-body">
          <div class="rfs-vc-title">Rider Dispatched</div>
          <div class="rfs-vc-sub">Arriving to you</div>
          <div class="rfs-vc-progress">
            <div class="rfs-vc-progress-fill"></div>
          </div>
        </div>
        <div class="rfs-vc-badge">~12 min</div>
      </div>

      <div class="rfs-visual-card">
        <span class="rfs-vc-icon">⚡</span>
        <div class="rfs-vc-body">
          <div class="rfs-vc-title">Instant Processing</div>
          <div class="rfs-vc-sub">Order confirmed live</div>
        </div>
        <div class="rfs-vc-badge">0 sec</div>
      </div>

      <div class="rfs-visual-card">
        <span class="rfs-vc-icon">📍</span>
        <div class="rfs-vc-body">
          <div class="rfs-vc-title">Smart Allocation</div>
          <div class="rfs-vc-sub">Nearest rider assigned</div>
        </div>
        <div class="rfs-vc-badge">Auto ✓</div>
      </div>

      <div class="rfs-visual-card">
        <span class="rfs-vc-icon">🔥</span>
        <div class="rfs-vc-body">
          <div class="rfs-vc-title">Real-Time Ops</div>
          <div class="rfs-vc-sub">Live monitoring, always</div>
        </div>
        <div class="rfs-vc-badge">24 / 7</div>
      </div>
    </div>

  </div>

  <!-- TICKER -->
  <div class="rfs-ticker">
    <div class="rfs-ticker-track">
      {% for i in (1..3) %}
        <span class="rfs-ticker-item"><span class="rfs-ticker-dot"></span> 20-Min Delivery</span>
        <span class="rfs-ticker-item"><span class="rfs-ticker-dot"></span> Instant Dispatch ⚡</span>
        <span class="rfs-ticker-item"><span class="rfs-ticker-dot"></span> Always On 🔥</span>
        <span class="rfs-ticker-item"><span class="rfs-ticker-dot"></span> Zero Delays 🚀</span>
        <span class="rfs-ticker-item"><span class="rfs-ticker-dot"></span> Fast Riders 🏍</span>
      {% endfor %}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Raftaar Speed",
  "tag": "section",
  "class": "raftaar-speed-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Experience RAFTAAR ⚡"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Speed of Quickbee"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Delivered in minutes. No waiting. No excuses."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Try Raftaar"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "presets": [
    {
      "name": "Raftaar Speed Section",
      "settings": {
        "title": "Experience RAFTAAR ⚡",
        "subtitle": "Speed of Quickbee",
        "description": "Delivered in minutes. No waiting. No excuses.",
        "cta_text": "Try Raftaar"
      }
    }
  ]
}
{% endschema %}
