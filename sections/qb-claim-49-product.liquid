{% comment %} sections/qb-claim-49-product.liquid — Claim Rs 49 Survey Product Template {% endcomment %}

<style>
html:not([data-theme="dark"]) .cp49-root {
  --cp-bg:        #F4F6FB;
  --cp-card:      #FFFFFF;
  --cp-text:      #0D0F1A;
  --cp-text2:     #5A6080;
  --cp-text3:     #9BA3B8;
  --cp-border:    rgba(0,0,0,0.07);
  --cp-gold:      #E6A800;
  --cp-gold2:     #F4B400;
  --cp-gold-bg:   rgba(244,180,0,0.10);
  --cp-hero-from: #080E20;
  --cp-hero-to:   #0D1A3A;
  --cp-inp-bg:    #F8F9FC;
  --cp-inp-border:#DDE0EC;
  --cp-shadow:    0 4px 20px rgba(0,0,0,0.07);
  --cp-shadow-lg: 0 12px 40px rgba(0,0,0,0.12);
}
html[data-theme="dark"] .cp49-root {
  --cp-bg:        #0A0C14;
  --cp-card:      #141828;
  --cp-text:      #EEF0FF;
  --cp-text2:     #7880A0;
  --cp-text3:     #454860;
  --cp-border:    rgba(255,255,255,0.07);
  --cp-gold:      #F4B400;
  --cp-gold2:     #FFD040;
  --cp-gold-bg:   rgba(244,180,0,0.08);
  --cp-hero-from: #060810;
  --cp-hero-to:   #0D1530;
  --cp-inp-bg:    #10111C;
  --cp-inp-border:rgba(255,255,255,0.10);
  --cp-shadow:    0 4px 28px rgba(0,0,0,0.4);
  --cp-shadow-lg: 0 12px 48px rgba(0,0,0,0.6);
}

.cp49-root {
  background: var(--cp-bg);
  color: var(--cp-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  min-height: 100vh;
  padding-bottom: 80px;
}
.cp49-root *, .cp49-root *::before, .cp49-root *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── HERO ── */
.cp49-hero {
  background: linear-gradient(160deg, var(--cp-hero-from) 0%, var(--cp-hero-to) 100%);
  position: relative; overflow: hidden;
  padding: 48px 20px 40px; text-align: center;
}
.cp49-hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% -10%, rgba(244,180,0,0.18) 0%, transparent 65%);
  pointer-events: none;
}
.cp49-hero-dots {
  position: absolute; inset: 0; pointer-events: none;
  background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 26px 26px;
}
.cp49-hero-inner { position: relative; z-index: 2; max-width: 500px; margin: 0 auto; }

.cp49-badge {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(244,180,0,0.15); border: 1px solid rgba(244,180,0,0.35);
  color: #F4B400; font-size: 11px; font-weight: 800;
  letter-spacing: 0.12em; text-transform: uppercase;
  padding: 6px 16px; border-radius: 999px; margin-bottom: 20px;
}
.cp49-badge-dot {
  width: 6px; height: 6px; background: #4ADE80; border-radius: 50%;
  box-shadow: 0 0 6px rgba(74,222,128,0.7);
  animation: cp49-pulse 1.8s ease-in-out infinite;
}
@keyframes cp49-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.6)} }

.cp49-amount {
  font-size: clamp(64px, 18vw, 108px); font-weight: 900; line-height: 1;
  background: linear-gradient(135deg, #F4B400 0%, #FFE066 50%, #F4B400 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  letter-spacing: -0.04em;
  filter: drop-shadow(0 4px 20px rgba(244,180,0,0.4));
}
.cp49-amount-sub {
  font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.45);
  letter-spacing: 0.1em; text-transform: uppercase; margin: 4px 0 14px;
}
.cp49-hero-title {
  font-size: clamp(20px, 5.5vw, 30px); font-weight: 900; color: #fff;
  line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 10px;
}
.cp49-hero-sub {
  font-size: 14px; color: rgba(255,255,255,0.55); line-height: 1.6;
  max-width: 380px; margin: 0 auto 24px;
}

/* countdown */
.cp49-timer-row {
  display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 20px;
}
.cp49-timer-label { font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.08em; }
.cp49-timer { display: flex; gap: 5px; align-items: center; }
.cp49-cd {
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 9px; padding: 7px 9px; text-align: center; min-width: 44px;
}
.cp49-cd-n { font-size: 20px; font-weight: 900; color: #F4B400; line-height: 1; font-variant-numeric: tabular-nums; }
.cp49-cd-u { font-size: 8px; font-weight: 700; color: rgba(255,255,255,0.35); text-transform: uppercase; margin-top: 2px; }
.cp49-cd-sep { font-size: 18px; font-weight: 900; color: rgba(244,180,0,0.45); margin-top: -4px; }

/* payment pills */
.cp49-pay-pills {
  display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; margin-bottom: 20px;
}
.cp49-pay-pill {
  display: flex; align-items: center; gap: 5px;
  background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);
  border-radius: 999px; padding: 5px 12px;
  font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.7);
}

/* step progress */
.cp49-progress {
  max-width: 500px; margin: 0 auto; padding: 20px 20px 0;
  display: flex; align-items: center; gap: 0;
}
.cp49-prog-step {
  flex: 1; text-align: center; position: relative;
}
.cp49-prog-step::after {
  content: ''; position: absolute; top: 14px; left: 50%; right: -50%;
  height: 2px; background: var(--cp-border); z-index: 0;
}
.cp49-prog-step:last-child::after { display: none; }
.cp49-prog-step.active::after,
.cp49-prog-step.done::after { background: var(--cp-gold); }
.cp49-prog-dot {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--cp-inp-bg); border: 2px solid var(--cp-border);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 800; color: var(--cp-text3);
  margin: 0 auto 4px; position: relative; z-index: 1;
  transition: all 0.25s;
}
.cp49-prog-step.active .cp49-prog-dot {
  background: var(--cp-gold); border-color: var(--cp-gold); color: #000;
  box-shadow: 0 0 0 4px rgba(244,180,0,0.2);
}
.cp49-prog-step.done .cp49-prog-dot {
  background: #22C55E; border-color: #22C55E; color: #fff;
}
.cp49-prog-label { font-size: 10px; font-weight: 600; color: var(--cp-text3); }
.cp49-prog-step.active .cp49-prog-label { color: var(--cp-gold); }

/* survey cards */
.cp49-survey { max-width: 500px; margin: 0 auto; padding: 20px 16px 0; }

.cp49-card {
  background: var(--cp-card); border: 1px solid var(--cp-border);
  border-radius: 20px; padding: 24px 20px;
  box-shadow: var(--cp-shadow);
  display: none;
  animation: cp49-slide-up 0.3s ease both;
}
.cp49-card.active { display: block; }
@keyframes cp49-slide-up { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }

.cp49-q-num {
  font-size: 10px; font-weight: 900; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--cp-gold); margin-bottom: 6px;
}
.cp49-q-title {
  font-size: 18px; font-weight: 900; color: var(--cp-text);
  line-height: 1.3; margin-bottom: 6px; letter-spacing: -0.01em;
}
.cp49-q-sub { font-size: 13px; color: var(--cp-text2); margin-bottom: 18px; line-height: 1.5; }

/* inputs */
.cp49-input, .cp49-select, .cp49-textarea {
  width: 100%; background: var(--cp-inp-bg); border: 1.5px solid var(--cp-inp-border);
  border-radius: 12px; padding: 13px 15px;
  font-size: 15px; color: var(--cp-text); outline: none;
  font-family: inherit; transition: border-color 0.2s;
}
.cp49-input:focus, .cp49-select:focus, .cp49-textarea:focus { border-color: var(--cp-gold); }
.cp49-input::placeholder, .cp49-textarea::placeholder { color: var(--cp-text3); }
.cp49-textarea { resize: vertical; min-height: 90px; }

/* option tiles */
.cp49-options { display: grid; gap: 10px; }
.cp49-options.cols-2 { grid-template-columns: 1fr 1fr; }
.cp49-opt-input { display: none; }
.cp49-opt-label {
  display: flex; align-items: center; gap: 10px;
  background: var(--cp-inp-bg); border: 1.5px solid var(--cp-inp-border);
  border-radius: 13px; padding: 13px 15px; cursor: pointer;
  font-size: 14px; font-weight: 600; color: var(--cp-text);
  transition: all 0.2s;
}
.cp49-opt-input:checked + .cp49-opt-label {
  border-color: var(--cp-gold); background: var(--cp-gold-bg);
  color: var(--cp-gold2);
}
.cp49-opt-emoji { font-size: 20px; flex-shrink: 0; }

/* multi-select chips */
.cp49-chips { display: flex; flex-wrap: wrap; gap: 8px; }
.cp49-chip-input { display: none; }
.cp49-chip-label {
  padding: 8px 16px; background: var(--cp-inp-bg);
  border: 1.5px solid var(--cp-inp-border);
  border-radius: 999px; font-size: 13px; font-weight: 700;
  color: var(--cp-text2); cursor: pointer; transition: all 0.18s;
}
.cp49-chip-input:checked + .cp49-chip-label {
  background: var(--cp-gold-bg); border-color: var(--cp-gold); color: var(--cp-gold2);
}

/* nav buttons */
.cp49-nav { display: flex; gap: 10px; margin-top: 20px; }
.cp49-btn-next {
  flex: 1; background: linear-gradient(135deg, #F4B400, #FFD040);
  color: #000; font-size: 15px; font-weight: 900;
  border: none; border-radius: 13px; padding: 15px;
  cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 6px 20px rgba(244,180,0,0.35);
}
.cp49-btn-next:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(244,180,0,0.5); }
.cp49-btn-next:active { transform: scale(0.97); }
.cp49-btn-next:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
.cp49-btn-back {
  background: var(--cp-inp-bg); border: 1.5px solid var(--cp-inp-border);
  color: var(--cp-text2); font-size: 15px; font-weight: 700;
  border-radius: 13px; padding: 15px 20px; cursor: pointer;
}

/* submit card */
.cp49-submit-card {
  max-width: 500px; margin: 20px auto 0; padding: 0 16px;
}
.cp49-submit-inner {
  background: var(--cp-card); border: 1px solid var(--cp-border);
  border-radius: 20px; padding: 24px 20px;
  box-shadow: var(--cp-shadow); text-align: center;
  display: none;
  animation: cp49-slide-up 0.3s ease both;
}
.cp49-submit-inner.active { display: block; }
.cp49-submit-trophy { font-size: 52px; margin-bottom: 12px; }
.cp49-submit-title { font-size: 22px; font-weight: 900; color: var(--cp-text); margin-bottom: 6px; }
.cp49-submit-sub { font-size: 14px; color: var(--cp-text2); line-height: 1.6; margin-bottom: 6px; }
.cp49-submit-amount {
  font-size: 40px; font-weight: 900;
  background: linear-gradient(135deg,#F4B400,#FFD040);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  margin: 8px 0 4px;
}
.cp49-submit-note { font-size: 12px; color: var(--cp-text3); margin-bottom: 20px; }
.cp49-pay-note {
  background: var(--cp-gold-bg); border: 1px solid rgba(244,180,0,0.2);
  border-radius: 12px; padding: 12px 16px;
  font-size: 13px; color: var(--cp-text2); text-align: left;
  margin-bottom: 16px; line-height: 1.6;
}
.cp49-pay-note strong { color: var(--cp-gold2); }
.cp49-checkout-btn {
  width: 100%; background: linear-gradient(135deg, #F4B400, #FFD040);
  color: #000; font-size: 17px; font-weight: 900;
  border: none; border-radius: 14px; padding: 17px;
  cursor: pointer; box-shadow: 0 8px 28px rgba(244,180,0,0.4);
  transition: transform 0.15s, box-shadow 0.15s;
}
.cp49-checkout-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 36px rgba(244,180,0,0.55); }
.cp49-checkout-btn:active { transform: scale(0.97); }
.cp49-checkout-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

/* locked */
.cp49-locked {
  display: none; text-align: center; padding: 64px 20px;
  max-width: 400px; margin: 0 auto;
}
.cp49-locked-icon { font-size: 56px; margin-bottom: 16px; }
.cp49-locked-title { font-size: 24px; font-weight: 900; color: var(--cp-text); margin-bottom: 8px; }
.cp49-locked-sub { font-size: 14px; color: var(--cp-text2); line-height: 1.6; }
</style>

<div class="cp49-root" id="cp49Root">

  <!-- ══ HERO ══ -->
  <div class="cp49-hero" id="cp49Hero">
    <div class="cp49-hero-dots"></div>
    <div class="cp49-hero-inner">
      <div class="cp49-badge"><span class="cp49-badge-dot"></span>Limited — 69 hrs only</div>
      <div class="cp49-amount">Rs 49</div>
      <div class="cp49-amount-sub">Free in your wallet</div>

      <!-- Countdown -->
      <div class="cp49-timer-row">
        <span class="cp49-timer-label">Ends in</span>
        <div class="cp49-timer">
          <div class="cp49-cd"><div class="cp49-cd-n" id="cpH">--</div><div class="cp49-cd-u">hrs</div></div>
          <div class="cp49-cd-sep">:</div>
          <div class="cp49-cd"><div class="cp49-cd-n" id="cpM">--</div><div class="cp49-cd-u">min</div></div>
          <div class="cp49-cd-sep">:</div>
          <div class="cp49-cd"><div class="cp49-cd-n" id="cpS">--</div><div class="cp49-cd-u">sec</div></div>
        </div>
      </div>

      <h1 class="cp49-hero-title">Answer 5 quick questions.<br>Earn Rs 49 in your wallet.</h1>
      <p class="cp49-hero-sub">Help us improve QuickBee — share your honest feedback and get Rs 49 credited instantly via eSewa, Khalti, or Bank Transfer.</p>

      <!-- Payment pills -->
      <div class="cp49-pay-pills">
        <div class="cp49-pay-pill">🟢 eSewa</div>
        <div class="cp49-pay-pill">🟣 Khalti</div>
        <div class="cp49-pay-pill">🏦 Bank Transfer</div>
      </div>
    </div>
  </div>

  <!-- ══ LOCKED STATE ══ -->
  <div class="cp49-locked" id="cp49Locked">
    <div class="cp49-locked-icon">🔒</div>
    <div class="cp49-locked-title">Offer Expired</div>
    <div class="cp49-locked-sub">This promotion has ended. Stay tuned — we run these regularly. Follow us for the next one!</div>
  </div>

  <!-- ══ PROGRESS ══ -->
  <div class="cp49-progress" id="cp49Progress">
    <div class="cp49-prog-step active" id="pStep1">
      <div class="cp49-prog-dot">1</div>
      <div class="cp49-prog-label">You</div>
    </div>
    <div class="cp49-prog-step" id="pStep2">
      <div class="cp49-prog-dot">2</div>
      <div class="cp49-prog-label">Shopping</div>
    </div>
    <div class="cp49-prog-step" id="pStep3">
      <div class="cp49-prog-dot">3</div>
      <div class="cp49-prog-label">Feedback</div>
    </div>
    <div class="cp49-prog-step" id="pStep4">
      <div class="cp49-prog-dot">4</div>
      <div class="cp49-prog-label">Payment</div>
    </div>
    <div class="cp49-prog-step" id="pStep5">
      <div class="cp49-prog-dot">✓</div>
      <div class="cp49-prog-label">Claim</div>
    </div>
  </div>

  <!-- ══ SURVEY ══ -->
  <div class="cp49-survey">

    <!-- Q1: Area + Frequency -->
    <div class="cp49-card active" id="cpCard1">
      <div class="cp49-q-num">Question 1 of 5</div>
      <div class="cp49-q-title">Where are you located?</div>
      <div class="cp49-q-sub">We use this to improve delivery coverage in your area.</div>
      <select class="cp49-select" id="cpArea">
        <option value="">Select your area</option>
        <option>Kathmandu — Thamel</option>
        <option>Kathmandu — Baneshwor</option>
        <option>Kathmandu — Kalanki</option>
        <option>Kathmandu — Lalitpur / Patan</option>
        <option>Kathmandu — Bhaktapur</option>
        <option>Kathmandu — Kirtipur</option>
        <option>Kathmandu — Other</option>
        <option>Outside Kathmandu Valley</option>
      </select>
      <div style="margin-top:14px;">
        <div class="cp49-q-sub" style="margin-bottom:10px;">How often do you order online?</div>
        <div class="cp49-options cols-2">
          <div>
            <input class="cp49-opt-input" type="radio" name="cpFreq" id="freq1" value="Daily">
            <label class="cp49-opt-label" for="freq1"><span class="cp49-opt-emoji">📅</span>Daily</label>
          </div>
          <div>
            <input class="cp49-opt-input" type="radio" name="cpFreq" id="freq2" value="Few times a week">
            <label class="cp49-opt-label" for="freq2"><span class="cp49-opt-emoji">🗓️</span>Few/week</label>
          </div>
          <div>
            <input class="cp49-opt-input" type="radio" name="cpFreq" id="freq3" value="Once a week">
            <label class="cp49-opt-label" for="freq3"><span class="cp49-opt-emoji">📆</span>Weekly</label>
          </div>
          <div>
            <input class="cp49-opt-input" type="radio" name="cpFreq" id="freq4" value="Rarely">
            <label class="cp49-opt-label" for="freq4"><span class="cp49-opt-emoji">🌙</span>Rarely</label>
          </div>
        </div>
      </div>
      <div class="cp49-nav">
        <button class="cp49-btn-next" onclick="cpNext(1)">Next →</button>
      </div>
    </div>

    <!-- Q2: What to shop + missing products -->
    <div class="cp49-card" id="cpCard2">
      <div class="cp49-q-num">Question 2 of 5</div>
      <div class="cp49-q-title">What do you want to shop online?</div>
      <div class="cp49-q-sub">Select all that apply — this helps us stock what you actually need.</div>
      <div class="cp49-chips">
        <input class="cp49-chip-input" type="checkbox" id="sh1" value="Groceries"><label class="cp49-chip-label" for="sh1">🥦 Groceries</label>
        <input class="cp49-chip-input" type="checkbox" id="sh2" value="Food & Snacks"><label class="cp49-chip-label" for="sh2">🍔 Food & Snacks</label>
        <input class="cp49-chip-input" type="checkbox" id="sh3" value="Beer & Drinks"><label class="cp49-chip-label" for="sh3">🍺 Beer & Drinks</label>
        <input class="cp49-chip-input" type="checkbox" id="sh4" value="Cakes & Bakery"><label class="cp49-chip-label" for="sh4">🎂 Cakes</label>
        <input class="cp49-chip-input" type="checkbox" id="sh5" value="Medicine"><label class="cp49-chip-label" for="sh5">💊 Medicine</label>
        <input class="cp49-chip-input" type="checkbox" id="sh6" value="Electronics"><label class="cp49-chip-label" for="sh6">📱 Electronics</label>
        <input class="cp49-chip-input" type="checkbox" id="sh7" value="Pet Supplies"><label class="cp49-chip-label" for="sh7">🐾 Pet Supplies</label>
        <input class="cp49-chip-input" type="checkbox" id="sh8" value="Baby Products"><label class="cp49-chip-label" for="sh8">👶 Baby Products</label>
        <input class="cp49-chip-input" type="checkbox" id="sh9" value="Flowers & Gifts"><label class="cp49-chip-label" for="sh9">💐 Flowers & Gifts</label>
        <input class="cp49-chip-input" type="checkbox" id="sh10" value="Household Items"><label class="cp49-chip-label" for="sh10">🏠 Household</label>
      </div>
      <div style="margin-top:14px;">
        <div class="cp49-q-sub" style="margin-bottom:8px;">Something missing? Tell us what you can't find:</div>
        <textarea class="cp49-textarea" id="cpMissing" placeholder="e.g. Fresh vegetables from my local market, specific brands, midnight snacks..."></textarea>
      </div>
      <div class="cp49-nav">
        <button class="cp49-btn-back" onclick="cpBack(2)">←</button>
        <button class="cp49-btn-next" onclick="cpNext(2)">Next →</button>
      </div>
    </div>

    <!-- Q3: Feedback -->
    <div class="cp49-card" id="cpCard3">
      <div class="cp49-q-num">Question 3 of 5</div>
      <div class="cp49-q-title">What's your biggest complaint about delivery apps?</div>
      <div class="cp49-q-sub">Be brutally honest — this directly shapes what we fix next.</div>
      <div class="cp49-options">
        <div>
          <input class="cp49-opt-input" type="radio" name="cpComplaint" id="c1" value="Too slow delivery">
          <label class="cp49-opt-label" for="c1"><span class="cp49-opt-emoji">🐢</span>Delivery is too slow</label>
        </div>
        <div>
          <input class="cp49-opt-input" type="radio" name="cpComplaint" id="c2" value="Too expensive delivery fee">
          <label class="cp49-opt-label" for="c2"><span class="cp49-opt-emoji">💸</span>Delivery fee is too high</label>
        </div>
        <div>
          <input class="cp49-opt-input" type="radio" name="cpComplaint" id="c3" value="Products not available">
          <label class="cp49-opt-label" for="c3"><span class="cp49-opt-emoji">📦</span>Products I want aren't available</label>
        </div>
        <div>
          <input class="cp49-opt-input" type="radio" name="cpComplaint" id="c4" value="Poor app experience">
          <label class="cp49-opt-label" for="c4"><span class="cp49-opt-emoji">📱</span>App is hard to use</label>
        </div>
        <div>
          <input class="cp49-opt-input" type="radio" name="cpComplaint" id="c5" value="Wrong or damaged items">
