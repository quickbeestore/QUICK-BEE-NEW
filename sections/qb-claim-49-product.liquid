<input type="hidden" id="cp49VariantId" value="{{ product.variants.first.id }}">

<script>
(function() {
  /* ── Countdown 69 hrs ── */
  const EXPIRY_KEY = 'qb_49_expiry_v2';
  const DURATION   = 69 * 60 * 60 * 1000;
  let expiry = parseInt(localStorage.getItem(EXPIRY_KEY) || '0');
  if (!expiry || expiry < Date.now()) {
    expiry = Date.now() + DURATION;
    localStorage.setItem(EXPIRY_KEY, expiry);
  }

  function pad(n) { return String(n).padStart(2,'0'); }

  function tick() {
    const diff = expiry - Date.now();
    if (diff <= 0) {
      lockPage(); return;
    }
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const hEl = document.getElementById('cpH');
    const mEl = document.getElementById('cpM');
    const sEl = document.getElementById('cpS');
    if (hEl) hEl.textContent = pad(h);
    if (mEl) mEl.textContent = pad(m);
    if (sEl) sEl.textContent = pad(s);
    setTimeout(tick, 1000);
  }

  function lockPage() {
    document.getElementById('cp49Hero').style.display = 'none';
    document.getElementById('cp49Progress').style.display = 'none';
    document.querySelector('.cp49-survey').style.display = 'none';
    document.querySelector('.cp49-submit-card').style.display = 'none';
    document.getElementById('cp49Locked').style.display = 'block';
  }

  tick();

  /* ── Survey navigation ── */
  let currentStep = 1;
  const TOTAL = 5;

  window.cpNext = function(step) {
    // Validate
    if (step === 1) {
      if (!document.getElementById('cpArea').value) {
        alert('Please select your area.'); return;
      }
      if (!document.querySelector('input[name="cpFreq"]:checked')) {
        alert('Please select how often you order.'); return;
      }
    }
    if (step === 2) {
      const anyShop = document.querySelectorAll('.cp49-chip-input:checked').length > 0;
      if (!anyShop) { alert('Please select at least one category.'); return; }
    }
    if (step === 3) {
      if (!document.querySelector('input[name="cpComplaint"]:checked')) {
        alert('Please select your biggest complaint.'); return;
      }
    }
    if (step === 4) {
      if (!document.querySelector('input[name="cpPay"]:checked')) {
        alert('Please select your preferred payment method.'); return;
      }
      if (!document.getElementById('cpPayNum').value.trim()) {
        alert('Please enter your payment number.'); return;
      }
    }
    if (step === 5) {
      if (!document.getElementById('cpName').value.trim()) {
        alert('Please enter your name.'); return;
      }
      if (!document.getElementById('cpPhone').value.trim()) {
        alert('Please enter your phone number.'); return;
      }
      // Show submit card
      document.getElementById('cpCard5').classList.remove('active');
      document.getElementById('cpSubmitCard').classList.add('active');
      setStep(6);
      // Update payment method display
      const payMethod = document.querySelector('input[name="cpPay"]:checked');
      if (payMethod) {
        document.getElementById('cpPayMethodDisplay').textContent = payMethod.value;
      }
      return;
    }
    document.getElementById('cpCard' + step).classList.remove('active');
    document.getElementById('cpCard' + (step + 1)).classList.add('active');
    setStep(step + 1);
    window.scrollTo({ top: document.getElementById('cp49Progress').offsetTop - 10, behavior: 'smooth' });
  };

  window.cpBack = function(step) {
    if (step <= 1) return;
    document.getElementById('cpCard' + step).classList.remove('active');
    document.getElementById('cpCard' + (step - 1)).classList.add('active');
    setStep(step - 1);
    window.scrollTo({ top: document.getElementById('cp49Progress').offsetTop - 10, behavior: 'smooth' });
  };

  function setStep(step) {
    currentStep = step;
    for (let i = 1; i <= TOTAL; i++) {
      const el = document.getElementById('pStep' + i);
      if (!el) continue;
      el.classList.remove('active', 'done');
      if (i < step) el.classList.add('done');
      else if (i === step) el.classList.add('active');
    }
  }

  /* ── Submit to cart → checkout ── */
  window.cpSubmit = async function() {
    const btn = document.getElementById('cpCheckoutBtn');
    btn.disabled = true;
    btn.textContent = '⏳ Processing...';

    const shopItems = Array.from(document.querySelectorAll('.cp49-chip-input:checked')).map(c => c.value).join(', ');
    const payMethod = document.querySelector('input[name="cpPay"]:checked')?.value || '—';

    const props = {
      '📍 Area':              document.getElementById('cpArea').value || '—',
      '📅 Order Frequency':   document.querySelector('input[name="cpFreq"]:checked')?.value || '—',
      '🛒 Wants to Shop':     shopItems || '—',
      '❓ Missing Products':  document.getElementById('cpMissing').value.trim() || '—',
      '😤 Biggest Complaint': document.querySelector('input[name="cpComplaint"]:checked')?.value || '—',
      '🕒 Order Time':        document.querySelector('input[name="cpTime"]:checked')?.value || '—',
      '💳 Preferred Payment': payMethod,
      '📞 Payment Number':    document.getElementById('cpPayNum').value.trim() || '—',
      '👤 Name':              document.getElementById('cpName').value.trim() || '—',
      '📱 Phone':             document.getElementById('cpPhone').value.trim() || '—',
      '💡 Suggestion':        document.getElementById('cpSuggestion').value.trim() || '—',
      '🕒 Submitted':         new Date().toLocaleString('en-NP', { timeZone: 'Asia/Kathmandu' })
    };

    const note = '💰 RS 49 CLAIM — SURVEY\n──────────────────────\n' +
      Object.entries(props).map(([k, v]) => k + ': ' + v).join('\n');

    const variantId = document.getElementById('cp49VariantId').value;

    try {
      await fetch('/cart/clear.js', { method: 'POST' });
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1, properties: props })
      });
      await fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ note })
      });
      window.location.href = '/checkout';
    } catch (e) {
      btn.disabled = false;
      btn.textContent = '💰 Confirm & Go to Checkout';
      alert('Something went wrong. Please try again.');
    }
  };
})();
</script>

