<!-- Shyam Bakery Collection Page -->
<style>

/* ── CSS Tokens ── */
html:not([data-theme="dark"]) .sb-wrap {
  --sb-bg: #FAFAF8;
  --sb-bg2: #FFF8F0;
  --sb-card: #FFFFFF;
  --sb-text: #1A1208;
  --sb-text2: #6B5040;
  --sb-border: rgba(0,0,0,0.08);
  --sb-accent: #C8813A;
  --sb-gold: #D4A545;
}
html[data-theme="dark"] .sb-wrap {
  --sb-bg: #0F0D0B;
  --sb-bg2: #1A1410;
  --sb-card: #1E1410;
  --sb-text: #F5EFE7;
  --sb-text2: #9A7A5A;
  --sb-border: rgba(255,255,255,0.08);
  --sb-accent: #E8A95C;
  --sb-gold: #F4B400;
}

/* ── Base ── */
.sb-wrap {
  background: var(--sb-bg);
  color: var(--sb-text);
  min-height: 100%;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

/* ── HERO ── */
.sb-hero {
  background: linear-gradient(160deg, #FFF8F0 0%, #FFF0DC 100%);
  padding: 40px 16px 36px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
html[data-theme="dark"] .sb-hero {
  background: linear-gradient(160deg, #1A0E04 0%, #0F0A06 100%) !important;
}
.sb-hero-left {
  flex: 1;
  min-width: 220px;
}
.sb-hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(200,129,58,0.12);
  border: 1px solid rgba(200,129,58,0.3);
  border-radius: 999px;
  padding: 4px 14px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--sb-accent);
  margin-bottom: 14px;
}
.sb-hero h1 {
  font-size: 40px;
  font-weight: 900;
  color: var(--sb-text);
  line-height: 1.05;
  margin-bottom: 6px;
}
.sb-hero-tagline {
  font-size: 17px;
  font-weight: 700;
  color: var(--sb-accent);
  margin-bottom: 10px;
}
.sb-hero-subtitle {
  font-size: 14px;
  color: var(--sb-text2);
  line-height: 1.6;
  margin-bottom: 20px;
  max-width: 400px;
}
.sb-hero-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.sb-hero-stat {
  background: rgba(200,129,58,0.1);
  border: 1px solid rgba(200,129,58,0.25);
  border-radius: 999px;
  padding: 5px 14px;
  font-size: 12px;
  font-weight: 700;
  color: var(--sb-accent);
}
html[data-theme="dark"] .sb-hero-stat {
  background: rgba(232,169,92,0.1) !important;
  border-color: rgba(232,169,92,0.2) !important;
}
.sb-hero-right {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120px;
}
.sb-hero-emoji {
  font-size: 80px;
  line-height: 1;
  animation: sbHeroFloat 3.5s ease-in-out infinite;
  filter: drop-shadow(0 8px 20px rgba(200,129,58,0.4));
}
@keyframes sbHeroFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}
@media(max-width: 480px) {
  .sb-hero { flex-direction: column; align-items: center; text-align: center; }
  .sb-hero-left { min-width: unset; }
  .sb-hero-stats { justify-content: center; }
  .sb-hero-subtitle { margin-left: auto; margin-right: auto; }
  .sb-hero-right { width: 100%; }
}
@media(min-width: 768px) {
  .sb-hero { padding: 56px 32px 48px; }
  .sb-hero h1 { font-size: 52px; }
}
@media(min-width: 1024px) {
  .sb-hero { padding: 64px 48px 56px; }
}

/* ── STICKY FILTER BAR ── */
.sb-bar {
  position: sticky;
  top: 60px;
  z-index: 100;
  background: rgba(255,248,240,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(200,129,58,0.15);
  padding: 10px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}
html[data-theme="dark"] .sb-bar {
  background: rgba(15,13,11,0.95) !important;
  border-bottom-color: rgba(255,255,255,0.06) !important;
}
.sb-bar-pills {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  flex: 1;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 2px;
}
.sb-bar-pills::-webkit-scrollbar { display: none; }
.sb-bar-pill {
  flex-shrink: 0;
  background: rgba(200,129,58,0.07);
  border: 1px solid rgba(200,129,58,0.2);
  border-radius: 999px;
  padding: 6px 16px;
  font-size: 12px;
  font-weight: 700;
  color: var(--sb-text2);
  cursor: pointer;
  transition: all 0.18s ease;
  white-space: nowrap;
  -webkit-appearance: none;
  appearance: none;
}
.sb-bar-pill:hover {
  background: rgba(200,129,58,0.14);
  color: var(--sb-accent);
  border-color: var(--sb-accent);
}
.sb-bar-pill.active {
  background: var(--sb-accent);
  color: #fff;
  border-color: var(--sb-accent);
}
html[data-theme="dark"] .sb-bar-pill.active {
  background: #E8A95C !important;
  color: #111 !important;
  border-color: #E8A95C !important;
}
.sb-sort-select {
  flex-shrink: 0;
  padding: 7px 14px;
  background: var(--sb-bg2);
  border: 1.5px solid rgba(200,129,58,0.25);
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
  color: var(--sb-text);
  cursor: pointer;
  transition: all 0.2s ease;
}
.sb-sort-select:hover {
  border-color: var(--sb-accent);
}
html[data-theme="dark"] .sb-sort-select {
  background: #1A1410 !important;
  color: #F5EFE7 !important;
}
@media(min-width: 640px) {
  .sb-bar { padding: 10px 24px; }
}

/* ── PRODUCT GRID SECTION ── */
.sb-grid-section {
  padding: 24px 16px 40px;
  flex: 1;
}
@media(min-width: 768px) {
  .sb-grid-section { padding: 32px 24px 48px; }
}
@media(min-width: 1024px) {
  .sb-grid-section { padding: 40px 48px 60px; }
}
.sb-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  gap: 12px;
  flex-wrap: wrap;
}
.sb-section-title {
  font-size: 20px;
  font-weight: 800;
  color: var(--sb-text);
}
.sb-product-count-pill {
  background: rgba(200,129,58,0.1);
  border: 1px solid rgba(200,129,58,0.25);
  border-radius: 999px;
  padding: 5px 14px;
  font-size: 12px;
  font-weight: 700;
  color: var(--sb-accent);
}
html[data-theme="dark"] .sb-product-count-pill {
  background: rgba(232,169,92,0.1) !important;
  border-color: rgba(232,169,92,0.2) !important;
  color: #E8A95C !important;
}

#sb-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
@media(min-width: 768px) {
  #sb-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
}
@media(min-width: 1200px) {
  #sb-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }
}

/* ── Product Card ── */
.sb-product {
  background: #FFFFFF;
  border: 1px solid #E8DCC8;
  border-radius: 16px;
  overflow: hidden;
  padding: 0;
  cursor: pointer;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.2s ease;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  box-shadow: 0 1px 6px rgba(44,36,18,0.06), 0 4px 16px rgba(44,36,18,0.04);
  position: relative;
}
[data-theme="dark"] .sb-product {
  background: #1E1410 !important;
  border-color: #3D2A1A !important;
  box-shadow: 0 2px 8px rgba(0,0,0,0.5) !important;
}
.sb-product:hover {
  transform: translateY(-3px);
  border-color: #C8813A;
  box-shadow: 0 8px 28px rgba(200,129,58,0.22);
}

.sb-product-img {
  width: 100%;
  aspect-ratio: 1;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  background: #FFF3E6;
  border-top-left-radius: 16px;
  border-top-right-radius: 16px;
}
[data-theme="dark"] .sb-product-img {
  background: #2A1A0E !important;
}
.sb-product-img img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}
.sb-product:hover .sb-product-img img {
  transform: scale(1.04);
}

.sb-product-info {
  padding: 8px 10px 12px 10px;
  display: flex;
  flex-direction: column;
  flex: 1;
  background: #FFFFFF;
}
[data-theme="dark"] .sb-product .sb-product-info {
  background: #1E1410 !important;
}

.sb-product-delivery {
  font-size: 11px;
  font-weight: 600;
  color: #6B5D4F;
  display: flex;
  align-items: center;
  gap: 3px;
  margin-bottom: 4px;
}
[data-theme="dark"] .sb-product .sb-product-delivery {
  color: #9A7A5A !important;
}

.sb-product-title {
  font-size: 13px;
  font-weight: 600;
  color: #2C2412;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 36px;
  margin-bottom: 8px;
}
[data-theme="dark"] .sb-product .sb-product-title {
  color: #F5EFE7 !important;
}

.sb-price-action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  gap: 4px;
}

.sb-product-price {
  font-size: 15px;
  font-weight: 800;
  color: #2C2412;
  letter-spacing: -0.3px;
  line-height: 1;
}
[data-theme="dark"] .sb-product .sb-product-price {
  color: #E8A95C !important;
}
.sb-product-original-price {
  font-size: 11px;
  color: #A89888;
  text-decoration: line-through;
}

.sb-product-btn {
  background: transparent !important;
  border: 1.5px solid #C8813A !important;
  border-radius: 20px !important;
  padding: 6px 16px !important;
  font-weight: 700 !important;
  font-size: 13px !important;
  color: #C8813A !important;
  cursor: pointer !important;
  transition: all 0.2s ease !important;
  font-family: inherit !important;
  white-space: nowrap !important;
}
.sb-product-btn:hover {
  background: rgba(200,129,58,0.1) !important;
}
.sb-product-btn:active {
  background: #C8813A !important;
  color: #fff !important;
  transform: scale(0.95) !important;
}
[data-theme="dark"] .sb-product-btn {
  border-color: #E8A95C !important;
  color: #E8A95C !important;
}
[data-theme="dark"] .sb-product-btn:hover {
  background: rgba(232,169,92,0.12) !important;
}

/* Eggless badge on image */
.sb-eggless-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  background: linear-gradient(120deg, #1b5e20, #2e7d32);
  color: #fff;
  font-size: 10px;
  font-weight: 900;
  padding: 3px 8px;
  border-radius: 20px;
  z-index: 2;
  box-shadow: 0 2px 6px rgba(27,94,32,0.4);
}

/* Discount badge */
.sb-off-badge {
  position: absolute;
  top: 8px;
  right: 8px;
  background: #FF4444;
  color: #fff;
  font-size: 10px;
  font-weight: 900;
  padding: 3px 8px;
  border-radius: 20px;
  z-index: 2;
}

/* ── DELIVERY STRIP ── */
/* ══════════════════════════════════════════════════
   DELIVERY STRIP — REDESIGNED
══════════════════════════════════════════════════ */
.sb-strip {
  padding: 40px 20px;
  background: var(--sb-bg2);
  position: relative;
  overflow: hidden;
}
.sb-strip::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(200,129,58,0.06) 0%, transparent 60%);
  pointer-events: none;
}
html[data-theme="dark"] .sb-strip { background: #140E08 !important; }
html[data-theme="dark"] .sb-strip::before { background: linear-gradient(135deg, rgba(232,169,92,0.05) 0%, transparent 60%) !important; }

.sb-strip-label {
  text-align: center;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--sb-accent);
  margin-bottom: 28px;
  opacity: 0.8;
}
.sb-strip-inner {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  max-width: 760px;
  margin: 0 auto;
}
@media(max-width: 480px) {
  .sb-strip-inner { grid-template-columns: 1fr; gap: 10px; }
}
.sb-strip-item {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--sb-card);
  border: 1px solid rgba(200,129,58,0.12);
  border-radius: 18px;
  padding: 18px 20px;
  box-shadow: 0 2px 12px rgba(200,129,58,0.07);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.sb-strip-item:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(200,129,58,0.14);
}
html[data-theme="dark"] .sb-strip-item {
  background: #1E1610 !important;
  border-color: rgba(232,169,92,0.1) !important;
  box-shadow: 0 2px 12px rgba(0,0,0,0.3) !important;
}
.sb-strip-icon-wrap {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: linear-gradient(135deg, rgba(200,129,58,0.15), rgba(200,129,58,0.08));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
  border: 1px solid rgba(200,129,58,0.2);
}
html[data-theme="dark"] .sb-strip-icon-wrap {
  background: linear-gradient(135deg, rgba(232,169,92,0.12), rgba(232,169,92,0.06)) !important;
  border-color: rgba(232,169,92,0.15) !important;
}
.sb-strip-text {}
.sb-strip-title {
  font-size: 14px;
  font-weight: 800;
  color: var(--sb-text);
  margin-bottom: 3px;
  line-height: 1.2;
}
.sb-strip-sub {
  font-size: 11.5px;
  color: var(--sb-text2);
  line-height: 1.4;
}

/* ══════════════════════════════════════════════════
   FOOTER CTA — REDESIGNED
══════════════════════════════════════════════════ */
.sb-footer {
  position: relative;
  overflow: hidden;
  background: linear-gradient(160deg, #3D1C00 0%, #5C2E00 35%, #3D1C00 70%, #1A0A00 100%);
  padding: 56px 20px 48px;
  text-align: center;
}
html[data-theme="dark"] .sb-footer {
  background: linear-gradient(160deg, #1A0A00 0%, #2E1600 35%, #1A0A00 70%, #0A0500 100%) !important;
}
/* decorative blobs */
.sb-footer::before {
  content: '';
  position: absolute;
  top: -60px; left: -60px;
  width: 280px; height: 280px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,169,92,0.18) 0%, transparent 70%);
  pointer-events: none;
}
.sb-footer::after {
  content: '';
  position: absolute;
  bottom: -40px; right: -40px;
  width: 220px; height: 220px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200,129,58,0.14) 0%, transparent 70%);
  pointer-events: none;
}
.sb-footer-inner { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; }

/* Big cake emoji */
.sb-footer-cake {
  font-size: 56px;
  line-height: 1;
  margin-bottom: 16px;
  display: block;
  filter: drop-shadow(0 4px 16px rgba(232,169,92,0.4));
  animation: sbFooterFloat 3s ease-in-out infinite;
}
@keyframes sbFooterFloat {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-8px); }
}

/* Eyebrow */
.sb-footer-eyebrow {
  display: inline-block;
  background: rgba(232,169,92,0.15);
  border: 1px solid rgba(232,169,92,0.3);
  color: #E8A95C;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 999px;
  margin-bottom: 16px;
}
.sb-footer-title {
  font-size: 32px;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: -0.5px;
  margin-bottom: 6px;
  line-height: 1.1;
}
.sb-footer-title em {
  font-style: normal;
  background: linear-gradient(120deg, #E8A95C, #F0CC70);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.sb-footer-tagline {
  font-size: 15px;
  color: rgba(255,255,255,0.55);
  margin-bottom: 32px;
  line-height: 1.5;
}

/* Stats row */
.sb-footer-stats {
  display: flex;
  justify-content: center;
  gap: 0;
  margin-bottom: 32px;
}
.sb-footer-stat {
  flex: 1;
  max-width: 120px;
  padding: 14px 8px;
  border-right: 1px solid rgba(255,255,255,0.08);
}
.sb-footer-stat:last-child { border-right: none; }
.sb-footer-stat-val {
  font-size: 22px;
  font-weight: 900;
  color: #E8A95C;
  display: block;
  line-height: 1;
  margin-bottom: 4px;
}
.sb-footer-stat-lbl {
  font-size: 10px;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

/* Contact links */
.sb-footer-links {
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 28px;
}
.sb-footer-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 999px;
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  transition: all 0.2s ease;
  backdrop-filter: blur(8px);
}
.sb-footer-link:hover {
  background: rgba(232,169,92,0.18);
  border-color: rgba(232,169,92,0.35);
  color: #E8A95C;
  transform: translateY(-2px);
}

/* Divider */
.sb-footer-divider {
  width: 48px;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(232,169,92,0.5), transparent);
  margin: 0 auto 20px;
  border-radius: 2px;
}
.sb-footer-copy {
  font-size: 11px;
  color: rgba(255,255,255,0.25);
  letter-spacing: 0.3px;
}
</style>

<div class="sb-wrap">

  <!-- ── HERO ── -->
  <div class="sb-hero">
    <div class="sb-hero-left">
      <div class="sb-hero-eyebrow">🎂 Kalanki · Kathmandu</div>
      <h1>Shyam Bakery</h1>
      <div class="sb-hero-tagline">Fresh Cakes Baked Daily</div>
      <div class="sb-hero-subtitle">Premium handcrafted cakes delivered fresh — custom orders welcome</div>
      <div class="sb-hero-stats">
        <span class="sb-hero-stat">🚀 Fast Delivery</span>
        <span class="sb-hero-stat">🥚 100% Eggless</span>
        <span class="sb-hero-stat">⭐ 4.9 Rated</span>
        <span class="sb-hero-stat">🎂 Custom Orders</span>
      </div>
    </div>
    <div class="sb-hero-right">
      <div class="sb-hero-emoji">🎂</div>
    </div>
  </div>

  <!-- ── STICKY FILTER BAR ── -->
  <div class="sb-bar">
    <div class="sb-bar-pills">
      <button class="sb-bar-pill active" data-filter="all">All 🎂</button>
      <button class="sb-bar-pill" data-filter="chocolate">Chocolate 🍫</button>
      <button class="sb-bar-pill" data-filter="vanilla">Vanilla 🍦</button>
      <button class="sb-bar-pill" data-filter="strawberry">Strawberry 🍓</button>
      <button class="sb-bar-pill" data-filter="black forest">Black Forest</button>
      <button class="sb-bar-pill" data-filter="butterscotch">Butterscotch</button>
      <button class="sb-bar-pill" data-filter="red velvet">Red Velvet</button>
      <button class="sb-bar-pill" data-filter="custom">Custom 🎨</button>
    </div>
    <select class="sb-sort-select" id="sb-sort">
      <option value="popular">Popular</option>
      <option value="price-asc">Price ↑</option>
      <option value="price-desc">Price ↓</option>
      <option value="newest">Newest</option>
    </select>
  </div>

  <!-- ── PRODUCT GRID ── -->
  <div class="sb-grid-section">
    <div class="sb-section-header">
      <div class="sb-section-title">🎂 Our Cakes</div>
      <div class="sb-product-count-pill">{{ collection.products_count | default: 0 }} Products</div>
    </div>

    <div id="sb-grid">
      {% for product in collection.products %}
        {%- assign has_discount = false -%}
        {%- if product.compare_at_price > product.price -%}
          {%- assign has_discount = true -%}
          {%- assign savings = product.compare_at_price | minus: product.price -%}
