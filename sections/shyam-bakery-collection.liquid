<script>
(function() {

  /* ── Add to Cart ── */
  window.sbAddToCart = function(btn, variantId) {
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
    }).then(function() {
      btn.textContent = '✓ Added';
      btn.style.setProperty('color', '#22c55e', 'important');
      btn.style.setProperty('border-color', '#22c55e', 'important');
      setTimeout(function() {
        btn.textContent = '+ Add';
        btn.style.removeProperty('color');
        btn.style.removeProperty('border-color');
      }, 1500);
    }).catch(function() {
      btn.textContent = 'Error';
      setTimeout(function() { btn.textContent = '+ Add'; }, 1500);
    });
  };

  /* ── Filter Pills ── */
  var pills = document.querySelectorAll('.sb-bar-pill');
  pills.forEach(function(pill) {
    pill.addEventListener('click', function() {
      pills.forEach(function(p) { p.classList.remove('active'); });
      pill.classList.add('active');
      var filter = pill.getAttribute('data-filter');
      document.querySelectorAll('#sb-grid .sb-product').forEach(function(card) {
        if (filter === 'all') {
          card.style.display = '';
        } else {
          var flavor = card.getAttribute('data-flavor') || '';
          card.style.display = flavor.indexOf(filter) !== -1 ? '' : 'none';
        }
      });
    });
  });

  /* ── Sort ── */
  var sortSelect = document.getElementById('sb-sort');
  if (sortSelect) {
    sortSelect.addEventListener('change', function() {
      var grid = document.getElementById('sb-grid');
      if (!grid) return;
      var cards = Array.prototype.slice.call(grid.querySelectorAll('.sb-product'));
      var val = sortSelect.value;
      cards.sort(function(a, b) {
        if (val === 'price-asc') {
          return parseInt(a.getAttribute('data-price') || 0) - parseInt(b.getAttribute('data-price') || 0);
        } else if (val === 'price-desc') {
          return parseInt(b.getAttribute('data-price') || 0) - parseInt(a.getAttribute('data-price') || 0);
        } else if (val === 'newest') {
          /* newest: reverse DOM order as fallback */
          return 0;
        } else {
          /* popular: restore original DOM order */
          return 0;
        }
      });
      cards.forEach(function(card) { grid.appendChild(card); });
    });
  }

  /* ── Theme Apply ── */
  function applyTheme() {
    var isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    document.querySelectorAll('.sb-product').forEach(function(el) {
      el.style.setProperty('background', isDark ? '#1E1410' : '#FFFFFF', 'important');
      el.style.setProperty('border-color', isDark ? '#3D2A1A' : '#E8DCC8', 'important');
    });
    document.querySelectorAll('.sb-product-title').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#F5EFE7' : '#2C2412', 'important');
    });
    document.querySelectorAll('.sb-product-price').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#E8A95C' : '#2C2412', 'important');
    });
    document.querySelectorAll('.sb-product-info').forEach(function(el) {
      el.style.setProperty('background', isDark ? '#1E1410' : '#FFFFFF', 'important');
    });
    document.querySelectorAll('.sb-product-img').forEach(function(el) {
      el.style.setProperty('background', isDark ? '#2A1A0E' : '#FFF3E6', 'important');
    });
    document.querySelectorAll('.sb-product-delivery').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#9A7A5A' : '#6B5D4F', 'important');
    });
    document.querySelectorAll('.sb-product-btn').forEach(function(el) {
      el.style.setProperty('border-color', isDark ? '#E8A95C' : '#C8813A', 'important');
      el.style.setProperty('color', isDark ? '#E8A95C' : '#C8813A', 'important');
    });
  }

  applyTheme();
  document.addEventListener('DOMContentLoaded', applyTheme);
  setTimeout(applyTheme, 100);
  setTimeout(applyTheme, 500);
  setTimeout(applyTheme, 1000);

  var observer = new MutationObserver(applyTheme);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

})();
</script>

