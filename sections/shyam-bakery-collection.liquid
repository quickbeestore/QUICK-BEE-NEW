            <div class="sb-product-title">{{ product.title }}</div>
            <div class="sb-price-action-row">
              <div>
                <div class="sb-product-price">Rs {{ product.price | divided_by: 100 }}</div>
                {%- if has_discount -%}
                  <div class="sb-product-original-price">Rs {{ product.compare_at_price | divided_by: 100 }}</div>
                {%- endif -%}
              </div>
              <button
                class="sb-product-btn"
                data-variant-id="{{ product.variants.first.id }}"
                onclick="event.preventDefault(); sbAddToCart(this, {{ product.variants.first.id }})"
              >+ Add</button>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>

