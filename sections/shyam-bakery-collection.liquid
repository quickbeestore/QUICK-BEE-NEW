            {%- endif -%}
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
            {% else %}
              <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:48px;">🎂</div>
            {% endif %}
          </div>
          <div class="sb-product-info">
