<style>
  .custom-banner-grid {
    width: 100%;
    padding: 20px 0;
  }

  .custom-banner-grid__large {
    width: 100%;
    margin-bottom: 10px;
  }

  .custom-banner-grid__large a,
  .custom-banner-grid__small a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .custom-banner-grid__large img,
  .custom-banner-grid__small img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  .custom-banner-grid__small-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 10px;
  }

  @media (max-width: 768px) {
    .custom-banner-grid__small-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<div class="custom-banner-grid">
  <!-- Set A -->
  <div class="custom-banner-grid__large">
    <a href="#">
      <img src="{{ 'LARGE - A1.png' | asset_url }}" loading="lazy" alt="Large Banner A1">
    </a>
  </div>
  <div class="custom-banner-grid__small-grid">
    <div class="custom-banner-grid__small">
      <a href="#">
        <img src="{{ 'SMALL - A1.png' | asset_url }}" loading="lazy" alt="Small Banner A1">
      </a>
    </div>
    <div class="custom-banner-grid__small">
      <a href="https://quickbee.store/collections/smokes">
        <img src="{{ 'SMALL - A2.png' | asset_url }}" loading="lazy" alt="Small Banner A2">
      </a>
    </div>
    <div class="custom-banner-grid__small">
      <a href="#">
        <img src="{{ 'SMALL - A3.png' | asset_url }}" loading="lazy" alt="Small Banner A3">
      </a>
    </div>
    <div class="custom-banner-grid__small">
      <a href="#">
        <img src="{{ 'SMALL - A4.png' | asset_url }}" loading="lazy" alt="Small Banner A4">
      </a>
    </div>
  </div>

  <!-- Set C -->
  <div class="custom-banner-grid__large">
    <a href="#">
      <img src="{{ 'LARGE - C1.png' | asset_url }}" loading="lazy" alt="Large Banner C1">
    </a>
  </div>
  <div class="custom-banner-grid__small-grid">
    <div class="custom-banner-grid__small">
      <a href="#">
        <img src="{{ 'SMALL - C1.png' | asset_url }}" loading="lazy" alt="Small Banner C1">
      </a>
    </div>
    <div class="custom-banner-grid__small">
      <a href="#">
        <img src="{{ 'SMALL - C2.png' | asset_url }}" loading="lazy" alt="Small Banner C2">
      </a>
    </div>
    <div class="custom-banner-grid__small">
      <a href="#">
        <img src="{{ 'SMALL - C3.png' | asset_url }}" loading="lazy" alt="Small Banner C3">
