/* RENDER */
var H='',totalCount=0;
sections.forEach(function(s){
  if(!s.prods||!s.prods.length) return;
  totalCount+=s.prods.length;
  H+=renderSec(s.id,s.eye,s.name,s.prods);
});

if(!H) H='<div class="qbwc-empty">No products found in this category yet.</div>';
document.getElementById('qbwcContent').innerHTML=H;
document.getElementById('qbwcCount').textContent=totalCount+' products';

/* SUB-NAV */
var navHtml='';
sections.forEach(function(s){
  if(!s.prods||!s.prods.length) return;
  var el=document.getElementById('cs-'+s.id);
  if(el) navHtml+='<button class="qbwc-nav-btn" data-id="cs-'+s.id+'" onclick="qbwcNav(this)">'+s.eye+'</button>';
});
document.getElementById('qbwcNav').innerHTML=navHtml;

/* NAV SCROLL */
function off(){
  var n=document.querySelector('.qbwc-nav');
  var h=document.querySelector('sticky-header,#shopify-section-quickbee-header');
  return (n?n.offsetHeight:44)+(h?h.offsetHeight:56)+8;
}
window.qbwcNav=function(btn){
  document.querySelectorAll('.qbwc-nav-btn').forEach(function(b){b.classList.remove('on');});
  btn.classList.add('on');
  var el=document.getElementById(btn.getAttribute('data-id'));
  if(el) window.scrollTo({top:el.getBoundingClientRect().top+window.scrollY-off(),behavior:'smooth'});
  btn.scrollIntoView({inline:'center',behavior:'smooth',block:'nearest'});
};
if(window.IntersectionObserver){
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting) return;
      var id=e.target.id;
      document.querySelectorAll('.qbwc-nav-btn').forEach(function(b){b.classList.toggle('on',b.getAttribute('data-id')===id);});
      var a=document.querySelector('.qbwc-nav-btn.on');
      if(a) a.scrollIntoView({inline:'nearest',behavior:'smooth',block:'nearest'});
    });
  },{threshold:0.2,rootMargin:'-50px 0px -55% 0px'});
  document.querySelectorAll('[id^="cs-"]').forEach(function(s){io.observe(s);});
}

})();
</script>

