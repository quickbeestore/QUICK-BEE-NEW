{% comment %} Pachali Bhairab Collection Section {% endcomment %}

<style>
  /* ─── CSS TOKENS ─── */
  html:not([data-theme="dark"]) .pb-wrap {
    --pb-bg: #FFF8EE;
    --pb-bg2: #FFF2DC;
    --pb-card: #FFFFFF;
    --pb-text: #2A0800;
    --pb-text2: #7A4010;
    --pb-text3: #B8855A;
    --pb-gold: #B8660A;
    --pb-gold2: #D4880C;
    --pb-gold-dim: rgba(180,100,10,0.08);
    --pb-maroon: #8B1A1A;
    --pb-border: rgba(120,60,10,0.15);
    --pb-shadow: 0 4px 20px rgba(100,40,0,0.10);
    --pb-shadow-lg: 0 12px 40px rgba(100,40,0,0.18);
    --pb-radius: 16px;
    --pb-hero-bg: linear-gradient(160deg, #5C1A00 0%, #8B2E00 40%, #3D1000 100%);
    --pb-culture-bg: linear-gradient(90deg, #5C1A00, #8B2E00, #5C1A00);
    --pb-pills-bg: rgba(255,248,238,0.97);
    --pb-pills-border: rgba(120,60,10,0.15);
    --pb-placeholder-bg: linear-gradient(135deg, #FFE8C8, #FFD4A0);
    --pb-placeholder-clr: rgba(180,100,10,0.4);
    --pb-wave-fill: #FFF8EE;
    --pb-story-bg: linear-gradient(135deg, #FFF2DC 0%, #FFE8C0 100%);
  }
  html[data-theme="dark"] .pb-wrap {
    --pb-bg: #110600;
    --pb-bg2: #1E0A00;
    --pb-card: #160800;
    --pb-text: #F5E6C8;
    --pb-text2: #B8855A;
    --pb-text3: #6A4525;
    --pb-gold: #D4A843;
    --pb-gold2: #F0CC70;
    --pb-gold-dim: rgba(212,168,67,0.1);
    --pb-maroon: #8B1A1A;
    --pb-border: rgba(212,168,67,0.12);
    --pb-shadow: 0 4px 32px rgba(0,0,0,0.7);
    --pb-shadow-lg: 0 16px 64px rgba(0,0,0,0.9);
    --pb-radius: 16px;
    --pb-hero-bg: linear-gradient(160deg, #2A0800 0%, #1A0500 40%, #0D0300 100%);
    --pb-culture-bg: linear-gradient(90deg, #2A0800, #3D1400, #2A0800);
    --pb-pills-bg: rgba(17,6,0,0.96);
    --pb-pills-border: rgba(212,168,67,0.15);
    --pb-placeholder-bg: linear-gradient(135deg, #2A1200, #1A0800);
    --pb-placeholder-clr: rgba(212,168,67,0.3);
    --pb-wave-fill: #110600;
    --pb-story-bg: linear-gradient(135deg, #2A0800 0%, #1A0500 100%);
  }

  /* ─── WRAP BASE ─── */
  .pb-wrap {
    background: var(--pb-bg);
    color: var(--pb-text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    min-height: 100%;
    overflow-x: hidden;
    position: relative;
  }

  /* ─── DECORATIVE MANDALA OVERLAY ─── */
  .pb-mandala-bg {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 700px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.04;
  }

  /* ─── HERO ─── */
  .pb-hero {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: flex-end;
    padding: 0 0 40px;
    overflow: hidden;
    background: var(--pb-hero-bg);
    z-index: 1;
  }
  .pb-hero-glow {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, rgba(212,168,67,0.18) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .pb-hero-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    pointer-events: none;
    z-index: 0;
    line-height: 0;
  }
  .pb-hero-mandala {
    position: absolute;
    top: 30px;
    right: 180px;
    width: 220px;
    height: 220px;
    border: 1px solid rgba(212,168,67,0.08);
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    animation: pb-spin 60s linear infinite;
  }
  .pb-hero-mandala::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 1px solid rgba(212,168,67,0.06);
    border-radius: 50%;
  }
  .pb-hero-mandala::after {
    content: '';
    position: absolute;
    top: 44px;
    left: 44px;
    right: 44px;
    bottom: 44px;
    border: 1px solid rgba(212,168,67,0.05);
    border-radius: 50%;
  }
  @keyframes pb-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes pb-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-14px); }
  }
  .pb-hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 60px 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .pb-hero-left {
    flex: 1;
    max-width: 560px;
  }
  .pb-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10.5px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pb-gold);
    background: rgba(139,26,26,0.25);
    border: 1px solid rgba(212,168,67,0.3);
    border-radius: 30px;
    padding: 5px 14px;
    margin-bottom: 18px;
  }
  .pb-hero-h1 {
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.1;
    font-weight: 400;
    color: var(--pb-text);
    margin: 0 0 6px;
  }
  .pb-hero-h1 .pb-gold-italic {
    display: block;
    font-style: italic;
    font-weight: 900;
    background: linear-gradient(120deg, var(--pb-gold), var(--pb-gold2), var(--pb-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .pb-hero-sub {
    font-size: 14px;
    color: var(--pb-text2);
    line-height: 1.6;
    margin: 14px 0 22px;
    max-width: 420px;
  }
  .pb-hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }
  .pb-hero-pill {
    font-size: 11px;
    font-weight: 700;
    color: var(--pb-text2);
    background: rgba(212,168,67,0.08);
    border: 1px solid rgba(212,168,67,0.2);
    border-radius: 30px;
    padding: 5px 12px;
    white-space: nowrap;
  }
  .pb-hero-cta {
    display: inline-block;
    background: linear-gradient(120deg, #C9972C, #D4A843, #F0CC70);
    color: #1A0800;
    font-weight: 900;
    font-size: 15px;
    border: none;
    border-radius: 50px;
    padding: 13px 32px;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(212,168,67,0.35);
    transition: filter 0.2s, transform 0.2s, box-shadow 0.2s;
    letter-spacing: 0.02em;
  }
  .pb-hero-cta:hover {
    filter: brightness(1.08);
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(212,168,67,0.45);
  }
  .pb-hero-right {
    flex-shrink: 0;
    width: 180px;
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 80px;
    animation: pb-float 4s ease-in-out infinite;
  }

  /* ─── CULTURE BAR ─── */
  .pb-culture-bar {
    background: var(--pb-culture-bg);
    border-top: 1px solid rgba(212,168,67,0.2);
    border-bottom: 1px solid rgba(212,168,67,0.2);
    padding: 10px 24px;
    position: relative;
    z-index: 2;
  }
  .pb-culture-bar-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
  }
  .pb-culture-item {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pb-gold);
    padding: 2px 20px;
  }
  .pb-culture-divider {
    color: rgba(212,168,67,0.3);
    font-size: 14px;
    line-height: 1;
  }

  /* ─── PILLS BAR ─── */
  .pb-pills-bar {
    position: sticky;
    top: 60px;
    z-index: 100;
    background: var(--pb-pills-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--pb-pills-border);
    padding: 10px 0;
  }
  .pb-pills-bar-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .pb-pills-bar-inner::-webkit-scrollbar { display: none; }
  .pb-filter-pill {
    flex-shrink: 0;
    font-size: 12px;
    font-weight: 700;
    border-radius: 30px;
    padding: 7px 16px;
    cursor: pointer;
    border: 1px solid rgba(212,168,67,0.2);
    background: rgba(212,168,67,0.05);
    color: var(--pb-text2);
    transition: all 0.2s;
    white-space: nowrap;
    user-select: none;
    -webkit-user-select: none;
  }
  .pb-filter-pill:hover {
    border-color: rgba(212,168,67,0.4);
    color: var(--pb-gold);
    background: rgba(212,168,67,0.1);
  }
  .pb-filter-pill.active {
    background: linear-gradient(120deg, #C9972C, #D4A843);
    color: #1A0800 !important;
    border-color: transparent;
  }

  /* ─── GRID SECTION ─── */
  .pb-grid-section {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 16px 48px;
  }
  .pb-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  @media (min-width: 640px) {
    .pb-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
  }
  @media (min-width: 900px) {
    .pb-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; }
  }
  @media (min-width: 1200px) {
    .pb-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }
  }

  /* ─── CARD ─── */
  .pb-card {
    background: var(--pb-card);
    border: 1px solid var(--pb-border);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition: transform 0.28s cubic-bezier(.25,.8,.25,1), box-shadow 0.28s ease, border-color 0.22s;
    box-shadow: var(--pb-shadow);
    position: relative;
  }
  /* Gold top accent line */
  .pb-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--pb-maroon), var(--pb-gold), var(--pb-maroon));
    opacity: 0;
    transition: opacity 0.25s;
    z-index: 5;
  }
  .pb-card:hover::before { opacity: 1; }
  .pb-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--pb-shadow-lg);
    border-color: rgba(212,168,67,0.35);
  }
  .pb-card.pb-hidden { display: none; }

  /* ─── IMAGE AREA ─── */
  .pb-card-img-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--pb-placeholder-bg);
    flex-shrink: 0;
  }
  .pb-card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s cubic-bezier(.25,.8,.25,1);
  }
  .pb-card:hover .pb-card-img-wrap img { transform: scale(1.08); }
  .pb-card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 52px;
    background: var(--pb-placeholder-bg);
    color: var(--pb-placeholder-clr);
    transition: transform 0.45s ease;
  }
  .pb-card:hover .pb-card-img-placeholder { transform: scale(1.08); }

  /* ─── BADGES ─── */
  .pb-badges {
    position: absolute;
    top: 9px;
    left: 9px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 3;
  }
  .pb-badge {
    font-size: 9px;
    font-weight: 900;
    padding: 3px 8px;
    border-radius: 20px;
    display: inline-block;
    line-height: 1.5;
    letter-spacing: 0.03em;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .pb-badge--fresh { background: rgba(27,94,32,0.92); color: #A5D6A7; border: 1px solid rgba(76,175,80,0.3); }
  .pb-badge--best  { background: rgba(139,26,26,0.92); color: #FFCDD2; border: 1px solid rgba(244,67,54,0.3); }
  .pb-badge--trad  { background: rgba(201,151,44,0.92); color: #111; border: 1px solid rgba(212,168,67,0.5); }
  .pb-badge--spicy { background: rgba(191,54,12,0.92); color: #FFCCBC; border: 1px solid rgba(255,87,34,0.3); }

  /* ─── DISCOUNT BADGE ─── */
  .pb-discount-badge {
    position: absolute;
    top: 9px;
    right: 9px;
    background: linear-gradient(135deg, #c62828, #e53935);
    color: #fff;
    font-size: 9.5px;
    font-weight: 900;
    padding: 4px 8px;
    border-radius: 20px;
    z-index: 3;
    letter-spacing: 0.04em;
    box-shadow: 0 2px 8px rgba(198,40,40,0.4);
  }

  /* ─── QUICK VIEW OVERLAY ─── */
  .pb-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 14px;
    opacity: 0;
    transition: opacity 0.28s;
    z-index: 4;
    pointer-events: none;
  }
  .pb-card:hover .pb-card-overlay { opacity: 1; }
  .pb-card-overlay-text {
    font-size: 11px;
    font-weight: 900;
    color: #fff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(212,168,67,0.25);
    padding: 5px 16px;
    border-radius: 20px;
    border: 1px solid rgba(212,168,67,0.5);
    backdrop-filter: blur(4px);
  }

  /* ─── CARD BODY ─── */
  .pb-card-body {
    padding: 13px 14px 14px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0;
  }
  .pb-card-cat {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pb-gold);
    margin-bottom: 5px;
    opacity: 0.8;
  }
  .pb-card-name {
    font-size: 14.5px;
    font-weight: 800;
    color: var(--pb-text);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 5px;
    letter-spacing: -0.01em;
  }
  .pb-card-desc {
    font-size: 11px;
    color: var(--pb-text2);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 12px;
    flex: 1;
  }

  /* ─── PRICE + ACTION ROW ─── */
  .pb-card-bottom {
    margin-top: auto;
  }
  .pb-card-price-row {
    display: flex;
    align-items: baseline;
    gap: 7px;
    margin-bottom: 10px;
  }
  .pb-card-price {
    font-size: 19px;
    font-weight: 900;
    color: var(--pb-gold);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .pb-card-compare {
    font-size: 12px;
    font-weight: 500;
    color: var(--pb-text3);
    text-decoration: line-through;
  }

  /* ─── ADD BUTTON (full width) ─── */
  .pb-card-actions {
    width: 100%;
  }
  .pb-add-btn {
    width: 100% !important;
    background: linear-gradient(120deg, #C9972C, #D4A843, #C9972C) !important;
    background-size: 200% !important;
    color: #1A0800 !important;
    border: none !important;
    border-radius: 12px !important;
    padding: 10px 0 !important;
    font-size: 13px !important;
    font-weight: 900 !important;
    cursor: pointer !important;
    transition: all 0.25s !important;
    font-family: inherit !important;
    letter-spacing: 0.03em !important;
    box-shadow: 0 3px 12px rgba(212,168,67,0.25) !important;
  }
  .pb-add-btn:hover {
    background-position: right center !important;
    filter: brightness(1.08) !important;
    box-shadow: 0 5px 18px rgba(212,168,67,0.4) !important;
    transform: translateY(-1px) !important;
  }
  .pb-add-btn:active { transform: scale(0.97) !important; }

  /* ─── STEPPER (full width) ─── */
  .pb-stepper {
    display: none;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    background: rgba(212,168,67,0.08);
    border: 1.5px solid rgba(212,168,67,0.35);
    border-radius: 12px;
    overflow: hidden;
    height: 40px;
  }
  .pb-stepper.visible { display: flex; }
  .pb-stepper-btn {
    background: none;
    border: none;
    color: var(--pb-gold);
    font-size: 18px;
    font-weight: 900;
    padding: 0 16px;
    cursor: pointer;
    height: 100%;
    line-height: 1;
    transition: background 0.15s;
  }
  .pb-stepper-btn:hover { background: rgba(212,168,67,0.18); }
  .pb-stepper-qty {
    font-size: 14px;
    font-weight: 900;
    color: var(--pb-text);
    min-width: 24px;
    text-align: center;
  }

  /* Empty state */
  .pb-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: var(--pb-text2);
  }
  .pb-empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.5; }
  .pb-empty-title { font-size: 18px; font-weight: 700; color: var(--pb-text); margin-bottom: 8px; }
  .pb-empty-desc { font-size: 13px; color: var(--pb-text2); }

  /* No results state (from filter) */
  .pb-no-results {
    display: none;
    grid-column: 1 / -1;
    text-align: center;
    padding: 48px 20px;
    color: var(--pb-text2);
  }
  .pb-no-results.visible { display: block; }
  .pb-no-results p { font-size: 14px; }

  /* ─── STORY SECTION ─── */
  .pb-story {
    background: var(--pb-story-bg);
    border-top: 1px solid rgba(212,168,67,0.2);
    padding: 56px 20px;
    position: relative;
    z-index: 1;
  }
  .pb-story-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    gap: 48px;
    align-items: center;
  }
  .pb-story-left {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .pb-story-icon { font-size: 60px; line-height: 1; }
  .pb-story-circles {
    position: relative;
    width: 120px;
    height: 120px;
  }
  .pb-story-circle {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(212,168,67,0.12);
  }
  .pb-story-circle:nth-child(1) { inset: 0; }
  .pb-story-circle:nth-child(2) { inset: 16px; border-color: rgba(212,168,67,0.09); }
  .pb-story-circle:nth-child(3) { inset: 32px; border-color: rgba(212,168,67,0.07); }
  .pb-story-right { flex: 1; }
  .pb-story-eyebrow {
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pb-gold);
    margin-bottom: 12px;
  }
  .pb-story-h2 {
    font-size: clamp(22px, 3.5vw, 36px);
    font-weight: 900;
    font-family: Georgia, 'Times New Roman', serif;
    background: linear-gradient(120deg, var(--pb-gold), var(--pb-gold2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
    margin: 0 0 18px;
  }
  .pb-story-body {
    font-size: 14px;
    line-height: 1.75;
    color: var(--pb-text2);
    margin-bottom: 32px;
    max-width: 560px;
  }
  .pb-story-stats {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .pb-story-stat {
    background: rgba(212,168,67,0.07);
    border: 1px solid rgba(212,168,67,0.15);
    border-radius: 12px;
    padding: 12px 18px;
    flex: 1;
    min-width: 130px;
  }
  .pb-story-stat-icon { font-size: 20px; margin-bottom: 6px; }
  .pb-story-stat-label {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pb-text3);
    margin-bottom: 2px;
  }
  .pb-story-stat-value {
    font-size: 13px;
    font-weight: 900;
    color: var(--pb-gold);
  }

  /* ─── COMBO SECTION ─── */
  .pb-combo {
    background: var(--pb-bg2);
    padding: 40px 20px;
    position: relative;
    z-index: 1;
  }
  .pb-combo-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .pb-section-title {
    font-size: 20px;
    font-weight: 900;
    color: var(--pb-text);
    margin-bottom: 24px;
    position: relative;
    display: inline-block;
  }
  .pb-section-title::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--pb-gold), transparent);
    border-radius: 2px;
  }
  .pb-combo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 560px) {
    .pb-combo-grid { grid-template-columns: 1fr; }
  }
  .pb-combo-card {
    border-radius: var(--pb-radius);
    background: var(--pb-card);
    border: 1px solid var(--pb-border);
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
    text-decoration: none;
  }
  .pb-combo-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--pb-shadow-lg);
  }
  .pb-combo-card--maroon { border-top: 3px solid var(--pb-maroon); }
  .pb-combo-card--gold   { border-top: 3px solid var(--pb-gold); }
  .pb-combo-card-emoji { font-size: 40px; line-height: 1; }
  .pb-combo-card-name {
    font-size: 17px;
    font-weight: 900;
    color: var(--pb-text);
  }
  .pb-combo-card-desc {
    font-size: 12.5px;
    color: var(--pb-text2);
    line-height: 1.5;
  }
  .pb-combo-card-price {
    font-size: 22px;
    font-weight: 900;
    color: var(--pb-gold);
  }
  .pb-combo-card-btn {
    display: inline-block;
    align-self: flex-start;
    background: linear-gradient(120deg, #C9972C, #D4A843);
    color: #1A0800;
    font-size: 12px;
    font-weight: 900;
    padding: 8px 20px;
    border-radius: 30px;
    text-decoration: none;
    transition: filter 0.2s, transform 0.2s;
    margin-top: 4px;
  }
  .pb-combo-card-btn:hover { filter: brightness(1.1); transform: scale(1.03); }

  /* ─── DELIVERY SECTION ─── */
  .pb-delivery {
    background: var(--pb-bg);
    padding: 40px 20px;
    border-top: 1px solid rgba(212,168,67,0.1);
    position: relative;
    z-index: 1;
  }
  .pb-delivery-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 640px) {
    .pb-delivery-inner { grid-template-columns: 1fr; }
  }
  .pb-delivery-card {
    background: var(--pb-card);
    border: 1px solid var(--pb-border);
    border-radius: var(--pb-radius);
    padding: 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
    transition: border-color 0.2s;
  }
  .pb-delivery-card:hover { border-color: rgba(212,168,67,0.3); }
  .pb-delivery-icon-box {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    background: rgba(212,168,67,0.1);
    border: 1px solid rgba(212,168,67,0.2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
  }
  .pb-delivery-text-title {
    font-size: 14px;
    font-weight: 900;
    color: var(--pb-text);
    margin-bottom: 3px;
  }
  .pb-delivery-text-desc {
    font-size: 12px;
    color: var(--pb-text2);
    line-height: 1.4;
  }

  /* ─── RESPONSIVE HERO MOBILE ─── */
  @media (max-width: 640px) {
    .pb-hero-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding-top: 40px;
    }
    .pb-hero-left { max-width: 100%; }
    .pb-hero-sub  { max-width: 100%; }
    .pb-hero-pills { justify-content: center; }
    .pb-hero-right { width: 120px; height: 120px; font-size: 56px; }
    .pb-hero-mandala { display: none; }
    .pb-culture-divider { display: none; }
    .pb-culture-item { width: 50%; text-align: center; padding: 3px 8px; }
    .pb-story-inner { flex-direction: column; text-align: center; gap: 28px; }
    .pb-story-body { max-width: 100%; margin: 0 auto 24px; }
    .pb-story-stats { justify-content: center; }
  }

  /* ─── LIGHT MODE SPECIFIC OVERRIDES ─── */
  html:not([data-theme="dark"]) .pb-hero-eyebrow {
    background: rgba(139,26,26,0.08);
    border-color: rgba(180,100,10,0.35);
    color: var(--pb-maroon);
  }
  html:not([data-theme="dark"]) .pb-hero-sub {
    color: var(--pb-text2);
  }
  html:not([data-theme="dark"]) .pb-hero-pill {
    background: rgba(180,100,10,0.07);
    border-color: rgba(180,100,10,0.2);
    color: var(--pb-text2);
  }
  html:not([data-theme="dark"]) .pb-culture-bar {
    border-top-color: rgba(120,60,10,0.2);
    border-bottom-color: rgba(120,60,10,0.2);
  }
  html:not([data-theme="dark"]) .pb-filter-pill {
    background: rgba(180,100,10,0.05);
    border-color: rgba(120,60,10,0.2);
    color: var(--pb-text2);
  }
  html:not([data-theme="dark"]) .pb-filter-pill:hover {
    border-color: rgba(120,60,10,0.4);
    color: var(--pb-maroon);
    background: rgba(180,100,10,0.1);
  }
  html:not([data-theme="dark"]) .pb-story {
    border-top-color: rgba(120,60,10,0.15);
  }
  html:not([data-theme="dark"]) .pb-story-circle {
    border-color: rgba(120,60,10,0.15);
  }
  html:not([data-theme="dark"]) .pb-story-stat {
    background: rgba(180,100,10,0.06);
    border-color: rgba(120,60,10,0.15);
  }
  html:not([data-theme="dark"]) .pb-delivery {
    border-top-color: rgba(120,60,10,0.1);
  }
  html:not([data-theme="dark"]) .pb-delivery-card {
    border-color: rgba(120,60,10,0.15);
  }
  html:not([data-theme="dark"]) .pb-delivery-icon-box {
    background: rgba(180,100,10,0.08);
    border-color: rgba(120,60,10,0.2);
  }
  html:not([data-theme="dark"]) .pb-card {
    border-color: rgba(120,60,10,0.12);
    box-shadow: 0 2px 12px rgba(100,40,0,0.08);
  }
  html:not([data-theme="dark"]) .pb-card:hover {
    border-color: rgba(180,100,10,0.3);
    box-shadow: 0 10px 36px rgba(100,40,0,0.16);
  }
  html:not([data-theme="dark"]) .pb-card::before {
    background: linear-gradient(90deg, var(--pb-maroon), #C9772C, var(--pb-maroon));
  }
  html:not([data-theme="dark"]) .pb-card-cat {
    color: var(--pb-maroon);
  }
  html:not([data-theme="dark"]) .pb-stepper {
    background: rgba(180,100,10,0.06);
    border-color: rgba(120,60,10,0.22);
  }
  html:not([data-theme="dark"]) .pb-add-btn {
    background: linear-gradient(120deg, #8B2E00, #C9772C, #8B2E00) !important;
    color: #fff !important;
    box-shadow: 0 3px 12px rgba(139,46,0,0.25) !important;
  }
  html:not([data-theme="dark"]) .pb-add-btn:hover {
    box-shadow: 0 5px 18px rgba(139,46,0,0.4) !important;
  }
  html:not([data-theme="dark"]) .pb-combo-card {
    border-color: rgba(120,60,10,0.12);
  }
  html:not([data-theme="dark"]) .pb-section-title::after {
    background: linear-gradient(90deg, var(--pb-maroon), transparent);
  }

  /* ─── LOADING SPINNER on add ─── */
  @keyframes pb-spin-btn {
    to { transform: rotate(360deg); }
  }
  .pb-add-btn.loading::after {
    content: '';
    display: inline-block;
    width: 10px;
    height: 10px;
    border: 2px solid rgba(26,8,0,0.4);
    border-top-color: #1A0800;
    border-radius: 50%;
    animation: pb-spin-btn 0.6s linear infinite;
    margin-left: 6px;
    vertical-align: middle;
  }
</style>

<div class="pb-wrap" id="pb-wrap">

  <!-- Decorative mandala SVG overlay -->
  <svg class="pb-mandala-bg" viewBox="0 0 700 700" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <g fill="none" stroke="#D4A843" stroke-width="1">
      <circle cx="350" cy="350" r="340"/>
      <circle cx="350" cy="350" r="280"/>
      <circle cx="350" cy="350" r="220"/>
      <circle cx="350" cy="350" r="160"/>
      <circle cx="350" cy="350" r="100"/>
      <circle cx="350" cy="350" r="50"/>
      <!-- Radial lines -->
      {% for i in (0..23) %}
        {% assign angle = i | times: 15 %}
        {% assign angle_rad = angle | times: 3.14159 | divided_by: 180.0 %}
        <line x1="350" y1="350" x2="{{ 350 | plus: 340 }}" y2="350" transform="rotate({{ angle }}, 350, 350)"/>
      {% endfor %}
      <!-- Petal shapes -->
      <ellipse cx="350" cy="180" rx="28" ry="60" transform="rotate(0,350,350)"/>
      <ellipse cx="350" cy="180" rx="28" ry="60" transform="rotate(45,350,350)"/>
      <ellipse cx="350" cy="180" rx="28" ry="60" transform="rotate(90,350,350)"/>
      <ellipse cx="350" cy="180" rx="28" ry="60" transform="rotate(135,350,350)"/>
      <ellipse cx="350" cy="180" rx="28" ry="60" transform="rotate(180,350,350)"/>
      <ellipse cx="350" cy="180" rx="28" ry="60" transform="rotate(225,350,350)"/>
      <ellipse cx="350" cy="180" rx="28" ry="60" transform="rotate(270,350,350)"/>
      <ellipse cx="350" cy="180" rx="28" ry="60" transform="rotate(315,350,350)"/>
    </g>
  </svg>

  <!-- ═══════════════════════════════════════ HERO ═══════════════════════════════════════ -->
