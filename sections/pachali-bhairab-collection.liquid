          <span class="pb-hero-pill">🔥 Made to Order</span>
        </div>
        <a href="#pb-content" class="pb-hero-cta">Order Now →</a>
      </div>
      <div class="pb-hero-right">🍽️</div>
    </div>

    <!-- Wave separator -->
    <div class="pb-hero-wave">
      <svg viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;height:48px;">
        <path d="M0,32 C240,0 480,48 720,24 C960,0 1200,40 1440,20 L1440,48 L0,48 Z" fill="var(--pb-bg)" opacity="0.6"/>
        <path d="M0,40 C360,12 720,46 1080,28 C1260,18 1380,42 1440,36 L1440,48 L0,48 Z" fill="#8B1A1A" opacity="0.08"/>
      </svg>
    </div>
  </section>

  <!-- ═════════════════════════════════ CULTURE BAR ═════════════════════════════════════ -->
  <div class="pb-culture-bar">
    <div class="pb-culture-bar-inner">
      <span class="pb-culture-item">🏛️ Est. Kathmandu</span>
      <span class="pb-culture-divider">|</span>
      <span class="pb-culture-item">🍶 Aila &amp; Chiura</span>
      <span class="pb-culture-divider">|</span>
      <span class="pb-culture-item">⭐ 4.8 Rated</span>
      <span class="pb-culture-divider">|</span>
      <span class="pb-culture-item">🎭 500+ Orders</span>
    </div>
  </div>

  <!-- ══════════════════════════════════ PILLS BAR ══════════════════════════════════════ -->
  <div class="pb-pills-bar">
    <div class="pb-pills-bar-inner" id="pb-pills-bar">
      <button class="pb-filter-pill active" data-filter="all">🍽️ All Dishes</button>
      <button class="pb-filter-pill" data-filter="popular">🔥 Popular</button>
      <button class="pb-filter-pill" data-filter="meat specials">🥩 Meat Specials</button>
      <button class="pb-filter-pill" data-filter="traditional snacks">🥟 Traditional Snacks</button>
      <button class="pb-filter-pill" data-filter="local drinks">🍶 Local Drinks</button>
      <button class="pb-filter-pill" data-filter="set meals">🎁 Set Meals</button>
      <button class="pb-filter-pill" data-filter="vegetarian">🌱 Vegetarian</button>
    </div>
  </div>

  <!-- ══════════════════════════════════ PRODUCT GRID ═══════════════════════════════════ -->
  <section class="pb-grid-section" id="pb-content">
    <div class="pb-grid" id="pb-grid">

      {% if collection.products.size > 0 %}
        {% for product in collection.products %}
          {% assign product_type_lower = product.type | downcase | strip %}
          {% assign product_tags_lower = product.tags | join: ',' | downcase %}
          {% assign has_compare = false %}
          {% if product.compare_at_price > product.price %}
            {% assign has_compare = true %}
          {% endif %}
          {% assign discount_pct = 0 %}
          {% if has_compare %}
            {% assign diff = product.compare_at_price | minus: product.price %}
            {% assign discount_pct = diff | times: 100 | divided_by: product.compare_at_price %}
          {% endif %}

          <div class="pb-card"
               data-cat="{{ product_type_lower }}"
               data-url="{{ product.url }}"
               data-price="{{ product.price }}"
               data-title="{{ product.title | downcase | escape }}"
               data-id="{{ product.variants.first.id }}">

            <!-- Image area -->
            <div class="pb-card-img-wrap">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '480x360', crop: 'center' }}"
                     alt="{{ product.featured_image.alt | default: product.title | escape }}"
                     loading="lazy"
                     width="480"
                     height="360">
              {% else %}
                <div class="pb-card-img-placeholder">🍽️</div>
              {% endif %}

              <!-- Badges -->
              <div class="pb-badges">
                <span class="pb-badge pb-badge--fresh">🍃 Fresh</span>
                {% if product_tags_lower contains 'bestseller' or product_tags_lower contains 'popular' %}
                  <span class="pb-badge pb-badge--best">🔥 Bestseller</span>
                {% endif %}
                {% if product_tags_lower contains 'traditional' %}
                  <span class="pb-badge pb-badge--trad">🏺 Traditional Pick</span>
                {% endif %}
                {% if product_tags_lower contains 'spicy' %}
                  <span class="pb-badge pb-badge--spicy">🌶 Spicy</span>
                {% endif %}
              </div>

              <!-- Discount badge -->
              {% if has_compare %}
                <span class="pb-discount-badge">{{ discount_pct }}% OFF</span>
              {% endif %}

              <!-- Quick view overlay -->
              <div class="pb-card-overlay">
                <span class="pb-card-overlay-text">Quick View</span>
              </div>
            </div>

            <!-- Card body -->
            <div class="pb-card-body">
              {% if product.type != blank %}
                <div class="pb-card-cat">{{ product.type }}</div>
              {% else %}
                <div class="pb-card-cat">🏺 Newari Special</div>
              {% endif %}
              <div class="pb-card-name">{{ product.title }}</div>
              {% if product.description != blank %}
                <div class="pb-card-desc">{{ product.description | strip_html | truncate: 80 }}</div>
              {% else %}
                <div class="pb-card-desc">Authentic Newari recipe, freshly prepared daily.</div>
              {% endif %}

              <div class="pb-card-bottom">
                <div class="pb-card-price-row">
                  <span class="pb-card-price">Rs {{ product.price | divided_by: 100 }}</span>
                  {% if has_compare %}
                    <span class="pb-card-compare">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                  {% endif %}
                </div>
                <div class="pb-card-actions">
                  <button class="pb-add-btn"
                          data-variant-id="{{ product.variants.first.id }}"
                          data-product-id="{{ product.id }}"
                          data-title="{{ product.title | escape }}"
                          onclick="event.stopPropagation();">
                    🛒 Add to Cart
                  </button>
                  <div class="pb-stepper"
                       data-variant-id="{{ product.variants.first.id }}"
                       data-line="">
                    <button class="pb-stepper-btn pb-stepper-minus" onclick="event.stopPropagation();">−</button>
                    <span class="pb-stepper-qty">1</span>
                    <button class="pb-stepper-btn pb-stepper-plus" onclick="event.stopPropagation();">+</button>
                  </div>
                </div>
              </div>
            </div>

          </div>
        {% endfor %}

        <!-- No results (shown by JS when filter matches nothing) -->
        <div class="pb-no-results" id="pb-no-results">
          <p>No dishes found in this category. Try another filter!</p>
        </div>

      {% else %}
        <!-- Empty collection state -->
        <div class="pb-empty">
          <div class="pb-empty-icon">🍽️</div>
          <div class="pb-empty-title">Coming Soon</div>
          <div class="pb-empty-desc">We're preparing something delicious. Check back soon!</div>
        </div>
      {% endif %}

    </div>
  </section>

  <!-- ══════════════════════════════════ STORY SECTION ═════════════════════════════════ -->
