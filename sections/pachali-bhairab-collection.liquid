{% comment %} Pachali Bhairab Collection — Mobile-First Premium UI {% endcomment %}

<style>
/* ═══════════════════════════════════════════
   TOKENS — light vs dark
═══════════════════════════════════════════ */
html:not([data-theme="dark"]) .pb-root {
  --pb-page:     #F5F2EE;
  --pb-card:     #FFFFFF;
  --pb-card2:    #FAF7F3;
  --pb-text:     #1A0800;
  --pb-text2:    #6B3A1F;
  --pb-text3:    #B8855A;
  --pb-gold:     #B8600A;
  --pb-gold2:    #D4800C;
  --pb-gold-bg:  rgba(180,96,10,0.08);
  --pb-maroon:   #8B1A1A;
  --pb-border:   rgba(100,50,10,0.12);
  --pb-shadow:   0 2px 12px rgba(80,30,0,0.08);
  --pb-shadow-md:0 6px 24px rgba(80,30,0,0.13);
  --pb-inp-bg:   rgba(100,50,10,0.06);
  --pb-hero-bg:  linear-gradient(160deg,#7B0F00 0%,#B02800 45%,#6B0C00 100%);
  --pb-pills-bg: rgba(245,242,238,0.95);
  --pb-strip-bg: linear-gradient(90deg,#5C0E00,#8B2000,#5C0E00);
  --pb-story-bg: #FFF2DC;
  --pb-footer-bg:#FFF8EE;
  /* hero text always cream */
  --pb-hero-text:#F5E6C8;
  --pb-hero-t2:  rgba(245,230,200,0.65);
  --pb-hero-pill:rgba(245,230,200,0.12);
  --pb-hero-pillt:rgba(245,230,200,0.75);
}
html[data-theme="dark"] .pb-root {
  --pb-page:     #0E0700;
  --pb-card:     #1A0D02;
  --pb-card2:    #140900;
  --pb-text:     #F5E6C8;
  --pb-text2:    #C4956A;
  --pb-text3:    #7A5535;
  --pb-gold:     #D4A843;
  --pb-gold2:    #F0CC70;
  --pb-gold-bg:  rgba(212,168,67,0.10);
  --pb-maroon:   #8B1A1A;
  --pb-border:   rgba(212,168,67,0.12);
  --pb-shadow:   0 2px 16px rgba(0,0,0,0.45);
  --pb-shadow-md:0 8px 32px rgba(0,0,0,0.6);
  --pb-inp-bg:   rgba(212,168,67,0.06);
  --pb-hero-bg:  linear-gradient(160deg,#2A0800 0%,#1A0500 45%,#0D0300 100%);
  --pb-pills-bg: rgba(14,7,0,0.96);
  --pb-strip-bg: linear-gradient(90deg,#2A0800,#3D1400,#2A0800);
  --pb-story-bg: #1A0D02;
  --pb-footer-bg:#110800;
  --pb-hero-text:#F5E6C8;
  --pb-hero-t2:  rgba(245,230,200,0.60);
  --pb-hero-pill:rgba(245,230,200,0.08);
  --pb-hero-pillt:rgba(245,230,200,0.65);
}

/* ═══════════════════════════════════════════
   BASE
═══════════════════════════════════════════ */
.pb-root { background:var(--pb-page); color:var(--pb-text); font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; }
.pb-root *,.pb-root *::before,.pb-root *::after { box-sizing:border-box; margin:0; padding:0; }

/* ═══════════════════════════════════════════
   HERO — compact mobile-first
═══════════════════════════════════════════ */
.pb-hero {
  background: var(--pb-hero-bg);
  position: relative; overflow: hidden;
  padding: 28px 16px 0;
}
.pb-hero-glow {
  position:absolute; top:-80px; right:-60px;
  width:320px; height:320px; border-radius:50%;
  background:radial-gradient(circle,rgba(212,168,67,0.16) 0%,transparent 65%);
  pointer-events:none;
}
.pb-hero-dots {
  position:absolute; inset:0; pointer-events:none;
  background-image:radial-gradient(rgba(255,255,255,0.035) 1px,transparent 1px);
  background-size:24px 24px;
}
/* Spinning mandala top-right */
.pb-hero-mandala-ring {
  position:absolute; top:-20px; right:-20px;
  width:160px; height:160px; border-radius:50%;
  border:1px solid rgba(212,168,67,0.08);
  animation:pb-spin 50s linear infinite;
  pointer-events:none;
}
.pb-hero-mandala-ring::before {
  content:''; position:absolute; inset:20px; border-radius:50%;
  border:1px solid rgba(212,168,67,0.06);
}
.pb-hero-mandala-ring::after {
  content:''; position:absolute; inset:40px; border-radius:50%;
  border:1px solid rgba(212,168,67,0.05);
}
@keyframes pb-spin { to{transform:rotate(360deg)} }
@keyframes pb-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
@keyframes pb-fade-up { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:none} }

.pb-hero-inner {
  position:relative; z-index:2;
  display:flex; align-items:center; justify-content:space-between; gap:12px;
  max-width:960px; margin:0 auto;
}
.pb-hero-left { flex:1; min-width:0; }
.pb-hero-badge {
  display:inline-flex; align-items:center; gap:6px;
  background:rgba(139,26,26,0.3); border:1px solid rgba(212,168,67,0.35);
  color:var(--pb-gold); font-size:9.5px; font-weight:900;
  letter-spacing:0.12em; text-transform:uppercase;
  padding:4px 11px; border-radius:999px; margin-bottom:10px;
}
.pb-hero-dot {
  width:5px; height:5px; background:var(--pb-gold); border-radius:50%;
  box-shadow:0 0 5px rgba(212,168,67,0.9);
  animation:pb-dot-pulse 2s ease-in-out infinite;
}
@keyframes pb-dot-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(1.7)} }
.pb-hero-h1 {
  font-size:clamp(26px,7vw,46px); font-weight:900;
  color:var(--pb-hero-text); line-height:1.05;
  letter-spacing:-0.025em; margin-bottom:6px;
  font-family:Georgia,'Times New Roman',serif;
}
.pb-hero-h1 em {
  font-style:italic; display:block;
  background:linear-gradient(120deg,var(--pb-gold),#F0CC70,var(--pb-gold));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.pb-hero-sub {
  font-size:12px; color:var(--pb-hero-t2);
  line-height:1.55; margin-bottom:14px; max-width:300px;
}
.pb-hero-pills {
  display:flex; flex-wrap:wrap; gap:6px; margin-bottom:18px;
}
.pb-hero-pill {
  font-size:10.5px; font-weight:700;
  color:var(--pb-hero-pillt);
  background:var(--pb-hero-pill);
  border:1px solid rgba(212,168,67,0.18);
  border-radius:999px; padding:4px 10px; white-space:nowrap;
}
.pb-hero-right {
  flex-shrink:0;
  font-size:64px; line-height:1;
  animation:pb-float 4s ease-in-out infinite;
  filter:drop-shadow(0 4px 16px rgba(212,168,67,0.25));
}
@media(max-width:380px){ .pb-hero-right { font-size:48px; } }

/* Rating bar */
.pb-rating-bar {
  position:relative; z-index:2;
  display:flex; align-items:center; justify-content:center; gap:0;
  background:rgba(255,255,255,0.06); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
  border:1px solid rgba(212,168,67,0.15); border-bottom:none;
  border-radius:16px 16px 0 0; overflow:hidden;
  max-width:960px; margin:16px auto 0;
}
.pb-rating-item {
  flex:1; text-align:center; padding:12px 8px;
  position:relative;
}
.pb-rating-item+.pb-rating-item::before {
  content:''; position:absolute; left:0; top:20%; height:60%; width:1px;
  background:rgba(212,168,67,0.2);
}
.pb-rating-num {
  font-size:15px; font-weight:900; color:var(--pb-gold); line-height:1;
  letter-spacing:-0.02em;
}
.pb-rating-label {
  font-size:9.5px; font-weight:700; color:var(--pb-hero-t2);
  text-transform:uppercase; letter-spacing:0.07em; margin-top:2px;
}

/* Hero wave */
.pb-hero-wave { display:block; width:100%; line-height:0; margin-top:-1px; }

/* ═══════════════════════════════════════════
   CULTURE STRIP
═══════════════════════════════════════════ */
.pb-strip {
  background:var(--pb-strip-bg);
  border-top:1px solid rgba(212,168,67,0.18);
  border-bottom:1px solid rgba(212,168,67,0.18);
  padding:8px 0; overflow:hidden;
}
.pb-strip-track {
  display:flex; gap:0; width:max-content;
  animation:pb-scroll 22s linear infinite;
}
.pb-strip:hover .pb-strip-track { animation-play-state:paused; }
@keyframes pb-scroll { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.pb-strip-item {
  display:flex; align-items:center; gap:6px; padding:2px 20px;
  font-size:10.5px; font-weight:800; letter-spacing:0.09em;
  text-transform:uppercase; color:var(--pb-gold); white-space:nowrap;
}
.pb-strip-sep { color:rgba(212,168,67,0.3); font-size:14px; }

/* ═══════════════════════════════════════════
   FILTER PILLS
═══════════════════════════════════════════ */
.pb-pills-bar {
  position:sticky; top:60px; z-index:100;
  background:var(--pb-pills-bg);
  backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid var(--pb-border);
  padding:10px 0;
}
.pb-pills-scroll {
  display:flex; gap:8px; padding:0 14px;
  overflow-x:auto; scrollbar-width:none; -ms-overflow-style:none;
}
.pb-pills-scroll::-webkit-scrollbar { display:none; }
.pb-filter-pill {
  flex-shrink:0; font-size:12px; font-weight:700;
  border-radius:999px; padding:8px 16px;
  cursor:pointer; border:1.5px solid var(--pb-border);
  background:transparent; color:var(--pb-text2);
  transition:all 0.2s; white-space:nowrap;
  user-select:none; -webkit-user-select:none;
  min-height:36px; display:flex; align-items:center;
  font-family:inherit;
}
.pb-filter-pill:hover { border-color:var(--pb-gold); color:var(--pb-gold); }
.pb-filter-pill.active {
  background:linear-gradient(120deg,#C9972C,#D4A843);
  color:#1A0800 !important; border-color:transparent;
  box-shadow:0 3px 12px rgba(212,168,67,0.3);
}

/* ═══════════════════════════════════════════
   SECTION TITLE
═══════════════════════════════════════════ */
.pb-section-head {
  max-width:960px; margin:0 auto;
  padding:18px 14px 10px;
  display:flex; align-items:center; justify-content:space-between;
}
.pb-grid-wrap {
  max-width:960px; margin:0 auto;
  padding:0 10px 48px;
  display:flex; flex-direction:column; gap:10px;
}
.pb-section-title {
  font-size:16px; font-weight:900; color:var(--pb-text);
  display:flex; align-items:center; gap:8px;
}
.pb-section-count {
  font-size:11px; font-weight:700; color:var(--pb-text3);
  background:var(--pb-gold-bg); border:1px solid var(--pb-border);
  border-radius:999px; padding:3px 9px;
}

/* ═══════════════════════════════════════════
   PRODUCT GRID — horizontal cards mobile-first
═══════════════════════════════════════════ */

/* ── Mobile: horizontal card ── */
.pb-card {
  background:var(--pb-card);
  border:1px solid var(--pb-border);
  border-radius:16px;
  display:flex; flex-direction:row; align-items:stretch;
  overflow:hidden; cursor:pointer;
  transition:transform 0.22s, box-shadow 0.22s, border-color 0.18s;
  box-shadow:var(--pb-shadow);
  position:relative;
  text-decoration:none;
}
.pb-card:hover {
  transform:translateY(-2px);
  box-shadow:var(--pb-shadow-md);
  border-color:rgba(212,168,67,0.35);
}
.pb-card.pb-hidden { display:none; }

/* Image */
.pb-card-img {
  width:105px; min-width:105px; height:105px;
  position:relative; overflow:hidden; flex-shrink:0;
  background:var(--pb-inp-bg);
}
@media(min-width:400px){ .pb-card-img { width:118px; min-width:118px; height:118px; } }
@media(min-width:480px){ .pb-card-img { width:130px; min-width:130px; height:130px; } }
.pb-card-img img {
  width:100%; height:100%; object-fit:cover; display:block;
  transition:transform 0.4s ease;
}
.pb-card:hover .pb-card-img img { transform:scale(1.07); }
.pb-card-img-placeholder {
  width:100%; height:100%;
  display:flex; align-items:center; justify-content:center;
  font-size:36px; color:var(--pb-text3);
}

/* Badges on image */
.pb-badges {
  position:absolute; top:6px; left:6px;
  display:flex; flex-direction:column; gap:3px; z-index:2;
}
.pb-badge {
  font-size:8.5px; font-weight:900; padding:2px 7px;
  border-radius:20px; line-height:1.5; letter-spacing:0.02em;
  backdrop-filter:blur(4px); white-space:nowrap;
}
.pb-badge--fresh { background:rgba(27,94,32,0.88); color:#A5D6A7; }
.pb-badge--best  { background:rgba(139,26,26,0.88); color:#FFCDD2; }
.pb-badge--trad  { background:rgba(201,151,44,0.88); color:#111; }
.pb-badge--spicy { background:rgba(191,54,12,0.88); color:#FFCCBC; }
.pb-discount-tag {
  position:absolute; top:6px; right:6px; z-index:2;
  background:linear-gradient(135deg,#c62828,#e53935);
  color:#fff; font-size:8.5px; font-weight:900;
  padding:3px 8px; border-radius:20px;
  box-shadow:0 2px 6px rgba(198,40,40,0.45);
}

/* Body */
.pb-card-body {
  flex:1; min-width:0;
  padding:10px 12px 10px;
  display:flex; flex-direction:column; justify-content:space-between;
  gap:2px;
}
.pb-card-cat {
  font-size:8.5px; font-weight:900; letter-spacing:0.1em;
  text-transform:uppercase; color:var(--pb-gold); margin-bottom:2px; opacity:0.85;
}
.pb-card-name {
  font-size:13.5px; font-weight:800; color:var(--pb-text);
  line-height:1.3; margin-bottom:3px;
  display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;
}
.pb-card-desc {
  font-size:11px; color:var(--pb-text3); line-height:1.4;
  display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;
  margin-bottom:6px; flex:1;
}
.pb-card-footer {
  display:flex; align-items:center; justify-content:space-between; gap:8px;
  flex-wrap:nowrap; min-width:0;
}
.pb-card-price {
  font-size:16px; font-weight:900; color:var(--pb-gold);
  line-height:1; letter-spacing:-0.01em; white-space:nowrap;
}
.pb-card-compare {
  font-size:11px; font-weight:500; color:var(--pb-text3);
  text-decoration:line-through; white-space:nowrap;
}
.pb-card-prices { display:flex; align-items:baseline; gap:5px; flex-shrink:0; }

/* Add button (small, right-aligned on mobile) */
.pb-add-btn {
  background:linear-gradient(120deg,#C9972C,#D4A843) !important;
  color:#1A0800 !important; border:none !important;
  border-radius:9px !important; padding:8px 13px !important;
  font-size:12px !important; font-weight:900 !important;
  cursor:pointer !important; font-family:inherit !important;
  white-space:nowrap !important; flex-shrink:0 !important;
  transition:all 0.2s !important;
  box-shadow:0 2px 8px rgba(212,168,67,0.28) !important;
  line-height:1 !important;
}
.pb-add-btn:active { transform:scale(0.93) !important; }
.pb-add-btn.loading {
  opacity:0.7 !important; pointer-events:none !important;
}
.pb-add-btn.loading::after {
  content:''; display:inline-block; width:9px; height:9px;
  border:2px solid rgba(0,0,0,0.3); border-top-color:#000;
  border-radius:50%; animation:pb-spin-btn 0.6s linear infinite;
  margin-left:6px; vertical-align:middle;
}
@keyframes pb-spin-btn { to{transform:rotate(360deg)} }

/* Stepper */
.pb-stepper {
  display:none; align-items:center; overflow:hidden;
  background:var(--pb-gold-bg);
  border:1.5px solid rgba(212,168,67,0.35); border-radius:10px;
  height:34px; flex-shrink:0;
}
.pb-stepper.visible { display:flex; }
.pb-stepper-btn {
  background:none; border:none; color:var(--pb-gold);
  font-size:16px; font-weight:900; padding:0 12px;
  cursor:pointer; height:100%; transition:background 0.15s; font-family:inherit;
}
.pb-stepper-btn:hover { background:rgba(212,168,67,0.15); }
.pb-stepper-qty {
  font-size:13px; font-weight:900; color:var(--pb-text);
  min-width:20px; text-align:center; padding:0 2px;
}

/* ── Tablet+: 2-col grid cards ── */
@media(min-width:600px) {
  .pb-grid-wrap {
    display:grid; grid-template-columns:repeat(2,1fr); gap:16px;
    align-items:start;
  }
  .pb-card {
    flex-direction:column; height:100%;
  }
  .pb-card-img {
    width:100%; min-width:0;
    aspect-ratio:4/3; height:auto;
    position:relative;
  }
  .pb-card-img img {
    position:absolute; inset:0; width:100%; height:100%;
  }
  .pb-card-img-placeholder {
    position:absolute; inset:0; font-size:48px;
  }
  .pb-card-body {
    padding:12px 14px 14px;
  }
  .pb-card-footer {
    flex-direction:column; align-items:stretch; gap:10px;
  }
  .pb-card-prices {
    justify-content:flex-start;
  }
  .pb-add-btn {
    width:100% !important; padding:11px 0 !important;
    border-radius:12px !important; font-size:13px !important;
    text-align:center !important; display:block !important;
  }
  .pb-stepper {
    width:100%; justify-content:space-between; height:40px;
    border-radius:12px;
  }
}
@media(min-width:900px) {
  .pb-grid-wrap { grid-template-columns:repeat(3,1fr); }
}
@media(min-width:1200px) {
  .pb-grid-wrap { grid-template-columns:repeat(4,1fr); }
}

/* Empty / No results */
.pb-empty,.pb-no-results {
  padding:48px 20px; text-align:center; color:var(--pb-text2);
  grid-column:1/-1;
}
.pb-no-results { display:none; }
.pb-no-results.visible { display:block; }
.pb-empty-icon { font-size:44px; margin-bottom:12px; opacity:0.5; }
.pb-empty-title { font-size:17px; font-weight:800; color:var(--pb-text); margin-bottom:6px; }

/* ═══════════════════════════════════════════
   STORY SECTION
═══════════════════════════════════════════ */
.pb-story {
  background:var(--pb-story-bg);
  border-top:1px solid var(--pb-border);
  padding:36px 16px;
}
.pb-story-inner {
  max-width:960px; margin:0 auto;
  display:grid; grid-template-columns:1fr; gap:20px;
}
@media(min-width:640px) {
  .pb-story-inner { grid-template-columns:auto 1fr; align-items:center; gap:36px; }
}
.pb-story-icon-col {
  display:flex; flex-direction:column; align-items:center; gap:12px;
}
.pb-story-big-icon { font-size:52px; line-height:1; }
.pb-story-circles { position:relative; width:80px; height:80px; }
.pb-story-circle {
  position:absolute; border-radius:50%;
  border:1px solid rgba(212,168,67,0.12);
}
.pb-story-circle:nth-child(1){inset:0}
.pb-story-circle:nth-child(2){inset:14px;border-color:rgba(212,168,67,0.08)}
.pb-story-circle:nth-child(3){inset:28px;border-color:rgba(212,168,67,0.06)}
.pb-story-eyebrow {
  font-size:10px; font-weight:900; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--pb-gold); margin-bottom:8px;
}
.pb-story-h2 {
  font-size:clamp(20px,4vw,30px); font-weight:900;
  font-family:Georgia,'Times New Roman',serif;
  background:linear-gradient(120deg,var(--pb-gold),#F0CC70);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  line-height:1.2; margin-bottom:12px;
}
.pb-story-body {
  font-size:13.5px; line-height:1.75; color:var(--pb-text2);
  margin-bottom:20px;
}
.pb-story-stats {
  display:flex; gap:10px; flex-wrap:wrap;
}
.pb-story-stat {
  background:var(--pb-gold-bg); border:1px solid var(--pb-border);
  border-radius:12px; padding:10px 14px; flex:1; min-width:100px;
}
.pb-story-stat-icon { font-size:18px; margin-bottom:4px; }
.pb-story-stat-label {
  font-size:9px; font-weight:800; letter-spacing:0.1em;
  text-transform:uppercase; color:var(--pb-text3); margin-bottom:1px;
}
.pb-story-stat-value { font-size:12px; font-weight:900; color:var(--pb-gold); }

/* ═══════════════════════════════════════════
   FOOTER STRIP
═══════════════════════════════════════════ */
.pb-footer {
  background:var(--pb-footer-bg); border-top:1px solid var(--pb-border);
  padding:20px 16px 32px;
}
.pb-footer-inner {
  max-width:960px; margin:0 auto;
  display:grid; grid-template-columns:1fr; gap:10px;
}
@media(min-width:600px){ .pb-footer-inner { grid-template-columns:repeat(3,1fr); } }
.pb-footer-card {
  display:flex; gap:12px; align-items:flex-start;
  background:var(--pb-card); border:1px solid var(--pb-border);
  border-radius:14px; padding:14px 16px;
  transition:border-color 0.2s;
}
.pb-footer-card:hover { border-color:rgba(212,168,67,0.3); }
.pb-footer-icon {
  width:38px; height:38px; min-width:38px; border-radius:10px;
  background:var(--pb-gold-bg); border:1px solid var(--pb-border);
  display:flex; align-items:center; justify-content:center; font-size:18px;
}
.pb-footer-title { font-size:13px; font-weight:800; color:var(--pb-text); margin-bottom:2px; }
.pb-footer-desc  { font-size:11.5px; color:var(--pb-text2); line-height:1.4; }
</style>

<div class="pb-root">

  <!-- ══════════════ HERO ══════════════ -->
  <div class="pb-hero">
    <div class="pb-hero-glow"></div>
    <div class="pb-hero-dots"></div>
    <div class="pb-hero-mandala-ring"></div>

    <div class="pb-hero-inner">
      <div class="pb-hero-left">
        <div class="pb-hero-badge">
          <span class="pb-hero-dot"></span>
          🏛️ Pachali Bhairab · Kathmandu
        </div>
        <h1 class="pb-hero-h1">
          Authentic Newari
          <em>Flavors</em>
        </h1>
        <p class="pb-hero-sub">Handcrafted recipes passed down generations — delivered hot to your door</p>
        <div class="pb-hero-pills">
          <span class="pb-hero-pill">⚡ 15–20 min</span>
          <span class="pb-hero-pill">🍃 Fresh Daily</span>
          <span class="pb-hero-pill">🏺 Traditional</span>
          <span class="pb-hero-pill">🔥 Made to Order</span>
        </div>
      </div>
      <div class="pb-hero-right">🍛</div>
    </div>

    <div class="pb-rating-bar">
      <div class="pb-rating-item">
        <div class="pb-rating-num">⭐ 4.8</div>
        <div class="pb-rating-label">Rating</div>
      </div>
      <div class="pb-rating-item">
        <div class="pb-rating-num">500+</div>
        <div class="pb-rating-label">Orders</div>
      </div>
      <div class="pb-rating-item">
        <div class="pb-rating-num">15 min</div>
        <div class="pb-rating-label">Avg. Delivery</div>
      </div>
      <div class="pb-rating-item">
        <div class="pb-rating-num">50+</div>
        <div class="pb-rating-label">Dishes</div>
      </div>
    </div>

    <svg class="pb-hero-wave" viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="height:40px;">
      <path d="M0,28 C360,4 720,40 1080,20 C1280,8 1380,34 1440,26 L1440,40 L0,40 Z" fill="var(--pb-page)"/>
    </svg>
  </div>

  <!-- ══════════════ CULTURE STRIP ══════════════ -->
  <div class="pb-strip">
    <div class="pb-strip-track">
      <!-- doubled for seamless loop -->
      {% for n in (1..2) %}
        <span class="pb-strip-item">🏛️ Est. Kathmandu</span><span class="pb-strip-sep">|</span>
        <span class="pb-strip-item">🥩 Choila &amp; Baji</span><span class="pb-strip-sep">|</span>
        <span class="pb-strip-item">🍶 Aila &amp; Chiura</span><span class="pb-strip-sep">|</span>
        <span class="pb-strip-item">⭐ 4.8 Rated</span><span class="pb-strip-sep">|</span>
        <span class="pb-strip-item">🔥 Made to Order</span><span class="pb-strip-sep">|</span>
        <span class="pb-strip-item">🥟 Traditional Snacks</span><span class="pb-strip-sep">|</span>
        <span class="pb-strip-item">🏺 Authentic Recipe</span><span class="pb-strip-sep">|</span>
        <span class="pb-strip-item">🎭 500+ Happy Customers</span><span class="pb-strip-sep">|</span>
      {% endfor %}
    </div>
  </div>

  <!-- ══════════════ FILTER PILLS ══════════════ -->
  <div class="pb-pills-bar">
    <div class="pb-pills-scroll" id="pb-pills-bar">
      <button class="pb-filter-pill active" data-filter="all">🍽️ All Dishes</button>
      <button class="pb-filter-pill" data-filter="popular">🔥 Popular</button>
      <button class="pb-filter-pill" data-filter="meat specials">🥩 Meat Specials</button>
      <button class="pb-filter-pill" data-filter="traditional snacks">🥟 Traditional Snacks</button>
      <button class="pb-filter-pill" data-filter="local drinks">🍶 Local Drinks</button>
      <button class="pb-filter-pill" data-filter="set meals">🎁 Set Meals</button>
      <button class="pb-filter-pill" data-filter="vegetarian">🌱 Vegetarian</button>
    </div>
  </div>

  <!-- ══════════════ PRODUCT GRID ══════════════ -->
  <div class="pb-section-head">
    <div class="pb-section-title">🏺 Our Menu</div>
    <span class="pb-section-count" id="pb-count">{{ collection.products.size }} items</span>
  </div>

  <div class="pb-grid-wrap" id="pb-grid">

    {% if collection.products.size > 0 %}
      {% for product in collection.products %}
        {% assign type_lower = product.type | downcase | strip %}
        {% assign tags_lower = product.tags | join: ',' | downcase %}
        {% assign has_compare = false %}
        {% if product.compare_at_price > product.price %}{% assign has_compare = true %}{% endif %}
        {% assign disc_pct = 0 %}
        {% if has_compare %}
          {% assign diff = product.compare_at_price | minus: product.price %}
          {% assign disc_pct = diff | times: 100 | divided_by: product.compare_at_price %}
        {% endif %}

        <div class="pb-card"
             data-cat="{{ type_lower }}"
             data-url="{{ product.url }}"
             data-id="{{ product.variants.first.id }}">

          <!-- Image -->
          <div class="pb-card-img">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
                   alt="{{ product.featured_image.alt | default: product.title | escape }}"
                   loading="lazy" width="400" height="400">
            {% else %}
              <div class="pb-card-img-placeholder">🍽️</div>
            {% endif %}

            <div class="pb-badges">
              {% if tags_lower contains 'bestseller' or tags_lower contains 'popular' %}
                <span class="pb-badge pb-badge--best">🔥 Bestseller</span>
              {% endif %}
              {% if tags_lower contains 'traditional' %}
                <span class="pb-badge pb-badge--trad">🏺 Traditional</span>
              {% endif %}
              {% if tags_lower contains 'spicy' %}
                <span class="pb-badge pb-badge--spicy">🌶 Spicy</span>
              {% endif %}
            </div>

            {% if has_compare %}
              <span class="pb-discount-tag">{{ disc_pct }}% OFF</span>
            {% endif %}
          </div>

          <!-- Body -->
          <div class="pb-card-body">
            {% if product.type != blank %}
              <div class="pb-card-cat">{{ product.type }}</div>
            {% else %}
              <div class="pb-card-cat">🏺 Newari Special</div>
            {% endif %}
            <div class="pb-card-name">{{ product.title }}</div>
            <div class="pb-card-desc">
              {% if product.description != blank %}
                {{ product.description | strip_html | truncate: 70 }}
              {% else %}
                Authentic Newari recipe, freshly prepared daily.
              {% endif %}
            </div>
            <div class="pb-card-footer">
              <div class="pb-card-prices">
                <span class="pb-card-price">Rs {{ product.price | divided_by: 100 }}</span>
                {% if has_compare %}
                  <span class="pb-card-compare">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                {% endif %}
              </div>
              <button class="pb-add-btn"
                      data-variant-id="{{ product.variants.first.id }}"
                      onclick="event.stopPropagation()">+ Add</button>
              <div class="pb-stepper"
                   data-variant-id="{{ product.variants.first.id }}"
                   data-line="">
                <button class="pb-stepper-btn pb-stepper-minus" onclick="event.stopPropagation()">−</button>
                <span class="pb-stepper-qty">1</span>
                <button class="pb-stepper-btn pb-stepper-plus" onclick="event.stopPropagation()">+</button>
              </div>
            </div>
          </div>

        </div>
      {% endfor %}

      <div class="pb-no-results" id="pb-no-results">
        <div class="pb-empty-icon">🍽️</div>
        <div class="pb-empty-title">No dishes in this category</div>
      </div>

    {% else %}
      <div class="pb-empty">
        <div class="pb-empty-icon">🍽️</div>
        <div class="pb-empty-title">Menu Coming Soon</div>
      </div>
    {% endif %}

  </div>

  <!-- ══════════════ STORY ══════════════ -->
  <section class="pb-story">
    <div class="pb-story-inner">
      <div class="pb-story-icon-col">
        <div class="pb-story-big-icon">🏛️</div>
        <div class="pb-story-circles">
          <div class="pb-story-circle"></div>
          <div class="pb-story-circle"></div>
          <div class="pb-story-circle"></div>
        </div>
      </div>
      <div>
        <div class="pb-story-eyebrow">✦ Our Heritage</div>
        <h2 class="pb-story-h2">A Taste of Newari Culture</h2>
        <p class="pb-story-body">Pachali Bhairab Food Court brings you the soul of Newari cuisine — from the sacred streets of Kathmandu. Every plate of Samay Baji, every bite of Choila, every sip of Aila carries the spirit of our ancestors.</p>
        <div class="pb-story-stats">
          <div class="pb-story-stat">
            <div class="pb-story-stat-icon">🏺</div>
            <div class="pb-story-stat-label">Recipes</div>
            <div class="pb-story-stat-value">50+ Traditional</div>
          </div>
          <div class="pb-story-stat">
            <div class="pb-story-stat-icon">🌿</div>
            <div class="pb-story-stat-label">Ingredients</div>
            <div class="pb-story-stat-value">Locally Sourced</div>
          </div>
          <div class="pb-story-stat">
            <div class="pb-story-stat-icon">⚡</div>
            <div class="pb-story-stat-label">Delivery</div>
            <div class="pb-story-stat-value">15–20 Mins</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════ FOOTER ══════════════ -->
  <div class="pb-footer">
    <div class="pb-footer-inner">
      <div class="pb-footer-card">
        <div class="pb-footer-icon">🚀</div>
        <div>
          <div class="pb-footer-title">Fast Delivery</div>
          <div class="pb-footer-desc">15–20 mins across KTM Valley</div>
        </div>
      </div>
      <div class="pb-footer-card">
        <div class="pb-footer-icon">🍺</div>
        <div>
          <div class="pb-footer-title">Fresh &amp; Hot</div>
          <div class="pb-footer-desc">Prepared fresh on every order</div>
        </div>
      </div>
      <div class="pb-footer-card">
        <div class="pb-footer-icon">⚡</div>
        <div>
          <div class="pb-footer-title">Order in 4 Clicks</div>
          <div class="pb-footer-desc">Browse → Add → Checkout → Done</div>
        </div>
      </div>
    </div>
  </div>

</div><!-- /.pb-root -->

<script>
(function () {
  'use strict';
  var grid     = document.getElementById('pb-grid');
  var pillsBar = document.getElementById('pb-pills-bar');
  var noRes    = document.getElementById('pb-no-results');

  /* ── Filter pills ── */
  if (pillsBar) {
    pillsBar.addEventListener('click', function (e) {
      var pill = e.target.closest('.pb-filter-pill');
      if (!pill) return;
      Array.from(pillsBar.querySelectorAll('.pb-filter-pill')).forEach(function (p) { p.classList.remove('active'); });
      pill.classList.add('active');
      filterCards(pill.getAttribute('data-filter'));
      /* smooth scroll pill into view */
      pill.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'smooth' });
    });
  }

  function filterCards(filter) {
    var cards = Array.from(grid.querySelectorAll('.pb-card'));
    var shown = 0;
    cards.forEach(function (c) {
      var cat = (c.getAttribute('data-cat') || '').toLowerCase();
      var match = filter === 'all' || cat === filter || cat.indexOf(filter) !== -1 || (filter.indexOf(cat) !== -1 && cat !== '');
      c.classList.toggle('pb-hidden', !match);
      if (match) shown++;
    });
    if (noRes) noRes.classList.toggle('visible', shown === 0 && cards.length > 0);
  }

  /* ── Card tap → navigate ── */
  if (grid) {
    grid.addEventListener('click', function (e) {
      if (e.target.closest('.pb-add-btn') || e.target.closest('.pb-stepper') || e.target.closest('button')) return;
      var card = e.target.closest('.pb-card');
      if (card) { var url = card.getAttribute('data-url'); if (url) window.location.href = url; }
    });
  }

  /* ── Cart helpers ── */
  function bumpCartCount(d) {
    document.querySelectorAll('[data-cart-count],.cart-count,.cart__count,#cart-count,.header__cart-count').forEach(function (el) {
      var n = Math.max(0, parseInt(el.textContent || el.getAttribute('data-cart-count') || '0', 10) + d);
      el.textContent = n;
      if (el.hasAttribute('data-cart-count')) el.setAttribute('data-cart-count', n);
    });
  }
  function getLine(vid, cb) {
    fetch('/cart.js').then(function (r) { return r.json(); }).then(function (cart) {
      var idx = 0;
      for (var i = 0; i < cart.items.length; i++) {
        if (String(cart.items[i].variant_id) === String(vid)) { idx = i + 1; break; }
      }
      cb(idx);
    }).catch(function () { cb(0); });
  }

  /* ── Add to cart ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.pb-add-btn');
    if (!btn || btn.classList.contains('loading')) return;
    var vid = btn.getAttribute('data-variant-id');
    if (!vid) return;
    btn.classList.add('loading');
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: 1 })
    })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (d.status && d.status !== 200) throw new Error(d.description);
      btn.classList.remove('loading');
      bumpCartCount(1);
      var card = btn.closest('.pb-card');
      if (card) {
        var sp = card.querySelector('.pb-stepper');
        if (sp) {
          btn.style.display = 'none';
          sp.classList.add('visible');
          sp.querySelector('.pb-stepper-qty').textContent = '1';
          getLine(vid, function (li) { sp.setAttribute('data-line', li); });
        }
      }
    })
    .catch(function () { btn.classList.remove('loading'); btn.textContent = '+ Add'; });
  });

  /* ── Stepper ── */
  document.addEventListener('click', function (e) {
    var isPlus  = e.target.closest('.pb-stepper-plus');
    var isMinus = e.target.closest('.pb-stepper-minus');
    if (!isPlus && !isMinus) return;
    var sp = e.target.closest('.pb-stepper');
    if (!sp) return;
    var qEl = sp.querySelector('.pb-stepper-qty');
    var vid = sp.getAttribute('data-variant-id');
    var cur = parseInt(qEl.textContent || '1', 10);
    var nxt = isPlus ? cur + 1 : cur - 1;
    if (nxt < 0) nxt = 0;
    qEl.textContent = nxt;
    getLine(vid, function (li) {
      if (!li) return;
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ line: li, quantity: nxt })
      })
      .then(function (r) { return r.json(); })
      .then(function () {
        bumpCartCount(isPlus ? 1 : -1);
        if (nxt === 0) {
          sp.classList.remove('visible');
          var card = sp.closest('.pb-card');
          if (card) { var ab = card.querySelector('.pb-add-btn'); if (ab) { ab.textContent = '+ Add'; ab.style.display = ''; } }
        } else { sp.setAttribute('data-line', li); }
      })
      .catch(function () { qEl.textContent = cur; });
    });
  });

})();
</script>

{% schema %}
{
  "name": "Pachali Bhairab",
  "settings": [],
  "presets": [{ "name": "Pachali Bhairab" }]
}
{% endschema %}
