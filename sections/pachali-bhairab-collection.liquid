    </div>
  </section>

</div><!-- /.pb-wrap -->

<script>
(function () {
  'use strict';

  /* ── Helpers ── */
  function qs(sel, ctx) { return (ctx || document).querySelector(sel); }
  function qsa(sel, ctx) { return Array.from((ctx || document).querySelectorAll(sel)); }

  var wrap    = document.getElementById('pb-wrap');
  var content = document.getElementById('pb-content');
  var grid    = document.getElementById('pb-grid');

  /* ─────────────────────────────────────────────────
     1. THEME OBSERVER
  ───────────────────────────────────────────────── */
  function applyTheme() {
    // Tokens are handled by CSS attribute selectors on html — nothing extra needed.
    // This function exists as a hook if inline-styled elements need updating.
  }

  var themeObserver = new MutationObserver(function (mutations) {
    mutations.forEach(function (m) {
      if (m.attributeName === 'data-theme') applyTheme();
    });
  });
  themeObserver.observe(document.documentElement, { attributes: true });
  applyTheme();

  /* ─────────────────────────────────────────────────
     2. FILTER PILLS
  ───────────────────────────────────────────────── */
  var pillsBar = document.getElementById('pb-pills-bar');
  var noResults = document.getElementById('pb-no-results');

  if (pillsBar) {
    pillsBar.addEventListener('click', function (e) {
      var pill = e.target.closest('.pb-filter-pill');
      if (!pill) return;

      // Update active pill
      qsa('.pb-filter-pill', pillsBar).forEach(function (p) { p.classList.remove('active'); });
      pill.classList.add('active');

      var filter = pill.getAttribute('data-filter');
      filterCards(filter);
    });
  }

  function filterCards(filter) {
    var cards = qsa('.pb-card', grid);
    var visibleCount = 0;

    cards.forEach(function (card) {
      var cat = (card.getAttribute('data-cat') || '').toLowerCase().trim();
      var matches = (filter === 'all') || (cat === filter) || (cat.indexOf(filter) !== -1) || (filter.indexOf(cat) !== -1 && cat !== '');

      if (matches) {
        card.classList.remove('pb-hidden');
        visibleCount++;
      } else {
        card.classList.add('pb-hidden');
      }
    });

    if (noResults) {
      noResults.classList.toggle('visible', visibleCount === 0 && cards.length > 0);
    }
  }

  /* ─────────────────────────────────────────────────
     3. CARD CLICK → NAVIGATE
  ───────────────────────────────────────────────── */
  if (content) {
    content.addEventListener('click', function (e) {
      // Skip if clicking interactive elements
      if (e.target.closest('.pb-add-btn') ||
          e.target.closest('.pb-stepper') ||
          e.target.closest('a') ||
          e.target.closest('button')) return;

      var card = e.target.closest('.pb-card');
      if (!card) return;
      var url = card.getAttribute('data-url');
      if (url) window.location.href = url;
    });
  }

  /* ─────────────────────────────────────────────────
     4. ADD TO CART
  ───────────────────────────────────────────────── */
  function updateCartCount(delta) {
    var counters = document.querySelectorAll('[data-cart-count], .cart-count, .cart__count, #cart-count, .header__cart-count');
    counters.forEach(function (el) {
      var current = parseInt(el.textContent || el.getAttribute('data-cart-count') || '0', 10);
      var next = Math.max(0, current + delta);
      el.textContent = next;
      if (el.hasAttribute('data-cart-count')) el.setAttribute('data-cart-count', next);
    });
  }

  function getLineIndex(variantId, callback) {
    fetch('/cart.js')
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        var lineIndex = 0;
        for (var i = 0; i < cart.items.length; i++) {
          if (String(cart.items[i].variant_id) === String(variantId)) {
            lineIndex = i + 1;
            break;
          }
        }
        callback(lineIndex, cart);
      })
      .catch(function () { callback(0, null); });
  }

  // Add to cart handler — delegated on document to catch stopPropagation-escaped events
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.pb-add-btn');
    if (!btn) return;
    if (btn.classList.contains('loading')) return;

    var variantId = btn.getAttribute('data-variant-id');
    if (!variantId) return;

    btn.classList.add('loading');
    btn.textContent = '';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.status && data.status !== 200) throw new Error(data.description || 'Error adding to cart');

      btn.classList.remove('loading');
      updateCartCount(1);

      // Show stepper
      var card = btn.closest('.pb-card');
      if (card) {
        var stepper = card.querySelector('.pb-stepper');
        if (stepper) {
          btn.style.display = 'none';
          stepper.classList.add('visible');
          stepper.querySelector('.pb-stepper-qty').textContent = '1';
          // Store line index lazily
          getLineIndex(variantId, function (lineIndex) {
            stepper.setAttribute('data-line', lineIndex);
          });
        }
      }
    })
    .catch(function (err) {
      console.error('[PB] Add to cart error:', err);
      btn.classList.remove('loading');
      btn.textContent = 'Add +';
    });
  });

  /* ─────────────────────────────────────────────────
     5. STEPPER (minus / plus)
  ───────────────────────────────────────────────── */
  document.addEventListener('click', function (e) {
    var isPlus  = e.target.closest('.pb-stepper-plus');
    var isMinus = e.target.closest('.pb-stepper-minus');
    if (!isPlus && !isMinus) return;

    var stepper   = e.target.closest('.pb-stepper');
    if (!stepper) return;

    var qtyEl     = stepper.querySelector('.pb-stepper-qty');
    var variantId = stepper.getAttribute('data-variant-id');
    var lineIndex = parseInt(stepper.getAttribute('data-line') || '0', 10);
    var currentQty = parseInt(qtyEl.textContent || '1', 10);
    var newQty    = isPlus ? currentQty + 1 : currentQty - 1;

    if (newQty < 0) newQty = 0;

    // Update display immediately for responsiveness
    if (newQty === 0) {
      qtyEl.textContent = '0';
    } else {
      qtyEl.textContent = newQty;
    }

    // Get fresh line index
    getLineIndex(variantId, function (freshLine) {
      var line = freshLine || lineIndex;
      if (line === 0) return;

      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ line: line, quantity: newQty })
      })
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        var delta = isPlus ? 1 : -1;
        if (newQty >= 0) updateCartCount(delta);

        if (newQty === 0) {
          // Hide stepper, show add button again
          stepper.classList.remove('visible');
          var card = stepper.closest('.pb-card');
          if (card) {
            var addBtn = card.querySelector('.pb-add-btn');
            if (addBtn) {
              addBtn.textContent = 'Add +';
              addBtn.style.display = '';
            }
          }
          stepper.setAttribute('data-line', '');
        } else {
          stepper.setAttribute('data-line', line);
        }
      })
      .catch(function (err) {
        console.error('[PB] Stepper cart error:', err);
        // Revert display on error
        qtyEl.textContent = currentQty;
      });
    });
  });

})();
</script>

