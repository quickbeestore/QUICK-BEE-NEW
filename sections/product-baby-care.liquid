{% assign baby_care_found = false %}
{% for collection in product.collections %}
  {% if collection.title == "Baby Care" or collection.title contains "Baby" %}
    {% assign baby_care_found = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% if baby_care_found or product.vendor == "BABY CARE" or product.type == "Baby Care" %}
  <!-- Baby Care Product - Caring & Gentle Design -->
  {% assign current_product_id = product.id %}
  <style>
    .baby-product-wrapper {
      background: #ffffff;
      padding: 0;
      margin: 0;
    }

    .baby-product-container {
      max-width: 100%;
      margin: 0 auto;
      padding: 16px;
    }

    /* Main Product Section */
    .baby-product-main {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-bottom: 0;
    }

    /* Product Image - Square with soft border */
    .baby-product-image-section {
      width: 100%;
      aspect-ratio: 1 / 1;
      background: linear-gradient(135deg, #FFF5F7 0%, #F0F8FF 100%);
      border-radius: 0;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      padding: 16px;
    }

    .baby-product-image {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 0;
    }

    /* Product Info Section */
    .baby-product-details {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 16px;
      background: #ffffff;
      border-top: 1px solid #f0e6e8;
      position: sticky;
      bottom: 0;
      z-index: 10;
      box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.08);
    }

    .baby-product-title {
      font-size: 18px;
      font-weight: 800;
      color: #2a2a2a;
      line-height: 1.3;
      margin: 0;
    }

    .baby-price-section {
      display: flex;
      align-items: center;
      gap: 8px;
      padding-bottom: 0;
      border-bottom: none;
    }

    .baby-price-current {
      font-size: 28px;
      font-weight: 900;
      color: #FF69B4;
      line-height: 1;
    }

    .baby-price-original {
      font-size: 14px;
      color: #999;
      text-decoration: line-through;
      margin-left: auto;
    }

    .baby-discount-badge {
      background: linear-gradient(135deg, #FFB6D9 0%, #FF69B4 100%);
      color: white;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 800;
      white-space: nowrap;
    }

    /* Delivery Box */
    .baby-delivery-info {
      background: linear-gradient(135deg, #F0F8FF 0%, #E6F7FF 100%);
      border-left: 3px solid #87CEEB;
      padding: 8px 12px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .baby-delivery-time {
      font-size: 13px;
      font-weight: 700;
      color: #2a2a2a;
      margin-bottom: 0;
    }

    .baby-delivery-subtext {
      font-size: 11px;
      color: #666;
    }

    /* Variants Section */
    .baby-variants-section {
      background: transparent;
      padding: 0;
      border-radius: 0;
      border: none;
    }

    .baby-section-label {
      font-size: 12px;
      font-weight: 700;
      color: #2a2a2a;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      margin-bottom: 12px;
      display: block;
    }

    .baby-select {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 13px;
      cursor: pointer;
      background: white;
    }

    /* Quantity & Add to Cart */
    .baby-qty-section {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }

    .baby-qty-controls {
      display: flex;
      gap: 4px;
      background: #f5f5f5;
      border-radius: 6px;
      padding: 6px;
    }

    .baby-qty-btn {
      width: 32px;
      height: 32px;
      border: none;
      background: white;
      border-radius: 4px;
      cursor: pointer;
      font-weight: 700;
      color: #FF69B4;
      transition: all 0.2s;
    }

    .baby-qty-btn:active {
      transform: scale(0.9);
    }

    .baby-qty-input {
      width: 28px;
      text-align: center;
      border: none;
      background: white;
      font-weight: 700;
      color: #2a2a2a;
      font-size: 13px;
    }

    .baby-add-btn {
      flex: 1;
      padding: 12px;
      background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.3s;
      min-height: 42px;
      font-size: 14px;
    }

    .baby-add-btn:hover {
      background: linear-gradient(135deg, #FF1493 0%, #FF0080 100%);
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(255, 105, 180, 0.3);
    }

    /* New Moms Section */
    .baby-new-moms-section {
      margin-top: 32px;
      padding: 24px 16px;
      background: linear-gradient(135deg, #FFF5F7 0%, #F0F8FF 100%);
      border-radius: 12px;
      border: 2px solid #FFB6D9;
    }

    .baby-new-moms-title {
      font-size: 18px;
      font-weight: 800;
      color: #2a2a2a;
      margin: 0 0 12px 0;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .baby-new-moms-description {
      font-size: 13px;
      color: #666;
      margin: 0 0 16px 0;
      line-height: 1.5;
    }

    .baby-new-moms-btn {
      width: 100%;
      padding: 12px;
      background: #87CEEB;
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
      font-size: 14px;
    }

    .baby-new-moms-btn:hover {
      background: #6BB6D6;
      transform: translateY(-2px);
    }

    /* More Baby Products Carousel */
    .baby-more-section {
      margin-top: 32px;
      padding-top: 24px;
    }

    .baby-section-title {
      font-size: 18px;
      font-weight: 800;
      color: #2a2a2a;
      margin: 0 0 16px 0;
    }

    /* Responsive */
    @media (min-width: 768px) {
      .baby-product-container {
        padding: 32px 24px;
      }

      .baby-product-main {
        grid-template-columns: 1fr 1fr;
        gap: 32px;
      }

      .baby-product-image-section {
        min-height: 300px;
        max-height: 500px;
        aspect-ratio: 1 / 1;
      }

      .baby-product-details {
        position: relative;
        bottom: auto;
        box-shadow: none;
        border-top: none;
      }
    }

    @media (min-width: 1024px) {
      .baby-product-container {
        padding: 40px 48px;
      }
    }
  </style>

  <div class="baby-product-wrapper">
    <div class="baby-product-container">
      <div class="baby-product-main">
        <!-- Product Image -->
        <div class="baby-product-image-section">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title }}" class="baby-product-image">
          {% else %}
            <div style="font-size: 64px;">👶</div>
          {% endif %}
        </div>

        <!-- Product Details -->
        <div class="baby-product-details">
          <h1 class="baby-product-title">{{ product.title }}</h1>

          <!-- Price -->
          <div class="baby-price-section">
            <span class="baby-price-current">Rs {{ product.price | divided_by: 100 }}</span>
            {% if product.compare_at_price and product.compare_at_price > product.price %}
              <span class="baby-price-original">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
              <span class="baby-discount-badge">{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round }}% OFF</span>
            {% endif %}
          </div>

          <!-- Delivery Info -->
          <div class="baby-delivery-info">
            <div>
              <p class="baby-delivery-time">⚡ <span class="baby-delivery-sync">18-22 mins</span></p>
              <p class="baby-delivery-subtext">Free delivery • Order tracking</p>
            </div>
          </div>

          <!-- Variants -->
          {% if product.available and product.variants.size > 1 %}
            <div class="baby-variants-section">
              <label class="baby-section-label">Choose Options</label>
              {% for option in product.options_with_values %}
                <select class="baby-select" id="select-{{ option.name | slugify }}" name="options[{{ option.name }}]">
                  <option disabled selected>{{ option.name }}</option>
                  {% for value in option.values %}
                    <option value="{{ value }}">{{ value }}</option>
                  {% endfor %}
                </select>
              {% endfor %}
            </div>
          {% endif %}

          <!-- Quantity & Add to Cart -->
          <div class="baby-qty-section">
            <div class="baby-qty-controls">
              <button type="button" class="baby-qty-btn" id="qty-minus">−</button>
              <input type="number" id="product-qty" class="baby-qty-input" value="1" min="1">
              <button type="button" class="baby-qty-btn" id="qty-plus">+</button>
            </div>
            <form action="/cart/add" method="post" style="flex: 1;">
              <input type="hidden" id="variant-id" name="id" value="{{ product.variants.first.id }}">
              <input type="hidden" id="final-qty" name="quantity" value="1">
              <button type="submit" class="baby-add-btn">🛒 Add to Cart</button>
            </form>
          </div>

          <!-- New Moms Guide -->
          <div class="baby-new-moms-section">
            <h3 class="baby-new-moms-title">👩‍👧 New Moms - Read This</h3>
            <p class="baby-new-moms-description">Everything you need to know about choosing the right baby products, safety precautions, and care tips from expert mothers.</p>
            <a href="/pages/baby-care-guide" class="baby-new-moms-btn">📖 Read Full Guide</a>
          </div>

          <!-- More Baby Products -->
          <div class="baby-more-section">
            <h2 class="baby-section-title">👶 More Baby Care Products</h2>
            <p style="font-size: 13px; color: #999; margin: 0;">Explore our collection of safe, tested, and mother-approved products for your little ones.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      // Delivery badge sync
      function updateDeliveryBadge() {
        let range = '18-22 mins';
        try {
          const stored = localStorage.getItem('qb_delivery_time');
          if (stored) {
            const data = JSON.parse(stored);
            if (data.range) range = data.range;
          }
        } catch (e) {}

        // Extract single time from range (e.g., "23-27 mins" → "25 mins")
        const match = range.match(/(\d+)-(\d+)\s*(mins?)/);
        let displayTime = range;
        if (match) {
          const min = parseInt(match[1]);
          const max = parseInt(match[2]);
          const avg = Math.round((min + max) / 2);
          displayTime = avg + ' ' + match[3];
        }

        const badge = document.querySelector('.baby-delivery-sync');
        if (badge) badge.textContent = displayTime;
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', updateDeliveryBadge);
      } else {
        updateDeliveryBadge();
      }

      window.addEventListener('locationSelected', function() {
        setTimeout(updateDeliveryBadge, 50);
      });

      // Quantity controls
      const qtyMinus = document.getElementById('qty-minus');
      const qtyPlus = document.getElementById('qty-plus');
      const qtyInput = document.getElementById('product-qty');
      const finalQty = document.getElementById('final-qty');

      if (qtyMinus) {
        qtyMinus.addEventListener('click', function(e) {
          e.preventDefault();
          let val = parseInt(qtyInput.value) || 1;
          if (val > 1) {
            qtyInput.value = val - 1;
            finalQty.value = qtyInput.value;
          }
        });
      }

      if (qtyPlus) {
        qtyPlus.addEventListener('click', function(e) {
          e.preventDefault();
          let val = parseInt(qtyInput.value) || 1;
          qtyInput.value = val + 1;
          finalQty.value = qtyInput.value;
        });
      }

      if (qtyInput) {
        qtyInput.addEventListener('change', function() {
          finalQty.value = Math.max(1, parseInt(this.value) || 1);
        });
      }

      // Variant change handling
      const allVariants = {{ product.variants | json }};
      const variantSelects = document.querySelectorAll('.baby-select');
      const variantId = document.getElementById('variant-id');
      const productOptions = {{ product.options | json }};

      variantSelects.forEach(select => {
        select.addEventListener('change', function() {
          const selectedOptions = {};
          variantSelects.forEach((s, index) => {
            if (s.value) {
              selectedOptions[productOptions[index]] = s.value;
            }
          });

          const variant = allVariants.find(v => {
            return productOptions.every((optionName, index) => {
              return v.options[index] === selectedOptions[optionName];
            });
          });

          if (variant) {
            variantId.value = variant.id;

            // Update price
            const priceEl = document.querySelector('.baby-price-current');
            if (priceEl && variant.price) {
              priceEl.textContent = 'Rs ' + (variant.price / 100);
            }

            // Update original price
            const origPriceEl = document.querySelector('.baby-price-original');
            if (origPriceEl && variant.compare_at_price) {
              origPriceEl.textContent = 'Rs ' + (variant.compare_at_price / 100);
            } else if (origPriceEl) {
              origPriceEl.style.display = 'none';
            }

            // Update discount badge
            const discountEl = document.querySelector('.baby-discount-badge');
            if (discountEl && variant.compare_at_price && variant.compare_at_price > variant.price) {
              const discount = Math.round((variant.compare_at_price - variant.price) * 100 / variant.compare_at_price);
              discountEl.textContent = discount + '% OFF';
              discountEl.style.display = 'inline-block';
            } else if (discountEl) {
              discountEl.style.display = 'none';
            }
          }
        });
      });
    })();
  </script>

  {% schema %}
  {
    "name": "Baby Care Product",
    "settings": []
  }
  {% endschema %}
{% else %}
  <!-- Fallback to default product template for non-baby-care products -->
  <div style="padding: 20px; text-align: center; color: #999;">
    <p>Product template not configured for this product type.</p>
  </div>
{% endif %}
