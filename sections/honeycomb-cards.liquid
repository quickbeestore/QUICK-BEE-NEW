{% stylesheet %}
  .honeycomb-section {
    padding: 40px 0;
  }

  .honeycomb-title {
    font-size: 36px;
    color: #8B4513;
    margin-bottom: 32px;
    text-align: center;
    font-weight: 800;
    position: relative;
    display: inline-block;
    width: 100%;
  }

  .honeycomb-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, #FDB913, #FFD700);
    margin: 12px auto 0;
    border-radius: 2px;
  }

  .honeycomb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
    margin: 40px 0;
  }

  .honeycomb-card {
    background: white;
    border-radius: 12px;
    padding: 32px 24px;
    border: 2px solid #FDB913;
    text-align: center;
    text-decoration: none;
    color: #8B4513;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .honeycomb-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, #FDB913, #FFD700);
  }

  .honeycomb-card:hover {
    box-shadow: 0 12px 24px rgba(253, 185, 19, 0.3);
    transform: translateY(-8px);
    border-color: #8B4513;
  }

  .honeycomb-card-icon {
    font-size: 48px;
    margin-bottom: 16px;
    display: inline-block;
    animation: buzz 2s ease-in-out infinite;
  }

  @keyframes buzz {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.05) rotate(2deg); }
  }

  .honeycomb-card h3 {
    font-size: 18px;
    margin-bottom: 12px;
    color: #8B4513;
    font-weight: 700;
  }

  .honeycomb-card p {
    font-size: 14px;
    color: #666;
  }
{% endstylesheet %}

<div class="honeycomb-section">
  <h2 class="honeycomb-title">{{ section.settings.title }}</h2>
  
  <div class="honeycomb-grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="honeycomb-card">
        <div class="honeycomb-card-icon">{{ block.settings.icon }}</div>
        <h3>{{ block.settings.title }}</h3>
        <p>{{ block.settings.description }}</p>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Honeycomb Cards",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "name": "Card",
      "type": "card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji)",
          "default": "🐝"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Browse products"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Honeycomb Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "📱",
            "title": "Electronics",
            "description": "Gadgets & devices"
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "👗",
            "title": "Fashion",
            "description": "Apparel & style"
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "🏠",
            "title": "Home & Kitchen",
            "description": "Essentials & tools"
          }
        }
      ]
    }
  ]
}
{% endschema %}
