.nt-date-scroll::-webkit-scrollbar { display: none; }

.nt-date-chip {
  all: unset; flex-shrink: 0;
  display: flex; flex-direction: column;
  align-items: center; gap: 2px;
  padding: 10px 14px;
  background: var(--d-chip-bg);
  border: 1.5px solid var(--d-border);
  border-radius: 14px; cursor: pointer;
  transition: border-color 0.18s, background 0.18s;
  min-width: 58px;
}
.nt-date-chip:hover { border-color: var(--d-gold); }
.nt-date-chip.selected { border-color: var(--d-gold); background: rgba(201,168,76,0.12); }
.nt-date-day { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--d-muted); }
.nt-date-chip.selected .nt-date-day { color: var(--d-gold); }
.nt-date-num { font-size: 20px; font-weight: 900; letter-spacing: -0.02em; color: var(--d-text); line-height: 1; }
.nt-date-chip.selected .nt-date-num { color: var(--d-gold); }
.nt-date-month { font-size: 10px; font-weight: 600; color: var(--d-muted); }
.nt-date-chip.selected .nt-date-month { color: var(--d-gold); }

.nt-slot-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 10px; }
.nt-slot {
  all: unset; display: flex; flex-direction: column;
  gap: 3px; padding: 14px;
  background: var(--d-chip-bg);
  border: 1.5px solid var(--d-border);
  border-radius: 14px; cursor: pointer;
  transition: border-color 0.18s, background 0.18s;
}
.nt-slot:hover { border-color: var(--d-gold); }
.nt-slot.selected { border-color: var(--d-gold); background: rgba(201,168,76,0.12); }
.nt-slot-time { font-size: 15px; font-weight: 900; color: var(--d-text); letter-spacing: -0.01em; }
.nt-slot.selected .nt-slot-time { color: var(--d-gold); }
.nt-slot-label { font-size: 11px; font-weight: 600; color: var(--d-muted); }
.nt-slot.selected .nt-slot-label { color: var(--d-gold); }

.nt-form-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 10px; }
.nt-field { display: flex; flex-direction: column; gap: 5px; }
.nt-field-full { grid-column: 1 / -1; }
.nt-field-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--d-muted); }
.nt-field-input {
  all: unset; box-sizing: border-box; width: 100%;
  padding: 12px 14px;
  border: 1.5px solid var(--d-border);
  border-radius: 12px; font-size: 14px; font-weight: 500;
  color: var(--d-text);
  background: var(--d-chip-bg);
  transition: border-color 0.18s;
}
.nt-field-input::placeholder { color: var(--d-muted2); font-weight: 400; }
.nt-field-input:focus { border-color: var(--d-gold); outline: none; }
.nt-field-textarea { resize: none; line-height: 1.5; }

.nt-bk-summary {
  margin-top: 14px; padding: 14px;
  background: rgba(27,58,45,0.10);
  border: 1px solid rgba(201,168,76,0.20);
  border-radius: 14px;
  display: flex; flex-direction: column; gap: 6px;
}
.nt-bk-sum-row {
  display: flex; align-items: center; gap: 8px;
  font-size: 12px; color: var(--d-text2);
}
.nt-bk-sum-row svg { color: var(--d-gold); flex-shrink: 0; }
.nt-bk-sum-row strong { color: var(--d-text); }

.nt-drawer-footer {
  display: flex; align-items: center; gap: 10px;
  padding: 14px 20px calc(14px + env(safe-area-inset-bottom));
  border-top: 1px solid var(--d-border);
  flex-shrink: 0;
  background: var(--d-bg);
}
.nt-footer-back {
  all: unset; display: flex; align-items: center; gap: 6px;
  padding: 13px 18px;
  border: 1.5px solid var(--d-border);
  border-radius: 14px; font-size: 13px; font-weight: 700;
  color: var(--d-muted); cursor: pointer;
  transition: border-color 0.18s, color 0.18s; white-space: nowrap;
}
.nt-footer-back:hover { border-color: var(--d-gold); color: var(--d-gold); }
.nt-footer-back.hidden { display: none; }

.nt-footer-next {
  all: unset; flex: 1; display: flex; align-items: center;
  justify-content: center; gap: 8px;
  padding: 15px 20px;
  background: #1B3A2D;
  color: #fff; border-radius: 14px;
  font-size: 14px; font-weight: 800; letter-spacing: 0.02em;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  box-shadow: 0 4px 16px rgba(27,58,45,0.35);
}
.nt-footer-next:hover { background: #2D5240; transform: translateY(-1px); box-shadow: 0 6px 22px rgba(27,58,45,0.45); }
.nt-footer-next:active { transform: scale(0.98); }
.nt-footer-next:disabled {
  background: var(--d-border) !important;
  color: var(--d-muted) !important;
  box-shadow: none !important; transform: none !important;
  cursor: not-allowed;
}
.nt-footer-next.checkout {
  background: linear-gradient(135deg, #1B3A2D, #C9A84C);
  box-shadow: 0 4px 20px rgba(201,168,76,0.30);
}
.nt-footer-next.checkout:hover {
  background: linear-gradient(135deg, #2D5240, #E8C97A);
  box-shadow: 0 6px 28px rgba(201,168,76,0.45);
}

.nt-field-input.error { border-color: #ef4444 !important; animation: ntShake 0.35s ease; }
@keyframes ntShake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-6px)} 40%{transform:translateX(6px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)} }
@keyframes ntSpinBtn { to { transform: rotate(360deg); } }
</style>

<script>
(function () {
  var overlay  = document.getElementById('ntBookingOverlay');
  var drawer   = document.getElementById('ntBookingDrawer');
  var closeBtn = document.getElementById('ntDrawerClose');
  var nextBtn  = document.getElementById('ntNext');
  var backBtn  = document.getElementById('ntBack');
  var steps    = [document.getElementById('ntStep1'), document.getElementById('ntStep2'), document.getElementById('ntStep3')];
  var progSteps = drawer.querySelectorAll('.nt-prog-step');
  var progLines = drawer.querySelectorAll('.nt-prog-line');
  var titleEl  = document.getElementById('ntDrawerTitle');
  var pkgEl    = document.getElementById('ntDrawerPkg');
  var summaryEl = document.getElementById('ntSummary');
  var dateScroll = document.getElementById('ntDateScroll');

  var state = { step:1, date:null, slot:null, variantId:null, name:'', price:'', currency:'NPR', duration:'' };

  /* Date chips */
  var DAYS   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  (function buildDates() {
    var today = new Date();
    for (var i = 1; i <= 14; i++) {
      var d = new Date(today);
      d.setDate(today.getDate() + i);
      var btn = document.createElement('button');
      btn.className = 'nt-date-chip';
      btn.setAttribute('data-date', d.toDateString());
      btn.innerHTML =
        '<span class="nt-date-day">' + DAYS[d.getDay()] + '</span>' +
        '<span class="nt-date-num">' + d.getDate() + '</span>' +
        '<span class="nt-date-month">' + MONTHS[d.getMonth()] + '</span>';
      btn.addEventListener('click', function () {
        dateScroll.querySelectorAll('.nt-date-chip').forEach(function (c) { c.classList.remove('selected'); });
        this.classList.add('selected');
        state.date = this.getAttribute('data-date');
        checkNextable();
      });
      dateScroll.appendChild(btn);
    }
  })();

  /* Slot selection */
  drawer.querySelectorAll('.nt-slot').forEach(function (btn) {
    btn.addEventListener('click', function () {
      drawer.querySelectorAll('.nt-slot').forEach(function (s) { s.classList.remove('selected'); });
      this.classList.add('selected');
      state.slot = this.getAttribute('data-slot');
      checkNextable();
    });
  });

  /* Open drawer */
  function ntOpenBooking(variantId, name, price, currency, duration) {
    state.variantId = variantId;
    state.name = name;
    state.price = price;
    state.currency = currency || 'NPR';
    state.duration = duration;
    state.step = 1; state.date = null; state.slot = null;
    dateScroll.querySelectorAll('.nt-date-chip').forEach(function (c) { c.classList.remove('selected'); });
    drawer.querySelectorAll('.nt-slot').forEach(function (s) { s.classList.remove('selected'); });
    document.getElementById('ntName').value = '';
    document.getElementById('ntPhone').value = '';
    document.getElementById('ntNotes').value = '';

    titleEl.textContent = name || 'Book Your Session';
    pkgEl.innerHTML = '<span style="font-size:20px;">🪷</span>' +
      '<span class="nt-pkg-name">' + (name || 'Treatment') + (duration ? ' · ' + duration : '') + '</span>' +
      (price ? '<span class="nt-pkg-price">' + (currency||'NPR') + ' ' + price + '</span>' : '');

    goStep(1);
    overlay.classList.add('open');
    drawer.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  window.ntOpenBooking = ntOpenBooking;

  function closeDrawer() {
    overlay.classList.remove('open');
    drawer.classList.remove('open');
    document.body.style.overflow = '';
  }

  function goStep(n) {
    state.step = n;
    steps.forEach(function (s, i) { s.classList.toggle('hidden', i !== n - 1); });
    progSteps.forEach(function (s, i) {
      s.classList.toggle('active', i === n - 1);
      s.classList.toggle('done', i < n - 1);
    });
    progLines.forEach(function (l, i) { l.classList.toggle('done', i < n - 1); });
    backBtn.classList.toggle('hidden', n === 1);
    if (n === 3) {
      nextBtn.innerHTML = 'Proceed to Payment <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>';
      nextBtn.classList.add('checkout');
      buildSummary();
    } else {
      nextBtn.classList.remove('checkout');
      nextBtn.innerHTML = 'Next <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>';
    }
    checkNextable();
  }

  function checkNextable() {
    var ok = false;
    if (state.step === 1) ok = !!state.date;
    if (state.step === 2) ok = !!state.slot;
    if (state.step === 3) ok = true;
    nextBtn.disabled = !ok;
  }

  function buildSummary() {
    summaryEl.innerHTML =
      '<div class="nt-bk-sum-row"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg><span><strong>Date:</strong> ' + state.date + '</span></div>' +
      '<div class="nt-bk-sum-row"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span><strong>Time:</strong> ' + state.slot + '</span></div>' +
      '<div class="nt-bk-sum-row"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg><span><strong>Treatment:</strong> ' + state.name + '</span></div>';
  }

  nextBtn.addEventListener('click', function () {
    if (state.step < 3) {
      goStep(state.step + 1);
    } else {
      doCheckout();
    }
  });

  backBtn.addEventListener('click', function () { if (state.step > 1) goStep(state.step - 1); });

  function doCheckout() {
    var name  = document.getElementById('ntName').value.trim();
    var phone = document.getElementById('ntPhone').value.trim();
    var notes = document.getElementById('ntNotes').value.trim();
    var nameInput  = document.getElementById('ntName');
    var phoneInput = document.getElementById('ntPhone');
    var valid = true;
    if (!name)  { nameInput.classList.add('error');  setTimeout(function(){ nameInput.classList.remove('error');  }, 600); valid = false; }
    if (!phone) { phoneInput.classList.add('error'); setTimeout(function(){ phoneInput.classList.remove('error'); }, 600); valid = false; }
    if (!valid) return;
    if (!state.variantId) { window.location.href = '/collections/nuad-thai-spa'; return; }

    nextBtn.disabled = true;
    nextBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:ntSpinBtn 0.8s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Adding…';

    var properties = {
      'Booking Date':     state.date,
      'Time Slot':        state.slot,
      'Guest Name':       name,
      'Phone / WhatsApp': phone,
      'Treatment':        state.name
    };
    if (state.duration) properties['Duration'] = state.duration;
    if (notes) properties['Special Requests'] = notes;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(state.variantId, 10), quantity: 1, properties: properties })
    })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (d.id) {
        document.dispatchEvent(new CustomEvent('qb:cart:update', { detail: { count: 1 } }));
        window.location.href = '/checkout';
      } else {
        throw new Error(d.description || 'Failed');
      }
    })
    .catch(function () {
      nextBtn.disabled = false;
      nextBtn.innerHTML = 'Try Again <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>';
    });
  }

  closeBtn.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeDrawer(); });
  checkNextable();
})();
</script>

{% schema %}
{
  "name": "Nuad Thai Spa Collection",
  "settings": [
    {
      "type": "header",
      "content": "Sections"
    },
    {
      "type": "checkbox",
      "id": "show_vip_packages",
      "label": "Show VIP City Packages section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pregnancy_section",
      "label": "Show Pregnancy Care section",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Nuad Thai Spa Collection"
    }
  ]
}
{% endschema %}
