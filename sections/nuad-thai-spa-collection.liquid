{%- comment -%} Nuad Thai Spa & Wellness — Collection Page Template {%- endcomment -%}

<style>
/* ════════════════════════════════════════════════
   NUAD THAI SPA & WELLNESS — COLLECTION TEMPLATE
   Premium · Calming · Luxury Thai Spa Aesthetic
   ════════════════════════════════════════════════ */

/* ── CSS Variables ── */
.nt-page {
  --nt-gold:         #C9A84C;
  --nt-gold-light:   #E8C97A;
  --nt-gold-bg:      rgba(201,168,76,0.10);
  --nt-gold-bd:      rgba(201,168,76,0.30);
  --nt-green:        #1B3A2D;
  --nt-green-mid:    #2D5240;
  --nt-green-light:  #3D6B53;
  --nt-beige:        #F5EFE0;
  --nt-beige-dark:   #E8DCC8;
  --nt-cream:        #FBF8F2;
  --nt-white:        #FFFFFF;
  --nt-text:         #1a1610;
  --nt-text-mid:     #4a3f2f;
  --nt-text-soft:    #7a6e5f;
  --nt-bg:           #FBF8F2;
  --nt-card:         #FFFFFF;
  --nt-border:       #E8DCC8;
  --nt-shadow:       0 4px 24px rgba(26,22,16,0.07);
  --nt-shadow-lg:    0 12px 40px rgba(26,22,16,0.13);
  --nt-radius:       16px;
  --nt-radius-sm:    10px;
}

[data-theme="dark"] .nt-page {
  --nt-bg:           #080e09;
  --nt-card:         #0e1a12;
  --nt-cream:        #0e1a12;
  --nt-beige:        #162318;
  --nt-beige-dark:   #1c2d1f;
  --nt-border:       #243628;
  --nt-text:         #f0ede6;
  --nt-text-mid:     #c8c0b0;
  --nt-text-soft:    #8a8070;
  --nt-shadow:       0 4px 24px rgba(0,0,0,0.45);
  --nt-shadow-lg:    0 12px 40px rgba(0,0,0,0.60);
}

/* ── Base ── */
.nt-page {
  background: var(--nt-bg);
  color: var(--nt-text);
  font-family: system-ui, -apple-system, sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

*, *::before, *::after { box-sizing: border-box; }

.nt-container {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 20px;
}

@media (min-width: 768px) { .nt-container { padding: 0 32px; } }
@media (min-width: 1024px) { .nt-container { padding: 0 48px; } }

/* ════════════════════════════════════════════════
   § 1  HERO BAND
   ════════════════════════════════════════════════ */
.nt-hero {
  position: relative;
  background: #1B3A2D;
  overflow: hidden;
  padding: 72px 0 64px;
  min-height: 520px;
  display: flex;
  align-items: center;
}

/* Gold dot pattern overlay */
.nt-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle, rgba(201,168,76,0.18) 1.2px, transparent 1.2px),
    radial-gradient(circle, rgba(201,168,76,0.08) 1px, transparent 1px);
  background-size: 40px 40px, 20px 20px;
  background-position: 0 0, 10px 10px;
  pointer-events: none;
  z-index: 0;
}

/* Gradient veil */
.nt-hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, rgba(27,58,45,0.92) 0%, rgba(27,58,45,0.70) 60%, rgba(27,58,45,0.55) 100%);
  pointer-events: none;
  z-index: 0;
}

/* Floating leaf shape 1 */
.nt-hero-leaf1 {
  position: absolute;
  top: -60px;
  right: 8%;
  width: 220px;
  height: 220px;
  border-radius: 50% 10% 50% 10%;
  background: radial-gradient(circle at 40% 40%, rgba(201,168,76,0.15), transparent 70%);
  border: 1px solid rgba(201,168,76,0.12);
  transform: rotate(35deg);
  pointer-events: none;
  z-index: 1;
  animation: nt-float1 8s ease-in-out infinite;
}

/* Floating leaf shape 2 */
.nt-hero-leaf2 {
  position: absolute;
  bottom: -40px;
  right: 18%;
  width: 140px;
  height: 140px;
  border-radius: 10% 50% 10% 50%;
  background: radial-gradient(circle at 60% 60%, rgba(201,168,76,0.10), transparent 70%);
  border: 1px solid rgba(201,168,76,0.09);
  transform: rotate(-20deg);
  pointer-events: none;
  z-index: 1;
  animation: nt-float2 10s ease-in-out infinite 2s;
}

/* Floating leaf shape 3 */
.nt-hero-leaf3 {
  position: absolute;
  top: 30%;
  left: -30px;
  width: 100px;
  height: 160px;
  border-radius: 50% 10% 50% 10%;
  background: radial-gradient(circle at 50% 50%, rgba(201,168,76,0.08), transparent 70%);
  border: 1px solid rgba(201,168,76,0.07);
  transform: rotate(60deg);
  pointer-events: none;
  z-index: 1;
  animation: nt-float1 12s ease-in-out infinite 4s;
}

@keyframes nt-float1 {
  0%, 100% { transform: rotate(35deg) translateY(0); }
  50% { transform: rotate(35deg) translateY(-18px); }
}
@keyframes nt-float2 {
  0%, 100% { transform: rotate(-20deg) translateY(0); }
  50% { transform: rotate(-20deg) translateY(14px); }
}

.nt-hero-inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  align-items: center;
  width: 100%;
}

@media (min-width: 900px) {
  .nt-hero-inner { grid-template-columns: 1fr 420px; gap: 64px; }
}

/* Hero text */
.nt-hero-content { animation: nt-slideup 0.8s ease both; }

@keyframes nt-slideup {
  from { opacity: 0; transform: translateY(32px); }
  to   { opacity: 1; transform: translateY(0); }
}

.nt-hero-eyebrow {
  display: inline-block;
  color: var(--nt-gold);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.nt-hero-heading {
  font-family: 'Georgia', serif;
  font-size: clamp(28px, 4.5vw, 52px);
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.18;
  margin: 0 0 18px;
}

.nt-hero-sub {
  color: rgba(255,255,255,0.72);
  font-size: 15px;
  line-height: 1.6;
  margin-bottom: 22px;
}

.nt-hero-location {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(201,168,76,0.15);
  border: 1px solid rgba(201,168,76,0.30);
  color: var(--nt-gold-light);
  font-size: 13px;
  padding: 6px 14px;
  border-radius: 50px;
  margin-bottom: 32px;
}

.nt-hero-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
}

.nt-btn-gold {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--nt-gold);
  color: #1B3A2D;
  font-size: 14px;
  font-weight: 700;
  padding: 13px 26px;
  border-radius: 50px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.22s, transform 0.18s, box-shadow 0.22s;
  box-shadow: 0 4px 18px rgba(201,168,76,0.30);
}
.nt-btn-gold:hover {
  background: var(--nt-gold-light);
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(201,168,76,0.40);
}

.nt-btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 600;
  padding: 12px 24px;
  border-radius: 50px;
  border: 1.5px solid rgba(255,255,255,0.40);
  cursor: pointer;
  text-decoration: none;
  transition: border-color 0.22s, color 0.22s, transform 0.18s;
}
.nt-btn-ghost:hover {
  border-color: var(--nt-gold);
  color: var(--nt-gold-light);
  transform: translateY(-2px);
}

/* Hero decorative circle / lotus */
.nt-hero-visual {
  display: flex;
  justify-content: center;
  align-items: center;
  animation: nt-slideup 0.8s ease 0.25s both;
}

.nt-lotus-wrap {
  position: relative;
  width: 280px;
  height: 280px;
  flex-shrink: 0;
}

.nt-lotus-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2px solid rgba(201,168,76,0.35);
  background: radial-gradient(circle at 50% 40%, rgba(201,168,76,0.12), rgba(27,58,45,0.60) 60%);
  box-shadow: 0 0 60px rgba(201,168,76,0.18), inset 0 0 40px rgba(201,168,76,0.08);
}

.nt-lotus-ring::before {
  content: '';
  position: absolute;
  inset: 18px;
  border-radius: 50%;
  border: 1px solid rgba(201,168,76,0.20);
}

/* CSS lotus petals — 8 petals */
.nt-lotus-petals {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nt-petal {
  position: absolute;
  width: 56px;
  height: 90px;
  background: linear-gradient(180deg, rgba(201,168,76,0.28) 0%, rgba(201,168,76,0.06) 100%);
  border-radius: 50% 50% 40% 40%;
  border: 1px solid rgba(201,168,76,0.25);
  transform-origin: 50% 100%;
  top: 50%;
  left: 50%;
  margin-left: -28px;
  margin-top: -90px;
}

.nt-petal:nth-child(1) { transform: rotate(0deg) translateY(-22px); }
.nt-petal:nth-child(2) { transform: rotate(45deg) translateY(-22px); }
.nt-petal:nth-child(3) { transform: rotate(90deg) translateY(-22px); }
.nt-petal:nth-child(4) { transform: rotate(135deg) translateY(-22px); }
.nt-petal:nth-child(5) { transform: rotate(180deg) translateY(-22px); }
.nt-petal:nth-child(6) { transform: rotate(225deg) translateY(-22px); }
.nt-petal:nth-child(7) { transform: rotate(270deg) translateY(-22px); }
.nt-petal:nth-child(8) { transform: rotate(315deg) translateY(-22px); }

.nt-lotus-center {
  position: absolute;
  width: 70px;
  height: 70px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(201,168,76,0.55) 0%, rgba(201,168,76,0.15) 70%);
  border-radius: 50%;
  border: 1.5px solid rgba(201,168,76,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  z-index: 2;
}

/* ════════════════════════════════════════════════
   § 2  MARQUEE TICKER
   ════════════════════════════════════════════════ */
.nt-marquee-bar {
  background: #1B3A2D;
  border-top: 1px solid rgba(201,168,76,0.20);
  border-bottom: 1px solid rgba(201,168,76,0.20);
  padding: 14px 0;
  overflow: hidden;
  white-space: nowrap;
}

.nt-marquee-track {
  display: inline-block;
  animation: nt-marquee 32s linear infinite;
}

.nt-marquee-track:hover { animation-play-state: paused; }

.nt-marquee-item {
  display: inline-block;
  color: var(--nt-gold);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  padding: 0 28px;
}

.nt-marquee-dot {
  display: inline-block;
  color: var(--nt-gold-light);
  opacity: 0.55;
}

@keyframes nt-marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-33.333%); }
}

/* ════════════════════════════════════════════════
   § 3  SIGNATURE PACKAGES
   ════════════════════════════════════════════════ */
.nt-signatures {
  padding: 72px 0 60px;
  background: var(--nt-beige);
}

[data-theme="dark"] .nt-signatures { background: #080e09; }

.nt-section-header {
  text-align: center;
  margin-bottom: 44px;
}

.nt-section-eyebrow {
  display: inline-block;
  color: var(--nt-gold);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 10px;
}

.nt-section-title {
  font-family: 'Georgia', serif;
  font-size: clamp(24px, 3.5vw, 38px);
  font-weight: 700;
  color: var(--nt-text);
  margin: 0 0 12px;
  line-height: 1.25;
}

.nt-section-sub {
  color: var(--nt-text-soft);
  font-size: 15px;
  max-width: 520px;
  margin: 0 auto;
  line-height: 1.65;
}

/* Horizontal scroll on mobile, 3-col on desktop */
.nt-sig-scroll {
  overflow-x: auto;
  padding-bottom: 12px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.nt-sig-scroll::-webkit-scrollbar { display: none; }

.nt-sig-grid {
  display: grid;
  grid-template-columns: repeat(7, 280px);
  gap: 20px;
  width: max-content;
}

@media (min-width: 900px) {
  .nt-sig-scroll { overflow-x: visible; padding-bottom: 0; }
  .nt-sig-grid {
    grid-template-columns: repeat(3, 1fr);
    width: auto;
  }
}

@media (min-width: 1100px) {
  .nt-sig-grid { grid-template-columns: repeat(4, 1fr); }
}

/* Signature card */
.nt-sig-card {
  background: var(--nt-card);
  border-radius: var(--nt-radius);
  border: 1.5px solid var(--nt-gold-bd);
  border-top: 3px solid var(--nt-gold);
  padding: 26px 22px 22px;
  box-shadow: var(--nt-shadow);
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: transform 0.24s, box-shadow 0.24s;
}
.nt-sig-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--nt-shadow-lg);
}

.nt-sig-name {
  font-family: 'Georgia', serif;
  font-size: 17px;
  font-weight: 700;
  color: var(--nt-text);
  line-height: 1.3;
  margin: 0;
}

.nt-sig-duration {
  display: inline-block;
  background: var(--nt-gold-bg);
  color: var(--nt-gold);
  font-size: 12px;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 50px;
  border: 1px solid var(--nt-gold-bd);
  width: fit-content;
}

.nt-sig-benefit {
  color: var(--nt-text-soft);
  font-size: 13.5px;
  line-height: 1.55;
  flex: 1;
}

.nt-sig-price {
  font-size: 15px;
  font-weight: 700;
  color: var(--nt-gold);
}

.nt-sig-btn {
  display: block;
  text-align: center;
  background: var(--nt-green);
  color: #fff;
  font-size: 13px;
  font-weight: 600;
  padding: 11px 18px;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.22s, transform 0.18s;
  margin-top: 4px;
}
.nt-sig-btn:hover {
  background: var(--nt-gold);
  color: #1B3A2D;
  transform: translateY(-1px);
}

/* ════════════════════════════════════════════════
   § 4  CATEGORY TABS + PRODUCT GRID
   ════════════════════════════════════════════════ */
.nt-catalog {
  padding: 60px 0 80px;
  background: var(--nt-bg);
}

/* Tabs spacer + sticky wrap */
#nt-tabs-spacer {
  height: 54px;
  pointer-events: none;
}
#nt-tabs-spacer.nt-tabs-spacer-active {
  height: 54px;
}

#nt-tabs-wrap {
  background: var(--nt-bg);
  border-bottom: 1px solid var(--nt-border);
  z-index: 100;
  transition: box-shadow 0.22s;
}
#nt-tabs-wrap.nt-tabs-fixed {
  position: fixed;
  left: 0;
  right: 0;
  box-shadow: 0 4px 20px rgba(0,0,0,0.10);
}

.nt-tabs-inner {
  display: flex;
  align-items: center;
  gap: 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 0 20px;
  max-width: 1240px;
  margin: 0 auto;
}
.nt-tabs-inner::-webkit-scrollbar { display: none; }

.nt-tab-btn {
  flex-shrink: 0;
  background: none;
  border: none;
  cursor: pointer;
  font-size: 13.5px;
  font-weight: 600;
  color: var(--nt-text-soft);
  padding: 15px 18px 13px;
  border-bottom: 2.5px solid transparent;
  transition: color 0.20s, border-color 0.20s;
  white-space: nowrap;
}
.nt-tab-btn:hover { color: var(--nt-text); }
.nt-tab-btn.nt-tab-active {
  color: var(--nt-gold);
  border-bottom-color: var(--nt-gold);
}

/* Product grid */
.nt-products-section {
  padding-top: 36px;
}

.nt-products-empty {
  text-align: center;
  padding: 60px 20px;
  color: var(--nt-text-soft);
}

.nt-products-empty svg {
  opacity: 0.35;
  margin-bottom: 16px;
}

.nt-prod-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

@media (min-width: 768px) { .nt-prod-grid { grid-template-columns: repeat(2, 1fr); gap: 22px; } }
@media (min-width: 1024px) { .nt-prod-grid { grid-template-columns: repeat(3, 1fr); gap: 26px; } }

/* Product card */
.nt-prod-card {
  background: var(--nt-card);
  border-radius: var(--nt-radius);
  border: 1px solid var(--nt-border);
  border-top: 3px solid var(--nt-gold);
  box-shadow: var(--nt-shadow);
  overflow: hidden;
  position: relative;
  transition: transform 0.24s, box-shadow 0.24s;
}
.nt-prod-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--nt-shadow-lg);
}

/* Full-card link overlay */
.nt-card-link {
  position: absolute;
  inset: 0;
  z-index: 0;
  display: block;
  border-radius: var(--nt-radius);
}

.nt-prod-card-inner {
  position: relative;
  z-index: 1;
  pointer-events: none;
}

/* Image */
.nt-prod-img-wrap {
  position: relative;
  aspect-ratio: 4 / 3;
  overflow: hidden;
  background: var(--nt-beige);
}

.nt-prod-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.36s ease;
}
.nt-prod-card:hover .nt-prod-img-wrap img { transform: scale(1.04); }

.nt-prod-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--nt-beige) 0%, var(--nt-beige-dark) 100%);
  font-size: 36px;
  color: var(--nt-gold);
  opacity: 0.60;
}

/* Type badge on image */
.nt-prod-type-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: var(--nt-green);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 50px;
  z-index: 2;
  pointer-events: none;
}

/* Card body */
.nt-prod-body {
  padding: 16px 16px 14px;
}

.nt-prod-name {
  font-family: 'Georgia', serif;
  font-size: 15px;
  font-weight: 700;
  color: var(--nt-text);
  line-height: 1.35;
  margin: 0 0 6px;
}

.nt-prod-desc {
  color: var(--nt-text-soft);
  font-size: 12.5px;
  line-height: 1.55;
  margin: 0 0 10px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Variant pills */
.nt-prod-variants {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-bottom: 10px;
}

.nt-variant-pill {
  font-size: 11px;
  font-weight: 600;
  color: var(--nt-text-mid);
  background: var(--nt-beige);
  border: 1px solid var(--nt-border);
  padding: 4px 10px;
  border-radius: 50px;
  cursor: pointer;
  transition: background 0.18s, border-color 0.18s, color 0.18s;
  line-height: 1.4;
}
.nt-variant-pill:hover {
  border-color: var(--nt-gold);
  color: var(--nt-gold);
}
.nt-variant-pill.nt-variant-active {
  background: var(--nt-green);
  border-color: var(--nt-green);
  color: #fff;
}
.nt-variant-pill:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}
[data-theme="dark"] .nt-variant-pill { background: var(--nt-beige-dark); }
[data-theme="dark"] .nt-variant-pill.nt-variant-active { background: var(--nt-green-mid); border-color: var(--nt-gold); color: var(--nt-gold); }

.nt-prod-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-top: 4px;
}

.nt-prod-price {
  font-size: 15px;
  font-weight: 700;
  color: var(--nt-gold);
}

/* Book button — must be z-index: 2 to sit above card link */
.nt-prod-book {
  position: relative;
  z-index: 2;
  pointer-events: all;
  display: inline-flex;
  align-items: center;
  font-size: 12px;
  font-weight: 700;
  background: var(--nt-green);
  color: #fff;
  padding: 8px 16px;
  border-radius: 50px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.22s, transform 0.18s;
  white-space: nowrap;
}
.nt-prod-book:hover {
  background: var(--nt-gold);
  color: #1B3A2D;
  transform: translateY(-1px);
}

/* ════════════════════════════════════════════════
   § 5  VIP PACKAGES
   ════════════════════════════════════════════════ */
.nt-vip {
  background: #1B3A2D;
  padding: 72px 0 64px;
  position: relative;
  overflow: hidden;
}

.nt-vip::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(201,168,76,0.12) 1px, transparent 1px);
  background-size: 32px 32px;
  pointer-events: none;
}

.nt-vip .nt-section-title { color: #fff; }
.nt-vip .nt-section-sub { color: rgba(255,255,255,0.62); }
.nt-vip .nt-section-eyebrow { color: var(--nt-gold-light); }

.nt-vip-scroll {
  overflow-x: auto;
  padding-bottom: 12px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.nt-vip-scroll::-webkit-scrollbar { display: none; }

.nt-vip-grid {
  display: grid;
  grid-template-columns: repeat(4, 290px);
  gap: 20px;
  width: max-content;
}

@media (min-width: 900px) {
  .nt-vip-scroll { overflow-x: visible; }
  .nt-vip-grid { grid-template-columns: repeat(4, 1fr); width: auto; }
}

.nt-vip-card {
  background: rgba(14,26,18,0.80);
  border: 1.5px solid rgba(201,168,76,0.35);
  border-radius: var(--nt-radius);
  padding: 28px 22px 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  backdrop-filter: blur(6px);
  transition: transform 0.24s, box-shadow 0.24s, border-color 0.22s;
}
.nt-vip-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.45);
  border-color: rgba(201,168,76,0.65);
}

.nt-vip-icon { font-size: 32px; margin-bottom: 2px; }

.nt-vip-name {
  font-family: 'Georgia', serif;
  font-size: 18px;
  font-weight: 700;
  color: #fff;
  margin: 0;
}

.nt-vip-duration {
  display: inline-block;
  background: rgba(201,168,76,0.15);
  color: var(--nt-gold-light);
  font-size: 12px;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 50px;
  border: 1px solid rgba(201,168,76,0.28);
  width: fit-content;
}

.nt-vip-includes {
  color: rgba(255,255,255,0.65);
  font-size: 13px;
  line-height: 1.6;
  flex: 1;
}

.nt-vip-price {
  font-size: 15px;
  font-weight: 700;
  color: var(--nt-gold);
}

.nt-vip-btn {
  display: block;
  text-align: center;
  background: var(--nt-gold);
  color: #1B3A2D;
  font-size: 13px;
  font-weight: 700;
  padding: 11px 18px;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.22s, transform 0.18s;
}
.nt-vip-btn:hover {
  background: var(--nt-gold-light);
  transform: translateY(-1px);
}

/* ════════════════════════════════════════════════
   § 6  PREGNANCY CARE
   ════════════════════════════════════════════════ */
.nt-preg {
  background: #fdf5ee;
  padding: 72px 0 60px;
  position: relative;
  overflow: hidden;
}

[data-theme="dark"] .nt-preg { background: #0e0a06; }

.nt-preg::before {
  content: '';
  position: absolute;
  top: -80px;
  right: -80px;
  width: 320px;
  height: 320px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,168,76,0.12), transparent 70%);
  pointer-events: none;
}

.nt-preg-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  align-items: center;
}
@media (min-width: 768px) {
  .nt-preg-inner { grid-template-columns: 1fr 1fr; }
}

.nt-preg-lotus {
  font-size: 64px;
  margin-bottom: 12px;
  display: block;
}

.nt-preg-heading {
  font-family: 'Georgia', serif;
  font-size: clamp(22px, 3vw, 34px);
  font-weight: 700;
  color: var(--nt-text);
  margin: 0 0 14px;
}
[data-theme="dark"] .nt-preg-heading { color: #f0ede6; }

.nt-preg-text {
  color: var(--nt-text-soft);
  font-size: 15px;
  line-height: 1.7;
  margin-bottom: 24px;
}
[data-theme="dark"] .nt-preg-text { color: #8a8070; }

.nt-preg-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 28px;
}

.nt-preg-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(201,168,76,0.12);
  border: 1px solid rgba(201,168,76,0.30);
  color: #5a4320;
  font-size: 13px;
  font-weight: 600;
  padding: 7px 16px;
  border-radius: 50px;
}
[data-theme="dark"] .nt-preg-pill { color: var(--nt-gold-light); background: rgba(201,168,76,0.10); }

.nt-preg-combos { margin-bottom: 28px; }

.nt-preg-combos-title {
  font-weight: 700;
  font-size: 14px;
  color: var(--nt-text-mid);
  margin-bottom: 10px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
[data-theme="dark"] .nt-preg-combos-title { color: var(--nt-text-soft); }

.nt-preg-combo-item {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--nt-text-mid);
  font-size: 14px;
  padding: 5px 0;
  border-bottom: 1px solid rgba(201,168,76,0.12);
}
[data-theme="dark"] .nt-preg-combo-item { color: #c8c0b0; }

.nt-preg-combo-item::before {
  content: '✦';
  color: var(--nt-gold);
  font-size: 10px;
  flex-shrink: 0;
}

/* Visual side */
.nt-preg-visual {
  display: flex;
  justify-content: center;
  align-items: center;
}

.nt-preg-circle {
  width: 260px;
  height: 260px;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%, rgba(201,168,76,0.18), rgba(253,245,238,0.60) 70%);
  border: 2px solid rgba(201,168,76,0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80px;
  box-shadow: 0 0 60px rgba(201,168,76,0.14);
}
[data-theme="dark"] .nt-preg-circle { background: radial-gradient(circle at 40% 35%, rgba(201,168,76,0.12), rgba(14,10,6,0.80) 70%); }

/* ════════════════════════════════════════════════
   § 7  WHY CHOOSE US
   ════════════════════════════════════════════════ */
.nt-why {
  background: var(--nt-cream);
  padding: 72px 0 64px;
}
[data-theme="dark"] .nt-why { background: #0e1a12; }

.nt-why-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-top: 44px;
}
@media (min-width: 768px) { .nt-why-grid { grid-template-columns: repeat(4, 1fr); } }

.nt-why-card {
  background: var(--nt-card);
  border-radius: var(--nt-radius);
  border: 1px solid var(--nt-border);
  padding: 32px 20px 28px;
  text-align: center;
  transition: transform 0.22s, box-shadow 0.22s;
}
.nt-why-card:hover { transform: translateY(-4px); box-shadow: var(--nt-shadow-lg); }

.nt-why-icon {
  font-size: 40px;
  margin-bottom: 14px;
  display: block;
}

.nt-why-title {
  font-family: 'Georgia', serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--nt-text);
  margin: 0 0 8px;
}

.nt-why-text {
  color: var(--nt-text-soft);
  font-size: 13px;
  line-height: 1.6;
}

/* ════════════════════════════════════════════════
   § 8  QUICK BOOKING BANNER
   ════════════════════════════════════════════════ */
.nt-booking-banner {
  background: linear-gradient(120deg, #b8891a 0%, var(--nt-gold) 45%, var(--nt-gold-light) 100%);
  padding: 60px 0;
  position: relative;
  overflow: hidden;
}

.nt-booking-banner::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.12) 1px, transparent 1px);
  background-size: 28px 28px;
  pointer-events: none;
}

.nt-booking-inner {
  position: relative;
  z-index: 1;
  text-align: center;
}

.nt-booking-title {
  font-family: 'Georgia', serif;
  font-size: clamp(22px, 3.5vw, 36px);
  font-weight: 700;
  color: #1B3A2D;
  margin: 0 0 10px;
}

.nt-booking-sub {
  color: rgba(27,58,45,0.75);
  font-size: 15px;
  margin-bottom: 36px;
}

.nt-steps {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 0;
  margin-bottom: 36px;
}

.nt-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 0 20px;
}

.nt-step-num {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #1B3A2D;
  color: var(--nt-gold-light);
  font-size: 15px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nt-step-label {
  font-size: 12.5px;
  font-weight: 700;
  color: #1B3A2D;
  text-align: center;
  white-space: nowrap;
}

.nt-step-arrow {
  color: rgba(27,58,45,0.45);
  font-size: 20px;
  padding: 0 4px;
  align-self: flex-start;
  margin-top: 8px;
}

.nt-booking-ctas {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14px;
}

.nt-btn-whatsapp {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  background: #1B3A2D;
  color: var(--nt-gold-light);
  font-size: 15px;
  font-weight: 700;
  padding: 14px 28px;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.22s, transform 0.18s, box-shadow 0.22s;
  box-shadow: 0 6px 24px rgba(27,58,45,0.30);
}
.nt-btn-whatsapp:hover {
  background: #0f2318;
  transform: translateY(-2px);
  box-shadow: 0 10px 32px rgba(27,58,45,0.40);
}

.nt-btn-book-inline {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(27,58,45,0.15);
  color: #1B3A2D;
  font-size: 14px;
  font-weight: 700;
  padding: 13px 24px;
  border-radius: 50px;
  border: 2px solid rgba(27,58,45,0.30);
  text-decoration: none;
  transition: background 0.22s, transform 0.18s;
}
.nt-btn-book-inline:hover {
  background: rgba(27,58,45,0.25);
  transform: translateY(-2px);
}

/* ════════════════════════════════════════════════
   UTILITY
   ════════════════════════════════════════════════ */
.nt-hidden { display: none !important; }

/* entry animations */
.nt-fade-in {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}
.nt-fade-in.nt-visible {
  opacity: 1;
  transform: translateY(0);
}
</style>

