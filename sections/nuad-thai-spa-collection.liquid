{% comment %} Nuad Thai Spa — Luxury Booking Page {% endcomment %}
{% assign nt_treatments = collection.products %}

<style>
:root {
  --nt-gold: #c9a96e;
  --nt-light-gold: #e8d5a3;
  --nt-dark: #1a1a14;
  --nt-surface: #22201a;
  --nt-card: #2a2820;
  --nt-border: rgba(201,169,110,0.2);
  --nt-text: #f5f0e8;
  --nt-muted: #998874;
  --nt-green: #4a7c59;
  --nt-radius: 16px;
}

.nt-page {
  background: var(--nt-dark);
  min-height: 100vh;
  color: var(--nt-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  overflow-x: hidden;
}

/* HERO */
.nt-hero {
  position: relative;
  background: linear-gradient(160deg, #0f0f0a 0%, #1a1a14 40%, #0a1410 100%);
  padding: 64px 20px 48px;
  text-align: center;
  overflow: hidden;
}
.nt-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c9a96e' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}
.nt-hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(201,169,110,0.1); border: 1px solid var(--nt-border);
  color: var(--nt-gold); padding: 8px 20px; border-radius: 24px;
  font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
  margin-bottom: 20px;
}
.nt-hero-title {
  font-size: clamp(32px, 7vw, 60px); font-weight: 300; letter-spacing: -1px;
  line-height: 1.1; color: var(--nt-text); margin: 0 0 8px;
}
.nt-hero-title em {
  font-style: italic; font-weight: 600;
  background: linear-gradient(135deg, #e8d5a3, #c9a96e, #9a7a4a);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.nt-hero-tagline { font-size: 16px; color: var(--nt-muted); margin: 12px 0 32px; font-style: italic; }
.nt-hero-divider {
  display: flex; align-items: center; gap: 12px; justify-content: center; margin-bottom: 32px;
}
.nt-divider-line { width: 60px; height: 1px; background: var(--nt-border); }
.nt-divider-icon { color: var(--nt-gold); font-size: 16px; }

/* SIGNATURE PACKAGES */
.nt-section { padding: 48px 20px; }
.nt-section-header { text-align: center; margin-bottom: 36px; }
.nt-section-eyebrow { font-size: 11px; color: var(--nt-gold); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
.nt-section-title { font-size: 28px; font-weight: 300; color: var(--nt-text); }
.nt-section-title strong { font-weight: 700; }

.nt-sig-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
  max-width: 1000px;
  margin: 0 auto;
}

.nt-sig-card {
  background: var(--nt-card); border: 1px solid var(--nt-border);
  border-radius: var(--nt-radius); overflow: hidden;
  transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
}
.nt-sig-card:hover { transform: translateY(-4px); border-color: rgba(201,169,110,0.4); box-shadow: 0 12px 40px rgba(0,0,0,0.4); }
.nt-sig-img { width: 100%; height: 180px; object-fit: cover; display: block; }
.nt-sig-img-ph {
  width: 100%; height: 180px;
  background: linear-gradient(135deg, #2a2820, #1a1a14);
  display: flex; align-items: center; justify-content: center;
  font-size: 56px; color: var(--nt-gold);
}
.nt-sig-body { padding: 20px; }
.nt-sig-name { font-size: 17px; font-weight: 700; color: var(--nt-text); margin-bottom: 6px; }
.nt-sig-desc { font-size: 13px; color: var(--nt-muted); line-height: 1.6; margin-bottom: 14px; }
.nt-sig-meta { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
.nt-sig-tag {
  background: rgba(201,169,110,0.08); border: 1px solid var(--nt-border);
  color: var(--nt-gold); padding: 4px 10px; border-radius: 10px; font-size: 11px; font-weight: 600;
}
.nt-sig-price { font-size: 18px; font-weight: 700; color: var(--nt-gold); margin-bottom: 14px; }
.nt-sig-price span { font-size: 12px; font-weight: 400; color: var(--nt-muted); }
.nt-sig-btn {
  width: 100%; padding: 13px; background: linear-gradient(135deg, #c9a96e, #9a7a4a);
  color: #fff; border: none; border-radius: 10px; font-size: 14px; font-weight: 700;
  cursor: pointer; transition: opacity 0.2s, transform 0.1s; letter-spacing: 0.3px;
}
.nt-sig-btn:hover { opacity: 0.9; }
.nt-sig-btn:active { transform: scale(0.98); }

/* BOOKING DRAWER */
.nt-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.7);
  backdrop-filter: blur(6px); z-index: 300; opacity: 0; pointer-events: none;
  transition: opacity 0.3s;
}
.nt-overlay.nt-open { opacity: 1; pointer-events: auto; }
.nt-drawer {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #1c1c14; border-top: 1px solid var(--nt-border);
  border-radius: 24px 24px 0 0; z-index: 301;
  transform: translateY(100%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
  max-height: 92vh; overflow-y: auto;
}
.nt-drawer.nt-open { transform: translateY(0); }

/* Drawer colors scoped outside .nt-page */
#ntBookingDrawer {
  --nt-gold: #c9a96e;
  --nt-light-gold: #e8d5a3;
  --nt-dark: #1a1a14;
  --nt-surface: #22201a;
  --nt-card: #2a2820;
  --nt-border: rgba(201,169,110,0.2);
  --nt-text: #f5f0e8;
  --nt-muted: #998874;
}
.nt-drawer-handle {
  width: 40px; height: 4px; background: rgba(255,255,255,0.15);
  border-radius: 2px; margin: 14px auto 0; cursor: pointer;
}
.nt-drawer-header { padding: 20px 24px; border-bottom: 1px solid var(--nt-border); }
.nt-drawer-title { font-size: 18px; font-weight: 700; color: var(--nt-text); }
.nt-drawer-sub { font-size: 13px; color: var(--nt-muted); margin-top: 4px; }
.nt-drawer-body { padding: 24px; }

/* STEP INDICATOR */
.nt-steps { display: flex; gap: 8px; margin-bottom: 28px; }
.nt-step-dot {
  flex: 1; height: 3px; border-radius: 2px; background: rgba(255,255,255,0.1);
  transition: background 0.3s;
}
.nt-step-dot.nt-done { background: var(--nt-gold); }
.nt-step-label { font-size: 11px; color: var(--nt-muted); text-align: center; margin-bottom: 8px; letter-spacing: 0.5px; }

/* DATE CHIPS */
.nt-date-grid { display: flex; gap: 10px; flex-wrap: wrap; }
.nt-date-chip {
  background: var(--nt-card); border: 1.5px solid var(--nt-border);
  border-radius: 12px; padding: 10px 14px; cursor: pointer;
  transition: all 0.2s; text-align: center;
}
.nt-date-chip:hover { border-color: rgba(201,169,110,0.5); }
.nt-date-chip.nt-sel { background: rgba(201,169,110,0.15); border-color: var(--nt-gold); }
.nt-date-chip-day { font-size: 11px; color: var(--nt-muted); text-transform: uppercase; }
.nt-date-chip-num { font-size: 20px; font-weight: 800; color: var(--nt-text); }
.nt-date-chip-mon { font-size: 11px; color: var(--nt-muted); }

/* TIME SLOTS */
.nt-time-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
.nt-time-slot {
  background: var(--nt-card); border: 1.5px solid var(--nt-border);
  border-radius: 12px; padding: 12px 14px; cursor: pointer; transition: all 0.2s;
}
.nt-time-slot:hover { border-color: rgba(201,169,110,0.5); }
.nt-time-slot.nt-sel { background: rgba(201,169,110,0.15); border-color: var(--nt-gold); }
.nt-time-period { font-size: 11px; color: var(--nt-gold); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
.nt-time-range { font-size: 14px; font-weight: 700; color: var(--nt-text); margin-top: 2px; }

/* DETAILS FORM */
.nt-form-field { margin-bottom: 16px; }
.nt-form-label { display: block; font-size: 11px; color: var(--nt-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
.nt-form-input, .nt-form-textarea {
  width: 100%; padding: 13px 16px;
  background: var(--nt-card); border: 1.5px solid var(--nt-border);
  border-radius: 12px; color: var(--nt-text); font-size: 14px; font-family: inherit;
  outline: none; transition: border-color 0.2s; box-sizing: border-box;
}
.nt-form-input:focus, .nt-form-textarea:focus { border-color: var(--nt-gold); }
.nt-form-textarea { resize: vertical; min-height: 80px; line-height: 1.6; }

/* BOOKING SUMMARY BOX */
.nt-summary {
  background: rgba(201,169,110,0.06); border: 1px solid var(--nt-border);
  border-radius: 14px; padding: 16px; margin-bottom: 20px;
}
.nt-summary-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 6px 0; }
.nt-summary-row + .nt-summary-row { border-top: 1px solid rgba(255,255,255,0.05); }
.nt-summary-key { font-size: 12px; color: var(--nt-muted); }
.nt-summary-val { font-size: 13px; font-weight: 600; color: var(--nt-text); text-align: right; max-width: 65%; }

/* DRAWER BUTTONS */
.nt-btn-row { display: flex; gap: 12px; margin-top: 20px; }
.nt-btn-back {
  flex: 0; padding: 14px 20px; background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1); color: var(--nt-text);
  border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer;
  transition: background 0.2s; white-space: nowrap;
}
.nt-btn-back:hover { background: rgba(255,255,255,0.1); }
.nt-btn-next {
  flex: 1; padding: 14px; background: linear-gradient(135deg, #c9a96e, #9a7a4a);
  color: #fff; border: none; border-radius: 12px; font-size: 14px; font-weight: 700;
  cursor: pointer; transition: opacity 0.2s; letter-spacing: 0.3px;
}
.nt-btn-next:hover { opacity: 0.9; }
.nt-btn-next:disabled { background: #444; color: #888; cursor: default; }

/* STEP PANELS */
.nt-step-panel { display: none; }
.nt-step-panel.nt-active { display: block; }
</style>

<div class="nt-page">

  <!-- HERO -->
  <div class="nt-hero">
    <div class="nt-hero-eyebrow">🌿 Traditional Thai Wellness</div>
    <h1 class="nt-hero-title">{{ collection.title | default: 'Nuad Thai' }}<br><em>Spa &amp; Wellness</em></h1>
    <p class="nt-hero-tagline">Restore. Rejuvenate. Reconnect.</p>
    <div class="nt-hero-divider">
      <div class="nt-divider-line"></div>
      <span class="nt-divider-icon">✦</span>
      <div class="nt-divider-line"></div>
    </div>
    {% if collection.description != blank %}
      <p style="font-size:15px;color:var(--nt-muted);max-width:540px;margin:0 auto;line-height:1.7">{{ collection.description | strip_html | truncate: 160 }}</p>
    {% endif %}
  </div>

  <!-- TREATMENTS / SIGNATURE PACKAGES -->
  <div class="nt-section">
    <div class="nt-section-header">
      <div class="nt-section-eyebrow">✦ Signature Experiences</div>
      <div class="nt-section-title">Choose Your <strong>Treatment</strong></div>
    </div>

    <div class="nt-sig-grid">
      {% for p in nt_treatments %}
        {% assign price_str = p.price | money_without_currency %}
        {% assign dur_tag = '' %}
        {% for tag in p.tags %}
          {% if tag contains 'min' or tag contains 'hour' %}
            {% assign dur_tag = tag %}
          {% endif %}
        {% endfor %}
        <div class="nt-sig-card">
          {% if p.featured_image %}
            <img class="nt-sig-img" src="{{ p.featured_image | img_url: '600x360', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
          {% else %}
            <div class="nt-sig-img-ph">🌿</div>
          {% endif %}
          <div class="nt-sig-body">
            <div class="nt-sig-name">{{ p.title }}</div>
            {% if p.description != blank %}
              <div class="nt-sig-desc">{{ p.description | strip_html | truncate: 120 }}</div>
            {% endif %}
            <div class="nt-sig-meta">
              {% if dur_tag != blank %}<span class="nt-sig-tag">⏱ {{ dur_tag }}</span>{% endif %}
              {% if p.type != blank %}<span class="nt-sig-tag">{{ p.type }}</span>{% endif %}
            </div>
            <div class="nt-sig-price">NPR {{ price_str }} <span>per session</span></div>
            {% if p.available %}
              <button type="button" class="nt-sig-btn nt-book-trigger"
                data-variant="{{ p.variants.first.id }}"
                data-name="{{ p.title | escape }}"
                data-price="{{ price_str }}"
                data-currency="NPR"
                data-duration="{{ dur_tag | default: 'As per package' }}"
                onclick="ntOpenBooking(this)">
                Book Now
              </button>
            {% else %}
              <button type="button" class="nt-sig-btn" disabled style="background:#444">Unavailable</button>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

</div><!-- .nt-page -->

<!-- BOOKING OVERLAY + DRAWER -->
<div class="nt-overlay" id="ntOverlay" onclick="ntCloseBooking()"></div>
<div class="nt-drawer" id="ntBookingDrawer">
  <div class="nt-drawer-handle" onclick="ntCloseBooking()"></div>
  <div class="nt-drawer-header">
    <div class="nt-drawer-title" id="ntDrawerTitle">Book Treatment</div>
    <div class="nt-drawer-sub" id="ntDrawerSub"></div>
  </div>
  <div class="nt-drawer-body">
    <div class="nt-step-label" id="ntStepLabel">Step 1 of 3 — Select Date</div>
    <div class="nt-steps">
      <div class="nt-step-dot nt-done" id="ntDot1"></div>
      <div class="nt-step-dot" id="ntDot2"></div>
      <div class="nt-step-dot" id="ntDot3"></div>
    </div>

    <!-- STEP 1: DATE -->
    <div class="nt-step-panel nt-active" id="ntStep1">
      <div class="nt-date-grid" id="ntDateGrid"></div>
      <div class="nt-btn-row">
        <button class="nt-btn-next" id="ntNext1" onclick="ntGoStep(2)" disabled>Continue →</button>
      </div>
    </div>

    <!-- STEP 2: TIME -->
    <div class="nt-step-panel" id="ntStep2">
      <div class="nt-time-grid">
        <div class="nt-time-slot" onclick="ntSelTime(this,'Morning','9:00 AM – 10:30 AM')">
          <div class="nt-time-period">Morning</div>
          <div class="nt-time-range">9:00 AM – 10:30 AM</div>
        </div>
        <div class="nt-time-slot" onclick="ntSelTime(this,'Late Morning','10:30 AM – 12:00 PM')">
          <div class="nt-time-period">Late Morning</div>
          <div class="nt-time-range">10:30 AM – 12:00 PM</div>
        </div>
        <div class="nt-time-slot" onclick="ntSelTime(this,'Afternoon','1:00 PM – 2:30 PM')">
          <div class="nt-time-period">Afternoon</div>
          <div class="nt-time-range">1:00 PM – 2:30 PM</div>
        </div>
        <div class="nt-time-slot" onclick="ntSelTime(this,'Late Afternoon','3:00 PM – 4:30 PM')">
          <div class="nt-time-period">Late Afternoon</div>
          <div class="nt-time-range">3:00 PM – 4:30 PM</div>
        </div>
        <div class="nt-time-slot" onclick="ntSelTime(this,'Evening','5:00 PM – 6:30 PM')">
          <div class="nt-time-period">Evening</div>
          <div class="nt-time-range">5:00 PM – 6:30 PM</div>
        </div>
        <div class="nt-time-slot" onclick="ntSelTime(this,'Late Evening','7:00 PM – 8:30 PM')">
          <div class="nt-time-period">Late Evening</div>
          <div class="nt-time-range">7:00 PM – 8:30 PM</div>
        </div>
      </div>
      <div class="nt-btn-row">
        <button class="nt-btn-back" onclick="ntGoStep(1)">← Back</button>
        <button class="nt-btn-next" id="ntNext2" onclick="ntGoStep(3)" disabled>Continue →</button>
      </div>
    </div>

    <!-- STEP 3: DETAILS -->
    <div class="nt-step-panel" id="ntStep3">
      <div class="nt-summary" id="ntSummaryBox"></div>
      <div class="nt-form-field">
        <label class="nt-form-label">Your Name *</label>
        <input type="text" class="nt-form-input" id="ntGuestName" placeholder="Full name" required>
      </div>
      <div class="nt-form-field">
        <label class="nt-form-label">Phone / WhatsApp *</label>
        <input type="tel" class="nt-form-input" id="ntGuestPhone" placeholder="98XXXXXXXX" required>
      </div>
      <div class="nt-form-field">
        <label class="nt-form-label">Special Requests</label>
        <textarea class="nt-form-textarea" id="ntSpecial" placeholder="e.g. Light pressure, allergies, preferences…"></textarea>
      </div>
      <div class="nt-btn-row">
        <button class="nt-btn-back" onclick="ntGoStep(2)">← Back</button>
        <button class="nt-btn-next" id="ntConfirmBtn" onclick="ntConfirmBooking()">Confirm Booking</button>
      </div>
    </div>

  </div>
</div>

<script>
(function(){
  var ntState = { variant: null, name: '', price: '', currency: '', duration: '', date: null, time: null, timePeriod: '' };

  // Build date chips (next 14 days)
  function ntBuildDates(){
    var grid = document.getElementById('ntDateGrid');
    var days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var html = '';
    var today = new Date();
    for(var i = 1; i <= 14; i++){
      var d = new Date(today);
      d.setDate(today.getDate() + i);
      html += '<div class="nt-date-chip" onclick="ntSelDate(this, \'' + d.toDateString() + '\')">' +
        '<div class="nt-date-chip-day">' + days[d.getDay()] + '</div>' +
        '<div class="nt-date-chip-num">' + d.getDate() + '</div>' +
        '<div class="nt-date-chip-mon">' + months[d.getMonth()] + '</div>' +
        '</div>';
    }
    grid.innerHTML = html;
  }
  ntBuildDates();

  window.ntOpenBooking = function(btn){
    ntState.variant  = btn.dataset.variant;
    ntState.name     = btn.dataset.name;
    ntState.price    = btn.dataset.price;
    ntState.currency = btn.dataset.currency;
    ntState.duration = btn.dataset.duration;
    ntState.date = null; ntState.time = null; ntState.timePeriod = '';
    document.getElementById('ntDrawerTitle').textContent = ntState.name;
    document.getElementById('ntDrawerSub').textContent = ntState.currency + ' ' + ntState.price + (ntState.duration ? ' · ' + ntState.duration : '');
    // Reset selections
    document.querySelectorAll('.nt-date-chip').forEach(function(c){ c.classList.remove('nt-sel'); });
    document.querySelectorAll('.nt-time-slot').forEach(function(s){ s.classList.remove('nt-sel'); });
    document.getElementById('ntGuestName').value = '';
    document.getElementById('ntGuestPhone').value = '';
    document.getElementById('ntSpecial').value = '';
    document.getElementById('ntNext1').disabled = true;
    document.getElementById('ntNext2').disabled = true;
    ntGoStep(1);
    document.getElementById('ntOverlay').classList.add('nt-open');
    document.getElementById('ntBookingDrawer').classList.add('nt-open');
    document.body.style.overflow = 'hidden';
  };

  window.ntCloseBooking = function(){
    document.getElementById('ntOverlay').classList.remove('nt-open');
    document.getElementById('ntBookingDrawer').classList.remove('nt-open');
    document.body.style.overflow = '';
  };

  window.ntGoStep = function(step){
    document.querySelectorAll('.nt-step-panel').forEach(function(p){ p.classList.remove('nt-active'); });
    document.getElementById('ntStep' + step).classList.add('nt-active');
    var labels = ['', 'Step 1 of 3 — Select Date', 'Step 2 of 3 — Select Time', 'Step 3 of 3 — Your Details'];
    document.getElementById('ntStepLabel').textContent = labels[step];
    ['ntDot1','ntDot2','ntDot3'].forEach(function(id, i){
      var el = document.getElementById(id);
      el.classList.toggle('nt-done', i < step);
    });
    if(step === 3) ntBuildSummary();
  };

  window.ntSelDate = function(chip, dateStr){
    document.querySelectorAll('.nt-date-chip').forEach(function(c){ c.classList.remove('nt-sel'); });
    chip.classList.add('nt-sel');
    ntState.date = dateStr;
    document.getElementById('ntNext1').disabled = false;
  };

  window.ntSelTime = function(slot, period, range){
    document.querySelectorAll('.nt-time-slot').forEach(function(s){ s.classList.remove('nt-sel'); });
    slot.classList.add('nt-sel');
    ntState.time = range;
    ntState.timePeriod = period;
    document.getElementById('ntNext2').disabled = false;
  };

  function ntBuildSummary(){
    var box = document.getElementById('ntSummaryBox');
    box.innerHTML =
      '<div class="nt-summary-row"><span class="nt-summary-key">Treatment</span><span class="nt-summary-val">' + ntState.name + '</span></div>' +
      '<div class="nt-summary-row"><span class="nt-summary-key">Duration</span><span class="nt-summary-val">' + ntState.duration + '</span></div>' +
      '<div class="nt-summary-row"><span class="nt-summary-key">Date</span><span class="nt-summary-val">' + ntState.date + '</span></div>' +
      '<div class="nt-summary-row"><span class="nt-summary-key">Time</span><span class="nt-summary-val">' + ntState.timePeriod + ' · ' + ntState.time + '</span></div>' +
      '<div class="nt-summary-row"><span class="nt-summary-key">Price</span><span class="nt-summary-val" style="color:var(--nt-gold)">' + ntState.currency + ' ' + ntState.price + '</span></div>';
  }

  window.ntConfirmBooking = function(){
    var name  = document.getElementById('ntGuestName').value.trim();
    var phone = document.getElementById('ntGuestPhone').value.trim();
    var special = document.getElementById('ntSpecial').value.trim();
    if(!name || !phone){ alert('Please enter your name and phone number.'); return; }

    var btn = document.getElementById('ntConfirmBtn');
    btn.disabled = true; btn.textContent = '⏳ Processing…';

    var note = [
      '--- NUAD THAI SPA BOOKING ---',
      'Treatment: ' + ntState.name,
      'Duration: ' + ntState.duration,
      'Date: ' + ntState.date,
      'Time: ' + ntState.timePeriod + ' · ' + ntState.time,
      'Guest Name: ' + name,
      'Phone / WhatsApp: ' + phone,
      special ? 'Special Requests: ' + special : 'Special Requests: None'
    ].join('\n');

    function setNoteAndGo(){
      fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ note: note })
      }).then(function(){ window.location.href = '/cart'; })
        .catch(function(){ window.location.href = '/cart'; });
    }

    if(ntState.variant){
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: ntState.variant, quantity: 1 })
      }).then(setNoteAndGo).catch(setNoteAndGo);
    } else {
      setNoteAndGo();
    }
  };
})();
</script>
