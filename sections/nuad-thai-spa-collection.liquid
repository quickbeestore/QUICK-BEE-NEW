  <!-- ══════════════════════════════════════
       § 4  CATEGORY TABS + PRODUCT GRID
       ══════════════════════════════════════ -->
  <section class="nt-catalog nt-fade-in" id="nt-catalog">
    <div class="nt-container">
      <div class="nt-section-header">
        <span class="nt-section-eyebrow">✦ All Services</span>
        <h2 class="nt-section-title">Our Full Menu</h2>
        <p class="nt-section-sub">Explore every treatment — from rejuvenating massages to beauty rituals</p>
      </div>
    </div>

    <!-- Spacer + sticky tabs wrap -->
    <div id="nt-tabs-spacer"></div>
    <div id="nt-tabs-wrap">
      <div class="nt-tabs-inner" role="tablist" aria-label="Service categories">
        {%- comment -%} Collect unique product types {%- endcomment -%}
        {%- assign nt_types = "" -%}
        {%- for product in collection.products -%}
          {%- unless nt_types contains product.type -%}
            {%- if product.type != blank -%}
              {%- assign nt_types = nt_types | append: product.type | append: "||" -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
        {%- assign nt_type_list = nt_types | split: "||" -%}

        <button class="nt-tab-btn nt-tab-active" data-filter="all" role="tab" aria-selected="true">All</button>
        {%- for ptype in nt_type_list -%}
          {%- if ptype != blank -%}
            <button class="nt-tab-btn" data-filter="{{ ptype | downcase | replace: ' ', '-' }}" role="tab" aria-selected="false">{{ ptype }}</button>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Fallback tabs when collection is empty {%- endcomment -%}
        {%- if collection.products.size == 0 -%}
          {%- assign fallback_tabs = "Thai Massage,Reflexology,Body Scrub,Facial Treatments,Nail Care,Waxing & Threading,Salon Services,Extras" | split: "," -%}
          {%- for ft in fallback_tabs -%}
            <button class="nt-tab-btn" data-filter="{{ ft | downcase | replace: ' ', '-' | replace: '&', 'and' }}" role="tab" aria-selected="false">{{ ft }}</button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <div class="nt-container">
      <div class="nt-products-section">

        {%- if collection.products.size > 0 -%}
          <div class="nt-prod-grid" id="nt-prod-grid">
            {%- for product in collection.products -%}
              {%- assign ptype_key = product.type | downcase | replace: ' ', '-' -%}
              <div class="nt-prod-card" data-type="{{ ptype_key }}">
                <a href="{{ product.url }}" class="nt-card-link" aria-label="{{ product.title | escape }}"></a>
                <div class="nt-prod-card-inner">
                  <div class="nt-prod-img-wrap">
                    {%- if product.featured_image -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 640 }}"
                        alt="{{ product.featured_image.alt | default: product.title | escape }}"
                        loading="lazy"
                        width="640"
                        height="480">
                    {%- else -%}
                      <div class="nt-prod-img-placeholder">🪷</div>
                    {%- endif -%}
                    {%- if product.type != blank -%}
                      <span class="nt-prod-type-badge">{{ product.type }}</span>
                    {%- endif -%}
                  </div>
                  <div class="nt-prod-body">
                    <h3 class="nt-prod-name">{{ product.title }}</h3>
                    {%- if product.description != blank -%}
                      <p class="nt-prod-desc">{{ product.description | strip_html | truncate: 80 }}</p>
                    {%- endif -%}

                    {%- comment -%} Variant selector (duration / options) {%- endcomment -%}
                    {%- if product.variants.size > 1 -%}
                      <div class="nt-prod-variants">
                        {%- for variant in product.variants -%}
                          <button
                            type="button"
                            class="nt-variant-pill nt-variant-btn{% if forloop.first %} nt-variant-active{% endif %}"
                            data-vid="{{ variant.id }}"
                            data-price="{{ variant.price | money }}"
                            data-card="{{ product.id }}"
                            {% unless variant.available %}disabled{% endunless %}>
                            {{ variant.title }}
                          </button>
                        {%- endfor -%}
                      </div>
                    {%- endif -%}

                    <div class="nt-prod-footer">
                      <span class="nt-prod-price" id="nt-price-{{ product.id }}">
                        {%- if product.price_varies -%}From {%- endif -%}
                        {{ product.price_min | money }}
                      </span>
                      <button
                        type="button"
                        class="nt-prod-book nt-book-trigger"
                        data-variant="{{ product.selected_or_first_available_variant.id }}"
                        data-name="{{ product.title | escape }}"
                        data-price="{{ product.price_min | money_without_currency }}"
                        data-currency="NPR"
                        data-duration="{{ product.selected_or_first_available_variant.title | escape }}"
                        data-pid="{{ product.id }}">
                        Book Now
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>

        {%- else -%}
          <!-- Empty / demo state -->
          <div class="nt-products-empty">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
              <circle cx="32" cy="32" r="30" stroke="#C9A84C" stroke-width="1.5"/>
              <path d="M32 18 C32 18 20 28 20 36 C20 42.6 25.4 48 32 48 C38.6 48 44 42.6 44 36 C44 28 32 18 32 18Z" fill="rgba(201,168,76,0.25)" stroke="#C9A84C" stroke-width="1.2"/>
