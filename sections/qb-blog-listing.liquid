<!-- QuickBee Blog Listing Page — Premium Mobile UI -->

<div class="qb-blog-page">

  <!-- Hero -->
  <div class="qb-blog-hero">
    <div class="qb-blog-hero-inner animate-fade-in">
      <span class="qb-blog-hero-bee">🐝</span>
      <h1 class="qb-blog-hero-title">QuickBee Blog</h1>
      <p class="qb-blog-hero-sub">Tips, guides & stories from Kathmandu's fastest delivery</p>
    </div>
  </div>

  <!-- Category Filters -->
  <div class="qb-blog-filters">
    <a href="/blogs/{{ blog.handle }}" class="qb-blog-filter {% unless current_tags %}active{% endunless %}">All</a>
    {% for tag in blog.all_tags %}
      <a href="/blogs/{{ blog.handle }}/tagged/{{ tag | handle }}" class="qb-blog-filter {% if current_tags contains tag %}active{% endif %}">{{ tag }}</a>
    {% endfor %}
  </div>

  <!-- Articles Grid -->
  <div class="qb-blog-grid-outer">
    {% paginate blog.articles by 12 %}
      {% if blog.articles_count > 0 %}
        <div class="qb-blog-grid">
          {% for article in blog.articles %}
            <a href="{{ article.url }}" class="qb-blog-card animate-fade-in" style="animation-delay: {{ forloop.index0 | times: 0.05 }}s">
              <!-- Image -->
              <div class="qb-blog-card-img">
                {% if article.image %}
                  <img
                    src="{{ article.image | img_url: '600x350', crop: 'center' }}"
                    alt="{{ article.title | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <div class="qb-blog-card-no-img">🐝</div>
                {% endif %}
              </div>

              <!-- Info -->
              <div class="qb-blog-card-info">
                {% if article.tags.size > 0 %}
                  <span class="qb-blog-card-tag">{{ article.tags.first }}</span>
                {% endif %}
                <h2 class="qb-blog-card-title">{{ article.title | truncate: 70 }}</h2>
                <p class="qb-blog-card-excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
                <div class="qb-blog-card-meta">
                  <span>📅 {{ article.published_at | date: '%b %d, %Y' }}</span>
                  <span>·</span>
                  <span>⏱️ {{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
                </div>
              </div>
            </a>
          {% endfor %}
        </div>

        <!-- Pagination -->
        {% if paginate.pages > 1 %}
          <div class="qb-blog-pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" class="qb-blog-page-btn">← Prev</a>
            {% endif %}
            <span class="qb-blog-page-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" class="qb-blog-page-btn">Next →</a>
            {% endif %}
          </div>
        {% endif %}

      {% else %}
        <div class="qb-blog-empty">
          <span>🐝</span>
          <p>No articles yet. Check back soon!</p>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>

</div>

<style>
  :root {
    --qb-purple: #7a14ac;
    --qb-purple-light: #fdf7ff;
    --qb-gold: #F4B400;
    --qb-black: #111111;
    --qb-text: #444444;
    --qb-bg: #f8f9fa;
  }

  .qb-blog-page {
    background: var(--qb-bg);
    min-height: 100vh;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  /* Hero */
  .qb-blog-hero {
    background: white;
    padding: 60px 20px;
    text-align: center;
    border-bottom: 1px solid #eee;
  }

  .qb-blog-hero-bee {
    font-size: 48px;
    display: block;
    margin-bottom: 12px;
    animation: bounce-bee 3s ease-in-out infinite;
  }

  @keyframes bounce-bee {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .qb-blog-hero-title {
    font-size: 32px;
    font-weight: 900;
    color: var(--qb-black);
    margin: 0 0 10px;
    letter-spacing: -1px;
  }

  .qb-blog-hero-sub {
    font-size: 15px;
    color: var(--qb-text);
    margin: 0;
    font-weight: 500;
  }

  /* Filters */
  .qb-blog-filters {
    display: flex;
    gap: 10px;
    padding: 20px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    background: white;
    border-bottom: 1px solid #eee;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .qb-blog-filters::-webkit-scrollbar { display: none; }

  .qb-blog-filter {
    display: inline-block;
    white-space: nowrap;
    padding: 8px 18px;
    border-radius: 20px;
    background: #f5f5f5;
    font-size: 13px;
    font-weight: 700;
    color: var(--qb-text);
    text-decoration: none;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .qb-blog-filter:hover {
    background: #e0e0e0;
  }

  .qb-blog-filter.active {
    background: var(--qb-purple);
    color: white;
    box-shadow: 0 4px 12px rgba(122, 20, 172, 0.2);
  }

  /* Grid */
  .qb-blog-grid-outer {
    padding: 24px 20px 60px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .qb-blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  /* Card */
  .qb-blog-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    transition: transform 0.2s, box-shadow 0.2s;
    border: 1px solid #f0f0f0;
  }

  .qb-blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.08);
  }

  .qb-blog-card-img {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: var(--qb-purple-light);
  }

  .qb-blog-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .qb-blog-card:hover .qb-blog-card-img img {
    transform: scale(1.05);
  }

  .qb-blog-card-no-img {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 60px;
  }

  .qb-blog-card-info {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .qb-blog-card-tag {
    align-self: flex-start;
    background: var(--qb-gold);
    color: var(--qb-black);
    font-size: 11px;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 12px;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .qb-blog-card-title {
    font-size: 18px;
    font-weight: 800;
    color: var(--qb-black);
    line-height: 1.4;
    margin: 0 0 10px;
  }

  .qb-blog-card-excerpt {
    font-size: 14px;
    color: var(--qb-text);
    line-height: 1.6;
    margin: 0 0 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .qb-blog-card-meta {
    margin-top: auto;
    display: flex;
    gap: 8px;
    font-size: 12px;
    color: #888;
    font-weight: 600;
  }

  /* Pagination */
  .qb-blog-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 40px 0 20px;
  }

  .qb-blog-page-btn {
    display: inline-block;
    padding: 10px 24px;
    background: var(--qb-purple);
    color: white;
    font-weight: 800;
    font-size: 14px;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .qb-blog-page-btn:hover { background: #5a0d8c; }

  .qb-blog-page-info {
    font-size: 14px;
    color: #666;
    font-weight: 700;
  }

  /* Empty */
  .qb-blog-empty {
    text-align: center;
    padding: 80px 20px;
    background: white;
    border-radius: 20px;
    color: #999;
  }

  .qb-blog-empty span { font-size: 60px; display: block; margin-bottom: 16px; }
  .qb-blog-empty p { font-size: 16px; font-weight: 600; }

  /* Animations */
  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive */
  @media (min-width: 640px) {
    .qb-blog-grid { grid-template-columns: repeat(2, 1fr); }
    .qb-blog-hero-title { font-size: 40px; }
  }

  @media (min-width: 1024px) {
    .qb-blog-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

{% schema %}
{
  "name": "QuickBee Blog Listing",
  "settings": [],
  "presets": [{ "name": "QuickBee Blog Listing" }]
}
{% endschema %}