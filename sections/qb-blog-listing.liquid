{% comment %}
  QuickBee Blog Listing — v3 Elite
  Magazine-style, dark/light mode, SEO-optimized, featured hero, sticky filter
{% endcomment %}

<div class="qbl-wrap">

  <!-- ═══ READING PROGRESS BAR ═══ -->
  <div class="qbl-progress" id="qblProgress"></div>

  <!-- ═══ HERO ═══ -->
  <section class="qbl-hero">
    <div class="qbl-hero-orb qbl-hero-orb-1"></div>
    <div class="qbl-hero-orb qbl-hero-orb-2"></div>
    <div class="qbl-hero-inner">
      <div class="qbl-hero-badge">
        <span class="qbl-hero-badge-dot"></span>
        Nepal's Fastest Delivery
      </div>
      <h1 class="qbl-hero-title">QuickBee <span class="qbl-hero-gold">Insider</span></h1>
      <p class="qbl-hero-sub">Delivery tips, food guides, business stories & the latest from Kathmandu Valley</p>
      <div class="qbl-hero-stats">
        <div class="qbl-hstat"><span class="qbl-hstat-n">{{ blog.articles_count }}+</span><span class="qbl-hstat-l">Articles</span></div>
        <div class="qbl-hstat-div"></div>
        <div class="qbl-hstat"><span class="qbl-hstat-n">20 min</span><span class="qbl-hstat-l">Delivery</span></div>
        <div class="qbl-hstat-div"></div>
        <div class="qbl-hstat"><span class="qbl-hstat-n">KTM</span><span class="qbl-hstat-l">Valley</span></div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED ARTICLE (first article, full-width) ═══ -->
  {% assign featured = blog.articles | first %}
  {% if featured %}
  <section class="qbl-featured-wrap">
    <a href="{{ featured.url }}" class="qbl-featured-card">
      <div class="qbl-featured-img">
        {% if featured.image %}
          <img src="{{ featured.image | img_url: '1400x700', crop: 'center' }}" alt="{{ featured.title | escape }}" loading="eager">
        {% else %}
          <div class="qbl-featured-no-img">🐝</div>
        {% endif %}
        <div class="qbl-featured-overlay"></div>
      </div>
      <div class="qbl-featured-body">
        <div class="qbl-featured-eyebrow">
          {% if featured.tags.size > 0 %}<span class="qbl-ftag">{{ featured.tags.first }}</span>{% endif %}
          <span class="qbl-featured-new">✦ Featured</span>
        </div>
        <h2 class="qbl-featured-title">{{ featured.title }}</h2>
        <p class="qbl-featured-excerpt">{{ featured.excerpt | strip_html | truncate: 160 }}</p>
        <div class="qbl-featured-meta">
          <span>📅 {{ featured.published_at | date: '%B %d, %Y' }}</span>
          <span>·</span>
          <span>⏱ {{ featured.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
          <span>·</span>
          <span>✍️ {{ featured.author }}</span>
        </div>
        <span class="qbl-featured-cta">Read Article →</span>
      </div>
    </a>
  </section>
  {% endif %}

  <!-- ═══ STICKY CATEGORY FILTER ═══ -->
  <div class="qbl-filters-wrap" id="qblFilters">
    <div class="qbl-filters-inner">
      <a href="/blogs/{{ blog.handle }}" class="qbl-filter {% unless current_tags %}active{% endunless %}">All Posts</a>
      {% for tag in blog.all_tags %}
        <a href="/blogs/{{ blog.handle }}/tagged/{{ tag | handle }}" class="qbl-filter {% if current_tags contains tag %}active{% endif %}">{{ tag }}</a>
      {% endfor %}
    </div>
  </div>

  <!-- ═══ ARTICLE GRID ═══ -->
  <div class="qbl-grid-section">
    {% paginate blog.articles by 12 %}

      {% if blog.articles_count > 0 %}
        <div class="qbl-grid">
          {% for article in blog.articles %}
            {% if forloop.first and featured.id == article.id %}{% continue %}{% endif %}
            <a href="{{ article.url }}" class="qbl-card" style="animation-delay:{{ forloop.index0 | times: 0.06 }}s">
              <div class="qbl-card-img-wrap">
                {% if article.image %}
                  <img src="{{ article.image | img_url: '600x360', crop: 'center' }}" alt="{{ article.title | escape }}" loading="lazy">
                {% else %}
                  <div class="qbl-card-no-img">
                    {% assign atl = article.tags | first | downcase %}
                    {% if atl contains 'food' %}🍖
                    {% elsif atl contains 'cake' %}🎂
                    {% elsif atl contains 'beer' %}🍺
                    {% elsif atl contains 'partner' %}🤝
                    {% elsif atl contains 'guide' %}📖
                    {% elsif atl contains 'seo' %}📈
                    {% else %}🐝{% endif %}
                  </div>
                {% endif %}
                {% if article.tags.size > 0 %}
                  <span class="qbl-card-tag-badge">{{ article.tags.first }}</span>
                {% endif %}
              </div>
              <div class="qbl-card-body">
                <h2 class="qbl-card-title">{{ article.title | truncate: 72 }}</h2>
                <p class="qbl-card-excerpt">{{ article.excerpt | strip_html | truncate: 110 }}</p>
                <div class="qbl-card-footer">
                  <div class="qbl-card-meta">
                    <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                    <span>·</span>
                    <span>{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min</span>
                  </div>
                  <span class="qbl-card-read">Read →</span>
                </div>
              </div>
            </a>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <div class="qbl-pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" class="qbl-page-btn">← Previous</a>
            {% endif %}
            <span class="qbl-page-info">{{ paginate.current_page }} / {{ paginate.pages }}</span>
            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" class="qbl-page-btn">Next →</a>
            {% endif %}
          </div>
        {% endif %}

      {% else %}
        <div class="qbl-empty">
          <span>🐝</span>
          <h3>Articles coming soon!</h3>
          <p>We're brewing fresh content about delivery, food &amp; business in Nepal.</p>
          <a href="/collections/all" class="qbl-empty-cta">Browse Products →</a>
        </div>
      {% endif %}

    {% endpaginate %}
  </div>

  <!-- ═══ QUICKBEE CTA STRIP ═══ -->
  <section class="qbl-cta-strip">
    <div class="qbl-cta-strip-inner">
      <div class="qbl-cta-left">
        <h3>Order anything in 20 minutes 🚀</h3>
        <p>Food, beer, cakes, groceries — delivered across Kathmandu Valley</p>
      </div>
      <div class="qbl-cta-right">
        <a href="/collections/all" class="qbl-cta-primary">Order Now</a>
        <a href="/products/vendor-registration" class="qbl-cta-ghost">Partner with Us</a>
      </div>
    </div>
  </section>

</div>

<style>
/* ═══════════════════════════════════════════════
   QUICKBEE BLOG LISTING v3 — DARK/LIGHT BOTH
   ═══════════════════════════════════════════════ */
:root {
  --qbl-bg:     var(--theme-bg-primary, #f7f7f7);
  --qbl-bg2:    var(--theme-bg-secondary, #ffffff);
  --qbl-text:   var(--theme-text-main, #111111);
  --qbl-muted:  var(--theme-text-muted, #666666);
  --qbl-border: var(--theme-border, #e5e5e5);
  --qbl-gold:   #F4B400;
  --qbl-red:    #E53935;
  --qbl-ease:   cubic-bezier(.4,0,.2,1);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.qbl-wrap { background: var(--qbl-bg); min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }

/* Progress bar */
.qbl-progress {
  position: fixed; top: 0; left: 0; width: 0; height: 3px;
  background: linear-gradient(90deg, #F4B400, #E53935);
  z-index: 9999; transition: width .1s linear;
  box-shadow: 0 0 8px rgba(244,180,0,0.5);
}

/* ── HERO ── */
.qbl-hero {
  position: relative; overflow: hidden;
  padding: 64px 20px 56px;
  background: var(--qbl-bg2);
  text-align: center;
  border-bottom: 1px solid var(--qbl-border);
}
.qbl-hero-orb { position:absolute; border-radius:50%; pointer-events:none; }
.qbl-hero-orb-1 {
  width:300px; height:300px; top:-80px; right:-60px;
  background: radial-gradient(circle, rgba(244,180,0,0.08) 0%, transparent 70%);
}
.qbl-hero-orb-2 {
  width:200px; height:200px; bottom:-40px; left:-40px;
  background: radial-gradient(circle, rgba(229,57,53,0.06) 0%, transparent 70%);
}
.qbl-hero-inner { position:relative; z-index:1; max-width:680px; margin:0 auto; }
.qbl-hero-badge {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(244,180,0,0.1); border: 1.5px solid rgba(244,180,0,0.3);
  color: var(--qbl-gold); padding: 5px 14px; border-radius: 20px;
  font-size: 11px; font-weight: 800; letter-spacing: 0.5px;
  margin-bottom: 20px; text-transform: uppercase;
}
.qbl-hero-badge-dot {
  width: 7px; height: 7px; border-radius: 50%; background: #22c55e;
  animation: hbDot 1.5s ease-in-out infinite;
}
@keyframes hbDot { 0%,100%{opacity:1} 50%{opacity:0.35} }
.qbl-hero-title {
  font-size: clamp(32px, 7vw, 52px); font-weight: 900;
  color: var(--qbl-text); line-height: 1.1; letter-spacing: -1.5px;
  margin-bottom: 14px;
}
.qbl-hero-gold { color: var(--qbl-gold); }
.qbl-hero-sub {
  font-size: 15px; color: var(--qbl-muted); line-height: 1.65;
  margin-bottom: 28px; max-width: 500px; margin-left: auto; margin-right: auto;
}
.qbl-hero-stats { display: flex; align-items: center; justify-content: center; gap: 0; }
.qbl-hstat { display: flex; flex-direction: column; align-items: center; padding: 0 20px; }
.qbl-hstat-n { font-size: 22px; font-weight: 900; color: var(--qbl-gold); line-height: 1; }
.qbl-hstat-l { font-size: 10px; font-weight: 700; color: var(--qbl-muted); text-transform: uppercase; letter-spacing: 0.8px; margin-top: 3px; }
.qbl-hstat-div { width: 1px; height: 36px; background: var(--qbl-border); }

/* ── FEATURED ── */
.qbl-featured-wrap { padding: 20px 16px 8px; max-width: 1200px; margin: 0 auto; }
.qbl-featured-card {
  display: block; text-decoration: none; border-radius: 22px; overflow: hidden;
  position: relative; background: #111;
  box-shadow: 0 12px 48px rgba(0,0,0,0.18);
  transition: transform .22s var(--qbl-ease), box-shadow .22s var(--qbl-ease);
}
.qbl-featured-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.25); }
.qbl-featured-img { position: relative; height: 320px; overflow: hidden; }
@media(min-width:768px){ .qbl-featured-img { height: 400px; } }
.qbl-featured-img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .4s ease; }
.qbl-featured-card:hover .qbl-featured-img img { transform: scale(1.04); }
.qbl-featured-no-img { width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:72px; background:linear-gradient(135deg,#0d0d0d,#1a1a1a); }
.qbl-featured-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.55) 60%, rgba(0,0,0,0.9) 100%);
}
.qbl-featured-body {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 24px 22px; color: #fff;
}
.qbl-featured-eyebrow { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.qbl-ftag {
  background: var(--qbl-gold); color: #000;
  font-size: 10px; font-weight: 900; padding: 3px 10px; border-radius: 10px;
  text-transform: uppercase; letter-spacing: 0.5px;
}
.qbl-featured-new {
  font-size: 11px; font-weight: 800; color: rgba(255,255,255,0.7); letter-spacing: 0.8px;
}
.qbl-featured-title {
  font-size: clamp(18px, 3.5vw, 26px); font-weight: 900; color: #fff;
  line-height: 1.3; margin-bottom: 8px; letter-spacing: -0.3px;
}
.qbl-featured-excerpt {
  font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.6;
  margin-bottom: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
@media(max-width:479px){ .qbl-featured-excerpt { display: none; } }
.qbl-featured-meta {
  display: flex; align-items: center; gap: 7px; flex-wrap: wrap;
  font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.55);
  margin-bottom: 14px;
}
.qbl-featured-cta {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 10px 20px; border-radius: 10px;
  background: var(--qbl-gold); color: #000;
  font-size: 13px; font-weight: 900;
  transition: transform .15s; box-shadow: 0 4px 16px rgba(244,180,0,0.4);
}
.qbl-featured-card:hover .qbl-featured-cta { transform: translateX(3px); }

/* ── FILTERS ── */
.qbl-filters-wrap {
  position: sticky; top: 0; z-index: 80;
  background: var(--qbl-bg2);
  border-bottom: 1px solid var(--qbl-border);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.qbl-filters-inner {
  display: flex; gap: 8px; padding: 12px 16px;
  overflow-x: auto; scrollbar-width: none;
  max-width: 1200px; margin: 0 auto;
}
.qbl-filters-inner::-webkit-scrollbar { display: none; }
.qbl-filter {
  flex-shrink: 0; display: inline-flex; align-items: center;
  padding: 7px 16px; border-radius: 20px;
  background: rgba(244,180,0,0.07); border: 1.5px solid rgba(244,180,0,0.15);
  color: var(--qbl-muted); font-size: 12px; font-weight: 700;
  text-decoration: none; white-space: nowrap;
  transition: all .18s var(--qbl-ease);
}
.qbl-filter:hover { background: rgba(244,180,0,0.15); color: var(--qbl-text); }
.qbl-filter.active {
  background: var(--qbl-gold); border-color: var(--qbl-gold);
  color: #000; box-shadow: 0 4px 12px rgba(244,180,0,0.3);
}

/* ── GRID ── */
.qbl-grid-section {
  padding: 20px 16px 40px;
  max-width: 1200px; margin: 0 auto;
}
.qbl-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}
@media(min-width:580px){ .qbl-grid { grid-template-columns: repeat(2,1fr); } }
@media(min-width:1024px){ .qbl-grid { grid-template-columns: repeat(3,1fr); } }

/* ── CARD ── */
.qbl-card {
  display: flex; flex-direction: column;
  text-decoration: none; background: var(--qbl-bg2);
  border-radius: 18px; overflow: hidden;
  border: 1px solid var(--qbl-border);
  transition: transform .22s var(--qbl-ease), box-shadow .22s var(--qbl-ease), border-color .22s;
  animation: qblCardIn .5s ease-out forwards; opacity: 0;
}
@keyframes qblCardIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
.qbl-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 14px 36px rgba(0,0,0,0.1);
  border-color: rgba(244,180,0,0.35);
}
.qbl-card-img-wrap { position:relative; height:200px; overflow:hidden; background:#1a1a1a; flex-shrink:0; }
html:not([data-theme="dark"]) .qbl-card-img-wrap { background: #f0f0f0; }
.qbl-card-img-wrap img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .35s ease; }
.qbl-card:hover .qbl-card-img-wrap img { transform:scale(1.06); }
.qbl-card-no-img { width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:56px; }
.qbl-card-tag-badge {
  position: absolute; top: 10px; left: 10px;
  background: var(--qbl-gold); color: #000;
  font-size: 10px; font-weight: 900; padding: 3px 9px; border-radius: 8px;
  text-transform: uppercase; letter-spacing: 0.4px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}
.qbl-card-body { display:flex; flex-direction:column; flex:1; padding:18px; }
.qbl-card-title {
  font-size: 16px; font-weight: 800; color: var(--qbl-text);
  line-height: 1.4; margin-bottom: 8px; letter-spacing: -0.2px;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.qbl-card-excerpt {
  font-size: 13px; color: var(--qbl-muted); line-height: 1.6;
  margin-bottom: 16px; flex: 1;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.qbl-card-footer { display:flex; align-items:center; justify-content:space-between; margin-top:auto; }
.qbl-card-meta { font-size: 11px; color: var(--qbl-muted); font-weight: 600; display:flex;gap:5px; }
.qbl-card-read {
  font-size: 12px; font-weight: 800; color: var(--qbl-gold);
  transition: transform .15s;
}
.qbl-card:hover .qbl-card-read { transform: translateX(3px); }

/* ── PAGINATION ── */
.qbl-pagination {
  display: flex; align-items: center; justify-content: center;
  gap: 16px; padding: 32px 0 16px;
}
.qbl-page-btn {
  padding: 10px 24px; border-radius: 12px;
  background: var(--qbl-gold); color: #000;
  font-size: 13px; font-weight: 900; text-decoration: none;
  transition: opacity .18s, transform .15s;
}
.qbl-page-btn:hover { opacity: 0.85; transform: scale(1.03); }
.qbl-page-info { font-size: 13px; font-weight: 700; color: var(--qbl-muted); }

/* ── EMPTY ── */
.qbl-empty {
  text-align: center; padding: 80px 20px;
  background: var(--qbl-bg2); border-radius: 20px;
  border: 1px solid var(--qbl-border);
}
.qbl-empty span { font-size: 64px; display:block; margin-bottom:16px; animation:hbDot 2s ease-in-out infinite; }
.qbl-empty h3 { font-size: 20px; font-weight: 900; color: var(--qbl-text); margin-bottom: 8px; }
.qbl-empty p { font-size: 14px; color: var(--qbl-muted); margin-bottom: 24px; }
.qbl-empty-cta {
  display: inline-block; padding: 12px 28px; border-radius: 12px;
  background: var(--qbl-gold); color: #000; font-weight: 900; text-decoration: none;
}

/* ── CTA STRIP ── */
.qbl-cta-strip {
  background: linear-gradient(135deg, #0d0d0d, #1a0a00, #0d0d0d);
  border-top: 1px solid rgba(244,180,0,0.15);
  padding: 32px 20px;
}
html:not([data-theme="dark"]) .qbl-cta-strip {
  background: linear-gradient(135deg, #1a1a2e, #16213e, #1a1a2e);
}
.qbl-cta-strip-inner {
  max-width: 900px; margin: 0 auto;
  display: flex; align-items: center; gap: 24px;
  flex-wrap: wrap; justify-content: space-between;
}
.qbl-cta-left h3 { font-size: 20px; font-weight: 900; color: #fff; margin-bottom: 4px; letter-spacing: -0.3px; }
.qbl-cta-left p { font-size: 13px; color: rgba(255,255,255,0.55); }
.qbl-cta-right { display: flex; gap: 10px; flex-wrap: wrap; }
.qbl-cta-primary {
  padding: 12px 24px; border-radius: 12px; font-size: 14px; font-weight: 900;
  background: var(--qbl-gold); color: #000; text-decoration: none;
  box-shadow: 0 4px 18px rgba(244,180,0,0.4); transition: all .18s;
}
.qbl-cta-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 26px rgba(244,180,0,0.55); }
.qbl-cta-ghost {
  padding: 12px 24px; border-radius: 12px; font-size: 14px; font-weight: 900;
  background: rgba(255,255,255,0.08); border: 1.5px solid rgba(255,255,255,0.2);
  color: #fff; text-decoration: none; transition: all .18s;
}
.qbl-cta-ghost:hover { background: rgba(255,255,255,0.15); }
</style>

<script>
(function() {
  // Reading progress
  var bar = document.getElementById('qblProgress');
  function updateProgress() {
    var s = document.documentElement.scrollTop || document.body.scrollTop;
    var h = document.documentElement.scrollHeight - window.innerHeight;
    if (bar && h > 0) bar.style.width = Math.min(100, (s/h)*100) + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive: true });

  // Sticky filter shadow
  var filtersEl = document.getElementById('qblFilters');
  if (filtersEl) {
    window.addEventListener('scroll', function() {
      filtersEl.style.boxShadow = window.scrollY > 60 ? '0 4px 20px rgba(0,0,0,0.1)' : 'none';
    }, { passive: true });
  }
})();
</script>

{% schema %}
{
  "name": "QB Blog Listing v3",
  "settings": [],
  "presets": [{ "name": "QB Blog Listing v3" }]
}
{% endschema %}
