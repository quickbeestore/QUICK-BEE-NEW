<!-- Collection Sidebar with Category Navigation -->
<section id="qb-collection-sidebar" class="qb-collection-container">
  <style>
    :root {
      --qb-gold: #F4B400;
      --qb-gold-light: #fff8e1;
      --qb-gold-dim: rgba(244,180,0,0.12);
      --qb-dark: #111111;
      --qb-text-muted: #888;
      --qb-sidebar-w: 84px;
    }

    * {
      box-sizing: border-box;
    }

    /* HIDE PREVIEW BUTTONS GLOBALLY */
    [class*="preview"],
    [id*="preview"],
    [class*="quick-view"],
    [id*="quick-view"],
    .shopify-section__overlay,
    .button-preview,
    .product-preview,
    [data-testid*="preview"],
    [role="tooltip"],
    .tooltip-preview {
      display: none !important;
    }

    /* MOBILE FIRST - Base styles for mobile screens */
    .qb-collection-container {
      display: flex;
      flex-direction: row;
      gap: 0;
      width: 100%;
      height: 100vh;
      background: #0A0A0A;
      overflow: hidden;
    }

    /* SIDEBAR - Fixed on left */
    .qb-sidebar {
      position: fixed;
      top: calc(var(--qb-header-height, 100px));
      bottom: 65px;
      left: 0;
      width: var(--qb-sidebar-w);
      background: #121212;
      border-right: 1px solid #333;
      padding: 8px 0 0;
      overflow-x: hidden;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 0;
      z-index: 100;
      flex-shrink: 0;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .qb-sidebar::-webkit-scrollbar { display: none; }

    .qb-main-content {
      margin-left: var(--qb-sidebar-w);
      background: #0A0A0A;
    }

    /* ── Sidebar Item ── */
    .qb-sidebar-category {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      gap: 6px;
      padding: 12px 4px 10px;
      cursor: pointer;
      text-decoration: none;
      color: #E0E0E0;
      font-size: 9.5px;
      font-weight: 500;
      text-align: center;
      transition: background 0.15s ease, color 0.15s ease;
      border-left: 3px solid transparent;
      border-right: 3px solid transparent;
      flex-shrink: 0;
      width: 100%;
      min-height: 80px;
      position: relative;
      line-height: 1;
    }

    .qb-sidebar-category:hover {
      background: #1E1E1E;
      color: #fff;
    }

    .qb-sidebar-category:hover .qb-sidebar-img-wrap {
      border-color: rgba(244,180,0,0.5);
    }

    /* ── Active state ── */
    .qb-sidebar-category.active {
      background: #1E1E1E;
      color: #fff;
      border-left-color: var(--qb-gold);
      font-weight: 700;
      font-size: 9.5px;
    }

    .qb-sidebar-category.active .qb-sidebar-img-wrap {
      border-color: var(--qb-gold);
      box-shadow: 0 0 0 2px rgba(244,180,0,0.18);
    }

    /* ── Image circle ── */
    .qb-sidebar-img-wrap {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid #333;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
      background: #1A1A1A;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .qb-sidebar-img-wrap img,
    .qb-sidebar-icon img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .qb-sidebar-icon {
      font-size: 24px;
      line-height: 1;
      width: 52px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
    }

    .qb-sidebar-label {
      width: 100%;
      word-break: break-word;
      line-height: 1.3;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      letter-spacing: 0;
      padding: 0 3px;
      font-size: 9.5px;
      color: #E0E0E0;
    }

    /* Active label gets bold gold color */
    .qb-sidebar-category.active .qb-sidebar-label {
      color: #fff;
      font-weight: 700;
    }

    /* MAIN CONTENT AREA */
    .qb-main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
      min-height: 0;
      overflow: hidden;
    }

    /* HEADER WITH FILTERS & SORT - Fixed at top */
    .qb-collection-header {
      padding: 12px 16px;
      border-bottom: 1px solid #333;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
      flex-wrap: wrap;
      background: #0A0A0A;
      z-index: 99;
      flex-shrink: 0;
    }

    /* PRODUCT GRID WRAPPER - Only this scrolls */
    .qb-product-grid-wrapper {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      min-width: 0;
      min-height: 0;
      background: #0A0A0A;
    }

    .qb-collection-title {
      font-size: 17px;
      font-weight: 800;
      color: #FFFFFF;
      margin: 0;
      width: 100%;
      letter-spacing: 0.3px;
      text-transform: uppercase;
    }

    .qb-header-controls {
      display: flex;
      gap: 8px;
      align-items: center;
      width: 100%;
    }

    .qb-sort-select {
      padding: 8px 12px;
      border: 1.5px solid #333;
      border-radius: 8px;
      background: #1A1A1A;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
      color: #E0E0E0;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
      width: 100%;
      min-height: 38px;
      appearance: auto;
    }

    .qb-sort-select:focus {
      outline: none;
      border-color: var(--qb-gold);
      box-shadow: 0 0 0 3px rgba(244,180,0,0.12);
    }

    .qb-sort-select:hover {
      border-color: #444;
    }

    /* PRODUCT GRID - Mobile: Strictly 2 columns */
    .qb-product-grid {
      padding: 8px;
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 8px;
      width: 100%;
      background: #0A0A0A;
    }

    .qb-product-card {
      background: #1E1E1E;
      border-radius: 12px;
      padding: 0;
      display: flex;
      flex-direction: column;
      border: 1px solid #333;
      overflow: hidden;
      height: 100%;
      position: relative;
    }

    .qb-product-image-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1;
      background: #121212;
      overflow: hidden;
      margin: 0;
      display: block;
    }

    .qb-product-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .qb-delivery-badge {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 70%, transparent 100%);
      color: #fff;
      padding: 24px 8px 6px;
      font-size: 10px;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 4px;
      z-index: 10;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .qb-product-name {
      font-size: 12px;
      font-weight: 600;
      color: #FFFFFF;
      line-height: 1.3;
      margin: 0;
      padding: 8px 10px 0 10px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .qb-product-price {
      font-size: 15px;
      font-weight: 900;
      color: #F4B400;
      margin: 4px 0 0 0;
      padding: 0 10px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .qb-product-compare-price {
      font-size: 11px;
      font-weight: 500;
      color: #777;
      text-decoration: line-through;
    }

    .qb-quantity-control {
      display: flex;
      align-items: center;
      background: #1A1A1A;
      border: 1px solid #333;
      border-radius: 8px;
      overflow: hidden;
      width: calc(100% - 16px);
      height: 32px;
      margin: 8px 8px 0;
    }

    .qb-qty-btn {
      flex: 0 0 32px;
      height: 100%;
      border: none;
      background: #252525;
      color: #fff;
      cursor: pointer;
      font-size: 16px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .qb-qty-input {
      flex: 1;
      height: 100%;
      border: none;
      border-left: 1px solid #333;
      border-right: 1px solid #333;
      text-align: center;
      font-size: 13px;
      font-weight: 700;
      color: #fff;
      background: #1A1A1A;
      padding: 0;
      margin: 0;
    }

    .qb-add-btn {
      width: calc(100% - 16px);
      background: #C41E3A !important;
      color: white !important;
      border: none !important;
      border-radius: 8px;
      padding: 8px 10px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      min-height: 36px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin: 6px 8px 10px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.3);
    }

    .qb-add-btn:hover {
      background: #A01830 !important;
      transform: translateY(-1px);
    }

    .qb-add-btn:active {
      transform: translateY(0);
      opacity: 0.9;
    }

    /* Dark mode support for collection buttons */
    @media (prefers-color-scheme: dark) {
      .qb-add-btn {
        background: #1a1a1a !important;
        color: white !important;
        border: none !important;
        color-scheme: light !important;
      }

      .qb-add-btn:active {
        background: #000000 !important;
        color: white !important;
      }
    }

    /* TABLET: 768px and up - 3 column grid */
    @media (min-width: 768px) {
      .qb-collection-header {
        padding: 16px 24px;
      }

      .qb-collection-title {
        font-size: 22px;
      }

      .qb-product-grid {
        padding: 18px;
        gap: 16px;
        grid-template-columns: repeat(3, 1fr) !important;
      }

      .qb-sidebar-category {
        min-height: 80px;
      }

      .qb-sidebar-img-wrap {
        width: 48px;
        height: 48px;
      }

      .qb-sidebar-icon {
        width: 48px;
        height: 48px;
      }

      .qb-product-name {
        font-size: 13px;
        line-height: 1.3;
      }

      .qb-product-price {
        font-size: 15px;
        margin: 3px 0 5px 0;
      }

      .qb-delivery-badge {
        font-size: 10px;
      }

      .qb-add-btn {
        min-height: 36px;
        font-size: 12px;
        padding: 8px 10px;
      }
    }

    /* DESKTOP: 1024px and up - vertical sidebar, 4 column grid */
    @media (min-width: 1024px) {
      :root {
        --qb-sidebar-w: 100px;
      }

      .qb-collection-container {
        flex-direction: row;
      }

      .qb-sidebar {
        position: fixed;
        top: 140px;
        bottom: 65px;
        width: var(--qb-sidebar-w);
        flex-direction: column;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 8px 0 0;
        gap: 2px;
      }

      .qb-sidebar-category {
        width: 100%;
        flex-shrink: 0;
        padding: 12px 8px 12px 12px;
        font-size: 10px;
        gap: 6px;
        min-height: 84px;
      }

      .qb-sidebar-img-wrap {
        width: 52px;
        height: 52px;
      }

      .qb-sidebar-icon {
        width: 52px;
        height: 52px;
      }

      .qb-collection-header {
        padding: 16px 24px;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .qb-collection-title {
        font-size: 24px;
      }

      .qb-header-controls {
        width: auto;
        gap: 12px;
      }

      .qb-filter-btn, .qb-sort-select {
        padding: 8px 12px;
        font-size: 14px;
        flex: none;
        min-height: auto;
      }

      .qb-product-grid {
        padding: 20px;
        grid-template-columns: repeat(4, 1fr) !important;
        gap: 16px;
      }

      .qb-product-card {
        padding: 12px;
        gap: 9px;
      }

      .qb-product-image-wrap {
        margin-bottom: 2px;
      }

      .qb-delivery-badge {
        font-size: 11px;
      }

      .qb-product-name {
        font-size: 14px;
        min-height: 26px;
        line-height: 1.3;
      }

      .qb-product-price {
        font-size: 16px;
        margin: 3px 0 5px 0;
      }

      .qb-add-btn {
        padding: 10px 12px;
        font-size: 13px;
        min-height: 38px;
      }

      .qb-product-grid:empty::after {
        content: 'No products available';
        grid-column: 1 / -1;
        padding: 40px;
        text-align: center;
        color: #999;
      }
    }
  </style>

  <!-- SIDEBAR CATEGORIES - Connected to Shopify Collections -->
  <aside class="qb-sidebar" id="category-sidebar">
    {% paginate collections by 100 %}
      {% for col in collections %}
        {% unless col.handle == 'all' %}
          <a href="/collections/{{ col.handle }}" class="qb-sidebar-category{% if collection.handle == col.handle %} active{% endif %}" data-collection-handle="{{ col.handle }}" data-collection-title="{{ col.title }}" data-collection-url="{{ col.url }}" title="{{ col.title }}">
            <div class="qb-sidebar-img-wrap">
              {% if col.featured_image %}
                <img src="{{ col.featured_image | img_url: '80x80' }}" alt="{{ col.title }}" style="width: 100%; height: 100%; object-fit: cover;">
              {% else %}
                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 22px; background: #121212;">📦</div>
              {% endif %}
            </div>
            <div class="qb-sidebar-label">{{ col.title | truncate: 16, '' }}</div>
          </a>
        {% endunless %}
      {% endfor %}
    {% endpaginate %}
  </aside>

  <!-- MAIN CONTENT -->
  <div class="qb-main-content">
    <!-- HEADER WITH FILTERS & SORT -->
    <div class="qb-collection-header">
      <h1 class="qb-collection-title">{{ current_collection.title | default: 'Shop by Collection' }}</h1>
      <div class="qb-header-controls">
        <select class="qb-sort-select" id="product-sort">
          <option value="">Sort by</option>
          <option value="price-asc">Price: Low to High</option>
          <option value="price-desc">Price: High to Low</option>
        </select>
      </div>
    </div>

    <!-- PRODUCT GRID WRAPPER - Only this scrolls -->
    <div class="qb-product-grid-wrapper">
      <!-- PRODUCT GRID - Shows products from current collection ONLY -->
      <div class="qb-product-grid" id="product-grid">
      {% assign current_collection = collection %}

      {% if current_collection and current_collection.products.size > 0 %}
        {% for product in current_collection.products limit: 50 %}
          <div class="qb-product-card">
            <div class="qb-product-image-wrap" style="cursor: pointer;" data-product-url="{{ product.url }}">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '1080x1080', crop: 'center' }}" alt="{{ product.title }}" class="qb-product-image" style="cursor: pointer;">
              {% else %}
                <div style="width:100%; height:100%; background:#121212; display:flex; align-items:center; justify-content:center; color:#999;">No Image</div>
              {% endif %}
              <div class="qb-delivery-badge qb-collection-delivery-badge"><span class="badge-icon">⚡</span><span class="badge-time qb-delivery-time-text">18-22 mins</span></div>
            </div>
            <h3 class="qb-product-name">{{ product.title }}</h3>
            <div class="qb-product-price">
              <span>Rs {{ product.price | divided_by: 100 }}</span>
              {% if product.compare_at_price > product.price %}
                <span class="qb-product-compare-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
              {% endif %}
            </div>
            <form action="/cart/add" method="post" class="product-form">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <div class="qb-quantity-control">
                <button type="button" class="qb-qty-btn qb-qty-minus">−</button>
                <input type="number" name="quantity" class="qb-qty-input" value="1" min="1" max="999">
                <button type="button" class="qb-qty-btn qb-qty-plus">+</button>
              </div>
              <button type="submit" class="qb-add-btn">ADD TO CART</button>
            </form>
          </div>
        {% endfor %}
      {% else %}
        <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
          <p>No products available</p>
        </div>
      {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    // Helper to get delivery range reliably from window or localStorage
    function getDeliveryRange() {
      let range = '';
      if (window.QB_DELIVERY_TIME?.range) {
        range = window.QB_DELIVERY_TIME.range;
      } else {
        try {
          const stored = localStorage.getItem('qb_delivery_time');
          if (stored) {
            const obj = JSON.parse(stored);
            if (obj.range) range = obj.range;
          }
        } catch (e) {}
      }

      // Default fallback
      if (!range) range = '18-22 mins';

      // Extract single time from range (e.g., "23-27 mins" → "25 mins")
      const match = range.match(/(\d+)-(\d+)\s*(mins?)/);
      if (match) {
        const min = parseInt(match[1]);
        const max = parseInt(match[2]);
        const avg = Math.round((min + max) / 2);
        return avg + ' ' + match[3];
      }

      return range;
    }

    const sidebar = document.getElementById('category-sidebar');
    const productGrid = document.getElementById('product-grid');
    const collectionTitle = document.querySelector('.qb-collection-title');

    // Initialize delivery badges on page load
    function initializeDeliveryBadges() {
      const range = getDeliveryRange();
      const badges = document.querySelectorAll('.qb-collection-delivery-badge, .qb-delivery-badge');
      badges.forEach(badge => {
        badge.textContent = '⚡ ' + range;
      });
    }

    // Initialize on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeDeliveryBadges);
    } else {
      initializeDeliveryBadges();
    }

    // Handle collection clicks for dynamic loading
    document.querySelectorAll('.qb-sidebar-category').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();

        const collectionHandle = this.dataset.collectionHandle;
        const collectionTitle = this.dataset.collectionTitle;

        // Update URL without page reload
        const newUrl = `/collections/${collectionHandle}`;
        window.history.pushState({ collection: collectionHandle }, collectionTitle, newUrl);

        // Update active state
        document.querySelectorAll('.qb-sidebar-category').forEach(l => l.classList.remove('active'));
        this.classList.add('active');

        // Update header title
        document.querySelector('.qb-collection-title').textContent = collectionTitle;

        // Load products from the collection using JSON API
        loadCollectionProducts(collectionHandle);
      });
    });

    function loadCollectionProducts(collectionHandle) {
      console.log('Loading collection:', collectionHandle);

      // Show loading state
      productGrid.innerHTML = `
        <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
          <p>Loading products...</p>
        </div>
      `;

      // Fetch the collection page to get properly filtered products from Shopify's server-side rendering
      fetch(`/collections/${collectionHandle}`)
        .then(response => {
          console.log('Response status:', response.status, response.ok);
          if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
          return response.text();
        })
        .then(html => {
          console.log('Fetched collection page HTML');

          // Parse HTML to extract product grid
          const tempDiv = document.createElement('div');
          tempDiv.innerHTML = html;

          // Find the product grid in the fetched HTML
          const fetchedProductGrid = tempDiv.querySelector('#product-grid');

          if (fetchedProductGrid && fetchedProductGrid.innerHTML.trim() !== '') {
            console.log('Found product grid in fetched HTML');

            // Replace current grid with fetched products
            productGrid.innerHTML = fetchedProductGrid.innerHTML;

            // Process badges in fetched HTML to ensure they have our update classes
            const currentDelivery = window.QB_DELIVERY_TIME?.range || '18-22 mins';
            const allBadges = productGrid.querySelectorAll('[class*="mins"], [class*="badge"]');
            allBadges.forEach(badge => {
              const text = badge.textContent || '';
              if (text.includes('mins') || text.includes('delivery')) {
                badge.classList.add('qb-delivery-badge');
                badge.classList.add('qb-sync-badge');
                badge.innerHTML = '⚡ ' + currentDelivery;
              }
            });

            // Re-attach event listeners to newly loaded products
            attachProductListeners();
          } else {
            console.log('No products found in collection');
            productGrid.innerHTML = `
              <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
                <p>No products available</p>
              </div>
            `;
          }
        })
        .catch(err => {
          console.error('Error loading collection:', err);
          productGrid.innerHTML = `
            <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
              <p>Error loading products. Please try again.</p>
            </div>
          `;
        });
    }

    function createProductCard(product) {
      const card = document.createElement('div');
      card.className = 'qb-product-card';

      // Get featured image
      const featuredImage = product.featured_image ? product.featured_image.src : null;
      const productImage = featuredImage
        ? `<img src="${featuredImage}?width=1080&height=1080&crop=center" alt="${product.title}" class="qb-product-image">`
        : '<div style="width:100%; height:100%; background:#121212; display:flex; align-items:center; justify-content:center; color:#999;">No Image</div>';

      // Get first variant ID for add to cart
      const variantId = product.variants && product.variants.length > 0 ? product.variants[0].id : '';

      // Format price in Rupees (divide by 100 for paise conversion)
      const price = Math.floor(product.price / 100);
      const comparePrice = product.compare_at_price ? Math.floor(product.compare_at_price / 100) : null;
      const comparePriceHTML = (comparePrice && comparePrice > price) 
        ? `<span class="qb-product-compare-price">Rs ${comparePrice}</span>` 
        : '';

      // Get product URL - construct from handle if not available
      const productUrl = product.url || `/products/${product.handle}`;

      const deliveryRange = getDeliveryRange();
      card.innerHTML = `
        <div class="qb-product-image-wrap" style="cursor: pointer;" data-product-url="${productUrl}">
          ${productImage}
          <div class="qb-delivery-badge qb-sync-badge"><span class="badge-icon">⚡</span><span class="badge-time qb-delivery-time-text">${deliveryRange}</span></div>
        </div>
        <h3 class="qb-product-name">${product.title}</h3>
        <div class="qb-product-price">
          <span>Rs ${price}</span>
          ${comparePriceHTML}
        </div>
        <form action="/cart/add" method="post" class="product-form">
          <input type="hidden" name="id" value="${variantId}">
          <div class="qb-quantity-control">
            <button type="button" class="qb-qty-btn qb-qty-minus">−</button>
            <input type="number" name="quantity" class="qb-qty-input" value="1" min="1" max="999">
            <button type="button" class="qb-qty-btn qb-qty-plus">+</button>
          </div>
          <button type="submit" class="qb-add-btn">ADD TO CART</button>
        </form>
      `;

      return card;
    }

    function attachProductListeners() {
      // Product image click - navigate to product page
      document.querySelectorAll('.qb-product-image-wrap').forEach(imageWrap => {
        imageWrap.removeEventListener('click', productImageClickHandler);
        imageWrap.addEventListener('click', productImageClickHandler);
      });

      // Quantity controls
      document.querySelectorAll('.qb-qty-minus').forEach(btn => {
        btn.removeEventListener('click', decreaseQty);
        btn.addEventListener('click', decreaseQty);
      });

      document.querySelectorAll('.qb-qty-plus').forEach(btn => {
        btn.removeEventListener('click', increaseQty);
        btn.addEventListener('click', increaseQty);
      });

      document.querySelectorAll('.qb-qty-input').forEach(input => {
        input.removeEventListener('change', validateQtyInput);
        input.addEventListener('change', validateQtyInput);
      });

      // Add to cart logic
      document.querySelectorAll('.product-form').forEach(form => {
        form.removeEventListener('submit', addToCartHandler);
        form.addEventListener('submit', addToCartHandler);
      });
    }

    function decreaseQty(e) {
      e.preventDefault();
      const input = this.parentElement.querySelector('.qb-qty-input');
      const currentValue = parseInt(input.value) || 1;
      if (currentValue > 1) {
        input.value = currentValue - 1;
      }
    }

    function increaseQty(e) {
      e.preventDefault();
      const input = this.parentElement.querySelector('.qb-qty-input');
      const currentValue = parseInt(input.value) || 1;
      const maxValue = parseInt(input.max) || 999;
      if (currentValue < maxValue) {
        input.value = currentValue + 1;
      }
    }

    function validateQtyInput(e) {
      let value = parseInt(this.value) || 1;
      const min = parseInt(this.min) || 1;
      const max = parseInt(this.max) || 999;

      if (value < min) value = min;
      if (value > max) value = max;

      this.value = value;
    }

    function productImageClickHandler(e) {
      const productUrl = this.dataset.productUrl;
      if (productUrl) {
        window.location.href = productUrl;
      }
    }

    function addToCartHandler(e) {
      // Allow normal form submission to /cart/add with default quantity of 1
      // The form will handle the POST request naturally
      const qtyInput = document.createElement('input');
      qtyInput.type = 'hidden';
      qtyInput.name = 'quantity';
      qtyInput.value = '1';
      this.appendChild(qtyInput);
    }

    // Auto-load collection from URL or default to first
    function initializeCollectionFromURL() {
      // Extract collection handle from URL
      const urlPath = window.location.pathname;
      const match = urlPath.match(/\/collections\/([^/?]+)/);
      const collectionHandleFromURL = match ? match[1] : null;

      let categoryToLoad = document.querySelector('.qb-sidebar-category');

      // If URL contains a collection, find and use that instead
      if (collectionHandleFromURL) {
        const urlCategory = document.querySelector(
          `.qb-sidebar-category[data-collection-handle="${collectionHandleFromURL}"]`
        );
        if (urlCategory) {
          categoryToLoad = urlCategory;
        }
      }

      // Load the selected collection
      if (categoryToLoad) {
        categoryToLoad.classList.add('active');
        const collectionHandle = categoryToLoad.dataset.collectionHandle;
        const collectionTitle = categoryToLoad.dataset.collectionTitle;

        // Update the title
        const titleElement = document.querySelector('.qb-collection-title');
        if (titleElement) {
          titleElement.textContent = collectionTitle;
        }

        loadCollectionProducts(collectionHandle);

        // Scroll collection button into view
        setTimeout(() => {
          categoryToLoad.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 100);
      }
    }

    // Initialize on page load
    initializeCollectionFromURL();

    // Initial attachment of listeners
    attachProductListeners();

    // Sort functionality
    const sortSelect = document.getElementById('product-sort');
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        const sortValue = this.value;
        if (!sortValue) return; // No sorting if "Sort by" is selected

        const products = Array.from(document.querySelectorAll('.qb-product-card'));

        // Sort products based on selection
        products.sort((a, b) => {
          const priceA = parseInt(a.querySelector('.qb-product-price').textContent.replace(/[^\d]/g, ''));
          const priceB = parseInt(b.querySelector('.qb-product-price').textContent.replace(/[^\d]/g, ''));

          switch(sortValue) {
            case 'price-asc':
              return priceA - priceB;
            case 'price-desc':
              return priceB - priceA;
            default:
              return 0;
          }
        });

        // Re-insert sorted products into the grid
        products.forEach(product => {
          productGrid.appendChild(product);
        });
      });
    }

    // Sync badges when location changes
    window.addEventListener('locationSelected', function(e) {
      console.log('locationSelected event received in collection-sidebar');
      setTimeout(initializeDeliveryBadges, 50);
    });
  })();
</script>
