<!-- Collection Sidebar with Category Navigation -->
<section id="qb-collection-sidebar" class="qb-collection-container">
  <style>
    :root {
      --qb-gold: #F4B400;
      --qb-gold-light: #fff8e1;
      --qb-gold-dim: rgba(244,180,0,0.12);
      --qb-dark: #111111;
      --qb-text-muted: #888;
      --qb-sidebar-w: 84px;
    }

    * {
      box-sizing: border-box;
    }

    /* HIDE PREVIEW BUTTONS GLOBALLY */
    [class*="preview"],
    [id*="preview"],
    [class*="quick-view"],
    [id*="quick-view"],
    .shopify-section__overlay,
    .button-preview,
    .product-preview,
    [data-testid*="preview"],
    [role="tooltip"],
    .tooltip-preview {
      display: none !important;
    }

    /* MOBILE FIRST - Base styles for mobile screens */
    .qb-collection-container {
      display: flex;
      flex-direction: row;
      gap: 0;
      width: 100%;
      /* Use min-height instead of height to allow content to grow naturally */
      min-height: calc(100vh - 65px);
      height: auto;
      background: #0A0A0A;
    }

    /* SIDEBAR - Fixed on left */
    .qb-sidebar {
      position: sticky;
      top: 0; /* Header is in flex layout, not fixed — no offset needed */
      left: 0;
      width: var(--qb-sidebar-w);
      background: #121212;
      border-right: 1px solid #333;
      padding: 8px 0 0;
      overflow-x: hidden;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 0;
      z-index: 100;
      flex-shrink: 0;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      /* Height fills remaining viewport below header */
      max-height: calc(100vh - 65px); /* 65px = mobile footer height */
    }

    .qb-sidebar::-webkit-scrollbar { display: none; }

    /* ── Sidebar Item ── */
    .qb-sidebar-category {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      gap: 6px;
      padding: 12px 4px 10px;
      cursor: pointer;
      text-decoration: none;
      color: #E0E0E0;
      font-size: 9.5px;
      font-weight: 500;
      text-align: center;
      transition: background 0.15s ease, color 0.15s ease;
      border-left: 3px solid transparent;
      border-right: 3px solid transparent;
      flex-shrink: 0;
      width: 100%;
      min-height: 80px;
      position: relative;
      line-height: 1;
    }

    .qb-sidebar-category:hover {
      background: #1E1E1E;
      color: #fff;
    }

    .qb-sidebar-category:hover .qb-sidebar-img-wrap {
      border-color: rgba(244,180,0,0.5);
    }

    /* ── Active state ── */
    .qb-sidebar-category.active {
      background: #1E1E1E;
      color: #fff;
      border-left-color: var(--qb-gold);
      font-weight: 700;
      font-size: 9.5px;
    }

    .qb-sidebar-category.active .qb-sidebar-img-wrap {
      border-color: var(--qb-gold);
      box-shadow: 0 0 0 2px rgba(244,180,0,0.18);
    }

    /* ── Image circle ── */
    .qb-sidebar-img-wrap {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid #333;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
      background: #1A1A1A;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .qb-sidebar-img-wrap img,
    .qb-sidebar-icon img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .qb-sidebar-icon {
      font-size: 24px;
      line-height: 1;
      width: 52px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
    }

    .qb-sidebar-label {
      width: 100%;
      word-break: break-word;
      line-height: 1.3;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      letter-spacing: 0;
      padding: 0 3px;
      font-size: 9.5px;
      color: #E0E0E0;
    }

    /* Active label gets bold gold color */
    .qb-sidebar-category.active .qb-sidebar-label {
      color: #fff;
      font-weight: 700;
    }

    /* MAIN CONTENT AREA */
    .qb-main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
      min-height: 0;
      background: #0A0A0A;
      overflow-x: hidden;
      overflow-y: visible;
    }

    /* HEADER WITH FILTERS & SORT - Fixed at top */
    .qb-collection-header {
      padding: 12px 16px;
      border-bottom: 1px solid #333;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
      flex-wrap: wrap;
      background: #0A0A0A;
      z-index: 99;
      flex-shrink: 0;
    }

    /* PRODUCT GRID WRAPPER - Only this scrolls */
    .qb-product-grid-wrapper {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      min-width: 0;
      min-height: 0;
      background: #0A0A0A;
    }

    .qb-collection-title {
      font-size: 17px;
      font-weight: 800;
      color: #FFFFFF;
      margin: 0;
      width: 100%;
      letter-spacing: 0.3px;
      text-transform: uppercase;
    }

    .qb-header-controls {
      display: flex;
      gap: 8px;
      align-items: center;
      width: 100%;
    }

    .qb-sort-select {
      padding: 8px 12px;
      border: 1.5px solid #333;
      border-radius: 8px;
      background: #1A1A1A;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
      color: #E0E0E0;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
      width: 100%;
      min-height: 38px;
      appearance: auto;
    }

    .qb-sort-select:focus {
      outline: none;
      border-color: var(--qb-gold);
      box-shadow: 0 0 0 3px rgba(244,180,0,0.12);
    }

    .qb-sort-select:hover {
      border-color: #444;
    }

    /* ═══════════════════════════════════
       PRODUCT GRID — 2 column mobile
    ═══════════════════════════════════ */
    .qb-product-grid {
      padding: 10px;
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 10px;
      width: 100%;
      background: transparent;
      align-items: start; /* cards align top, not stretched */
    }

    /* ═══════════════════════════════════
       PRODUCT CARD — Redesigned for Mobile App Experience
    ═══════════════════════════════════ */
    .qb-product-card {
      background: #ffffff;
      border-radius: 16px;
      padding: 0;
      display: flex;
      flex-direction: column;
      box-shadow: 0 4px 16px rgba(0,0,0,0.06);
      border: 1px solid #f0f0f0;
      position: relative;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      overflow: hidden;
      gap: 0;
    }

    /* ── Image section (Full Bleed) ── */
    .qb-card-img-section {
      position: relative;
      cursor: pointer;
      width: 100%;
    }

    .qb-card-img-circle {
      width: 100%;
      aspect-ratio: 1 / 1;
      background: #f8f8f8;
      border-top-left-radius: 16px;
      border-top-right-radius: 16px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .qb-product-image {
      width: 100%;
      height: 100%;
      object-fit: contain; /* Better for grocery/packaged goods */
      padding: 4px;
      display: block;
      transition: transform 0.25s ease;
    }

    .qb-card-img-section:hover .qb-product-image {
      transform: scale(1.04);
    }

    /* ── Product Info Wrapper ── */
    .product-info-wrapper {
      padding: 8px 10px 12px 10px;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    /* ── Delivery time ── */
    .qb-card-delivery {
      font-size: 11px;
      color: #666;
      font-weight: 600;
      margin-bottom: 4px;
      line-height: 1;
    }
    .qb-delivery-time-text { color: #F4B400; }

    /* ── Product name ── */
    .qb-product-name {
      font-size: 13px;
      font-weight: 600;
      color: #1a1a1a;
      line-height: 1.4;
      margin: 0 0 8px 0;
      min-height: 36px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ── Price & Action Row ── */
    .price-action-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: auto;
      gap: 4px;
    }

    .qb-price-column {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .qb-price-row {
      display: flex;
      align-items: baseline;
      gap: 4px;
    }

    .qb-price {
      font-size: 15px;
      font-weight: 800;
      color: #000;
    }

    .qb-compare-price {
      font-size: 11px;
      color: #999;
      text-decoration: line-through;
    }

    .qb-discount-badge {
      font-size: 10px;
      font-weight: 800;
      color: #2e7d32;
      background: #e8f5e9;
      padding: 1px 6px;
      border-radius: 4px;
      width: fit-content;
    }

    /* ── CTA Button ── */
    .qb-card-footer { margin: 0; }

    .qb-add-btn {
      background: transparent !important;
      color: #FF0055 !important;
      border: 1.5px solid #FF0055 !important;
      border-radius: 20px !important;
      padding: 6px 16px !important;
      font-size: 13px !important;
      font-weight: 700 !important;
      cursor: pointer !important;
      transition: all 0.2s ease !important;
      line-height: 1 !important;
      height: auto !important;
      width: auto !important;
      min-height: unset !important;
      text-transform: none !important;
      box-shadow: none !important;
    }

    .qb-add-btn:active {
      transform: scale(0.95) !important;
      background: #FF0055 !important;
      color: #fff !important;
    }

    /* Quantity stepper style update */
    .qb-qty-stepper {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #FF0055;
      border-radius: 20px;
      height: 32px;
      padding: 0 4px;
    }


    .qb-qty-btn {
      background: transparent;
      border: none;
      color: #fff;
      font-size: 22px;
      font-weight: 300;
      width: 36px;
      height: 34px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: background 0.1s;
      padding: 0;
      line-height: 1;
      touch-action: manipulation;
      font-family: inherit;
    }

    .qb-qty-btn:active { background: rgba(0,0,0,0.2); }

    .qb-qty-num {
      color: #fff;
      font-size: 15px;
      font-weight: 800;
      flex: 1;
      text-align: center;
      line-height: 1;
      pointer-events: none;
    }

    /* Hide legacy quantity control */
    .qb-quantity-control { display: none !important; }

    /* TABLET: 768px and up - 3 column grid */
    @media (min-width: 768px) {
      .qb-collection-header { padding: 16px 24px; }
      .qb-collection-title { font-size: 22px; }

      .qb-product-grid {
        padding: 16px;
        gap: 14px;
        grid-template-columns: repeat(3, 1fr) !important;
      }

      .qb-sidebar-category { min-height: 80px; }
      .qb-sidebar-img-wrap { width: 48px; height: 48px; }
      .qb-sidebar-icon { width: 48px; height: 48px; }

      .qb-product-name { font-size: 12px; }
      .qb-price { font-size: 15px; }
      .qb-card-delivery { font-size: 11px; }
    }

    /* DESKTOP: 1024px and up - vertical sidebar, 4 column grid */
    @media (min-width: 1024px) {
      :root {
        --qb-sidebar-w: 100px;
      }

      .qb-collection-container {
        flex-direction: row;
      }

      .qb-sidebar {
        position: sticky;
        top: 0;
        align-self: flex-start;
        height: calc(100vh - 65px);
        width: var(--qb-sidebar-w);
        flex-direction: column;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 8px 0 0;
        gap: 2px;
        flex-shrink: 0;
      }

      .qb-sidebar-category {
        width: 100%;
        flex-shrink: 0;
        padding: 12px 8px 12px 12px;
        font-size: 10px;
        gap: 6px;
        min-height: 84px;
      }

      .qb-sidebar-img-wrap {
        width: 52px;
        height: 52px;
      }

      .qb-sidebar-icon {
        width: 52px;
        height: 52px;
      }

      .qb-collection-header {
        padding: 16px 24px;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .qb-collection-title {
        font-size: 24px;
      }

      .qb-header-controls {
        width: auto;
        gap: 12px;
      }

      .qb-filter-btn, .qb-sort-select {
        padding: 8px 12px;
        font-size: 14px;
        flex: none;
        min-height: auto;
      }

      .qb-product-grid {
        padding: 20px;
        grid-template-columns: repeat(4, 1fr) !important;
        gap: 16px;
      }

      .qb-product-card {
        padding: 0;
        gap: 0;
      }

      .qb-product-image-wrap {
        margin-bottom: 2px;
      }

      .qb-delivery-badge {
        font-size: 11px;
      }

      .qb-product-name {
        font-size: 14px;
        min-height: 26px;
        line-height: 1.3;
      }

      .qb-product-price {
        font-size: 16px;
        margin: 3px 0 5px 0;
      }

      .qb-add-btn {
        padding: 10px 12px;
        font-size: 13px;
        min-height: 38px;
      }

      .qb-product-grid:empty::after {
        content: 'No products available';
        grid-column: 1 / -1;
        padding: 40px;
        text-align: center;
        color: #999;
      }
    }

    /* ═══════════════════════════════════════════
       SIDE CART
    ═══════════════════════════════════════════ */
    .qb-sc-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.55);
      z-index: 8000;
      opacity: 0; pointer-events: none;
      transition: opacity 0.3s ease;
      backdrop-filter: blur(3px);
      -webkit-backdrop-filter: blur(3px);
    }
    .qb-sc-overlay.open { opacity: 1; pointer-events: all; }

    .qb-side-cart {
      position: fixed; top: 0; right: 0;
      width: 380px; max-width: 100vw; height: 100vh;
      background: #fff;
      z-index: 8001;
      transform: translateX(100%);
      transition: transform 0.38s cubic-bezier(0.4,0,0.2,1);
      display: flex; flex-direction: column;
      box-shadow: -8px 0 40px rgba(0,0,0,0.15);
    }
    [data-theme="dark"] .qb-side-cart {
      background: #111; border-left: 1px solid #222;
    }
    .qb-side-cart.open { transform: translateX(0); }

    .qb-sc-header {
      padding: 18px 20px;
      display: flex; justify-content: space-between; align-items: center;
      border-bottom: 1px solid #f0f0f0;
      flex-shrink: 0;
    }
    [data-theme="dark"] .qb-sc-header { border-color: #222; }

    .qb-sc-title {
      font-size: 17px; font-weight: 800; color: #111;
      display: flex; align-items: center; gap: 8px;
    }
    [data-theme="dark"] .qb-sc-title { color: #f0f0f0; }

    .qb-sc-count {
      background: #F4B400; color: #000;
      font-size: 11px; font-weight: 900;
      padding: 2px 8px; border-radius: 20px;
    }

    .qb-sc-close {
      width: 34px; height: 34px; border: none;
      background: #f5f5f5; border-radius: 50%;
      font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s; color: #333;
    }
    .qb-sc-close:hover { background: #ffe082; }
    [data-theme="dark"] .qb-sc-close { background: #222; color: #ccc; }

    .qb-sc-body {
      flex: 1; overflow-y: auto; padding: 14px;
      display: flex; flex-direction: column; gap: 10px;
    }
    .qb-sc-body::-webkit-scrollbar { width: 4px; }
    .qb-sc-body::-webkit-scrollbar-track { background: transparent; }
    .qb-sc-body::-webkit-scrollbar-thumb { background: #ddd; border-radius: 4px; }

    .qb-sc-empty {
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; height: 100%; gap: 10px;
      color: #aaa; font-size: 14px; font-weight: 600;
    }

    .qb-sc-item {
      display: flex; gap: 12px;
      padding: 12px; background: #f9f9f9;
      border-radius: 14px; align-items: center;
      animation: scItemIn 0.25s ease;
    }
    @keyframes scItemIn {
      from { opacity: 0; transform: translateX(16px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    [data-theme="dark"] .qb-sc-item { background: #1a1a1a; }

    .qb-sc-item-img {
      width: 60px; height: 60px; border-radius: 10px;
      object-fit: cover; flex-shrink: 0; background: #eee;
    }
    .qb-sc-item-info { flex: 1; min-width: 0; }
    .qb-sc-item-name {
      font-size: 12px; font-weight: 700; color: #111;
      line-height: 1.4; margin-bottom: 4px;
      display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    [data-theme="dark"] .qb-sc-item-name { color: #f0f0f0; }
    .qb-sc-item-price {
      font-size: 14px; font-weight: 900; color: #F4B400; margin-bottom: 6px;
    }
    .qb-sc-qty-row {
      display: flex; align-items: center; gap: 0;
      background: #fff; border: 1px solid #e0e0e0;
      border-radius: 20px; overflow: hidden; width: fit-content;
    }
    [data-theme="dark"] .qb-sc-qty-row { background: #111; border-color: #333; }
    .qb-sc-qbtn {
      width: 30px; height: 28px; border: none; background: transparent;
      font-size: 18px; font-weight: 300; cursor: pointer; color: #333;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.1s; padding: 0; line-height: 1;
    }
    .qb-sc-qbtn:hover { background: #f0f0f0; }
    [data-theme="dark"] .qb-sc-qbtn { color: #ccc; }
    .qb-sc-qnum {
      font-size: 13px; font-weight: 800; color: #111;
      min-width: 24px; text-align: center; padding: 0 2px;
    }
    [data-theme="dark"] .qb-sc-qnum { color: #f0f0f0; }

    .qb-sc-footer {
      padding: 14px 18px 20px; border-top: 1px solid #f0f0f0; flex-shrink: 0;
    }
    [data-theme="dark"] .qb-sc-footer { border-color: #222; }
    .qb-sc-total-row {
      display: flex; justify-content: space-between; align-items: baseline;
      margin-bottom: 14px; font-size: 14px; font-weight: 700; color: #555;
    }
    [data-theme="dark"] .qb-sc-total-row { color: #aaa; }
    .qb-sc-total-val { font-size: 22px; font-weight: 900; color: #111; }
    [data-theme="dark"] .qb-sc-total-val { color: #f0f0f0; }
    .qb-sc-checkout-btn {
      width: 100%; height: 52px;
      background: linear-gradient(135deg, #F4B400, #FFD700);
      border: none; border-radius: 14px;
      font-size: 16px; font-weight: 900; color: #000;
      cursor: pointer; transition: all 0.2s; letter-spacing: 0.2px;
    }
    .qb-sc-checkout-btn:hover {
      transform: translateY(-2px); box-shadow: 0 8px 24px rgba(244,180,0,0.4);
    }

    /* ═══════════════════════════════════════════
       ADD TO CART TOAST
    ═══════════════════════════════════════════ */
    .qb-toast {
      position: fixed; bottom: 76px; left: 50%;
      transform: translateX(-50%) translateY(24px);
      z-index: 9000; opacity: 0; pointer-events: none;
      transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s ease;
      width: calc(100% - 32px); max-width: 400px;
    }
    .qb-toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1; pointer-events: all;
    }
    .qb-toast-inner {
      background: #111; color: #fff; border-radius: 18px;
      padding: 12px 14px; display: flex; align-items: center; gap: 12px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    }
    .qb-toast-check {
      width: 36px; height: 36px; background: #22c55e;
      border-radius: 50%; display: flex; align-items: center;
      justify-content: center; font-size: 16px; font-weight: 800;
      flex-shrink: 0; animation: checkPop 0.4s cubic-bezier(0.34,1.56,0.64,1);
    }
    @keyframes checkPop {
      from { transform: scale(0); } to { transform: scale(1); }
    }
    .qb-toast-text { flex: 1; min-width: 0; }
    .qb-toast-title { font-size: 13px; font-weight: 800; margin-bottom: 2px; }
    .qb-toast-name {
      font-size: 11px; color: rgba(255,255,255,0.6); font-weight: 500;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .qb-toast-cta {
      background: #F4B400; color: #000; border: none;
      padding: 8px 14px; border-radius: 10px;
      font-size: 12px; font-weight: 800; cursor: pointer;
      white-space: nowrap; flex-shrink: 0; transition: background 0.15s;
    }
    .qb-toast-cta:hover { background: #FFD700; }
  </style>

  <!-- SIDEBAR CATEGORIES - Connected to Shopify Collections -->
  <aside class="qb-sidebar" id="category-sidebar">
    {% paginate collections by 100 %}
      {% for col in collections %}
        {% unless col.handle == 'all' %}
          <a href="/collections/{{ col.handle }}" class="qb-sidebar-category{% if collection.handle == col.handle %} active{% endif %}" data-collection-handle="{{ col.handle }}" data-collection-title="{{ col.title }}" data-collection-url="{{ col.url }}" title="{{ col.title }}">
            <div class="qb-sidebar-img-wrap">
              {% if col.featured_image %}
                <img src="{{ col.featured_image | img_url: '80x80' }}" alt="{{ col.title }}" style="width: 100%; height: 100%; object-fit: cover;">
              {% else %}
                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 22px; background: #121212;">📦</div>
              {% endif %}
            </div>
            <div class="qb-sidebar-label">{{ col.title | truncate: 16, '' }}</div>
          </a>
        {% endunless %}
      {% endfor %}
    {% endpaginate %}
  </aside>

  <!-- MAIN CONTENT -->
  <div class="qb-main-content">
    <!-- HEADER WITH FILTERS & SORT -->
    <div class="qb-collection-header">
      <h1 class="qb-collection-title">{{ current_collection.title | default: 'Shop by Collection' }}</h1>
      <div class="qb-header-controls">
        <select class="qb-sort-select" id="product-sort">
          <option value="">Sort by</option>
          <option value="price-asc">Price: Low to High</option>
          <option value="price-desc">Price: High to Low</option>
        </select>
      </div>
    </div>

    <!-- PRODUCT GRID WRAPPER - Only this scrolls -->
    <div class="qb-product-grid-wrapper">
      <!-- PRODUCT GRID - Shows products from current collection ONLY -->
      <div class="qb-product-grid" id="product-grid">
      {% assign current_collection = collection %}

      {% if current_collection and current_collection.products.size > 0 %}
        {% for product in current_collection.products limit: 50 %}
          {%- comment -%}Extract size tag from product tags{%- endcomment -%}
          {%- assign size_tag = '' -%}
          {%- for tag in product.tags -%}
            {%- assign tag_up = tag | upcase -%}
            {%- if tag_up contains 'ML' or tag_up contains 'LTR' or tag_up == '1L' or tag_up == '2L' or tag_up == '3L' -%}
              {%- assign size_tag = tag_up -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if size_tag == '' -%}
            {%- assign v_title = product.variants.first.title | upcase -%}
            {%- if v_title != 'DEFAULT TITLE' -%}{%- assign size_tag = v_title -%}{%- endif -%}
          {%- endif -%}
          {%- comment -%}Discount %{%- endcomment -%}
          {%- assign disc_pct = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign diff = product.compare_at_price | minus: product.price -%}
            {%- assign disc_pct = diff | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}

          <div class="qb-product-card">

            <!-- IMAGE -->
            <div class="qb-card-img-section" data-product-url="{{ product.url }}">
              <div class="qb-card-img-circle">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}" alt="{{ product.title }}" class="qb-product-image" loading="lazy">
                {% else %}
                  <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:28px;">📦</div>
                {% endif %}
              </div>
              {% if size_tag != '' %}<span class="qb-vol-badge">{{ size_tag }}</span>{% endif %}
            </div>

            <div class="product-info-wrapper">
              <!-- DELIVERY -->
              <div class="qb-card-delivery qb-collection-delivery-badge">⚡ <span class="qb-delivery-time-text">18-22 mins</span></div>

              <!-- NAME -->
              <h3 class="qb-product-name">{{ product.title }}</h3>

              <div class="price-action-row">
                <div class="qb-price-column">
                  <!-- PRICE -->
                  <div class="qb-price-row">
                    <span class="qb-price">Rs {{ product.price | divided_by: 100 }}</span>
                    {% if product.compare_at_price > product.price %}
                      <span class="qb-compare-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                    {% endif %}
                  </div>
                  {% if disc_pct > 0 %}<span class="qb-discount-badge">{{ disc_pct }}% OFF</span>{% endif %}
                </div>

                <!-- CTA -->
                <div class="qb-card-footer">
                  <form action="/cart/add" method="post" class="product-form">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="button" class="qb-add-btn">+ Add</button>
                  </form>
                </div>
              </div>
            </div>

          </div>
        {% endfor %}
      {% else %}
        <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
          <p>No products available</p>
        </div>
      {% endif %}
      </div>
    </div>
  </div>
</section>

<!-- SIDE CART OVERLAY -->
<div id="qb-sc-overlay" class="qb-sc-overlay" onclick="qbCloseCart()"></div>

<!-- SIDE CART PANEL -->
<div id="qb-side-cart" class="qb-side-cart">
  <div class="qb-sc-header">
    <div class="qb-sc-title">🛒 Cart <span id="qb-sc-count" class="qb-sc-count">0</span></div>
    <button class="qb-sc-close" onclick="qbCloseCart()">✕</button>
  </div>
  <div class="qb-sc-body" id="qb-sc-body">
    <div class="qb-sc-empty"><div style="font-size:48px">🛒</div><div>Your cart is empty</div></div>
  </div>
  <div class="qb-sc-footer" id="qb-sc-footer" style="display:none">
    <div class="qb-sc-total-row">
      <span>Total</span>
      <span class="qb-sc-total-val">Rs <span id="qb-sc-total">0</span></span>
    </div>
    <button class="qb-sc-checkout-btn" onclick="location.href='/cart'">View Cart & Checkout →</button>
  </div>
</div>

<!-- ADD TO CART TOAST -->
<div id="qb-toast" class="qb-toast">
  <div class="qb-toast-inner">
    <div class="qb-toast-check">✓</div>
    <div class="qb-toast-text">
      <div class="qb-toast-title">Added to cart!</div>
      <div id="qb-toast-name" class="qb-toast-name">Item</div>
    </div>
    <button class="qb-toast-cta" onclick="qbOpenCart()">View Cart →</button>
  </div>
</div>


<script>
  (function() {
    // Helper to get delivery range reliably from window or localStorage
    function getDeliveryRange() {
      let range = '';
      if (window.QB_DELIVERY_TIME?.range) {
        range = window.QB_DELIVERY_TIME.range;
      } else {
        try {
          const stored = localStorage.getItem('qb_delivery_time');
          if (stored) {
            const obj = JSON.parse(stored);
            if (obj.range) range = obj.range;
          }
        } catch (e) {}
      }

      // Default fallback
      if (!range) range = '18-22 mins';

      // Extract single time from range (e.g., "23-27 mins" → "25 mins")
      const match = range.match(/(\d+)-(\d+)\s*(mins?)/);
      if (match) {
        const min = parseInt(match[1]);
        const max = parseInt(match[2]);
        const avg = Math.round((min + max) / 2);
        return avg + ' ' + match[3];
      }

      return range;
    }

    const sidebar = document.getElementById('category-sidebar');
    const productGrid = document.getElementById('product-grid');
    const collectionTitle = document.querySelector('.qb-collection-title');

    // Initialize delivery badges on page load
    function initializeDeliveryBadges() {
      const range = getDeliveryRange();
      const badges = document.querySelectorAll('.qb-collection-delivery-badge, .qb-delivery-badge');
      badges.forEach(badge => {
        badge.textContent = '⚡ ' + range;
      });
    }

    // Initialize on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeDeliveryBadges);
    } else {
      initializeDeliveryBadges();
    }

    // Handle collection clicks for dynamic loading
    document.querySelectorAll('.qb-sidebar-category').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();

        const collectionHandle = this.dataset.collectionHandle;
        const collectionTitle = this.dataset.collectionTitle;

        // Update URL without page reload
        const newUrl = `/collections/${collectionHandle}`;
        window.history.pushState({ collection: collectionHandle }, collectionTitle, newUrl);

        // Update active state
        document.querySelectorAll('.qb-sidebar-category').forEach(l => l.classList.remove('active'));
        this.classList.add('active');

        // Update header title
        document.querySelector('.qb-collection-title').textContent = collectionTitle;

        // Load products from the collection using JSON API
        loadCollectionProducts(collectionHandle);
      });
    });

    function loadCollectionProducts(collectionHandle) {
      console.log('Loading collection:', collectionHandle);

      // Show loading state
      productGrid.innerHTML = `
        <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
          <p>Loading products...</p>
        </div>
      `;

      // Fetch the collection page to get properly filtered products from Shopify's server-side rendering
      fetch(`/collections/${collectionHandle}`)
        .then(response => {
          console.log('Response status:', response.status, response.ok);
          if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
          return response.text();
        })
        .then(html => {
          console.log('Fetched collection page HTML');

          // Parse HTML to extract product grid
          const tempDiv = document.createElement('div');
          tempDiv.innerHTML = html;

          // Find the product grid in the fetched HTML
          const fetchedProductGrid = tempDiv.querySelector('#product-grid');

          if (fetchedProductGrid && fetchedProductGrid.innerHTML.trim() !== '') {
            console.log('Found product grid in fetched HTML');

            // Replace current grid with fetched products
            productGrid.innerHTML = fetchedProductGrid.innerHTML;

            // Process badges in fetched HTML to ensure they have our update classes
            const currentDelivery = window.QB_DELIVERY_TIME?.range || '18-22 mins';
            const allBadges = productGrid.querySelectorAll('[class*="mins"], [class*="badge"]');
            allBadges.forEach(badge => {
              const text = badge.textContent || '';
              if (text.includes('mins') || text.includes('delivery')) {
                badge.classList.add('qb-delivery-badge');
                badge.classList.add('qb-sync-badge');
                badge.innerHTML = '⚡ ' + currentDelivery;
              }
            });

            // Re-attach event listeners to newly loaded products
            attachProductListeners();
          } else {
            console.log('No products found in collection');
            productGrid.innerHTML = `
              <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
                <p>No products available</p>
              </div>
            `;
          }
        })
        .catch(err => {
          console.error('Error loading collection:', err);
          productGrid.innerHTML = `
            <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
              <p>Error loading products. Please try again.</p>
            </div>
          `;
        });
    }

    function createProductCard(product) {
      const card = document.createElement('div');
      card.className = 'qb-product-card';

      // Image
      const featuredImage = product.featured_image ? product.featured_image.src : null;
      const productImage = featuredImage
        ? `<img src="${featuredImage}?width=400&height=400&crop=center" alt="${product.title}" class="qb-product-image" loading="lazy">`
        : '<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:28px;">📦</div>';

      // Size/volume badge — look in tags first
      let sizeTag = '';
      if (product.tags) {
        const tags = Array.isArray(product.tags) ? product.tags : product.tags.split(', ');
        const sizeMatch = tags.find(t => /ml|ltr|^\d+l$/i.test(t.trim()));
        if (sizeMatch) sizeTag = sizeMatch.trim().toUpperCase();
      }
      if (!sizeTag && product.variants && product.variants[0]) {
        const vt = product.variants[0].title;
        if (vt && vt.toLowerCase() !== 'default title') sizeTag = vt.toUpperCase();
      }
      const volBadge = sizeTag ? `<span class="qb-vol-badge">${sizeTag}</span>` : '';

      // Variant
      const variantId = product.variants && product.variants.length > 0 ? product.variants[0].id : '';

      // Prices
      const price = Math.floor(product.price / 100);
      const comparePrice = product.compare_at_price ? Math.floor(product.compare_at_price / 100) : null;
      const comparePriceHTML = (comparePrice && comparePrice > price)
        ? `<span class="qb-compare-price">Rs ${comparePrice}</span>` : '';
      let discountHTML = '';
      if (comparePrice && comparePrice > price) {
        const pct = Math.round((comparePrice - price) * 100 / comparePrice);
        if (pct > 0) discountHTML = `<span class="qb-discount-badge">${pct}% OFF</span>`;
      }

      const productUrl = product.url || `/products/${product.handle}`;
      const deliveryRange = getDeliveryRange();

      card.innerHTML = `
        <div class="qb-card-img-section" data-product-url="${productUrl}" style="cursor:pointer;">
          <div class="qb-card-img-circle">${productImage}</div>
          ${volBadge}
        </div>
        <div class="product-info-wrapper">
          <div class="qb-card-delivery qb-sync-badge">⚡ <span class="qb-delivery-time-text">${deliveryRange}</span></div>
          <h3 class="qb-product-name">${product.title}</h3>
          <div class="price-action-row">
            <div class="qb-price-column">
              <div class="qb-price-row">
                <span class="qb-price">Rs ${price}</span>
                ${comparePriceHTML}
              </div>
              ${discountHTML}
            </div>
            <div class="qb-card-footer">
              <form action="/cart/add" method="post" class="product-form">
                <input type="hidden" name="id" value="${variantId}">
                <input type="hidden" name="quantity" value="1">
                <button type="button" class="qb-add-btn">+ Add</button>
              </form>
            </div>
          </div>
        </div>
      `;

      return card;
    }

    function attachProductListeners() {
      // Image section click → navigate to product page
      document.querySelectorAll('.qb-card-img-section').forEach(section => {
        section.removeEventListener('click', productImageClickHandler);
        section.addEventListener('click', productImageClickHandler);
      });

      // "+ Add" button → add to cart + show toast + update side cart
      document.querySelectorAll('.qb-add-btn').forEach(btn => {
        btn.replaceWith(btn.cloneNode(true));
      });
      document.querySelectorAll('.qb-add-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          if (this.dataset.adding) return;
          const form = this.closest('.product-form');
          const variantId = form?.querySelector('input[name="id"]')?.value;
          const productName = this.closest('.qb-product-card')?.querySelector('.qb-product-name')?.textContent?.trim() || 'Item';
          if (!variantId) return;

          this.dataset.adding = '1';
          const original = this.textContent;
          this.textContent = '✓';
          this.style.background = '#22c55e';
          this.style.color = '#fff';
          this.style.borderColor = '#22c55e';

          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: variantId, quantity: 1 })
          })
          .then(r => r.json())
          .then(() => {
            updateCartCount();
            qbShowToast(productName);
            setTimeout(() => {
              this.textContent = original;
              this.style.background = '';
              this.style.color = '';
              this.style.borderColor = '';
              delete this.dataset.adding;
            }, 1400);
          })
          .catch(() => {
            this.textContent = original;
            this.style.background = '';
            this.style.color = '';
            this.style.borderColor = '';
            delete this.dataset.adding;
          });
        });
      });
    }

    /* ═══════════════════════════════════════
       SIDE CART FUNCTIONS
    ═══════════════════════════════════════ */
    window.qbOpenCart = function() {
      document.getElementById('qb-side-cart')?.classList.add('open');
      document.getElementById('qb-sc-overlay')?.classList.add('open');
      document.documentElement.style.overflow = 'hidden';
      qbLoadCart();
    }
    window.qbCloseCart = function() {
      document.getElementById('qb-side-cart')?.classList.remove('open');
      document.getElementById('qb-sc-overlay')?.classList.remove('open');
      document.documentElement.style.overflow = '';
    }
    function qbLoadCart() {
      fetch('/cart.js').then(r => r.json()).then(qbRenderCart).catch(console.error);
    }
    function qbRenderCart(cart) {
      const body = document.getElementById('qb-sc-body');
      const footer = document.getElementById('qb-sc-footer');
      const countEl = document.getElementById('qb-sc-count');
      const totalEl = document.getElementById('qb-sc-total');
      if (countEl) countEl.textContent = cart.item_count;
      if (!body) return;
      if (cart.item_count === 0) {
        body.innerHTML = '<div class="qb-sc-empty"><div style="font-size:48px">🛒</div><div>Your cart is empty</div></div>';
        if (footer) footer.style.display = 'none';
        return;
      }
      if (footer) footer.style.display = '';
      if (totalEl) totalEl.textContent = Math.floor(cart.total_price / 100);
      body.innerHTML = cart.items.map(item => {
        const imgSrc = item.featured_image?.url || item.image || '';
        return `
          <div class="qb-sc-item">
            ${imgSrc ? `<img src="${imgSrc}" alt="${item.title}" class="qb-sc-item-img">` : '<div class="qb-sc-item-img" style="display:flex;align-items:center;justify-content:center;font-size:24px">📦</div>'}
            <div class="qb-sc-item-info">
              <div class="qb-sc-item-name">${item.title}</div>
              <div class="qb-sc-item-price">Rs ${Math.floor(item.final_line_price / 100)}</div>
              <div class="qb-sc-qty-row">
                <button class="qb-sc-qbtn" onclick="qbUpdateQty('${item.key}', ${item.quantity - 1})">−</button>
                <span class="qb-sc-qnum">${item.quantity}</span>
                <button class="qb-sc-qbtn" onclick="qbUpdateQty('${item.key}', ${item.quantity + 1})">+</button>
              </div>
            </div>
          </div>`;
      }).join('');
    }
    window.qbUpdateQty = function(key, qty) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: Math.max(0, qty) })
      }).then(r => r.json()).then(cart => {
        qbRenderCart(cart);
        updateCartCount();
      }).catch(console.error);
    }

    /* ═══════════════════════════════════════
       TOAST FUNCTIONS
    ═══════════════════════════════════════ */
    let _toastTimer = null;
    function qbShowToast(productName) {
      const toast = document.getElementById('qb-toast');
      const nameEl = document.getElementById('qb-toast-name');
      if (!toast) return;
      if (nameEl) nameEl.textContent = productName;
      toast.classList.add('show');
      clearTimeout(_toastTimer);
      _toastTimer = setTimeout(() => toast.classList.remove('show'), 3200);
    }

    function submitCartAdd(form, delta) {
      if (!form) return;
      const variantId = form.querySelector('input[name="id"]')?.value;
      if (!variantId) return;
      const qty = Math.max(1, Math.abs(delta));
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      }).then(r => r.json()).then(() => updateCartCount()).catch(() => {});
    }

    function submitCartRemove(form) {
      if (!form) return;
      const variantId = form.querySelector('input[name="id"]')?.value;
      if (!variantId) return;
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 0 })
      }).then(r => r.json()).then(() => updateCartCount()).catch(() => {});
    }

    function updateCartCount() {
      fetch('/cart.js')
        .then(r => r.json())
        .then(cart => {
          const count = cart.item_count;
          // Hit every possible cart badge selector across the theme
          const selectors = [
            '#cart-count',
            '.cart-count',
            '[data-cart-count]',
            '.cart-count-bubble span',
            '.cart-icon-bubble span',
            '[aria-label*="cart"] .badge',
            '.header__cart-count'
          ];
          selectors.forEach(sel => {
            document.querySelectorAll(sel).forEach(el => {
              el.textContent = count;
              // Show/hide if 0
              el.style.display = count > 0 ? '' : 'none';
            });
          });
        }).catch(() => {});
    }

    function productImageClickHandler(e) {
      const productUrl = this.dataset.productUrl;
      if (productUrl) {
        window.location.href = productUrl;
      }
    }

    function addToCartHandler(e) {
      // Form already contains hidden quantity=1, so we just let it submit naturally.
      // Any additional client-side logic (like toast messages) can go here.
    }

    // Auto-load collection from URL or default to first
    function initializeCollectionFromURL() {
      // Extract collection handle from URL
      const urlPath = window.location.pathname;
      const match = urlPath.match(/\/collections\/([^/?]+)/);
      const collectionHandleFromURL = match ? match[1] : null;

      let categoryToLoad = document.querySelector('.qb-sidebar-category');

      // If URL contains a collection, find and use that instead
      if (collectionHandleFromURL) {
        const urlCategory = document.querySelector(
          `.qb-sidebar-category[data-collection-handle="${collectionHandleFromURL}"]`
        );
        if (urlCategory) {
          categoryToLoad = urlCategory;
        }
      }

      // Load the selected collection
      if (categoryToLoad) {
        categoryToLoad.classList.add('active');
        const collectionHandle = categoryToLoad.dataset.collectionHandle;
        const collectionTitle = categoryToLoad.dataset.collectionTitle;

        // Update the title
        const titleElement = document.querySelector('.qb-collection-title');
        if (titleElement) {
          titleElement.textContent = collectionTitle;
        }

        loadCollectionProducts(collectionHandle);
        // Sidebar always stays at top — no scroll-to-active
      }
    }

    // Initialize on page load
    initializeCollectionFromURL();

    // Initial attachment of listeners
    attachProductListeners();

    // Sort functionality
    const sortSelect = document.getElementById('product-sort');
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        const sortValue = this.value;
        if (!sortValue) return; // No sorting if "Sort by" is selected

        const products = Array.from(document.querySelectorAll('.qb-product-card'));

        // Sort products based on selection
        products.sort((a, b) => {
          const priceA = parseInt(a.querySelector('.qb-product-price').textContent.replace(/[^\d]/g, ''));
          const priceB = parseInt(b.querySelector('.qb-product-price').textContent.replace(/[^\d]/g, ''));

          switch(sortValue) {
            case 'price-asc':
              return priceA - priceB;
            case 'price-desc':
              return priceB - priceA;
            default:
              return 0;
          }
        });

        // Re-insert sorted products into the grid
        products.forEach(product => {
          productGrid.appendChild(product);
        });
      });
    }

    // Sync badges when location changes
    window.addEventListener('locationSelected', function(e) {
      console.log('locationSelected event received in collection-sidebar');
      setTimeout(initializeDeliveryBadges, 50);
    });
  })();
</script>
