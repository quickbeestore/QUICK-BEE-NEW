<!-- Collection Sidebar with Category Navigation -->
<section id="qb-collection-sidebar" class="qb-collection-container">
  <style>
    :root {
      --qb-red: #8B0000;
      --qb-gold: #DAA520;
      --qb-cream: #fff8e1;
      --qb-dark: #111111;
    }

    * {
      box-sizing: border-box;
    }

    /* HIDE PREVIEW BUTTONS GLOBALLY */
    [class*="preview"],
    [id*="preview"],
    [class*="quick-view"],
    [id*="quick-view"],
    .shopify-section__overlay,
    .button-preview,
    .product-preview,
    [data-testid*="preview"],
    [role="tooltip"],
    .tooltip-preview {
      display: none !important;
    }

    /* MOBILE FIRST - Base styles for mobile screens */
    .qb-collection-container {
      display: flex;
      flex-direction: row;
      gap: 0;
      width: 100%;
      height: 100vh;
      background: #fff;
      overflow: hidden;
    }

    /* SIDEBAR - Fixed on left */
    .qb-sidebar {
      position: fixed;
      top: 140px;
      bottom: 65px;
      left: 0;
      width: 80px;
      background: #f9f9f9;
      border-right: 1px solid #eee;
      padding: 8px 0;
      overflow-x: hidden;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 4px;
      z-index: 100;
      flex-shrink: 0;
      -webkit-overflow-scrolling: touch;
    }

    .qb-main-content {
      margin-left: 80px;
    }

    .qb-sidebar-category {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      padding: 8px 6px;
      border-radius: 8px;
      cursor: pointer;
      text-decoration: none;
      color: #666;
      font-size: 9px;
      font-weight: 500;
      text-align: center;
      transition: all 0.2s ease;
      border: 2px solid transparent;
      flex-shrink: 0;
      width: 100%;
      min-height: 80px;
    }

    .qb-sidebar-category:hover {
      background: #f0f0f0;
      color: var(--qb-red);
    }

    .qb-sidebar-category.active {
      background: var(--qb-cream);
      color: var(--qb-red);
      border-color: var(--qb-red);
    }

    .qb-sidebar-icon {
      font-size: 24px;
      line-height: 1;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .qb-sidebar-icon img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 6px;
    }

    .qb-sidebar-label {
      width: 100%;
      word-break: break-word;
      line-height: 1.2;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    /* MAIN CONTENT AREA */
    .qb-main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
      min-height: 0;
      overflow: hidden;
    }

    /* HEADER WITH FILTERS & SORT - Fixed at top */
    .qb-collection-header {
      padding: 12px 16px;
      border-bottom: 1px solid #eee;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
      flex-wrap: wrap;
      background: #fff;
      z-index: 99;
      flex-shrink: 0;
    }

    /* PRODUCT GRID WRAPPER - Only this scrolls */
    .qb-product-grid-wrapper {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      min-width: 0;
      min-height: 0;
    }

    .qb-collection-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--qb-dark);
      margin: 0;
      width: 100%;
    }

    .qb-header-controls {
      display: flex;
      gap: 8px;
      align-items: center;
      width: 100%;
    }

    .qb-sort-select {
      padding: 6px 10px;
      border: 1px solid #ddd;
      border-radius: 4px;
      background: #fff;
      cursor: pointer;
      font-size: 12px;
      color: #333;
      transition: all 0.2s;
      width: 100%;
      min-height: 36px;
    }

    .qb-sort-select:hover {
      border-color: var(--qb-red);
      color: var(--qb-red);
    }

    /* PRODUCT GRID - Mobile: 3 columns */
    .qb-product-grid {
      padding: 12px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      width: 100%;
    }

    .qb-product-card {
      background: #fff;
      border-radius: 6px;
      padding: 8px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      gap: 6px;
      border: 1px solid #f0f0f0;
    }

    .qb-product-card:hover {
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      transform: translateY(-2px);
    }

    .qb-product-image-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 1;
      background: #f5f5f5;
      border-radius: 6px;
      overflow: hidden;
      margin-bottom: 4px;
    }

    .qb-product-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .qb-product-card:hover .qb-product-image {
      transform: scale(1.05);
    }

    .qb-delivery-badge {
      position: absolute;
      top: 4px;
      right: 4px;
      background: var(--qb-red);
      color: white;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 3px;
      z-index: 10;
    }

    .qb-product-name {
      font-size: 12px;
      font-weight: 600;
      color: var(--qb-dark);
      line-height: 1.2;
      min-height: auto;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      text-transform: capitalize;
    }

    .qb-product-price {
      font-size: 13px;
      font-weight: 700;
      color: var(--qb-red);
      letter-spacing: -0.5px;
    }

    .qb-qty-selector {
      display: flex;
      gap: 6px;
      align-items: center;
      margin-top: 4px;
    }

    .qb-qty-btn {
      width: 28px;
      height: 28px;
      border: 1px solid #ddd;
      background: #fff;
      border-radius: 3px;
      cursor: pointer;
      font-size: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      flex-shrink: 0;
      padding: 0;
    }

    .qb-qty-btn:hover {
      border-color: var(--qb-red);
      background: #f9f9f9;
    }

    .qb-qty-btn:active {
      border-color: var(--qb-red);
      color: var(--qb-red);
      background: #fff;
    }

    .qb-qty-input {
      flex: 1;
      text-align: center;
      border: 1px solid #ddd;
      border-radius: 3px;
      padding: 4px 2px;
      font-size: 12px;
      min-height: 28px;
    }

    .qb-qty-input:focus {
      outline: none;
      border-color: var(--qb-red);
      box-shadow: 0 0 0 1px rgba(139, 0, 0, 0.15);
    }

    .qb-add-btn {
      width: 100%;
      background: var(--qb-red) !important;
      color: white !important;
      border: none !important;
      border-radius: 4px;
      padding: 6px 8px;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      min-height: 32px;
      color-scheme: light !important;
      margin-top: auto;
    }

    .qb-add-btn:hover:not(:disabled) {
      background: #6b0000 !important;
      transform: scale(1.02);
    }

    .qb-add-btn:active {
      background: #5a0000 !important;
      transform: scale(0.98);
      color: white !important;
    }

    /* Dark mode support for collection buttons */
    @media (prefers-color-scheme: dark) {
      .qb-add-btn {
        background: var(--qb-red) !important;
        color: white !important;
        border: none !important;
        color-scheme: light !important;
      }

      .qb-add-btn:active {
        background: #6b0000 !important;
        color: white !important;
      }
    }

    /* TABLET: 600px and up - 2 column grid */
    @media (min-width: 600px) {
      .qb-collection-header {
        padding: 14px 20px;
      }

      .qb-collection-title {
        font-size: 20px;
      }

      .qb-product-grid {
        padding: 14px;
        gap: 12px;
        grid-template-columns: repeat(3, 1fr);
      }

      .qb-sidebar-category {
        width: 75px;
        padding: 10px 12px;
      }

      .qb-sidebar-icon {
        font-size: 26px;
        width: 50px;
        height: 50px;
      }

      .qb-product-card {
        padding: 10px;
      }

      .qb-product-name {
        font-size: 13px;
      }

      .qb-product-price {
        font-size: 14px;
      }

      .qb-qty-btn {
        width: 30px;
        height: 30px;
        font-size: 14px;
      }

      .qb-qty-input {
        min-height: 30px;
        font-size: 12px;
      }

      .qb-delivery-badge {
        padding: 4px 8px;
        font-size: 10px;
      }
    }

    /* DESKTOP: 1024px and up - vertical sidebar, 4 column grid */
    @media (min-width: 1024px) {
      .qb-collection-container {
        flex-direction: row;
      }

      .qb-sidebar {
        position: fixed;
        top: 140px;
        bottom: 65px;
        width: 100px;
        flex-direction: column;
        overflow-y: auto;
        overflow-x: hidden;
        border-right: 1px solid #eee;
        border-bottom: none;
        padding: 16px 8px;
        gap: 8px;
      }

      .qb-sidebar-category {
        width: 100%;
        flex-shrink: 0;
        padding: 12px 8px;
        font-size: 11px;
        gap: 6px;
      }

      .qb-sidebar-icon {
        font-size: 28px;
        width: 60px;
        height: 60px;
      }

      .qb-collection-header {
        padding: 16px 24px;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .qb-collection-title {
        font-size: 24px;
      }

      .qb-header-controls {
        width: auto;
        gap: 12px;
      }

      .qb-filter-btn, .qb-sort-select {
        padding: 8px 12px;
        font-size: 14px;
        flex: none;
        min-height: auto;
      }

      .qb-product-grid {
        padding: 20px;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
      }

      .qb-product-card {
        padding: 12px;
        gap: 8px;
      }

      .qb-product-image-wrap {
        margin-bottom: 4px;
      }

      .qb-delivery-badge {
        padding: 5px 8px;
        font-size: 11px;
        top: 6px;
        right: 6px;
      }

      .qb-product-name {
        font-size: 14px;
        min-height: 24px;
      }

      .qb-product-price {
        font-size: 15px;
      }

      .qb-qty-selector {
        gap: 4px;
        margin-top: 4px;
      }

      .qb-qty-btn {
        width: 32px;
        height: 32px;
        min-height: 32px;
        font-size: 14px;
      }

      .qb-qty-input {
        font-size: 13px;
        min-height: 32px;
      }

      .qb-add-btn {
        padding: 8px 10px;
        font-size: 12px;
        min-height: 36px;
      }

      .qb-product-grid:empty::after {
        content: 'No products available';
        grid-column: 1 / -1;
        padding: 40px;
        text-align: center;
        color: #999;
      }
    }
  </style>

  <!-- SIDEBAR CATEGORIES - Connected to Shopify Collections -->
  <aside class="qb-sidebar" id="category-sidebar">
    {% paginate collections by 100 %}
      {% for col in collections %}
        {% unless col.handle == 'all' %}
          <a href="/collections/{{ col.handle }}" class="qb-sidebar-category" data-collection-handle="{{ col.handle }}" data-collection-title="{{ col.title }}" data-collection-url="{{ col.url }}" title="{{ col.title }}">
            <div class="qb-sidebar-icon">
              {% if col.featured_image %}
                <img src="{{ col.featured_image | img_url: '80x80' }}" alt="{{ col.title }}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 6px;">
              {% else %}
                <div style="width: 100%; height: 100%; background: #f5f5f5; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 24px;">📦</div>
              {% endif %}
            </div>
            <div class="qb-sidebar-label">{{ col.title | split: ' ' | first }}</div>
          </a>
        {% endunless %}
      {% endfor %}
    {% endpaginate %}
  </aside>

  <!-- MAIN CONTENT -->
  <div class="qb-main-content">
    <!-- HEADER WITH FILTERS & SORT -->
    <div class="qb-collection-header">
      <h1 class="qb-collection-title">{{ current_collection.title | default: 'Shop by Collection' }}</h1>
      <div class="qb-header-controls">
        <select class="qb-sort-select" id="product-sort">
          <option value="">Sort by</option>
          <option value="price-asc">Price: Low to High</option>
          <option value="price-desc">Price: High to Low</option>
        </select>
      </div>
    </div>

    <!-- PRODUCT GRID WRAPPER - Only this scrolls -->
    <div class="qb-product-grid-wrapper">
      <!-- PRODUCT GRID - Shows products from current collection ONLY -->
      <div class="qb-product-grid" id="product-grid">
      {% assign current_collection = collection %}

      {% if current_collection and current_collection.products.size > 0 %}
        {% for product in current_collection.products limit: 50 %}
          <div class="qb-product-card">
            <div class="qb-product-image-wrap" style="cursor: pointer;" data-product-url="{{ product.url }}">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '300x300' }}" alt="{{ product.title }}" class="qb-product-image" style="cursor: pointer;">
              {% else %}
                <div style="width:100%; height:100%; background:#f5f5f5; display:flex; align-items:center; justify-content:center; color:#999;">No Image</div>
              {% endif %}
              <div class="qb-delivery-badge">🚚 13 mins</div>
            </div>
            <h3 class="qb-product-name">{{ product.title }}</h3>
            <div class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</div>
            <div class="qb-qty-selector">
              <button class="qb-qty-btn">−</button>
              <input type="number" class="qb-qty-input" value="1" min="1">
              <button class="qb-qty-btn">+</button>
            </div>
            <form action="/cart/add" method="post" class="product-form">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button type="submit" class="qb-add-btn">ADD TO CART</button>
            </form>
          </div>
        {% endfor %}
      {% else %}
        <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
          <p>No products available</p>
        </div>
      {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const sidebar = document.getElementById('category-sidebar');
    const productGrid = document.getElementById('product-grid');
    const collectionTitle = document.querySelector('.qb-collection-title');

    // Handle collection clicks for dynamic loading
    document.querySelectorAll('.qb-sidebar-category').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();

        const collectionHandle = this.dataset.collectionHandle;
        const collectionTitle = this.dataset.collectionTitle;

        // Update URL without page reload
        const newUrl = `/collections/${collectionHandle}`;
        window.history.pushState({ collection: collectionHandle }, collectionTitle, newUrl);

        // Update active state
        document.querySelectorAll('.qb-sidebar-category').forEach(l => l.classList.remove('active'));
        this.classList.add('active');

        // Update header title
        document.querySelector('.qb-collection-title').textContent = collectionTitle;

        // Load products from the collection using JSON API
        loadCollectionProducts(collectionHandle);
      });
    });

    function loadCollectionProducts(collectionHandle) {
      console.log('Loading collection:', collectionHandle);

      // Show loading state
      productGrid.innerHTML = `
        <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
          <p>Loading products...</p>
        </div>
      `;

      // Fetch the collection page to get properly filtered products from Shopify's server-side rendering
      fetch(`/collections/${collectionHandle}`)
        .then(response => {
          console.log('Response status:', response.status, response.ok);
          if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
          return response.text();
        })
        .then(html => {
          console.log('Fetched collection page HTML');

          // Parse HTML to extract product grid
          const tempDiv = document.createElement('div');
          tempDiv.innerHTML = html;

          // Find the product grid in the fetched HTML
          const fetchedProductGrid = tempDiv.querySelector('#product-grid');

          if (fetchedProductGrid && fetchedProductGrid.innerHTML.trim() !== '') {
            console.log('Found product grid in fetched HTML');

            // Replace current grid with fetched products
            productGrid.innerHTML = fetchedProductGrid.innerHTML;

            // Re-attach event listeners to newly loaded products
            attachProductListeners();
          } else {
            console.log('No products found in collection');
            productGrid.innerHTML = `
              <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
                <p>No products available</p>
              </div>
            `;
          }
        })
        .catch(err => {
          console.error('Error loading collection:', err);
          productGrid.innerHTML = `
            <div style="grid-column: 1/-1; padding: 40px; text-align: center; color: #999;">
              <p>Error loading products. Please try again.</p>
            </div>
          `;
        });
    }

    function createProductCard(product) {
      const card = document.createElement('div');
      card.className = 'qb-product-card';

      // Get featured image
      const featuredImage = product.featured_image ? product.featured_image.src : null;
      const productImage = featuredImage
        ? `<img src="${featuredImage}?width=300&height=300" alt="${product.title}" class="qb-product-image">`
        : '<div style="width:100%; height:100%; background:#f5f5f5; display:flex; align-items:center; justify-content:center; color:#999;">No Image</div>';

      // Get first variant ID for add to cart
      const variantId = product.variants && product.variants.length > 0 ? product.variants[0].id : '';

      // Format price in Rupees (divide by 100 for paise conversion)
      const price = Math.floor(product.price / 100);

      // Get product URL - construct from handle if not available
      const productUrl = product.url || `/products/${product.handle}`;

      card.innerHTML = `
        <div class="qb-product-image-wrap" style="cursor: pointer;" data-product-url="${productUrl}">
          ${productImage}
          <div class="qb-delivery-badge">🚚 13 mins</div>
        </div>
        <h3 class="qb-product-name">${product.title}</h3>
        <div class="qb-product-price">Rs ${price}</div>
        <div class="qb-qty-selector">
          <button class="qb-qty-btn" type="button">−</button>
          <input type="number" class="qb-qty-input" value="1" min="1">
          <button class="qb-qty-btn" type="button">+</button>
        </div>
        <form action="/cart/add" method="post" class="product-form">
          <input type="hidden" name="id" value="${variantId}">
          <button type="submit" class="qb-add-btn">ADD TO CART</button>
        </form>
      `;

      return card;
    }

    function attachProductListeners() {
      // Product image click - navigate to product page
      document.querySelectorAll('.qb-product-image-wrap').forEach(imageWrap => {
        imageWrap.removeEventListener('click', productImageClickHandler);
        imageWrap.addEventListener('click', productImageClickHandler);
      });

      // Quantity selector logic
      document.querySelectorAll('.qb-qty-selector').forEach(selector => {
        const minusBtn = selector.querySelector('.qb-qty-btn:first-child');
        const input = selector.querySelector('.qb-qty-input');
        const plusBtn = selector.querySelector('.qb-qty-btn:last-child');

        minusBtn.removeEventListener('click', qtyMinusHandler);
        plusBtn.removeEventListener('click', qtyPlusHandler);

        minusBtn.addEventListener('click', qtyMinusHandler);
        plusBtn.addEventListener('click', qtyPlusHandler);
      });

      // Add to cart logic
      document.querySelectorAll('.product-form').forEach(form => {
        form.removeEventListener('submit', addToCartHandler);
        form.addEventListener('submit', addToCartHandler);
      });
    }

    function productImageClickHandler(e) {
      const productUrl = this.dataset.productUrl;
      if (productUrl) {
        window.location.href = productUrl;
      }
    }

    function qtyMinusHandler(e) {
      e.preventDefault();
      const selector = this.closest('.qb-qty-selector');
      const input = selector.querySelector('.qb-qty-input');
      let val = parseInt(input.value) || 1;
      if (val > 1) input.value = val - 1;
    }

    function qtyPlusHandler(e) {
      e.preventDefault();
      const selector = this.closest('.qb-qty-selector');
      const input = selector.querySelector('.qb-qty-input');
      let val = parseInt(input.value) || 1;
      input.value = val + 1;
    }

    function addToCartHandler(e) {
      // Allow normal form submission to /cart/add
      // The form will handle the POST request naturally
      const card = this.closest('.qb-product-card');
      const qty = card.querySelector('.qb-qty-input').value;

      // Update the form with quantity before submission
      const qtyInput = document.createElement('input');
      qtyInput.type = 'hidden';
      qtyInput.name = 'quantity';
      qtyInput.value = qty;
      this.appendChild(qtyInput);
    }

    // Auto-load collection from URL or default to first
    function initializeCollectionFromURL() {
      // Extract collection handle from URL
      const urlPath = window.location.pathname;
      const match = urlPath.match(/\/collections\/([^/?]+)/);
      const collectionHandleFromURL = match ? match[1] : null;

      let categoryToLoad = document.querySelector('.qb-sidebar-category');

      // If URL contains a collection, find and use that instead
      if (collectionHandleFromURL) {
        const urlCategory = document.querySelector(
          `.qb-sidebar-category[data-collection-handle="${collectionHandleFromURL}"]`
        );
        if (urlCategory) {
          categoryToLoad = urlCategory;
        }
      }

      // Load the selected collection
      if (categoryToLoad) {
        categoryToLoad.classList.add('active');
        const collectionHandle = categoryToLoad.dataset.collectionHandle;
        const collectionTitle = categoryToLoad.dataset.collectionTitle;

        // Update the title
        const titleElement = document.querySelector('.qb-collection-title');
        if (titleElement) {
          titleElement.textContent = collectionTitle;
        }

        loadCollectionProducts(collectionHandle);

        // Scroll collection button into view
        setTimeout(() => {
          categoryToLoad.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 100);
      }
    }

    // Initialize on page load
    initializeCollectionFromURL();

    // Initial attachment of listeners
    attachProductListeners();

    // Sort functionality
    const sortSelect = document.getElementById('product-sort');
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        const sortValue = this.value;
        if (!sortValue) return; // No sorting if "Sort by" is selected

        const products = Array.from(document.querySelectorAll('.qb-product-card'));

        // Sort products based on selection
        products.sort((a, b) => {
          const priceA = parseInt(a.querySelector('.qb-product-price').textContent.replace(/[^\d]/g, ''));
          const priceB = parseInt(b.querySelector('.qb-product-price').textContent.replace(/[^\d]/g, ''));

          switch(sortValue) {
            case 'price-asc':
              return priceA - priceB;
            case 'price-desc':
              return priceB - priceA;
            default:
              return 0;
          }
        });

        // Re-insert sorted products into the grid
        products.forEach(product => {
          productGrid.appendChild(product);
        });
      });
    }
  })();
</script>
