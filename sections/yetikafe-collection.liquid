              <h3 class="yk-item-name">{{ p.title }}</h3>
              {%- unless p.description == blank -%}<p class="yk-item-desc">{{ p.description | strip_html | truncate: 60 }}</p>{%- endunless -%}
              <div class="yk-price-row"><span class="yk-price">Rs {{ p.price | divided_by: 100 }}</span>{%- if cp > p.price -%}<span class="yk-old-price">Rs {{ cp | divided_by: 100 }}</span><span class="yk-save">{{ pct }}% off</span>{%- endif -%}</div>
            </div>
            <div class="yk-card-right">
              {%- if p.featured_image -%}<div class="yk-img-wrap"><img src="{{ p.featured_image | img_url: '300x300', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy" width="72" height="72"></div>{%- else -%}<div class="yk-img-fallback">🌟</div>{%- endif -%}
              <button class="yk-add-btn" data-vid="{{ vid }}">ADD</button>
              <div class="yk-stepper" data-vid="{{ vid }}"><button class="yk-stepper-btn yk-stepper-minus" data-vid="{{ vid }}">−</button><span class="yk-stepper-count" data-vid="{{ vid }}">1</span><button class="yk-stepper-btn yk-stepper-plus" data-vid="{{ vid }}">+</button></div>
