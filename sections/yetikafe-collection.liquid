  {%- endif -%}

  <!-- Cart bar removed — universal qb-sticky-cart handles this -->

  <!-- ── TOAST ──────────────────────────────────────────────────── -->
  <div class="yk-toast" id="ykToast" aria-live="polite">Added to cart ✓</div>

</div><!-- /yk-wrap -->

<script>
(function () {
  'use strict';

  /* ── Product data ─────────────────────────────────────────────── */
  window.YK_PRODUCTS = [
    {%- for p in all_products -%}
    {
      id: {{ p.id }},
      vid: {{ p.variants.first.id }},
      title: {{ p.title | json }},
      price: {{ p.price }},
      cp: {{ p.compare_at_price | default: 0 }},
      img: "{{ p.featured_image | img_url: '300x300', crop: 'center' }}"
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  /* ── State ────────────────────────────────────────────────────── */
  var ykCart = {};
  var toastTimer = null;

  /* ── Price lookup ────────────────────────────────────────────── */
  function vidToPrice(vid) {
    for (var i = 0; i < window.YK_PRODUCTS.length; i++) {
      if (String(window.YK_PRODUCTS[i].vid) === String(vid)) {
        return window.YK_PRODUCTS[i].price;
      }
    }
    return 0;
  }

  /* ── Update cart bar UI ──────────────────────────────────────── */
  function ykUpdateBar() {
    var totalQty = 0;
    var totalPrice = 0;
    var vids = Object.keys(ykCart);
    for (var i = 0; i < vids.length; i++) {
      var qty = ykCart[vids[i]];
      if (qty > 0) {
        totalQty += qty;
        totalPrice += qty * vidToPrice(vids[i]);
      }
    }
    var bar      = document.getElementById('ykCartBar');
    var countEl  = document.getElementById('ykCartCount');
    var subEl    = document.getElementById('ykCartSubtitle');
    var totalEl  = document.getElementById('ykCartTotal');
    if (!bar) return;
    countEl.textContent = totalQty;
    subEl.textContent   = totalQty === 1 ? 'item added' : 'items added';
    totalEl.textContent = 'Rs ' + Math.round(totalPrice / 100);
    if (totalQty > 0) {
      bar.classList.add('visible');
    } else {
      bar.classList.remove('visible');
    }
  }

  /* ── Sync DOM for a single variant ──────────────────────────── */
  function ykRenderVid(vid) {
    var qty      = ykCart[vid] || 0;
    var addBtns  = document.querySelectorAll('.yk-add-btn[data-vid="' + vid + '"]');
    var steppers = document.querySelectorAll('.yk-stepper[data-vid="' + vid + '"]');
    var counts   = document.querySelectorAll('.yk-stepper-count[data-vid="' + vid + '"]');

    addBtns.forEach(function (btn) {
      if (qty > 0) {
        btn.style.display = 'none';
      } else {
        btn.style.display = '';
        // Reset any leftover animation states so the button is fully clickable
        btn.classList.remove('loading', 'success');
        btn.removeAttribute('disabled');
        btn.textContent = 'ADD';
      }
    });
    steppers.forEach(function (s) {
      if (qty > 0) { s.classList.add('visible'); }
      else          { s.classList.remove('visible'); }
    });
    counts.forEach(function (c) { c.textContent = qty; });
  }

  /* ── Toast notification ──────────────────────────────────────── */
  function ykShowToast(msg) {
    var t = document.getElementById('ykToast');
    if (!t) return;
    t.textContent = msg;
    t.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(function () { t.classList.remove('show'); }, 2000);
  }

  /* ── Add to cart (with loading animation) ────────────────────── */
  function ykAddToCart(vid, qty, btn) {
    if (btn) {
      // 1. Ripple effect on tap position
      btn.style.position = 'relative';
      btn.style.overflow = 'hidden';
      var ripple = document.createElement('span');
      ripple.className = 'yk-ripple';
      btn.appendChild(ripple);
      // 2. Enter loading state
      btn.classList.add('loading');
      btn.setAttribute('disabled', true);
    }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: qty })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      ykCart[vid] = (ykCart[vid] || 0) + qty;
      // 3. Brief green success flash, then swap to stepper
      if (btn) {
        btn.classList.remove('loading');
        btn.classList.add('success');
        btn.textContent = '✓';
        setTimeout(function () {
          ykRenderVid(vid);
          ykUpdateBar();
          ykShowToast('Added to cart ✓');
        }, 320);
      } else {
        ykRenderVid(vid);
        ykUpdateBar();
        ykShowToast('Added to cart ✓');
      }
    })
    .catch(function (e) {
      console.error('[YetiKafe] add error', e);
      if (btn) {
        btn.classList.remove('loading');
        btn.removeAttribute('disabled');
        btn.textContent = 'ADD';
      }
    });
  }

  /* ── Change quantity (with stepper busy state) ────────────────── */
  function ykChangeQty(vid, newQty, btn) {
    // Busy-lock the tapped button
    if (btn) { btn.classList.add('busy'); }
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: newQty })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      if (newQty <= 0) { delete ykCart[vid]; }
      else             { ykCart[vid] = newQty; }
      ykRenderVid(vid);
      ykUpdateBar();
    })
    .catch(function (e) {
      console.error('[YetiKafe] change error', e);
      if (btn) { btn.classList.remove('busy'); }
    });
  }

  /* ── Restore cart state on load ──────────────────────────────── */
  function ykRestoreCart() {
    fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      ykCart = {};
      if (data && data.items) {
        data.items.forEach(function (item) {
          ykCart[String(item.variant_id)] = item.quantity;
        });
      }
      Object.keys(ykCart).forEach(function (vid) { ykRenderVid(vid); });
      ykUpdateBar();
    })
    .catch(function (e) { console.error('[YetiKafe] restore error', e); });
  }

  /* ── Category tab scroll + active state ─────────────────────── */
  function ykInitTabs() {
    var tabs = document.querySelectorAll('.yk-tab');
    if (!tabs.length) return;

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var targetId = tab.getAttribute('data-target');
        var target   = document.getElementById(targetId);
        if (!target) return;
        var tabsH  = ykTabsWrapEl ? ykTabsWrapEl.offsetHeight : 44;
        var offset = ykHeaderH + tabsH + 8;
        /* Use absolute offsetTop walk — never use getBoundingClientRect on fixed elements */
        var absTop = 0;
        var node = target;
        while (node) { absTop += node.offsetTop || 0; node = node.offsetParent; }
        window.scrollTo({ top: absTop - offset, behavior: 'smooth' });
      });
    });

    if (!('IntersectionObserver' in window)) return;

    var sections = [
      { id: 'yk-sec-hot',    tabId: 'yk-tab-hot'    },
      { id: 'yk-sec-cold',   tabId: 'yk-tab-cold'   },
      { id: 'yk-sec-mains',  tabId: 'yk-tab-mains'  },
      { id: 'yk-sec-snacks', tabId: 'yk-tab-snacks' },
      { id: 'yk-sec-cakes',  tabId: 'yk-tab-cakes'  },
      { id: 'yk-sec-bakery', tabId: 'yk-tab-bakery' },
      { id: 'yk-sec-combos', tabId: 'yk-tab-combos' },
      { id: 'yk-sec-others', tabId: 'yk-tab-others' }
    ];

    /* Build rootMargin dynamically so it accounts for real header+tabs height */
    function ykMakeObserver() {
      var tabsH   = ykTabsWrapEl ? ykTabsWrapEl.offsetHeight : 44;
      var topBias = ykHeaderH + tabsH;          /* px from top to ignore */
      var botBias = Math.round(window.innerHeight * 0.55); /* bottom dead zone */
      var margin  = '-' + topBias + 'px 0px -' + botBias + 'px 0px';

      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var sid = entry.target.id;
          sections.forEach(function (s) {
            var tab = document.getElementById(s.tabId);
            if (!tab) return;
            if (s.id === sid) {
              tab.classList.add('active');
              /* Auto-scroll the tab bar so active tab is visible */
              var tabsEl = document.getElementById('ykTabs');
              if (tabsEl) {
                var tLeft  = tab.offsetLeft;
                var tW     = tab.offsetWidth;
                var barW   = tabsEl.offsetWidth;
                var scroll = tabsEl.scrollLeft;
                if (tLeft < scroll + 20) {
                  tabsEl.scrollTo({ left: tLeft - 20, behavior: 'smooth' });
                } else if (tLeft + tW > scroll + barW - 20) {
                  tabsEl.scrollTo({ left: tLeft + tW - barW + 20, behavior: 'smooth' });
                }
              }
            } else {
              tab.classList.remove('active');
            }
          });
        });
      }, { rootMargin: margin, threshold: 0 });

      sections.forEach(function (s) {
        var el = document.getElementById(s.id);
        if (el) obs.observe(el);
      });
      return obs;
    }

    ykMakeObserver();
  }

  /* ── Event delegation for ADD / stepper ─────────────────────── */
  function ykBindCards() {
    var wrap = document.getElementById('ykWrap');
    if (!wrap) return;

    wrap.addEventListener('click', function (e) {
      var target = e.target;

      if (target.classList.contains('yk-add-btn') && !target.classList.contains('loading') && !target.classList.contains('success')) {
        var vid = target.getAttribute('data-vid');
        ykAddToCart(vid, 1, target);
        return;
      }

      if (target.classList.contains('yk-stepper-minus') && !target.classList.contains('busy')) {
        var vid     = target.getAttribute('data-vid');
        var current = ykCart[vid] || 0;
        ykChangeQty(vid, Math.max(0, current - 1), target);
        return;
      }

      if (target.classList.contains('yk-stepper-plus') && !target.classList.contains('busy')) {
        var vid     = target.getAttribute('data-vid');
        var current = ykCart[vid] || 0;
        ykChangeQty(vid, current + 1, target);
        return;
      }
    });
  }

  /* ── Boot ────────────────────────────────────────────────────── */
  var ykHeaderH = 0;
  var ykTabsWrapEl = null;
  var ykTabsSpacerEl = null;
  var ykTabsFixed = false;

  function ykGetHeaderH() {
    var hdr = document.querySelector('.qb-header');
    var ann = document.querySelector('.qb-announcement');
    var h = 0;
    if (hdr) h += hdr.offsetHeight;
    if (ann) h += ann.offsetHeight;
    return h > 20 ? h : 102;
  }

  /* Track the scroll-Y at which the tabs should become fixed */
  var ykTabsTriggerY = 0;

  function ykUpdateTabsFixed() {
    if (!ykTabsWrapEl || !ykTabsSpacerEl) return;
    var scrollY = window.scrollY || window.pageYOffset;

    if (!ykTabsFixed) {
      /* Use spacer's offsetTop (relative to document) as trigger point */
      if (scrollY + ykHeaderH >= ykTabsTriggerY) {
        ykTabsFixed = true;
        ykTabsWrapEl.classList.add('yk-tabs-fixed');
        ykTabsWrapEl.style.top = ykHeaderH + 'px';
        ykTabsSpacerEl.style.height = ykTabsWrapEl.offsetHeight + 'px';
        ykTabsSpacerEl.classList.add('yk-tabs-spacer-active');
      }
    } else {
      if (scrollY + ykHeaderH < ykTabsTriggerY) {
        ykTabsFixed = false;
        ykTabsWrapEl.classList.remove('yk-tabs-fixed');
        ykTabsWrapEl.style.top = '';
        ykTabsSpacerEl.classList.remove('yk-tabs-spacer-active');
      }
    }
  }

  function ykComputeTrigger() {
    /* ALWAYS walk from ykTabsWrapEl — spacer starts display:none so offsetParent=null → returns 0 which breaks everything */
    var top = 0;
    var node = ykTabsWrapEl;
    while (node) { top += node.offsetTop || 0; node = node.offsetParent; }
    return top;
  }

  function ykInitFixed() {
    ykTabsWrapEl   = document.getElementById('ykTabsWrap');
    ykTabsSpacerEl = document.getElementById('ykTabsSpacer');
    if (!ykTabsWrapEl) return;
    ykHeaderH      = ykGetHeaderH();
    ykTabsTriggerY = ykComputeTrigger();
    var tabsH = ykTabsWrapEl.offsetHeight;
    document.documentElement.style.setProperty('--yk-scroll-margin', (ykHeaderH + tabsH + 8) + 'px');
    window.addEventListener('scroll', ykUpdateTabsFixed, { passive: true });
    window.addEventListener('resize', function () {
      ykHeaderH      = ykGetHeaderH();
      ykTabsTriggerY = ykComputeTrigger();
      var th = ykTabsWrapEl.offsetHeight;
      document.documentElement.style.setProperty('--yk-scroll-margin', (ykHeaderH + th + 8) + 'px');
      if (ykTabsFixed) ykTabsWrapEl.style.top = ykHeaderH + 'px';
    }, { passive: true });
  }

  function ykInit() {
    ykBindCards();
    ykInitTabs();
    ykRestoreCart();
    requestAnimationFrame(function() {
      setTimeout(ykInitFixed, 300);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', ykInit);
  } else {
    ykInit();
  }

})();
</script>

