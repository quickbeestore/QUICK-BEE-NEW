{%- assign all_products = collection.products -%}
{%- assign has_drinks = false -%}{%- assign drink_count = 0 -%}
{%- assign has_slices = false -%}{%- assign slice_count = 0 -%}
{%- assign has_boxes = false -%}{%- assign box_count = 0 -%}
{%- assign has_biscuits = false -%}{%- assign biscuit_count = 0 -%}
{%- assign has_others = false -%}{%- assign other_count = 0 -%}
{%- for p in all_products -%}
  {%- assign pt = p.type | downcase | strip -%}
  {%- if pt contains 'drink' or pt contains 'tea' or pt contains 'coffee' or pt contains 'juice' or pt contains 'shake' or pt contains 'smoothie' or pt contains 'latte' or pt contains 'cappuccino' or pt contains 'mocktail' or pt contains 'lassi' or pt contains 'bubble' or pt contains 'beverage' -%}
    {%- assign has_drinks = true -%}{%- assign drink_count = drink_count | plus: 1 -%}
  {%- elsif pt contains 'slice' -%}{%- assign has_slices = true -%}{%- assign slice_count = slice_count | plus: 1 -%}
  {%- elsif pt contains 'box' -%}{%- assign has_boxes = true -%}{%- assign box_count = box_count | plus: 1 -%}
  {%- elsif pt contains 'biscuit' or pt contains 'bread' or pt contains 'cookie' -%}{%- assign has_biscuits = true -%}{%- assign biscuit_count = biscuit_count | plus: 1 -%}
  {%- else -%}{%- assign has_others = true -%}{%- assign other_count = other_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

<style>
/* ─── CSS Variables ──────────────────────────────────────────────────── */
:root {
  --yk-bg: #faf9f7;
  --yk-card: #ffffff;
  --yk-card-hover: #f5f3ef;
  --yk-border: #ede9e0;
  --yk-text: #1a1a1a;
  --yk-text2: #666666;
  --yk-text3: #aaaaaa;
  --yk-acc: #ffcc00;
  --yk-acc2: #e6b800;
  --yk-acc-fg: #1a1a1a;
  --yk-hero-bg: linear-gradient(145deg, #fffbee 0%, #faf9f7 100%);
  --yk-section-head: #f0ede6;
  --yk-pill-bg: #f0ede6;
  --yk-pill-active-bg: #ffcc00;
  --yk-pill-active-fg: #1a1a1a;
  --yk-shadow: 0 1px 3px rgba(0,0,0,0.07), 0 4px 12px rgba(0,0,0,0.04);
  --yk-shadow-btn: 0 2px 8px rgba(255,204,0,0.35);
  --yk-veg: #22c55e;
  --yk-discount: #ef4444;
  --yk-transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
}
[data-theme="dark"] {
  --yk-bg: #0f0f0f;
  --yk-card: #1c1c1c;
  --yk-card-hover: #232323;
  --yk-border: #2e2e2e;
  --yk-text: #f0f0f0;
  --yk-text2: #909090;
  --yk-text3: #505050;
  --yk-acc: #ffcc00;
  --yk-acc2: #e6b800;
  --yk-acc-fg: #0f0f0f;
  --yk-hero-bg: linear-gradient(145deg, #1c1600 0%, #0f0f0f 100%);
  --yk-section-head: #161616;
  --yk-pill-bg: #232323;
  --yk-pill-active-bg: #ffcc00;
  --yk-pill-active-fg: #0f0f0f;
  --yk-shadow: 0 1px 3px rgba(0,0,0,0.5), 0 4px 12px rgba(0,0,0,0.3);
  --yk-shadow-btn: 0 2px 8px rgba(255,204,0,0.25);
  --yk-veg: #22c55e;
  --yk-discount: #f87171;
  --yk-transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
}

/* ─── Base ───────────────────────────────────────────────────────────── */
.yk-wrap {
  background: var(--yk-bg);
  color: var(--yk-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  min-height: 60vh;
  padding-bottom: calc(110px + env(safe-area-inset-bottom));
  transition: var(--yk-transition);
  -webkit-tap-highlight-color: transparent;
}
.yk-wrap *, .yk-wrap *::before, .yk-wrap *::after { box-sizing: border-box; }

/* ─── Keyframes ──────────────────────────────────────────────────────── */
@keyframes yk-pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.5; transform: scale(1.4); }
}
@keyframes yk-fade-in {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes yk-bounce {
  0%   { transform: scale(0.8); }
  60%  { transform: scale(1.1); }
  100% { transform: scale(1); }
}
@keyframes yk-toast-in {
  from { opacity: 0; transform: translateX(-50%) translateY(12px); }
  to   { opacity: 1; transform: translateX(-50%) translateY(0); }
}

/* ─── Hero ───────────────────────────────────────────────────────────── */
.yk-hero {
  background: var(--yk-hero-bg);
  padding: 32px 20px 28px;
  text-align: center;
  border-bottom: 1px solid var(--yk-border);
  transition: var(--yk-transition);
}
.yk-hero-status {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.8px;
  color: var(--yk-text2);
  text-transform: uppercase;
  margin-bottom: 14px;
  transition: var(--yk-transition);
}
.yk-status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--yk-veg);
  display: inline-block;
  animation: yk-pulse-dot 1.8s ease-in-out infinite;
  flex-shrink: 0;
}
.yk-hero-title {
  margin: 0 0 6px;
  font-size: 2.4rem;
  font-weight: 900;
  letter-spacing: -1.5px;
  color: var(--yk-text);
  line-height: 1;
  transition: var(--yk-transition);
}
.yk-hero-icon {
  color: var(--yk-acc);
}
.yk-hero-tagline {
  margin: 0 0 18px;
  font-size: 13px;
  color: var(--yk-text2);
  letter-spacing: 0.3px;
  transition: var(--yk-transition);
}
.yk-hero-chips {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 7px;
}
.yk-chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 11px;
  border-radius: 20px;
  border: 1px solid var(--yk-border);
  font-size: 11px;
  font-weight: 500;
  color: var(--yk-text2);
  background: var(--yk-card);
  transition: var(--yk-transition);
}

/* ─── Category Tabs ──────────────────────────────────────────────────── */
.yk-tabs-wrap {
  position: sticky;
  top: 56px;
  z-index: 200;
  background: transparent;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--yk-border);
  transition: border-color 0.25s ease;
}
.yk-tabs {
  display: flex;
  gap: 6px;
  padding: 10px 16px;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.yk-tabs::-webkit-scrollbar { display: none; }
.yk-tab {
  flex-shrink: 0;
  padding: 6px 14px;
  border-radius: 20px;
  border: none;
  background: var(--yk-pill-bg);
  color: var(--yk-text2);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  letter-spacing: 0.3px;
  transition: background 0.2s ease, color 0.2s ease;
  outline: none;
}
.yk-tab.active,
.yk-tab:hover {
  background: var(--yk-pill-active-bg);
  color: var(--yk-pill-active-fg);
}

/* ─── Section Header ─────────────────────────────────────────────────── */
.yk-section-head {
  background: var(--yk-section-head);
  padding: 14px 16px;
  border-bottom: 1px solid var(--yk-border);
  transition: var(--yk-transition);
}
.yk-section-head-inner {
  display: flex;
  align-items: center;
  gap: 10px;
  max-width: 480px;
  margin: 0 auto;
}
.yk-section-emoji {
  font-size: 22px;
  line-height: 1;
}
.yk-section-title {
  margin: 0;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1.5px;
  color: var(--yk-text);
  text-transform: uppercase;
  transition: var(--yk-transition);
}
.yk-section-sub {
  margin: 2px 0 0;
  font-size: 11px;
  color: var(--yk-text3);
  transition: var(--yk-transition);
}

/* ─── Product Card ───────────────────────────────────────────────────── */
.yk-list {
  max-width: 480px;
  margin: 0 auto;
}
.yk-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12px;
  padding: 16px;
  background: var(--yk-card);
  border-bottom: 1px solid var(--yk-border);
  transition: background 0.2s ease, border-color 0.25s ease;
  animation: yk-fade-in 0.3s ease forwards;
  opacity: 0;
}
.yk-card:hover {
  background: var(--yk-card-hover);
}
.yk-card:nth-child(1)  { animation-delay: 0.03s; }
.yk-card:nth-child(2)  { animation-delay: 0.06s; }
.yk-card:nth-child(3)  { animation-delay: 0.09s; }
.yk-card:nth-child(4)  { animation-delay: 0.12s; }
.yk-card:nth-child(5)  { animation-delay: 0.15s; }
.yk-card:nth-child(6)  { animation-delay: 0.18s; }
.yk-card:nth-child(7)  { animation-delay: 0.21s; }
.yk-card:nth-child(8)  { animation-delay: 0.24s; }
.yk-card:nth-child(9)  { animation-delay: 0.27s; }
.yk-card:nth-child(10) { animation-delay: 0.30s; }

/* LEFT */
.yk-card-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.yk-card-top {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.yk-veg-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--yk-veg);
  flex-shrink: 0;
  display: inline-block;
}
.yk-badge {
  display: inline-block;
  padding: 1px 6px;
  border-radius: 4px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}
.yk-badge--popular { background: var(--yk-acc); color: var(--yk-acc-fg); }
.yk-badge--new     { background: var(--yk-veg); color: #fff; }
.yk-badge--deal    { background: var(--yk-discount); color: #fff; }
.yk-item-name {
  margin: 0;
  font-size: 15px;
  font-weight: 700;
  color: var(--yk-text);
  line-height: 1.3;
  transition: var(--yk-transition);
}
.yk-item-desc {
  margin: 0;
  font-size: 12px;
  color: var(--yk-text2);
  line-height: 1.45;
  transition: var(--yk-transition);
}
.yk-price-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 4px;
}
.yk-price {
  font-size: 14px;
  font-weight: 700;
  color: var(--yk-text);
  transition: var(--yk-transition);
}
.yk-old-price {
  font-size: 12px;
  color: var(--yk-text3);
  text-decoration: line-through;
  transition: var(--yk-transition);
}
.yk-save {
  font-size: 10px;
  font-weight: 700;
  color: var(--yk-discount);
}

/* RIGHT */
.yk-card-right {
  width: 88px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.yk-img-wrap {
  width: 72px;
  height: 72px;
  border-radius: 10px;
  overflow: hidden;
  flex-shrink: 0;
}
.yk-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.yk-img-fallback {
  width: 72px;
  height: 72px;
  border-radius: 10px;
  background: var(--yk-section-head);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  flex-shrink: 0;
  transition: var(--yk-transition);
}
.yk-add-btn {
  width: 100%;
  padding: 6px 0;
  border-radius: 8px;
  border: none;
  background: var(--yk-acc);
  color: var(--yk-acc-fg);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.5px;
  cursor: pointer;
  box-shadow: var(--yk-shadow-btn);
  transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  outline: none;
}
.yk-add-btn:active { transform: scale(0.94); }
.yk-add-btn:hover  { background: var(--yk-acc2); }
.yk-stepper {
  display: none;
  width: 100%;
  align-items: center;
  justify-content: space-between;
  background: var(--yk-acc);
  border-radius: 8px;
  overflow: hidden;
}
.yk-stepper.visible {
  display: flex;
  animation: yk-bounce 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.yk-stepper-btn {
  background: transparent;
  border: none;
  color: var(--yk-acc-fg);
  font-size: 17px;
  font-weight: 700;
  width: 28px;
  height: 28px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  outline: none;
  transition: background 0.15s ease;
}
.yk-stepper-btn:active { background: rgba(0,0,0,0.1); }
.yk-stepper-count {
  font-size: 13px;
  font-weight: 700;
  color: var(--yk-acc-fg);
  min-width: 20px;
  text-align: center;
}

/* ─── Empty State ────────────────────────────────────────────────────── */
.yk-empty {
  text-align: center;
  padding: 72px 24px;
  color: var(--yk-text2);
}
.yk-empty-icon { font-size: 52px; margin-bottom: 16px; line-height: 1; }
.yk-empty h2 {
  font-size: 20px; font-weight: 700;
  color: var(--yk-text); margin: 0 0 8px;
  transition: var(--yk-transition);
}
.yk-empty p { font-size: 14px; margin: 0; transition: var(--yk-transition); }

/* ─── Cart Bar ───────────────────────────────────────────────────────── */
.yk-cart-bar {
  position: fixed;
  bottom: calc(72px + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%) translateY(calc(100% + 80px + env(safe-area-inset-bottom)));
  width: calc(100% - 24px);
  max-width: 460px;
  height: 58px;
  border-radius: 16px;
  background: var(--yk-acc);
  color: var(--yk-acc-fg);
  z-index: 10000;
  transition: transform 0.42s cubic-bezier(0.34, 1.56, 0.64, 1);
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18px;
  box-shadow: 0 8px 32px rgba(255, 204, 0, 0.4);
}
.yk-cart-bar.visible {
  transform: translateX(-50%) translateY(0);
}
.yk-cart-bar-left {
  display: flex;
  align-items: center;
  gap: 12px;
}
.yk-cart-badge {
  background: var(--yk-acc-fg);
  color: var(--yk-acc);
  font-size: 13px;
  font-weight: 800;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.yk-cart-bar-text { display: flex; flex-direction: column; gap: 1px; }
.yk-cart-bar-sub  { font-size: 10px; font-weight: 600; opacity: 0.75; letter-spacing: 0.3px; }
.yk-cart-bar-total { font-size: 15px; font-weight: 800; }
.yk-cart-cta {
  font-size: 13px; font-weight: 700;
  letter-spacing: 0.2px;
  display: flex; align-items: center; gap: 5px;
}

/* ─── Toast ──────────────────────────────────────────────────────────── */
.yk-toast {
  position: fixed;
  bottom: calc(147px + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%) translateY(0);
  background: #22c55e;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.3px;
  padding: 10px 20px;
  border-radius: 24px;
  z-index: 10001;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.22s ease;
  white-space: nowrap;
  box-shadow: 0 4px 16px rgba(34, 197, 94, 0.35);
}
.yk-toast.show {
  opacity: 1;
  animation: yk-toast-in 0.22s ease forwards;
}

/* ─── ADD Button Loading State ─────────────────────────────────────────── */
@keyframes yk-spin { to { transform: rotate(360deg); } }
@keyframes yk-btn-pop {
  0%   { transform: scale(1); }
  40%  { transform: scale(0.88); }
  70%  { transform: scale(1.08); }
  100% { transform: scale(1); }
}
@keyframes yk-checkmark {
  0%   { stroke-dashoffset: 24; opacity: 0; }
  30%  { opacity: 1; }
  100% { stroke-dashoffset: 0; opacity: 1; }
}
.yk-add-btn.loading {
  color: transparent !important;
  pointer-events: none;
  position: relative;
}
.yk-add-btn.loading::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 16px; height: 16px;
  margin: -8px 0 0 -8px;
  border: 2.5px solid rgba(0,0,0,0.18);
  border-top-color: #000;
  border-radius: 50%;
  animation: yk-spin 0.55s linear infinite;
}
.yk-add-btn.success {
  background: #22c55e !important;
  color: #fff !important;
  pointer-events: none;
  animation: yk-btn-pop 0.35s cubic-bezier(0.34,1.56,0.64,1) forwards;
}
/* Ripple on ADD tap */
.yk-add-btn .yk-ripple {
  position: absolute;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: rgba(0,0,0,0.2);
  transform: translate(-50%,-50%) scale(0);
  animation: yk-ripple-out 0.5s ease-out forwards;
  pointer-events: none;
}
@keyframes yk-ripple-out {
  to { transform: translate(-50%,-50%) scale(18); opacity: 0; }
}
/* Stepper +/- loading micro-state */
.yk-stepper-btn.busy {
  opacity: 0.4;
  pointer-events: none;
}
</style>

<div class="yk-wrap" id="ykWrap">

  <!-- ── HERO ───────────────────────────────────────────────────── -->
  <div class="yk-hero">
    <div class="yk-hero-status">
      <span class="yk-status-dot"></span> OPEN NOW &nbsp;·&nbsp; FAST DELIVERY
    </div>
    <h1 class="yk-hero-title">YETIKAFE <span class="yk-hero-icon">☕</span></h1>
    <p class="yk-hero-tagline">Nepal's First Virtual Café</p>
    <div class="yk-hero-chips">
      <span class="yk-chip">⚡ 15 min delivery</span>
      <span class="yk-chip">⭐ 4.8 rated</span>
      <span class="yk-chip">🚚 Free delivery</span>
      <span class="yk-chip">📍 Kathmandu</span>
    </div>
  </div>

  <!-- ── CATEGORY TABS ──────────────────────────────────────────── -->
  {%- if all_products.size > 0 -%}
  <div class="yk-tabs-wrap">
    <div class="yk-tabs" id="ykTabs">
      {%- if has_drinks -%}
      <button class="yk-tab" id="yk-tab-drinks" data-target="yk-sec-drinks">🥤 Drinks</button>
      {%- endif -%}
      {%- if has_slices -%}
      <button class="yk-tab" id="yk-tab-slices" data-target="yk-sec-slices">🍰 Slices</button>
      {%- endif -%}
      {%- if has_boxes -%}
      <button class="yk-tab" id="yk-tab-boxes" data-target="yk-sec-boxes">📦 Boxes</button>
      {%- endif -%}
      {%- if has_biscuits -%}
      <button class="yk-tab" id="yk-tab-biscuits" data-target="yk-sec-biscuits">🍪 Biscuits & Bread</button>
      {%- endif -%}
      {%- if has_others -%}
      <button class="yk-tab" id="yk-tab-others" data-target="yk-sec-others">🍽️ Food</button>
      {%- endif -%}
    </div>
  </div>
  {%- endif -%}

  <!-- ── PRODUCT SECTIONS ───────────────────────────────────────── -->
  {%- if all_products.size == 0 -%}
  <div class="yk-empty">
    <div class="yk-empty-icon">☕</div>
    <h2>Menu coming soon</h2>
    <p>We're preparing something delicious</p>
  </div>
  {%- else -%}

    <!-- DRINKS -->
    {%- if has_drinks -%}
    <div class="yk-section-head" id="yk-sec-drinks">
      <div class="yk-section-head-inner">
        <span class="yk-section-emoji">🥤</span>
        <div>
          <h2 class="yk-section-title">Drinks</h2>
          <p class="yk-section-sub">{{ drink_count }} refreshing choices</p>
        </div>
      </div>
    </div>
    <div class="yk-list">
      {%- for p in all_products -%}
        {%- assign pt = p.type | downcase | strip -%}
        {%- if pt contains 'drink' or pt contains 'tea' or pt contains 'coffee' or pt contains 'juice' or pt contains 'shake' or pt contains 'smoothie' or pt contains 'latte' or pt contains 'cappuccino' or pt contains 'mocktail' or pt contains 'lassi' or pt contains 'bubble' or pt contains 'beverage' -%}
          {%- assign cp = p.compare_at_price | default: 0 -%}
          {%- assign vid = p.variants.first.id -%}
          {%- assign pct = 0 -%}
          {%- if cp > p.price -%}{%- assign diff = cp | minus: p.price -%}{%- assign pct = diff | times: 100 | divided_by: cp -%}{%- endif -%}
          <div class="yk-card" data-vid="{{ vid }}" data-pid="{{ p.id }}">
            <div class="yk-card-left">
              <div class="yk-card-top">
                <span class="yk-veg-dot"></span>
                {%- if pct >= 10 -%}<span class="yk-badge yk-badge--deal">DEAL</span>{%- endif -%}
                {%- if p.tags contains 'popular' or p.tags contains 'Popular' -%}<span class="yk-badge yk-badge--popular">POPULAR</span>{%- endif -%}
                {%- if p.tags contains 'new' or p.tags contains 'New' -%}<span class="yk-badge yk-badge--new">NEW</span>{%- endif -%}
              </div>
              <h3 class="yk-item-name">{{ p.title }}</h3>
              {%- unless p.description == blank -%}
              <p class="yk-item-desc">{{ p.description | strip_html | truncate: 60 }}</p>
              {%- endunless -%}
              <div class="yk-price-row">
