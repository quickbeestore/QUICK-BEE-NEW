{%- comment -%} Real Therapy Spa — Collection Page Template {%- endcomment -%}

<style>
/* ════════════════════════════════════════════════
   REAL THERAPY SPA — COLLECTION TEMPLATE
   Luxurious · Serene · Mobile-First
   ════════════════════════════════════════════════ */

:root {
  --rts-bg:        #F9F6F1;
  --rts-surface:   #FFFFFF;
  --rts-card:      #FFFFFF;
  --rts-border:    #E8E0D5;
  --rts-border2:   #D5CAB9;
  --rts-text:      #1C1A17;
  --rts-text2:     #4A4035;
  --rts-muted:     #8C7B68;
  --rts-muted2:    #BEB0A0;
  --rts-gold:      #B8913A;
  --rts-gold-bg:   rgba(184,145,58,0.08);
  --rts-gold-bd:   rgba(184,145,58,0.20);
  --rts-green:     #2D5A27;
  --rts-green-lt:  #4A7C43;
  --rts-green-bg:  rgba(45,90,39,0.07);
  --rts-green-bd:  rgba(45,90,39,0.18);
  --rts-rose:      #9B4B4B;
  --rts-rose-bg:   rgba(155,75,75,0.07);
  --rts-rose-bd:   rgba(155,75,75,0.20);
  --rts-radius:    20px;
  --rts-shadow:    0 4px 24px rgba(28,26,23,0.07);
  --rts-shadow2:   0 12px 40px rgba(28,26,23,0.12);
}

/* ── Base ── */
.rts-page {
  background: var(--rts-bg);
  color: var(--rts-text);
  font-family: var(--font-body--family, system-ui, sans-serif);
  min-height: 100vh;
}

/* ════════════════════════════════════════════════
   HERO BANNER
   ════════════════════════════════════════════════ */
.rts-hero {
  position: relative;
  background: linear-gradient(155deg, #1C2E1A 0%, #2D5A27 55%, #3D7035 100%);
  overflow: hidden;
  padding: 60px 24px 52px;
  text-align: center;
}

.rts-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(ellipse 60% 50% at 30% 40%, rgba(255,255,255,0.04) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 80% 70%, rgba(184,145,58,0.10) 0%, transparent 70%);
  pointer-events: none;
}

/* Decorative leaf shapes */
.rts-hero::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  height: 48px;
  background: var(--rts-bg);
  clip-path: ellipse(55% 100% at 50% 100%);
}

.rts-hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 5px 14px;
  background: rgba(184,145,58,0.15);
  border: 1px solid rgba(184,145,58,0.30);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #D4AF6A;
  margin-bottom: 18px;
}

.rts-hero-title {
  font-size: clamp(28px, 8vw, 48px);
  font-weight: 800;
  letter-spacing: -0.02em;
  color: #FFFFFF;
  margin: 0 0 14px;
  line-height: 1.1;
}

.rts-hero-subtitle {
  font-size: clamp(14px, 3.5vw, 16px);
  color: rgba(255,255,255,0.70);
  max-width: 48ch;
  margin: 0 auto 28px;
  line-height: 1.6;
}

.rts-hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  background: #B8913A;
  color: #fff;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 800;
  letter-spacing: 0.03em;
  text-decoration: none;
  transition: background 0.2s, transform 0.18s, box-shadow 0.2s;
  box-shadow: 0 4px 20px rgba(184,145,58,0.35);
}

.rts-hero-cta:hover {
  background: #D4AF6A;
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(184,145,58,0.45);
}

/* ════════════════════════════════════════════════
   TRUST BADGES
   ════════════════════════════════════════════════ */
.rts-trust {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 0 16px;
  margin: 28px 0 0;
  flex-wrap: wrap;
}

.rts-trust-item {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 10px 18px;
  font-size: 12px;
  font-weight: 700;
  color: var(--rts-muted);
  white-space: nowrap;
  position: relative;
}

.rts-trust-item + .rts-trust-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 25%;
  height: 50%;
  width: 1px;
  background: var(--rts-border2);
}

.rts-trust-icon {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  background: var(--rts-green-bg);
  border: 1px solid var(--rts-green-bd);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  flex-shrink: 0;
}

/* ════════════════════════════════════════════════
   SECTION HEADING
   ════════════════════════════════════════════════ */
.rts-section-head {
  text-align: center;
  padding: 52px 24px 40px;
}

.rts-section-eyebrow {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--rts-gold);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.rts-section-eyebrow::before,
.rts-section-eyebrow::after {
  content: '';
  display: inline-block;
  width: 24px;
  height: 1px;
  background: var(--rts-gold);
  opacity: 0.5;
}

.rts-section-title {
  font-size: clamp(22px, 5vw, 32px);
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--rts-text);
  margin: 0 0 12px;
  line-height: 1.2;
}

.rts-section-desc {
  font-size: 15px;
  color: var(--rts-muted);
  max-width: 50ch;
  margin: 0 auto;
  line-height: 1.65;
}

/* ════════════════════════════════════════════════
   PACKAGE CARDS
   ════════════════════════════════════════════════ */
.rts-grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
  padding: 0 16px 64px;
  max-width: 960px;
  margin: 0 auto;
}

@media (min-width: 700px) {
  .rts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    padding: 0 24px 72px;
  }
}

@media (min-width: 1024px) {
  .rts-grid {
    grid-template-columns: repeat(3, 1fr);
    padding: 0 32px 80px;
  }
}

/* The featured card spans full width on desktop */
.rts-card.featured {
  grid-column: 1 / -1;
}

@media (min-width: 700px) and (max-width: 1023px) {
  .rts-card.featured {
    grid-column: 1 / -1;
  }
}

@media (min-width: 1024px) {
  .rts-card.featured {
    grid-column: span 1;
  }
}

/* ── Card ── */
.rts-card {
  background: var(--rts-card);
  border: 1px solid var(--rts-border);
  border-radius: var(--rts-radius);
  overflow: hidden;
  box-shadow: var(--rts-shadow);
  transition: border-color 0.25s, transform 0.22s, box-shadow 0.25s;
  display: flex;
  flex-direction: column;
  position: relative;
}

.rts-card:hover {
  border-color: var(--rts-gold-bd);
  transform: translateY(-4px);
  box-shadow: var(--rts-shadow2);
}

/* Card image */
.rts-card-img {
  aspect-ratio: 16 / 9;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #D5CAB9 0%, #C5B8A5 100%);
}

.rts-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.rts-card:hover .rts-card-img img { transform: scale(1.04); }

.rts-card-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52px;
  background: linear-gradient(135deg, #D5ECD0 0%, #C5D9C0 100%);
}

/* Ribbon badge */
.rts-ribbon {
  position: absolute;
  top: 16px;
  left: -4px;
  padding: 5px 14px 5px 12px;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border-radius: 0 6px 6px 0;
  z-index: 2;
  box-shadow: 2px 2px 8px rgba(0,0,0,0.15);
}

.rts-ribbon.bestseller {
  background: #B8913A;
  color: #fff;
}

.rts-ribbon.popular {
  background: var(--rts-green);
  color: #fff;
}

.rts-ribbon.romantic {
  background: var(--rts-rose);
  color: #fff;
}

/* Discount pill on image */
.rts-discount-pill {
  position: absolute;
  bottom: 12px;
  right: 12px;
  padding: 4px 10px;
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(4px);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
  border-radius: 999px;
  z-index: 2;
}

/* Card body */
.rts-card-body {
  padding: 20px;
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 14px;
}

.rts-card-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.rts-duration-chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 4px 10px;
  background: var(--rts-green-bg);
  border: 1px solid var(--rts-green-bd);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  color: var(--rts-green-lt);
}

.rts-type-chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 4px 10px;
  background: var(--rts-gold-bg);
  border: 1px solid var(--rts-gold-bd);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  color: var(--rts-gold);
}

.rts-card-title {
  font-size: 18px;
  font-weight: 800;
  letter-spacing: -0.015em;
  color: var(--rts-text);
  margin: 0;
  line-height: 1.2;
}

/* Includes list */
.rts-includes {
  display: flex;
  flex-direction: column;
  gap: 6px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.rts-includes li {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 13px;
  color: var(--rts-text2);
  line-height: 1.4;
}

.rts-includes li::before {
  content: '';
  flex-shrink: 0;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--rts-green-bg);
  border: 1.5px solid var(--rts-green-bd);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 1px;
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='10' viewBox='0 0 24 24' fill='none' stroke='%232D5A27' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpolyline points='20 6 9 17 4 12'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 10px;
}

/* Divider */
.rts-card-divider {
  height: 1px;
  background: var(--rts-border);
}

/* Pricing */
.rts-price-area {
  display: flex;
  align-items: flex-end;
  gap: 10px;
}

.rts-price {
  font-size: 26px;
  font-weight: 900;
  letter-spacing: -0.03em;
  color: var(--rts-text);
  line-height: 1;
}

.rts-price-currency {
  font-size: 14px;
  font-weight: 700;
  color: var(--rts-muted);
  margin-bottom: 2px;
}

.rts-compare-price {
  font-size: 14px;
  font-weight: 600;
  color: var(--rts-muted2);
  text-decoration: line-through;
  margin-bottom: 2px;
}

.rts-savings-badge {
  margin-left: auto;
  padding: 4px 10px;
  background: rgba(45,90,39,0.10);
  border: 1px solid rgba(45,90,39,0.20);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  color: var(--rts-green-lt);
}

/* Card footer CTAs */
.rts-card-footer {
  display: flex;
  gap: 10px;
  margin-top: auto;
}

.rts-btn-book {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 14px 18px;
  background: var(--rts-green);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.03em;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.2s, transform 0.18s, box-shadow 0.2s;
  box-shadow: 0 4px 16px rgba(45,90,39,0.25);
}

.rts-btn-book:hover {
  background: #3D7035;
  transform: translateY(-1px);
  box-shadow: 0 6px 22px rgba(45,90,39,0.35);
}

.rts-btn-details {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px;
  background: transparent;
  border: 1.5px solid var(--rts-border2);
  border-radius: 12px;
  color: var(--rts-muted);
  cursor: pointer;
  text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
}

.rts-btn-details:hover {
  border-color: var(--rts-gold-bd);
  color: var(--rts-gold);
}

/* ════════════════════════════════════════════════
   WHY CHOOSE US STRIP
   ════════════════════════════════════════════════ */
.rts-why {
  background: var(--rts-green);
  padding: 48px 24px;
  text-align: center;
  color: #fff;
}

.rts-why-title {
  font-size: clamp(18px, 4vw, 24px);
  font-weight: 800;
  letter-spacing: -0.01em;
  margin: 0 0 32px;
  color: #fff;
}

.rts-why-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  max-width: 800px;
  margin: 0 auto;
}

@media (min-width: 640px) {
  .rts-why-grid { grid-template-columns: repeat(4, 1fr); }
}

.rts-why-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

.rts-why-icon {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
}

.rts-why-label {
  font-size: 12px;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  line-height: 1.35;
}

/* ════════════════════════════════════════════════
   BOOK STRIP
   ════════════════════════════════════════════════ */
.rts-book-strip {
  padding: 56px 24px;
  text-align: center;
  background: var(--rts-bg);
}

.rts-book-title {
  font-size: clamp(20px, 5vw, 28px);
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--rts-text);
  margin: 0 0 10px;
}

.rts-book-sub {
  font-size: 14px;
  color: var(--rts-muted);
  margin: 0 auto 28px;
  max-width: 40ch;
  line-height: 1.6;
}

.rts-book-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

.rts-call-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 26px;
  background: var(--rts-green);
  color: #fff;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 800;
  text-decoration: none;
  transition: background 0.2s, transform 0.18s;
  box-shadow: 0 4px 16px rgba(45,90,39,0.25);
}

.rts-call-btn:hover { background: #3D7035; transform: translateY(-2px); }

.rts-wa-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 26px;
  background: #25D366;
  color: #fff;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 800;
  text-decoration: none;
  transition: background 0.2s, transform 0.18s;
  box-shadow: 0 4px 16px rgba(37,211,102,0.30);
}

.rts-wa-btn:hover { background: #1ebe5a; transform: translateY(-2px); }

.rts-discount-note {
  margin-top: 20px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 8px 18px;
  background: var(--rts-gold-bg);
  border: 1px solid var(--rts-gold-bd);
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
  color: var(--rts-gold);
}

/* ════════════════════════════════════════════════
   ACCESSIBILITY
   ════════════════════════════════════════════════ */
@media (prefers-reduced-motion: reduce) {
  .rts-card, .rts-btn-book, .rts-hero-cta,
  .rts-card-img img { transition: none !important; transform: none !important; }
}
</style>

<div class="rts-page">

  <!-- ═══════════════════════════
       HERO
       ═══════════════════════════ -->
  <div class="rts-hero">
    <div class="rts-hero-eyebrow">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
      Thamel, Kathmandu · Since 2002
    </div>
    <h1 class="rts-hero-title">Spa Packages<br>in Kathmandu</h1>
    <p class="rts-hero-subtitle">Complete wellness journeys blending Ayurvedic traditions with modern therapeutic practices — in the heart of Thamel.</p>
    <a href="/pages/contact" class="rts-hero-cta">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Book Now
    </a>
  </div>

  <!-- ═══════════════════════════
       TRUST BADGES
       ═══════════════════════════ -->
  <div class="rts-trust">
    <div class="rts-trust-item">
      <div class="rts-trust-icon">⭐</div>
      <span>5-Star Rated<br>on TripAdvisor</span>
    </div>
    <div class="rts-trust-item">
      <div class="rts-trust-icon">🏛️</div>
      <span>Since 2002<br>Trusted Heritage</span>
    </div>
    <div class="rts-trust-item">
      <div class="rts-trust-icon">🔒</div>
      <span>Private<br>Facilities</span>
    </div>
    <div class="rts-trust-item">
      <div class="rts-trust-icon">🌿</div>
      <span>Ayurvedic<br>Methods</span>
    </div>
  </div>

  <!-- ═══════════════════════════
       PACKAGES
       ═══════════════════════════ -->
  <div class="rts-section-head">
    <p class="rts-section-eyebrow">Our Packages</p>
    <h2 class="rts-section-title">Choose Your Wellness Journey</h2>
    <p class="rts-section-desc">Each package is fully customizable. Swap any treatment for another of equal duration — just let our front desk know when booking.</p>
  </div>

  <div class="rts-grid">

    {%- for product in collection.products -%}

      {%- assign is_featured = false -%}
      {%- if product.tags contains 'full-day' or product.handle contains 'full-day' -%}
        {%- assign is_featured = true -%}
        {%- assign ribbon_class = 'bestseller' -%}
        {%- assign ribbon_text = 'Best Value' -%}
        {%- assign duration_text = '8 Hours' -%}
        {%- assign type_icon = '✦' -%}
        {%- assign card_includes = 'Sauna & Steam + Jacuzzi (x2)|Best Treatment or Hot Stone Massage (120 min)|Full Body Scrub & Massage (60 min)|Lunch Included|Facial + Pedicure + Manicure (60 min each)' | split: '|' -%}
      {%- elsif product.tags contains 'half-day' or product.handle contains 'half-day' -%}
        {%- assign ribbon_class = 'popular' -%}
        {%- assign ribbon_text = 'Most Popular' -%}
        {%- assign duration_text = '5 Hours' -%}
        {%- assign type_icon = '◆' -%}
        {%- assign card_includes = 'Sauna & Steam + Jacuzzi (60 min)|Best Treatment or Hot Stone Massage (90 min)|Facial or Full Body Scrub (60 min)|Pedicure or Full Leg Waxing (60 min)|Lunch Included' | split: '|' -%}
      {%- elsif product.tags contains 'couples' or product.handle contains 'couple' -%}
        {%- assign ribbon_class = 'romantic' -%}
        {%- assign ribbon_text = 'For Couples' -%}
        {%- assign duration_text = 'Flexible' -%}
        {%- assign type_icon = '♥' -%}
        {%- assign card_includes = 'Private Couples Sauna & Jacuzzi (120 min)|Ayurvedic Massage for Both (60 min each)|Private Shower & Resting Area|Unlimited Tea & Coffee|Fully Separate from Other Guests' | split: '|' -%}
      {%- else -%}
        {%- assign ribbon_class = '' -%}
        {%- assign ribbon_text = '' -%}
        {%- assign duration_text = product.metafields.custom.duration | default: 'Custom' -%}
        {%- assign type_icon = '◆' -%}
        {%- assign card_includes = '' | split: ',' -%}
      {%- endif -%}

      {%- assign has_discount = false -%}
      {%- if product.compare_at_price > product.price -%}
        {%- assign has_discount = true -%}
        {%- assign savings = product.compare_at_price | minus: product.price -%}
      {%- endif -%}

      <div class="rts-card{% if is_featured %} featured{% endif %}">

        <div class="rts-card-img">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              loading="lazy"
              width="800"
              height="450"
            >
          {%- else -%}
            <div class="rts-card-img-placeholder">
              {%- if ribbon_class == 'romantic' -%}🌹
              {%- elsif ribbon_class == 'popular' -%}🌿
              {%- else -%}🪷{%- endif -%}
            </div>
          {%- endif -%}

          {%- if ribbon_text != '' -%}
            <span class="rts-ribbon {{ ribbon_class }}">{{ ribbon_text }}</span>
          {%- endif -%}

          {%- if has_discount -%}
            {%- assign discount_pct = savings | times: 100 | divided_by: product.compare_at_price -%}
            <span class="rts-discount-pill">{{ discount_pct }}% OFF</span>
          {%- endif -%}
        </div>

        <div class="rts-card-body">

          <div class="rts-card-meta">
            {%- if duration_text != '' -%}
              <span class="rts-duration-chip">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {{ duration_text }}
              </span>
            {%- endif -%}
            <span class="rts-type-chip">{{ type_icon }} Spa Package</span>
          </div>

          <h3 class="rts-card-title">{{ product.title }}</h3>

          {%- if card_includes.size > 0 -%}
            <ul class="rts-includes">
              {%- for item in card_includes limit: 5 -%}
                <li>{{ item }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          <div class="rts-card-divider"></div>

          <div class="rts-price-area">
            <span class="rts-price-currency">
              {%- if product.tags contains 'npr' or product.handle contains 'couple' -%}NPR{%- else -%}USD{%- endif -%}
            </span>
            <span class="rts-price">{{ product.price | money_without_currency }}</span>
            {%- if has_discount -%}
              <span class="rts-compare-price">
                {%- if product.tags contains 'npr' or product.handle contains 'couple' -%}NPR{%- else -%}USD{%- endif -%}
                {{ product.compare_at_price | money_without_currency }}
              </span>
            {%- endif -%}
            {%- if has_discount -%}
              <span class="rts-savings-badge">Save {{ savings | money_without_currency }}</span>
            {%- endif -%}
          </div>

          <div class="rts-card-footer">
            <a href="/pages/contact" class="rts-btn-book">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Book This Package
            </a>
            <a href="{{ product.url }}" class="rts-btn-details" aria-label="View details for {{ product.title | escape }}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M9 18l6-6-6-6"/></svg>
            </a>
          </div>

        </div>
      </div>

    {%- endfor -%}

  </div>

  <!-- ═══════════════════════════
       WHY CHOOSE US
       ═══════════════════════════ -->
  <div class="rts-why">
    <h2 class="rts-why-title">Why Real Therapy Spa?</h2>
    <div class="rts-why-grid">
      <div class="rts-why-item">
        <div class="rts-why-icon">🏛️</div>
        <span class="rts-why-label">20+ Years<br>of Excellence</span>
      </div>
      <div class="rts-why-item">
        <div class="rts-why-icon">🌿</div>
        <span class="rts-why-label">Ayurvedic<br>Wellness</span>
      </div>
      <div class="rts-why-item">
        <div class="rts-why-icon">🔒</div>
        <span class="rts-why-label">Private<br>Facilities</span>
      </div>
      <div class="rts-why-item">
        <div class="rts-why-icon">✏️</div>
        <span class="rts-why-label">Fully<br>Customizable</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════
       BOOK CTA STRIP
       ═══════════════════════════ -->
  <div class="rts-book-strip">
    <h2 class="rts-book-title">Ready to Unwind?</h2>
    <p class="rts-book-sub">Walk-ins welcome. Advance booking recommended for packages to guarantee availability.</p>
    <div class="rts-book-actions">
      <a href="/pages/contact" class="rts-call-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Book an Appointment
      </a>
    </div>
    <div>
      <span class="rts-discount-note">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><path d="M12 22V7M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
        Book online and get 20% off your appointment
      </span>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "RTS Spa Collection",
  "settings": [],
  "presets": []
}
{% endschema %}
