{% comment %} Real Therapy Spa — Booking Page {% endcomment %}
{% assign rts_treatments = collection.products %}

<style>
:root {
  --rts-teal: #2a9d8f;
  --rts-light-teal: #70c8be;
  --rts-dark: #0d1a19;
  --rts-surface: #122220;
  --rts-card: #192e2c;
  --rts-border: rgba(42,157,143,0.2);
  --rts-text: #e8f5f4;
  --rts-muted: #6aada8;
  --rts-radius: 16px;
}
.rts-page {
  background: var(--rts-dark);
  min-height: 100vh;
  color: var(--rts-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  overflow-x: hidden;
}
.rts-hero {
  background: linear-gradient(160deg, #0d1a19 0%, #122e2a 50%, #0a1812 100%);
  padding: 64px 20px 48px;
  text-align: center;
  position: relative; overflow: hidden;
}
.rts-hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(42,157,143,0.1); border: 1px solid var(--rts-border);
  color: var(--rts-teal); padding: 8px 20px; border-radius: 24px;
  font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 20px;
}
.rts-hero-title {
  font-size: clamp(30px, 7vw, 56px); font-weight: 300; line-height: 1.1; margin: 0 0 10px;
}
.rts-hero-title em {
  font-style: italic; font-weight: 700;
  background: linear-gradient(135deg, #70c8be, #2a9d8f, #1a7a70);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.rts-hero-sub { font-size: 15px; color: var(--rts-muted); margin: 10px 0 0; font-style: italic; }

.rts-section { padding: 48px 20px; }
.rts-section-title-wrap { text-align: center; margin-bottom: 36px; }
.rts-eyebrow { font-size: 11px; color: var(--rts-teal); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
.rts-section-h { font-size: 26px; font-weight: 300; }
.rts-section-h strong { font-weight: 800; }

.rts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 18px; max-width: 960px; margin: 0 auto;
}
.rts-card {
  background: var(--rts-card); border: 1px solid var(--rts-border);
  border-radius: var(--rts-radius); overflow: hidden;
  transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
}
.rts-card:hover { transform: translateY(-4px); border-color: rgba(42,157,143,0.4); box-shadow: 0 12px 40px rgba(0,0,0,0.4); }
.rts-card-img { width: 100%; height: 170px; object-fit: cover; }
.rts-card-img-ph {
  width: 100%; height: 170px;
  background: linear-gradient(135deg, #192e2c, #0d1a19);
  display: flex; align-items: center; justify-content: center; font-size: 52px;
}
.rts-card-body { padding: 18px; }
.rts-card-name { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
.rts-card-desc { font-size: 13px; color: var(--rts-muted); line-height: 1.6; margin-bottom: 12px; }
.rts-card-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
.rts-tag {
  background: rgba(42,157,143,0.08); border: 1px solid var(--rts-border);
  color: var(--rts-teal); padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: 600;
}
.rts-card-price { font-size: 17px; font-weight: 700; color: var(--rts-teal); margin-bottom: 14px; }
.rts-book-btn {
  width: 100%; padding: 13px; background: linear-gradient(135deg, #2a9d8f, #1a7a70);
  color: #fff; border: none; border-radius: 10px; font-size: 14px; font-weight: 700;
  cursor: pointer; transition: opacity 0.2s;
}
.rts-book-btn:hover { opacity: 0.88; }
.rts-book-btn:disabled { background: #333; color: #666; cursor: default; }

/* DRAWER */
.rts-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.72);
  backdrop-filter: blur(6px); z-index: 300; opacity: 0; pointer-events: none;
  transition: opacity 0.3s;
}
.rts-overlay.rts-open { opacity: 1; pointer-events: auto; }
.rts-drawer {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #122220; border-top: 1px solid var(--rts-border);
  border-radius: 22px 22px 0 0; z-index: 301;
  transform: translateY(100%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
  max-height: 92vh; overflow-y: auto;
}
.rts-drawer.rts-open { transform: translateY(0); }
#rtsBookingDrawer {
  --rts-teal: #2a9d8f; --rts-border: rgba(42,157,143,0.2);
  --rts-card: #192e2c; --rts-text: #e8f5f4; --rts-muted: #6aada8;
}
.rts-drawer-handle { width: 40px; height: 4px; background: rgba(255,255,255,0.15); border-radius: 2px; margin: 14px auto 0; cursor: pointer; }
.rts-drawer-hdr { padding: 18px 22px; border-bottom: 1px solid var(--rts-border); }
.rts-drawer-title { font-size: 17px; font-weight: 700; color: var(--rts-text); }
.rts-drawer-sub { font-size: 13px; color: var(--rts-muted); margin-top: 3px; }
.rts-drawer-body { padding: 22px; }
.rts-step-lbl { font-size: 11px; color: var(--rts-muted); margin-bottom: 8px; letter-spacing: 0.5px; }
.rts-dots { display: flex; gap: 8px; margin-bottom: 24px; }
.rts-dot { flex: 1; height: 3px; border-radius: 2px; background: rgba(255,255,255,0.1); transition: background 0.3s; }
.rts-dot.rts-done { background: var(--rts-teal); }
.rts-panel { display: none; }
.rts-panel.rts-active { display: block; }
.rts-date-grid { display: flex; gap: 10px; flex-wrap: wrap; }
.rts-date-chip {
  background: var(--rts-card); border: 1.5px solid var(--rts-border);
  border-radius: 12px; padding: 10px 12px; cursor: pointer; text-align: center; transition: all 0.2s;
}
.rts-date-chip.rts-sel { background: rgba(42,157,143,0.15); border-color: var(--rts-teal); }
.rts-date-day { font-size: 11px; color: var(--rts-muted); text-transform: uppercase; }
.rts-date-num { font-size: 20px; font-weight: 800; color: var(--rts-text); }
.rts-date-mon { font-size: 11px; color: var(--rts-muted); }
.rts-time-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 10px; }
.rts-slot {
  background: var(--rts-card); border: 1.5px solid var(--rts-border);
  border-radius: 12px; padding: 12px; cursor: pointer; transition: all 0.2s;
}
.rts-slot.rts-sel { background: rgba(42,157,143,0.15); border-color: var(--rts-teal); }
.rts-slot-period { font-size: 11px; color: var(--rts-teal); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
.rts-slot-range { font-size: 14px; font-weight: 700; color: var(--rts-text); margin-top: 2px; }
.rts-summary {
  background: rgba(42,157,143,0.06); border: 1px solid var(--rts-border);
  border-radius: 14px; padding: 16px; margin-bottom: 18px;
}
.rts-sum-row { display: flex; justify-content: space-between; padding: 6px 0; }
.rts-sum-row + .rts-sum-row { border-top: 1px solid rgba(255,255,255,0.05); }
.rts-sum-k { font-size: 12px; color: var(--rts-muted); }
.rts-sum-v { font-size: 13px; font-weight: 600; color: var(--rts-text); text-align: right; max-width: 65%; }
.rts-field { margin-bottom: 14px; }
.rts-lbl { display: block; font-size: 11px; color: var(--rts-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 7px; }
.rts-input, .rts-ta {
  width: 100%; padding: 13px 16px; background: var(--rts-card); border: 1.5px solid var(--rts-border);
  border-radius: 12px; color: var(--rts-text); font-size: 14px; font-family: inherit;
  outline: none; transition: border-color 0.2s; box-sizing: border-box;
}
.rts-input:focus, .rts-ta:focus { border-color: var(--rts-teal); }
.rts-ta { resize: vertical; min-height: 70px; line-height: 1.6; }
.rts-btn-row { display: flex; gap: 10px; margin-top: 18px; }
.rts-btn-back {
  padding: 13px 18px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
  color: var(--rts-text); border-radius: 12px; font-size: 14px; font-weight: 600;
  cursor: pointer; transition: background 0.2s; white-space: nowrap;
}
.rts-btn-back:hover { background: rgba(255,255,255,0.1); }
.rts-btn-next {
  flex: 1; padding: 13px; background: linear-gradient(135deg, #2a9d8f, #1a7a70);
  color: #fff; border: none; border-radius: 12px; font-size: 14px; font-weight: 700;
  cursor: pointer; transition: opacity 0.2s;
}
.rts-btn-next:disabled { background: #333; color: #666; cursor: default; }
.rts-btn-next:hover:not(:disabled) { opacity: 0.88; }
</style>

<div class="rts-page">
  <div class="rts-hero">
    <div class="rts-hero-eyebrow">💆 Therapeutic Wellness</div>
    <h1 class="rts-hero-title">{{ collection.title | default: 'Real Therapy Spa' }}<br><em>Book Your Session</em></h1>
    <p class="rts-hero-sub">Healing therapies, expert hands, genuine care.</p>
  </div>

  <div class="rts-section">
    <div class="rts-section-title-wrap">
      <div class="rts-eyebrow">✦ Our Treatments</div>
      <div class="rts-section-h">Choose Your <strong>Therapy</strong></div>
    </div>
    <div class="rts-grid">
      {% for p in rts_treatments %}
        {% assign dur_tag = '' %}
        {% for tag in p.tags %}{% if tag contains 'min' or tag contains 'hour' %}{% assign dur_tag = tag %}{% endif %}{% endfor %}
        <div class="rts-card">
          {% if p.featured_image %}
            <img class="rts-card-img" src="{{ p.featured_image | img_url: '600x340', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
          {% else %}
            <div class="rts-card-img-ph">💆</div>
          {% endif %}
          <div class="rts-card-body">
            <div class="rts-card-name">{{ p.title }}</div>
            {% if p.description != blank %}<div class="rts-card-desc">{{ p.description | strip_html | truncate: 110 }}</div>{% endif %}
            <div class="rts-card-tags">
              {% if dur_tag != blank %}<span class="rts-tag">⏱ {{ dur_tag }}</span>{% endif %}
              {% if p.type != blank %}<span class="rts-tag">{{ p.type }}</span>{% endif %}
            </div>
            <div class="rts-card-price">NPR {{ p.price | money_without_currency }}</div>
            {% if p.available %}
              <button class="rts-book-btn"
                data-variant="{{ p.variants.first.id }}"
                data-name="{{ p.title | escape }}"
                data-price="{{ p.price | money_without_currency }}"
                data-duration="{{ dur_tag | default: 'As per package' }}"
                onclick="rtsOpenBooking(this)">Book Now</button>
            {% else %}
              <button class="rts-book-btn" disabled>Unavailable</button>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<div class="rts-overlay" id="rtsOverlay" onclick="rtsCloseBooking()"></div>
<div class="rts-drawer" id="rtsBookingDrawer">
  <div class="rts-drawer-handle" onclick="rtsCloseBooking()"></div>
  <div class="rts-drawer-hdr">
    <div class="rts-drawer-title" id="rtsDrawerTitle">Book Treatment</div>
    <div class="rts-drawer-sub" id="rtsDrawerSub"></div>
  </div>
  <div class="rts-drawer-body">
    <div class="rts-step-lbl" id="rtsStepLbl">Step 1 of 3 — Select Date</div>
    <div class="rts-dots">
      <div class="rts-dot rts-done" id="rtsDot1"></div>
      <div class="rts-dot" id="rtsDot2"></div>
      <div class="rts-dot" id="rtsDot3"></div>
    </div>

    <div class="rts-panel rts-active" id="rtsPanel1">
      <div class="rts-date-grid" id="rtsDateGrid"></div>
      <div class="rts-btn-row">
        <button class="rts-btn-next" id="rtsNext1" onclick="rtsGoStep(2)" disabled>Continue →</button>
      </div>
    </div>

    <div class="rts-panel" id="rtsPanel2">
      <div class="rts-time-grid">
        <div class="rts-slot" onclick="rtsSelTime(this,'Morning','9:00 AM – 10:30 AM')"><div class="rts-slot-period">Morning</div><div class="rts-slot-range">9:00 AM – 10:30 AM</div></div>
        <div class="rts-slot" onclick="rtsSelTime(this,'Late Morning','10:30 AM – 12:00 PM')"><div class="rts-slot-period">Late Morning</div><div class="rts-slot-range">10:30 AM – 12:00 PM</div></div>
        <div class="rts-slot" onclick="rtsSelTime(this,'Afternoon','1:00 PM – 2:30 PM')"><div class="rts-slot-period">Afternoon</div><div class="rts-slot-range">1:00 PM – 2:30 PM</div></div>
        <div class="rts-slot" onclick="rtsSelTime(this,'Late Afternoon','3:00 PM – 4:30 PM')"><div class="rts-slot-period">Late Afternoon</div><div class="rts-slot-range">3:00 PM – 4:30 PM</div></div>
        <div class="rts-slot" onclick="rtsSelTime(this,'Evening','5:00 PM – 6:30 PM')"><div class="rts-slot-period">Evening</div><div class="rts-slot-range">5:00 PM – 6:30 PM</div></div>
        <div class="rts-slot" onclick="rtsSelTime(this,'Late Evening','7:00 PM – 8:30 PM')"><div class="rts-slot-period">Late Evening</div><div class="rts-slot-range">7:00 PM – 8:30 PM</div></div>
      </div>
      <div class="rts-btn-row">
        <button class="rts-btn-back" onclick="rtsGoStep(1)">← Back</button>
        <button class="rts-btn-next" id="rtsNext2" onclick="rtsGoStep(3)" disabled>Continue →</button>
      </div>
    </div>

    <div class="rts-panel" id="rtsPanel3">
      <div class="rts-summary" id="rtsSummary"></div>
      <div class="rts-field">
        <label class="rts-lbl">Your Name *</label>
        <input type="text" class="rts-input" id="rtsGuestName" placeholder="Full name">
      </div>
      <div class="rts-field">
        <label class="rts-lbl">Phone / WhatsApp *</label>
        <input type="tel" class="rts-input" id="rtsGuestPhone" placeholder="98XXXXXXXX">
      </div>
      <div class="rts-field">
        <label class="rts-lbl">Special Requests</label>
        <textarea class="rts-ta" id="rtsSpecial" placeholder="Any preferences or notes…"></textarea>
      </div>
      <div class="rts-btn-row">
        <button class="rts-btn-back" onclick="rtsGoStep(2)">← Back</button>
        <button class="rts-btn-next" id="rtsConfirmBtn" onclick="rtsConfirm()">Confirm Booking</button>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  var S = { variant: null, name: '', price: '', duration: '', date: null, time: null, period: '' };
  var days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  function buildDates(){
    var today = new Date(); var html = '';
    for(var i = 1; i <= 14; i++){
      var d = new Date(today); d.setDate(today.getDate() + i);
      html += '<div class="rts-date-chip" onclick="rtsSelDate(this,\'' + d.toDateString() + '\')">' +
        '<div class="rts-date-day">' + days[d.getDay()] + '</div>' +
        '<div class="rts-date-num">' + d.getDate() + '</div>' +
        '<div class="rts-date-mon">' + months[d.getMonth()] + '</div>' +
        '</div>';
    }
    document.getElementById('rtsDateGrid').innerHTML = html;
  }
  buildDates();

  window.rtsOpenBooking = function(btn){
    S.variant = btn.dataset.variant; S.name = btn.dataset.name;
    S.price = btn.dataset.price; S.duration = btn.dataset.duration;
    S.date = null; S.time = null; S.period = '';
    document.getElementById('rtsDrawerTitle').textContent = S.name;
    document.getElementById('rtsDrawerSub').textContent = 'NPR ' + S.price + (S.duration ? ' · ' + S.duration : '');
    document.querySelectorAll('.rts-date-chip,.rts-slot').forEach(function(e){ e.classList.remove('rts-sel'); });
    ['rtsGuestName','rtsGuestPhone','rtsSpecial'].forEach(function(id){ document.getElementById(id).value = ''; });
    document.getElementById('rtsNext1').disabled = true;
    document.getElementById('rtsNext2').disabled = true;
    rtsGoStep(1);
    document.getElementById('rtsOverlay').classList.add('rts-open');
    document.getElementById('rtsBookingDrawer').classList.add('rts-open');
    document.body.style.overflow = 'hidden';
  };
  window.rtsCloseBooking = function(){
    document.getElementById('rtsOverlay').classList.remove('rts-open');
    document.getElementById('rtsBookingDrawer').classList.remove('rts-open');
    document.body.style.overflow = '';
  };
  window.rtsGoStep = function(step){
    document.querySelectorAll('.rts-panel').forEach(function(p){ p.classList.remove('rts-active'); });
    document.getElementById('rtsPanel' + step).classList.add('rts-active');
    var lbls = ['','Step 1 of 3 — Select Date','Step 2 of 3 — Select Time','Step 3 of 3 — Your Details'];
    document.getElementById('rtsStepLbl').textContent = lbls[step];
    ['rtsDot1','rtsDot2','rtsDot3'].forEach(function(id,i){ document.getElementById(id).classList.toggle('rts-done', i < step); });
    if(step === 3){
      var b = document.getElementById('rtsSummary');
      b.innerHTML = '<div class="rts-sum-row"><span class="rts-sum-k">Treatment</span><span class="rts-sum-v">' + S.name + '</span></div>' +
        '<div class="rts-sum-row"><span class="rts-sum-k">Duration</span><span class="rts-sum-v">' + S.duration + '</span></div>' +
        '<div class="rts-sum-row"><span class="rts-sum-k">Date</span><span class="rts-sum-v">' + S.date + '</span></div>' +
        '<div class="rts-sum-row"><span class="rts-sum-k">Time</span><span class="rts-sum-v">' + S.period + ' · ' + S.time + '</span></div>' +
        '<div class="rts-sum-row"><span class="rts-sum-k">Price</span><span class="rts-sum-v" style="color:var(--rts-teal)">NPR ' + S.price + '</span></div>';
    }
  };
  window.rtsSelDate = function(chip, dateStr){
    document.querySelectorAll('.rts-date-chip').forEach(function(c){ c.classList.remove('rts-sel'); });
    chip.classList.add('rts-sel'); S.date = dateStr;
    document.getElementById('rtsNext1').disabled = false;
  };
  window.rtsSelTime = function(slot, period, range){
    document.querySelectorAll('.rts-slot').forEach(function(s){ s.classList.remove('rts-sel'); });
    slot.classList.add('rts-sel'); S.time = range; S.period = period;
    document.getElementById('rtsNext2').disabled = false;
  };
  window.rtsConfirm = function(){
    var name = document.getElementById('rtsGuestName').value.trim();
    var phone = document.getElementById('rtsGuestPhone').value.trim();
    var special = document.getElementById('rtsSpecial').value.trim();
    if(!name || !phone){ alert('Please enter your name and phone number.'); return; }
    var btn = document.getElementById('rtsConfirmBtn');
    btn.disabled = true; btn.textContent = '⏳ Processing…';
    var note = [
      '--- REAL THERAPY SPA BOOKING ---',
      'Treatment: ' + S.name,
      'Duration: ' + S.duration,
      'Date: ' + S.date,
      'Time: ' + S.period + ' · ' + S.time,
      'Guest Name: ' + name,
      'Phone / WhatsApp: ' + phone,
      special ? 'Special Requests: ' + special : 'Special Requests: None'
    ].join('\n');
    function setNoteAndGo(){
      fetch('/cart/update.js', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ note: note })
      }).then(function(){ window.location.href = '/cart'; }).catch(function(){ window.location.href = '/cart'; });
    }
    if(S.variant){
      fetch('/cart/add.js', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: S.variant, quantity: 1 })
      }).then(setNoteAndGo).catch(setNoteAndGo);
    } else { setNoteAndGo(); }
  };
})();
</script>
