          </label>
          <textarea class="dc-textarea" id="dc-notes" placeholder="Gate code, specific items, accessibility info..." style="min-height:80px;"></textarea>
        </div>

        <!-- Submit -->
        <button type="button" class="dc-submit-btn" id="dcSubmitBtn" onclick="dcSubmitPickup({{ product.variants.first.id }})">
          <span id="dcBtnText">🚀 Schedule Free Pickup</span>
          <div class="dc-btn-loader" id="dcBtnLoader"></div>
        </button>

        <p style="text-align:center;font-size:12px;color:var(--dc-muted);margin-top:8px;">
          🔒 Your info is attached to your order. No cart detour — straight to checkout.
        </p>

      </div>
    </div>
  </div>

  <!-- ── FOOTER INFO STRIP ── -->
  <div class="dc-form-section" style="margin-top:0;">
    <div class="dc-footer-info">
      <div class="dc-footer-emoji">♻️</div>
      <div class="dc-footer-text">
        Every piece you donate is <strong>professionally washed</strong> by KapadaWash, then <strong>distributed by Nepal Youth Club</strong> to families across Kathmandu Valley — at zero cost to you.
        <br><span style="color:var(--dc-green);font-weight:700;margin-top:6px;display:block;">"One bag of clothes. One family's dignity."</span>
      </div>
    </div>
  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {

  // Set min date to tomorrow
  var dateInput = document.getElementById('dc-date');
  if (dateInput) {
    var tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    dateInput.min = tomorrow.toISOString().split('T')[0];
  }

  // Pill selector for clothes count
  var pills = document.querySelectorAll('.dc-count-pill');
  pills.forEach(function(pill) {
    pill.addEventListener('click', function() {
      pills.forEach(function(p) { p.classList.remove('selected'); });
      this.classList.add('selected');
    });
  });

});

// ── DIRECT-TO-CHECKOUT PICKUP SUBMIT ──────────────────────────────────────
function dcSubmitPickup(variantId) {
  var errorBanner = document.getElementById('dcErrorBanner');
  var btnText     = document.getElementById('dcBtnText');
  var btnLoader   = document.getElementById('dcBtnLoader');
  var submitBtn   = document.getElementById('dcSubmitBtn');

  function showError(msg) {
    errorBanner.innerHTML = '⚠️ ' + msg;
    errorBanner.style.display = 'block';
    errorBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function hideError() {
    errorBanner.style.display = 'none';
    errorBanner.innerHTML = '';
  }

  function setLoading(on) {
    if (on) {
      btnText.textContent = 'Scheduling…';
      btnLoader.style.display = 'block';
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.75';
    } else {
      btnText.textContent = '🚀 Schedule Free Pickup';
      btnLoader.style.display = 'none';
      submitBtn.disabled = false;
      submitBtn.style.opacity = '1';
    }
  }

  // ── 1. Collect field values ──────────────────────────────────────────────
  var name     = (document.getElementById('dc-name')     || {}).value || '';
  var email    = (document.getElementById('dc-email')    || {}).value || '';
  var phone    = (document.getElementById('dc-phone')    || {}).value || '';
  var location = (document.getElementById('dc-location') || {}).value || '';
  var address  = (document.getElementById('dc-address')  || {}).value || '';
  var date     = (document.getElementById('dc-date')     || {}).value || '';
  var time     = (document.getElementById('dc-time')     || {}).value || '';
  var notes    = (document.getElementById('dc-notes')    || {}).value || '';

  var selectedPill = document.querySelector('.dc-count-pill.selected input[type="radio"]');
  var clothesCount = selectedPill ? selectedPill.value : '5–10 clothes';

  // ── 2. Validate ──────────────────────────────────────────────────────────
  hideError();

  if (!name.trim()) {
    showError('Please enter your full name.'); return;
  }
  if (!email.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.trim())) {
    showError('Please enter a valid email address.'); return;
  }
  if (!phone.trim() || !/^[0-9]{10}$/.test(phone.trim())) {
    showError('Please enter a valid 10-digit phone number.'); return;
  }
  if (!location) {
    showError('Please select your area.'); return;
  }
  if (!address.trim()) {
    showError('Please enter your pickup address.'); return;
  }
  if (!date) {
    showError('Please choose a preferred pickup date.'); return;
  }

  // ── 3. Start loading ─────────────────────────────────────────────────────
  setLoading(true);

  // ── 4. Clear cart, then add donation product with pickup details ─────────
  fetch('/cart/clear.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  })
  .then(function() {
    return fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id: variantId,
        quantity: 1,
        properties: {
          'Donor Name':       name.trim(),
          'Email':            email.trim(),
          'Phone':            phone.trim(),
          'Pickup Area':      location,
          'Pickup Address':   address.trim(),
          'Pickup Date':      date,
          'Time Slot':        time,
          'Clothes Count':    clothesCount,
          'Special Notes':    notes.trim() || '—'
        }
      })
    });
  })
  .then(function(res) {
    if (!res.ok) {
      return res.json().then(function(d) {
        throw new Error(d.description || 'Failed to add to cart.');
      });
    }
    return res.json();
  })
  .then(function() {
    // ── 5. Redirect straight to checkout ────────────────────────────────
    window.location.href = '/checkout';
  })
  .catch(function(err) {
    setLoading(false);
    showError(err.message || 'Something went wrong. Please try again.');
  });
}
</script>

{% schema %}
{
  "name": "Donate Clothes",
  "settings": [],
  "presets": [
    {
      "name": "Donate Clothes"
    }
  ]
}
{% endschema %}
