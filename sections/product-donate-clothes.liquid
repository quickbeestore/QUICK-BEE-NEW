<style>
/* ═══════════════════════════════════════════════════════
   CLOTHES DONATION — EMOTIONAL UI
   KapadaWash × Nepal Youth Club × QuickBee
═══════════════════════════════════════════════════════ */
:root {
  --dc-green:   #10B981;
  --dc-green2:  #059669;
  --dc-glow:    rgba(16,185,129,0.18);
  --dc-gold:    #F4B400;
  --dc-bg:      var(--theme-bg-primary,  #080808);
  --dc-surface: var(--theme-bg-secondary, #141414);
  --dc-s2:      #1c1c1c;
  --dc-border:  var(--theme-border, #222);
  --dc-text:    var(--theme-text-main, #F9FAFB);
  --dc-muted:   var(--theme-text-muted, #9CA3AF);
  --dc-r:       16px;
  --dc-ease:    cubic-bezier(0.4,0,0.2,1);
}
*{box-sizing:border-box;}

.dc-wrap {
  font-family: -apple-system, BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  background: var(--dc-bg);
  color: var(--dc-text);
  min-height: 100vh;
  padding-bottom: 80px;
}

/* ── HERO ── */
.dc-hero {
  position: relative; overflow: hidden;
  padding: 44px 20px 56px;
  text-align: center;
  background: linear-gradient(160deg,rgba(16,185,129,.08) 0%,var(--dc-bg) 55%,rgba(244,180,0,.04) 100%);
  border-bottom: 1px solid var(--dc-border);
}
.dc-hero::before {
  content:''; position:absolute; top:-80px; left:50%; transform:translateX(-50%);
  width:560px; height:560px; pointer-events:none;
  background:radial-gradient(circle,rgba(16,185,129,.08) 0%,transparent 70%);
}
.dc-partners { display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:32px; flex-wrap:wrap; }
.dc-partner-logo {
  background:var(--dc-surface); border:1px solid var(--dc-border); border-radius:14px;
  padding:10px 18px; display:flex; align-items:center; justify-content:center;
  transition:transform .2s,box-shadow .2s;
}
.dc-partner-logo:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(16,185,129,.12); }
.dc-partner-logo img { height:38px; max-width:110px; object-fit:contain; display:block; }
.dc-collab-sep { font-size:22px; font-weight:200; color:var(--dc-muted); padding:0 4px; }
.dc-hero-badge {
  display:inline-flex; align-items:center; gap:6px;
  background:rgba(16,185,129,.1); border:1px solid rgba(16,185,129,.28);
  color:var(--dc-green); font-size:11px; font-weight:700;
  letter-spacing:1.4px; text-transform:uppercase;
  padding:5px 14px; border-radius:20px; margin-bottom:20px;
}
.dc-hero h1 {
  font-size:clamp(28px,5vw,48px); font-weight:900; line-height:1.15;
  letter-spacing:-.5px; margin:0 auto 16px; max-width:620px; color:var(--dc-text);
}
.dc-hero h1 span {
  background:linear-gradient(135deg,var(--dc-green),#34D399);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.dc-hero-sub { font-size:16px; color:var(--dc-muted); max-width:480px; margin:0 auto 32px; line-height:1.65; }
.dc-stats { display:flex; justify-content:center; gap:8px; flex-wrap:wrap; margin-top:8px; }
.dc-stat { background:var(--dc-surface); border:1px solid var(--dc-border); border-radius:12px; padding:12px 20px; min-width:100px; text-align:center; }
.dc-stat-num { font-size:22px; font-weight:900; color:var(--dc-green); line-height:1; }
.dc-stat-label { font-size:11px; color:var(--dc-muted); margin-top:4px; font-weight:500; }

/* ── STEPS ── */
.dc-steps-section { padding:44px 20px 0; max-width:900px; margin:0 auto; }
.dc-section-title {
  font-size:18px; font-weight:800; color:var(--dc-text);
  margin-bottom:20px; display:flex; align-items:center; gap:10px;
}
.dc-section-title::after { content:''; flex:1; height:1px; background:linear-gradient(90deg,var(--dc-green),transparent); }
.dc-steps { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; }
@media(min-width:640px){.dc-steps{grid-template-columns:repeat(4,1fr);gap:12px;}}
.dc-step {
  background:var(--dc-surface); border:1px solid var(--dc-border);
  border-radius:var(--dc-r); padding:18px 14px; text-align:center;
  position:relative; transition:border-color .2s,transform .2s;
}
.dc-step:hover { border-color:var(--dc-green); transform:translateY(-2px); }
.dc-step-num {
  position:absolute; top:-10px; left:50%; transform:translateX(-50%);
  background:var(--dc-green); color:#fff; width:22px; height:22px;
  border-radius:50%; font-size:11px; font-weight:900;
  display:flex; align-items:center; justify-content:center;
}
.dc-step-icon { font-size:30px; margin:8px 0 10px; }
.dc-step-label { font-size:12px; font-weight:700; color:var(--dc-text); margin-bottom:4px; }
.dc-step-desc { font-size:11px; color:var(--dc-muted); line-height:1.4; }

/* ── FORM SECTION WRAPPER ── */
.dc-form-outer { padding:40px 20px 0; max-width:900px; margin:0 auto; }

/* ── FORM CARD ── */
.dc-form-card {
  background:var(--dc-surface); border:1px solid var(--dc-border);
  border-radius:24px; overflow:hidden; position:relative;
  animation:dcFadeUp .5s var(--dc-ease) both;
}
@keyframes dcFadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

/* Animated rainbow top bar */
.dc-form-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg,#10B981,#34D399,#F4B400,#F472B6,#818CF8,#10B981);
  background-size:200% 100%; animation:dcRainbow 5s linear infinite;
}
@keyframes dcRainbow { 0%{background-position:0%} 100%{background-position:200%} }

/* Card header */
.dc-card-top {
  padding:36px 24px 28px; text-align:center;
  border-bottom:1px solid var(--dc-border);
  background:linear-gradient(180deg,rgba(16,185,129,.05) 0%,transparent 100%);
}
@media(min-width:640px){.dc-card-top{padding:40px 44px 32px;}}
.dc-card-emoji {
  display:block; font-size:52px; margin-bottom:14px;
  animation:dcFloat 3.5s ease-in-out infinite;
  filter:drop-shadow(0 4px 20px rgba(16,185,129,.3));
}
@keyframes dcFloat {
  0%,100%{transform:translateY(0) rotate(0deg)}
  33%{transform:translateY(-9px) rotate(-3deg)}
  66%{transform:translateY(-4px) rotate(3deg)}
}
.dc-card-top h2 { font-size:22px; font-weight:900; color:var(--dc-text); margin:0 0 8px; }
.dc-card-top p { font-size:14px; color:var(--dc-muted); line-height:1.6; max-width:400px; margin:0 auto; }

/* Form body */
.dc-form-body { padding:28px 20px; display:flex; flex-direction:column; }
@media(min-width:640px){.dc-form-body{padding:32px 36px;}}
@media(min-width:1024px){.dc-form-body{padding:36px 48px;}}

/* Error banner */
.dc-error {
  display:none; background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.25);
  border-radius:12px; padding:12px 16px; font-size:13px; color:#F87171;
  margin-bottom:24px; animation:dcShake .4s ease;
}
@keyframes dcShake {
  0%,100%{transform:translateX(0)} 20%{transform:translateX(-6px)}
  40%{transform:translateX(6px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)}
}

/* Form groups */
.dc-group { padding:24px 0; border-bottom:1px solid var(--dc-border); }
.dc-group:first-of-type { padding-top:0; }
.dc-group:last-of-type { border-bottom:none; padding-bottom:0; }

.dc-group-head { display:flex; align-items:center; gap:10px; margin-bottom:18px; }
.dc-group-num {
  width:26px; height:26px; border-radius:8px;
  background:rgba(16,185,129,.12); border:1px solid rgba(16,185,129,.3);
  color:var(--dc-green); font-size:11px; font-weight:900;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.dc-group-name { font-size:12px; font-weight:700; letter-spacing:1px; text-transform:uppercase; color:var(--dc-green); }
.dc-group-req { font-size:10px; color:#F472B6; font-weight:700; text-transform:uppercase; letter-spacing:.5px; margin-left:auto; }

/* Fields */
.dc-field { display:flex; flex-direction:column; gap:7px; }
.dc-row { display:grid; grid-template-columns:1fr; gap:14px; }
@media(min-width:600px){.dc-row{grid-template-columns:1fr 1fr;}}
.dc-label { font-size:12px; font-weight:700; color:var(--dc-muted); letter-spacing:.3px; }
.dc-req { color:#F472B6; }

.dc-input-wrap { position:relative; }
.dc-input-icon { position:absolute; left:14px; top:50%; transform:translateY(-50%); font-size:15px; pointer-events:none; user-select:none; }

.dc-input, .dc-textarea {
  width:100%; background:var(--dc-bg); border:1.5px solid var(--dc-border);
  border-radius:14px; padding:14px 16px; font-size:15px; color:var(--dc-text);
  outline:none; font-family:inherit; transition:border-color .2s,box-shadow .2s,background .15s;
  -webkit-appearance:none; appearance:none;
}
.dc-input-wrap .dc-input { padding-left:42px; }
.dc-input:focus,.dc-textarea:focus {
  border-color:var(--dc-green); box-shadow:0 0 0 3.5px var(--dc-glow); background:var(--dc-s2);
}
.dc-input::placeholder,.dc-textarea::placeholder { color:var(--dc-muted); opacity:.55; }
.dc-textarea { resize:none; min-height:92px; padding:14px 52px 14px 16px; }
.dc-textarea-plain { resize:none; min-height:88px; padding:14px 16px; }

/* GPS address */
.dc-addr-wrap { position:relative; }
.dc-gps-btn {
  position:absolute; top:10px; right:10px;
  width:38px; height:38px; border-radius:10px;
  background:rgba(16,185,129,.1); border:1.5px solid rgba(16,185,129,.3);
  color:var(--dc-green); font-size:16px; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  transition:all .2s; flex-shrink:0;
}
.dc-gps-btn:hover { background:rgba(16,185,129,.22); transform:scale(1.05); }
.dc-gps-btn.pulsing { animation:dcPulse 1.2s ease-in-out infinite; }
@keyframes dcPulse {
  0%,100%{box-shadow:0 0 0 0 rgba(16,185,129,.45)}
  50%{box-shadow:0 0 0 10px rgba(16,185,129,0)}
}
.dc-gps-status {
  margin-top:8px; font-size:12px; color:var(--dc-green); display:none;
  align-items:center; gap:6px; padding:9px 13px;
  background:rgba(16,185,129,.07); border:1px solid rgba(16,185,129,.18);
  border-radius:10px; line-height:1.5;
}
.dc-gps-status.on { display:flex; animation:dcSlideDown .25s var(--dc-ease); }
.dc-gps-status.err { color:#F87171; background:rgba(248,113,113,.07); border-color:rgba(248,113,113,.2); }
@keyframes dcSlideDown { from{opacity:0;transform:translateY(-5px)} to{opacity:1;transform:translateY(0)} }

/* Area pills */
.dc-area-row { display:flex; gap:8px; flex-wrap:wrap; }
.dc-area-pill {
  flex:1; min-width:90px; padding:11px 14px;
  border:1.5px solid var(--dc-border); border-radius:12px;
  font-size:13px; font-weight:600; color:var(--dc-muted);
  cursor:pointer; text-align:center;
  transition:all .18s var(--dc-ease); background:var(--dc-bg); user-select:none;
}
.dc-area-pill:hover { border-color:rgba(16,185,129,.5); color:var(--dc-green); }
.dc-area-pill.on { border-color:var(--dc-green); background:rgba(16,185,129,.1); color:var(--dc-green); font-weight:800; }

/* ── DATE PICKER ── */
.dc-date-scroll-outer {
  overflow-x:auto; -webkit-overflow-scrolling:touch;
  padding:4px 2px 12px; scrollbar-width:none; position:relative;
}
.dc-date-scroll-outer::-webkit-scrollbar { display:none; }
/* Fade hint on right edge */
.dc-date-scroll-outer::after {
  content:''; position:absolute; top:0; right:0; bottom:12px; width:40px;
  background:linear-gradient(90deg,transparent,var(--dc-surface));
  pointer-events:none;
}
.dc-date-scroll { display:flex; gap:8px; width:max-content; padding:2px 0; }

.dc-day {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  width:64px; min-height:88px; flex-shrink:0;
  border:1.5px solid var(--dc-border); border-radius:18px;
  cursor:pointer; background:var(--dc-bg); user-select:none;
  transition:all .22s var(--dc-ease); gap:2px; padding:10px 0;
}
.dc-day:hover { border-color:rgba(16,185,129,.5); transform:translateY(-3px); box-shadow:0 6px 16px rgba(0,0,0,.2); }
.dc-day.on {
  border-color:var(--dc-green); background:rgba(16,185,129,.1);
  transform:translateY(-4px); box-shadow:0 10px 24px rgba(16,185,129,.22);
}
.dc-day-wd { font-size:9px; font-weight:700; letter-spacing:1px; text-transform:uppercase; color:var(--dc-muted); }
.dc-day.on .dc-day-wd { color:var(--dc-green); }
.dc-day-d { font-size:26px; font-weight:900; color:var(--dc-text); line-height:1.1; }
.dc-day.on .dc-day-d { color:var(--dc-green); }
.dc-day-mo { font-size:9px; color:var(--dc-muted); font-weight:600; text-transform:uppercase; letter-spacing:.5px; }
.dc-day.on .dc-day-mo { color:var(--dc-green); opacity:.8; }

/* ── TIME SLOTS ── */
.dc-time-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
@media(max-width:360px){.dc-time-grid{gap:6px;}}

.dc-time-card {
  position:relative; overflow:hidden;
  border:1.5px solid var(--dc-border); border-radius:18px;
  padding:20px 10px 16px; cursor:pointer;
  background:var(--dc-bg); text-align:center; user-select:none;
  transition:all .25s var(--dc-ease);
}
.dc-time-card:hover { transform:translateY(-3px); }
.dc-time-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  border-radius:2px 2px 0 0; opacity:0; transition:opacity .25s;
}
.dc-time-card[data-s="m"]::before { background:linear-gradient(90deg,#FBBF24,#FDE68A); }
.dc-time-card[data-s="a"]::before { background:linear-gradient(90deg,#FB923C,#FED7AA); }
.dc-time-card[data-s="e"]::before { background:linear-gradient(90deg,#818CF8,#C4B5FD); }
.dc-time-card.on::before { opacity:1; }
.dc-time-card.on { transform:translateY(-4px); }
.dc-time-card[data-s="m"].on { border-color:#FBBF24; box-shadow:0 10px 28px rgba(251,191,36,.2); background:rgba(251,191,36,.05); }
.dc-time-card[data-s="a"].on { border-color:#FB923C; box-shadow:0 10px 28px rgba(251,146,60,.2); background:rgba(251,146,60,.05); }
.dc-time-card[data-s="e"].on { border-color:#818CF8; box-shadow:0 10px 28px rgba(129,140,248,.22); background:rgba(129,140,248,.06); }

.dc-time-emoji { font-size:30px; margin-bottom:8px; display:block; transition:transform .3s var(--dc-ease); }
.dc-time-card:hover .dc-time-emoji, .dc-time-card.on .dc-time-emoji { transform:scale(1.18); }
.dc-time-name { font-size:13px; font-weight:800; color:var(--dc-text); margin-bottom:3px; }
.dc-time-range { font-size:10px; color:var(--dc-muted); margin-bottom:3px; }
.dc-time-vibe { font-size:10px; color:var(--dc-muted); opacity:.6; font-style:italic; }
.dc-time-card[data-s="m"].on .dc-time-name,.dc-time-card[data-s="m"].on .dc-time-range { color:#FBBF24; }
.dc-time-card[data-s="a"].on .dc-time-name,.dc-time-card[data-s="a"].on .dc-time-range { color:#FB923C; }
.dc-time-card[data-s="e"].on .dc-time-name,.dc-time-card[data-s="e"].on .dc-time-range { color:#A5B4FC; }

/* ── CLOTHES COUNT ── */
.dc-count-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }
@media(max-width:480px){.dc-count-grid{grid-template-columns:repeat(2,1fr);}}

.dc-count-card {
  border:1.5px solid var(--dc-border); border-radius:16px;
  padding:16px 10px; text-align:center; cursor:pointer;
  background:var(--dc-bg); user-select:none;
  transition:all .22s var(--dc-ease);
}
.dc-count-card:hover { border-color:rgba(16,185,129,.5); transform:translateY(-2px); }
.dc-count-card.on { border-color:var(--dc-green); background:rgba(16,185,129,.1); transform:translateY(-3px); box-shadow:0 8px 20px rgba(16,185,129,.15); }
.dc-count-icon { font-size:24px; margin-bottom:8px; display:block; transition:transform .25s; }
.dc-count-card:hover .dc-count-icon { transform:scale(1.15) rotate(-5deg); }
.dc-count-card.on .dc-count-icon { transform:scale(1.2); }
.dc-count-range { font-size:14px; font-weight:900; color:var(--dc-text); }
.dc-count-card.on .dc-count-range { color:var(--dc-green); }
.dc-count-sub { font-size:10px; color:var(--dc-muted); margin-top:3px; }

/* ── SUBMIT WRAP ── */
.dc-submit-wrap {
  padding:28px 20px 36px; border-top:1px solid var(--dc-border);
  background:linear-gradient(0deg,rgba(16,185,129,.03),transparent);
}
@media(min-width:640px){.dc-submit-wrap{padding:28px 36px 40px;}}
@media(min-width:1024px){.dc-submit-wrap{padding:28px 48px 44px;}}

.dc-submit-btn {
  width:100%; padding:18px 28px;
  background:linear-gradient(135deg,#10B981 0%,#059669 50%,#10B981 100%);
  background-size:200% 100%;
  color:#fff !important; font-size:16px; font-weight:900;
  border:none; border-radius:16px; cursor:pointer;
  display:flex; align-items:center; justify-content:center; gap:10px;
  position:relative; overflow:hidden; letter-spacing:.3px;
  transition:transform .25s var(--dc-ease),box-shadow .25s;
  box-shadow:0 8px 28px rgba(16,185,129,.4);
  animation:dcBtnShift 4s ease infinite;
}
@keyframes dcBtnShift { 0%,100%{background-position:0%} 50%{background-position:100%} }
.dc-submit-btn::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.08),transparent);
  transform:translateX(-100%); transition:transform .6s;
}
.dc-submit-btn:hover::after { transform:translateX(100%); }
.dc-submit-btn:hover { transform:translateY(-3px); box-shadow:0 14px 40px rgba(16,185,129,.5); }
.dc-submit-btn:active { transform:translateY(0); }
.dc-submit-btn:disabled { opacity:.65; cursor:not-allowed; transform:none; animation:none; }

.dc-btn-loader {
  display:none; width:18px; height:18px; flex-shrink:0;
  border:2.5px solid rgba(255,255,255,.3); border-top-color:#fff;
  border-radius:50%; animation:dcSpin .8s linear infinite;
}
@keyframes dcSpin { to{transform:rotate(360deg)} }

.dc-submit-note {
  text-align:center; font-size:12px; color:var(--dc-muted);
  margin-top:12px; display:flex; align-items:center; justify-content:center; gap:5px;
}

/* ── FOOTER STRIP ── */
.dc-footer-outer { padding:28px 20px 0; max-width:900px; margin:0 auto; }
.dc-footer-box {
  border:1px solid var(--dc-border); border-radius:var(--dc-r); background:var(--dc-surface);
  display:flex; flex-direction:column; gap:12px; align-items:center; text-align:center; padding:24px 20px;
}
@media(min-width:640px){.dc-footer-box{flex-direction:row;text-align:left;padding:20px 28px;}}
.dc-footer-icon { font-size:32px; flex-shrink:0; }
.dc-footer-txt { font-size:13px; color:var(--dc-muted); line-height:1.6; }
.dc-footer-txt strong { color:var(--dc-green); }

/* ── LIGHT MODE ── */
html:not([data-theme="dark"]) .dc-wrap { background:#F5F7FA; color:#111; }
html:not([data-theme="dark"]) .dc-hero { background:linear-gradient(160deg,rgba(16,185,129,.05) 0%,#F5F7FA 55%); }
html:not([data-theme="dark"]) .dc-surface,
html:not([data-theme="dark"]) .dc-partner-logo,
html:not([data-theme="dark"]) .dc-stat,
html:not([data-theme="dark"]) .dc-step,
html:not([data-theme="dark"]) .dc-form-card,
html:not([data-theme="dark"]) .dc-footer-box { background:#fff; border-color:#E5E7EB; }
html:not([data-theme="dark"]) .dc-card-top { background:rgba(16,185,129,.03); }
html:not([data-theme="dark"]) .dc-input,
html:not([data-theme="dark"]) .dc-textarea,
html:not([data-theme="dark"]) .dc-day,
html:not([data-theme="dark"]) .dc-time-card,
html:not([data-theme="dark"]) .dc-count-card,
html:not([data-theme="dark"]) .dc-area-pill { background:#F9FAFB; border-color:#E5E7EB; }
html:not([data-theme="dark"]) .dc-input,
html:not([data-theme="dark"]) .dc-textarea { color:#111827; }
html:not([data-theme="dark"]) .dc-card-top h2,
html:not([data-theme="dark"]) .dc-group-title,
html:not([data-theme="dark"]) .dc-section-title,
html:not([data-theme="dark"]) .dc-step-label,
html:not([data-theme="dark"]) .dc-day-d,
html:not([data-theme="dark"]) .dc-time-name,
html:not([data-theme="dark"]) .dc-count-range,
html:not([data-theme="dark"]) .dc-hero h1 { color:#111827; }
html:not([data-theme="dark"]) .dc-submit-wrap { background:rgba(16,185,129,.02); }
</style>

<div class="dc-wrap">

  <!-- ── HERO ── -->
  <div class="dc-hero">
    <div class="dc-partners">
      <div class="dc-partner-logo">
        <img src="{{ 'kapadawash.png' | asset_url }}" alt="KapadaWash">
      </div>
      <span class="dc-collab-sep">×</span>
