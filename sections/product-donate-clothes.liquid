/* ═══════════════════════════════════════════════════
   CLOTHES DONATION — PREMIUM PRODUCT TEMPLATE
   KapadaWash × Nepal Youth Club × QuickBee
═══════════════════════════════════════════════════ */
:root {
  --dc-green:     #10B981;
  --dc-green2:    #059669;
  --dc-green-glow: rgba(16,185,129,0.18);
  --dc-gold:      #F4B400;
  --dc-pink:      #F472B6;
  --dc-bg:        var(--theme-bg-primary, #0A0A0A);
  --dc-surface:   var(--theme-bg-secondary, #1E1E1E);
  --dc-border:    var(--theme-border, #2a2a2a);
  --dc-text:      var(--theme-text-main, #F9FAFB);
  --dc-muted:     var(--theme-text-muted, #9CA3AF);
  --dc-radius:    16px;
  --dc-ease:      cubic-bezier(0.4, 0, 0.2, 1);
}

* { box-sizing: border-box; }

.dc-wrap {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: var(--dc-bg);
  color: var(--dc-text);
  min-height: 100vh;
  padding-bottom: 80px;
}

/* ── HERO ── */
.dc-hero {
  position: relative;
  overflow: hidden;
  padding: 40px 20px 52px;
  text-align: center;
  background: linear-gradient(160deg,
    rgba(16,185,129,0.08) 0%,
    var(--dc-bg) 55%,
    rgba(244,180,0,0.05) 100%);
  border-bottom: 1px solid var(--dc-border);
}

.dc-hero::before {
  content: '';
  position: absolute;
  top: -80px; left: 50%;
  transform: translateX(-50%);
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(16,185,129,0.1) 0%, transparent 70%);
  pointer-events: none;
}

/* Partner logos row */
.dc-partners {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}

.dc-partner-logo {
  background: var(--dc-surface);
  border: 1px solid var(--dc-border);
  border-radius: 14px;
  padding: 10px 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s var(--dc-ease), box-shadow 0.2s;
}
.dc-partner-logo:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(16,185,129,0.15);
}
.dc-partner-logo img {
  height: 38px;
  max-width: 110px;
  object-fit: contain;
  display: block;
}

.dc-collab-sep {
  font-size: 22px;
  font-weight: 200;
  color: var(--dc-muted);
  line-height: 1;
  padding: 0 4px;
}

/* Heading */
.dc-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(16,185,129,0.12);
  border: 1px solid rgba(16,185,129,0.3);
  color: var(--dc-green);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 20px;
  margin-bottom: 20px;
}

.dc-hero h1 {
  font-size: clamp(28px, 5vw, 48px);
  font-weight: 900;
  line-height: 1.15;
  letter-spacing: -0.5px;
  margin: 0 auto 16px;
  max-width: 620px;
  color: var(--dc-text);
}
.dc-hero h1 span {
  background: linear-gradient(135deg, var(--dc-green), #34D399);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.dc-hero-sub {
  font-size: 16px;
  color: var(--dc-muted);
  max-width: 480px;
  margin: 0 auto 32px;
  line-height: 1.65;
}

/* Impact stats */
.dc-stats {
  display: flex;
  justify-content: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 8px;
}
.dc-stat {
  background: var(--dc-surface);
  border: 1px solid var(--dc-border);
  border-radius: 12px;
  padding: 12px 20px;
  min-width: 100px;
  text-align: center;
}
.dc-stat-num {
  font-size: 22px;
  font-weight: 900;
  color: var(--dc-green);
  line-height: 1;
}
.dc-stat-label {
  font-size: 11px;
  color: var(--dc-muted);
  margin-top: 4px;
  font-weight: 500;
}

/* ── HOW IT WORKS ── */
.dc-steps-section {
  padding: 44px 20px 0;
  max-width: 900px;
  margin: 0 auto;
}
.dc-section-title {
  font-size: 18px;
  font-weight: 800;
  color: var(--dc-text);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.dc-section-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, var(--dc-green), transparent);
}

.dc-steps {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}
@media(min-width: 640px) { .dc-steps { grid-template-columns: repeat(4, 1fr); gap: 12px; } }

.dc-step {
  background: var(--dc-surface);
  border: 1px solid var(--dc-border);
  border-radius: var(--dc-radius);
  padding: 18px 14px;
  text-align: center;
  position: relative;
  transition: border-color 0.2s, transform 0.2s;
}
.dc-step:hover { border-color: var(--dc-green); transform: translateY(-2px); }

.dc-step-num {
  position: absolute;
  top: -10px; left: 50%;
  transform: translateX(-50%);
  background: var(--dc-green);
  color: #fff;
  width: 22px; height: 22px;
  border-radius: 50%;
  font-size: 11px;
  font-weight: 900;
  display: flex; align-items: center; justify-content: center;
}
.dc-step-icon { font-size: 30px; margin: 8px 0 10px; }
.dc-step-label {
  font-size: 12px;
  font-weight: 700;
  color: var(--dc-text);
  margin-bottom: 4px;
}
.dc-step-desc {
  font-size: 11px;
  color: var(--dc-muted);
  line-height: 1.4;
}

/* ── FORM ── */
.dc-form-section {
  padding: 36px 20px 0;
  max-width: 900px;
  margin: 0 auto;
}

.dc-form-card {
  background: var(--dc-surface);
  border: 1px solid var(--dc-border);
  border-radius: 20px;
  padding: 28px 20px;
  position: relative;
  overflow: hidden;
}
.dc-form-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--dc-green), #34D399, var(--dc-gold));
}
@media(min-width: 640px) { .dc-form-card { padding: 36px 32px; } }
@media(min-width: 1024px) { .dc-form-card { padding: 44px 48px; } }

.dc-form-header {
  margin-bottom: 28px;
}
.dc-form-header h2 {
  font-size: 20px;
  font-weight: 900;
  color: var(--dc-text);
  margin: 0 0 6px;
}
.dc-form-header p {
  font-size: 14px;
  color: var(--dc-muted);
}

/* Field groups */
.dc-form { display: flex; flex-direction: column; gap: 18px; }

.dc-field-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}
@media(min-width: 600px) { .dc-field-row { grid-template-columns: 1fr 1fr; } }

.dc-field { display: flex; flex-direction: column; gap: 7px; }

.dc-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--dc-text);
  display: flex;
  align-items: center;
  gap: 6px;
}
.dc-label-icon { font-size: 14px; }
.dc-required { color: #F472B6; margin-left: 2px; }

.dc-input,
.dc-select,
.dc-textarea {
  width: 100%;
  background: var(--dc-bg);
  border: 1.5px solid var(--dc-border);
  border-radius: 12px;
  padding: 13px 16px;
  font-size: 15px;
  color: var(--dc-text);
  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  outline: none;
  -webkit-appearance: none;
  appearance: none;
  font-family: inherit;
}
.dc-textarea {
  min-height: 100px;
  resize: vertical;
}
.dc-input:focus,
.dc-select:focus,
.dc-textarea:focus {
  border-color: var(--dc-green);
  box-shadow: 0 0 0 3px var(--dc-green-glow);
  background: var(--dc-surface);
}
.dc-input::placeholder,
.dc-textarea::placeholder { color: var(--dc-muted); }

/* Clothes count pills */
.dc-count-group {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.dc-count-pill {
  flex: 1;
  min-width: 80px;
  text-align: center;
  padding: 10px 8px;
  border: 1.5px solid var(--dc-border);
  border-radius: 10px;
  font-size: 13px;
  font-weight: 600;
  color: var(--dc-muted);
  cursor: pointer;
  transition: all 0.18s var(--dc-ease);
  background: var(--dc-bg);
  user-select: none;
}
.dc-count-pill:hover { border-color: var(--dc-green); color: var(--dc-green); }
.dc-count-pill.selected {
  border-color: var(--dc-green);
  background: rgba(16,185,129,0.1);
  color: var(--dc-green);
  font-weight: 800;
}
.dc-count-pill input[type="radio"] { display: none; }

/* Submit button */
.dc-submit-btn {
  width: 100%;
  padding: 16px 24px;
  background: linear-gradient(135deg, var(--dc-green), var(--dc-green2));
  color: #fff !important;
  font-size: 16px;
  font-weight: 800;
  border: none;
  border-radius: 14px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: all 0.25s var(--dc-ease);
  box-shadow: 0 6px 20px rgba(16,185,129,0.35);
  margin-top: 8px;
  letter-spacing: 0.3px;
}
.dc-submit-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(16,185,129,0.45);
  filter: brightness(1.05);
}
.dc-submit-btn:active { transform: translateY(0); }
.dc-submit-btn:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

.dc-btn-loader {
  display: none;
  width: 18px; height: 18px;
  border: 2.5px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: dc-spin 0.8s linear infinite;
}
@keyframes dc-spin { to { transform: rotate(360deg); } }

/* ── SUCCESS ── */
.dc-success {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 52px 20px;
  gap: 16px;
  animation: dc-fadeUp 0.5s var(--dc-ease) forwards;
}
@keyframes dc-fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
.dc-success-icon {
  width: 88px; height: 88px;
  background: rgba(16,185,129,0.12);
  border: 2px solid var(--dc-green);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
}
.dc-success h2 {
  font-size: 26px;
  font-weight: 900;
  color: var(--dc-text);
  margin: 0;
}
.dc-success p {
  font-size: 15px;
  color: var(--dc-muted);
  max-width: 400px;
  line-height: 1.6;
  margin: 0;
}
.dc-success-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
  width: 100%;
  max-width: 320px;
  margin-top: 8px;
}
.dc-action-btn {
  padding: 14px 24px;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.2s;
  border: none;
}
.dc-action-btn.primary {
  background: linear-gradient(135deg, var(--dc-green), var(--dc-green2));
  color: #fff !important;
  box-shadow: 0 4px 16px rgba(16,185,129,0.3);
}
.dc-action-btn.secondary {
  background: var(--dc-surface);
  border: 1.5px solid var(--dc-border);
  color: var(--dc-text) !important;
}
.dc-action-btn:hover { transform: translateY(-1px); }

/* ── FOOTER INFO ── */
.dc-footer-info {
  max-width: 900px;
  margin: 36px auto 0;
  padding: 24px 20px;
  border: 1px solid var(--dc-border);
  border-radius: var(--dc-radius);
  background: var(--dc-surface);
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: center;
  text-align: center;
}
@media(min-width: 640px) {
  .dc-footer-info { flex-direction: row; text-align: left; padding: 20px 28px; }
}
.dc-footer-emoji { font-size: 32px; flex-shrink: 0; }
.dc-footer-text {
  font-size: 13px;
  color: var(--dc-muted);
  line-height: 1.6;
}
.dc-footer-text strong { color: var(--dc-green); }

/* ── LIGHT MODE ── */
html:not([data-theme="dark"]) .dc-wrap { background: #F8FAFC; color: #111; }
html:not([data-theme="dark"]) .dc-hero { background: linear-gradient(160deg, rgba(16,185,129,0.06) 0%, #F8FAFC 55%); }
html:not([data-theme="dark"]) .dc-surface,
html:not([data-theme="dark"]) .dc-partner-logo,
html:not([data-theme="dark"]) .dc-stat,
html:not([data-theme="dark"]) .dc-step,
html:not([data-theme="dark"]) .dc-form-card,
html:not([data-theme="dark"]) .dc-footer-info { background: #fff; border-color: #E5E7EB; }
html:not([data-theme="dark"]) .dc-input,
html:not([data-theme="dark"]) .dc-select,
html:not([data-theme="dark"]) .dc-textarea { background: #F9FAFB; border-color: #D1D5DB; color: #111; }
html:not([data-theme="dark"]) .dc-count-pill { background: #F9FAFB; border-color: #D1D5DB; color: #6B7280; }
html:not([data-theme="dark"]) .dc-label,
html:not([data-theme="dark"]) .dc-step-label,
html:not([data-theme="dark"]) .dc-form-header h2,
html:not([data-theme="dark"]) .dc-section-title,
html:not([data-theme="dark"]) .dc-hero h1 { color: #111827; }
html:not([data-theme="dark"]) .dc-hero-sub,
html:not([data-theme="dark"]) .dc-step-desc,
html:not([data-theme="dark"]) .dc-stat-label,
html:not([data-theme="dark"]) .dc-form-header p,
html:not([data-theme="dark"]) .dc-footer-text { color: #6B7280; }
</style>

