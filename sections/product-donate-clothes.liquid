<script>
/* ── DATE PICKER ─────────────────────────────────────── */
(function buildDatePicker() {
  var scroll = document.getElementById('dcDateScroll');
  if (!scroll) return;
  var days  = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var today = new Date(); today.setHours(0,0,0,0);
  for (var i = 1; i <= 21; i++) {
    var d = new Date(today); d.setDate(today.getDate() + i);
    var card = document.createElement('div');
    card.className = 'dc-day';
    card.dataset.val = d.toISOString().split('T')[0];
    card.innerHTML =
      '<span class="dc-day-wd">' + days[d.getDay()] + '</span>' +
      '<span class="dc-day-d">'  + d.getDate()       + '</span>' +
      '<span class="dc-day-mo">' + months[d.getMonth()] + '</span>';
    card.addEventListener('click', function() {
      document.querySelectorAll('.dc-day').forEach(function(c){ c.classList.remove('on'); });
      this.classList.add('on');
      document.getElementById('dc-date').value = this.dataset.val;
    });
    scroll.appendChild(card);
  }
})();

/* ── LIVE GPS LOCATION ───────────────────────────────── */
function dcDetectLocation() {
  var btn    = document.getElementById('dcGpsBtn');
  var status = document.getElementById('dcGpsStatus');
  var addrEl = document.getElementById('dc-address');
  if (!navigator.geolocation) {
    status.textContent = '❌ Geolocation not supported.';
    status.className = 'dc-gps-status on err'; return;
  }
  btn.classList.add('pulsing');
  status.textContent = '📡 Detecting your location…';
  status.className = 'dc-gps-status on';
  navigator.geolocation.getCurrentPosition(
    function(pos) {
      var lat = pos.coords.latitude, lon = pos.coords.longitude;
      fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat='+lat+'&lon='+lon+'&accept-language=en')
        .then(function(r){ return r.json(); })
        .then(function(data) {
          btn.classList.remove('pulsing');
          var a = data.address || {};
          var parts = [
            a.road || a.pedestrian || a.residential || a.footway,
            a.suburb || a.neighbourhood || a.village || a.quarter,
            a.city_district
          ].filter(Boolean);
          addrEl.value = parts.length ? parts.join(', ') : (data.display_name||'').split(',').slice(0,3).join(', ');
          // auto-select area
          var dn = (data.display_name||'').toLowerCase();
          var area = dn.includes('lalitpur')||dn.includes('patan') ? 'Lalitpur' :
                     dn.includes('bhaktapur') ? 'Bhaktapur' : 'Kathmandu';
          document.querySelectorAll('.dc-area-pill').forEach(function(p){ p.classList.remove('on'); });
          var target = document.querySelector('.dc-area-pill[data-area="'+area+'"]');
          if (target) target.classList.add('on');
          document.getElementById('dc-location').value = area;
          status.innerHTML = '✅ Location found! You can edit the address if needed.';
          status.className = 'dc-gps-status on';
        })
        .catch(function() {
          btn.classList.remove('pulsing');
          status.textContent = '⚠️ Couldn\'t fetch address. Please type manually.';
          status.className = 'dc-gps-status on err';
        });
    },
    function(err) {
      btn.classList.remove('pulsing');
      status.textContent = err.code===1 ? '❌ Location access denied. Please type your address.' : '❌ Location unavailable.';
      status.className = 'dc-gps-status on err';
    },
    { timeout: 10000, enableHighAccuracy: true }
  );
}

/* ── SELECTOR HELPERS ────────────────────────────────── */
function dcSelectArea(el) {
  document.querySelectorAll('.dc-area-pill').forEach(function(p){ p.classList.remove('on'); });
  el.classList.add('on');
  document.getElementById('dc-location').value = el.dataset.area;
}
function dcSelectTime(el) {
  document.querySelectorAll('.dc-time-card').forEach(function(c){ c.classList.remove('on'); });
  el.classList.add('on');
  document.getElementById('dc-time').value = el.dataset.val;
}
function dcSelectCount(el) {
  document.querySelectorAll('.dc-count-card').forEach(function(c){ c.classList.remove('on'); });
  el.classList.add('on');
  document.getElementById('dc-clothes-count').value = el.dataset.val;
}

/* ── SUBMIT → CART → CHECKOUT ───────────────────────── */
function dcSubmitPickup(variantId) {
  var errorEl  = document.getElementById('dcError');
  var btnText  = document.getElementById('dcBtnText');
  var btnLoader= document.getElementById('dcBtnLoader');
  var submitBtn= document.getElementById('dcSubmitBtn');

  function showError(msg) {
    errorEl.innerHTML = '⚠️ ' + msg;
    errorEl.style.display = 'block';
    errorEl.style.animation = 'none'; errorEl.offsetHeight; errorEl.style.animation = '';
    errorEl.scrollIntoView({ behavior:'smooth', block:'center' });
  }
  function hideError() { errorEl.style.display='none'; errorEl.innerHTML=''; }
  function setLoading(on) {
    if (on) {
      btnText.textContent = 'Scheduling…';
      btnLoader.style.display = 'block';
      submitBtn.disabled = true;
    } else {
      btnText.textContent = '💚 Schedule My Donation Pickup';
      btnLoader.style.display = 'none';
      submitBtn.disabled = false;
    }
  }

  var name         = (document.getElementById('dc-name')         ||{}).value || '';
  var email        = (document.getElementById('dc-email')        ||{}).value || '';
  var location     = (document.getElementById('dc-location')     ||{}).value || '';
  var address      = (document.getElementById('dc-address')      ||{}).value || '';
  var date         = (document.getElementById('dc-date')         ||{}).value || '';
  var time         = (document.getElementById('dc-time')         ||{}).value || 'Morning (8AM–12PM)';
  var clothesCount = (document.getElementById('dc-clothes-count')||{}).value || '5–10 clothes';
  var notes        = (document.getElementById('dc-notes')        ||{}).value || '';

  hideError();
  if (!name.trim())    { showError('Please enter your full name.'); return; }
  if (!email.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.trim())) { showError('Please enter a valid email address.'); return; }
  if (!location)       { showError('Please select your area.'); return; }
  if (!address.trim()) { showError('Please enter your pickup address.'); return; }
  if (!date)           { showError('Please choose a pickup date from the calendar above.'); return; }

  setLoading(true);

  fetch('/cart/clear.js', { method:'POST', headers:{'Content-Type':'application/json'} })
  .then(function() {
    return fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        id: variantId, quantity: 1,
        properties: {
          'Donor Name':     name.trim(),
          'Email':          email.trim(),
          'Pickup Area':    location,
          'Pickup Address': address.trim(),
          'Pickup Date':    date,
          'Time Slot':      time,
          'Clothes Count':  clothesCount,
          'Special Notes':  notes.trim() || '—'
        }
      })
    });
  })
  .then(function(res) {
    if (!res.ok) return res.json().then(function(d){ throw new Error(d.description||'Failed to add to cart.'); });
    return res.json();
  })
  .then(function() { window.location.href = '/pages/payment'; })
  .catch(function(err) {
    setLoading(false);
    showError(err.message || 'Something went wrong. Please try again.');
  });
}
</script>

