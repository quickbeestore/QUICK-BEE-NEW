    <!-- SLIDE 5 — Express Delivery -->
    <a href="/collections/all" class="qbpb-slide qbpb-slide-5">
      <div class="qbpb-content">
        <div class="qbpb-eyebrow">⚡ QuickBee Promise</div>
        <div class="qbpb-title">20 MIN<br><em>DELIVERY</em></div>
        <div class="qbpb-subtitle">Across Kathmandu Valley<br>Use code <strong style="color:#FFD700">FREE28</strong> for free delivery</div>
        <span class="qbpb-badge">🐝 Shop Now</span>
      </div>
      <div class="qbpb-icon" style="animation-name:none;transform:translateY(-50%)">🛵</div>
    </a>

  </div>
  <div class="qbpb-progress" id="qbpbProgress"></div>
</div>
<div class="qbpb-dots" id="qbpbDots"></div>

<script>
(function(){
  var track    = document.getElementById('qbpbTrack');
  var dotsWrap = document.getElementById('qbpbDots');
  var progress = document.getElementById('qbpbProgress');
  if(!track) return;

  var slides  = track.querySelectorAll('.qbpb-slide');
  var total   = slides.length;
  var current = 0;
  var timer;

  /* Build dots */
  slides.forEach(function(_, i){
    var d = document.createElement('div');
    d.className = 'qbpb-dot' + (i===0?' act':'');
    d.addEventListener('click', function(){ goTo(i); resetTimer(); });
    dotsWrap.appendChild(d);
  });

  function goTo(idx){
    current = (idx + total) % total;
    track.style.transform = 'translateX(-'+current+'00%)';
    dotsWrap.querySelectorAll('.qbpb-dot').forEach(function(d,i){ d.classList.toggle('act', i===current); });
    /* Progress bar */
    if(progress){
      progress.classList.remove('running');
      progress.style.width = '0';
      void progress.offsetWidth; /* reflow */
      progress.classList.add('running');
    }
  }

  function next(){ goTo(current+1); }

  function resetTimer(){
    clearInterval(timer);
    timer = setInterval(next, 4200);
  }

  /* Touch swipe */
  var sx = 0;
  track.addEventListener('touchstart', function(e){ sx = e.touches[0].clientX; }, {passive:true});
  track.addEventListener('touchend', function(e){
    var dx = e.changedTouches[0].clientX - sx;
    if(Math.abs(dx) > 40){ dx < 0 ? next() : goTo(current-1); resetTimer(); }
  }, {passive:true});

  /* Click on slide stops propagation (already an <a>) */

  goTo(0);
  resetTimer();
})();
</script>

