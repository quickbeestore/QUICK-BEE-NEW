{%- comment -%}
  QuickBee — Code-Based Promotional Banner Carousel
  Pure CSS/HTML banners — no image files needed
  Fiery food promo style matching brand aesthetic
{%- endcomment -%}

<style>
/* ══════════════════════════════════════════════════
   PROMO BANNER CAROUSEL
   ══════════════════════════════════════════════════ */
.qbpb-outer {
  position: relative;
  overflow: hidden;
  margin: 0;
  touch-action: pan-y;
}

.qbpb-track {
  display: flex;
  transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}

/* ── Individual slide ─────────────────────────── */
.qbpb-slide {
  flex-shrink: 0;
  width: 100%;
  min-height: 180px;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  cursor: pointer;
  padding: 28px 22px 28px 28px;
  gap: 0;
}
@media (min-width: 480px) { .qbpb-slide { min-height: 200px; padding: 32px 28px; } }
@media (min-width: 768px) { .qbpb-slide { min-height: 220px; padding: 36px 40px; } }

/* ── BG gradients per slide ──────────────────── */
.qbpb-slide-1 { background: linear-gradient(135deg, #7a1200 0%, #c93100 35%, #e84e00 65%, #ff7a00 100%); }
.qbpb-slide-2 { background: linear-gradient(135deg, #5a0a0a 0%, #a01515 35%, #cc2222 65%, #e83a00 100%); }
.qbpb-slide-3 { background: linear-gradient(135deg, #1a1a00 0%, #4a3500 35%, #7a5500 65%, #c48c00 100%); }
.qbpb-slide-4 { background: linear-gradient(135deg, #3a1800 0%, #6b2e00 35%, #a04800 65%, #c86000 100%); }
.qbpb-slide-5 { background: linear-gradient(135deg, #001a3a 0%, #002d6b 40%, #003d8f 70%, #0055c8 100%); }

/* ── Animated flame/glow bg ──────────────────── */
.qbpb-slide::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 70% at 80% 50%, rgba(255,200,50,0.18) 0%, transparent 65%),
              radial-gradient(circle 200px at 20% 100%, rgba(255,100,0,0.2) 0%, transparent 60%);
  pointer-events: none;
  animation: qbpbGlow 3s ease-in-out infinite alternate;
}
@keyframes qbpbGlow {
  from { opacity: 0.8; }
  to   { opacity: 1.2; }
}

/* Smoke / particle effect */
.qbpb-slide::after {
  content: '🔥';
  position: absolute;
  font-size: 120px;
  right: -10px; bottom: -20px;
  opacity: 0.07;
  transform: rotate(-15deg);
  pointer-events: none;
  animation: qbpbFloat 4s ease-in-out infinite;
}
.qbpb-slide-5::after { content: '⚡'; }
@keyframes qbpbFloat {
  0%,100% { transform: rotate(-15deg) translateY(0); }
  50%     { transform: rotate(-10deg) translateY(-10px); }
}

/* ── Left content ─────────────────────────────── */
.qbpb-content {
  flex: 1;
  min-width: 0;
  position: relative;
  z-index: 2;
}
.qbpb-eyebrow {
  display: inline-flex; align-items: center; gap: 5px;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 100px;
  padding: 3px 10px;
  font-size: 9px; font-weight: 800;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: rgba(255,255,255,0.9);
  margin-bottom: 8px;
}
.qbpb-title {
  font-size: clamp(26px, 7vw, 52px);
  font-weight: 900;
  line-height: 1.0;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: -1px;
  margin-bottom: 4px;
  text-shadow: 0 2px 8px rgba(0,0,0,0.4);
}
.qbpb-title em {
  font-style: normal;
  color: #FFD700;
  display: block;
}
.qbpb-subtitle {
  font-size: clamp(11px, 2.5vw, 14px);
  color: rgba(255,255,255,0.8);
  line-height: 1.4;
  margin-bottom: 16px;
  font-weight: 500;
}
.qbpb-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: #FFD700;
  color: #1a0a00;
  font-size: clamp(11px, 2.5vw, 13px);
  font-weight: 900;
  padding: 8px 16px;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  transition: transform 0.18s, box-shadow 0.18s;
  text-decoration: none;
  animation: qbpbPulse 2s ease-in-out infinite;
}
@keyframes qbpbPulse {
  0%,100% { transform: scale(1); box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
  50%     { transform: scale(1.04); box-shadow: 0 6px 28px rgba(255,215,0,0.4); }
}
.qbpb-badge:hover { transform: scale(1.08) !important; }

/* ── Right food icon ─────────────────────────── */
.qbpb-icon {
  position: absolute;
  right: 16px; top: 50%;
  transform: translateY(-50%);
  font-size: clamp(72px, 16vw, 110px);
  line-height: 1;
  filter: drop-shadow(0 8px 24px rgba(0,0,0,0.35));
  animation: qbpbBounce 2.5s ease-in-out infinite;
  pointer-events: none;
  z-index: 2;
}
@media (max-width: 380px) { .qbpb-icon { font-size: 58px; right: 8px; } }
@keyframes qbpbBounce {
  0%,100% { transform: translateY(-50%) rotate(-5deg); }
  50%     { transform: translateY(calc(-50% - 8px)) rotate(3deg); }
}

/* Price tag badge */
.qbpb-price-tag {
  position: absolute;
  top: 16px; right: 16px;
  background: rgba(0,0,0,0.45);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 12px;
  padding: 6px 12px;
  text-align: center;
  z-index: 3;
}
.qbpb-price-tag .from { font-size: 8px; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 1px; display: block; }
.qbpb-price-tag .amt  { font-size: 20px; font-weight: 900; color: #FFD700; line-height: 1; }
.qbpb-price-tag .unit { font-size: 9px; color: rgba(255,255,255,0.7); }

/* ── DOTS ─────────────────────────────────────── */
.qbpb-dots {
  display: flex; justify-content: center; gap: 6px;
  padding: 10px 0 6px;
}
.qbpb-dot {
  width: 6px; height: 6px; border-radius: 3px;
  background: rgba(255,255,255,0.25);
  transition: all 0.3s;
  cursor: pointer;
}
.qbpb-dot.act {
  width: 22px;
  background: #F4B400;
}

/* Auto-play progress bar */
.qbpb-progress {
  position: absolute; bottom: 0; left: 0;
  height: 3px; width: 0;
  background: linear-gradient(90deg, #FFD700, #F4B400);
  z-index: 10;
  transition: none;
}
.qbpb-progress.running {
  width: 100%;
  transition: width 4s linear;
}
</style>

<!-- ════════════════════════════════════════════════
     PROMO BANNER CAROUSEL
     ════════════════════════════════════════════════ -->
<div class="qbpb-outer" id="qbpbOuter">
  <div class="qbpb-track" id="qbpbTrack">

    <!-- SLIDE 1 — Fried Chicken -->
    <a href="/collections/typical-taste" class="qbpb-slide qbpb-slide-1">
      <div class="qbpb-content">
        <div class="qbpb-eyebrow">🔥 Hot & Crispy</div>
        <div class="qbpb-title">FRIED<br><em>CHICKEN</em></div>
        <div class="qbpb-subtitle">Crispy on the outside,<br>juicy on the inside, every time.</div>
        <span class="qbpb-badge">🛒 Order Now</span>
      </div>
      <div class="qbpb-icon">🍗</div>
    </a>

    <!-- SLIDE 2 — Spicy Wings -->
    <a href="/collections/typical-taste" class="qbpb-slide qbpb-slide-2">
      <div class="qbpb-price-tag">
        <span class="from">Free</span>
        <span class="amt">Onion</span>
        <span class="unit">Ring</span>
      </div>
      <div class="qbpb-content">
        <div class="qbpb-eyebrow">🌶️ With Flavor Sauce</div>
        <div class="qbpb-title">SPICY<br><em>WINGS</em></div>
        <div class="qbpb-subtitle">Chili • Mayo • Cheese<br>Free Onion Ring with every order!</div>
        <span class="qbpb-badge">🛒 Order Now</span>
      </div>
      <div class="qbpb-icon">🍖</div>
    </a>

    <!-- SLIDE 3 — Triple Combo -->
    <a href="/collections/typical-taste" class="qbpb-slide qbpb-slide-3">
      <div class="qbpb-price-tag">
        <span class="from">Only</span>
        <span class="amt">789</span>
        <span class="unit">Rs</span>
      </div>
      <div class="qbpb-content">
        <div class="qbpb-eyebrow">⚡ Get 3 Burgers</div>
        <div class="qbpb-title">TRIPLE<br><em>COMBO</em></div>
        <div class="qbpb-subtitle">+Add on Coke<br>+Add on French Fries</div>
