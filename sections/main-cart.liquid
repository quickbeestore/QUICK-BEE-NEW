<!-- sections/main-cart.liquid -->
<cart-items-component class="qb-cart-component-final" data-section-id="{{ section.id }}">
  <div class="qb-cart-main-wrapper">
    {%- if cart.empty? -%}
      <!-- Empty Hive State -->
      <div class="qb-empty-hive-state animate-fade-in">
        <div class="qb-empty-bee-icon">🐝</div>
        <h1 class="qb-empty-h">Your Hive is Empty</h1>
        <p class="qb-empty-p">Time to fill your basket! Browse our collections to get started.</p>
        <a href="{{ routes.all_products_collection_url }}" class="qb-btn-explore-gold">Explore Collections</a>
      </div>
    {%- else -%}
      
      <!-- CART HEADER -->
      <div class="qb-cart-header-pro">
        <h1 class="qb-cart-title-pro">Review Order</h1>
        <span class="qb-badge-pro" ref="cartItemCount">{{ cart.item_count }} Items</span>
      </div>

      <div class="qb-cart-sections-stack">
        
        <!-- SECTION: SELECTED PRODUCTS -->
        <div class="qb-card-pro">
          <div class="qb-card-tag-row">
            <span class="qb-tag-text-pro">SELECTED PRODUCTS</span>
          </div>
          
          <div class="qb-items-pro-list">
            {%- for item in cart.items -%}
              <div class="qb-item-card-pro" ref="cartItemRows" data-key="{{ item.key }}">
                <div class="qb-item-visual-pro">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title | escape }}" loading="lazy">
                  {% else %}
                    <div class="qb-item-visual-fallback">🐝</div>
                  {% endif %}
                </div>
                
                <div class="qb-item-content-pro">
                  <div class="qb-item-top-pro">
                    <a href="{{ item.url }}" class="qb-item-title-pro">{{ item.product.title | truncate: 50 }}</a>
                    <!-- TOP-RIGHT REMOVE BUTTON -->
                    <form action="{{ routes.cart_change_url }}" method="post" class="qb-remove-form">
                      <input type="hidden" name="id" value="{{ item.key }}">
                      <input type="hidden" name="quantity" value="0">
                      <button type="submit" class="qb-item-remove-btn-pro" aria-label="Remove item">✕</button>
                    </form>
                  </div>
                  
                  {%- unless item.product.has_only_default_variant -%}
                    <div class="qb-item-variant-pro">{{ item.variant.title }}</div>
                  {%- endunless -%}

                  <div class="qb-item-footer-pro">
                    <div class="qb-item-price-pro">
                      <span class="qb-price-label-pro">Price</span>
                      <span class="qb-price-val-pro">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    </div>
                    
                    <!-- CENTERED QUANTITY PILL -->
                    <div class="qb-qty-control-pro" ref="quantitySelectors">
                      <form action="{{ routes.cart_change_url }}" method="post" class="qb-qty-flex-pro">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-qty-act-btn-pro" data-action="minus" data-qbtn>−</button>
                        <div class="qb-qty-num-wrapper">
                          <input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-qty-input-centered">
                        </div>
                        <button type="button" class="qb-qty-act-btn-pro" data-action="plus" data-qbtn>+</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          
          <a href="{{ routes.all_products_collection_url }}" class="qb-pro-add-items-link">+ Add more items</a>
        </div>

        <!-- SECTION: DELIVERY DESTINATION -->
        <div class="qb-card-pro">
          <div class="qb-card-tag-row qb-flex-between">
            <span class="qb-tag-text-pro">DELIVERY DESTINATION</span>
            <!-- PROFESSIONAL GUIDE BUTTON (Icon Only) -->
            <button type="button" class="qb-pro-help-icon-btn" id="openHelpBtn" aria-label="Tutorial">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </button>
          </div>
          
          <div class="qb-pro-input-field-frame">
            <div class="qb-pro-input-icon-pro">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <input type="text" id="LandmarkLink" placeholder="Paste Google Maps location link..." class="qb-pro-main-input-field" required>
          </div>
          
          <div class="qb-pro-nicknames-grid">
            <button type="button" class="qb-pro-chip-action" data-nickname="Home">🏠 Home</button>
            <button type="button" class="qb-pro-chip-action" data-nickname="Office">🏢 Office</button>
            <button type="button" class="qb-pro-chip-action" data-nickname="Other">✨ Other</button>
            <button type="button" class="qb-pro-chip-action" data-nickname="Current">📦 Current</button>
          </div>
        </div>

        <!-- SECTION: BILLING SUMMARY -->
        <div class="qb-card-pro">
          <!-- DYNAMIC VALIDATION ERROR -->
          <div id="qbCheckoutError" class="qb-pro-error-banner animate-fade-in active">
            <span class="qb-pro-warn-icon">⚠️</span>
            <p class="qb-pro-warn-msg">enter the google maps location link TO PROCEED CHECKOUT</p>
          </div>

          <div class="qb-card-tag-row">
            <span class="qb-tag-text-pro">BILLING SUMMARY</span>
          </div>
          <div class="qb-pro-bill-list">
            <div class="qb-pro-bill-item">
              <span>Item Total</span>
              <span>Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
            <div class="qb-pro-bill-item">
              <span>Delivery Fee</span>
              <span class="qb-pro-calc-text">Calculated at checkout</span>
            </div>
            <div class="qb-pro-bill-divider"></div>
            <div class="qb-pro-bill-total-row">
              <span class="qb-pro-total-lbl">Grand Total</span>
              <span class="qb-pro-total-val" ref="cartTotal">Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- STICKY FOOTER -->
      <div class="qb-sticky-checkout-bar-pro">
        <div class="qb-sticky-summary-block">
          <span class="qb-sticky-label-pro">PAYABLE AMOUNT</span>
          <span class="qb-sticky-val-pro">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-btn-main-checkout-pro qb-btn-disabled-pro" id="qbMainCheckoutBtn" disabled>
          Checkout ➔
        </button>
      </div>
    {%- endif -%}
  </div>
</cart-items-component>

<!-- ROBUST POP-OUT MODAL -->
<div id="landmarkModalOverlay" class="qb-portal-modal-layer">
  <div class="qb-portal-modal-card animate-slide-up">
    <div class="qb-portal-modal-notch"></div>
    <button class="qb-portal-modal-close-x" id="closeHelpBtn" type="button">✕</button>
    <div class="qb-portal-modal-inner">
      <h3 class="qb-portal-modal-h">How to share location?</h3>
      <p class="qb-portal-modal-p">Follow these steps to share your precise location via Google Maps.</p>
      <div class="qb-portal-modal-media-frame">
        <img src="{{ 'popupgoogle.png' | asset_url }}" alt="Tutorial" id="tutImg">
      </div>
      <div class="qb-portal-modal-actions">
        <a href="https://www.google.com/maps" target="_blank" class="qb-btn-maps-large-action">📍 Open Google Maps App</a>
        <button type="button" class="qb-btn-modal-got-it-action" id="doneHelpBtn">Got it!</button>
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    --qb-gold: #F4B400;
    --qb-gold-soft: #FFF9E6;
    --qb-black: #111111;
    --qb-gray: #757575;
    --qb-red: #C41E3A;
    --qb-bg: #F8F9FA;
    --qb-border: #EEEEEE;
    --qb-radius-lg: 24px;
    --qb-radius-md: 16px;
    --qb-shadow: 0 4px 20px rgba(0,0,0,0.06);
    --qb-ease: cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Body Scroll Lock Fix */
  html.qb-no-scroll { overflow: hidden !important; }

  /* Base UI */
  .qb-cart-component-final { display: block; background: var(--qb-bg); min-height: 100vh; padding-bottom: 160px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .qb-cart-main-wrapper { max-width: 500px; margin: 0 auto; background: #fff; min-height: 100vh; position: relative; }

  /* Header */
  .qb-cart-header-pro { padding: 30px 20px 20px; display: flex; justify-content: space-between; align-items: center; }
  .qb-cart-title-pro { font-size: 24px; font-weight: 900; color: var(--qb-black); margin: 0; }
  .qb-badge-pro { background: var(--qb-gold-soft); color: var(--qb-gold); font-size: 12px; font-weight: 800; padding: 4px 12px; border-radius: 20px; }

  /* Cards */
  .qb-cart-sections-stack { padding: 0 16px; display: flex; flex-direction: column; gap: 16px; }
  .qb-card-pro { background: #fff; border: 1px solid var(--qb-border); border-radius: var(--qb-radius-lg); padding: 20px; box-shadow: var(--qb-shadow); position: relative; }
  .qb-tag-text-pro { font-size: 10px; font-weight: 900; color: #BBB; letter-spacing: 1.5px; text-transform: uppercase; }

  /* Item Cards */
  .qb-items-pro-list { display: flex; flex-direction: column; gap: 20px; }
  .qb-item-card-pro { display: flex; gap: 16px; padding-bottom: 20px; border-bottom: 1.5px solid #F9F9F9; }
  .qb-item-card-pro:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .qb-item-visual-pro { width: 90px; height: 90px; border-radius: 14px; overflow: hidden; border: 1px solid #F0F0F0; flex-shrink: 0; background: #F9F9F9; }
  .qb-item-visual-pro img { width: 100%; height: 100%; object-fit: cover; }
  .qb-item-visual-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 32px; }

  .qb-item-content-pro { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; }
  .qb-item-top-pro { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
  .qb-item-title-pro { font-size: 15px; font-weight: 800; color: var(--qb-black); text-decoration: none; line-height: 1.4; }
  .qb-item-remove-btn-pro { background: #F5F5F5; border: none; color: #BBB; width: 26px; height: 26px; border-radius: 50%; cursor: pointer; transition: 0.2s; }
  .qb-item-remove-btn-pro:active { background: var(--qb-red); color: #fff; }
  .qb-item-variant-pro { font-size: 12px; color: var(--qb-gray); margin-top: 4px; font-weight: 600; }

  .qb-item-footer-pro { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 12px; }
  .qb-price-label-pro { font-size: 9px; font-weight: 800; color: #BBB; text-transform: uppercase; }
  .qb-price-val-pro { font-size: 17px; font-weight: 900; color: var(--qb-black); }

  /* Centered Quantity Pill */
  .qb-qty-control-pro { background: #F5F5F5; border-radius: 14px; padding: 2px; display: flex; width: 110px; }
  .qb-qty-flex-pro { display: flex; align-items: center; width: 100%; }
  .qb-qty-act-btn-pro { width: 34px; height: 34px; border: none; background: none; font-size: 20px; font-weight: 800; color: var(--qb-black); cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .qb-qty-num-wrapper { flex: 1; display: flex; align-items: center; justify-content: center; }
  .qb-qty-input-centered { width: 100%; border: none; background: transparent; text-align: center !important; font-size: 15px; font-weight: 900; color: var(--qb-black); pointer-events: none; padding: 0; margin: 0; }

  /* Info Trigger */
  .qb-pro-help-icon-btn { width: 32px; height: 32px; border-radius: 50%; background: #fff; border: 1.5px solid var(--qb-gold); color: var(--qb-gold); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 16px; cursor: pointer; box-shadow: 0 4px 12px rgba(244, 180, 0, 0.15); transition: 0.2s; }

  /* Professional Input box */
  .qb-pro-input-field-frame { display: flex; align-items: center; background: #F9F9F9; border: 1.5px solid var(--qb-border); border-radius: 18px; margin: 16px 0; transition: 0.3s; }
  .qb-pro-input-field-frame:focus-within { border-color: var(--qb-gold); background: #fff; box-shadow: 0 0 0 4px var(--qb-gold-soft); }
  .qb-pro-input-icon-pro { padding-left: 18px; color: var(--qb-gold); display: flex; align-items: center; }
  .qb-pro-main-input-field { flex: 1; padding: 18px 18px 18px 12px; background: transparent; border: none; font-size: 15px; font-weight: 700; color: var(--qb-black); outline: none; }

  .qb-pro-address-chips { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .qb-pro-chip-action { padding: 14px; background: #fff; border: 1.5px solid var(--qb-border); border-radius: 16px; font-size: 14px; font-weight: 800; color: var(--qb-gray); cursor: pointer; transition: 0.2s; }
  .qb-pro-chip-action.active { border-color: var(--qb-gold); background: var(--qb-gold-soft); color: var(--qb-gold); }

  /* Billing & Error Alert */
  .qb-pro-error-banner { display: none; background: #FFF1F2; border: 1px solid #FDA4AF; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; align-items: center; gap: 10px; }
  .qb-pro-error-banner.active { display: flex; animation: qbShake 0.4s; }
  .qb-pro-warn-msg { font-size: 12px; font-weight: 700; color: #9F1239; margin: 0; text-transform: uppercase; line-height: 1.4; }
  @keyframes qbShake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

  .qb-pro-bill-item { display: flex; justify-content: space-between; font-size: 15px; font-weight: 700; color: var(--qb-gray); margin-bottom: 12px; }
  .qb-pro-calc-text { font-size: 12px; color: #AAA; font-weight: 600; }
  .qb-pro-bill-total-row { display: flex; justify-content: space-between; align-items: baseline; padding-top: 16px; border-top: 1.5px dashed var(--qb-border); }
  .qb-pro-total-val { font-size: 24px; font-weight: 900; color: var(--qb-black); }

  /* Sticky Bottom Footer */
  .qb-sticky-checkout-bar-pro { position: fixed; bottom: 65px; left: 0; right: 0; max-width: 500px; margin: 0 auto; background: #fff; padding: 16px 20px; border-top: 1px solid var(--qb-border); display: flex; align-items: center; gap: 16px; z-index: 1000; box-shadow: 0 -10px 40px rgba(0,0,0,0.05); }
  .qb-sticky-val-pro { font-size: 22px; font-weight: 900; color: var(--qb-black); }
  .qb-btn-main-checkout-pro { flex: 1; height: 58px; background: var(--qb-red); color: white; border: none; border-radius: 18px; font-size: 18px; font-weight: 900; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 25px rgba(196,30,58,0.25); }
  .qb-btn-main-checkout-pro.qb-btn-disabled-pro { opacity: 0.6; filter: blur(0.4px); background: #999 !important; cursor: not-allowed; transform: scale(0.98); }

  /* MODAL (PORTAL POP-OUT) */
  .qb-portal-modal-layer { position: fixed !important; inset: 0 !important; background: rgba(0,0,0,0.8) !important; backdrop-filter: blur(10px) !important; z-index: 2147483647 !important; display: none; align-items: flex-end; justify-content: center; overflow: hidden !important; touch-action: none; }
  .qb-portal-modal-layer.is-active { display: flex; }
  .qb-portal-modal-card { background: #fff; width: 100%; max-width: 500px; border-radius: 32px 32px 0 0; padding: 24px 24px calc(24px + env(safe-area-inset-bottom)); position: relative; box-shadow: 0 -10px 40px rgba(0,0,0,0.5); }
  .qb-portal-modal-notch { width: 40px; height: 4px; background: #eee; border-radius: 2px; margin: 0 auto 20px; }
  .qb-portal-modal-close-x { position: absolute; top: 20px; right: 20px; background: #f5f5f5; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-weight: bold; color: #333; }
  .qb-portal-modal-h { font-size: 20px; font-weight: 900; text-align: center; color: #111; margin-bottom: 8px; }
  .qb-portal-modal-p { font-size: 14px; color: #666; text-align: center; margin-bottom: 24px; line-height: 1.5; }
  .qb-portal-modal-media-frame { width: 100%; border-radius: 18px; overflow: hidden; border: 1px solid #eee; margin-bottom: 24px; background: #f9f9f9; }
  .qb-portal-modal-media-frame img { width: 100%; display: block; max-height: 50vh; object-fit: contain; }
  .qb-btn-maps-large-action { display: flex; align-items: center; justify-content: center; background: #4285F4; color: #fff; text-decoration: none; padding: 16px; border-radius: 16px; font-weight: 800; font-size: 15px; margin-bottom: 12px; }
  .qb-btn-modal-got-it-action { width: 100%; padding: 16px; background: #f5f5f5; border: none; border-radius: 16px; font-weight: 700; color: #333; cursor: pointer; font-size: 15px; }

  .qb-flex-between { display: flex; justify-content: space-between; align-items: center; }
  .animate-fade-in { animation: qbFadeIn 0.6s ease-out; }
  @keyframes qbFadeIn { from { opacity: 0; } to { opacity: 1; } }
  .animate-slide-up { animation: qbSlideUp 0.4s var(--qb-ease) forwards; }
  @keyframes qbSlideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

  .qb-empty-hive-state { padding: 80px 20px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; }
  .qb-empty-bee-icon { font-size: 90px; margin-bottom: 24px; filter: drop-shadow(0 10px 10px rgba(0,0,0,0.1)); }
  .qb-btn-explore-gold { background: var(--qb-gold); color: white; padding: 18px 45px; border-radius: 16px; text-decoration: none; font-weight: 900; display: inline-block; margin-top: 30px; box-shadow: 0 10px 30px rgba(244,180,0,0.3); }
</style>

<script>
(function() {
  function initFinalValidatedCart() {
    const input = document.getElementById('LandmarkLink');
    const checkoutBtn = document.getElementById('qbMainCheckoutBtn');
    const errorBox = document.getElementById('qbCheckoutError');
    const modal = document.getElementById('landmarkModalOverlay');
    const body = document.body;

    // PORTAL: Move modal to Body Root to bypass clipping
    if (modal && modal.parentNode !== body) body.appendChild(modal);

    const validate = () => {
      const val = (input?.value || '').trim();
      const isValid = val.length > 8 && (val.includes('google.com') || val.includes('maps.app') || val.includes('http'));
      if (checkoutBtn) {
        checkoutBtn.disabled = !isValid;
        checkoutBtn.classList.toggle('qb-btn-disabled-pro', !isValid);
      }
      if (errorBox) errorBox.classList.toggle('active', !isValid);
    };

    if (input) { input.addEventListener('input', validate); validate(); }

    document.addEventListener('click', (e) => {
      // ? Trigger
      if (e.target.closest('#openHelpBtn')) {
        e.preventDefault(); e.stopPropagation();
        modal.classList.add('is-active');
        document.documentElement.classList.add('qb-no-scroll');
        return;
      }
      // Modal Close
      if (e.target.closest('#closeHelpBtn') || e.target.closest('#doneHelpBtn') || e.target === modal) {
        modal.classList.remove('is-active');
        document.documentElement.classList.remove('qb-no-scroll');
        return;
      }
      // Quantity Action
      const qtyBtn = e.target.closest('[data-qbtn]');
      if (qtyBtn) {
        const form = qtyBtn.closest('form');
        const inp = form.querySelector('.qb-qty-input-centered');
        let val = parseInt(inp.value);
        if (qtyBtn.dataset.action === 'minus') {
          if (val > 1) val--; else if (confirm('Remove item from selection?')) val = 0; else return;
        } else val++;
        inp.value = val; form.submit();
        return;
      }
      // Nickname Interaction
      const chip = e.target.closest('.qb-pro-chip-action');
      if (chip) {
        localStorage.setItem('qb_landmark_' + (localStorage.getItem('qb_active_nickname') || 'Home'), input.value);
        document.querySelectorAll('.qb-pro-chip-action').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        const next = chip.dataset.nickname;
        localStorage.setItem('qb_active_nickname', next);
        input.value = localStorage.getItem('qb_landmark_' + next) || '';
        validate();
        return;
      }
      // Checkout Processing
      if (e.target.closest('#qbMainCheckoutBtn')) {
        const btn = e.target.closest('#qbMainCheckoutBtn');
        if (btn.disabled) return;
        btn.disabled = true; btn.innerHTML = 'Wait...';
        const nick = localStorage.getItem('qb_active_nickname') || 'Home';
        const fullNote = `Address Type: ${nick}\nGoogle Maps: ${input.value}\nLocation Data: ${localStorage.getItem('qb_selected_location') || 'N/A'}`;
        fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ note: fullNote }) })
        .finally(() => { window.location.href = '/checkout'; });
      }
    });

    const activeNick = localStorage.getItem('qb_active_nickname') || 'Home';
    document.querySelectorAll('.qb-pro-chip-action').forEach(chip => {
      if (chip.dataset.nickname === activeNick) chip.classList.add('active');
      const saved = localStorage.getItem('qb_landmark_' + activeNick);
      if (chip.dataset.nickname === activeNick && saved) { input.value = saved; validate(); }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initFinalValidatedCart);
  else initFinalValidatedCart();
})();
</script>

{% schema %}{ "name": "Cart Page", "settings": [], "presets": [{ "name": "Cart Page" }] }{% endschema %}