{% capture cart_page_more_blocks_content %}
  <div class="cart-page__more-blocks">
    {%- content_for 'blocks' -%}
  </div>
{% endcapture %}

<cart-items-component
  class="cart-items-component"
  data-section-id="{{ section.id }}"
>
  <template id="empty-cart-template">
    <div class="section-background color-{{ section.settings.color_scheme }}"></div>
    <div class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}">
      <div class="cart-page spacing-style{% if cart.empty? %} cart-page--empty{% endif %}" style="{% render 'spacing-style', settings: section.settings %}">
        <div class="cart-page__title">
          {%- content_for 'block', id: 'cart-page-title', type: '_cart-title', force_empty: true %}
        </div>
        <div class="cart-page__items">
          {%- content_for 'block', id: 'cart-page-items', type: '_cart-products', force_empty: true %}
        </div>
        {{ cart_page_more_blocks_content }}
      </div>
    </div>
  </template>

  {% # theme-check-disable UniqueStaticBlockId %}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}">
    <div class="cart-page spacing-style{% if cart.empty? %} cart-page--empty{% endif %}" style="{% render 'spacing-style', settings: section.settings %}">
      <!-- CART HEADER -->
      <div class="cart-page__header">
        <h1 class="cart-page__title">
          {%- content_for 'block', id: 'cart-page-title', type: '_cart-title' %}
        </h1>
      </div>

      {%- unless cart.empty? -%}
        <!-- URGENCY BANNER -->
        <div class="cart-page__urgency">
          {% render 'delivery-countdown-timer' %}
        </div>

        <!-- MAIN CONTENT: Items List + Summary -->
        <div class="cart-page__container">
          <!-- LEFT: Cart Items -->
          <div class="cart-page__items-section">
            <div class="cart-page__items">
              {%- content_for 'block', id: 'cart-page-items', type: '_cart-products' %}
            </div>
          </div>

          <!-- RIGHT: Order Summary (Sticky on Desktop) -->
          <div class="cart-page__summary-section">
            <div class="cart-page__summary-sticky">
              <!-- Wallet Balance Reminder -->
              <div class="cart-page__wallet-reminder">
                {% render 'wallet-balance' %}
              </div>

              <!-- Order Summary -->
              <div class="cart-page__summary">
                {%- content_for 'block', id: 'cart-page-summary', type: '_cart-summary' -%}
              </div>
            </div>
          </div>
        </div>

        <!-- RECOMMENDATIONS SECTION -->
        {{ cart_page_more_blocks_content }}
      {%- endunless -%}
    </div>
  </div>
  {% # theme-check-enable UniqueStaticBlockId %}
</cart-items-component>

{% stylesheet %}
  /* BASE CART PAGE STYLING */
  .cart-page {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-lg);
    width: 100%;
  }

  .cart-page--empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }

  /* HEADER */
  .cart-page__header {
    padding-bottom: var(--padding-lg);
    border-bottom: 1px solid #e5e5e5;
  }

  .cart-page__title {
    font-size: 32px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* URGENCY BANNER */
  .cart-page__urgency {
    margin: var(--margin-lg) 0;
    animation: slideDown 0.4s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* MAIN CONTAINER - Two-column layout for desktop */
  .cart-page__container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-2xl);
    width: 100%;
  }

  .cart-page__items-section {
    width: 100%;
    min-width: 0;
  }

  .cart-page__items {
    width: 100%;
  }

  .cart-page__summary-section {
    width: 100%;
    order: 2;
  }

  /* SUMMARY STICKY */
  .cart-page__summary-sticky {
    background: white;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
    padding: var(--padding-lg);
    display: flex;
    flex-direction: column;
    gap: var(--gap-lg);
  }

  /* WALLET REMINDER */
  .cart-page__wallet-reminder {
    background: linear-gradient(135deg, #f0f4ff 0%, #f9f5ff 100%);
    border: 1px solid #e5e0ff;
    border-radius: 6px;
    padding: var(--padding-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ORDER SUMMARY */
  .cart-page__summary {
    border-top: 1px solid #e5e5e5;
    padding-top: var(--padding-md);
  }

  .cart-page__more-blocks {
    width: 100%;
    grid-column: 1 / -1;
    margin-top: var(--margin-5xl);
    padding-top: var(--padding-5xl);
    border-top: 2px solid #e5e5e5;
  }

  /* ============================================================================
     MOBILE: Stack items and summary vertically (max-width: 749px)
     ============================================================================ */
  @media screen and (max-width: 749px) {
    .cart-page__header {
      padding-top: var(--padding-md);
      padding-bottom: var(--padding-md);
    }

    .cart-page__title {
      font-size: 24px;
      margin-bottom: var(--margin-md);
    }

    .cart-page__urgency {
      margin: var(--margin-md) 0;
    }

    .cart-page__container {
      grid-template-columns: 1fr;
      gap: var(--gap-lg);
    }

    .cart-page__items-section {
      order: 1;
    }

    .cart-page__summary-section {
      order: 2;
      position: sticky;
      bottom: 0;
      z-index: 10;
    }

    .cart-page__summary-sticky {
      background: white;
      border-radius: 0;
      border: 1px solid #e5e5e5;
      border-bottom: none;
      box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.06);
      padding: var(--padding-md);
      gap: var(--gap-md);
      border-top: 1px solid #e5e5e5;
    }

    .cart-page__wallet-reminder {
      flex-direction: column;
      text-align: center;
      gap: var(--gap-sm);
    }

    .cart-page__summary {
      padding-top: var(--padding-sm);
    }
  }

  /* ============================================================================
     TABLET: Two-column layout (750px - 1023px)
     ============================================================================ */
  @media screen and (min-width: 750px) and (max-width: 1023px) {
    .cart-page__container {
      grid-template-columns: 1fr 350px;
      gap: var(--gap-2xl);
      align-items: start;
    }

    .cart-page__items-section {
      order: 1;
    }

    .cart-page__summary-section {
      order: 2;
      position: sticky;
      top: 100px;
    }

    .cart-page__summary-sticky {
      top: 0;
    }
  }

  /* ============================================================================
     DESKTOP: Two-column layout (1024px+)
     ============================================================================ */
  @media screen and (min-width: 1024px) {
    .cart-page__container {
      grid-template-columns: 1fr 380px;
      gap: var(--gap-4xl);
      align-items: start;
    }

    .cart-page__items-section {
      order: 1;
    }

    .cart-page__summary-section {
      order: 2;
      position: sticky;
      top: 120px;
    }

    .cart-page__summary-sticky {
      top: 0;
    }

    .cart-page__title {
      font-size: 36px;
      margin-bottom: var(--margin-lg);
    }
  }

  /* ============================================================================
     DARK MODE SUPPORT
     ============================================================================ */
  @media (prefers-color-scheme: dark) {
    .cart-page {
      color-scheme: light;
    }

    .cart-page__header {
      border-color: #ddd;
      background: white;
    }

    .cart-page__title {
      color: #1a1a1a !important;
      color-scheme: light !important;
    }

    .cart-page__summary-sticky {
      background: white !important;
      border-color: #ddd;
    }

    .cart-page__wallet-reminder {
      background: linear-gradient(135deg, #f0f4ff 0%, #f9f5ff 100%);
      border-color: #e5e0ff;
      color-scheme: light;
    }

    .cart-page__summary {
      border-color: #ddd;
    }

    .cart-page__more-blocks {
      border-color: #ddd;
    }
  }

  /* Animations */
  html:active-view-transition-type(empty-cart-page) {
    .cart-items-component {
      view-transition-name: cart-page-content;
    }
  }

  ::view-transition-old(cart-page-content) {
    animation: cart-page-content-old var(--animation-speed-fast) var(--animation-easing) forwards;
  }

  @keyframes cart-page-content-old {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
      filter: blur(4px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.cart",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
