{% capture cart_page_more_blocks_content %}
  <div class="cart-recommendations">
    {%- content_for 'blocks' -%}
  </div>
{% endcapture %}

<cart-items-component
  class="cart-items-component"
  data-section-id="{{ section.id }}"
>
  <template id="empty-cart-template">
    <div class="section-background color-{{ section.settings.color_scheme }}"></div>
    <div class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}">
      <div class="cart--empty">
        <div class="empty-icon">🛒</div>
        <h1 class="empty-title">{{ 'sections.cart.empty_html' | t }}</h1>
        <a href="{{ routes.all_products_collection_url }}" class="empty-button">
          {{ 'general.continue_shopping' | t }}
        </a>
      </div>
    </div>
  </template>

  {% # theme-check-disable UniqueStaticBlockId %}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}">
    <div class="cart-wrapper">

      <!-- HEADER -->
      <div class="cart-header">
        <h1 class="cart-title">Your Cart</h1>
      </div>

      {%- unless cart.empty? -%}

        <!-- MAIN CONTENT GRID -->
        <div class="cart-container">
          <!-- LEFT COLUMN: ITEMS & RECOMMENDATIONS -->
          <div class="cart-main">
            <!-- REVIEW YOUR ORDER -->
            <div class="cart-section">
              <h2 class="section-heading">Review Your Order</h2>
              <div class="cart-items-list">
                {%- content_for 'block', id: 'cart-page-items', type: '_cart-products' -%}
              </div>
            </div>

            <!-- MISSED SOMETHING -->
            <div class="cart-section">
              <div class="missed-something">
                <p class="missed-title">Missed Something?</p>
                <a href="{{ routes.all_products_collection_url }}" class="add-more-button">Add More Items</a>
              </div>
            </div>

            <!-- YOU MIGHT ALSO LIKE -->
            {% if cart_page_more_blocks_content != blank %}
              <div class="cart-section recommendations-section">
                <h2 class="section-heading">You might also like</h2>
                {{ cart_page_more_blocks_content }}
              </div>
            {% endif %}
          </div>

          <!-- RIGHT COLUMN: BILLING SUMMARY (sticky on desktop) -->
          <div class="cart-sidebar">
            <div class="billing-summary-sticky">
              <h3 class="summary-heading">Billing Summary</h3>
              <div class="billing-details">
                {%- content_for 'block', id: 'cart-page-summary', type: '_cart-summary' -%}
              </div>
            </div>
          </div>
        </div>

      {%- endunless -%}

    </div>
  </div>
  {% # theme-check-enable UniqueStaticBlockId %}
</cart-items-component>

{% stylesheet %}
  :root {
    --color-primary: #d94a4a;
    --color-border: #e5e5e5;
    --color-text: #333;
    --color-text-light: #999;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .cart-wrapper {
    background: #f9f9f9;
    min-height: 100vh;
  }

  /* HEADER */
  .cart-header {
    background: white;
    padding: 20px;
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .cart-title {
    font-size: 24px;
    font-weight: 600;
    color: var(--color-text);
  }

  /* MAIN CONTAINER */
  .cart-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* SECTIONS */
  .cart-section {
    background: white;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 20px;
  }

  .section-heading {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 20px;
  }

  /* ITEMS LIST */
  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* MISSED SOMETHING */
  .missed-something {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    background: #f5f5f5;
    border-radius: 6px;
  }

  .missed-title {
    font-size: 14px;
    color: var(--color-text);
    font-weight: 500;
  }

  .add-more-button {
    padding: 10px 20px;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    background: white;
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s;
    cursor: pointer;
  }

  .add-more-button:hover {
    background: var(--color-primary);
    color: white;
  }

  /* BILLING SUMMARY */
  .billing-summary-sticky {
    background: white;
    border-radius: 8px;
    padding: 24px;
  }

  .summary-heading {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 20px;
  }

  .billing-details {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* EMPTY CART */
  .cart--empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    text-align: center;
  }

  .empty-icon {
    font-size: 80px;
    margin-bottom: 20px;
  }

  .empty-title {
    font-size: 24px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 20px;
  }

  .empty-button {
    display: inline-block;
    padding: 12px 24px;
    background: var(--color-primary);
    color: white;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .empty-button:hover {
    opacity: 0.9;
  }

  /* RECOMMENDATIONS SECTION */
  .recommendations-section {
    margin-top: 40px;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .cart-header {
      padding: 16px;
    }

    .cart-title {
      font-size: 20px;
    }

    .cart-container {
      grid-template-columns: 1fr;
      padding: 16px;
      gap: 16px;
    }

    .cart-section {
      padding: 16px;
      margin-bottom: 16px;
    }

    .section-heading {
      font-size: 16px;
      margin-bottom: 16px;
    }

    .missed-something {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }

    .add-more-button {
      width: 100%;
    }
  }

  /* DESKTOP - TWO COLUMN LAYOUT */
  @media (min-width: 769px) {
    .cart-container {
      grid-template-columns: 2fr 1fr;
      gap: 32px;
    }

    .billing-summary-sticky {
      position: sticky;
      top: 80px;
      height: fit-content;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "t:names.cart",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
