<!-- sections/main-cart.liquid -->
<cart-items-component class="qb-cart-component-ultra" data-section-id="{{ section.id }}">
  <div class="qb-cart-page-shell">
    {%- if cart.empty? -%}
      <div class="qb-empty-hive-state animate-fade-in">
        <div class="qb-empty-bee-art">🐝</div>
        <h1 class="qb-empty-h1">Your Hive is Empty</h1>
        <p class="qb-empty-p">Time to fill your basket! Browse our collections to get started.</p>
        <a href="{{ routes.all_products_collection_url }}" class="qb-btn-explore-gold">Explore Collections</a>
      </div>
    {%- else -%}
      
      <!-- HEADER -->
      <div class="qb-cart-header-main">
        <h1 class="qb-cart-header-title">Review Order</h1>
        <span class="qb-cart-header-badge" ref="cartItemCount">{{ cart.item_count }} Items</span>
      </div>

      <div class="qb-cart-body-stack">
        
        <!-- SECTION: SELECTED PRODUCTS -->
        <div class="qb-cart-card">
          <div class="qb-cart-card-label">SELECTED PRODUCTS</div>
          <div class="qb-cart-items-list">
            {%- for item in cart.items -%}
              <div class="qb-cart-item-row" ref="cartItemRows" data-key="{{ item.key }}">
                <div class="qb-cart-item-img">
                  {% if item.image %}<img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title | escape }}">{% else %}<div class="qb-cart-item-img-fallback">🐝</div>{% endif %}
                </div>
                <div class="qb-cart-item-info">
                  <div class="qb-cart-item-header">
                    <a href="{{ item.url }}" class="qb-cart-item-name">{{ item.product.title | truncate: 50 }}</a>
                    <form action="{{ routes.cart_change_url }}" method="post" class="qb-remove-form">
                      <input type="hidden" name="id" value="{{ item.key }}"><input type="hidden" name="quantity" value="0">
                      <button type="submit" class="qb-item-x-btn" aria-label="Remove">
                        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M13 1L1 13M1 1L13 13"/></svg>
                      </button>
                    </form>
                  </div>
                  {%- unless item.product.has_only_default_variant -%}<div class="qb-cart-item-variant">{{ item.variant.title }}</div>{%- endunless -%}
                  <div class="qb-cart-item-footer">
                    <span class="qb-cart-item-price">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    <div class="qb-cart-qty-pill-pro" ref="quantitySelectors">
                      <form action="{{ routes.cart_change_url }}" method="post" class="qb-qty-pro-flex">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-qty-pro-btn" data-action="minus" data-qbtn>−</button>
                        <div class="qb-qty-pro-num">
                          <input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-qty-pro-input">
                        </div>
                        <button type="button" class="qb-qty-pro-btn" data-action="plus" data-qbtn>+</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          <a href="{{ routes.all_products_collection_url }}" class="qb-cart-add-more">+ Add more items</a>
        </div>

        <!-- SECTION: DELIVERY -->
        <div class="qb-cart-card">
          <div class="qb-cart-card-header-flex">
            <span class="qb-cart-card-label">DELIVERY DESTINATION</span>
            <button type="button" class="qb-help-circle-btn" id="openHelpBtn">?</button>
          </div>
          <div class="qb-landmark-input-pro-frame">
            <div class="qb-landmark-pro-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <input type="text" id="LandmarkLink" placeholder="Paste Google Maps link here..." class="qb-landmark-pro-field" required>
          </div>
          <div class="qb-landmark-pro-chips">
            <button type="button" class="qb-nickname-pro-chip" data-nickname="Home">🏠 Home</button>
            <button type="button" class="qb-nickname-pro-chip" data-nickname="Office">🏢 Office</button>
            <button type="button" class="qb-nickname-pro-chip" data-nickname="Other">✨ Other</button>
            <button type="button" class="qb-nickname-pro-chip" data-nickname="Current">📦 Current</button>
          </div>
        </div>

        <!-- SECTION: BILLING -->
        <div class="qb-cart-card">
          <div id="qbCheckoutError" class="qb-error-banner-pro animate-fade-in active">
            <span>⚠️ enter the google maps location link TO PROCEED CHECKOUT</span>
          </div>
          <div class="qb-cart-card-label">BILLING SUMMARY</div>
          <div class="qb-bill-stack-pro">
            <div class="qb-bill-row-pro"><span>Item Total</span><span>Rs {{ cart.total_price | divided_by: 100 }}</span></div>
            <div class="qb-bill-row-pro"><span>Delivery Fee</span><span class="qb-bill-muted-pro">Calculated at checkout</span></div>
            <div class="qb-bill-divider-pro"></div>
            <div class="qb-bill-total-pro">
              <span class="qb-total-label-pro">Grand Total</span>
              <span class="qb-total-val-pro" ref="cartTotal">Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- STICKY FOOTER -->
      <div class="qb-cart-sticky-footer-pro">
        <div class="qb-footer-price-stack">
          <span class="qb-footer-tag-pro">PAYABLE AMOUNT</span>
          <span class="qb-footer-val-pro">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-btn-checkout-final qb-is-locked-pro" id="qbMainCheckoutBtn" disabled>Checkout ➔</button>
      </div>
    {%- endif -%}
  </div>
</cart-items-component>

<!-- TRUE POP-OUT MODAL -->
<div id="landmarkModalOverlay" class="qb-portal-overlay">
  <div class="qb-portal-card animate-slide-up">
    <div class="qb-portal-notch"></div>
    <button class="qb-portal-close" id="closeHelpBtn" type="button">✕</button>
    <div class="qb-portal-inner">
      <h3 class="qb-portal-h">How to share location?</h3>
      <p class="qb-portal-p">Follow these simple steps to share your precise location via Google Maps.</p>
      <div class="qb-portal-media">
        <img src="{{ 'popupgoogle.png' | asset_url }}" alt="Tutorial" id="tutImgPro">
      </div>
      <div class="qb-portal-actions">
        <a href="https://www.google.com/maps" target="_blank" class="qb-btn-maps-action">📍 Open Google Maps App</a>
        <button type="button" class="qb-btn-done-action" id="doneHelpBtn">Got it!</button>
      </div>
    </div>
  </div>
</div>

<style>
  :root { --qb-gold: #F4B400; --qb-gold-soft: #FFF9E6; --qb-black: #111111; --qb-gray: #757575; --qb-red: #C41E3A; --qb-bg: #F8F9FA; --qb-border: #EEEEEE; }
  
  html.qb-locked { overflow: hidden !important; }
  
  .qb-cart-component-ultra { display: block; background: var(--qb-bg); min-height: 100vh; padding-bottom: 160px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .qb-cart-page-shell { max-width: 500px; margin: 0 auto; background: #fff; min-height: 100vh; position: relative; }

  /* Header */
  .qb-cart-header-main { padding: 30px 20px 20px; display: flex; justify-content: space-between; align-items: center; }
  .qb-cart-header-title { font-size: 24px; font-weight: 900; color: #111; margin: 0; }
  .qb-cart-header-badge { background: var(--qb-gold-soft); color: var(--qb-gold); font-size: 12px; font-weight: 800; padding: 4px 12px; border-radius: 20px; }

  /* Cards */
  .qb-cart-body-stack { padding: 0 16px; display: flex; flex-direction: column; gap: 16px; }
  .qb-cart-card { background: #fff; border: 1px solid var(--qb-border); border-radius: 20px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.04); position: relative; }
  .qb-cart-card-label { font-size: 10px; font-weight: 900; color: #BBB; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 18px; }
  .qb-cart-card-header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }

  /* Items */
  .qb-cart-items-list { display: flex; flex-direction: column; gap: 20px; }
  .qb-cart-item-row { display: flex; gap: 16px; padding-bottom: 20px; border-bottom: 1.5px solid #F9F9F9; }
  .qb-cart-item-row:last-child { border-bottom: none; padding-bottom: 0; }
  .qb-cart-item-img { width: 95px; height: 95px; border-radius: 14px; overflow: hidden; border: 1px solid #F0F0F0; flex-shrink: 0; background: #F9F9F9; }
  .qb-cart-item-img img { width: 100%; height: 100%; object-fit: cover; }
  .qb-cart-item-info { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  .qb-cart-item-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .qb-cart-item-name { font-size: 15px; font-weight: 800; color: #111; text-decoration: none; line-height: 1.35; flex: 1; }
  .qb-item-x-btn { background: #F5F5F5; border: none; color: #BBB; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
  .qb-item-x-btn:active { background: var(--qb-red); color: white; transform: scale(0.9); }
  .qb-cart-item-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 12px; }
  .qb-cart-item-price { font-size: 17px; font-weight: 900; }

  /* Centered Qty Pill */
  .qb-qty-pill-pro { background: #F5F5F5; border-radius: 14px; padding: 2px; display: flex; width: 110px; }
  .qb-qty-pro-flex { display: flex; align-items: center; width: 100%; }
  .qb-qty-pro-btn { width: 32px; height: 32px; border: none; background: none; color: #111; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .qb-qty-pro-num { flex: 1; display: flex; align-items: center; justify-content: center; }
  .qb-qty-pro-input { width: 100%; border: none; background: transparent; text-align: center !important; font-size: 15px; font-weight: 900; color: #111; pointer-events: none; padding: 0; margin: 0; }

  /* ? Button */
  .qb-help-circle-btn { width: 32px; height: 32px; border-radius: 50%; background: #fff; border: 1.5px solid var(--qb-gold); color: var(--qb-gold); font-weight: 900; font-size: 16px; cursor: pointer; box-shadow: 0 4px 12px rgba(244,180,0,0.15); transition: 0.2s; }
  .qb-help-circle-btn:active { transform: scale(0.9); background: var(--qb-gold-soft); }

  /* Input Box */
  .qb-landmark-input-pro-frame { display: flex; align-items: center; background: #F9F9F9; border: 1.5px solid var(--qb-border); border-radius: 16px; margin: 16px 0; transition: 0.3s; }
  .qb-landmark-input-pro-frame:focus-within { border-color: var(--qb-gold); background: #fff; box-shadow: 0 0 0 4px var(--qb-gold-soft); }
  .qb-landmark-pro-icon { padding-left: 16px; color: var(--qb-gold); display: flex; align-items: center; }
  .qb-landmark-pro-field { flex: 1; padding: 18px 18px 18px 12px; background: transparent; border: none; font-size: 15px; font-weight: 700; color: #111; outline: none; }

  .qb-landmark-pro-chips { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .qb-nickname-pro-chip { padding: 14px; background: #fff; border: 1.5px solid var(--qb-border); border-radius: 16px; font-size: 14px; font-weight: 800; color: var(--qb-gray); cursor: pointer; text-align: center; }
  .qb-nickname-pro-chip.active { border-color: var(--qb-gold); background: var(--qb-gold-soft); color: var(--qb-gold); }

  /* Sticky Footer */
  .qb-btn-checkout-final.qb-is-locked-pro { opacity: 0.6; filter: blur(0.4px); background: #999 !important; cursor: not-allowed; }
  .qb-cart-sticky-footer-pro { position: fixed; bottom: 65px; left: 0; right: 0; max-width: 500px; margin: 0 auto; background: #fff; padding: 16px 20px; border-top: 1px solid var(--qb-border); display: flex; align-items: center; gap: 16px; z-index: 1000; box-shadow: 0 -10px 40px rgba(0,0,0,0.05); }
  .qb-btn-checkout-final { flex: 1; height: 58px; background: var(--qb-red); color: white; border: none; border-radius: 18px; font-size: 18px; font-weight: 900; cursor: pointer; }

  /* PORTAL MODAL - DEFINITIVE FIX */
  .qb-portal-overlay { position: fixed !important; inset: 0 !important; background: rgba(0,0,0,0.85) !important; z-index: 2147483647 !important; display: none; align-items: flex-end; justify-content: center; overflow: hidden !important; touch-action: none; }
  .qb-portal-overlay.is-active { display: flex !important; }
  .qb-portal-card { background: #fff !important; width: 100% !important; max-width: 500px !important; border-radius: 32px 32px 0 0 !important; padding: 24px 24px calc(24px + env(safe-area-inset-bottom)) !important; position: relative !important; box-shadow: 0 -10px 40px rgba(0,0,0,0.5) !important; text-align: center !important; }
  .qb-portal-notch { width: 40px; height: 4px; background: #eee; border-radius: 2px; margin: 0 auto 20px; }
  .qb-portal-close { position: absolute; top: 20px; right: 20px; background: #f5f5f5; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-weight: bold; color: #333; }
  .qb-portal-media { width: 100%; border-radius: 18px; overflow: hidden; border: 1px solid #eee; margin-bottom: 24px; background: #f9f9f9; padding: 10px; }
  .qb-portal-media img { width: 100%; display: block; max-height: 45vh; object-fit: contain; }
  .qb-btn-maps-action { display: flex; align-items: center; justify-content: center; background: #4285F4; color: #fff; text-decoration: none; padding: 16px; border-radius: 16px; font-weight: 800; font-size: 15px; margin-bottom: 12px; }
  .qb-btn-done-action { width: 100%; padding: 16px; background: #f5f5f5; border: none; border-radius: 16px; font-weight: 700; color: #333; cursor: pointer; font-size: 15px; }

  .qb-error-banner-pro { display: none; background: #FFF1F2; border: 1px solid #FDA4AF; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; font-size: 12px; font-weight: 700; color: #9F1239; text-transform: uppercase; }
  .qb-error-banner-pro.active { display: block; }
</style>

<script>
(function() {
  function initUltraCart() {
    const input = document.getElementById('LandmarkLink');
    const checkoutBtn = document.getElementById('qbMainCheckoutBtn');
    const errorBox = document.getElementById('qbCheckoutError');
    const modal = document.getElementById('landmarkModalOverlay');
    const body = document.body;

    // TRUE PORTAL: Detach and attach to body root immediately
    if (modal && modal.parentNode !== body) {
      body.appendChild(modal);
    }

    const validate = () => {
      const val = (input?.value || '').trim();
      const isValid = val.length > 8 && (val.includes('google.com') || val.includes('maps.app') || val.includes('http'));
      if (checkoutBtn) {
        checkoutBtn.disabled = !isValid;
        checkoutBtn.classList.toggle('qb-is-locked-pro', !isValid);
      }
      if (errorBox) errorBox.classList.toggle('active', !isValid);
    };

    if (input) { input.addEventListener('input', validate); validate(); }

    // GLOBAL CLICK LISTENER: Solves "?" not clicking
    document.addEventListener('click', (e) => {
      // ? Trigger
      if (e.target.closest('#openHelpBtn')) {
        e.preventDefault(); e.stopPropagation();
        if(modal) modal.classList.add('is-active');
        document.documentElement.classList.add('qb-locked');
        return;
      }
      // Modal Close
      if (e.target.closest('#closeHelpBtn') || e.target.closest('#doneHelpBtn') || e.target === modal) {
        if(modal) modal.classList.remove('is-active');
        document.documentElement.classList.remove('qb-locked');
        return;
      }
      // Quantity
      const qtyBtn = e.target.closest('[data-qbtn]');
      if (qtyBtn) {
        const form = qtyBtn.closest('form');
        const inp = form.querySelector('.qb-qty-pro-input');
        let val = parseInt(inp.value);
        if (qtyBtn.dataset.action === 'minus') {
          if (val > 1) val--; else if (confirm('Remove item?')) val = 0; else return;
        } else val++;
        inp.value = val; form.submit();
        return;
      }
      // Nickname
      const chip = e.target.closest('.qb-nickname-pro-chip') || e.target.closest('.qb-pro-chip-btn');
      if (chip) {
        localStorage.setItem('qb_landmark_' + (localStorage.getItem('qb_active_nickname') || 'Home'), input.value);
        document.querySelectorAll('.qb-nickname-pro-chip, .qb-pro-chip-btn').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        const next = chip.dataset.nickname;
        localStorage.setItem('qb_active_nickname', next);
        input.value = localStorage.getItem('qb_landmark_' + next) || '';
        validate();
        return;
      }
      // Checkout
      if (e.target.closest('#qbMainCheckoutBtn')) {
        const btn = e.target.closest('#qbMainCheckoutBtn');
        if (btn.disabled) return;
        btn.disabled = true; btn.innerHTML = 'Wait...';
        const nick = localStorage.getItem('qb_active_nickname') || 'Home';
        const fullNote = `Type: ${nick} | Map: ${input.value} | Loc: ${localStorage.getItem('qb_selected_location') || 'N/A'}`;
        fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ note: fullNote }) })
        .finally(() => { window.location.href = '/checkout'; });
      }
    });

    const activeNick = localStorage.getItem('qb_active_nickname') || 'Home';
    document.querySelectorAll('.qb-nickname-pro-chip, .qb-pro-chip-btn').forEach(chip => {
      if (chip.dataset.nickname === activeNick) chip.classList.add('active');
      const saved = localStorage.getItem('qb_landmark_' + activeNick);
      if (chip.dataset.nickname === activeNick && saved) { input.value = saved; validate(); }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initUltraCart);
  else initUltraCart();
})();
</script>

{% schema %}{ "name": "Cart Page", "settings": [], "presets": [{ "name": "Cart Page" }] }{% endschema %}