<!-- sections/main-cart.liquid -->
<cart-items-component class="qb-main-cart-section" data-section-id="{{ section.id }}">
  <div class="qb-page-container">
    {%- if cart.empty? -%}
      <div class="qb-empty-state animate-fade-in">
        <div class="qb-empty-icon">🐝</div>
        <h1 class="qb-empty-title">Your Hive is Empty</h1>
        <p class="qb-empty-text">Looks like you haven't added any treats yet!</p>
        <a href="{{ routes.all_products_collection_url }}" class="qb-btn-primary">Start Shopping</a>
      </div>
    {%- else -%}
      
      <!-- CART HEADER -->
      <div class="qb-cart-header">
        <h1 class="qb-cart-title">Review Order</h1>
        <span class="qb-item-count-badge" ref="cartItemCount">{{ cart.item_count }} Items</span>
      </div>

      <div class="qb-cart-content-flow">
        
        <!-- PRODUCTS SECTION -->
        <div class="qb-cart-card">
          <div class="qb-card-label">SELECTED PRODUCTS</div>
          
          <div class="qb-items-list">
            {%- for item in cart.items -%}
              <div class="qb-item-row" ref="cartItemRows" data-key="{{ item.key }}">
                <div class="qb-item-image">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title | escape }}" loading="lazy">
                  {% else %}
                    <div class="qb-img-placeholder">🐝</div>
                  {% endif %}
                </div>
                
                <div class="qb-item-details">
                  <div class="qb-item-top-line">
                    <a href="{{ item.url }}" class="qb-item-title">{{ item.product.title | truncate: 55 }}</a>
                    <!-- PROFESSIONALLY POSITIONED REMOVE BUTTON -->
                    <form action="{{ routes.cart_change_url }}" method="post" class="qb-remove-form">
                      <input type="hidden" name="id" value="{{ item.key }}">
                      <input type="hidden" name="quantity" value="0">
                      <button type="submit" class="qb-item-remove-btn" aria-label="Remove item">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M13 1L1 13M1 1L13 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </form>
                  </div>
                  
                  {%- unless item.product.has_only_default_variant -%}
                    <div class="qb-item-variant">{{ item.variant.title }}</div>
                  {%- endunless -%}

                  <div class="qb-item-controls-row">
                    <div class="qb-item-price">
                      <span class="qb-price-amt">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    </div>
                    
                    <!-- PERFECTLY CENTERED QUANTITY SELECTOR -->
                    <div class="qb-qty-selector" ref="quantitySelectors">
                      <form action="{{ routes.cart_change_url }}" method="post" class="qb-qty-form">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-qty-btn" data-action="minus" data-qbtn>−</button>
                        <div class="qb-qty-val-wrapper">
                          <input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-qty-input">
                        </div>
                        <button type="button" class="qb-qty-btn" data-action="plus" data-qbtn>+</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          
          <a href="{{ routes.all_products_collection_url }}" class="qb-add-more-link">+ Add more items</a>
        </div>

        <!-- DELIVERY SECTION -->
        <div class="qb-cart-card">
          <div class="qb-card-header-row">
            <span class="qb-card-label">DELIVERY DESTINATION</span>
            <button type="button" class="qb-help-info-trigger" id="openHelpBtn" aria-label="Tutorial">?</button>
          </div>
          
          <div class="qb-input-pro-box">
            <div class="qb-input-pin-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <input type="text" id="LandmarkLink" placeholder="Paste Google Maps location link..." class="qb-input-main-field" required>
          </div>
          
          <div class="qb-nickname-chips">
            <button type="button" class="qb-nick-chip" data-nickname="Home">🏠 Home</button>
            <button type="button" class="qb-nick-chip" data-nickname="Office">🏢 Office</button>
            <button type="button" class="qb-nick-chip" data-nickname="Other">✨ Other</button>
            <button type="button" class="qb-nickname-chip" data-nickname="Current">📦 Current</button>
          </div>
        </div>

        <!-- BILLING SECTION -->
        <div class="qb-cart-card">
          <!-- ERROR BANNER -->
          <div id="qbCheckoutError" class="qb-validation-alert animate-fade-in active">
            <span class="qb-err-icon">⚠️</span>
            <p class="qb-err-text">enter the google maps location link TO PROCEED CHECKOUT</p>
          </div>

          <div class="qb-card-label">BILLING SUMMARY</div>
          <div class="qb-billing-stack">
            <div class="qb-bill-line">
              <span>Item Total</span>
              <span>Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
            <div class="qb-bill-line">
              <span>Delivery Fee</span>
              <span class="qb-calc-muted">Calculated at checkout</span>
            </div>
            <div class="qb-bill-divider"></div>
            <div class="qb-total-row">
              <span class="qb-total-lbl">Grand Total</span>
              <span class="qb-total-val" ref="cartTotal">Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- STICKY FOOTER -->
      <div class="qb-sticky-checkout-bar">
        <div class="qb-footer-price-info">
          <span class="qb-footer-tag">PAYABLE AMOUNT</span>
          <span class="qb-footer-price">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-btn-main-checkout qb-btn-locked" id="qbMainCheckoutBtn" disabled>
          Checkout ➔
        </button>
      </div>
    {%- endif -%}
  </div>
</cart-items-component>

<!-- TRUE FIXED MODAL POP-OUT (Teleported to body root) -->
<div id="landmarkModalOverlay" class="qb-fixed-popup-overlay">
  <div class="qb-popup-card animate-slide-up">
    <div class="qb-popup-notch"></div>
    <button class="qb-popup-close-x" id="closeHelpBtn">✕</button>
    <div class="qb-popup-inner">
      <h3 class="qb-popup-h">How to share location?</h3>
      <p class="qb-popup-p">Share your exact Google Maps location link to help our bees find your hive!</p>
      <div class="qb-popup-media">
        <img src="{{ 'popupgoogle.png' | asset_url }}" alt="Guide" id="modalTutImg">
      </div>
      <div class="qb-popup-actions">
        <a href="https://www.google.com/maps" target="_blank" class="qb-btn-maps-app">📍 Open Google Maps App</a>
        <button type="button" class="qb-btn-done-modal" id="doneHelpBtn">Got it!</button>
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    --qb-gold: #F4B400;
    --qb-gold-soft: #FFF9E6;
    --qb-black: #111111;
    --qb-gray: #757575;
    --qb-red: #C41E3A;
    --qb-bg: #F8F9FA;
    --qb-border: #EEEEEE;
    --qb-radius-xl: 24px;
    --qb-radius-lg: 18px;
    --qb-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }

  /* Body Scroll Lock Fix */
  html.qb-no-scroll-final { overflow: hidden !important; height: 100% !important; }

  /* Base Layout - Respects Theme Header */
  .qb-main-cart-section { display: block; background: var(--qb-bg); min-height: 100vh; padding-bottom: 160px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .qb-page-container { max-width: 500px; margin: 0 auto; background: #fff; min-height: 100vh; position: relative; }

  /* Cart Header */
  .qb-cart-header { padding: 30px 20px 20px; display: flex; justify-content: space-between; align-items: center; }
  .qb-cart-title { font-size: 24px; font-weight: 900; color: var(--qb-black); margin: 0; }
  .qb-item-count-badge { background: var(--qb-gold-soft); color: var(--qb-gold); font-size: 12px; font-weight: 800; padding: 4px 12px; border-radius: 20px; }

  /* Stacked Cards */
  .qb-cart-content-flow { padding: 0 16px; display: flex; flex-direction: column; gap: 16px; }
  .qb-cart-card { background: #fff; border: 1px solid var(--qb-border); border-radius: var(--qb-radius-xl); padding: 20px; box-shadow: var(--qb-shadow); position: relative; }
  .qb-card-label { font-size: 10px; font-weight: 900; color: #BBB; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 18px; }
  .qb-card-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }

  /* Item Row Redesign */
  .qb-items-list { display: flex; flex-direction: column; gap: 20px; }
  .qb-item-row { display: flex; gap: 16px; padding-bottom: 20px; border-bottom: 1.5px solid #F9F9F9; }
  .qb-item-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  
  .qb-item-image { width: 95px; height: 95px; border-radius: 16px; overflow: hidden; border: 1px solid #F0F0F0; flex-shrink: 0; background: #F9F9F9; }
  .qb-item-image img { width: 100%; height: 100%; object-fit: cover; }
  .qb-img-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 32px; }

  .qb-item-details { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  .qb-item-top-line { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .qb-item-title { font-size: 15px; font-weight: 800; color: var(--qb-black); text-decoration: none; line-height: 1.35; flex: 1; }
  
  /* PROFESSIONALLY POSITIONED X BUTTON */
  .qb-item-remove-btn { background: #F5F5F5; border: none; color: #BBB; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 12px; transition: 0.2s; }
  .qb-item-remove-btn:active { background: var(--qb-red); color: white; transform: scale(0.9); }
  
  .qb-item-variant { font-size: 12px; color: var(--qb-gray); margin-top: 4px; font-weight: 600; }
  .qb-item-controls-row { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 12px; }
  .qb-price-amt { font-size: 17px; font-weight: 900; color: var(--qb-black); }

  /* Centered Qty Pill */
  .qb-qty-selector { background: #F5F5F5; border-radius: 14px; padding: 3px; display: flex; width: 110px; }
  .qb-qty-form { display: flex; align-items: center; width: 100%; }
  .qb-qty-btn { width: 32px; height: 32px; border: none; background: none; font-size: 20px; font-weight: 800; color: var(--qb-black); cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .qb-qty-val-wrapper { flex: 1; display: flex; align-items: center; justify-content: center; }
  .qb-qty-input { width: 100%; border: none; background: transparent; text-align: center !important; font-size: 15px; font-weight: 900; color: var(--qb-black); pointer-events: none; padding: 0; margin: 0; }

  .qb-add-more-link { display: block; text-align: center; margin-top: 20px; font-size: 14px; font-weight: 800; color: var(--qb-gold); text-decoration: none; padding: 14px; border: 2px dashed var(--qb-gold); border-radius: 16px; transition: 0.2s; }

  /* ? Button Circle */
  .qb-help-info-trigger { width: 30px; height: 30px; border-radius: 50%; background: var(--qb-gold); color: white; border: 2px solid white; font-weight: 900; font-size: 16px; cursor: pointer; box-shadow: 0 4px 10px rgba(244,180,0,0.3); transition: 0.2s; }
  .qb-help-info-trigger:active { transform: scale(0.9); }

  /* Delivery Input Box */
  .qb-input-pro-box { display: flex; align-items: center; background: #F9F9F9; border: 1.5px solid var(--qb-border); border-radius: 18px; margin: 16px 0; transition: 0.3s; }
  .qb-input-pro-box:focus-within { border-color: var(--qb-gold); background: #fff; box-shadow: 0 0 0 4px var(--qb-gold-soft); }
  .qb-input-pin-icon { padding-left: 18px; color: var(--qb-gold); display: flex; align-items: center; }
  .qb-input-main-field { flex: 1; padding: 18px 18px 18px 12px; background: transparent; border: none; font-size: 15px; font-weight: 700; color: var(--qb-black); outline: none; }

  .qb-nickname-chips { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .qb-nick-chip { padding: 14px; background: #fff; border: 1.5px solid var(--qb-border); border-radius: 16px; font-size: 14px; font-weight: 800; color: var(--qb-gray); cursor: pointer; text-align: center; }
  .qb-nick-chip.active { border-color: var(--qb-gold); background: var(--qb-gold-soft); color: var(--qb-gold); box-shadow: 0 4px 12px rgba(244,180,0,0.1); }

  /* Error Banner */
  .qb-validation-alert { display: none; background: #FFF1F2; border: 1px solid #FDA4AF; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; align-items: center; gap: 10px; animation: qbShake 0.4s; }
  .qb-validation-alert.active { display: flex; }
  .qb-err-text { font-size: 12px; font-weight: 700; color: #9F1239; margin: 0; text-transform: uppercase; line-height: 1.4; }
  @keyframes qbShake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

  /* Sticky Footer */
  .qb-sticky-checkout-bar { position: fixed; bottom: 65px; left: 0; right: 0; max-width: 500px; margin: 0 auto; background: #fff; padding: 16px 20px; border-top: 1px solid var(--qb-border); display: flex; align-items: center; gap: 16px; z-index: 1000; box-shadow: 0 -10px 40px rgba(0,0,0,0.05); }
  .qb-footer-tag { font-size: 10px; font-weight: 900; color: var(--qb-gray); letter-spacing: 1px; }
  .qb-footer-price { font-size: 22px; font-weight: 900; color: var(--qb-black); }
  .qb-btn-main-checkout { flex: 1; height: 58px; background: var(--qb-red); color: white; border: none; border-radius: 18px; font-size: 18px; font-weight: 900; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 25px rgba(196,30,58,0.25); }
  .qb-btn-main-checkout.qb-btn-locked { opacity: 0.6; filter: blur(0.4px); background: #999 !important; cursor: not-allowed; transform: scale(0.98); }

  /* TRUE GLOBAL MODAL (Portal Pop-out) */
  .qb-fixed-popup-overlay {
    position: fixed !important;
    inset: 0 !important;
    background: rgba(0,0,0,0.85) !important;
    backdrop-filter: blur(8px) !important;
    z-index: 2147483647 !important;
    display: none;
    align-items: flex-end;
    justify-content: center;
    padding: 20px;
    touch-action: none;
  }
  .qb-fixed-popup-overlay.is-active { display: flex; }

  .qb-popup-card { background: #fff !important; width: 100% !important; max-width: 500px !important; border-radius: 32px 32px 0 0 !important; padding: 24px 24px calc(24px + env(safe-area-inset-bottom)) !important; position: relative !important; box-shadow: 0 -10px 40px rgba(0,0,0,0.5) !important; text-align: center !important; }
  .qb-popup-notch { width: 40px; height: 4px; background: #eee; border-radius: 2px; margin: 0 auto 20px; }
  .qb-popup-close-x { position: absolute; top: 20px; right: 20px; background: #f5f5f5; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-weight: bold; color: #333; display: flex; align-items: center; justify-content: center; }
  .qb-popup-h { font-size: 20px; font-weight: 900; color: #111; margin-bottom: 8px; }
  .qb-popup-p { font-size: 14px; color: #666; margin-bottom: 24px; line-height: 1.5; }
  .qb-popup-media { width: 100%; border-radius: 18px; overflow: hidden; border: 1px solid #eee; margin-bottom: 24px; background: #f9f9f9; padding: 10px; }
  .qb-popup-media img { width: 100%; display: block; border-radius: 8px; max-height: 40vh; object-fit: contain; }
  .qb-btn-maps-app { display: flex; align-items: center; justify-content: center; background: #4285F4; color: #fff; text-decoration: none; padding: 16px; border-radius: 16px; font-weight: 800; font-size: 15px; margin-bottom: 12px; }
  .qb-btn-done-modal { width: 100%; padding: 16px; background: #f5f5f5; border: none; border-radius: 16px; font-weight: 700; color: #333; cursor: pointer; font-size: 15px; }

  .qb-billing-stack { display: flex; flex-direction: column; gap: 12px; }
  .qb-bill-line { display: flex; justify-content: space-between; font-size: 15px; font-weight: 700; color: var(--qb-gray); }
  .qb-calc-muted { font-size: 12px; color: #AAA; font-weight: 600; }
  .qb-bill-divider { height: 1px; border-top: 1.5px dashed var(--qb-border); margin: 4px 0; }
  .qb-total-row { display: flex; justify-content: space-between; align-items: baseline; }
  .qb-total-lbl { font-size: 18px; font-weight: 900; color: var(--qb-black); }
  .qb-total-val { font-size: 24px; font-weight: 900; color: var(--qb-black); }

  .qb-flex-between { display: flex; justify-content: space-between; align-items: center; }
  .animate-fade-in { animation: qbFadeIn 0.6s ease-out; }
  @keyframes qbFadeIn { from { opacity: 0; } to { opacity: 1; } }
  .animate-slide-up { animation: qbSlideUp 0.4s var(--qb-ease) forwards; }
  @keyframes qbSlideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

  .qb-empty-state { padding: 80px 20px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; }
  .qb-empty-icon { font-size: 90px; margin-bottom: 24px; filter: drop-shadow(0 10px 10px rgba(0,0,0,0.1)); }
  .qb-empty-title { font-size: 28px; font-weight: 900; }
  .qb-btn-primary { background: var(--qb-gold); color: white; padding: 18px 45px; border-radius: 16px; text-decoration: none; font-weight: 900; display: inline-block; margin-top: 30px; box-shadow: 0 10px 30px rgba(244,180,0,0.3); }
</style>

<script>
(function() {
  function initFinalCartRedesign() {
    const input = document.getElementById('LandmarkLink');
    const checkoutBtn = document.getElementById('qbMainCheckoutBtn');
    const errorBox = document.getElementById('qbCheckoutError');
    const modal = document.getElementById('landmarkModalOverlay');
    const body = document.body;

    // PORTAL: Physically move modal to Body root to bypass all section clipping
    if (modal && modal.parentNode !== body) body.appendChild(modal);

    const validate = () => {
      const val = (input?.value || '').trim();
      const isValid = val.length > 8 && (val.includes('google.com') || val.includes('maps.app') || val.includes('http'));
      if (checkoutBtn) {
        checkoutBtn.disabled = !isValid;
        checkoutBtn.classList.toggle('qb-btn-locked', !isValid);
      }
      if (errorBox) errorBox.classList.toggle('active', !isValid);
    };

    if (input) { input.addEventListener('input', validate); validate(); }

    document.addEventListener('click', (e) => {
      // ? Button Click - Trigger Modal
      if (e.target.closest('#openHelpBtn')) {
        e.preventDefault(); e.stopPropagation();
        if(modal) modal.classList.add('is-active');
        document.documentElement.classList.add('qb-no-scroll-final');
        return;
      }
      
      // Modal Close Clicks
      if (e.target.closest('#closeHelpBtn') || e.target.closest('#doneHelpBtn') || e.target === modal) {
        if(modal) modal.classList.remove('is-active');
        document.documentElement.classList.remove('qb-no-scroll-final');
        return;
      }

      // Quantity Actions
      const qtyBtn = e.target.closest('[data-qbtn]');
      if (qtyBtn) {
        const form = qtyBtn.closest('form');
        const inp = form.querySelector('.qb-qty-input');
        let val = parseInt(inp.value);
        if (qtyBtn.dataset.action === 'minus') {
          if (val > 1) val--; else if (confirm('Remove this item?')) val = 0; else return;
        } else val++;
        inp.value = val; form.submit();
        return;
      }

      // Nickname Interaction
      const chip = e.target.closest('.qb-nick-chip');
      if (chip) {
        localStorage.setItem('qb_landmark_' + (localStorage.getItem('qb_active_nickname') || 'Home'), input.value);
        document.querySelectorAll('.qb-nick-chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        const next = chip.dataset.nickname;
        localStorage.setItem('qb_active_nickname', next);
        input.value = localStorage.getItem('qb_landmark_' + next) || '';
        validate();
        return;
      }

      // Checkout Execution
      if (e.target.closest('#qbMainCheckoutBtn')) {
        const btn = e.target.closest('#qbMainCheckoutBtn');
        if (btn.disabled) return;
        btn.disabled = true; btn.innerHTML = 'Wait...';
        const nick = localStorage.getItem('qb_active_nickname') || 'Home';
        const fullNote = `Address Type: ${nick}\nGoogle Maps: ${input.value}\nLocation Data: ${localStorage.getItem('qb_selected_location') || 'N/A'}`;
        fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ note: fullNote }) })
        .finally(() => { window.location.href = '/checkout'; });
      }
    });

    const activeNick = localStorage.getItem('qb_active_nickname') || 'Home';
    document.querySelectorAll('.qb-nick-chip').forEach(chip => {
      if (chip.dataset.nickname === activeNick) chip.classList.add('active');
      const saved = localStorage.getItem('qb_landmark_' + activeNick);
      if (chip.dataset.nickname === activeNick && saved) { input.value = saved; validate(); }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initFinalCartRedesign);
  else initFinalProCartRedesign(); // Ensure it runs if DOM already ready
})();
</script>

{% schema %}{ "name": "Cart Page", "settings": [], "presets": [{ "name": "Cart Page" }] }{% endschema %}