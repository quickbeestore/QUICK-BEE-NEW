<!-- sections/main-cart.liquid -->
<cart-items-component class="qb-cart-component" data-section-id="{{ section.id }}">
  <div class="qb-cart-wrapper">
    {%- if cart.empty? -%}
      <div class="qb-empty-cart animate-fade-in">
        <div class="qb-empty-card">
          <div class="qb-empty-icon-wrap">
            <span class="qb-empty-emoji">🛒</span>
          </div>
          <h1 class="qb-empty-title">Your cart is empty</h1>
          <p class="qb-empty-subtitle">Add items to get started!</p>
          <a href="{{ routes.all_products_collection_url }}" class="qb-empty-btn">Start Shopping</a>
        </div>
      </div>
    {%- else -%}

      <div class="qb-cart-header">
        <div class="qb-header-content">
          <h1>Review Order</h1>
          <span class="qb-header-count">{{ cart.item_count }} items</span>
        </div>
      </div>

      <div class="qb-cart-main-scroll">
        <div class="qb-cart-section">
          <div class="qb-cart-items">
            {%- for item in cart.items -%}
              <div class="qb-cart-item">
                <div class="qb-item-img">
                  {% if item.image %}<img src="{{ item.image | image_url: width: 180 }}" alt="{{ item.title | escape }}">{% else %}<div class="qb-no-img">🐝</div>{% endif %}
                </div>
                <div class="qb-item-details">
                  <div class="qb-item-row">
                    <a href="{{ item.url }}" class="qb-item-name">{{ item.product.title | truncate: 45 }}</a>
                    <form action="{{ routes.cart_change_url }}" method="post" class="qb-item-remove">
                      <input type="hidden" name="id" value="{{ item.key }}">
                      <input type="hidden" name="quantity" value="0">
                      <button type="submit">✕</button>
                    </form>
                  </div>
                  <div class="qb-item-bottom">
                    <span class="qb-price-curr">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    <div class="qb-qty-box">
                      <form action="{{ routes.cart_change_url }}" method="post">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-qty-act qb-qty-minus">−</button>
                        <input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-qty-val">
                        <button type="button" class="qb-qty-act qb-qty-plus">+</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          <a href="{{ routes.all_products_collection_url }}" class="qb-add-more">+ Add more items</a>
        </div>

        <div class="qb-cart-section">
          <div class="qb-landmark-header">
            <h2 class="qb-landmark-title">DELIVERY LANDMARK</h2>
            <button type="button" class="qb-help-cute-circle" id="openHelpBtn">?</button>
          </div>
          <div class="qb-landmark-input-wrapper">
            <span class="qb-input-icon">📍</span>
            <input type="text" id="LandmarkLink" placeholder="Paste Google Maps link here..." class="qb-landmark-input">
          </div>
          <div class="qb-nickname-grid">
            <button type="button" class="qb-nick-btn" data-nickname="Home">🏠 Home</button>
            <button type="button" class="qb-nick-btn" data-nickname="Office">🏢 Office</button>
            <button type="button" class="qb-nick-btn" data-nickname="Other">✨ Other</button>
            <button type="button" class="qb-nick-btn" data-nickname="Current">📦 Current</button>
          </div>
        </div>

        <div class="qb-cart-section qb-bill-card">
          <h2 class="qb-bill-title">Bill Details</h2>
          <div class="qb-bill-row"><span>Item Total</span><span>Rs {{ cart.total_price | divided_by: 100 }}</span></div>
          <div class="qb-bill-row"><span>Delivery Fee</span><span class="qb-text-green">FREE</span></div>
          <div class="qb-total-row"><span>Grand Total</span><span>Rs {{ cart.total_price | divided_by: 100 }}</span></div>
        </div>
      </div>

      <div class="qb-sticky-footer">
        <div class="qb-footer-info">
          <span class="qb-footer-label">TOTAL</span>
          <span class="qb-footer-price">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-checkout-submit" id="qb-checkout-btn">Checkout ➔</button>
      </div>
    {%- endif -%}
  </div>
</cart-items-component>

<!-- HELP MODAL (FAIL-SAFE TOP LEVEL) -->
<div id="landmarkModalOverlay" class="qb-modal-overlay">
  <div class="qb-modal-container animate-slide-up">
    <div class="qb-modal-handle"></div>
    <button class="qb-modal-close" id="closeHelpBtn">✕</button>
    <div class="qb-modal-body">
      <h3 class="qb-modal-title">How to share location?</h3>
      <img src="{{ 'popupgoogle.png' | asset_url }}" alt="Tutorial" class="qb-guide-image">
      <a href="https://www.google.com/maps" target="_blank" class="qb-maps-app-btn">Open Google Maps App</a>
      <button type="button" class="qb-modal-done" id="doneHelpBtn">Got it!</button>
    </div>
  </div>
</div>

<style>
  :root { --qb-purple: #7a14ac; --qb-red: #C41E3A; --qb-black: #111111; --qb-bg: #f8f9fa; --qb-border: #eaecf0; --qb-ease: cubic-bezier(0.4, 0, 0.2, 1); }
  
  .qb-cart-component { display: block; background: var(--qb-bg); min-height: 100vh; }
  .qb-cart-wrapper { max-width: 500px; margin: 0 auto; background: #fff; box-shadow: 0 0 20px rgba(0,0,0,0.05); min-height: 100vh; position: relative; }

  /* Help Circle Button Design */
  .qb-help-cute-circle {
    width: 30px;
    height: 30px;
    background: var(--qb-purple);
    color: #fff;
    border: 3px solid #fff;
    border-radius: 50%;
    font-size: 16px;
    font-weight: 900;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(122, 20, 172, 0.2);
    transition: all 0.2s;
    z-index: 100;
  }
  .qb-help-cute-circle:active { transform: scale(0.9); }

  /* Scroller */
  .qb-cart-main-scroll { padding: 16px 16px 140px; display: flex; flex-direction: column; gap: 16px; overflow-y: auto; -webkit-overflow-scrolling: touch; }
  .qb-cart-section { background: #fff; border-radius: 20px; border: 1px solid var(--qb-border); padding: 16px; }
  
  /* Landmark */
  .qb-landmark-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .qb-landmark-title { font-size: 12px; font-weight: 900; color: #888; margin: 0; letter-spacing: 0.5px; }
  .qb-landmark-input-wrapper { position: relative; display: flex; align-items: center; margin-bottom: 16px; }
  .qb-input-icon { position: absolute; left: 12px; font-size: 16px; }
  .qb-landmark-input { width: 100%; padding: 12px 12px 12px 38px; background: #f8f9fa; border: 1.5px solid var(--qb-border); border-radius: 12px; font-size: 14px; outline: none; }
  .qb-nickname-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .qb-nick-btn { padding: 10px; background: #fff; border: 1.5px solid var(--qb-border); border-radius: 10px; font-size: 12px; font-weight: 700; cursor: pointer; }
  .qb-nick-btn.active { border-color: var(--qb-purple); background: #fdf7ff; color: var(--qb-purple); }

  /* Sticky Footer */
  .qb-sticky-footer { position: fixed; bottom: 65px; left: 0; right: 0; background: #fff; padding: 16px 20px calc(16px + env(safe-area-inset-bottom)); border-top: 1px solid var(--qb-border); display: flex; align-items: center; justify-content: space-between; gap: 16px; z-index: 1000; box-shadow: 0 -5px 20px rgba(0,0,0,0.1); width: 100%; max-width: 500px; margin: 0 auto; }
  .qb-checkout-submit { flex: 1; background: var(--qb-red); color: #fff; border: none; height: 50px; border-radius: 16px; font-size: 17px; font-weight: 900; cursor: pointer; }

  /* Modal */
  .qb-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(6px); z-index: 999999999; display: none; align-items: flex-end; justify-content: center; }
  .qb-modal-overlay.active { display: flex; }
  .qb-modal-container { background: #fff; width: 100%; max-width: 500px; border-radius: 32px 32px 0 0; padding: 24px; position: relative; box-shadow: 0 -10px 40px rgba(0,0,0,0.3); }
  .qb-modal-handle { width: 40px; height: 4px; background: #eee; border-radius: 2px; margin: 0 auto 20px; }
  .qb-modal-close { position: absolute; top: 20px; right: 20px; background: #f5f5f5; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: bold; }
  .qb-guide-image { width: 100%; border-radius: 20px; margin-bottom: 20px; border: 1px solid #eee; display: block; }
  .qb-maps-app-btn { display: flex; align-items: center; justify-content: center; background: #4285F4; color: #fff; text-decoration: none; padding: 16px; border-radius: 16px; font-weight: 800; margin-bottom: 12px; }
  .qb-modal-done { width: 100%; padding: 16px; background: #f0f0f0; border: none; border-radius: 16px; font-weight: 700; color: #333; cursor: pointer; }

  .animate-slide-up { animation: qbSlideUp 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
  @keyframes qbSlideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
</style>

<script>
(function() {
  function init() {
    const input = document.getElementById('LandmarkLink');
    const openBtn = document.getElementById('openHelpBtn');
    const closeBtn = document.getElementById('closeHelpBtn');
    const doneBtn = document.getElementById('doneHelpBtn');
    const modal = document.getElementById('landmarkModalOverlay');

    if (openBtn && modal) {
      openBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        modal.classList.add('active');
      });
      [closeBtn, doneBtn].forEach(btn => {
        if (btn) btn.addEventListener('click', () => modal.classList.remove('active'));
      });
      modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('active'); });
    }

    if (!input) return;

    // Load initial storage data
    const activeNick = localStorage.getItem('qb_active_nickname') || 'Home';
    document.querySelectorAll('.qb-nick-btn').forEach(btn => {
      const savedLink = localStorage.getItem('qb_landmark_' + btn.dataset.nickname);
      if (btn.dataset.nickname === activeNick) {
        btn.classList.add('active');
        if (savedLink) input.value = savedLink;
      }
    });

    // Global listener
    document.addEventListener('click', (e) => {
      const nickBtn = e.target.closest('.qb-nick-btn');
      if (nickBtn) {
        const inp = document.getElementById('LandmarkLink');
        const oldNick = localStorage.getItem('qb_active_nickname') || 'Home';
        if (inp) localStorage.setItem('qb_landmark_' + oldNick, inp.value);
        document.querySelectorAll('.qb-nick-btn').forEach(b => b.classList.remove('active'));
        nickBtn.classList.add('active');
        const newNick = nickBtn.dataset.nickname;
        localStorage.setItem('qb_active_nickname', newNick);
        const newSaved = localStorage.getItem('qb_landmark_' + newNick);
        if (inp) inp.value = newSaved || '';
        return;
      }
      
      const act = e.target.closest('.qb-qty-act');
      if (act) {
        const form = act.closest('form');
        const valInp = form.querySelector('.qb-qty-val');
        let val = parseInt(valInp.value);
        if (act.classList.contains('qb-qty-minus')) {
          if (val > 1) val--;
          else if (confirm('Remove item?')) val = 0;
          else return;
        } else { val++; }
        valInp.value = val;
        form.submit();
        return;
      }

      const checkout = e.target.closest('#qb-checkout-btn');
      if (checkout) {
        if (checkout.disabled) return;
        checkout.innerHTML = 'Wait...';
        checkout.disabled = true;
        const note = 'Map: ' + (document.getElementById('LandmarkLink')?.value || '');
        fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ note: note }) })
        .finally(() => { window.location.href = '/checkout'; });
      }
    });

    input.addEventListener('input', () => {
      const nick = localStorage.getItem('qb_active_nickname') || 'Home';
      localStorage.setItem('qb_landmark_' + nick, input.value);
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

