<cart-items-component class="cart-items-component" data-section-id="{{ section.id }}">
  <div class="quick-cart-wrapper">
    {%- if cart.empty? -%}

    <!-- EMPTY CART STATE -->
    <div class="empty-cart-state">
      <div class="empty-cart-content">
        <div class="empty-icon">🐝</div>
        <h1 class="empty-title">Your Hive is Empty</h1>
        <p class="empty-text">No sweet treats here yet. Let's go shopping!</p>
        <a href="{{ routes.all_products_collection_url }}" class="empty-cta">Start Shopping</a>
      </div>
    </div>

    {%- else -%}

    <!-- HEADER -->
    <div class="cart-header">
      <h1>🐝 Your Hive</h1>
      <p>{{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %}</p>
    </div>

    <!-- CART ITEMS -->
    <div class="cart-items-section">
      {%- for item in cart.items -%}
        <div class="cart-item-card">
          <!-- Product Image -->
          <div class="item-image">
            <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title }}">
          </div>

          <!-- Product Info + Actions (right column) -->
          <div class="item-right">
            <!-- Top row: name + remove -->
            <div class="item-top-row">
              <h3 class="item-name">{{ item.title }}</h3>
              <form action="{{ routes.cart_change_url }}" method="post" class="remove-form">
                <input type="hidden" name="id" value="{{ item.key }}">
                <input type="hidden" name="quantity" value="0">
                <button type="submit" class="remove-btn" title="Remove">✕</button>
              </form>
            </div>

            {%- if item.variant.title != 'Default Title' -%}
              <p class="item-variant">{{ item.variant.title }}</p>
            {%- endif -%}

            <!-- Bottom row: qty stepper + total price -->
            <div class="item-bottom-row">
              <form action="{{ routes.cart_change_url }}" method="post" class="qty-form">
                <input type="hidden" name="id" value="{{ item.key }}">
                <div class="qty-controls">
                  <button type="button" class="qty-btn qty-decrease" data-item-key="{{ item.key }}">−</button>
                  <input type="number" name="quantity" value="{{ item.quantity }}" min="1" class="qty-input" data-item-key="{{ item.key }}">
                  <button type="button" class="qty-btn qty-increase" data-item-key="{{ item.key }}">+</button>
                </div>
              </form>
              <p class="item-total">Rs {{ item.final_line_price | money_without_currency }}</p>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <!-- ADD MORE LINK -->
    <div class="add-more-section">
      <a href="{{ routes.all_products_collection_url }}" class="add-more-btn">+ Add More Items</a>
    </div>

    <!-- ORDER SUMMARY -->
    {%- assign subtotal_calc = 0 -%}
    {%- for item in cart.items -%}
      {%- assign subtotal_calc = subtotal_calc | plus: item.final_line_price -%}
    {%- endfor -%}

    <div class="order-summary">
      <h3 class="summary-title">Order Summary</h3>

      <div class="summary-row">
        <span>Subtotal</span>
        <span class="summary-value">Rs {{ subtotal_calc | divided_by: 100 }}</span>
      </div>

      <div class="summary-row">
        <span>Delivery</span>
        <span class="summary-value">At checkout</span>
      </div>

      <div class="summary-row">
        <span>Taxes</span>
        <span class="summary-value">At checkout</span>
      </div>

      <div class="summary-divider"></div>

      <div class="summary-total">
        <span class="total-label">Total</span>
        <span class="total-amount">Rs {{ subtotal_calc | divided_by: 100 }}</span>
      </div>
    </div>

    <!-- CHECKOUT BUTTON (Sticky) -->
    <div class="checkout-section">
      <a href="{{ routes.checkout_url }}" class="checkout-btn">🐝 Checkout Now</a>
    </div>

    {%- endif -%}
  </div>
</cart-items-component>

<style>
  :root {
    --bee-gold: #F4B400;
    --bee-light: #FFF9E6;
    --bee-dark: #1a1a1a;
    --bee-gray: #666666;
    --bee-light-gray: #f5f5f5;
  }

  * {
    box-sizing: border-box;
  }

  .quick-cart-wrapper {
    background: #f7f7f7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* EMPTY CART */
  .empty-cart-state {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .empty-cart-content {
    text-align: center;
  }

  .empty-icon {
    font-size: 80px;
    margin-bottom: 16px;
    animation: bounce 2s infinite;
  }

  .empty-title {
    font-size: 24px;
    font-weight: 900;
    color: var(--bee-dark);
    margin: 0 0 8px 0;
  }

  .empty-text {
    font-size: 14px;
    color: var(--bee-gray);
    margin: 0 0 24px 0;
  }

  .empty-cta {
    display: inline-block;
    background: var(--bee-gold);
    color: var(--bee-dark);
    padding: 12px 32px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    transition: all 0.2s;
  }

  .empty-cta:active {
    transform: scale(0.95);
  }

  /* HEADER */
  .cart-header {
    padding: 16px 16px 12px 16px;
    background: linear-gradient(135deg, #FFF9E6 0%, #FFFBF0 100%);
    border-bottom: 1px solid #e8e8e8;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .cart-header h1 {
    font-size: 24px;
    font-weight: 900;
    color: var(--bee-dark);
    margin: 0;
  }

  .cart-header p {
    font-size: 12px;
    color: var(--bee-gray);
    margin: 4px 0 0 0;
  }

  /* CART ITEMS */
  .cart-items-section {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cart-item-card {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 12px;
    padding: 12px;
    background: #fff;
    border-radius: 16px;
    align-items: center;
    box-shadow: 0 1px 6px rgba(0,0,0,0.07);
  }

  .item-image {
    width: 90px;
    height: 90px;
    border-radius: 12px;
    overflow: hidden;
    border: 2px solid var(--bee-gold);
    flex-shrink: 0;
  }

  .item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* RIGHT COLUMN */
  .item-right {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .item-top-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }

  .item-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--bee-dark);
    margin: 0;
    line-height: 1.3;
    flex: 1;
    min-width: 0;
    word-break: break-word;
  }

  .item-variant {
    font-size: 11px;
    color: var(--bee-gray);
    margin: 0;
  }

  .item-bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .item-total {
    font-size: 16px;
    font-weight: 800;
    color: var(--bee-gold);
    margin: 0;
    white-space: nowrap;
  }

  .qty-form { flex: 0 0 auto; }

  .qty-controls {
    display: flex;
    align-items: center;
    background: #f5f5f5;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    overflow: hidden;
    width: fit-content;
  }

  .qty-btn {
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    cursor: pointer;
    font-weight: 700;
    font-size: 16px;
    color: var(--bee-dark);
    transition: background 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .qty-btn:active { background: #e0e0e0; }

  .qty-input {
    width: 32px;
    height: 32px;
    border: none;
    border-left: 1px solid #e0e0e0;
    border-right: 1px solid #e0e0e0;
    text-align: center;
    font-size: 13px;
    font-weight: 700;
    background: #fff;
    color: var(--bee-dark);
    padding: 0;
  }

  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .remove-btn {
    width: 30px;
    height: 30px;
    border: none;
    background: #FFF0F0;
    color: #FF4444;
    border-radius: 50%;
    cursor: pointer;
    font-size: 14px;
    font-weight: 700;
    transition: background 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .remove-btn:active {
    background: #FF4444;
    color: white;
  }

  /* ADD MORE */
  .add-more-section {
    padding: 4px 12px 12px;
    text-align: center;
  }

  .add-more-btn {
    display: inline-block;
    color: var(--bee-gold);
    text-decoration: none;
    font-weight: 700;
    font-size: 13px;
    padding: 10px 24px;
    border: 1.5px solid var(--bee-gold);
    border-radius: 8px;
    transition: all 0.2s;
    background: #fff;
  }

  .add-more-btn:active {
    background: var(--bee-gold);
    color: var(--bee-dark);
  }

  /* ORDER SUMMARY */
  .order-summary {
    padding: 16px 16px 0 16px;
    background: var(--bee-light);
    border-top: 1px solid #e8e8e8;
  }

  .summary-title {
    font-size: 13px;
    font-weight: 800;
    color: var(--bee-dark);
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin: 0 0 12px 0;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--bee-gray);
    margin-bottom: 10px;
    font-weight: 500;
  }

  .summary-value {
    color: var(--bee-dark);
    font-weight: 600;
  }

  .summary-divider {
    height: 1px;
    background: var(--bee-gold);
    margin: 12px 0;
  }

  .summary-total {
    display: flex;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .total-label {
    font-size: 15px;
    font-weight: 800;
    color: var(--bee-dark);
  }

  .total-amount {
    font-size: 20px;
    font-weight: 900;
    color: var(--bee-gold);
  }

  /* CHECKOUT SECTION (Sticky) */
  .checkout-section {
    padding: 12px 16px 16px 16px;
    background: white;
    border-top: 1px solid #e8e8e8;
    position: sticky;
    bottom: 0;
    z-index: 20;
  }

  .checkout-btn {
    display: block;
    width: 100%;
    padding: 14px 16px;
    background: linear-gradient(135deg, var(--bee-gold) 0%, #E8A500 100%);
    color: var(--bee-dark);
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 800;
    text-decoration: none;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 4px 12px rgba(244, 180, 0, 0.3);
  }

  .checkout-btn:active {
    transform: scale(0.98);
    box-shadow: 0 2px 8px rgba(244, 180, 0, 0.2);
  }

  /* ANIMATIONS */
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* RESPONSIVE */
  @media (min-width: 768px) {
    .cart-item-card {
      grid-template-columns: 100px 1fr;
      align-items: start;
    }

    .item-image {
      width: 100px;
      height: 100px;
    }

    .checkout-btn {
      padding: 16px 20px;
      font-size: 16px;
    }
  }
</style>

<script>
  // Quantity controls
  document.addEventListener('click', function(e) {
    const decreaseBtn = e.target.closest('.qty-decrease');
    const increaseBtn = e.target.closest('.qty-increase');

    if (decreaseBtn) {
      e.preventDefault();
      const input = decreaseBtn.closest('.qty-controls').querySelector('.qty-input');
      if (parseInt(input.value) > 1) {
        input.value = parseInt(input.value) - 1;
        input.closest('.qty-form').submit();
      }
    }

    if (increaseBtn) {
      e.preventDefault();
      const input = increaseBtn.closest('.qty-controls').querySelector('.qty-input');
      input.value = parseInt(input.value) + 1;
      input.closest('.qty-form').submit();
    }
  });

  // Quantity input change
  document.querySelectorAll('.qty-input').forEach(input => {
    input.addEventListener('change', function() {
      if (this.value < 1) this.value = 1;
      this.closest('.qty-form').submit();
    });
  });
</script>

{% schema %}
{
  "name": "Cart",
  "settings": [],
  "presets": [
    {
      "name": "Cart"
    }
  ]
}
{% endschema %}
