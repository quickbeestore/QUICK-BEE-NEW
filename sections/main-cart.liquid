<!-- sections/main-cart.liquid — Theme-aware cart + fixed qty selector -->
<style>
/* ── ROOT ── */
:root {
  --c-bg: #FAFAF6;
  --c-card: #FFFFFF;
  --c-card2: #F5EFE4;
  --c-card3: #EDE5D8;
  --c-border: rgba(100, 75, 40, 0.10);
  --c-border2: rgba(100, 75, 40, 0.18);
  --c-gold: #F4B400;
  --c-gold2: #FFD700;
  --c-gold-dim: rgba(244,180,0,0.10);
  --c-gold-border: rgba(244,180,0,0.25);
  --c-gold-glow: 0 0 28px rgba(244,180,0,0.18);
  --c-text: #121826;
  --c-text2: #516074;
  --c-text3: #7b8798;
  --c-red: #FF4444;
  --c-red-dim: rgba(255,68,68,0.12);
  --c-ease: cubic-bezier(0.4,0,0.2,1);
  --c-input-bg: #ffffff;
  --c-input-border: #d8dee8;
  --c-input-text: #121826;
  --c-modal-bg: #ffffff;
  --c-modal-title: #121826;
  --c-modal-copy: #66758a;
  --c-overlay: rgba(12, 18, 28, 0.58);
  --c-shadow: 0 18px 40px rgba(15, 23, 42, 0.10);
  --c-sticky-bg: rgba(255,255,255,0.96);
  --c-sticky-border: rgba(15, 23, 42, 0.10);
  --c-sticky-shadow: 0 -16px 32px rgba(15, 23, 42, 0.12);
}

[data-theme="dark"] {
  --c-bg: #090909;
  --c-card: #111111;
  --c-card2: #181818;
  --c-card3: #202020;
  --c-border: rgba(255,255,255,0.07);
  --c-border2: rgba(255,255,255,0.12);
  --c-text: #F0F0F0;
  --c-text2: #999999;
  --c-text3: #555555;
  --c-input-bg: #1A1A1A;
  --c-input-border: #333333;
  --c-input-text: #FFFFFF;
  --c-modal-bg: #0F0F0F;
  --c-modal-title: #F0F0F0;
  --c-modal-copy: #777777;
  --c-overlay: rgba(0,0,0,0.88);
  --c-shadow: 0 32px 80px rgba(0,0,0,0.9), 0 0 60px rgba(244,180,0,0.08);
  --c-sticky-bg: rgba(9,9,9,0.97);
  --c-sticky-border: rgba(255,255,255,0.12);
  --c-sticky-shadow: 0 -20px 40px rgba(0,0,0,0.6);
}

html.qb-no-scroll { overflow: hidden !important; }
body { background: var(--c-bg) !important; color: var(--c-text) !important; }

/* ── ROOT CONTAINER ── */
.qb-cart-root {
  display: block;
  background: var(--c-bg);
  min-height: 100vh;
  padding-bottom: 160px;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.qb-cart-container {
  max-width: 500px;
  margin: 0 auto;
  background: var(--c-bg);
  min-height: 100vh;
  position: relative;
}

/* ── EMPTY ── */
.qb-empty-hive {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: 60vh; text-align: center;
  padding: 40px 24px; gap: 16px;
}
.qb-empty-icon { font-size: 64px; }
.qb-empty-hive h1 { font-size: 24px; font-weight: 900; color: var(--c-text); }
.qb-empty-hive p { font-size: 15px; color: var(--c-text2); }
.qb-btn-explore {
  display: inline-block; background: var(--c-gold); color: #000;
  font-weight: 900; font-size: 15px; padding: 14px 32px;
  border-radius: 14px; text-decoration: none; transition: all 0.22s;
}
.qb-btn-explore:hover {
  background: var(--c-gold2); box-shadow: 0 6px 20px rgba(244,180,0,0.4);
  transform: translateY(-2px);
}

/* ── HEADER ── */
.qb-header-row {
  padding: 28px 20px 18px;
  display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1px solid var(--c-border);
}
.qb-page-title { font-size: 22px; font-weight: 900; color: var(--c-text); margin: 0; }
.qb-badge-count {
  background: var(--c-gold-dim); color: var(--c-gold); font-size: 11px;
  font-weight: 800; padding: 5px 12px; border-radius: 20px;
  border: 1px solid var(--c-gold-border);
}

/* ── BODY ── */
.qb-cart-body { padding: 14px 14px 0; display: flex; flex-direction: column; gap: 12px; }

/* ── SECTION CARD ── */
.qb-cart-section {
  background: var(--c-card);
  border: 1px solid var(--c-border);
  border-radius: 18px;
  padding: 18px;
  position: relative;
}
.qb-sec-tag {
  font-size: 10px; font-weight: 900; color: var(--c-text3);
  letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 14px;
}

/* ── ITEMS ── */
.qb-items-list { display: flex; flex-direction: column; gap: 16px; }
.qb-item-card {
  display: flex; gap: 14px; padding-bottom: 16px;
  border-bottom: 1px solid var(--c-border);
}
.qb-item-card:last-child { border-bottom: none; padding-bottom: 0; }
.qb-item-thumb {
  width: 80px; height: 80px; border-radius: 12px; overflow: hidden;
  border: 1px solid var(--c-border); flex-shrink: 0; background: var(--c-card2);
}
.qb-item-thumb img { width: 100%; height: 100%; object-fit: cover; }
.qb-thumb-fall { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 28px; }
.qb-item-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.qb-item-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
.qb-item-name {
  font-size: 14px; font-weight: 700; color: var(--c-text); text-decoration: none;
  line-height: 1.4; flex: 1; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
/* REMOVE BUTTON — override global button:100% */
.qb-item-remove {
  background: var(--c-card2) !important; border: 1px solid var(--c-border) !important;
  color: var(--c-text3) !important; width: 26px !important; min-width: 26px !important;
  max-width: 26px !important; height: 26px !important; border-radius: 50% !important;
  cursor: pointer !important; display: flex !important; align-items: center !important;
  justify-content: center !important; flex-shrink: 0 !important; transition: all 0.18s !important;
  padding: 0 !important; min-height: unset !important;
}
.qb-item-remove:hover {
  background: var(--c-red-dim) !important; border-color: rgba(255,68,68,0.3) !important;
  color: var(--c-red) !important;
}
.qb-item-v { font-size: 11px; color: var(--c-text3); font-weight: 500; }
.qb-item-bottom {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: auto; padding-top: 8px;
}
.qb-item-price { font-size: 16px; font-weight: 900; color: var(--c-gold); letter-spacing: -0.3px; }

/* ── QUANTITY PILL — override theme's global button:100% & flex-wrap:wrap ── */
.qb-qty-pill {
  background: var(--c-card2) !important;
  border: 1px solid var(--c-border2) !important;
  border-radius: 12px !important;
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
  align-items: center !important;
  overflow: hidden !important;
  width: 106px !important;
  max-width: 106px !important;
  height: 36px !important;
  flex-shrink: 0 !important;
}
.qb-qty-form {
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
  align-items: center !important;
  width: 100% !important;
  height: 100% !important;
  overflow: hidden !important;
  margin: 0 !important;
  padding: 0 !important;
}
.qb-qty-act {
  width: 34px !important; min-width: 34px !important; max-width: 34px !important;
  height: 34px !important; border: none !important; background: transparent !important;
  font-size: 18px !important; font-weight: 800 !important; color: var(--c-text) !important;
  cursor: pointer !important; display: flex !important; align-items: center !important;
  justify-content: center !important; flex-shrink: 0 !important; transition: background 0.15s !important;
  padding: 0 !important; margin: 0 !important; border-radius: 0 !important;
  min-height: unset !important; line-height: 1 !important;
}
.qb-qty-act:active { background: var(--c-card3) !important; }
.qb-qty-box {
  flex: 1 !important; display: flex !important; align-items: center !important;
  justify-content: center !important; border-left: 1px solid var(--c-border) !important;
  border-right: 1px solid var(--c-border) !important; height: 100% !important; min-width: 0 !important;
}
.qb-qty-num {
  width: 36px !important; max-width: 36px !important; border: none !important;
  background: transparent !important; text-align: center !important; font-size: 14px !important;
  font-weight: 900 !important; color: var(--c-text) !important; pointer-events: none !important;
  padding: 0 !important; margin: 0 !important; min-height: unset !important;
}
.qb-qty-num::-webkit-inner-spin-button,
.qb-qty-num::-webkit-outer-spin-button { -webkit-appearance: none !important; }

/* ADD MORE */
.qb-add-more-items {
  display: block; text-align: center; margin-top: 14px; padding: 12px;
  background: var(--c-card2); border: 1px dashed var(--c-border2);
  border-radius: 12px; color: var(--c-gold); font-size: 13px;
  font-weight: 700; text-decoration: none; transition: all 0.2s;
}
.qb-add-more-items:hover { background: var(--c-gold-dim); border-color: var(--c-gold-border); }

/* ── BILLING ── */
.qb-bill-stack { display: flex; flex-direction: column; gap: 10px; }
.qb-bill-row { display: flex; justify-content: space-between; font-size: 14px; font-weight: 600; color: var(--c-text2); }
.qb-muted-txt { color: var(--c-text3); font-style: italic; }
.qb-bill-dash { height: 1px; border-top: 1px dashed var(--c-border2); margin: 2px 0; }
.qb-bill-total { display: flex; justify-content: space-between; align-items: baseline; }
.qb-total-lbl { font-size: 14px; font-weight: 800; color: var(--c-text); }
.qb-total-val { font-size: 20px; font-weight: 900; color: var(--c-gold); letter-spacing: -0.5px; }

/* ── STICKY CHECKOUT — CENTERED FULL WIDTH ── */
.qb-sticky-checkout {
  position: fixed; bottom: 65px; left: 0; right: 0; max-width: 500px;
  margin: 0 auto; background: var(--c-sticky-bg); padding: 12px 16px 14px;
  border-top: 1px solid var(--c-sticky-border); z-index: 900;
  box-shadow: var(--c-sticky-shadow); backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px); display: flex; flex-direction: column; gap: 10px;
}
.qb-sticky-amount-row {
  display: flex; justify-content: space-between; align-items: center; padding: 0 2px;
}
.qb-sticky-tag { font-size: 10px; font-weight: 800; letter-spacing: 1.5px; color: var(--c-text3); text-transform: uppercase; }
.qb-sticky-price { font-size: 20px; font-weight: 900; color: var(--c-gold); letter-spacing: -0.5px; }
.qb-btn-checkout-main {
  width: 100% !important; height: 54px !important;
  background: linear-gradient(135deg, var(--c-gold), var(--c-gold2)) !important;
  color: #000 !important; border: none !important; border-radius: 16px !important;
  font-size: 17px !important; font-weight: 900 !important; cursor: pointer !important;
  transition: all 0.22s !important; letter-spacing: 0.3px !important; min-height: unset !important;
}
.qb-btn-checkout-main:not(.qb-is-locked):hover {
  box-shadow: 0 8px 24px rgba(244,180,0,0.45) !important; transform: translateY(-1px) !important;
}
.qb-btn-checkout-main.qb-is-locked {
  opacity: 0.35 !important; background: var(--c-card3) !important;
  color: var(--c-text3) !important; cursor: not-allowed !important;
  box-shadow: none !important; transform: none !important;
}

.animate-fade-in { animation: qbFadeIn 0.3s ease-out; }
@keyframes qbFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.animate-pop-in { animation: qbPopIn 0.38s cubic-bezier(0.34, 1.56, 0.64, 1); }
@keyframes qbPopIn {
  from { transform: scale(0.88) translateY(16px); opacity: 0; }
  to   { transform: scale(1) translateY(0); opacity: 1; }
}

/* ═══════════════════════════════════
   CHECKOUT CONFIRM BOTTOM SHEET
═══════════════════════════════════ */
.qb-co-backdrop {
  position: fixed; inset: 0; z-index: 99998;
  background: rgba(0,0,0,0);
  pointer-events: none;
  transition: background 0.32s ease, backdrop-filter 0.32s ease;
}
.qb-co-backdrop.show {
  background: rgba(0,0,0,0.52);
  pointer-events: all;
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
}

.qb-co-sheet {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  max-width: 500px; margin: 0 auto;
  background: #fff;
  border-radius: 26px 26px 0 0;
  padding: 0 20px calc(28px + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -12px 48px rgba(0,0,0,0.18);
}
[data-theme="dark"] .qb-co-sheet { background: #161616; border-top: 1px solid #2a2a2a; }
.qb-co-backdrop.show .qb-co-sheet { transform: translateY(0); }

.qb-co-handle {
  width: 38px; height: 4px;
  background: #e0e0e0; border-radius: 2px;
  margin: 12px auto 22px;
}
[data-theme="dark"] .qb-co-handle { background: #333; }

.qb-co-top {
  text-align: center; margin-bottom: 18px;
}
.qb-co-icon { font-size: 42px; display: block; margin-bottom: 10px; }
.qb-co-title {
  font-size: 19px; font-weight: 900; color: #0d0d0d;
  margin: 0 0 5px; letter-spacing: -0.3px; line-height: 1.25;
}
[data-theme="dark"] .qb-co-title { color: #f0f0f0; }
.qb-co-sub {
  font-size: 12.5px; color: #999; font-weight: 500; line-height: 1.5; margin: 0;
}

/* Items mini-list */
.qb-co-items {
  background: var(--c-card2, #f8f8f8);
  border-radius: 14px; padding: 4px 12px;
  margin-bottom: 14px;
  max-height: 180px; overflow-y: auto;
}
[data-theme="dark"] .qb-co-items { background: #1e1e1e; }
.qb-co-item {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 0;
  border-bottom: 1px solid rgba(0,0,0,0.055);
}
[data-theme="dark"] .qb-co-item { border-bottom-color: rgba(255,255,255,0.06); }
.qb-co-item:last-child { border-bottom: none; }
.qb-co-item-img {
  width: 38px; height: 38px; border-radius: 9px;
  object-fit: cover; flex-shrink: 0;
  background: #eee;
}
.qb-co-item-fallback {
  width: 38px; height: 38px; border-radius: 9px;
  background: #f0f0f0; display: flex; align-items: center;
  justify-content: center; font-size: 18px; flex-shrink: 0;
}
[data-theme="dark"] .qb-co-item-fallback { background: #2a2a2a; }
.qb-co-item-name {
  flex: 1; font-size: 12.5px; font-weight: 600;
  color: #1a1a1a; line-height: 1.35;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
[data-theme="dark"] .qb-co-item-name { color: #ddd; }
.qb-co-item-price {
  font-size: 13px; font-weight: 900; color: #0d0d0d; flex-shrink: 0;
}
[data-theme="dark"] .qb-co-item-price { color: #f0f0f0; }

/* Total strip */
.qb-co-total {
  display: flex; justify-content: space-between; align-items: center;
  padding: 11px 14px;
  background: rgba(244,180,0,0.1);
  border: 1px solid rgba(244,180,0,0.25);
  border-radius: 13px;
  margin-bottom: 18px;
}
.qb-co-total-lbl { font-size: 12px; font-weight: 700; color: #888; text-transform: uppercase; letter-spacing: 0.4px; }
[data-theme="dark"] .qb-co-total-lbl { color: #666; }
.qb-co-total-val { font-size: 22px; font-weight: 900; color: #F4B400; letter-spacing: -0.5px; }

/* Buttons */
.qb-co-btn-go {
  width: 100%; height: 54px;
  background: linear-gradient(135deg, #F4B400 0%, #E8A500 100%);
  color: #000; border: none; border-radius: 16px;
  font-size: 15px; font-weight: 900; cursor: pointer;
  letter-spacing: 0.3px; margin-bottom: 10px;
  box-shadow: 0 6px 22px rgba(244,180,0,0.38);
  transition: transform 0.18s ease, box-shadow 0.18s ease;
  display: flex; align-items: center; justify-content: center; gap: 6px;
}
.qb-co-btn-go:hover { transform: translateY(-1px); box-shadow: 0 8px 30px rgba(244,180,0,0.5); }
.qb-co-btn-go:active { transform: scale(0.97); }

.qb-co-btn-back {
  width: 100%; height: 46px;
  background: transparent;
  border: 1.5px solid rgba(0,0,0,0.12);
  color: #666; border-radius: 14px;
  font-size: 14px; font-weight: 700; cursor: pointer;
  transition: all 0.18s ease;
  display: flex; align-items: center; justify-content: center; gap: 5px;
}
[data-theme="dark"] .qb-co-btn-back { border-color: #2e2e2e; color: #777; }
.qb-co-btn-back:hover { background: rgba(0,0,0,0.04); color: #333; }
[data-theme="dark"] .qb-co-btn-back:hover { background: rgba(255,255,255,0.04); color: #aaa; }

/* ═══════════════════════════════════════════════════════
   DARK THEME — HARD OVERRIDES (fight Shopify global CSS)
   ═══════════════════════════════════════════════════════ */
[data-theme="dark"] .qb-cart-root,
[data-theme="dark"] .qb-cart-container,
[data-theme="dark"] body { background: #090909 !important; }

[data-theme="dark"] .qb-cart-section {
  background: #111111 !important;
  border-color: rgba(255,255,255,0.07) !important;
}

[data-theme="dark"] .qb-item-thumb {
  background: #1e1e1e !important;
  border-color: rgba(255,255,255,0.07) !important;
}
[data-theme="dark"] .qb-item-thumb img {
  background: #1e1e1e !important;
}

[data-theme="dark"] .qb-item-name  { color: #f0f0f0 !important; }
[data-theme="dark"] .qb-item-v     { color: #666 !important; }
[data-theme="dark"] .qb-sec-tag    { color: #555 !important; }
[data-theme="dark"] .qb-page-title { color: #f0f0f0 !important; }

[data-theme="dark"] .qb-item-remove {
  background: #202020 !important;
  border-color: rgba(255,255,255,0.09) !important;
  color: #555 !important;
}
[data-theme="dark"] .qb-item-remove:hover {
  background: rgba(255,68,68,0.14) !important;
  border-color: rgba(255,68,68,0.3) !important;
  color: #ff4444 !important;
}

[data-theme="dark"] .qb-qty-pill {
  background: #1e1e1e !important;
  border-color: rgba(255,255,255,0.12) !important;
}
[data-theme="dark"] .qb-qty-act { color: #f0f0f0 !important; }
[data-theme="dark"] .qb-qty-act:active { background: #2a2a2a !important; }
[data-theme="dark"] .qb-qty-box {
  border-left-color: rgba(255,255,255,0.08) !important;
  border-right-color: rgba(255,255,255,0.08) !important;
}
[data-theme="dark"] .qb-qty-num { color: #f0f0f0 !important; }

[data-theme="dark"] .qb-add-more-items {
  background: #181818 !important;
  border-color: rgba(255,255,255,0.12) !important;
  color: #F4B400 !important;
}
[data-theme="dark"] .qb-add-more-items:hover {
  background: rgba(244,180,0,0.08) !important;
}

[data-theme="dark"] .qb-bill-row   { color: #888 !important; }
[data-theme="dark"] .qb-total-lbl  { color: #f0f0f0 !important; }
[data-theme="dark"] .qb-muted-txt  { color: #555 !important; }
[data-theme="dark"] .qb-bill-dash  { border-top-color: rgba(255,255,255,0.08) !important; }
[data-theme="dark"] .qb-item-card  { border-bottom-color: rgba(255,255,255,0.06) !important; }

[data-theme="dark"] .qb-sticky-checkout {
  background: rgba(9,9,9,0.97) !important;
  border-top-color: rgba(255,255,255,0.1) !important;
}
[data-theme="dark"] .qb-sticky-tag   { color: #555 !important; }

/* Co-sheet (confirm bottom sheet) full dark */
[data-theme="dark"] .qb-co-sheet    { background: #161616 !important; }
[data-theme="dark"] .qb-co-title    { color: #f0f0f0 !important; }
[data-theme="dark"] .qb-co-subtitle { color: #777 !important; }
[data-theme="dark"] .qb-co-items    { background: #1e1e1e !important; }
[data-theme="dark"] .qb-co-item     { border-bottom-color: rgba(255,255,255,0.06) !important; }
[data-theme="dark"] .qb-co-item-name  { color: #ddd !important; }
[data-theme="dark"] .qb-co-item-price { color: #f0f0f0 !important; }
[data-theme="dark"] .qb-co-item-fallback { background: #2a2a2a !important; }
[data-theme="dark"] .qb-co-total-lbl { color: #666 !important; }
[data-theme="dark"] .qb-co-total-val { color: #F4B400 !important; }

/* ── GOLD PRICE OVERRIDES (beat base.css span !important) ── */
/* base.css forces all spans to #F9FAFB in dark mode — override here */
[data-theme="dark"] .qb-item-price   { color: #F4B400 !important; }
[data-theme="dark"] .qb-total-val    { color: #F4B400 !important; }
[data-theme="dark"] .qb-sticky-price { color: #F4B400 !important; }
[data-theme="dark"] .qb-badge-count  { color: #F4B400 !important; }

/* Muted text spans — keep them properly muted, not bright white */
[data-theme="dark"] .qb-bill-row     { color: #888888 !important; }
[data-theme="dark"] .qb-bill-row span{ color: #888888 !important; }
[data-theme="dark"] .qb-muted-txt    { color: #555555 !important; font-style: italic; }
[data-theme="dark"] .qb-item-v       { color: #666666 !important; }
[data-theme="dark"] .qb-sec-tag      { color: #555555 !important; }
[data-theme="dark"] .qb-sticky-tag   { color: #555555 !important; }
[data-theme="dark"] .qb-view-cart-link { color: #777777 !important; }

/* Missing: checkout sheet item image fallback bg */
[data-theme="dark"] .qb-co-item-img  { background: #2a2a2a !important; }
</style>

<cart-items-component class="qb-cart-root" data-section-id="{{ section.id }}">
  <div class="qb-cart-container">
    {%- if cart.empty? -%}
      <div class="qb-empty-hive animate-fade-in">
        <div class="qb-empty-icon">🐝</div>
        <h1>Your Hive is Empty</h1>
        <p>Your basket is waiting for some sweet treats!</p>
        <a href="{{ routes.all_products_collection_url }}" class="qb-btn-explore">Start Shopping</a>
      </div>
    {%- else -%}

      <!-- HEADER -->
      <div class="qb-header-row">
        <h1 class="qb-page-title">Review Order</h1>
        <span class="qb-badge-count" ref="cartItemCount">{{ cart.item_count }} Items</span>
      </div>

      <div class="qb-cart-body">

        <!-- SELECTED PRODUCTS -->
        <div class="qb-cart-section">
          <div class="qb-sec-tag">SELECTED PRODUCTS</div>
          <div class="qb-items-list">
            {%- for item in cart.items -%}
              <div class="qb-item-card" ref="cartItemRows" data-key="{{ item.key }}">
                <div class="qb-item-thumb">
                  {% if item.image %}<img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title }}">{% else %}<div class="qb-thumb-fall">🐝</div>{% endif %}
                </div>
                <div class="qb-item-main">
                  <div class="qb-item-top">
                    <a href="{{ item.url }}" class="qb-item-name">{{ item.product.title | truncate: 50 }}</a>
                    <form action="{{ routes.cart_change_url }}" method="post">
                      <input type="hidden" name="id" value="{{ item.key }}">
                      <input type="hidden" name="quantity" value="0">
                      <button type="submit" class="qb-item-remove">
                        <svg width="10" height="10" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 1L1 13M1 1L13 13"/></svg>
                      </button>
                    </form>
                  </div>
                  {%- unless item.product.has_only_default_variant -%}
                    <div class="qb-item-v">{{ item.variant.title }}</div>
                  {%- endunless -%}
                  <div class="qb-item-bottom">
                    <span class="qb-item-price">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    <div class="qb-qty-pill" ref="quantitySelectors">
                      <form action="{{ routes.cart_change_url }}" method="post" class="qb-qty-form">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-qty-act" data-action="minus" data-qbtn>−</button>
                        <div class="qb-qty-box"><input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-qty-num"></div>
                        <button type="button" class="qb-qty-act" data-action="plus" data-qbtn>+</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          <a href="{{ routes.all_products_collection_url }}" class="qb-add-more-items">+ Add more items</a>
        </div>

        <!-- BILLING -->
        <div class="qb-cart-section">
          <div class="qb-sec-tag">BILLING SUMMARY</div>
          <div class="qb-bill-stack">
            <div class="qb-bill-row"><span>Item Total</span><span>Rs {{ cart.total_price | divided_by: 100 }}</span></div>
            <div class="qb-bill-row"><span>Delivery Fee</span><span class="qb-muted-txt">At checkout</span></div>
            <div class="qb-bill-dash"></div>
            <div class="qb-bill-total">
              <span class="qb-total-lbl">Grand Total</span>
              <span class="qb-total-val" ref="cartTotal">Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
          </div>
        </div>

      </div><!-- end .qb-cart-body -->

      <!-- STICKY CHECKOUT FOOTER — full-width centered gold button -->
      <div class="qb-sticky-checkout">
        <div class="qb-sticky-amount-row">
          <span class="qb-sticky-tag">TOTAL PAYABLE</span>
          <span class="qb-sticky-price">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-btn-checkout-main" id="qbMainCheckoutBtn">
          Proceed to Checkout ➔
        </button>
      </div>

    {%- endif -%}
  </div>
</cart-items-component>

<!-- ── CHECKOUT CONFIRM BOTTOM SHEET ── -->
<div class="qb-co-backdrop" id="qbCoBackdrop" role="dialog" aria-modal="true" aria-label="Confirm checkout">
  <div class="qb-co-sheet" id="qbCoSheet">
    <div class="qb-co-handle"></div>

    <div class="qb-co-top">
      <span class="qb-co-icon">🛒</span>
      <p class="qb-co-title">Review your order before checkout</p>
      <p class="qb-co-sub">You won't be able to edit items after proceeding</p>
    </div>

    <!-- Mini item list (populated by JS) -->
    <div class="qb-co-items" id="qbCoItems"></div>

    <!-- Total -->
    <div class="qb-co-total">
      <span class="qb-co-total-lbl">Total Payable</span>
      <span class="qb-co-total-val" id="qbCoTotalVal">Rs 0</span>
    </div>

    <button class="qb-co-btn-go" id="qbCoBtnGo">
      <span>Continue to Checkout</span><span>➔</span>
    </button>
    <button class="qb-co-btn-back" id="qbCoBtnBack">
      <span>←</span><span>Go Back &amp; Edit</span>
    </button>
  </div>
</div>

<script>
(function() {
  function init() {
    document.addEventListener('click', (e) => {
      const qtyBtn = e.target.closest('[data-qbtn]');
      if (qtyBtn) {
        const form = qtyBtn.closest('form');
        const inp  = form.querySelector('.qb-qty-num');
        let val = parseInt(inp.value);
        if (qtyBtn.dataset.action === 'minus') {
          if (val > 1) val--; else if (confirm('Remove this item?')) val = 0; else return;
        } else val++;
        inp.value = val; form.submit(); return;
      }
      if (e.target.closest('#qbMainCheckoutBtn')) {
        showCheckoutConfirm();
      }
    });
  }

  /* ═══════════════════════════════════════════════════════
     DELIVERY CHARGE AUTO-INJECT
     Flat Delivery  : 6:00 AM – 8:00 PM
     Late Night     : 8:00 PM – 6:00 AM
     Skipped for    : carts with only Rs 0 / donation items
     ═══════════════════════════════════════════════════════ */
  async function injectDeliveryCharge() {
    /* 1. Determine Nepal time (UTC +5:45) */
    const nowUtc   = Date.now();
    const npOffset = (5 * 60 + 45) * 60 * 1000;
    const npDate   = new Date(nowUtc + npOffset + (new Date().getTimezoneOffset() * 60000));
    const totalMin = npDate.getHours() * 60 + npDate.getMinutes();
    // Late night = before 6am (< 360) OR 8pm and after (>= 1200)
    const isLateNight = totalMin < 360 || totalMin >= 1200;

    /* 2. Fetch live cart */
    const cartResp = await fetch('/cart.js');
    const cart     = await cartResp.json();

    const FLAT_HANDLE  = 'flat-delivery-charge';
    const LATE_HANDLE  = 'late-night-delivery-charge';

    /* 3. Skip if cart has no paid non-delivery items */
    const paidItems = cart.items.filter(i =>
      i.price > 0 &&
      i.handle !== FLAT_HANDLE &&
      i.handle !== LATE_HANDLE
    );
    if (paidItems.length === 0) return;

    /* 4. Fetch both product variant IDs dynamically */
    const [flatProd, lateProd] = await Promise.all([
      fetch('/products/' + FLAT_HANDLE + '.js').then(r => r.json()),
      fetch('/products/' + LATE_HANDLE + '.js').then(r => r.json())
    ]);
    const flatVariantId = flatProd.variants[0].id;
    const lateVariantId = lateProd.variants[0].id;

    const correctHandle    = isLateNight ? LATE_HANDLE  : FLAT_HANDLE;
    const correctVariantId = isLateNight ? lateVariantId : flatVariantId;
    const wrongHandle      = isLateNight ? FLAT_HANDLE  : LATE_HANDLE;

    /* 5. Remove wrong delivery charge if present */
    const wrongItem = cart.items.find(i => i.handle === wrongHandle);
    if (wrongItem) {
      await fetch('/cart/change.js', {
        method : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body   : JSON.stringify({ id: wrongItem.key, quantity: 0 })
      });
    }

    /* 6. Add correct delivery charge if missing */
    const hasCorrect = cart.items.some(i => i.handle === correctHandle);
    if (!hasCorrect) {
      await fetch('/cart/add.js', {
        method : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body   : JSON.stringify({ id: correctVariantId, quantity: 1 })
      });
    }

    console.log('[QB Delivery] ' + (isLateNight ? 'Late Night' : 'Flat') + ' charge applied ✓');
  }

  /* ═══════════════════════════════════════════════════════
     CHECKOUT FLOW: Inject charge → Extract location → Update cart note → Redirect
     ═══════════════════════════════════════════════════════ */
  window.proceedToCheckout = async function() {
    const btn = document.getElementById('qbMainCheckoutBtn');
    if (btn.disabled) return;

    btn.disabled = true;
    btn.textContent = 'Processing...';

    /* STEP 1: Extract location data from localStorage */
    let locationData = null;
    try {
      const stored = localStorage.getItem('qb_selected_location');
      locationData = stored ? JSON.parse(stored) : null;
    } catch (e) {
      console.warn('Error parsing location:', e);
    }

    // Robust display address detection
    const displayAddr = locationData?.address || locationData?.street || locationData?.landmark_link || '';

    /* STEP 2: If no location, block checkout */
    if (!locationData || !displayAddr) {
      btn.disabled = false;
      btn.textContent = 'Proceed to Checkout ➔';
      alert('📍 Please select your delivery location first');
      return;
    }

    /* STEP 3: Auto-inject correct delivery charge based on Nepal time */
    btn.textContent = 'Adding delivery fee...';
    try {
      await injectDeliveryCharge();
    } catch (err) {
      console.warn('[QB Delivery] charge injection failed:', err);
    }

    /* STEP 4: Format comprehensive order note */
    /* Nepal time */
    const npMs      = Date.now() + (5*3600000 + 45*60000) + (new Date().getTimezoneOffset()*60000);
    const npDate    = new Date(npMs);
    const npTimeStr = npDate.toLocaleString('en-US', { dateStyle:'medium', timeStyle:'short' });
    const totalMin  = npDate.getHours()*60 + npDate.getMinutes();
    const delivType = (totalMin < 360 || totalMin >= 1200) ? 'Late Night (8PM–6AM)' : 'Daytime (6AM–8PM)';

    let orderNote = `═══════════════════════════════
  QUICKBEE ORDER DETAILS
═══════════════════════════════

📍 DELIVERY LOCATION
  Address : ${displayAddr}
  Mode    : ${locationData.mode || 'N/A'}`;

    if (locationData.mode === 'someone_else') {
      orderNote += `
  Recipient : ${locationData.recipient_name || 'N/A'}
  Landmark  : ${locationData.landmark_link || 'N/A'}`;
    } else if (locationData.latitude && locationData.longitude) {
      orderNote += `
  Lat  : ${locationData.latitude}
  Lng  : ${locationData.longitude}
  Map  : https://www.google.com/maps?q=${locationData.latitude},${locationData.longitude}`;
    }

    orderNote += `

🕐 ORDER TIME
  Nepal Time    : ${npTimeStr}
  Delivery Type : ${delivType}

💳 PAYMENT
  Method : (to be selected on payment page)
  Status : Pending

═══════════════════════════════
  quickbee.store
═══════════════════════════════`;

    /* timestamp already in npTimeStr above */

    /* STEP 5: Update cart with the order note */
    fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ note: orderNote })
    })
    .then(res => {
      if (!res.ok) throw new Error(`Cart update failed: ${res.status}`);
      console.log('✓ Order note saved to cart');
    })
    .then(() => {
      /* STEP 5: Redirect to payment page */
      btn.textContent = 'Redirecting...';
      window.location.href = '/pages/payment';
    })
    .catch(err => {
      console.error('❌ Checkout error:', err);
      btn.disabled = false;
      btn.textContent = 'Proceed to Checkout ➔';
      alert('Failed to process checkout. Please try again.');
    });
  };

  /* ═══════════════════════════════════
     CHECKOUT CONFIRM BOTTOM SHEET
  ═══════════════════════════════════ */
  function showCheckoutConfirm() {
    var backdrop = document.getElementById('qbCoBackdrop');
    var itemsEl  = document.getElementById('qbCoItems');
    var totalEl  = document.getElementById('qbCoTotalVal');
    if (!backdrop) { proceedToCheckout(); return; }

    // Populate mini item list from live DOM
    if (itemsEl) {
      itemsEl.innerHTML = '';
      document.querySelectorAll('.qb-item-card').forEach(function(card) {
        var img   = card.querySelector('.qb-item-thumb img');
        var name  = card.querySelector('.qb-item-name');
        var price = card.querySelector('.qb-item-price');
        var row   = document.createElement('div');
        row.className = 'qb-co-item';
        row.innerHTML =
          (img
            ? '<img class="qb-co-item-img" src="' + img.src + '" alt="" loading="lazy">'
            : '<div class="qb-co-item-fallback">🐝</div>') +
          '<span class="qb-co-item-name">' + (name ? name.textContent.trim() : '') + '</span>' +
          '<span class="qb-co-item-price">' + (price ? price.textContent.trim() : '') + '</span>';
        itemsEl.appendChild(row);
      });
    }

    // Sync total from sticky bar
    if (totalEl) {
      var stickyPrice = document.querySelector('.qb-sticky-price');
      if (stickyPrice) totalEl.textContent = stickyPrice.textContent.trim();
    }

    backdrop.classList.add('show');
    document.body.style.overflow = 'hidden';
  }

  function hideCheckoutConfirm() {
    var backdrop = document.getElementById('qbCoBackdrop');
    if (backdrop) backdrop.classList.remove('show');
    document.body.style.overflow = '';
  }

  // Wire up modal buttons once DOM is ready
  function initCheckoutModal() {
    var btnGo   = document.getElementById('qbCoBtnGo');
    var btnBack = document.getElementById('qbCoBtnBack');
    var backdrop = document.getElementById('qbCoBackdrop');

    if (btnGo) btnGo.addEventListener('click', function() {
      hideCheckoutConfirm();
      proceedToCheckout();
    });
    if (btnBack) btnBack.addEventListener('click', hideCheckoutConfirm);

    // Tap backdrop to dismiss
    if (backdrop) backdrop.addEventListener('click', function(e) {
      if (e.target === backdrop) hideCheckoutConfirm();
    });

    // Swipe down to dismiss (touch)
    var sheet = document.getElementById('qbCoSheet');
    if (sheet) {
      var startY = 0;
      sheet.addEventListener('touchstart', function(e) { startY = e.touches[0].clientY; }, { passive: true });
      sheet.addEventListener('touchend', function(e) {
        if (e.changedTouches[0].clientY - startY > 60) hideCheckoutConfirm();
      }, { passive: true });
    }
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function() { init(); initCheckoutModal(); });
  else { init(); initCheckoutModal(); }
})();
</script>

