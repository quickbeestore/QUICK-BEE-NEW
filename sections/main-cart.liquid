<!-- sections/main-cart.liquid -->
<cart-items-component class="qb-cart-page-component" data-section-id="{{ section.id }}">
  <div class="qb-cart-main-container">
    {%- if cart.empty? -%}
      <div class="qb-empty-hive-state animate-fade-in">
        <div class="qb-empty-art">🐝</div>
        <h1 class="qb-empty-title">Your Hive is Empty</h1>
        <p class="qb-empty-desc">Time to fill your basket! Browse our collections to get started.</p>
        <a href="{{ routes.all_products_collection_url }}" class="qb-btn-shop-gold">Explore Collections</a>
      </div>
    {%- else -%}
      
      <!-- CART HEADER (Respects Theme Header) -->
      <div class="qb-cart-header-pro">
        <h1 class="qb-cart-title-pro">Review Order</h1>
        <span class="qb-badge-pro" ref="cartItemCount">{{ cart.item_count }} Items</span>
      </div>

      <div class="qb-cart-body-stack">
        <!-- SECTION: PRODUCTS -->
        <div class="qb-card-pro">
          <div class="qb-card-label-row"><span class="qb-card-tag-pro">SELECTED PRODUCTS</span></div>
          <div class="qb-items-list-pro">
            {%- for item in cart.items -%}
              <div class="qb-item-row-pro" ref="cartItemRows" data-key="{{ item.key }}">
                <div class="qb-item-media-pro">
                  {% if item.image %}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy">{% else %}<div class="qb-placeholder-pro">🐝</div>{% endif %}
                </div>
                <div class="qb-item-details-pro">
                  <div class="qb-item-top-pro">
                    <a href="{{ item.url }}" class="qb-item-name-pro">{{ item.product.title | truncate: 50 }}</a>
                    <form action="{{ routes.cart_change_url }}" method="post">
                      <input type="hidden" name="id" value="{{ item.key }}"><input type="hidden" name="quantity" value="0">
                      <button type="submit" class="qb-remove-pro">✕</button>
                    </form>
                  </div>
                  {%- unless item.product.has_only_default_variant -%}<div class="qb-item-meta-pro">{{ item.variant.title }}</div>{%- endunless -%}
                  <div class="qb-item-footer-pro">
                    <span class="qb-price-pro">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    <div class="qb-qty-pill-pro" ref="quantitySelectors">
                      <form action="{{ routes.cart_change_url }}" method="post">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-qty-act-pro" data-action="minus">−</button>
                        <input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-qty-val-pro">
                        <button type="button" class="qb-qty-act-pro" data-action="plus">+</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          <a href="{{ routes.all_products_collection_url }}" class="qb-add-more-pro">+ Add more items</a>
        </div>

        <!-- SECTION: DELIVERY -->
        <div class="qb-card-pro">
          <div class="qb-card-label-row qb-flex-between">
            <span class="qb-card-tag-pro">DELIVERY DESTINATION</span>
            <button type="button" class="qb-help-btn-circle" id="openHelpBtn">?</button>
          </div>
          <div class="qb-input-wrap-pro">
            <span class="qb-input-icon-pro">📍</span>
            <input type="text" id="LandmarkLink" placeholder="Paste Google Maps link here..." class="qb-field-pro" required>
          </div>
          <div class="qb-chips-grid-pro">
            <button type="button" class="qb-pro-nick-chip" data-nickname="Home">🏠 Home</button>
            <button type="button" class="qb-pro-nick-chip" data-nickname="Office">🏢 Office</button>
            <button type="button" class="qb-pro-nick-chip" data-nickname="Other">✨ Other</button>
            <button type="button" class="qb-pro-nick-chip" data-nickname="Current">📦 Current</button>
          </div>
        </div>

        <!-- SECTION: BILLING -->
        <div class="qb-card-pro">
          <div id="qbCheckoutError" class="qb-error-banner animate-fade-in active">
            <span class="qb-error-icon">⚠️</span>
            <p class="qb-error-msg">enter the google maps location link TO PROCEED CHECKOUT</p>
          </div>
          <div class="qb-card-label-row"><span class="qb-card-tag-pro">BILLING SUMMARY</span></div>
          <div class="qb-bill-list-pro">
            <div class="qb-bill-line-pro"><span>Item Total</span><span>Rs {{ cart.total_price | divided_by: 100 }}</span></div>
            <div class="qb-bill-line-pro"><span>Delivery Fee</span><span class="qb-bill-calc-pro">Calculated at checkout</span></div>
            <div class="qb-bill-total-pro">
              <span>Grand Total</span>
              <span class="qb-total-val-pro" ref="cartTotal">Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- STICKY FOOTER -->
      <div class="qb-checkout-sticky-bar">
        <div class="qb-checkout-price-info">
          <span class="qb-checkout-label-pro">TOTAL PAYABLE</span>
          <span class="qb-checkout-val-pro">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-main-checkout-pro-btn qb-button-locked" id="qbMainCheckoutBtn" disabled>Checkout ➔</button>
      </div>
    {%- endif -%}
  </div>
</cart-items-component>

<!-- HELP MODAL (Teleported to Body) -->
<div id="landmarkModalOverlay" class="qb-modal-fixed-overlay">
  <div class="qb-modal-card-pro animate-slide-up">
    <div class="qb-modal-notch"></div>
    <button class="qb-modal-close-pro" id="closeHelpBtn">✕</button>
    <div class="qb-modal-body-pro">
      <h3 class="qb-modal-title-pro">How to share location?</h3>
      <p class="qb-modal-desc-pro">Share your precise location via Google Maps so we can reach you quickly!</p>
      <div class="qb-modal-image-wrap">
        <img src="{{ 'popupgoogle.png' | asset_url }}" alt="Tutorial" id="modalTutImg">
      </div>
      <div class="qb-modal-actions-pro">
        <a href="https://www.google.com/maps" target="_blank" class="qb-btn-maps-pro">📍 Open Google Maps App</a>
        <button type="button" class="qb-btn-done-pro" id="doneHelpBtn">Got it!</button>
      </div>
    </div>
  </div>
</div>

<style>
  :root { --qb-gold: #F4B400; --qb-gold-soft: #FFF9E6; --qb-black: #111111; --qb-gray: #757575; --qb-red: #C41E3A; --qb-bg: #F8F9FA; --qb-border: #EEEEEE; --qb-radius-lg: 24px; --qb-shadow: 0 4px 20px rgba(0,0,0,0.06); }
  
  body.qb-modal-open { overflow: hidden !important; padding-right: var(--qb-sw, 0px); }

  .qb-cart-page-component { display: block; background: var(--qb-bg); min-height: 100vh; padding-bottom: 160px; font-family: -apple-system, sans-serif; }
  .qb-cart-main-container { max-width: 500px; margin: 0 auto; background: #fff; min-height: 100vh; position: relative; }

  /* Help Button Circle */
  .qb-help-btn-circle { width: 30px; height: 30px; border-radius: 50%; background: var(--qb-gold); color: white; border: 2px solid white; font-weight: 900; font-size: 16px; cursor: pointer; box-shadow: 0 4px 10px rgba(244,180,0,0.3); }

  /* MODAL OVERLAY (Portal) */
  .qb-modal-fixed-overlay { position: fixed !important; inset: 0 !important; background: rgba(0,0,0,0.8) !important; backdrop-filter: blur(10px) !important; z-index: 2147483647 !important; display: none; align-items: flex-end; justify-content: center; }
  .qb-modal-fixed-overlay.active { display: flex; }
  .qb-modal-card-pro { background: #fff; width: 100%; max-width: 500px; border-radius: 32px 32px 0 0; padding: 24px 24px calc(24px + env(safe-area-inset-bottom)); position: relative; box-shadow: 0 -10px 40px rgba(0,0,0,0.5); }
  .qb-modal-notch { width: 40px; height: 4px; background: #eee; border-radius: 2px; margin: 0 auto 20px; }
  .qb-modal-close-pro { position: absolute; top: 20px; right: 20px; background: #f5f5f5; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: bold; color: #333; }
  .qb-modal-title-pro { font-size: 20px; font-weight: 900; text-align: center; margin-bottom: 8px; color: #111; }
  .qb-modal-desc-pro { font-size: 14px; color: #666; text-align: center; margin-bottom: 24px; line-height: 1.4; }
  .qb-modal-image-wrap { width: 100%; border-radius: 20px; overflow: hidden; border: 1px solid #eee; margin-bottom: 24px; background: #f9f9f9; }
  .qb-modal-image-wrap img { width: 100%; display: block; max-height: 50vh; object-fit: contain; }
  .qb-modal-actions-pro { display: flex; flex-direction: column; gap: 12px; }
  .qb-btn-maps-pro { display: flex; align-items: center; justify-content: center; background: #4285F4; color: #fff; text-decoration: none; padding: 16px; border-radius: 16px; font-weight: 800; }
  .qb-btn-done-pro { width: 100%; padding: 16px; background: #f5f5f5; border: none; border-radius: 16px; font-weight: 700; color: #333; cursor: pointer; }

  /* Error Banner */
  .qb-error-banner { display: none; background: #FFF1F2; border: 1px solid #FDA4AF; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; align-items: center; gap: 10px; }
  .qb-error-banner.active { display: flex; animation: qbShake 0.4s; }
  .qb-error-msg { font-size: 13px; font-weight: 700; color: #9F1239; margin: 0; text-transform: uppercase; }
  @keyframes qbShake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

  /* Sticky Bar & Lock */
  .qb-main-checkout-pro-btn.qb-button-locked { opacity: 0.6; filter: blur(0.4px); background: #999 !important; cursor: not-allowed; }
  .qb-checkout-sticky-bar { position: fixed; bottom: 65px; left: 0; right: 0; max-width: 500px; margin: 0 auto; background: #fff; padding: 16px 20px; border-top: 1px solid var(--qb-border); display: flex; align-items: center; gap: 16px; z-index: 1000; box-shadow: 0 -10px 40px rgba(0,0,0,0.05); }
  .qb-main-checkout-pro-btn { flex: 1; height: 58px; background: var(--qb-red); color: white; border: none; border-radius: 18px; font-size: 18px; font-weight: 900; cursor: pointer; }

  /* Card Pro & Items */
  .qb-card-pro { background: #fff; border: 1px solid var(--qb-border); border-radius: var(--qb-radius-lg); padding: 20px; box-shadow: var(--qb-shadow); margin-bottom: 16px; }
  .qb-card-tag-pro { font-size: 10px; font-weight: 900; color: #BBB; letter-spacing: 1.5px; text-transform: uppercase; }
  .qb-item-row-pro { display: flex; gap: 16px; padding-bottom: 20px; border-bottom: 1.5px solid #F9F9F9; margin-bottom: 20px; }
  .qb-item-media-pro { width: 90px; height: 90px; border-radius: 14px; overflow: hidden; border: 1px solid #F0F0F0; flex-shrink: 0; }
  .qb-item-media-pro img { width: 100%; height: 100%; object-fit: cover; }
  .qb-qty-pill-pro { background: #F5F5F5; border-radius: 14px; padding: 2px; display: flex; }
  .qb-qty-act-pro { width: 34px; height: 34px; border: none; background: none; font-size: 20px; font-weight: 800; cursor: pointer; }
  .qb-qty-val-pro { width: 32px; border: none; background: transparent; text-align: center; font-size: 15px; font-weight: 900; pointer-events: none; }

  /* Delivery Chips */
  .qb-input-wrap-pro { position: relative; display: flex; align-items: center; margin: 16px 0; }
  .qb-input-icon-pro { position: absolute; left: 16px; font-size: 22px; }
  .qb-field-pro { width: 100%; padding: 18px 18px 18px 52px; background: #F9F9F9; border: 1.5px solid var(--qb-border); border-radius: 16px; font-size: 15px; font-weight: 700; outline: none; }
  .qb-chips-grid-pro { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .qb-pro-nick-chip { padding: 14px; background: #fff; border: 1.5px solid var(--qb-border); border-radius: 16px; font-size: 14px; font-weight: 800; color: var(--qb-gray); cursor: pointer; }
  .qb-pro-nick-chip.active { border-color: var(--qb-gold); background: var(--qb-gold-soft); color: var(--qb-gold); }

  .qb-cart-header-pro { padding: 30px 20px 20px; display: flex; justify-content: space-between; align-items: center; }
  .qb-cart-title-pro { font-size: 24px; font-weight: 900; color: #111; margin: 0; }
  .qb-badge-pro { background: var(--qb-gold-soft); color: var(--qb-gold); font-size: 12px; font-weight: 800; padding: 4px 12px; border-radius: 20px; }
  .qb-bill-line-pro { display: flex; justify-content: space-between; font-size: 15px; font-weight: 700; color: var(--qb-gray); margin-bottom: 12px; }
  .qb-bill-total-pro { display: flex; justify-content: space-between; align-items: baseline; padding-top: 16px; border-top: 1.5px dashed var(--qb-border); }
  .qb-total-val-pro { font-size: 24px; font-weight: 900; color: #111; }

  .qb-flex-between { display: flex; justify-content: space-between; align-items: center; }
  .animate-fade-in { animation: qbFadeIn 0.6s ease-out; }
  @keyframes qbFadeIn { from { opacity: 0; } to { opacity: 1; } }
  .animate-slide-up { animation: qbSlideUp 0.4s ease forwards; }
  @keyframes qbSlideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
  .qb-empty-hive-state { padding: 80px 20px; text-align: center; }
  .qb-empty-art { font-size: 90px; margin-bottom: 24px; filter: drop-shadow(0 10px 10px rgba(0,0,0,0.1)); }
  .qb-btn-shop-gold { background: var(--qb-gold); color: white; padding: 18px 45px; border-radius: 16px; text-decoration: none; font-weight: 900; display: inline-block; margin-top: 30px; box-shadow: 0 10px 30px rgba(244,180,0,0.3); }
</style>

<script>
(function() {
  function initFinalCart() {
    const input = document.getElementById('LandmarkLink');
    const checkoutBtn = document.getElementById('qbMainCheckoutBtn');
    const errorBox = document.getElementById('qbCheckoutError');
    const modal = document.getElementById('landmarkModalOverlay');
    const body = document.body;

    if (modal && modal.parentNode !== body) body.appendChild(modal);

    const validate = () => {
      const val = (input?.value || '').trim();
      const isValid = val.length > 8 && (val.includes('google.com/maps') || val.includes('maps.app.goo.gl') || val.includes('http'));
      if (isValid) {
        checkoutBtn.disabled = false; checkoutBtn.classList.remove('qb-button-locked');
        errorBox.classList.remove('active');
      } else {
        checkoutBtn.disabled = true; checkoutBtn.classList.add('qb-button-locked');
        errorBox.classList.add('active');
      }
    };

    if (input) { input.addEventListener('input', validate); validate(); }

    document.addEventListener('click', (e) => {
      // ? Trigger
      if (e.target.closest('#openHelpBtn')) {
        e.preventDefault(); e.stopPropagation();
        modal.classList.add('active');
        body.classList.add('qb-modal-open');
        return;
      }
      // Modal Close
      if (e.target.closest('#closeHelpBtn') || e.target.closest('#doneHelpBtn') || e.target === modal) {
        modal.classList.remove('active');
        body.classList.remove('qb-modal-open');
        return;
      }
      // Quantity
      const qtyBtn = e.target.closest('.qb-qty-act-pro');
      if (qtyBtn) {
        const form = qtyBtn.closest('form');
        const inp = form.querySelector('.qb-qty-val-pro');
        let val = parseInt(inp.value);
        if (qtyBtn.dataset.action === 'minus') {
          if (val > 1) val--; else if (confirm('Remove item?')) val = 0; else return;
        } else val++;
        inp.value = val; form.submit();
        return;
      }
      // Nickname
      const chip = e.target.closest('.qb-pro-nick-chip');
      if (chip) {
        localStorage.setItem('qb_landmark_' + (localStorage.getItem('qb_active_nickname') || 'Home'), input.value);
        document.querySelectorAll('.qb-pro-nick-chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        const next = chip.dataset.nickname;
        localStorage.setItem('qb_active_nickname', next);
        input.value = localStorage.getItem('qb_landmark_' + next) || '';
        validate();
        return;
      }
      // Checkout
      if (e.target.closest('#qbMainCheckoutBtn')) {
        const btn = e.target.closest('#qbMainCheckoutBtn');
        if (btn.disabled) return;
        btn.disabled = true; btn.innerHTML = 'Wait...';
        const nick = localStorage.getItem('qb_active_nickname') || 'Home';
        const fullNote = `Address Type: ${nick}\nGoogle Maps: ${input.value}\nLocation Data: ${localStorage.getItem('qb_selected_location') || 'N/A'}`;
        fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ note: fullNote }) })
        .finally(() => { window.location.href = '/checkout'; });
      }
    });

    const activeNick = localStorage.getItem('qb_active_nickname') || 'Home';
    document.querySelectorAll('.qb-pro-nick-chip').forEach(chip => {
      if (chip.dataset.nickname === activeNick) chip.classList.add('active');
      const saved = localStorage.getItem('qb_landmark_' + activeNick);
      if (chip.dataset.nickname === activeNick && saved) { input.value = saved; validate(); }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initFinalCart);
  else initFinalCart();
})();
</script>

