<!-- sections/main-cart.liquid -->
<cart-items-component class="qb-cart-main-component" data-section-id="{{ section.id }}">
  <div class="qb-cart-wrapper-final">
    {%- if cart.empty? -%}
      <div class="qb-cart-empty-hive animate-fade-in">
        <div class="qb-cart-empty-bee">🐝</div>
        <h1 class="qb-cart-empty-h1">Your Hive is Empty</h1>
        <p class="qb-cart-empty-p">Time to fill your basket! Browse our collections to get started.</p>
        <a href="{{ routes.all_products_collection_url }}" class="qb-cart-empty-btn">Explore Shop</a>
      </div>
    {%- else -%}
      
      <!-- HEADER -->
      <div class="qb-cart-title-block">
        <h1 class="qb-cart-main-title">Review Order</h1>
        <span class="qb-cart-items-badge" ref="cartItemCount">{{ cart.item_count }} Items</span>
      </div>

      <div class="qb-cart-sections-list">
        
        <!-- SELECTED PRODUCTS -->
        <div class="qb-cart-section-card">
          <div class="qb-cart-section-label">SELECTED PRODUCTS</div>
          
          <div class="qb-cart-items-stack">
            {%- for item in cart.items -%}
              <div class="qb-cart-item-box" ref="cartItemRows" data-key="{{ item.key }}">
                <div class="qb-cart-item-visual">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title | escape }}" loading="lazy">
                  {% else %}
                    <div class="qb-cart-visual-fall">🐝</div>
                  {% endif %}
                </div>
                
                <div class="qb-cart-item-content">
                  <div class="qb-cart-item-top">
                    <a href="{{ item.url }}" class="qb-cart-item-name">{{ item.product.title | truncate: 50 }}</a>
                    <form action="{{ routes.cart_change_url }}" method="post">
                      <input type="hidden" name="id" value="{{ item.key }}"><input type="hidden" name="quantity" value="0">
                      <button type="submit" class="qb-cart-item-remove" aria-label="Remove">
                        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M13 1L1 13M1 1L13 13"/></svg>
                      </button>
                    </form>
                  </div>
                  
                  {%- unless item.product.has_only_default_variant -%}
                    <div class="qb-cart-item-meta">{{ item.variant.title }}</div>
                  {%- endunless -%}

                  <div class="qb-cart-item-footer">
                    <div class="qb-cart-price-display">
                      <span class="qb-cart-price-val">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    </div>
                    
                    <div class="qb-cart-qty-pill" ref="quantitySelectors">
                      <form action="{{ routes.cart_change_url }}" method="post" class="qb-cart-qty-flex">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-cart-qty-act" data-action="minus" data-qty-btn aria-label="Decrease">
                          <svg width="12" height="2" viewBox="0 0 12 2" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M1 1H11"/></svg>
                        </button>
                        <div class="qb-cart-qty-num">
                          <input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-cart-qty-input">
                        </div>
                        <button type="button" class="qb-cart-qty-act" data-action="plus" data-qty-btn aria-label="Increase">
                          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 1V11M1 6H11"/></svg>
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          
          <a href="{{ routes.all_products_collection_url }}" class="qb-cart-add-more-items">+ Add more items</a>
        </div>

        <!-- DELIVERY -->
        <div class="qb-cart-section-card">
          <div class="qb-cart-card-header-flex">
            <span class="qb-cart-section-label">DELIVERY DESTINATION</span>
            <button type="button" class="qb-cart-help-trigger" id="openHelpBtn" aria-label="Location Guide">?</button>
          </div>
          
          <div class="qb-cart-input-group">
            <div class="qb-cart-input-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <input type="text" id="LandmarkLink" placeholder="Paste Google Maps link here..." class="qb-cart-main-input" required>
          </div>
          
          <div class="qb-cart-nicknames-grid">
            <button type="button" class="qb-cart-nick-chip" data-nickname="Home">🏠 Home</button>
            <button type="button" class="qb-cart-nick-chip" data-nickname="Office">🏢 Office</button>
            <button type="button" class="qb-cart-nick-chip" data-nickname="Other">✨ Other</button>
            <button type="button" class="qb-cart-nick-chip" data-nickname="Current">📦 Current</button>
          </div>
        </div>

        <!-- BILLING -->
        <div class="qb-cart-section-card">
          <div id="qbCheckoutError" class="qb-cart-error-banner animate-fade-in active">
            <span class="qb-cart-err-icon">⚠️</span>
            <p class="qb-cart-err-msg">enter the google maps location link TO PROCEED CHECKOUT</p>
          </div>

          <div class="qb-cart-section-label">BILLING SUMMARY</div>
          <div class="qb-cart-bill-stack">
            <div class="qb-cart-bill-row">
              <span class="qb-cart-bill-lbl">Item Total</span>
              <span class="qb-cart-bill-val">Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
            <div class="qb-cart-bill-row">
              <span class="qb-cart-bill-lbl">Delivery Fee</span>
              <span class="qb-cart-bill-muted">Calculated at checkout</span>
            </div>
            <div class="qb-cart-bill-divider"></div>
            <div class="qb-cart-bill-total">
              <span class="qb-cart-total-lbl">Grand Total</span>
              <span class="qb-cart-total-val" ref="cartTotal">Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- STICKY FOOTER -->
      <div class="qb-cart-sticky-footer">
        <div class="qb-cart-sticky-summary">
          <span class="qb-cart-sticky-label">PAYABLE AMOUNT</span>
          <span class="qb-cart-sticky-price">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-cart-checkout-btn qb-cart-locked" id="qbMainCheckoutBtn" disabled>
          Checkout ➔
        </button>
      </div>
    {%- endif -%}
  </div>
</cart-items-component>

<!-- GLOBAL MODAL (Portal Pop-out) -->
<div id="landmarkModalOverlay" class="qb-cart-modal-overlay">
  <div class="qb-cart-modal-card animate-slide-up">
    <div class="qb-cart-modal-notch"></div>
    <button class="qb-cart-modal-close" id="closeHelpBtn" type="button">✕</button>
    <div class="qb-cart-modal-body">
      <h3 class="qb-cart-modal-h3">How to share location?</h3>
      <p class="qb-cart-modal-p">Follow these simple steps to share your precise location via Google Maps.</p>
      <div class="qb-cart-modal-media">
        <img src="{{ 'popupgoogle.png' | asset_url }}" alt="Tutorial">
      </div>
      <div class="qb-cart-modal-actions">
        <a href="https://www.google.com/maps" target="_blank" class="qb-cart-modal-btn-maps">📍 Open Google Maps App</a>
        <button type="button" class="qb-cart-modal-btn-done" id="doneHelpBtn">Got it!</button>
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    --qb-gold: #F4B400;
    --qb-gold-soft: #FFF9E6;
    --qb-black: #111111;
    --qb-gray: #757575;
    --qb-red: #C41E3A;
    --qb-bg: #F8F9FA;
    --qb-border: #EEEEEE;
    --qb-radius: 20px;
    --qb-ease: cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Body Scroll Lock */
  html.qb-no-scroll { overflow: hidden !important; height: 100% !important; }

  /* Base UI */
  .qb-cart-main-component { display: block; background: var(--qb-bg); min-height: 100vh; padding-bottom: 160px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .qb-cart-wrapper-final { max-width: 500px; margin: 0 auto; background: #fff; min-height: 100vh; position: relative; }

  /* Header */
  .qb-cart-title-block { padding: 30px 20px 20px; display: flex; justify-content: space-between; align-items: center; }
  .qb-cart-main-title { font-size: 24px; font-weight: 900; color: var(--qb-black); margin: 0; }
  .qb-cart-items-badge { background: var(--qb-gold-soft); color: var(--qb-gold); font-size: 12px; font-weight: 800; padding: 4px 12px; border-radius: 20px; }

  /* Cards */
  .qb-cart-sections-list { padding: 0 16px; display: flex; flex-direction: column; gap: 16px; }
  .qb-cart-section-card { background: #fff; border: 1px solid var(--qb-border); border-radius: var(--qb-radius); padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.04); position: relative; }
  .qb-cart-section-label { font-size: 10px; font-weight: 900; color: #BBB; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 18px; }

  /* Item Cards */
  .qb-cart-items-stack { display: flex; flex-direction: column; gap: 20px; }
  .qb-cart-item-box { display: flex; gap: 16px; padding-bottom: 20px; border-bottom: 1.5px solid #F9F9F9; }
  .qb-cart-item-box:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .qb-cart-item-visual { width: 90px; height: 90px; border-radius: 14px; overflow: hidden; border: 1px solid #F0F0F0; flex-shrink: 0; background: #F9F9F9; }
  .qb-cart-item-visual img { width: 100%; height: 100%; object-fit: cover; }
  .qb-cart-visual-fall { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 32px; }

  .qb-cart-item-content { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; }
  .qb-cart-item-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .qb-cart-item-name { font-size: 15px; font-weight: 800; color: var(--qb-black); text-decoration: none; line-height: 1.4; }
  .qb-cart-item-remove { background: #F5F5F5; border: none; color: #BBB; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
  .qb-cart-item-remove:active { background: var(--qb-red); color: #fff; transform: scale(0.9); }
  .qb-cart-item-meta { font-size: 12px; color: var(--qb-gray); margin-top: 4px; font-weight: 600; }

  .qb-cart-item-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 12px; }
  .qb-cart-price-val { font-size: 17px; font-weight: 900; color: var(--qb-black); }

  /* Centered Qty Pill */
  .qb-cart-qty-pill { background: #F5F5F5; border-radius: 14px; padding: 2px; display: flex; width: 110px; }
  .qb-cart-qty-flex { display: flex; align-items: center; width: 100%; }
  .qb-cart-qty-act { width: 34px; height: 34px; border: none; background: none; font-size: 20px; font-weight: 800; color: var(--qb-black); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
  .qb-cart-qty-act:active { opacity: 0.5; transform: scale(0.85); }
  .qb-cart-qty-num { flex: 1; display: flex; align-items: center; justify-content: center; }
  .qb-cart-qty-input { width: 100%; border: none; background: transparent; text-align: center !important; font-size: 15px; font-weight: 900; color: var(--qb-black); pointer-events: none; padding: 0; margin: 0; }

  .qb-cart-add-more-items { display: block; text-align: center; margin-top: 20px; font-size: 14px; font-weight: 800; color: var(--qb-gold); text-decoration: none; padding: 14px; border: 2px dashed var(--qb-gold); border-radius: 16px; transition: 0.2s; }
  .qb-cart-add-more-items:active { background: var(--qb-gold-soft); }

  /* Help Circle Trigger */
  .qb-cart-help-trigger {
    width: 32px; height: 32px; border-radius: 50%; background: #fff;
    border: 1.5px solid var(--qb-gold); color: var(--qb-gold);
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: 16px; cursor: pointer;
    box-shadow: 0 4px 12px rgba(244, 180, 0, 0.15); transition: 0.2s;
  }
  .qb-cart-help-trigger:active { transform: scale(0.9); background: var(--qb-gold-soft); }

  /* Input Field Frame */
  .qb-cart-input-group { display: flex; align-items: center; background: #F9F9F9; border: 1.5px solid var(--qb-border); border-radius: 18px; margin: 16px 0; transition: 0.3s; }
  .qb-cart-input-group:focus-within { border-color: var(--qb-gold); background: #fff; box-shadow: 0 0 0 4px var(--qb-gold-soft); }
  .qb-cart-input-icon { padding-left: 18px; color: var(--qb-gold); display: flex; align-items: center; }
  .qb-cart-main-input { flex: 1; padding: 18px 18px 18px 12px; background: transparent; border: none; font-size: 15px; font-weight: 700; color: var(--qb-black); outline: none; }

  .qb-cart-nicknames-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .qb-cart-nick-chip { padding: 14px; background: #fff; border: 1.5px solid var(--qb-border); border-radius: 16px; font-size: 14px; font-weight: 800; color: var(--qb-gray); cursor: pointer; transition: 0.2s; }
  .qb-cart-nick-chip.active { border-color: var(--qb-gold); background: var(--qb-gold-soft); color: var(--qb-gold); box-shadow: 0 4px 12px rgba(244, 180, 0, 0.1); }

  /* Error Banner */
  .qb-cart-error-banner { display: none; background: #FFF1F2; border: 1px solid #FDA4AF; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; align-items: center; gap: 10px; }
  .qb-cart-error-banner.active { display: flex; animation: qbShake 0.4s; }
  .qb-cart-err-msg { font-size: 12px; font-weight: 700; color: #9F1239; margin: 0; text-transform: uppercase; line-height: 1.4; }
  @keyframes qbShake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

  /* Billing Summary Fix */
  .qb-cart-bill-stack { display: flex; flex-direction: column; gap: 12px; }
  .qb-cart-bill-row { display: flex; justify-content: space-between; font-size: 15px; font-weight: 700; color: var(--qb-gray); }
  .qb-cart-bill-muted { font-size: 12px; color: #AAA; font-weight: 600; }
  .qb-cart-bill-divider { height: 1px; border-top: 1.5px dashed var(--qb-border); margin: 4px 0 16px; }
  .qb-cart-bill-total { display: flex; justify-content: space-between; align-items: baseline; }
  .qb-cart-total-lbl { font-size: 18px; font-weight: 900; color: var(--qb-black); }
  .qb-cart-total-val { font-size: 24px; font-weight: 900; color: var(--qb-black); }

  /* Sticky Footer Fix */
  .qb-cart-sticky-footer { position: fixed; bottom: 65px; left: 0; right: 0; max-width: 500px; margin: 0 auto; background: #fff; padding: 16px 20px; border-top: 1px solid var(--qb-border); display: flex; align-items: center; gap: 16px; z-index: 1000; box-shadow: 0 -10px 40px rgba(0,0,0,0.05); }
  .qb-cart-sticky-label { font-size: 10px; font-weight: 900; color: var(--qb-gray); letter-spacing: 1px; }
  .qb-cart-sticky-price { font-size: 22px; font-weight: 900; color: var(--qb-black); }
  .qb-cart-checkout-btn { flex: 1; height: 58px; background: var(--qb-red); color: white; border: none; border-radius: 18px; font-size: 18px; font-weight: 900; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 25px rgba(196, 30, 58, 0.25); }
  .qb-cart-checkout-btn.qb-cart-locked { opacity: 0.6; filter: blur(0.4px); background: #999 !important; cursor: not-allowed; transform: scale(0.98); }

  /* MODAL (Pop-out Fix) */
  .qb-cart-modal-overlay { position: fixed !important; inset: 0 !important; background: rgba(0,0,0,0.85) !important; z-index: 2147483647 !important; display: none; align-items: flex-end; justify-content: center; overflow: hidden !important; touch-action: none; }
  .qb-cart-modal-overlay.active { display: flex; }
  .qb-cart-modal-card { background: #fff; width: 100%; max-width: 500px; border-radius: 32px 32px 0 0; padding: 24px 24px calc(24px + env(safe-area-inset-bottom)); position: relative; box-shadow: 0 -10px 40px rgba(0,0,0,0.5); text-align: center; }
  .qb-cart-modal-notch { width: 40px; height: 4px; background: #eee; border-radius: 2px; margin: 0 auto 20px; }
  .qb-cart-modal-close { position: absolute; top: 20px; right: 20px; background: #f5f5f5; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-weight: bold; color: #333; }
  .qb-cart-modal-h3 { font-size: 20px; font-weight: 900; color: #111; margin-bottom: 8px; }
  .qb-cart-modal-p { font-size: 14px; color: #666; margin-bottom: 24px; line-height: 1.5; }
  .qb-cart-modal-media { width: 100%; border-radius: 18px; overflow: hidden; border: 1px solid #eee; margin-bottom: 24px; background: #f9f9f9; padding: 10px; }
  .qb-cart-modal-media img { width: 100%; display: block; max-height: 45vh; object-fit: contain; }
  .qb-cart-modal-btn-maps { display: flex; align-items: center; justify-content: center; background: #4285F4; color: #fff; text-decoration: none; padding: 16px; border-radius: 16px; font-weight: 800; font-size: 15px; margin-bottom: 12px; }
  .qb-cart-modal-btn-done { width: 100%; padding: 16px; background: #f5f5f5; border: none; border-radius: 16px; font-weight: 700; color: #333; cursor: pointer; font-size: 15px; }

  .qb-flex-between { display: flex; justify-content: space-between; align-items: center; }
  .animate-fade-in { animation: qbFadeIn 0.6s ease-out; }
  @keyframes qbFadeIn { from { opacity: 0; } to { opacity: 1; } }
  .animate-slide-up { animation: qbSlideUp 0.4s var(--qb-ease) forwards; }
  @keyframes qbSlideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

  .qb-cart-empty-hive { padding: 80px 20px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; }
  .qb-cart-empty-bee { font-size: 90px; margin-bottom: 24px; filter: drop-shadow(0 10px 10px rgba(0,0,0,0.1)); }
  .qb-cart-empty-btn { background: var(--qb-gold); color: white; padding: 18px 45px; border-radius: 16px; text-decoration: none; font-weight: 900; display: inline-block; margin-top: 30px; box-shadow: 0 10px 30px rgba(244,180,0,0.3); }
</style>

<script>
(function() {
  function initFinalProCart() {
    const input = document.getElementById('LandmarkLink');
    const checkoutBtn = document.getElementById('qbMainCheckoutBtn');
    const errorBox = document.getElementById('qbCheckoutError');
    const modal = document.getElementById('landmarkModalOverlay');
    const body = document.body;

    // PORTAL: Move modal to Body Root to bypass clipping
    if (modal && modal.parentNode !== body) body.appendChild(modal);

    const validate = () => {
      const val = (input?.value || '').trim();
      const isValid = val.length > 8 && (val.includes('google.com') || val.includes('maps.app') || val.includes('http'));
      if (checkoutBtn) {
        checkoutBtn.disabled = !isValid;
        checkoutBtn.classList.toggle('qb-cart-locked', !isValid);
      }
      if (errorBox) errorBox.classList.toggle('active', !isValid);
    };

    if (input) { input.addEventListener('input', validate); validate(); }

    document.addEventListener('click', (e) => {
      // ? Trigger
      if (e.target.closest('#openHelpBtn')) {
        e.preventDefault(); e.stopPropagation();
        if(modal) modal.classList.add('active');
        document.documentElement.classList.add('qb-no-scroll');
        return;
      }
      // Modal Close
      if (e.target.closest('#closeHelpBtn') || e.target.closest('#doneHelpBtn') || e.target === modal) {
        if(modal) modal.classList.remove('active');
        document.documentElement.classList.remove('qb-no-scroll');
        return;
      }
      // Quantity
      const qtyBtn = e.target.closest('[data-qty-btn]');
      if (qtyBtn) {
        const form = qtyBtn.closest('form');
        const inp = form.querySelector('.qb-cart-qty-input');
        let val = parseInt(inp.value);
        if (qtyBtn.dataset.action === 'minus') {
          if (val > 1) val--; else if (confirm('Remove item?')) val = 0; else return;
        } else val++;
        inp.value = val; form.submit();
        return;
      }
      // Nickname
      const chip = e.target.closest('.qb-cart-nick-chip') || e.target.closest('.qb-nickname-chip');
      if (chip) {
        localStorage.setItem('qb_landmark_' + (localStorage.getItem('qb_active_nickname') || 'Home'), input.value);
        document.querySelectorAll('.qb-cart-nick-chip, .qb-nickname-chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        const next = chip.dataset.nickname;
        localStorage.setItem('qb_active_nickname', next);
        input.value = localStorage.getItem('qb_landmark_' + next) || '';
        validate();
        return;
      }
      // Checkout
      if (e.target.closest('#qbMainCheckoutBtn')) {
        const btn = e.target.closest('#qbMainCheckoutBtn');
        if (btn.disabled) return;
        btn.disabled = true; btn.innerHTML = 'Wait...';
        const nick = localStorage.getItem('qb_active_nickname') || 'Home';
        const fullNote = `Type: ${nick} | Map: ${input.value} | Loc: ${localStorage.getItem('qb_selected_location') || 'N/A'}`;
        fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ note: fullNote }) })
        .finally(() => { window.location.href = '/checkout'; });
      }
    });

    const activeNick = localStorage.getItem('qb_active_nickname') || 'Home';
    document.querySelectorAll('.qb-cart-nick-chip, .qb-nickname-chip').forEach(chip => {
      if (chip.dataset.nickname === activeNick) chip.classList.add('active');
      const saved = localStorage.getItem('qb_landmark_' + activeNick);
      if (chip.dataset.nickname === activeNick && saved) { input.value = saved; validate(); }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initFinalProCart);
  else initFinalProCart();
})();
</script>

