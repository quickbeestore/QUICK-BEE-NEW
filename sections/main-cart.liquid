<!-- sections/main-cart.liquid -->
<cart-items-component class="qb-main-cart-final" data-section-id="{{ section.id }}">
  <div class="qb-cart-shell">
    {%- if cart.empty? -%}
      <div class="qb-empty-state-hive animate-fade-in">
        <div class="qb-empty-icon-bee">🐝</div>
        <h1 class="qb-empty-title-h1">Your Hive is Empty</h1>
        <p class="qb-empty-text-p">Time to fill your basket! Browse our collections to get started.</p>
        <a href="{{ routes.all_products_collection_url }}" class="qb-btn-start-shopping">Explore Shop</a>
      </div>
    {%- else -%}
      
      <!-- INLINE HEADER -->
      <div class="qb-cart-header-pro">
        <h1 class="qb-cart-title-pro">Review Order</h1>
        <span class="qb-cart-badge-pro" ref="cartItemCount">{{ cart.item_count }} Items</span>
      </div>

      <div class="qb-cart-content-flow">
        
        <!-- SECTION: SELECTED PRODUCTS -->
        <div class="qb-section-card-final">
          <div class="qb-card-label-row">
            <span class="qb-tag-pro-text">SELECTED PRODUCTS</span>
          </div>
          
          <div class="qb-items-stack-pro">
            {%- for item in cart.items -%}
              <div class="qb-item-card-pro" ref="cartItemRows" data-key="{{ item.key }}">
                <div class="qb-item-visual-pro">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title | escape }}" loading="lazy">
                  {% else %}
                    <div class="qb-placeholder-pro">🐝</div>
                  {% endif %}
                </div>
                
                <div class="qb-item-info-pro">
                  <div class="qb-item-top-pro">
                    <a href="{{ item.url }}" class="qb-item-name-pro">{{ item.product.title | truncate: 50 }}</a>
                    <form action="{{ routes.cart_change_url }}" method="post">
                      <input type="hidden" name="id" value="{{ item.key }}">
                      <input type="hidden" name="quantity" value="0">
                      <button type="submit" class="qb-item-x-btn-pro" aria-label="Remove item">
                        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M13 1L1 13M1 1L13 13"/></svg>
                      </button>
                    </form>
                  </div>
                  
                  {%- unless item.product.has_only_default_variant -%}
                    <div class="qb-item-variant-pro">{{ item.variant.title }}</div>
                  {%- endunless -%}

                  <div class="qb-item-footer-pro">
                    <span class="qb-price-amt-pro">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    
                    <div class="qb-qty-pill-pro" ref="quantitySelectors">
                      <form action="{{ routes.cart_change_url }}" method="post" class="qb-qty-flex-pro">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-qty-act-pro" data-action="minus" data-qtybtn>−</button>
                        <div class="qb-qty-val-box-pro">
                          <input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-qty-input-pro">
                        </div>
                        <button type="button" class="qb-qty-act-pro" data-action="plus" data-qtybtn>+</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          
          <a href="{{ routes.all_products_collection_url }}" class="qb-add-items-link-pro">+ Add more items</a>
        </div>

        <!-- SECTION: DELIVERY DESTINATION -->
        <div class="qb-section-card-final">
          <div class="qb-card-header-flex-pro">
            <span class="qb-tag-pro-text">DELIVERY DESTINATION</span>
            <!-- PROPER CIRCLE ? BUTTON DESIGN -->
            <button type="button" class="qb-help-circle-final" id="openHelpBtn" aria-label="Help">?</button>
          </div>
          
          <div class="qb-pro-field-box">
            <div class="qb-pro-field-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <input type="text" id="LandmarkLink" placeholder="Paste Google Maps link here..." class="qb-pro-main-input" required>
          </div>
          
          <div class="qb-pro-chips-grid">
            <button type="button" class="qb-pro-chip-btn" data-nickname="Home">🏠 Home</button>
            <button type="button" class="qb-pro-chip-btn" data-nickname="Office">🏢 Office</button>
            <button type="button" class="qb-pro-chip-btn" data-nickname="Other">✨ Other</button>
            <button type="button" class="qb-pro-chip-btn" data-nickname="Current">📦 Current</button>
          </div>
        </div>

        <!-- SECTION: BILLING -->
        <div class="qb-section-card-final">
          <div id="qbCheckoutError" class="qb-error-banner-final animate-fade-in active">
            <span>⚠️ enter the google maps location link TO PROCEED CHECKOUT</span>
          </div>

          <div class="qb-tag-pro-text">BILLING SUMMARY</div>
          <div class="qb-bill-stack-pro">
            <div class="qb-bill-row-pro"><span>Item Total</span><span>Rs {{ cart.total_price | divided_by: 100 }}</span></div>
            <div class="qb-bill-row-pro"><span>Delivery Fee</span><span class="qb-subtext-muted-pro">Calculated at checkout</span></div>
            <div class="qb-bill-divider-pro"></div>
            <div class="qb-bill-total-pro">
              <span class="qb-total-label-pro">Grand Total</span>
              <span class="qb-total-val-pro" ref="cartTotal">Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- STICKY FOOTER -->
      <div class="qb-sticky-checkout-pro">
        <div class="qb-sticky-info-pro">
          <span class="qb-sticky-tag-pro">PAYABLE AMOUNT</span>
          <span class="qb-sticky-price-pro">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-btn-main-checkout-pro qb-is-locked-pro" id="qbMainCheckoutBtn" disabled>
          Checkout ➔
        </button>
      </div>
    {%- endif -%}
  </div>
</cart-items-component>

<!-- TRUE POP-OUT MODAL -->
<div id="landmarkModalOverlay" class="qb-portal-modal-overlay">
  <div class="qb-portal-modal-card animate-slide-up">
    <div class="qb-portal-modal-notch"></div>
    <button class="qb-portal-modal-close-x" id="closeHelpBtn" type="button">✕</button>
    <div class="qb-portal-modal-inner">
      <h3 class="qb-modal-title-final">How to share location?</h3>
      <p class="qb-modal-p-final">Follow these simple steps to share your precise location via Google Maps.</p>
      <div class="qb-modal-media-final">
        <img src="{{ 'popupgoogle.png' | asset_url }}" alt="Tutorial">
      </div>
      <div class="qb-modal-actions-final">
        <a href="https://www.google.com/maps" target="_blank" class="qb-btn-maps-action-pro">📍 Open Google Maps App</a>
        <button type="button" class="qb-btn-modal-dismiss-pro" id="doneHelpBtn">Got it!</button>
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    --qb-gold: #F4B400;
    --qb-gold-soft: #FFF9E6;
    --qb-black: #111111;
    --qb-gray: #757575;
    --qb-red: #C41E3A;
    --qb-bg: #F8F9FA;
    --qb-border: #EEEEEE;
    --qb-radius-xl: 24px;
    --qb-radius-lg: 18px;
    --qb-shadow: 0 4px 20px rgba(0,0,0,0.06);
    --qb-ease: cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Body Scroll Lock Fix */
  html.qb-no-scroll-final { overflow: hidden !important; height: 100% !important; }

  /* Base UI */
  .qb-main-cart-final { display: block; background: var(--qb-bg); min-height: 100vh; padding-bottom: 160px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .qb-cart-shell { max-width: 500px; margin: 0 auto; background: #fff; min-height: 100vh; position: relative; }

  /* Header */
  .qb-cart-header-pro { padding: 30px 20px 20px; display: flex; justify-content: space-between; align-items: center; }
  .qb-cart-title-pro { font-size: 24px; font-weight: 900; color: var(--qb-black); margin: 0; }
  .qb-cart-badge-pro { background: var(--qb-gold-soft); color: var(--qb-gold); font-size: 12px; font-weight: 800; padding: 4px 12px; border-radius: 20px; }

  /* Cards */
  .qb-cart-content-flow { padding: 0 16px; display: flex; flex-direction: column; gap: 16px; }
  .qb-section-card-final { background: #fff; border: 1px solid var(--qb-border); border-radius: var(--qb-radius-xl); padding: 20px; box-shadow: var(--qb-shadow); position: relative; margin-bottom: 4px; }
  .qb-tag-pro-text { font-size: 10px; font-weight: 900; color: #BBB; letter-spacing: 1.5px; text-transform: uppercase; }

  /* Item Cards */
  .qb-items-stack-pro { display: flex; flex-direction: column; gap: 20px; }
  .qb-item-card-pro { display: flex; gap: 16px; padding-bottom: 20px; border-bottom: 1.5px solid #F9F9F9; }
  .qb-item-card-pro:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .qb-item-visual-pro { width: 95px; height: 95px; border-radius: 14px; overflow: hidden; border: 1px solid #F0F0F0; flex-shrink: 0; background: #F9F9F9; }
  .qb-item-visual-pro img { width: 100%; height: 100%; object-fit: cover; }

  .qb-item-info-pro { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; }
  .qb-item-top-pro { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .qb-item-name-pro { font-size: 15px; font-weight: 800; color: var(--qb-black); text-decoration: none; line-height: 1.4; }
  .qb-item-x-btn-pro { background: #F5F5F5; border: none; color: #BBB; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; }
  .qb-item-x-btn-pro:active { background: var(--qb-red); color: #fff; transform: scale(0.9); }
  .qb-item-variant-pro { font-size: 12px; color: var(--qb-gray); margin-top: 4px; font-weight: 600; }

  .qb-item-footer-pro { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 12px; }
  .qb-price-amt-pro { font-size: 17px; font-weight: 900; color: var(--qb-black); }

  /* Centered Qty Pill */
  .qb-qty-pill-pro { background: #F5F5F5; border-radius: 14px; padding: 2px; display: flex; width: 110px; box-shadow: inset 0 1px 4px rgba(0,0,0,0.02); }
  .qb-qty-flex-pro { display: flex; align-items: center; width: 100%; }
  .qb-qty-act-pro { width: 34px; height: 34px; border: none; background: none; font-size: 20px; font-weight: 800; color: var(--qb-black); cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .qb-qty-val-box-pro { flex: 1; display: flex; align-items: center; justify-content: center; }
  .qb-qty-input-pro { width: 100%; border: none; background: transparent; text-align: center !important; font-size: 15px; font-weight: 900; color: var(--qb-black); pointer-events: none; padding: 0; margin: 0; }

  .qb-add-items-link-pro { display: block; text-align: center; margin-top: 20px; font-size: 14px; font-weight: 800; color: var(--qb-gold); text-decoration: none; padding: 14px; border: 2px dashed var(--qb-gold); border-radius: var(--qb-radius-md); transition: 0.2s; }

  /* PROPER CIRCLE ? BUTTON */
  .qb-help-circle-final {
    width: 32px; height: 32px; border-radius: 50% !important; background: #fff !important;
    border: 1.5px solid var(--qb-gold) !important; color: var(--qb-gold) !important;
    display: flex !important; align-items: center !important; justify-content: center !important;
    font-weight: 900 !important; font-size: 16px !important; cursor: pointer !important;
    box-shadow: 0 4px 12px rgba(244, 180, 0, 0.15) !important; transition: 0.2s !important;
  }
  .qb-help-circle-final:active { transform: scale(0.9); background: var(--qb-gold-soft); }

  /* Input Frame */
  .qb-pro-field-box { display: flex; align-items: center; background: #F9F9F9; border: 1.5px solid var(--qb-border); border-radius: 18px; margin: 16px 0; transition: 0.3s; }
  .qb-pro-field-box:focus-within { border-color: var(--qb-gold); background: #fff; box-shadow: 0 0 0 4px var(--qb-gold-soft); }
  .qb-pro-field-icon { padding-left: 18px; color: var(--qb-gold); display: flex; align-items: center; }
  .qb-pro-main-input { flex: 1; padding: 18px 18px 18px 12px; background: transparent; border: none; font-size: 15px; font-weight: 700; color: var(--qb-black); outline: none; }

  .qb-pro-chips-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .qb-pro-chip-btn { padding: 14px; background: #fff; border: 1.5px solid var(--qb-border); border-radius: 16px; font-size: 14px; font-weight: 800; color: var(--qb-gray); cursor: pointer; transition: 0.2s; text-align: center; }
  .qb-pro-chip-btn.active { border-color: var(--qb-gold); background: var(--qb-gold-soft); color: var(--qb-gold); box-shadow: 0 4px 12px rgba(244, 180, 0, 0.1); }

  /* Error Alert */
  .qb-error-banner-final { display: none; background: #FFF1F2; border: 1px solid #FDA4AF; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; align-items: center; gap: 10px; animation: qbShake 0.4s; }
  .qb-error-banner-final.active { display: flex; }
  .qb-error-banner-final span { font-size: 12px; font-weight: 700; color: #9F1239; margin: 0; text-transform: uppercase; line-height: 1.4; }
  @keyframes qbShake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

  /* Sticky Footer */
  .qb-sticky-checkout-pro { position: fixed; bottom: 65px; left: 0; right: 0; max-width: 500px; margin: 0 auto; background: #fff; padding: 16px 20px; border-top: 1px solid var(--qb-border); display: flex; align-items: center; gap: 16px; z-index: 1000; box-shadow: 0 -10px 40px rgba(0,0,0,0.05); }
  .qb-sticky-tag-pro { font-size: 10px; font-weight: 900; color: var(--qb-gray); letter-spacing: 1px; }
  .qb-sticky-price-pro { font-size: 22px; font-weight: 900; color: var(--qb-black); }
  .qb-btn-main-checkout-pro { flex: 1; height: 58px; background: var(--qb-red); color: white; border: none; border-radius: 18px; font-size: 18px; font-weight: 900; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 25px rgba(196, 30, 58, 0.25); }
  .qb-btn-main-checkout-pro.qb-is-locked-pro { opacity: 0.6; filter: blur(0.4px); background: #999 !important; cursor: not-allowed; transform: scale(0.98); }

  /* PORTAL MODAL LAYER */
  .qb-portal-modal-overlay { position: fixed !important; inset: 0 !important; background: rgba(0,0,0,0.85) !important; z-index: 2147483647 !important; display: none; align-items: flex-end; justify-content: center; overflow: hidden !important; touch-action: none; }
  .qb-portal-modal-overlay.is-active { display: flex; }
  .qb-portal-modal-card { background: #fff !important; width: 100% !important; max-width: 500px !important; border-radius: 32px 32px 0 0 !important; padding: 24px 24px calc(24px + env(safe-area-inset-bottom)) !important; position: relative !important; box-shadow: 0 -10px 40px rgba(0,0,0,0.5) !important; text-align: center !important; }
  .qb-portal-modal-notch { width: 40px; height: 4px; background: #eee; border-radius: 2px; margin: 0 auto 20px; }
  .qb-portal-modal-close-x { position: absolute; top: 20px; right: 20px; background: #f5f5f5; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-weight: bold; color: #333; }
  .qb-modal-title-final { font-size: 20px; font-weight: 900; color: #111; margin-bottom: 8px; }
  .qb-modal-p-final { font-size: 14px; color: #666; margin-bottom: 24px; line-height: 1.5; }
  .qb-modal-media-final { width: 100%; border-radius: 18px; overflow: hidden; border: 1px solid #eee; margin-bottom: 24px; background: #f9f9f9; padding: 10px; }
  .qb-modal-media-final img { width: 100%; display: block; border-radius: 8px; max-height: 40vh; object-fit: contain; }
  .qb-btn-maps-action-pro { display: flex; align-items: center; justify-content: center; background: #4285F4; color: #fff; text-decoration: none; padding: 16px; border-radius: 16px; font-weight: 800; font-size: 15px; margin-bottom: 12px; }
  .qb-btn-modal-dismiss-pro { width: 100%; padding: 16px; background: #f5f5f5; border: none; border-radius: 16px; font-weight: 700; color: #333; cursor: pointer; font-size: 15px; }

  .qb-bill-stack-pro { display: flex; flex-direction: column; gap: 12px; }
  .qb-bill-row-pro { display: flex; justify-content: space-between; font-size: 15px; font-weight: 700; color: var(--qb-gray); }
  .qb-subtext-muted-pro { font-size: 12px; color: #AAA; font-weight: 600; }
  .qb-bill-divider-pro { height: 1px; border-top: 1.5px dashed var(--qb-border); margin: 4px 0 16px; }
  .qb-bill-total-pro { display: flex; justify-content: space-between; align-items: baseline; }
  .qb-total-val-pro { font-size: 24px; font-weight: 900; color: var(--qb-black); }

  .qb-flex-between { display: flex; justify-content: space-between; align-items: center; }
  .qb-card-header-flex-pro { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
  .animate-fade-in { animation: qbFadeIn 0.6s ease-out; }
  @keyframes qbFadeIn { from { opacity: 0; } to { opacity: 1; } }
  .animate-slide-up { animation: qbSlideUp 0.4s var(--qb-ease) forwards; }
  @keyframes qbSlideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

  .qb-empty-state-hive { padding: 80px 20px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; }
  .qb-empty-icon-bee { font-size: 90px; margin-bottom: 24px; filter: drop-shadow(0 10px 10px rgba(0,0,0,0.1)); }
  .qb-btn-start-shopping { background: var(--qb-gold); color: white; padding: 18px 45px; border-radius: 16px; text-decoration: none; font-weight: 900; display: inline-block; margin-top: 30px; box-shadow: 0 10px 30px rgba(244,180,0,0.3); }
</style>

<script>
(function() {
  function initFinalProCartFixed() {
    const input = document.getElementById('LandmarkLink');
    const checkoutBtn = document.getElementById('qbMainCheckoutBtn');
    const errorBox = document.getElementById('qbCheckoutError');
    const modal = document.getElementById('landmarkModalOverlay');
    const body = document.body;

    // PORTAL: Move modal to Body Root to bypass clipping
    if (modal && modal.parentNode !== body) body.appendChild(modal);

    const validate = () => {
      const val = (input?.value || '').trim();
      const isValid = val.length > 8 && (val.includes('google.com') || val.includes('maps.app') || val.includes('http'));
      if (checkoutBtn) {
        checkoutBtn.disabled = !isValid;
        checkoutBtn.classList.toggle('qb-is-locked-pro', !isValid);
      }
      if (errorBox) errorBox.classList.toggle('active', !isValid);
    };

    if (input) { input.addEventListener('input', validate); validate(); }

    document.addEventListener('click', (e) => {
      // ? Trigger
      if (e.target.closest('#openHelpBtn')) {
        e.preventDefault(); e.stopPropagation();
        if(modal) modal.classList.add('is-active');
        document.documentElement.classList.add('qb-no-scroll-final');
        return;
      }
      // Modal Close
      if (e.target.closest('#closeHelpBtn') || e.target.closest('#doneHelpBtn') || e.target === modal) {
        if(modal) modal.classList.remove('is-active');
        document.documentElement.classList.remove('qb-no-scroll-final');
        return;
      }
      // Quantity Action
      const qtyBtn = e.target.closest('[data-qtybtn]');
      if (qtyBtn) {
        const form = qtyBtn.closest('form');
        const inp = form.querySelector('.qb-qty-input-pro');
        let val = parseInt(inp.value);
        if (qtyBtn.dataset.action === 'minus') {
          if (val > 1) val--; else if (confirm('Remove item?')) val = 0; else return;
        } else val++;
        inp.value = val; form.submit();
        return;
      }
      // Nickname Interaction
      const chip = e.target.closest('.qb-pro-chip-btn');
      if (chip) {
        localStorage.setItem('qb_landmark_' + (localStorage.getItem('qb_active_nickname') || 'Home'), input.value);
        document.querySelectorAll('.qb-pro-chip-btn').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        const next = chip.dataset.nickname;
        localStorage.setItem('qb_active_nickname', next);
        input.value = localStorage.getItem('qb_landmark_' + next) || '';
        validate();
        return;
      }
      // Checkout Processing
      if (e.target.closest('#qbMainCheckoutBtn')) {
        const btn = e.target.closest('#qbMainCheckoutBtn');
        if (btn.disabled) return;
        btn.disabled = true; btn.innerHTML = 'Wait...';
        const nick = localStorage.getItem('qb_active_nickname') || 'Home';
        const fullNote = `Address Type: ${nick}\nGoogle Maps: ${input.value}\nLocation Data: ${localStorage.getItem('qb_selected_location') || 'N/A'}`;
        fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ note: fullNote }) })
        .finally(() => { window.location.href = '/checkout'; });
      }
    });

    const activeNick = localStorage.getItem('qb_active_nickname') || 'Home';
    document.querySelectorAll('.qb-pro-chip-btn').forEach(chip => {
      if (chip.dataset.nickname === activeNick) chip.classList.add('active');
      const saved = localStorage.getItem('qb_landmark_' + activeNick);
      if (chip.dataset.nickname === activeNick && saved) { input.value = saved; validate(); }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initFinalProCartFixed);
  else initFinalProCartFixed();
})();
</script>

