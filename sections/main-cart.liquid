<!-- sections/main-cart.liquid -->
<cart-items-component class="qb-cart-root" data-section-id="{{ section.id }}">
  <div class="qb-cart-container">
    {%- if cart.empty? -%}
      <div class="qb-empty-hive animate-fade-in">
        <div class="qb-empty-icon">🐝</div>
        <h1>Your Hive is Empty</h1>
        <p>Your basket is waiting for some sweet treats!</p>
        <a href="{{ routes.all_products_collection_url }}" class="qb-btn-explore">Start Shopping</a>
      </div>
    {%- else -%}
      
      <!-- HEADER -->
      <div class="qb-header-row">
        <h1 class="qb-page-title">Review Order</h1>
        <span class="qb-badge-count" ref="cartItemCount">{{ cart.item_count }} Items</span>
      </div>

      <div class="qb-cart-body">
        
        <!-- SECTION: SELECTED PRODUCTS -->
        <div class="qb-cart-section">
          <div class="qb-sec-tag">SELECTED PRODUCTS</div>
          <div class="qb-items-list">
            {%- for item in cart.items -%}
              <div class="qb-item-card" ref="cartItemRows" data-key="{{ item.key }}">
                <div class="qb-item-thumb">
                  {% if item.image %}<img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title }}">{% else %}<div class="qb-thumb-fall">🐝</div>{% endif %}
                </div>
                
                <div class="qb-item-main">
                  <div class="qb-item-top">
                    <a href="{{ item.url }}" class="qb-item-name">{{ item.product.title | truncate: 50 }}</a>
                    <!-- TOP RIGHT X -->
                    <form action="{{ routes.cart_change_url }}" method="post">
                      <input type="hidden" name="id" value="{{ item.key }}"><input type="hidden" name="quantity" value="0">
                      <button type="submit" class="qb-item-remove">
                        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 1L1 13M1 1L13 13"/></svg>
                      </button>
                    </form>
                  </div>
                  
                  {%- unless item.product.has_only_default_variant -%}<div class="qb-item-v">{{ item.variant.title }}</div>{%- endunless -%}

                  <div class="qb-item-bottom">
                    <span class="qb-item-price">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    
                    <!-- CENTERED QUANTITY PILL -->
                    <div class="qb-qty-pill" ref="quantitySelectors">
                      <form action="{{ routes.cart_change_url }}" method="post" class="qb-qty-form">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-qty-act" data-action="minus" data-qbtn>−</button>
                        <div class="qb-qty-box"><input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-qty-num"></div>
                        <button type="button" class="qb-qty-act" data-action="plus" data-qbtn>+</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          <a href="{{ routes.all_products_collection_url }}" class="qb-add-more-items">+ Add more items</a>
        </div>

        <!-- SECTION: DELIVERY -->
        <div class="qb-cart-section">
          <span class="qb-sec-tag">DELIVERY DESTINATION</span>
          
          <div class="qb-input-pro-box">
            <div class="qb-input-pro-pin">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <input type="text" id="LandmarkLink" placeholder="Paste Google Maps location link..." class="qb-input-pro-field" required>
          </div>
          
          <div class="qb-chips-grid">
            <button type="button" class="qb-chip-pro" data-nickname="Home">🏠 Home</button>
            <button type="button" class="qb-chip-pro" data-nickname="Office">🏢 Office</button>
            <button type="button" class="qb-chip-pro" data-nickname="Other">✨ Other</button>
            <button type="button" class="qb-chip-pro" data-nickname="Current">📦 Current</button>
          </div>
        </div>

        <!-- SECTION: BILLING -->
        <div class="qb-cart-section">
          <div id="qbErrBanner" class="qb-error-pro animate-fade-in active">
            <span>⚠️ enter the google maps location link TO PROCEED CHECKOUT</span>
          </div>

          <div class="qb-sec-tag">BILLING SUMMARY</div>
          <div class="qb-bill-stack">
            <div class="qb-bill-row"><span>Item Total</span><span>Rs {{ cart.total_price | divided_by: 100 }}</span></div>
            <div class="qb-bill-row"><span>Delivery Fee</span><span class="qb-muted-txt">Calculated at checkout</span></div>
            <div class="qb-bill-dash"></div>
            <div class="qb-bill-total">
              <span class="qb-total-lbl">Grand Total</span>
              <span class="qb-total-val" ref="cartTotal">Rs {{ cart.total_price | divided_by: 100 }}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- STICKY FOOTER -->
      <div class="qb-sticky-checkout">
        <div class="qb-sticky-info">
          <span class="qb-sticky-tag">PAYABLE AMOUNT</span>
          <span class="qb-sticky-price">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-btn-checkout-main qb-is-locked" id="qbMainCheckoutBtn" disabled>
          Checkout ➔
        </button>
      </div>
    {%- endif -%}
  </div>
</cart-items-component>

<style>
  :root { --qb-gold: #F4B400; --qb-gold-soft: #FFF9E6; --qb-black: #111111; --qb-gray: #757575; --qb-red: #C41E3A; --qb-bg: #F8F9FA; --qb-border: #EEEEEE; }
  
  .qb-cart-root { display: block; background: var(--qb-bg); min-height: 100vh; padding-bottom: 160px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .qb-cart-container { max-width: 500px; margin: 0 auto; background: #fff; min-height: 100vh; position: relative; }

  /* Header */
  .qb-header-row { padding: 30px 20px 20px; display: flex; justify-content: space-between; align-items: center; }
  .qb-page-title { font-size: 24px; font-weight: 900; color: #111; margin: 0; }
  .qb-badge-count { background: var(--qb-gold-soft); color: var(--qb-gold); font-size: 12px; font-weight: 800; padding: 4px 12px; border-radius: 20px; }

  .qb-cart-body { padding: 0 16px; display: flex; flex-direction: column; gap: 16px; }
  .qb-cart-section { background: #fff; border: 1px solid var(--qb-border); border-radius: 20px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.04); position: relative; }
  .qb-sec-tag { font-size: 10px; font-weight: 900; color: #BBB; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 18px; display: block; }

  /* Item Card */
  .qb-items-list { display: flex; flex-direction: column; gap: 20px; }
  .qb-item-card { display: flex; gap: 16px; padding-bottom: 20px; border-bottom: 1.5px solid #F9F9F9; }
  .qb-item-card:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .qb-item-thumb { width: 90px; height: 90px; border-radius: 14px; overflow: hidden; border: 1px solid #F0F0F0; flex-shrink: 0; background: #F9F9F9; }
  .qb-item-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .qb-thumb-fall { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 32px; }
  
  .qb-item-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  .qb-item-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .qb-item-name { font-size: 15px; font-weight: 800; color: #111; text-decoration: none; line-height: 1.4; flex: 1; }
  .qb-item-remove { background: #F5F5F5; border: none; color: #BBB; width: 26px; height: 26px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
  .qb-item-remove:active { background: var(--qb-red); color: white; }
  .qb-item-v { font-size: 12px; color: var(--qb-gray); margin-top: 4px; font-weight: 600; }
  .qb-item-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 12px; }
  .qb-item-price { font-size: 17px; font-weight: 900; color: #111; }

  /* Qty Pill CENTERED */
  .qb-qty-pill { background: #F5F5F5; border-radius: 12px; padding: 2px; display: flex; width: 110px; }
  .qb-qty-form { display: flex; align-items: center; width: 100%; }
  .qb-qty-act { width: 34px; height: 34px; border: none; background: none; font-size: 18px; font-weight: 800; color: #111; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .qb-qty-box { flex: 1; display: flex; align-items: center; justify-content: center; }
  .qb-qty-num { width: 100%; border: none; background: transparent; text-align: center !important; font-size: 15px; font-weight: 900; color: #111; pointer-events: none; padding: 0; margin: 0; }

  .qb-add-more-items { display: block; text-align: center; margin-top: 20px; font-size: 14px; font-weight: 800; color: var(--qb-gold); text-decoration: none; padding: 14px; border: 2px dashed var(--qb-gold); border-radius: 16px; }

  /* Delivery Box */
  .qb-input-pro-box { display: flex; align-items: center; background: #F9F9F9; border: 1.5px solid var(--qb-border); border-radius: 16px; margin: 16px 0; transition: 0.3s; }
  .qb-input-pro-box:focus-within { border-color: var(--qb-gold); background: #fff; box-shadow: 0 0 0 4px var(--qb-gold-soft); }
  .qb-input-pro-pin { padding-left: 16px; color: var(--qb-gold); display: flex; align-items: center; }
  .qb-input-pro-field { flex: 1; padding: 16px 12px; background: transparent; border: none; font-size: 15px; font-weight: 700; outline: none; color: #111; }
  
  .qb-chips-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .qb-chip-pro { padding: 14px; background: #fff; border: 1.5px solid var(--qb-border); border-radius: 14px; font-size: 13px; font-weight: 800; color: #757575; cursor: pointer; transition: 0.2s; }
  .qb-chip-pro.active { border-color: var(--qb-gold); background: var(--qb-gold-soft); color: var(--qb-gold); }

  /* Error Banner */
  .qb-error-pro { display: none; background: #FFF1F2; border: 1px solid #FDA4AF; padding: 12px; border-radius: 12px; margin-bottom: 16px; font-size: 12px; font-weight: 700; color: #9F1239; line-height: 1.4; text-transform: uppercase; }
  .qb-error-pro.active { display: block; }

  /* Billing */
  .qb-bill-stack { display: flex; flex-direction: column; gap: 12px; }
  .qb-bill-row { display: flex; justify-content: space-between; font-size: 15px; font-weight: 700; color: #757575; }
  .qb-muted-txt { font-size: 12px; color: #AAA; }
  .qb-bill-dash { height: 1px; border-top: 1.5px dashed #eee; margin: 4px 0; }
  .qb-bill-total { display: flex; justify-content: space-between; align-items: baseline; padding-top: 4px; }
  .qb-total-lbl { font-size: 18px; font-weight: 900; }
  .qb-total-val { font-size: 24px; font-weight: 900; }

  /* Sticky Footer */
  .qb-sticky-checkout { position: fixed; bottom: 65px; left: 0; right: 0; max-width: 500px; margin: 0 auto; background: #fff; padding: 16px 20px; border-top: 1px solid var(--qb-border); display: flex; align-items: center; gap: 16px; z-index: 900; box-shadow: 0 -10px 40px rgba(0,0,0,0.05); }
  .qb-sticky-tag { font-size: 10px; font-weight: 900; color: #757575; letter-spacing: 1px; }
  .qb-sticky-price { font-size: 22px; font-weight: 900; color: #111; }
  .qb-btn-checkout-main { flex: 1; height: 58px; background: var(--qb-red); color: white; border: none; border-radius: 18px; font-size: 18px; font-weight: 900; cursor: pointer; transition: 0.2s; }
  .qb-btn-checkout-main.qb-is-locked { opacity: 0.5; background: #999 !important; cursor: not-allowed; filter: blur(0.5px); }

  .animate-fade-in { animation: qbIn 0.6s ease; }
  @keyframes qbIn { from { opacity: 0; } to { opacity: 1; } }
</style>

<script>
(function() {
  function init() {
    const input = document.getElementById('LandmarkLink');
    const checkoutBtn = document.getElementById('qbMainCheckoutBtn');
    const errorBox = document.getElementById('qbErrBanner');

    const validate = () => {
      const val = (input?.value || '').trim();
      const isValid = val.length > 8 && (val.includes('google.com') || val.includes('maps.app') || val.includes('http'));
      if (checkoutBtn) {
        checkoutBtn.disabled = !isValid;
        checkoutBtn.classList.toggle('qb-is-locked', !isValid);
      }
      if (errorBox) errorBox.classList.toggle('active', !isValid);
    };

    if (input) { input.addEventListener('input', validate); validate(); }

    document.addEventListener('click', (e) => {
      // Quantity
      const qtyBtn = e.target.closest('[data-qbtn]');
      if (qtyBtn) {
        const form = qtyBtn.closest('form');
        const inp = form.querySelector('.qb-qty-num');
        let val = parseInt(inp.value);
        if (qtyBtn.dataset.action === 'minus') {
          if (val > 1) val--; else if (confirm('Remove item?')) val = 0; else return;
        } else val++;
        inp.value = val; form.submit();
        return;
      }
      // Chips
      const chip = e.target.closest('.qb-chip-pro');
      if (chip) {
        localStorage.setItem('qb_landmark_' + (localStorage.getItem('qb_active_nickname') || 'Home'), input.value);
        document.querySelectorAll('.qb-chip-pro').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        const next = chip.dataset.nickname;
        localStorage.setItem('qb_active_nickname', next);
        input.value = localStorage.getItem('qb_landmark_' + next) || '';
        validate();
        return;
      }
      // Checkout
      if (e.target.closest('#qbMainCheckoutBtn')) {
        const btn = e.target.closest('#qbMainCheckoutBtn');
        if (btn.disabled) return;
        btn.disabled = true; btn.innerHTML = 'Wait...';
        const nick = localStorage.getItem('qb_active_nickname') || 'Home';
        const note = `Type: ${nick} | Map: ${input.value} | Loc: ${localStorage.getItem('qb_selected_location') || 'N/A'}`;
        fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ note: note }) })
        .finally(() => { window.location.href = '/checkout'; });
      }
    });

    const activeNick = localStorage.getItem('qb_active_nickname') || 'Home';
    document.querySelectorAll('.qb-chip-pro').forEach(chip => {
      if (chip.dataset.nickname === activeNick) chip.classList.add('active');
      const saved = localStorage.getItem('qb_landmark_' + activeNick);
      if (chip.dataset.nickname === activeNick && saved) { input.value = saved; validate(); }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

