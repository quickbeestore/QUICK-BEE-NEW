{% capture cart_page_more_blocks_content %}
  <div class="cart-recommendations">
    {%- content_for 'blocks' -%}
  </div>
{% endcapture %}

<cart-items-component
  class="cart-items-component"
  data-section-id="{{ section.id }}"
>
  <template id="empty-cart-template">
    <div class="section-background color-{{ section.settings.color_scheme }}"></div>
    <div class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}">
      <div class="cart--empty" style="{% render 'spacing-style', settings: section.settings %}">
        <div class="empty-icon">🛒</div>
        <h1 class="empty-title">Your cart is empty</h1>
        <a href="/" class="empty-button">Start Shopping</a>
      </div>
    </div>
  </template>

  {% # theme-check-disable UniqueStaticBlockId %}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}">
    <div class="cart-wrapper">

      <!-- COMPACT MOBILE-FIRST HEADER -->
      <div class="cart-header-compact">
        <h1 class="cart-title">Cart</h1>
        <span class="item-badge">{{ cart.item_count }}</span>
      </div>

      {%- unless cart.empty? -%}

        <!-- QUICK DELIVERY INFO -->
        <div class="delivery-chip">
          ⚡ 15-30 min delivery • {% render 'delivery-countdown-timer' %}
        </div>

        <!-- TWO-COLUMN LAYOUT: ITEMS LEFT, SUMMARY RIGHT -->
        <div class="cart-layout">
          <!-- ITEMS LIST - LEFT COLUMN -->
          <div class="items-section">
            <div class="cart-items-list">
              {%- content_for 'block', id: 'cart-page-items', type: '_cart-products' %}
            </div>
          </div>

          <!-- STICKY ORDER SUMMARY - RIGHT COLUMN -->
          <div class="summary-sticky">
            <div class="wallet-section">
              {% render 'wallet-balance' %}
            </div>
            <div class="price-breakdown">
              {%- content_for 'block', id: 'cart-page-summary', type: '_cart-summary' -%}
            </div>
          </div>
        </div>

        <!-- RECOMMENDATIONS SECTION -->
        {% if cart_page_more_blocks_content != blank %}
          {{ cart_page_more_blocks_content }}
        {% endif %}

      {%- endunless -%}

    </div>
  </div>
  {% # theme-check-enable UniqueStaticBlockId %}
</cart-items-component>

{% stylesheet %}
  /* ============================================================================
     PROFESSIONAL MOBILE-FIRST CART - COMPACT & EFFICIENT
     ============================================================================ */

  /* BASE - ZERO UNNECESSARY SPACING */
  .cart-wrapper {
    width: 100%;
    background: #fff;
    overflow: visible !important;
    display: block !important;
  }

  .cart--empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    gap: 16px;
    padding: 40px 20px;
  }

  .empty-icon {
    font-size: 72px;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  .empty-title {
    font-size: 24px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
  }

  .empty-button {
    padding: 12px 28px;
    background: #8B0000;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.2s ease;
  }

  .empty-button:active {
    transform: scale(0.95);
  }

  /* ============================================================================
     COMPACT HEADER - STICKY
     ============================================================================ */
  .cart-header-compact {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(135deg, #8B0000 0%, #600000 100%);
    padding: 14px 16px;
    gap: 12px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
  }

  .cart-title {
    font-size: 20px;
    font-weight: 700;
    color: white;
    margin: 0;
  }

  .item-badge {
    background: rgba(255, 255, 255, 0.25);
    color: white;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
    backdrop-filter: blur(4px);
  }

  /* ============================================================================
     QUICK DELIVERY CHIP - COMPACT
     ============================================================================ */
  .delivery-chip {
    background: linear-gradient(90deg, #fff8e1 0%, #fffbf0 100%);
    border-bottom: 2px solid #DAA520;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 600;
    color: #8B0000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    animation: slideDown 0.3s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ============================================================================
     TWO-COLUMN LAYOUT: ITEMS LEFT, SUMMARY RIGHT
     ============================================================================ */
  .cart-layout {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 12px 0;
  }

  /* ITEMS SECTION - LEFT COLUMN (FULL WIDTH ON MOBILE) */
  .items-section {
    flex: 1;
    min-width: 0;
  }

  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0 12px;
  }

  .cart-items-list > * {
    animation: itemFade 0.3s ease-out;
  }

  @keyframes itemFade {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ============================================================================
     STICKY SUMMARY - RIGHT COLUMN (FIXED ON DESKTOP)
     ============================================================================ */
  .summary-sticky {
    background: white;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 12px 14px;
    z-index: 50;
    width: 100%;
    overflow: visible !important;
    max-width: none !important;
    display: block !important;
  }

  .wallet-section {
    background: linear-gradient(135deg, #f0f4ff 0%, #f9f5ff 100%);
    border: 1px solid #e5e0ff;
    border-radius: 6px;
    padding: 8px 10px;
    margin-bottom: 8px;
    font-size: 11px;
    line-height: 1.3;
  }

  .price-breakdown {
    display: block !important;
    font-size: 12px;
    overflow: visible !important;
    max-width: none !important;
    width: 100%;
    min-width: 260px;
  }

  .price-breakdown > * {
    display: flex !important;
    justify-content: space-between;
    align-items: flex-start;
    line-height: 1.4;
    gap: 6px;
    overflow: visible !important;
    width: 100% !important;
    max-width: none !important;
    color: #333 !important;
    visibility: visible !important;
    flex-wrap: wrap;
  }

  .price-breakdown > * > * {
    flex-shrink: 0;
    white-space: normal !important;
    word-break: break-word;
    color: #333 !important;
    visibility: visible !important;
    overflow: visible !important;
    max-width: none !important;
    display: inline-block !important;
    min-width: 0;
  }

  .price-breakdown > * > :first-child {
    flex-shrink: 0;
    white-space: normal;
    word-break: break-word;
    color: #333 !important;
    visibility: visible !important;
    flex: 1;
  }

  .price-breakdown > * > :last-child {
    flex-shrink: 0;
    text-align: right;
    white-space: nowrap !important;
    color: #333 !important;
    visibility: visible !important;
    flex: 0 0 auto;
  }

  /* Target Shopify's built-in cart summary elements */
  .price-breakdown {
    display: flex !important;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    overflow: visible !important;
    max-width: none !important;
    width: 100%;
  }

  .price-breakdown dt,
  .price-breakdown dd {
    flex-shrink: 0;
    white-space: normal !important;
    word-break: break-word;
    color: #333 !important;
    visibility: visible !important;
    overflow: visible !important;
    max-width: none !important;
    display: inline !important;
  }

  .price-breakdown > * > * {
    flex-shrink: 0;
    white-space: normal !important;
    word-break: break-word;
    color: #333 !important;
    visibility: visible !important;
    overflow: visible !important;
    max-width: none !important;
    display: inline !important;
  }

  /* ============================================================================
     RECOMMENDATIONS
     ============================================================================ */
  .cart-recommendations {
    padding: 20px 0;
    margin-top: 12px;
    border-top: 1px dashed #e5e5e5;
  }

  /* ============================================================================
     ENSURE SINGLE SCROLLBAR
     ============================================================================ */
  .section,
  .section-background,
  .cart-items-component,
  main,
  .content-for-layout {
    overflow: visible !important;
    height: auto !important;
    max-height: none !important;
  }

  html {
    overflow-y: scroll !important;
    scroll-behavior: smooth;
  }

  body {
    overflow: visible !important;
    height: auto !important;
  }

  /* ============================================================================
     DARK MODE - MAINTAIN LIGHT THEME
     ============================================================================ */
  @media (prefers-color-scheme: dark) {
    .cart-wrapper {
      background: #fff !important;
      color-scheme: light !important;
    }

    .cart-header-compact {
      background: linear-gradient(135deg, #8B0000 0%, #600000 100%) !important;
      color-scheme: light !important;
    }

    .cart-title {
      color: #ffffff !important;
      color-scheme: light !important;
    }

    .item-badge {
      background: rgba(255, 255, 255, 0.25) !important;
      color: white !important;
      color-scheme: light !important;
    }

    .delivery-chip {
      background: linear-gradient(90deg, #fff8e1 0%, #fffbf0 100%) !important;
      border-color: #DAA520 !important;
      color: #8B0000 !important;
      color-scheme: light !important;
    }

    .summary-sticky {
      background: white !important;
      border-color: #e5e5e5 !important;
      color-scheme: light !important;
      box-shadow: none !important;
    }

    .wallet-section {
      background: linear-gradient(135deg, #f0f4ff 0%, #f9f5ff 100%) !important;
      border-color: #e5e0ff !important;
      color-scheme: light !important;
    }

    .empty-title {
      color: #1a1a1a !important;
    }
  }

  /* ============================================================================
     TABLET - 750PX+ (TWO-COLUMN LAYOUT BEGINS)
     ============================================================================ */
  @media (min-width: 750px) {
    .cart-header-compact {
      padding: 16px 24px;
    }

    .cart-title {
      font-size: 24px;
    }

    .delivery-chip {
      padding: 12px 24px;
      font-size: 14px;
    }

    .cart-layout {
      flex-direction: row;
      gap: 24px;
      padding: 16px 24px;
      align-items: flex-start;
      max-width: none !important;
      width: 100% !important;
    }

    .items-section {
      flex: 1.2;
      padding: 0;
      min-width: 0;
      max-width: none !important;
    }

    .cart-items-list {
      padding: 0;
      gap: 12px;
    }

    .summary-sticky {
      flex: 0 1 420px;
      position: sticky;
      top: 60px;
      padding: 14px 16px;
      height: fit-content;
      margin-top: 0;
      min-width: 0;
      max-width: none !important;
      overflow: visible !important;
      width: 100% !important;
    }

    .price-breakdown {
      font-size: 13px;
      overflow: visible !important;
      max-width: none !important;
      width: 100% !important;
      min-width: 350px;
    }

    .price-breakdown > * {
      overflow: visible !important;
      max-width: none !important;
      width: 100% !important;
      min-width: 0;
    }

    .cart-recommendations {
      padding: 32px 24px;
    }
  }

  /* ============================================================================
     DESKTOP - 1024PX+ (OPTIMIZED TWO-COLUMN)
     ============================================================================ */
  @media (min-width: 1024px) {
    .cart-header-compact {
      padding: 18px 32px;
    }

    .cart-title {
      font-size: 28px;
    }

    .delivery-chip {
      padding: 14px 32px;
    }

    .cart-layout {
      padding: 20px 32px;
      gap: 40px;
    }

    .items-section {
      flex: 1.8;
    }

    .summary-sticky {
      flex: 0 1 500px;
      padding: 20px;
      top: 70px;
      min-width: 450px;
    }

    .cart-recommendations {
      padding: 40px 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.cart",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
