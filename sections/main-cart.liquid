<!-- sections/main-cart.liquid -->
<cart-items-component class="qb-cart-component" data-section-id="{{ section.id }}">
  <div class="qb-cart-wrapper">
    {%- if cart.empty? -%}
      <!-- EMPTY CART -->
      <div class="qb-empty-cart animate-fade-in">
        <div class="qb-empty-card">
          <div class="qb-empty-icon-wrap">
            <span class="qb-empty-emoji">🛒</span>
          </div>
          <h1 class="qb-empty-title">Your cart is empty</h1>
          <p class="qb-empty-subtitle">Add items to get started!</p>
          <a href="{{ routes.all_products_collection_url }}" class="qb-empty-btn">Start Shopping</a>
        </div>
      </div>
    {%- else -%}

      <!-- CART HEADER -->
      <div class="qb-cart-header">
        <h1>Review Order</h1>
        <span class="qb-header-count">{{ cart.item_count }} item{% if cart.item_count > 1 %}s{% endif %}</span>
      </div>

      <!-- MAIN CONTENT -->
      <div class="qb-cart-container">
        <!-- ITEM LIST -->
        <div class="qb-cart-card">
          <div class="qb-cart-items">
            {%- for item in cart.items -%}
              <div class="qb-cart-item">
                <div class="qb-item-img">
                  {% if item.image %}<img src="{{ item.image | image_url: width: 180 }}" alt="{{ item.title | escape }}">{% else %}<div class="qb-no-img">🐝</div>{% endif %}
                </div>
                <div class="qb-item-details">
                  <div class="qb-item-row">
                    <a href="{{ item.url }}" class="qb-item-name">{{ item.product.title | truncate: 45 }}</a>
                    <form action="{{ routes.cart_change_url }}" method="post">
                      <input type="hidden" name="id" value="{{ item.key }}">
                      <input type="hidden" name="quantity" value="0">
                      <button type="submit" class="qb-remove-item">✕</button>
                    </form>
                  </div>
                  {% if item.variant.title != 'Default Title' %}<span class="qb-item-var">{{ item.variant.title }}</span>{% endif %}
                  <div class="qb-item-bottom">
                    <span class="qb-price-curr">Rs {{ item.final_line_price | divided_by: 100 }}</span>
                    <div class="qb-qty-box">
                      <form action="{{ routes.cart_change_url }}" method="post">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <button type="button" class="qb-qty-act qb-qty-minus">−</button>
                        <input type="number" name="quantity" value="{{ item.quantity }}" readonly class="qb-qty-val">
                        <button type="button" class="qb-qty-act qb-qty-plus">+</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          <a href="{{ routes.all_products_collection_url }}" class="qb-add-more">+ Add more items</a>
        </div>

        <!-- DELIVERY LANDMARK -->
        <div class="qb-cart-card">
          <div class="qb-landmark-header">
            <h2 class="qb-card-title">DELIVERY LANDMARK</h2>
            <button type="button" class="qb-help-pill" onclick="window.qbOpenHelp()">
              HELP <span>?</span>
            </button>
          </div>
          <div class="qb-input-wrap">
            <span class="qb-input-icon">📍</span>
            <input type="text" id="LandmarkLink" placeholder="Paste Google Maps link here..." class="qb-landmark-input">
          </div>
          <div class="qb-nick-grid">
            <button type="button" class="qb-nick-btn" data-nickname="Home">🏠 Home</button>
            <button type="button" class="qb-nick-btn" data-nickname="Office">🏢 Office</button>
            <button type="button" class="qb-nick-btn" data-nickname="Other">✨ Other</button>
            <button type="button" class="qb-nick-btn" data-nickname="Current">📦 Current</button>
          </div>
        </div>

        <!-- BILLING -->
        <div class="qb-cart-card qb-bill-card">
          <h2 class="qb-card-title">Bill Details</h2>
          <div class="qb-bill-row"><span>Item Total</span><span>Rs {{ cart.total_price | divided_by: 100 }}</span></div>
          <div class="qb-bill-row"><span>Delivery Fee</span><span class="qb-text-green">FREE</span></div>
          <div class="qb-total-row"><span>Grand Total</span><span>Rs {{ cart.total_price | divided_by: 100 }}</span></div>
        </div>

        <!-- TRUST -->
        <div class="qb-trust-row">
          <span>🛡️ Secure Checkout</span>
          <span>⚡ Fast Delivery</span>
        </div>
      </div>

      <!-- FOOTER BUTTON -->
      <div class="qb-sticky-footer">
        <div class="qb-footer-info">
          <span class="qb-footer-label">TOTAL</span>
          <span class="qb-footer-price">Rs {{ cart.total_price | divided_by: 100 }}</span>
        </div>
        <button type="button" class="qb-checkout-btn" id="qb-checkout-btn">Checkout ➔</button>
      </div>

    {%- endif -%}
  </div>
</cart-items-component>

<!-- HELP MODAL -->
<div id="qb-help-modal" class="qb-modal-overlay" style="display: none;" onclick="if(event.target === this) window.qbCloseHelp()">
  <div class="qb-modal-container animate-slide-up">
    <div class="qb-modal-handle"></div>
    <button class="qb-modal-close" type="button" onclick="window.qbCloseHelp()">✕</button>
    <div class="qb-modal-body">
      <h3 class="qb-modal-title">How to share location?</h3>
      <img src="{{ 'popupgoogle.png' | asset_url }}" alt="Instructions" class="qb-modal-img">
      <a href="https://www.google.com/maps" target="_blank" class="qb-maps-link">Open Google Maps App</a>
      <button type="button" class="qb-modal-done" onclick="window.qbCloseHelp()">Got it!</button>
    </div>
  </div>
</div>

<style>
  :root { --qb-purple: #7a14ac; --qb-red: #C41E3A; --qb-black: #111111; --qb-bg: #f8f9fa; --qb-border: #eaecf0; --qb-ease: cubic-bezier(0.4, 0, 0.2, 1); }
  
  .qb-cart-component { display: block; background: var(--qb-bg); min-height: 100vh; padding-bottom: 120px; }
  .qb-cart-wrapper { max-width: 500px; margin: 0 auto; background: #fff; box-shadow: 0 0 20px rgba(0,0,0,0.05); min-height: 100vh; position: relative; }

  /* HEADER */
  .qb-cart-header { padding: 20px; border-bottom: 1px solid var(--qb-border); display: flex; align-items: center; justify-content: space-between; background: #fff; position: sticky; top: 0; z-index: 100; }
  .qb-cart-header h1 { font-size: 20px; font-weight: 900; margin: 0; }
  .qb-header-count { background: #f5f5f5; padding: 4px 10px; border-radius: 8px; font-size: 13px; font-weight: 700; color: #666; }

  /* CONTAINER */
  .qb-cart-container { padding: 16px; display: flex; flex-direction: column; gap: 16px; }
  .qb-cart-card { background: #fff; border: 1px solid var(--qb-border); border-radius: 20px; padding: 16px; }
  .qb-card-title { font-size: 13px; font-weight: 900; color: #888; margin: 0 0 16px; letter-spacing: 0.5px; }

  /* ITEMS */
  .qb-cart-item { display: flex; gap: 12px; align-items: center; padding-bottom: 16px; border-bottom: 1px solid #f8f9fa; margin-bottom: 16px; }
  .qb-cart-item:last-child { border-bottom: none; padding-bottom: 0; margin-bottom: 0; }
  .qb-item-img { width: 70px; height: 70px; border-radius: 12px; overflow: hidden; background: #f8f9fa; flex-shrink: 0; }
  .qb-item-img img { width: 100%; height: 100%; object-fit: cover; }
  .qb-item-details { flex: 1; min-width: 0; }
  .qb-item-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
  .qb-item-name { font-size: 14px; font-weight: 700; color: inherit; text-decoration: none; line-height: 1.3; }
  .qb-remove-item { background: none; border: none; color: #ccc; cursor: pointer; font-size: 16px; }
  .qb-item-var { font-size: 11px; color: #999; display: block; margin-top: 2px; }
  .qb-item-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; }
  .qb-price-curr { font-weight: 800; color: var(--qb-purple); font-size: 16px; }
  .qb-qty-box { display: flex; align-items: center; border: 1px solid #ddd; border-radius: 8px; overflow: hidden; height: 32px; background: #fff; }
  .qb-qty-act { width: 32px; height: 100%; border: none; background: #f8f9fa; cursor: pointer; font-weight: 800; }
  .qb-qty-val { width: 32px; border: none; text-align: center; font-weight: 800; font-size: 14px; background: #fff; }
  .qb-add-more { display: block; text-align: center; padding: 12px; border: 1px dashed #ccc; border-radius: 12px; text-decoration: none; color: var(--qb-purple); font-weight: 700; font-size: 14px; margin-top: 16px; }

  /* LANDMARK */
  .qb-landmark-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .qb-help-pill { background: #fff; border: 1.5px solid var(--qb-purple); border-radius: 20px; padding: 4px 10px; color: var(--qb-purple); font-size: 11px; font-weight: 900; cursor: pointer; display: flex; align-items: center; gap: 6px; }
  .qb-help-pill span { background: var(--qb-purple); color: #fff; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .qb-input-wrap { position: relative; display: flex; align-items: center; margin-bottom: 16px; }
  .qb-input-icon { position: absolute; left: 12px; font-size: 16px; }
  .qb-landmark-input { width: 100%; padding: 12px 12px 12px 38px; background: #f8f9fa; border: 1.5px solid var(--qb-border); border-radius: 12px; font-size: 14px; outline: none; }
  .qb-landmark-input:focus { border-color: var(--qb-purple); background: #fff; }
  .qb-nick-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .qb-nick-btn { padding: 10px; background: #fff; border: 1.5px solid var(--qb-border); border-radius: 10px; font-size: 12px; font-weight: 700; cursor: pointer; text-align: center; }
  .qb-nick-btn.active { border-color: var(--qb-purple); background: #fdf7ff; color: var(--qb-purple); }

  /* BILL */
  .qb-bill-row { display: flex; justify-content: space-between; font-size: 14px; color: #555; margin-bottom: 10px; }
  .qb-text-green { color: #039855; font-weight: 800; }
  .qb-total-row { border-top: 1px dashed #ddd; padding-top: 12px; font-size: 17px; font-weight: 900; color: #111; }
  .qb-trust-row { display: flex; justify-content: center; gap: 20px; font-size: 11px; font-weight: 700; color: #bbb; margin-top: 8px; }

  /* STICKY FOOTER - Bulletproof Fixed Positioning (Above Mobile Nav) */
  .qb-sticky-footer { position: fixed; bottom: 65px; left: 0; right: 0; background: #fff; padding: 16px 20px calc(16px + env(safe-area-inset-bottom)); border-top: 1px solid var(--qb-border); display: flex !important; align-items: center; justify-content: space-between; gap: 16px; z-index: 9997; box-shadow: 0 -5px 20px rgba(0,0,0,0.1); width: 100%; max-width: 500px; margin: 0 auto; }
  .qb-footer-info { display: flex; flex-direction: column; }
  .qb-footer-label { font-size: 10px; font-weight: 800; color: #999; }
  .qb-footer-price { font-size: 20px; font-weight: 900; }
  .qb-checkout-btn { flex: 1; background: var(--qb-red) !important; color: #fff !important; border: none !important; height: 50px !important; border-radius: 16px !important; font-size: 17px !important; font-weight: 900 !important; cursor: pointer !important; display: flex !important; align-items: center !important; justify-content: center !important; }

  /* MODAL */
  .qb-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(4px); z-index: 999999999999 !important; display: flex; align-items: flex-end; justify-content: center; }
  .qb-modal-container { background: #fff; width: 100%; max-width: 500px; border-radius: 32px 32px 0 0; padding: 24px; position: relative; }
  .qb-modal-handle { width: 40px; height: 4px; background: #eee; border-radius: 2px; margin: 0 auto 20px; }
  .qb-modal-close { position: absolute; top: 20px; right: 20px; background: #f5f5f5; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: bold; }
  .qb-modal-title { font-size: 18px; font-weight: 800; margin: 0 0 20px; text-align: center; }
  .qb-modal-img { width: 100%; border-radius: 20px; margin-bottom: 20px; border: 1px solid #eee; display: block; }
  .qb-maps-link { display: flex; align-items: center; justify-content: center; background: #4285F4; color: #fff; text-decoration: none; padding: 16px; border-radius: 16px; font-weight: 800; margin-bottom: 12px; }
  .qb-modal-done { width: 100%; padding: 16px; background: #f0f0f0; border: none; border-radius: 16px; font-weight: 700; color: #333; cursor: pointer; }

  .animate-slide-up { animation: slideUp 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
  @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
</style>

<script>
// FAIL-SAFE GLOBAL MODAL TRIGGER
window.qbOpenHelp = function() {
  const modal = document.getElementById('qb-help-modal');
  if (modal) modal.style.display = 'flex';
};
window.qbCloseHelp = function() {
  const modal = document.getElementById('qb-help-modal');
  if (modal) modal.style.display = 'none';
};

(function() {
  function init() {
    const input = document.getElementById('LandmarkLink');
    if (!input) return;

    // INITIAL NICKNAME LOAD
    const active = localStorage.getItem('qb_active_nickname') || 'Home';
    document.querySelectorAll('.qb-nick-btn').forEach(btn => {
      const saved = localStorage.getItem('qb_landmark_' + btn.dataset.nickname);
      if (btn.dataset.nickname === active) {
        btn.classList.add('active');
        if (saved) input.value = saved;
      }
    });

    // CLICKS
    document.addEventListener('click', (e) => {
      // 1. Nicknames
      const nick = e.target.closest('.qb-nick-btn');
      if (nick) {
        const inp = document.getElementById('LandmarkLink');
        const oldNick = localStorage.getItem('qb_active_nickname') || 'Home';
        if (inp) localStorage.setItem('qb_landmark_' + oldNick, inp.value);

        document.querySelectorAll('.qb-nick-btn').forEach(b => b.classList.remove('active'));
        nick.classList.add('active');
        
        const newNick = nick.dataset.nickname;
        localStorage.setItem('qb_active_nickname', newNick);
        const newSaved = localStorage.getItem('qb_landmark_' + newNick);
        if (inp) inp.value = newSaved || '';
        return;
      }

      // 2. Qty
      const act = e.target.closest('.qb-qty-act');
      if (act) {
        const form = act.closest('form');
        const valInp = form.querySelector('.qb-qty-val');
        let val = parseInt(valInp.value);
        if (act.classList.contains('qb-qty-minus')) {
          if (val > 1) val--;
          else if (confirm('Remove item?')) val = 0;
          else return;
        } else { val++; }
        valInp.value = val;
        form.submit();
        return;
      }

      // 3. Checkout
      const checkout = e.target.closest('#qb-checkout-btn');
      if (checkout) {
        if (checkout.disabled) return;
        checkout.innerHTML = 'Wait...';
        checkout.disabled = true;
        const landmark = document.getElementById('LandmarkLink')?.value || '';
        fetch('/cart/update.js', { 
          method: 'POST', 
          headers: { 'Content-Type': 'application/json' }, 
          body: JSON.stringify({ note: 'Map: ' + landmark }) 
        }).finally(() => { window.location.href = '/checkout'; });
      }
    });

    // TYPING
    input.addEventListener('input', () => {
      const current = localStorage.getItem('qb_active_nickname') || 'Home';
      localStorage.setItem('qb_landmark_' + current, input.value);
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

{% schema %}
{ "name": "Cart Page", "settings": [], "presets": [{ "name": "Cart Page" }] }
{% endschema %}