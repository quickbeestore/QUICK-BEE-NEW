{% comment %}
  Birthday Magazine Builder — Quickbee
  Fully self-contained multi-step custom magazine builder.
  - 5-step wizard with live CSS magazine mockup
  - Photo upload with drag & drop (up to 20 photos, client-side compressed)
  - EmailJS integration → sends photos to print@quickbee.store
  - Shopify cart via /cart/add.js with order note + line item properties
  - Dark/light theme aware, fully responsive
{% endcomment %}

{% comment %}EmailJS removed — photos submitted by customer email after order{% endcomment %}

<div class="bmb"
  id="bmb-root"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-service-id="{{ section.settings.emailjs_service_id | escape }}"
  data-template-id="{{ section.settings.emailjs_template_id | escape }}"
  data-max-photos="{{ section.settings.max_photos | default: 20 }}"
  data-print-email="{{ section.settings.print_email | default: 'print@quickbee.store' }}">

  <!-- HERO -->
  <div class="bmb-hero">
    <span class="bmb-hero-chip">🎂 Custom Birthday Magazine</span>
    <h1 class="bmb-hero-h1">Build a Magazine They'll<br><span class="bmb-gold">Never Forget</span></h1>
    <p class="bmb-hero-p">Turn your favourite memories into a stunning printed magazine — personalised, beautifully designed, delivered fresh.</p>
  </div>

  <!-- STEP PROGRESS -->
  <div class="bmb-prog-wrap">
    <div class="bmb-prog-rail">
      <div class="bmb-prog-fill" id="bmb-prog-fill"></div>
    </div>
    <div class="bmb-prog-steps">
      {% assign step_labels = "Person,Photos,Style,Message,Order" | split: "," %}
      {% for lbl in step_labels %}
      <div class="bmb-prog-dot{% if forloop.first %} active{% endif %}" data-step="{{ forloop.index }}">
        <div class="bmb-prog-circle">
          <span class="bmb-prog-n">{{ forloop.index }}</span>
          <span class="bmb-prog-ck" aria-hidden="true">✓</span>
        </div>
        <span class="bmb-prog-lbl">{{ lbl }}</span>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- BODY: FORM + PREVIEW -->
  <div class="bmb-body">

    <!-- ── FORM SIDE ── -->
    <div class="bmb-form-side">

      <!-- ╔══════════╗ -->
      <!-- ║  STEP 1  ║ -->
      <!-- ╚══════════╝ -->
      <div class="bmb-panel" id="bmb-panel-1" data-panel="1">
        <div class="bmb-panel-head">
          <div class="bmb-panel-emoji">🎂</div>
          <div>
            <h2 class="bmb-panel-title">Who's the star?</h2>
            <p class="bmb-panel-sub">Tell us about the person being celebrated.</p>
          </div>
        </div>

        <div class="bmb-fg">
          <div class="bmb-f bmb-f--full">
            <label class="bmb-lbl" for="bmb-recipient">Recipient's Name <span class="bmb-ast">*</span></label>
            <input class="bmb-inp" id="bmb-recipient" type="text" placeholder="e.g. Priya Sharma" autocomplete="off">
          </div>

          <div class="bmb-f bmb-f--full">
            <label class="bmb-lbl">Occasion <span class="bmb-ast">*</span></label>
            <div class="bmb-occ-wrap">
              <button type="button" class="bmb-occ bmb-occ--on" data-occ="Birthday">🎂<span>Birthday</span></button>
              <button type="button" class="bmb-occ" data-occ="Anniversary">💑<span>Anniversary</span></button>
              <button type="button" class="bmb-occ" data-occ="Graduation">🎓<span>Graduation</span></button>
              <button type="button" class="bmb-occ" data-occ="Farewell">✈️<span>Farewell</span></button>
              <button type="button" class="bmb-occ" data-occ="Appreciation">🌟<span>Appreciation</span></button>
              <button type="button" class="bmb-occ" data-occ="Wedding">💍<span>Wedding</span></button>
            </div>
            <input type="hidden" id="bmb-occasion" value="Birthday">
          </div>

          <div class="bmb-f">
            <label class="bmb-lbl" for="bmb-date">Date of Occasion</label>
            <input class="bmb-inp" id="bmb-date" type="date">
          </div>

          <div class="bmb-f">
            <label class="bmb-lbl" for="bmb-from">From (Your Name) <span class="bmb-ast">*</span></label>
            <input class="bmb-inp" id="bmb-from" type="text" placeholder="e.g. The Sharma Family">
          </div>
        </div>
      </div>

      <!-- ╔══════════╗ -->
      <!-- ║  STEP 2  ║ -->
      <!-- ╚══════════╝ -->
      <div class="bmb-panel bmb-gone" id="bmb-panel-2" data-panel="2">
        <div class="bmb-panel-head">
          <div class="bmb-panel-emoji">📸</div>
          <div>
            <h2 class="bmb-panel-title">Your Photos</h2>
            <p class="bmb-panel-sub">Send us your pictures after placing the order — we'll handle the rest.</p>
          </div>
        </div>

        <div class="bmb-photo-instruction">
          <div class="bmb-photo-instr-icon">📧</div>
          <h3 class="bmb-photo-instr-title">Email Us Your Photos</h3>
          <p class="bmb-photo-instr-text">
            After placing your order, email your pictures to <strong>print@quickbee.store</strong>
            with your <strong>Order ID &amp; Name</strong>.<br><br>
            Our team will respond within <strong>20 minutes</strong> and start building your magazine right away.
          </p>
          <div class="bmb-photo-instr-steps">
            <div class="bmb-photo-instr-step">
              <span class="bmb-photo-instr-num">1</span>
              <span>Place your order below — note your Order ID</span>
            </div>
            <div class="bmb-photo-instr-step">
              <span class="bmb-photo-instr-num">2</span>
              <span>Email photos to <strong>print@quickbee.store</strong></span>
            </div>
            <div class="bmb-photo-instr-step">
              <span class="bmb-photo-instr-num">3</span>
              <span>Include your Order ID &amp; Name in the email subject</span>
            </div>
            <div class="bmb-photo-instr-step">
              <span class="bmb-photo-instr-num">4</span>
              <span>We reply within 20 minutes 🚀</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ╔══════════╗ -->
      <!-- ║  STEP 3  ║ -->
      <!-- ╚══════════╝ -->
      <div class="bmb-panel bmb-gone" id="bmb-panel-3" data-panel="3">
        <div class="bmb-panel-head">
          <div class="bmb-panel-emoji">✨</div>
          <div>
            <h2 class="bmb-panel-title">Choose your style</h2>
            <p class="bmb-panel-sub">Pick the package and visual theme for your magazine.</p>
          </div>
        </div>

        <!-- Packages (from Shopify variants) -->
        <div class="bmb-f bmb-f--full">
          <label class="bmb-lbl">Magazine Package</label>
          <div class="bmb-pkgs" id="bmb-pkgs">
            {% for variant in product.variants %}
            <label class="bmb-pkg{% if forloop.first %} bmb-pkg--on{% endif %}"
                   data-vid="{{ variant.id }}"
                   data-price="{{ variant.price | money_without_currency }}">
              <input type="radio" name="bmb-variant" value="{{ variant.id }}"{% if forloop.first %} checked{% endif %}>
              <div class="bmb-pkg-inner">
                <div class="bmb-pkg-name">{{ variant.title }}</div>
                <div class="bmb-pkg-price">{{ variant.price | money }}</div>
                {% if forloop.index == 3 %}<div class="bmb-pkg-badge">⭐ Most Popular</div>{% endif %}
              </div>
            </label>
            {% else %}
            <label class="bmb-pkg bmb-pkg--on"
                   data-vid="{{ product.variants.first.id }}"
                   data-price="{{ product.price | money_without_currency }}">
              <input type="radio" name="bmb-variant" value="{{ product.variants.first.id }}" checked>
              <div class="bmb-pkg-inner">
                <div class="bmb-pkg-name">Birthday Magazine</div>
                <div class="bmb-pkg-price">{{ product.price | money }}</div>
              </div>
            </label>
            {% endfor %}
          </div>
        </div>

        <!-- Cover Style -->
        <div class="bmb-f bmb-f--full">
          <label class="bmb-lbl">Cover Style</label>
          <div class="bmb-cs-wrap">
            <button type="button" class="bmb-cs bmb-cs--on" data-cs="Modern"    data-cc="#1a1a2e">
              <div class="bmb-cs-dot" style="background:#1a1a2e"></div><span>Modern</span>
            </button>
            <button type="button" class="bmb-cs" data-cs="Vintage"   data-cc="#6b4a2a">
              <div class="bmb-cs-dot" style="background:#6b4a2a"></div><span>Vintage</span>
            </button>
            <button type="button" class="bmb-cs" data-cs="Elegant"   data-cc="#2d3a4a">
              <div class="bmb-cs-dot" style="background:#2d3a4a"></div><span>Elegant</span>
            </button>
            <button type="button" class="bmb-cs" data-cs="Playful"   data-cc="#e91e8c">
              <div class="bmb-cs-dot" style="background:#e91e8c"></div><span>Playful</span>
            </button>
            <button type="button" class="bmb-cs" data-cs="Minimal"   data-cc="#f5f5f0">
              <div class="bmb-cs-dot" style="background:#f5f5f0;border:2px solid #ccc"></div><span>Minimal</span>
            </button>
            <button type="button" class="bmb-cs" data-cs="Golden"    data-cc="#b8860b">
              <div class="bmb-cs-dot" style="background:linear-gradient(135deg,#b8860b,#F4B400)"></div><span>Golden</span>
            </button>
          </div>
          <input type="hidden" id="bmb-cs-val" value="Modern">
          <input type="hidden" id="bmb-cc-val" value="#1a1a2e">
        </div>

        <div class="bmb-fg">
          <div class="bmb-f">
            <label class="bmb-lbl">Paper Finish</label>
            <div class="bmb-pills" data-target="bmb-paper">
              <button type="button" class="bmb-pill bmb-pill--on" data-v="Glossy">Glossy ✨</button>
              <button type="button" class="bmb-pill" data-v="Matte">Matte</button>
              <button type="button" class="bmb-pill" data-v="Satin">Satin</button>
            </div>
            <input type="hidden" id="bmb-paper" value="Glossy">
          </div>
          <div class="bmb-f">
            <label class="bmb-lbl">Orientation</label>
            <div class="bmb-pills" data-target="bmb-orientation">
              <button type="button" class="bmb-pill bmb-pill--on" data-v="Portrait">Portrait</button>
              <button type="button" class="bmb-pill" data-v="Square">Square</button>
            </div>
            <input type="hidden" id="bmb-orientation" value="Portrait">
          </div>
        </div>
      </div>

      <!-- ╔══════════╗ -->
      <!-- ║  STEP 4  ║ -->
      <!-- ╚══════════╝ -->
      <div class="bmb-panel bmb-gone" id="bmb-panel-4" data-panel="4">
        <div class="bmb-panel-head">
          <div class="bmb-panel-emoji">💬</div>
          <div>
            <h2 class="bmb-panel-title">Add your words</h2>
            <p class="bmb-panel-sub">These appear on the cover and opening page of your magazine.</p>
          </div>
        </div>

        <div class="bmb-fg">
          <div class="bmb-f bmb-f--full">
            <label class="bmb-lbl" for="bmb-headline">Magazine Headline <span class="bmb-ast">*</span></label>
            <input class="bmb-inp bmb-inp--big" id="bmb-headline" type="text"
                   placeholder="e.g. 25 Years of Priya" maxlength="50">
            <span class="bmb-cnt"><span id="bmb-hl-n">0</span>/50</span>
          </div>

          <div class="bmb-f bmb-f--full">
            <label class="bmb-lbl" for="bmb-ded">Dedication Message</label>
            <textarea class="bmb-ta" id="bmb-ded" rows="4"
                      placeholder="A heartfelt message for the opening page…" maxlength="400"></textarea>
            <span class="bmb-cnt"><span id="bmb-ded-n">0</span>/400</span>
          </div>

          <div class="bmb-f bmb-f--full">
            <label class="bmb-lbl" for="bmb-quote">Special Quote <span class="bmb-opt">(optional)</span></label>
            <input class="bmb-inp" id="bmb-quote" type="text"
                   placeholder='"Happiness is homemade"' maxlength="120">
          </div>
        </div>
      </div>

      <!-- ╔══════════╗ -->
      <!-- ║  STEP 5  ║ -->
      <!-- ╚══════════╝ -->
      <div class="bmb-panel bmb-gone" id="bmb-panel-5" data-panel="5">
        <div class="bmb-panel-head">
          <div class="bmb-panel-emoji">🎉</div>
          <div>
            <h2 class="bmb-panel-title">Review & Order</h2>
            <p class="bmb-panel-sub">One last look before we start printing your memories.</p>
          </div>
        </div>

        <div class="bmb-review" id="bmb-review"><!-- filled by JS --></div>
        <div class="bmb-photo-chip" id="bmb-photo-chip"><!-- filled by JS --></div>

        <div class="bmb-f bmb-f--full bmb-email-row">
          <label class="bmb-lbl" for="bmb-email">Your Email <span class="bmb-ast">*</span></label>
          <input class="bmb-inp" id="bmb-email" type="email"
                 placeholder="your@email.com"
                 value="{{ customer.email | default: '' }}">
          <p class="bmb-email-note">📬 Order confirmation and updates will be sent here.</p>
        </div>

        <div class="bmb-photo-reminder">
          <span>📸</span>
          <p>After placing your order, email your photos + Order ID &amp; Name to <strong>print@quickbee.store</strong> — we'll respond within <strong>20 minutes</strong>.</p>
        </div>

        <button type="button" class="bmb-atc" id="bmb-atc">
          <span class="bmb-atc-idle">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            Place Order
          </span>
          <span class="bmb-atc-busy" hidden><span class="bmb-spin"></span> Processing…</span>
          <span class="bmb-atc-ok"   hidden>✓ Done! Redirecting to cart…</span>
        </button>
        <div class="bmb-err" id="bmb-err" hidden></div>
      </div>

      <!-- NAVIGATION -->
      <div class="bmb-nav">
        <button type="button" class="bmb-btn-back" id="bmb-back" hidden>← Back</button>
        <button type="button" class="bmb-btn-next" id="bmb-next">Continue →</button>
      </div>
    </div>

  </div><!-- /bmb-body -->
</div><!-- /bmb -->

<!-- ════════════════════════════════════════════════════ -->
<!--                       STYLES                        -->
<!-- ════════════════════════════════════════════════════ -->
<style>
/* ── Design Tokens ── */
.bmb {
  --bmb-gold: #F4B400;
  --bmb-gold-dim: rgba(244,180,0,.18);
  --bmb-bg: #fff;
  --bmb-bg2: #f6f7f9;
  --bmb-bg3: #eef0f3;
  --bmb-text: #111;
  --bmb-text2: #555;
  --bmb-text3: #888;
  --bmb-border: rgba(0,0,0,.10);
  --bmb-radius: 16px;
  --bmb-radius-sm: 10px;
  --bmb-shadow: 0 4px 24px rgba(0,0,0,.08);
  --bmb-shadow-card: 0 2px 12px rgba(0,0,0,.06);
  --bmb-inp-bg: #f5f6f8;
  --bmb-inp-border: rgba(0,0,0,.12);
}
[data-theme="dark"] .bmb {
  --bmb-bg: #111;
  --bmb-bg2: #1a1a1a;
  --bmb-bg3: #232323;
  --bmb-text: #f0f0f0;
  --bmb-text2: #aaa;
  --bmb-text3: #666;
  --bmb-border: rgba(255,255,255,.08);
  --bmb-shadow: 0 4px 24px rgba(0,0,0,.4);
  --bmb-shadow-card: 0 2px 12px rgba(0,0,0,.3);
  --bmb-inp-bg: #1e1e1e;
  --bmb-inp-border: rgba(255,255,255,.10);
}

/* ── Wrapper ── */
.bmb {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 0 80px;
  color: var(--bmb-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* ── Hero ── */
.bmb-hero {
  text-align: center;
  padding: 56px 24px 40px;
}
.bmb-hero-chip {
  display: inline-block;
  background: var(--bmb-gold-dim);
  color: var(--bmb-gold);
  border: 1.5px solid var(--bmb-gold-dim);
  border-radius: 999px;
  padding: 6px 16px;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: .04em;
  margin-bottom: 16px;
}
.bmb-hero-h1 {
  font-size: clamp(26px, 5vw, 44px);
  font-weight: 800;
  line-height: 1.15;
  margin: 0 0 12px;
  color: var(--bmb-text);
}
.bmb-gold { color: var(--bmb-gold); }
.bmb-hero-p {
  font-size: 16px;
  color: var(--bmb-text2);
  max-width: 560px;
  margin: 0 auto;
  line-height: 1.6;
}

/* ── Progress ── */
.bmb-prog-wrap {
  position: relative;
  padding: 0 24px 40px;
  max-width: 680px;
  margin: 0 auto;
}
.bmb-prog-rail {
  position: absolute;
  top: 20px;
  left: calc(24px + 10%);
  right: calc(24px + 10%);
  height: 3px;
  background: var(--bmb-bg3);
  border-radius: 2px;
  z-index: 0;
}
.bmb-prog-fill {
  height: 100%;
  background: var(--bmb-gold);
  border-radius: 2px;
  transition: width .4s ease;
  width: 0%;
}
.bmb-prog-steps {
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}
.bmb-prog-dot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  cursor: default;
}
.bmb-prog-circle {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--bmb-bg3);
  border: 2.5px solid var(--bmb-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 14px;
  color: var(--bmb-text3);
  transition: all .3s ease;
  position: relative;
}
.bmb-prog-ck { display: none; }
.bmb-prog-dot.active .bmb-prog-circle {
  background: var(--bmb-gold);
  border-color: var(--bmb-gold);
  color: #000;
  box-shadow: 0 0 0 5px rgba(244,180,0,.18);
}
.bmb-prog-dot.done .bmb-prog-circle {
  background: var(--bmb-gold);
  border-color: var(--bmb-gold);
  color: #000;
}
.bmb-prog-dot.done .bmb-prog-n { display: none; }
.bmb-prog-dot.done .bmb-prog-ck { display: block; }
.bmb-prog-lbl {
  font-size: 12px;
  font-weight: 600;
  color: var(--bmb-text3);
  letter-spacing: .02em;
}
.bmb-prog-dot.active .bmb-prog-lbl,
.bmb-prog-dot.done .bmb-prog-lbl { color: var(--bmb-text); }

/* ── Body Layout ── */
.bmb-body {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  padding: 0 24px;
  align-items: start;
  max-width: 700px;
  margin: 0 auto;
}

/* ── Photo Instruction ── */
.bmb-photo-instruction {
  background: var(--bmb-bg2);
  border: 2px dashed var(--bmb-gold-dim);
  border-radius: var(--bmb-radius);
  padding: 32px 28px;
  text-align: center;
}
.bmb-photo-instr-icon { font-size: 48px; margin-bottom: 12px; }
.bmb-photo-instr-title {
  font-size: 20px;
  font-weight: 800;
  color: var(--bmb-text);
  margin: 0 0 12px;
}
.bmb-photo-instr-text {
  font-size: 15px;
  color: var(--bmb-text2);
  line-height: 1.7;
  margin: 0 0 24px;
}
.bmb-photo-instr-steps {
  display: flex;
  flex-direction: column;
  gap: 10px;
  text-align: left;
  max-width: 360px;
  margin: 0 auto;
}
.bmb-photo-instr-step {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 14px;
  color: var(--bmb-text);
}
.bmb-photo-instr-num {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--bmb-gold);
  color: #000;
  font-size: 13px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── Panel ── */
.bmb-panel {
  background: var(--bmb-bg);
  border: 1.5px solid var(--bmb-border);
  border-radius: var(--bmb-radius);
  padding: 32px;
  box-shadow: var(--bmb-shadow-card);
  margin-bottom: 0;
}
.bmb-gone { display: none !important; }
.bmb-panel-head {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  margin-bottom: 28px;
}
.bmb-panel-emoji {
  font-size: 36px;
  line-height: 1;
  flex-shrink: 0;
}
.bmb-panel-title {
  font-size: 22px;
  font-weight: 800;
  margin: 0 0 4px;
  color: var(--bmb-text);
}
.bmb-panel-sub {
  font-size: 14px;
  color: var(--bmb-text2);
  margin: 0;
  line-height: 1.5;
}

/* ── Field Grid ── */
.bmb-fg {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
.bmb-f { display: flex; flex-direction: column; gap: 6px; position: relative; }
.bmb-f--full { grid-column: 1 / -1; }
.bmb-lbl {
  font-size: 13px;
  font-weight: 600;
  color: var(--bmb-text);
  letter-spacing: .01em;
}
.bmb-ast { color: var(--bmb-gold); }
.bmb-opt { color: var(--bmb-text3); font-weight: 400; }
@media (max-width: 520px) {
  .bmb-fg { grid-template-columns: 1fr; }
}

/* ── Inputs ── */
.bmb-inp {
  height: 48px;
  padding: 0 14px;
  background: var(--bmb-inp-bg);
  border: 1.5px solid var(--bmb-inp-border);
  border-radius: var(--bmb-radius-sm);
  font-size: 15px;
  color: var(--bmb-text);
  -webkit-text-fill-color: var(--bmb-text);
  caret-color: var(--bmb-gold);
  outline: none;
