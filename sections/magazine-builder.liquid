<!--                    JAVASCRIPT                       -->
<!-- ════════════════════════════════════════════════════ -->
<script>
(function(){
'use strict';

// ── State ──────────────────────────────────────────────
var state = {
  step: 1,
  recipient: '',
  occasion: 'Birthday',
  date: '',
  from: '',
  photos: [],       // {id, dataUrl, thumbUrl, name, size}
  variantId: null,
  variantTitle: '',
  variantPrice: '',
  coverStyle: 'Modern',
  coverColor: '#1a1a2e',
  paper: 'Glossy',
  orientation: 'Portrait',
  headline: '',
  dedication: '',
  quote: '',
  email: ''
};

var MAX_PHOTOS = parseInt(document.getElementById('bmb-root').dataset.maxPhotos) || 20;
var PRINT_EMAIL = document.getElementById('bmb-root').dataset.printEmail || 'print@quickbee.store';

// ── DOM refs ───────────────────────────────────────────
function $id(id){ return document.getElementById(id); }

// ── INIT ───────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function(){
  init();
});
// Also call directly in case DOM already loaded
if(document.readyState !== 'loading'){ init(); }

function init(){
  var root = $id('bmb-root');
  if(!root || root.dataset.bmbInit){ return; }
  root.dataset.bmbInit = '1';

  // Set max labels
  var maxLabel = $id('bmb-max-label');
  var maxLabelN = $id('bmb-photo-max-n');
  if(maxLabel) maxLabel.textContent = MAX_PHOTOS;
  if(maxLabelN) maxLabelN.textContent = MAX_PHOTOS;

  // Default variantId from first package
  var firstPkg = root.querySelector('.bmb-pkg');
  if(firstPkg){
    state.variantId = firstPkg.dataset.vid;
    state.variantTitle = firstPkg.querySelector('.bmb-pkg-name') ? firstPkg.querySelector('.bmb-pkg-name').textContent.trim() : '';
    state.variantPrice = firstPkg.dataset.price;
  }

  bindStep1();
  bindStep2();
  bindStep3();
  bindStep4();
  bindStep5();
  bindNav();
  updateProgress();
  updatePreview();
}

// ── Step 1 bindings ────────────────────────────────────
function bindStep1(){
  var rec = $id('bmb-recipient');
  var frm = $id('bmb-from');
  var dte = $id('bmb-date');
  if(rec) rec.addEventListener('input', function(){ state.recipient = rec.value.trim(); updatePreview(); });
  if(frm) frm.addEventListener('input', function(){ state.from = frm.value.trim(); });
  if(dte) dte.addEventListener('change', function(){ state.date = dte.value; updatePreview(); });

  // Occasion buttons
  var occBtns = document.querySelectorAll('.bmb-occ');
  occBtns.forEach(function(btn){
    btn.addEventListener('click', function(){
      occBtns.forEach(function(b){ b.classList.remove('bmb-occ--on'); });
      btn.classList.add('bmb-occ--on');
      state.occasion = btn.dataset.occ;
      var hid = $id('bmb-occasion');
      if(hid) hid.value = state.occasion;
    });
  });
}

// ── Step 2 bindings ────────────────────────────────────
function bindStep2(){
  var drop = $id('bmb-drop');
  var input = $id('bmb-file-input');
  var clearBtn = $id('bmb-clear');

  if(!drop || !input) return;

  drop.addEventListener('dragover', function(e){
    e.preventDefault();
    drop.classList.add('drag-over');
  });
  drop.addEventListener('dragleave', function(){
    drop.classList.remove('drag-over');
  });
  drop.addEventListener('drop', function(e){
    e.preventDefault();
    drop.classList.remove('drag-over');
    handleFiles(e.dataTransfer.files);
  });

  input.addEventListener('change', function(){
    handleFiles(input.files);
    input.value = '';
  });

  if(clearBtn){
    clearBtn.addEventListener('click', function(){
      state.photos = [];
      renderPhotoGrid();
      updatePreview();
    });
  }
}

function handleFiles(files){
  var arr = Array.from(files);
  arr.forEach(function(file){
    if(!file.type.startsWith('image/')) return;
    if(state.photos.length >= MAX_PHOTOS) return;
    compressImage(file, 900, 0.75, function(dataUrl, thumbUrl){
      var id = 'ph_' + Date.now() + '_' + Math.random().toString(36).slice(2,7);
      state.photos.push({ id: id, dataUrl: dataUrl, thumbUrl: thumbUrl, name: file.name, size: file.size });
      renderPhotoGrid();
      updatePreview();
    });
  });
}

function compressImage(file, maxSize, quality, cb){
  var reader = new FileReader();
  reader.onload = function(e){
    var img = new Image();
    img.onload = function(){
      // Full size (max 900px)
      var canvas = document.createElement('canvas');
      var w = img.width, h = img.height;
      if(w > maxSize || h > maxSize){
        var ratio = Math.min(maxSize/w, maxSize/h);
        w = Math.round(w*ratio); h = Math.round(h*ratio);
      }
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(img, 0, 0, w, h);
      var dataUrl = canvas.toDataURL('image/jpeg', quality);
      // Thumbnail (120px)
      var tc = document.createElement('canvas');
      var ts = 120;
      tc.width = ts; tc.height = ts;
      var cx = tc.getContext('2d');
      var scale = Math.max(ts/w, ts/h);
      var dw = w*scale, dh = h*scale;
      cx.drawImage(img, (ts-dw)/2, (ts-dh)/2, dw, dh);
      var thumbUrl = tc.toDataURL('image/jpeg', 0.6);
      cb(dataUrl, thumbUrl);
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function renderPhotoGrid(){
  var grid = $id('bmb-photo-grid');
  var nEl = $id('bmb-photo-n');
  var clearBtn = $id('bmb-clear');
  if(!grid) return;
  if(nEl) nEl.textContent = state.photos.length;
  if(clearBtn) clearBtn.hidden = state.photos.length === 0;
  grid.innerHTML = '';
  state.photos.forEach(function(ph, idx){
    var div = document.createElement('div');
    div.className = 'bmb-thumb' + (idx === 0 ? ' bmb-thumb--cover' : '');
    var img = document.createElement('img');
    img.src = ph.thumbUrl;
    img.alt = ph.name;
    var del = document.createElement('button');
    del.type = 'button';
    del.className = 'bmb-thumb-del';
    del.textContent = '×';
    del.setAttribute('aria-label', 'Remove photo');
    del.addEventListener('click', function(e){
      e.stopPropagation();
      state.photos = state.photos.filter(function(p){ return p.id !== ph.id; });
      renderPhotoGrid();
      updatePreview();
    });
    div.appendChild(img);
    div.appendChild(del);
    grid.appendChild(div);
  });
  // Update preview stats
  var pvPhotos = $id('bmb-pv-photos');
  if(pvPhotos) pvPhotos.textContent = state.photos.length + ' added';
}

// ── Step 3 bindings ────────────────────────────────────
function bindStep3(){
  // Package selection
  var pkgs = document.querySelectorAll('.bmb-pkg');
  pkgs.forEach(function(pkg){
    pkg.addEventListener('click', function(){
      pkgs.forEach(function(p){ p.classList.remove('bmb-pkg--on'); });
      pkg.classList.add('bmb-pkg--on');
      var radio = pkg.querySelector('input[type="radio"]');
      if(radio) radio.checked = true;
      state.variantId = pkg.dataset.vid;
      state.variantTitle = pkg.querySelector('.bmb-pkg-name') ? pkg.querySelector('.bmb-pkg-name').textContent.trim() : '';
      state.variantPrice = pkg.dataset.price;
      var pvPkg = $id('bmb-pv-pkg');
      if(pvPkg) pvPkg.textContent = state.variantTitle;
      var pvPrice = $id('bmb-pv-price');
      if(pvPrice) pvPrice.textContent = formatMoney(state.variantPrice);
    });
  });

  // Cover styles
  var csbtns = document.querySelectorAll('.bmb-cs');
  csbtns.forEach(function(btn){
    btn.addEventListener('click', function(){
      csbtns.forEach(function(b){ b.classList.remove('bmb-cs--on'); });
      btn.classList.add('bmb-cs--on');
      state.coverStyle = btn.dataset.cs;
      state.coverColor = btn.dataset.cc;
      var csv = $id('bmb-cs-val');
      var ccv = $id('bmb-cc-val');
      if(csv) csv.value = state.coverStyle;
      if(ccv) ccv.value = state.coverColor;
      var pvStyle = $id('bmb-pv-style');
      if(pvStyle) pvStyle.textContent = state.coverStyle;
      applyMagCoverColor(state.coverColor);
    });
  });

  // Pill groups
  var pillGroups = document.querySelectorAll('.bmb-pills');
  pillGroups.forEach(function(grp){
    var pills = grp.querySelectorAll('.bmb-pill');
    var targetId = grp.dataset.target;
    pills.forEach(function(pill){
      pill.addEventListener('click', function(){
        pills.forEach(function(p){ p.classList.remove('bmb-pill--on'); });
        pill.classList.add('bmb-pill--on');
        var hid = $id(targetId);
        if(hid) hid.value = pill.dataset.v;
        if(targetId === 'bmb-paper') state.paper = pill.dataset.v;
        if(targetId === 'bmb-orientation') state.orientation = pill.dataset.v;
      });
    });
  });
}

function formatMoney(val){
  if(!val) return '';
  // val could be like "1500" or already formatted
  var num = parseFloat(String(val).replace(/[^0-9.]/g, ''));
  if(isNaN(num)) return val;
  return 'Rs. ' + num.toLocaleString('en-IN');
}

function applyMagCoverColor(color){
  var front = $id('bmb-mag-front');
  var spine = $id('bmb-mag-spine');
  if(front) front.style.background = color;
  if(spine){
    spine.style.background = 'linear-gradient(to right, rgba(0,0,0,.6), ' + color + ')';
  }
}

// ── Step 4 bindings ────────────────────────────────────
function bindStep4(){
  var hl = $id('bmb-headline');
  var ded = $id('bmb-ded');
  var qt = $id('bmb-quote');
  var hlN = $id('bmb-hl-n');
  var dedN = $id('bmb-ded-n');

  if(hl){
    hl.addEventListener('input', function(){
      state.headline = hl.value;
      if(hlN) hlN.textContent = hl.value.length;
      var magHl = $id('bmb-mag-hl');
      if(magHl) magHl.textContent = hl.value || 'Your Title Here';
    });
  }
  if(ded){
    ded.addEventListener('input', function(){
      state.dedication = ded.value;
      if(dedN) dedN.textContent = ded.value.length;
    });
  }
  if(qt){
    qt.addEventListener('input', function(){
      state.quote = qt.value;
    });
  }
}

// ── Step 5 bindings ────────────────────────────────────
function bindStep5(){
  var emailInput = $id('bmb-email');
  if(emailInput){
    emailInput.addEventListener('input', function(){
      state.email = emailInput.value.trim();
    });
    // Pre-fill
    state.email = emailInput.value.trim();
  }

  var atcBtn = $id('bmb-atc');
  if(atcBtn){
    atcBtn.addEventListener('click', handleOrder);
  }
}

// ── Navigation ─────────────────────────────────────────
function bindNav(){
  var nextBtn = $id('bmb-next');
  var backBtn = $id('bmb-back');
  if(nextBtn) nextBtn.addEventListener('click', goNext);
  if(backBtn) backBtn.addEventListener('click', goBack);
}

function goNext(){
  if(!validateStep(state.step)) return;
  if(state.step < 5){
    setStep(state.step + 1);
  }
}
function goBack(){
  if(state.step > 1) setStep(state.step - 1);
}

function setStep(n){
  var old = state.step;
  state.step = n;

  var oldPanel = $id('bmb-panel-' + old);
  var newPanel = $id('bmb-panel-' + n);
  if(oldPanel) oldPanel.classList.add('bmb-gone');
  if(newPanel) newPanel.classList.remove('bmb-gone');

  // Nav buttons
  var backBtn = $id('bmb-back');
  var nextBtn = $id('bmb-next');
  if(backBtn) backBtn.hidden = n === 1;
  if(nextBtn) nextBtn.hidden = n === 5;

  // Dots
  updateProgress();

  // Step 5 populate
  if(n === 5) populateReview();

  // Scroll to top of form
  var formSide = document.querySelector('.bmb-form-side');
  if(formSide){ formSide.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
}

function validateStep(n){
  var err = $id('bmb-err');
  function showErr(msg){
    if(err){ err.textContent = msg; err.hidden = false; }
    setTimeout(function(){ if(err) err.hidden = true; }, 4000);
  }
  if(n === 1){
    var rec = $id('bmb-recipient');
    var frm = $id('bmb-from');
    if(!rec || !rec.value.trim()){ showErr('Please enter the recipient\'s name.'); rec && rec.focus(); return false; }
    if(!frm || !frm.value.trim()){ showErr('Please enter your name (From).'); frm && frm.focus(); return false; }
    state.recipient = rec.value.trim();
    state.from = frm.value.trim();
  }
  if(n === 2){
    // Step 2 is photo instruction — always valid, customer emails photos after order
    return true;
  }
  if(n === 4){
    var hl = $id('bmb-headline');
    if(!hl || !hl.value.trim()){ showErr('Please enter a magazine headline.'); hl && hl.focus(); return false; }
    state.headline = hl.value.trim();
  }
  return true;
}

function updateProgress(){
  var fill = $id('bmb-prog-fill');
  var pct = ((state.step - 1) / 4) * 100;
  if(fill) fill.style.width = pct + '%';

  var dots = document.querySelectorAll('.bmb-prog-dot');
  dots.forEach(function(dot){
    var ds = parseInt(dot.dataset.step);
    dot.classList.remove('active', 'done');
    if(ds === state.step) dot.classList.add('active');
    else if(ds < state.step) dot.classList.add('done');
  });
}

// ── Review ─────────────────────────────────────────────
function populateReview(){
  var card = $id('bmb-review');
  var chip = $id('bmb-photo-chip');
  if(!card) return;

  var dateStr = state.date ? new Date(state.date + 'T00:00:00').toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' }) : '—';

  var rows = [
    { k: 'Recipient', v: state.recipient || '—' },
    { k: 'Occasion',  v: state.occasion },
    { k: 'From',      v: state.from || '—' },
    { k: 'Date',      v: dateStr },
    { k: 'Package',   v: state.variantTitle || '—' },
    { k: 'Cover Style', v: state.coverStyle },
    { k: 'Paper',     v: state.paper },
    { k: 'Headline',  v: state.headline || '—' },
  ];

  card.innerHTML = rows.map(function(r){
    return '<div class="bmb-review-row"><span class="bmb-review-k">' + escHtml(r.k) +
      '</span><span class="bmb-review-v">' + escHtml(r.v) + '</span></div>';
  }).join('');

  if(chip){
    chip.innerHTML = '📷 <strong>' + state.photos.length + ' photo' + (state.photos.length !== 1 ? 's' : '') +
      '</strong> will be sent to our print team at ' + escHtml(PRINT_EMAIL);
  }
}

// ── Live Preview ───────────────────────────────────────
function updatePreview(){
  // Cover photo
  var img = $id('bmb-mag-img');
  var ph  = $id('bmb-mag-ph');
  if(state.photos.length > 0){
    if(img){ img.src = state.photos[0].thumbUrl; img.hidden = false; }
    if(ph)  ph.style.display = 'none';
  } else {
    if(img) img.hidden = true;
    if(ph)  ph.style.display = '';
  }

  // Text
  var magHl = $id('bmb-mag-hl');
  var magWho = $id('bmb-mag-who');
  var magWhen = $id('bmb-mag-when');
  if(magHl)  magHl.textContent = state.headline || 'Your Title Here';
  if(magWho) magWho.textContent = state.recipient ? 'For ' + state.recipient : 'For Someone Special';
  if(magWhen && state.date){
    magWhen.textContent = new Date(state.date+'T00:00:00').toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
  }

  // Stats
  var pvPkg = $id('bmb-pv-pkg');
  var pvPhotos = $id('bmb-pv-photos');
  var pvStyle = $id('bmb-pv-style');
  if(pvPkg) pvPkg.textContent = state.variantTitle || '—';
  if(pvPhotos) pvPhotos.textContent = state.photos.length + ' added';
  if(pvStyle) pvStyle.textContent = state.coverStyle;
}

// ── Order Handling ─────────────────────────────────────
async function handleOrder(){
  var emailInput = $id('bmb-email');
  state.email = emailInput ? emailInput.value.trim() : '';

  if(!state.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(state.email)){
    showError('Please enter a valid email address.');
    if(emailInput) emailInput.focus();
    return;
  }

  setAtcState('busy');

  try {
    // 1. Build order note
    var note = buildOrderNote();

    // 2. Build line item properties
    var props = buildProperties();

    // 3. Add to cart
    await addToCart(props);

    // 4. Update cart note
    await updateCartNote(note);

    // 5. Success — customer emails photos manually after order
    setAtcState('ok');
    setTimeout(function(){ window.location.href = '/cart'; }, 1800);

  } catch(err){
    setAtcState('idle');
    showError('Something went wrong: ' + (err.message || 'Please try again.'));
    console.error(err);
  }
}

function buildOrderNote(){
  var lines = [
    '=== BIRTHDAY MAGAZINE ORDER ===',
    'Recipient: ' + state.recipient,
    'Occasion: ' + state.occasion,
    'From: ' + state.from,
    state.date ? 'Date: ' + state.date : '',
    'Package: ' + state.variantTitle,
    'Cover Style: ' + state.coverStyle,
    'Paper Finish: ' + state.paper,
    'Orientation: ' + state.orientation,
    'Headline: ' + state.headline,
    state.dedication ? 'Dedication: ' + state.dedication : '',
    state.quote ? 'Quote: ' + state.quote : '',
    'Customer Email: ' + state.email,
    '=== PHOTOS: Customer will email to ' + PRINT_EMAIL + ' with Order ID & Name ==='
  ].filter(Boolean);
  return lines.join('\n');
}

function buildProperties(){
  var props = {
    'Recipient': state.recipient,
    'Occasion': state.occasion,
    'From': state.from,
    'Cover Style': state.coverStyle,
    'Paper': state.paper,
    'Orientation': state.orientation,
    'Headline': state.headline,
    'Photos Uploaded': state.photos.length + ' photo(s)',
    'Customer Email': state.email
  };
  if(state.date) props['Occasion Date'] = state.date;
  if(state.dedication) props['Dedication'] = state.dedication.slice(0,250);
  if(state.quote) props['Quote'] = state.quote;
  return props;
}

async function addToCart(properties){
  var vid = state.variantId;
  if(!vid){
    var root = $id('bmb-root');
    vid = root ? root.dataset.variantId : null;
  }
  if(!vid) throw new Error('No product variant selected.');

  var resp = await fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
    body: JSON.stringify({ id: parseInt(vid), quantity: 1, properties: properties })
  });
  if(!resp.ok){
    var text = await resp.text();
    throw new Error('Cart error: ' + text);
  }
  return resp.json();
}

async function updateCartNote(note){
  var resp = await fetch('/cart/update.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
    body: JSON.stringify({ note: note })
  });
  if(!resp.ok) console.warn('Note update failed');
}

async function sendPhotosEmail(){
  var root = $id('bmb-root');
  var serviceId = root ? root.dataset.serviceId : '';
  var templateId = root ? root.dataset.templateId : '';

  if(!serviceId || !templateId){
    console.info('EmailJS not configured — skipping photo email.');
    return;
  }
  if(typeof emailjs === 'undefined'){
    console.warn('EmailJS not loaded');
    return;
  }

  // Build template params
  var params = {
    to_email: PRINT_EMAIL,
    customer_email: state.email,
    recipient_name: state.recipient,
    occasion: state.occasion,
    from_name: state.from,
    headline: state.headline,
    package: state.variantTitle,
    cover_style: state.coverStyle,
    paper: state.paper,
    orientation: state.orientation,
    dedication: state.dedication || '—',
    quote: state.quote || '—',
    photo_count: state.photos.length,
    occasion_date: state.date || '—',
    order_note: buildOrderNote()
  };

  // Attach up to 10 compressed thumbnails as inline params
  state.photos.slice(0, 10).forEach(function(ph, idx){
    params['photo_' + (idx + 1)] = ph.thumbUrl;
    params['photo_name_' + (idx + 1)] = ph.name;
  });

  return emailjs.send(serviceId, templateId, params);
}

// ── UI helpers ─────────────────────────────────────────
function setAtcState(st){
  var btn = $id('bmb-atc');
  if(!btn) return;
  var idle = btn.querySelector('.bmb-atc-idle');
  var busy = btn.querySelector('.bmb-atc-busy');
  var ok   = btn.querySelector('.bmb-atc-ok');
  if(idle) idle.hidden = st !== 'idle';
  if(busy) busy.hidden = st !== 'busy';
  if(ok)   ok.hidden   = st !== 'ok';
  btn.disabled = st !== 'idle';
}

function showError(msg){
  var err = $id('bmb-err');
  if(err){ err.textContent = msg; err.hidden = false; }
  setTimeout(function(){ if(err) err.hidden = true; }, 6000);
}

function escHtml(s){
  return String(s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
}

})();
</script>

