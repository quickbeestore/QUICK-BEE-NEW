<script>
(function () {
  /* ─── Variant selection ─────────────────────────────────────── */
  window.qbCmbSelectVariant = function (btn, sid) {
    var container = document.getElementById('qb-cmb-variants-' + sid);
    if (container) {
      container.querySelectorAll('.qb-cmb__variant-pill').forEach(function (p) {
        p.classList.remove('is-active');
      });
    }
    btn.classList.add('is-active');

    var priceEl = document.getElementById('qb-cmb-price-' + sid);
    if (priceEl) priceEl.textContent = btn.dataset.variantPrice;

    var atcBtn = document.getElementById('qb-cmb-atc-' + sid);
    if (atcBtn) atcBtn.dataset.firstVariant = btn.dataset.variantId;
  };

  /* ─── Quantity stepper ──────────────────────────────────────── */
  window.qbCmbQty = function (sid, delta) {
    var el = document.getElementById('qb-cmb-qty-' + sid);
    if (!el) return;
    var current = parseInt(el.textContent, 10) || 1;
    var next = Math.min(Math.max(current + delta, 1), 10);
    el.textContent = next;
  };

  /* ─── Add to cart ───────────────────────────────────────────── */
  window.qbCmbAddToCart = function (sid) {
    var btn     = document.getElementById('qb-cmb-atc-' + sid);
    var msgEl   = document.getElementById('qb-cmb-msg-' + sid);
    var qtyEl   = document.getElementById('qb-cmb-qty-' + sid);
    if (!btn) return;

    var variantId = parseInt(btn.dataset.firstVariant, 10);
    var qty       = parseInt(qtyEl ? qtyEl.textContent : '1', 10) || 1;
    var title     = btn.dataset.productTitle || '';
    var serves    = btn.dataset.serves || '2';
    var prepTime  = btn.dataset.preptime || '20 mins';

    if (!variantId) {
      qbCmbShowMsg(msgEl, 'Please select a size.', 'error');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        id: variantId,
        quantity: qty,
        properties: {
          'Meal Kit': title,
          'Serves': serves + ' people',
          'Prep Time': prepTime
        }
      })
    })
    .then(function (res) {
      if (!res.ok) return res.json().then(function (d) { throw new Error(d.description || 'Error'); });
      return res.json();
    })
    .then(function () {
      btn.textContent = '✓ Added to Cart!';
      qbCmbShowMsg(msgEl, '🎉 Meal kit added! Check your cart.', 'success');
      setTimeout(function () {
        btn.disabled = false;
        btn.textContent = '🛒 Add to Cart';
        qbCmbShowMsg(msgEl, '', '');
      }, 3000);
    })
    .catch(function (err) {
      btn.disabled = false;
      btn.textContent = '🛒 Add to Cart';
      qbCmbShowMsg(msgEl, err.message || 'Could not add to cart. Try again.', 'error');
    });
  };

  function qbCmbShowMsg(el, text, type) {
    if (!el) return;
    el.textContent = text;
    el.className = 'qb-cmb__atc-msg' + (type ? ' qb-cmb__atc-msg--' + type : '');
  }
})();
</script>

