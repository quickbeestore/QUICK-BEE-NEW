{% schema %}
{
  "name": "Trust Section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Why Choose QuickBee?"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F5F5F5"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "text",
          "id": "trust_icon",
          "label": "Icon/Emoji",
          "default": "⚡"
        },
        {
          "type": "text",
          "id": "trust_title",
          "label": "Title",
          "default": "~20 Min Delivery"
        },
        {
          "type": "text",
          "id": "trust_desc",
          "label": "Description",
          "default": "Lightning-fast across Kathmandu Valley"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Section",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "trust_icon": "⚡",
            "trust_title": "~20 Min Delivery",
            "trust_desc": "Lightning-fast across Kathmandu Valley"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "trust_icon": "📦",
            "trust_title": "20,000+ Products",
            "trust_desc": "Everything from food to electronics"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "trust_icon": "🔒",
            "trust_title": "Secure Checkout",
            "trust_desc": "Safe & encrypted transactions"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "trust_icon": "🌍",
            "trust_title": "City Convenience",
            "trust_desc": "Local, fast, and reliable service"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
.qb-trust-section {
  padding: 40px 16px;
  background: var(--bg-color);
}
@media(min-width:1024px) {
  .qb-trust-section {
    padding: 60px 48px;
  }
}
.qb-trust-section h2 {
  font-size: 24px;
  font-weight: 900;
  margin: 0 0 32px 0;
  color: #111111;
}
@media(min-width:1024px) {
  .qb-trust-section h2 {
    font-size: 32px;
  }
}
.qb-trust-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}
@media(min-width:768px) {
  .qb-trust-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
.qb-trust-item {
  text-align: center;
}
.qb-trust-icon {
  font-size: 40px;
  margin-bottom: 12px;
  display: block;
}
.qb-trust-title {
  font-size: 14px;
  font-weight: 700;
  color: #111111;
  margin-bottom: 4px;
}
.qb-trust-desc {
  font-size: 12px;
  color: #666;
}
</style>

<!-- Trust Section -->
<section class="qb-trust-section" style="--bg-color: {{ section.settings.bg_color }};">
  <h2>{{ section.settings.section_title }}</h2>

  <div class="qb-trust-grid">
    {% for block in section.blocks %}
      {% if block.type == 'trust_item' %}
        <div class="qb-trust-item" {{ block.shopify_attributes }}>
          <span class="qb-trust-icon">{{ block.settings.trust_icon }}</span>
          <div class="qb-trust-title">{{ block.settings.trust_title }}</div>
          <div class="qb-trust-desc">{{ block.settings.trust_desc }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
