{% comment %} QuickBee Payment Page — sections/quickbee-payment.liquid {% endcomment %}

<style>
/* ============================================================
   QUICKBEE PAYMENT PAGE
   CashApp-styled · Dark/Light sync · Smooth animations
   ============================================================ */

.qbp-page {
  min-height: 100svh;
  background: var(--theme-bg-primary, #0f0f0f);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 72px 16px 120px;
  font-family: inherit;
}
.qbp-wrap {
  width: 100%;
  max-width: 460px;
  position: relative;
}

/* ── Steps ─────────────────────────────────────────── */
.qbp-step { animation: qbpFadeUp 0.38s cubic-bezier(0.25,0.46,0.45,0.94) forwards; }
.qbp-step.hidden { display: none !important; }

@keyframes qbpFadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0);    }
}
@keyframes qbpSpin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
@keyframes qbpSlideUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0);    }
}
@keyframes qbpPop {
  0%   { transform: scale(0.3); opacity: 0; }
  70%  { transform: scale(1.1); }
  100% { transform: scale(1);   opacity: 1; }
}
@keyframes qbpRingDraw {
  to { stroke-dashoffset: 0; }
}
@keyframes qbpTickDraw {
  to { stroke-dashoffset: 60; }
}
@keyframes qbpDotPulse {
  0%, 80%, 100% { transform: scale(0.55); opacity: 0.35; }
  40%           { transform: scale(1);    opacity: 1; }
}
@keyframes qbpShieldFloat {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-6px); }
}

/* ── Header ─────────────────────────────────────────── */
.qbp-header {
  text-align: center;
  padding: 28px 0 20px;
}
.qbp-logo {
  font-size: 42px;
  display: block;
  margin-bottom: 10px;
  animation: qbpPop 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards;
}
.qbp-header h1 {
  font-size: 24px;
  font-weight: 800;
  color: var(--theme-text-main, #f0f0f0);
  margin: 0 0 6px;
}
.qbp-header p {
  font-size: 13px;
  color: var(--theme-text-muted, #888);
  margin: 0;
}

/* ── Method Cards ───────────────────────────────────── */
.qbp-methods {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}
.qbp-method {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 15px 16px;
  background: var(--theme-bg-secondary, #1c1c1c);
  border: 2px solid var(--theme-border, #2e2e2e);
  border-radius: 16px;
  cursor: pointer;
  transition: border-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  position: relative;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
}
.qbp-method:active { transform: scale(0.98); }
.qbp-method.selected {
  border-color: #ffcc00;
  box-shadow: 0 0 0 3px rgba(255,204,0,0.12);
}
.qbp-method-icon {
  font-size: 26px;
  width: 46px;
  height: 46px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--theme-bg-primary, #111);
  border-radius: 13px;
  flex-shrink: 0;
  transition: background 0.2s;
}
.qbp-method.selected .qbp-method-icon {
  background: rgba(255,204,0,0.1);
}
.qbp-method-info { flex: 1; min-width: 0; }
.qbp-method-title {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: var(--theme-text-main, #f0f0f0);
  margin-bottom: 2px;
}
.qbp-method-sub {
  display: block;
  font-size: 11.5px;
  color: var(--theme-text-muted, #888);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.qbp-method-radio {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 2px solid var(--theme-border, #3a3a3a);
  flex-shrink: 0;
  transition: all 0.2s cubic-bezier(0.34,1.56,0.64,1);
  display: flex;
  align-items: center;
  justify-content: center;
}
.qbp-method.selected .qbp-method-radio {
  background: #ffcc00;
  border-color: #ffcc00;
}
.qbp-method.selected .qbp-method-radio::after {
  content: '';
  width: 7px;
  height: 11px;
  border: 2.5px solid #1a1a1a;
  border-top: none;
  border-left: none;
  transform: rotate(42deg) translateY(-1px);
  display: block;
}

/* ── Secure badge ───────────────────────────────────── */
.qbp-secure-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 11.5px;
  font-weight: 600;
  color: var(--theme-text-muted, #666);
  margin-bottom: 16px;
  letter-spacing: 0.3px;
}
.qbp-secure-badge::before,
.qbp-secure-badge::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--theme-border, #2a2a2a);
}

/* ── Buttons ────────────────────────────────────────── */
.qbp-btn {
  width: 100%;
  padding: 15px 20px;
  background: #ffcc00;
  color: #1a1a1a;
  border: none;
  border-radius: 14px;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.22s cubic-bezier(0.34,1.56,0.64,1);
  letter-spacing: 0.1px;
  display: block;
}
.qbp-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: none !important;
}
.qbp-btn:not(:disabled):hover {
  background: #ffd700;
  transform: translateY(-2px);
  box-shadow: 0 6px 22px rgba(255,204,0,0.38);
}
.qbp-btn:not(:disabled):active { transform: scale(0.97); }

.qbp-btn-ghost {
  width: 100%;
  padding: 13px 20px;
  background: transparent;
  color: var(--theme-text-muted, #888);
  border: 1.5px solid var(--theme-border, #2e2e2e);
  border-radius: 14px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  margin-top: 10px;
  display: block;
  transition: all 0.2s;
}
.qbp-btn-ghost:hover {
  border-color: #ffcc00;
  color: var(--theme-text-main, #f0f0f0);
}

/* ── Back button ────────────────────────────────────── */
.qbp-back {
  background: none;
  border: none;
  color: var(--theme-text-muted, #888);
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  padding: 0;
  margin-bottom: 22px;
  display: flex;
  align-items: center;
  gap: 5px;
  transition: color 0.2s;
}
.qbp-back:hover { color: var(--theme-text-main, #f0f0f0); }

/* ── Step titles ────────────────────────────────────── */
.qbp-step-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--theme-text-main, #f0f0f0);
  margin: 0 0 6px;
}
.qbp-step-sub {
  font-size: 13.5px;
  color: var(--theme-text-muted, #888);
  margin: 0 0 20px;
  line-height: 1.55;
}

/* ── QR image ───────────────────────────────────────── */
.qbp-qr-wrap {
  background: #fff;
  border-radius: 20px;
  padding: 14px;
  margin: 18px 0 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 32px rgba(0,0,0,0.22);
  animation: qbpFadeUp 0.4s ease 0.1s both;
}
.qbp-qr-img {
  width: 100%;
  max-width: 300px;
  height: auto;
  display: block;
  border-radius: 8px;
}

/* ── Inputs ─────────────────────────────────────────── */
.qbp-field {
  margin-bottom: 18px;
}
.qbp-label {
  display: block;
  font-size: 11.5px;
  font-weight: 700;
  color: var(--theme-text-muted, #888);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.6px;
}
.qbp-input {
  width: 100%;
  padding: 13px 16px;
  background: var(--theme-bg-secondary, #1c1c1c);
  border: 1.5px solid var(--theme-border, #2e2e2e);
  border-radius: 12px;
  color: var(--theme-text-main, #f0f0f0);
  font-size: 16px;
  font-weight: 600;
  transition: border-color 0.2s, box-shadow 0.2s;
  box-sizing: border-box;
  display: block;
}
.qbp-input::placeholder { color: var(--theme-text-muted, #555); font-weight: 400; }
.qbp-input:focus {
  outline: none;
  border-color: #ffcc00;
  box-shadow: 0 0 0 3px rgba(255,204,0,0.1);
}
.qbp-phone-row {
  display: flex;
  gap: 8px;
  align-items: stretch;
}
.qbp-phone-prefix {
  padding: 13px 14px;
  background: var(--theme-bg-secondary, #1c1c1c);
  border: 1.5px solid var(--theme-border, #2e2e2e);
  border-radius: 12px;
  color: var(--theme-text-main, #f0f0f0);
  font-size: 15px;
  font-weight: 700;
  white-space: nowrap;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}
.qbp-phone-row .qbp-input { flex: 1; }

/* ── Verify step ────────────────────────────────────── */
.qbp-verify-emoji {
  font-size: 50px;
  text-align: center;
  display: block;
  margin-bottom: 10px;
  animation: qbpPop 0.5s cubic-bezier(0.34,1.56,0.64,1);
}
.qbp-txn-box {
  background: var(--theme-bg-secondary, #1c1c1c);
  border: 2px solid #ffcc00;
  border-radius: 14px;
  padding: 18px 20px;
  font-size: 19px;
  font-weight: 800;
  color: #ffcc00;
  text-align: center;
  letter-spacing: 1.5px;
  margin: 16px 0 10px;
  word-break: break-all;
  animation: qbpFadeUp 0.3s ease 0.1s both;
}
.qbp-verify-note {
  font-size: 12.5px;
  color: var(--theme-text-muted, #777);
  text-align: center;
  margin: 0 0 24px;
  line-height: 1.5;
}

/* ── Success screen ─────────────────────────────────── */
#qbpStepSuccess {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 24px 0 48px;
  position: relative;
  overflow: hidden;
}
#qbpParticleCanvas {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}
.qbp-success-inner { position: relative; z-index: 1; width: 100%; }

/* Ripple rings behind checkmark */
.qbp-ripple-wrap {
  position: relative;
  width: 140px;
  height: 140px;
  margin: 0 auto 20px;
}
.qbp-ripple {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2px solid rgba(34,197,94,0.4);
  animation: qbpRipple 2.4s ease-out infinite;
}
.qbp-ripple:nth-child(2) { animation-delay: 0.6s; }
.qbp-ripple:nth-child(3) { animation-delay: 1.2s; }
@keyframes qbpRipple {
  0%   { transform: scale(0.6); opacity: 0.8; }
  100% { transform: scale(2.2); opacity: 0; }
}
.qbp-check-circle {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.qbp-svg {
  width: 140px;
  height: 140px;
  filter: drop-shadow(0 0 24px rgba(34,197,94,0.55));
}
.qbp-ring {
  fill: none;
  stroke: #22c55e;
  stroke-width: 3;
  stroke-dasharray: 364;
  stroke-dashoffset: 364;
  stroke-linecap: round;
  transform-origin: center;
  animation: qbpRingDraw 0.75s cubic-bezier(0.65,0,0.35,1) 0.2s forwards;
}
.qbp-tick {
  fill: none;
  stroke: #22c55e;
  stroke-width: 5;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: 68;
  stroke-dashoffset: -68;
  animation: qbpTickDraw 0.45s cubic-bezier(0.34,1.56,0.64,1) 0.88s forwards;
}
/* Circle fill pulse after tick */
.qbp-ring-fill {
  fill: rgba(34,197,94,0);
  stroke: none;
  transform-origin: center;
  animation: qbpFillPulse 0.5s ease 1.2s forwards;
}
@keyframes qbpFillPulse {
  0%   { fill: rgba(34,197,94,0); }
  50%  { fill: rgba(34,197,94,0.18); }
  100% { fill: rgba(34,197,94,0.08); }
}

/* Bee emoji that flies in */
.qbp-success-bee {
  font-size: 28px;
  display: block;
  margin: 0 0 4px;
  opacity: 0;
  animation: qbpBeeFly 0.7s cubic-bezier(0.34,1.56,0.64,1) 1.1s forwards;
}
@keyframes qbpBeeFly {
  0%   { opacity:0; transform: translateX(-40px) rotate(-20deg) scale(0.6); }
  70%  { transform: translateX(4px) rotate(5deg) scale(1.1); }
  100% { opacity:1; transform: translateX(0) rotate(0deg) scale(1); }
}

/* Amount — slot machine style */
.qbp-success-paid-label {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #22c55e;
  opacity: 0;
  margin-bottom: 4px;
  animation: qbpFadeIn2 0.3s ease 1.3s both;
}
.qbp-success-amount {
  font-size: 44px;
  font-weight: 900;
  color: #22c55e;
  letter-spacing: -2px;
  line-height: 1;
  margin: 0 0 20px;
  opacity: 0;
  animation: qbpCountUp 0.6s cubic-bezier(0.34,1.56,0.64,1) 1.4s forwards;
}
@keyframes qbpCountUp {
  0%   { opacity:0; transform: translateY(16px) scale(0.7); filter: blur(6px); }
  60%  { opacity:1; transform: translateY(-4px) scale(1.06); filter: blur(0); }
  100% { opacity:1; transform: translateY(0) scale(1); filter: blur(0); }
}
@keyframes qbpFadeIn2 {
  from { opacity:0; transform: translateY(6px); }
  to   { opacity:1; transform: translateY(0); }
}

/* Title */
.qbp-anim-title {
  font-size: 24px;
  font-weight: 900;
  color: var(--theme-text-main, #f0f0f0);
  margin: 0 0 6px;
  opacity: 0;
  animation: qbpSlideUp 0.4s ease 1.6s both;
  line-height: 1.2;
}
.qbp-anim-sub {
  font-size: 13.5px;
  color: var(--theme-text-muted, #888);
  margin: 0 0 24px;
  line-height: 1.6;
  max-width: 280px;
  opacity: 0;
  animation: qbpSlideUp 0.4s ease 1.75s both;
}

/* Receipt card */
.qbp-success-info {
  background: linear-gradient(135deg, rgba(34,197,94,0.06) 0%, rgba(34,197,94,0.02) 100%);
  border: 1px solid rgba(34,197,94,0.18);
  border-radius: 18px;
  padding: 4px 0;
  width: 100%;
  margin: 0 0 20px;
  opacity: 0;
  animation: qbpSlideUp 0.45s ease 1.9s both;
  overflow: hidden;
}
.qbp-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 11px 18px;
  font-size: 13px;
  transition: background 0.2s;
}
.qbp-info-row:not(:last-child) {
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.qbp-info-label { color: var(--theme-text-muted, #666); font-weight: 600; }
.qbp-info-val   { color: var(--theme-text-main, #f0f0f0); font-weight: 700; }
.qbp-info-val.green { color: #22c55e; }

/* Redirect line */
.qbp-redirect-line {
  width: 100%;
  opacity: 0;
  animation: qbpSlideUp 0.4s ease 2.05s both;
}
.qbp-redirect-text {
  font-size: 12px;
  color: var(--theme-text-muted, #666);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.qbp-redirect-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #22c55e;
  animation: qbpDotBlink 1s ease-in-out infinite;
}
@keyframes qbpDotBlink {
  0%,100% { opacity:1; transform:scale(1); }
  50%     { opacity:0.3; transform:scale(0.6); }
}
.qbp-progress-track {
  width: 100%;
  height: 4px;
  background: rgba(255,255,255,0.06);
  border-radius: 99px;
  overflow: hidden;
}
.qbp-progress-bar {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, #16a34a, #22c55e, #4ade80);
  background-size: 200% 100%;
  border-radius: 99px;
  transition: width 3.2s cubic-bezier(0.4,0,0.2,1);
  animation: qbpBarShimmer 1.5s linear infinite;
}
@keyframes qbpBarShimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ── Final redirect ─────────────────────────────────── */
.qbp-cod-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 0 8px;
}
.qbp-shield-icon {
  font-size: 52px;
  display: block;
  animation: qbpShieldFloat 2.5s ease-in-out infinite, qbpPop 0.5s cubic-bezier(0.34,1.56,0.64,1);
  margin-bottom: 10px;
}
.qbp-cod-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--theme-text-main, #f0f0f0);
  text-align: center;
  margin: 14px 0 6px;
}
.qbp-cod-sub {
  font-size: 13.5px;
  color: var(--theme-text-muted, #888);
  text-align: center;
  margin: 0 0 26px;
  line-height: 1.55;
  max-width: 320px;
}

/* ── Final redirect ─────────────────────────────────── */
#qbpStepFinal {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
.qbp-final-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 0;
  text-align: center;
  gap: 0;
}
/* Spinning bee orbit */
.qbp-orbit-wrap {
  position: relative;
  width: 110px;
  height: 110px;
  margin: 0 auto 24px;
}
.qbp-orbit-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2px dashed rgba(244,180,0,0.3);
  animation: qbpOrbitSpin 3s linear infinite;
}
@keyframes qbpOrbitSpin { to { transform: rotate(360deg); } }
.qbp-orbit-bee {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24px;
  animation: qbpOrbitSpin 3s linear infinite;
  transform-origin: 50% calc(55px + 12px);
}
.qbp-orbit-center {
  position: absolute;
  inset: 14px;
  border-radius: 50%;
  background: rgba(244,180,0,0.08);
  border: 1.5px solid rgba(244,180,0,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  animation: qbpGlowPulse 1.8s ease-in-out infinite;
}
.qbp-final-title {
  font-size: 22px;
  font-weight: 900;
  color: var(--theme-text-main, #f0f0f0);
  margin: 0 0 8px;
  animation: qbpSlideUp 0.4s ease 0.1s both;
}
.qbp-final-sub {
  font-size: 13.5px;
  color: var(--theme-text-muted, #888);
  margin: 0 0 28px;
  line-height: 1.6;
  animation: qbpSlideUp 0.4s ease 0.2s both;
}
/* Warp bar */
.qbp-warp-track {
  width: 220px;
  height: 6px;
  background: rgba(255,255,255,0.06);
  border-radius: 99px;
  overflow: hidden;
  margin: 0 auto;
  animation: qbpSlideUp 0.4s ease 0.3s both;
}
.qbp-warp-bar {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, #F4B400, #FFD700, #FFF176);
  border-radius: 99px;
  animation: qbpWarpFill 2s cubic-bezier(0.4,0,0.6,1) 0.4s forwards;
}
@keyframes qbpWarpFill {
  0%   { width: 0%; }
  70%  { width: 85%; }
  85%  { width: 92%; }
  100% { width: 100%; }
}
</style>

<!-- ══════════════════════════════════════════════════════
     QuickBee Payment Page — v2 (customer name, no txn ID)
     ══════════════════════════════════════════════════════ -->
<div class="qbp-page">
  <div class="qbp-wrap">

    <!-- ─── STEP 1: Choose Method ─────────────────────── -->
    <div class="qbp-step" id="qbpStep1">
      <div class="qbp-header">
        <span class="qbp-logo">🐝</span>
        <h1>Choose Payment</h1>
        <p>Select how you'd like to pay for your order</p>
      </div>

      <!-- Cart total display -->
      <div id="qbpCartSummary" style="background:rgba(244,180,0,0.08);border:1.5px solid rgba(244,180,0,0.2);border-radius:14px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;gap:10px;">
        <div style="display:flex;flex-direction:column;gap:4px;">
          <span style="font-size:13px;font-weight:700;color:#888;">Order Total</span>
          <a href="/cart" style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;color:#F4B400;text-decoration:none;opacity:0.85;letter-spacing:0.3px;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Edit Cart
          </a>
        </div>
        <span id="qbpCartTotal" style="font-size:22px;font-weight:900;color:#F4B400;letter-spacing:-0.5px;">Loading…</span>
      </div>

      <div class="qbp-methods">
        <div class="qbp-method" data-method="qr" id="qbpM_qr">
          <div class="qbp-method-icon">📱</div>
          <div class="qbp-method-info">
            <span class="qbp-method-title">Online QR Payment</span>
            <span class="qbp-method-sub">Fonepay · eSewa · Khalti · Bank QR</span>
          </div>
          <div class="qbp-method-radio"></div>
        </div>

        <div class="qbp-method" data-method="card" id="qbpM_card">
          <div class="qbp-method-icon">💳</div>
          <div class="qbp-method-info">
            <span class="qbp-method-title">Card on Delivery</span>
            <span class="qbp-method-sub">Debit/credit card paid when delivered</span>
          </div>
          <div class="qbp-method-radio"></div>
        </div>

        <div class="qbp-method" data-method="cash" id="qbpM_cash">
          <div class="qbp-method-icon">💵</div>
          <div class="qbp-method-info">
            <span class="qbp-method-title">Cash on Delivery</span>
            <span class="qbp-method-sub">Pay in cash when your order arrives</span>
          </div>
          <div class="qbp-method-radio"></div>
        </div>
      </div>

      <div class="qbp-secure-badge">🔒 SSL Encrypted &amp; Secure</div>
      <button class="qbp-btn" id="qbpContinueBtn" disabled>Continue →</button>
    </div>

    <!-- ─── STEP 2: QR Scan & Pay ─────────────────────── -->
    <div class="qbp-step hidden" id="qbpStepQR">
      <button class="qbp-back" id="qbpBackQR">← Back</button>
      <h2 class="qbp-step-title">Scan &amp; Pay</h2>
      <p class="qbp-step-sub">Open Fonepay, eSewa, Khalti or your bank app → scan the QR → pay the exact amount shown.</p>

      <!-- Amount chip -->
      <div style="text-align:center;margin:-4px 0 4px;">
        <span style="display:inline-block;background:rgba(244,180,0,0.15);border:1.5px solid rgba(244,180,0,0.3);border-radius:999px;padding:6px 18px;font-size:16px;font-weight:900;color:#F4B400;" id="qbpQRAmount">Rs —</span>
      </div>

      <div class="qbp-qr-wrap" style="position:relative;min-height:220px;">
        <div id="qbpQRLoader" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;">
          <svg width="40" height="40" viewBox="0 0 40 40" style="animation:qbpSpin 0.8s linear infinite;"><circle cx="20" cy="20" r="16" fill="none" stroke="#F4B400" stroke-width="4" stroke-dasharray="60 40" stroke-linecap="round"/></svg>
          <span style="font-size:13px;color:#888;">Generating your QR…</span>
        </div>
        <img src="" alt="QuickBee Payment QR Code" class="qbp-qr-img" id="qbpQRImage" style="display:none;">
      </div>

      <!-- Customer name -->
      <div class="qbp-field">
        <label class="qbp-label" for="qbpNameInput">Your Name <span style="color:#ef4444">*</span></label>
        <input type="text" id="qbpNameInput" class="qbp-input" placeholder="e.g. Ramesh Sharma" autocomplete="name" autocorrect="off" spellcheck="false">
      </div>
      <p style="font-size:12.5px;color:#666;text-align:center;margin:0 0 14px;">📞 Contact number will be asked on the next page</p>
      <button class="qbp-btn" id="qbpPaidBtn" disabled>I Have Paid →</button>
    </div>

    <!-- ─── STEP 3: QR Submitted Success ─────────────── -->
    <div class="qbp-step hidden" id="qbpStepSuccess">
      <canvas id="qbpParticleCanvas"></canvas>
      <div class="qbp-success-inner">
        <!-- Ripple rings + checkmark -->
        <div class="qbp-ripple-wrap">
          <div class="qbp-ripple"></div>
          <div class="qbp-ripple"></div>
          <div class="qbp-ripple"></div>
          <div class="qbp-check-circle">
            <svg class="qbp-svg" viewBox="0 0 140 140" aria-hidden="true">
              <circle class="qbp-ring-fill" cx="70" cy="70" r="62"/>
              <circle class="qbp-ring" cx="70" cy="70" r="62"/>
              <polyline class="qbp-tick" points="38,70 58,90 102,47"/>
            </svg>
          </div>
        </div>

        <!-- Bee flies in -->
        <span class="qbp-success-bee">🐝</span>

        <!-- Amount -->
        <div class="qbp-success-paid-label">PAYMENT CONFIRMED</div>
        <div class="qbp-success-amount" id="qbpSuccessAmt">Rs —</div>

        <h2 class="qbp-anim-title">Your order is placed!</h2>
        <p class="qbp-anim-sub">We'll verify your payment &amp; get your order ready. Sit tight — heading to checkout now.</p>

        <!-- Receipt -->
        <div class="qbp-success-info">
          <div class="qbp-info-row">
            <span class="qbp-info-label">👤 Name</span>
            <span class="qbp-info-val" id="qbpSuccessName">—</span>
          </div>
          <div class="qbp-info-row">
            <span class="qbp-info-label">✅ Status</span>
            <span class="qbp-info-val green">Payment Sent</span>
          </div>
          <div class="qbp-info-row">
            <span class="qbp-info-label">⏱ Verification</span>
            <span class="qbp-info-val">5–10 mins</span>
          </div>
        </div>

        <!-- Live dot + progress bar -->
        <div class="qbp-redirect-line">
          <div class="qbp-redirect-text">
            <span class="qbp-redirect-dot"></span>
            <span>Taking you to checkout</span>
          </div>
          <div class="qbp-progress-track">
            <div class="qbp-progress-bar" id="qbpProgressBar"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── STEP COD/Card: Secured ───────────────────── -->
    <div class="qbp-step hidden" id="qbpStepCOD">
      <div class="qbp-cod-wrap">
        <span class="qbp-shield-icon">🔒</span>
        <svg class="qbp-svg" viewBox="0 0 80 80" aria-hidden="true">
          <circle class="qbp-ring" cx="40" cy="40" r="36"/>
          <polyline class="qbp-tick" points="22,40 34,52 58,28"/>
        </svg>
        <p class="qbp-cod-title">Order Confirmed ✓</p>
        <p class="qbp-cod-sub" id="qbpCODDesc">Your order will be delivered. Please have payment ready.</p>
      </div>

      <div class="qbp-field">
        <label class="qbp-label" for="qbpNameCOD">Your Name <span style="color:#ef4444">*</span></label>
        <input type="text" id="qbpNameCOD" class="qbp-input" placeholder="e.g. Ramesh Sharma" autocomplete="name">
      </div>
      <p style="font-size:12.5px;color:#666;text-align:center;margin:0 0 14px;">📞 Contact number will be asked on the next page</p>
      <button class="qbp-btn" id="qbpCODCheckoutBtn">Confirm &amp; Checkout →</button>
    </div>

    <!-- ─── FINAL: Redirect ───────────────────────────── -->
    <div class="qbp-step hidden" id="qbpStepFinal">
      <div class="qbp-final-center">
        <div class="qbp-orbit-wrap">
          <div class="qbp-orbit-ring"></div>
          <div class="qbp-orbit-bee">🐝</div>
          <div class="qbp-orbit-center">🛒</div>
        </div>
        <h2 class="qbp-final-title">Opening Checkout…</h2>
        <p class="qbp-final-sub">Almost there! Filling in your order details.</p>
        <div class="qbp-warp-track">
          <div class="qbp-warp-bar"></div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
(function () {
  'use strict';

  var selectedMethod  = null;
  var cartTotal       = 0;
  var activeQRString  = '';
  var RAILWAY_API     = 'https://quickbee-fonepay-qr-production.up.railway.app';

  /* ── helpers ────────────────────────────────── */
  function show(id) {
    document.querySelectorAll('.qbp-step').forEach(function (s) { s.classList.add('hidden'); });
    var el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('hidden');
    el.querySelectorAll('.qbp-ring, .qbp-tick').forEach(function (n) {
      n.style.animation = 'none'; void n.offsetHeight; n.style.animation = '';
    });
    var page = document.querySelector('.qbp-page');
    var offset = page ? page.getBoundingClientRect().top + window.pageYOffset - 8 : 0;
    window.scrollTo({ top: offset, behavior: 'smooth' });
  }

  /* ─────────────────────────────────────────────────────
     CART NOTE — comprehensive order data
  ───────────────────────────────────────────────────── */
  var cartItems = [];

  function buildOrderNote(paymentMethod, customerName, amtRs) {
    /* Nepal time */
    var nowUtc  = Date.now();
    var npMs    = nowUtc + (5*3600000 + 45*60000) + (new Date().getTimezoneOffset()*60000);
    var npDate  = new Date(npMs);
    var npTime  = npDate.toLocaleString('en-US', { dateStyle:'medium', timeStyle:'short' });
    var totalMin = npDate.getHours()*60 + npDate.getMinutes();
    var isLate  = totalMin < 360 || totalMin >= 1200;

    /* Location from localStorage */
    var loc = null;
    try { loc = JSON.parse(localStorage.getItem('qb_selected_location') || 'null'); } catch(e){}

    /* Cart items summary */
    var itemLines = '';
    if (cartItems.length > 0) {
      cartItems.forEach(function(item) {
        itemLines += '\n  • ' + item.quantity + 'x ' + item.product_title +
                     ' — Rs ' + Math.round(item.final_line_price / 100);
      });
    }

    /* Build note */
    var note = '';
    note += '═══════════════════════════════\n';
    note += '  QUICKBEE ORDER DETAILS\n';
    note += '═══════════════════════════════\n\n';

    note += '💳 PAYMENT\n';
    note += '  Method : ' + paymentMethod + '\n';
    note += '  Name   : ' + customerName  + '\n';
    note += '  Amount : Rs ' + amtRs       + '\n\n';

    if (loc) {
      var addr = loc.address || loc.street || loc.landmark_link || '';
      note += '📍 DELIVERY LOCATION\n';
      if (addr)             note += '  Address : ' + addr + '\n';
      if (loc.mode)         note += '  Mode    : ' + loc.mode + '\n';
      if (loc.latitude)     note += '  Lat     : ' + loc.latitude  + '\n';
      if (loc.longitude)    note += '  Lng     : ' + loc.longitude + '\n';
      if (loc.latitude && loc.longitude) {
        note += '  Map     : https://www.google.com/maps?q=' + loc.latitude + ',' + loc.longitude + '\n';
      }
      if (loc.recipient_name) note += '  Recipient : ' + loc.recipient_name + '\n';
      note += '\n';
    }

    note += '🕐 ORDER TIME\n';
    note += '  Nepal Time    : ' + npTime + '\n';
    note += '  Delivery Type : ' + (isLate ? 'Late Night (8PM–6AM)' : 'Daytime (6AM–8PM)') + '\n\n';

    if (itemLines) {
      note += '🛒 CART ITEMS' + itemLines + '\n';
      note += '  ─────────────────────\n';
      note += '  Total : Rs ' + amtRs + '\n\n';
    }

    note += '═══════════════════════════════\n';
    note += '  quickbee.store\n';
    note += '═══════════════════════════════';

    return note;
  }

  function cartNote(noteText) {
    return fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ note: noteText })
    });
  }

  function goCheckout() {
    show('qbpStepFinal');
    setTimeout(function () { window.location.href = '/checkout'; }, 2200);
  }

  /* ── Load cart total on page load ──────────── */
  fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function (r) { return r.json(); })
    .then(function (cart) {
      cartTotal = cart.total_price || 0;
      cartItems = cart.items || [];
      var totalEl = document.getElementById('qbpCartTotal');
      if (totalEl) totalEl.textContent = 'Rs ' + Math.round(cartTotal / 100);
      var amtEl = document.getElementById('qbpQRAmount');
      if (amtEl) amtEl.textContent = 'Rs ' + Math.round(cartTotal / 100);
      /* If cart is empty, auto-redirect to checkout */
      if (cartTotal === 0) { window.location.href = '/checkout'; }
    })
    .catch(function () {
      var totalEl = document.getElementById('qbpCartTotal');
      if (totalEl) totalEl.textContent = '—';
    });

  /* ── Method selection ───────────────────────── */
  document.querySelectorAll('.qbp-method').forEach(function (card) {
    card.addEventListener('click', function () {
      document.querySelectorAll('.qbp-method').forEach(function (c) { c.classList.remove('selected'); });
      card.classList.add('selected');
      selectedMethod = card.getAttribute('data-method');
      var btn = document.getElementById('qbpContinueBtn');
      if (btn) { btn.disabled = false; btn.textContent = 'Continue →'; }
    });
  });

  /* ── Continue button ────────────────────────── */
  var continueBtn = document.getElementById('qbpContinueBtn');
  if (continueBtn) {
    continueBtn.addEventListener('click', function (e) {
      e.preventDefault();
      if (!selectedMethod) return;
      if (selectedMethod === 'qr') {
        show('qbpStepQR');
        var qrImg    = document.getElementById('qbpQRImage');
        var qrLoader = document.getElementById('qbpQRLoader');
        var amtRs    = Math.round(cartTotal / 100);
        if (qrImg && amtRs > 0) {
          if (qrLoader) qrLoader.style.display = 'flex';
          qrImg.style.display = 'none';
          fetch(RAILWAY_API + '/api/generate-qr?amount=' + amtRs)
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (data.success && data.qr_image) {
                qrImg.src = data.qr_image;
                qrImg.style.display = 'block';
                if (qrLoader) qrLoader.style.display = 'none';
              }
            })
            .catch(function () {
              qrImg.src = '{{ "PAYMENTSQRONLINE.png" | asset_url }}';
              qrImg.style.display = 'block';
              if (qrLoader) qrLoader.style.display = 'none';
            });
        }
      } else {
        var desc = document.getElementById('qbpCODDesc');
        if (desc) desc.textContent = selectedMethod === 'card'
          ? 'Pay with your debit or credit card when delivery arrives.'
          : 'Pay in cash when your order is delivered. Keep exact change ready!';
        show('qbpStepCOD');
      }
    });
  }

  /* ── Back from QR ───────────────────────────── */
  var backQR = document.getElementById('qbpBackQR');
  if (backQR) backQR.addEventListener('click', function () { show('qbpStep1'); });

  /* ── Particle burst ─────────────────────────── */
  function launchParticles() {
    var canvas = document.getElementById('qbpParticleCanvas');
    if (!canvas) return;
    var step = document.getElementById('qbpStepSuccess');
    canvas.width  = step.offsetWidth  || 400;
    canvas.height = step.offsetHeight || 600;
    var ctx = canvas.getContext('2d');
    var colors = ['#22c55e','#4ade80','#ffcc00','#ffd700','#fff','#86efac','#fef08a'];
    var particles = [];
    for (var i = 0; i < 90; i++) {
      particles.push({
        x: canvas.width / 2,
        y: canvas.height * 0.28,
        vx: (Math.random() - 0.5) * 14,
        vy: (Math.random() - 1.2) * 14,
        r: Math.random() * 5 + 2,
        color: colors[Math.floor(Math.random() * colors.length)],
        alpha: 1,
        gravity: 0.38,
        shape: Math.random() > 0.5 ? 'circle' : 'rect'
      });
    }
    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var alive = false;
      particles.forEach(function (p) {
        if (p.alpha <= 0) return;
        alive = true;
        p.x  += p.vx;
        p.y  += p.vy;
        p.vy += p.gravity;
        p.alpha -= 0.016;
        ctx.globalAlpha = Math.max(0, p.alpha);
        ctx.fillStyle = p.color;
        ctx.beginPath();
        if (p.shape === 'circle') {
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        } else {
          ctx.rect(p.x - p.r, p.y - p.r, p.r * 2, p.r * 1.4);
        }
        ctx.fill();
      });
      ctx.globalAlpha = 1;
      if (alive) requestAnimationFrame(draw);
    }
    draw();
  }

  /* ── Progress bar countdown ──────────────────── */
  function startProgressBar(durationMs) {
    var bar = document.getElementById('qbpProgressBar');
    if (!bar) return;
    /* Let CSS transition handle it — just set to 100% after delay */
    setTimeout(function () { bar.style.width = '100%'; }, 120);
  }

  /* ── QR: enable "I Have Paid" when name filled ── */
  var nameInput = document.getElementById('qbpNameInput');
  var paidBtn   = document.getElementById('qbpPaidBtn');
  if (nameInput && paidBtn) {
    nameInput.addEventListener('input', function () {
      paidBtn.disabled = nameInput.value.trim().length < 2;
    });
  }

  /* ── "I Have Paid" button ───────────────────── */
  if (paidBtn) {
    paidBtn.addEventListener('click', function (e) {
      e.preventDefault();
      var name  = nameInput ? nameInput.value.trim() : '—';
      if (name.length < 2) { nameInput && nameInput.focus(); return; }

      paidBtn.disabled = true;
      paidBtn.textContent = 'Submitting…';

      var amtRs   = Math.round(cartTotal / 100);
      var noteStr = buildOrderNote('Fonepay QR (Online)', name, amtRs);

      /* Populate success screen */
      var sAmt  = document.getElementById('qbpSuccessAmt');
      var sName = document.getElementById('qbpSuccessName');
      if (sAmt)  sAmt.textContent  = 'Rs ' + amtRs;
      if (sName) sName.textContent = name;

      cartNote(noteStr)
        .finally(function () {
          window.scrollTo(0, 0);
          document.documentElement.scrollTop = 0;
          document.body.scrollTop = 0;
          show('qbpStepSuccess');
          setTimeout(launchParticles, 100);
          startProgressBar(3200);
          setTimeout(goCheckout, 3800);
        });
    });
  }

  /* ── COD/Card: enable Checkout when name filled ── */
  var nameCOD  = document.getElementById('qbpNameCOD');
  var codBtn   = document.getElementById('qbpCODCheckoutBtn');
  if (nameCOD && codBtn) {
    nameCOD.addEventListener('input', function () {
      codBtn.disabled = nameCOD.value.trim().length < 2;
    });
    codBtn.disabled = true; /* start disabled */
  }

  /* ── COD/Card Checkout ──────────────────────── */
  if (codBtn) {
    codBtn.addEventListener('click', function (e) {
      e.preventDefault();
      var name  = nameCOD ? nameCOD.value.trim() : '—';
      var method = selectedMethod === 'card' ? 'Card on Delivery' : 'Cash on Delivery';
      if (name.length < 2) { nameCOD && nameCOD.focus(); return; }

      codBtn.disabled = true;
      codBtn.textContent = 'Processing…';

      var amtRsCOD = Math.round(cartTotal / 100);
      var noteStr  = buildOrderNote(method, name, amtRsCOD);
      cartNote(noteStr).finally(function() {
        window.scrollTo(0, 0);
        document.documentElement.scrollTop = 0;
        document.body.scrollTop = 0;
        setTimeout(goCheckout, 300);
      });
    });
  }

})();
</script>

{% schema %}
{
  "name": "QuickBee Payment",
  "settings": [],
  "presets": [
    { "name": "QuickBee Payment" }
  ]
}
{% endschema %}
