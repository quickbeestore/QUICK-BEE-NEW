{% comment %} QuickBee Payment Page — sections/quickbee-payment.liquid {% endcomment %}

<style>
/* ============================================================
   QUICKBEE PAYMENT PAGE
   CashApp-styled · Dark/Light sync · Smooth animations
   ============================================================ */

.qbp-page {
  min-height: 80vh;
  background: var(--theme-bg-primary, #0f0f0f);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 20px 16px 120px;
  font-family: inherit;
}
.qbp-wrap {
  width: 100%;
  max-width: 460px;
  position: relative;
}

/* ── Steps ─────────────────────────────────────────── */
.qbp-step { animation: qbpFadeUp 0.38s cubic-bezier(0.25,0.46,0.45,0.94) forwards; }
.qbp-step.hidden { display: none !important; }

@keyframes qbpFadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0);    }
}
@keyframes qbpSpin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
@keyframes qbpSlideUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0);    }
}
@keyframes qbpPop {
  0%   { transform: scale(0.3); opacity: 0; }
  70%  { transform: scale(1.1); }
  100% { transform: scale(1);   opacity: 1; }
}
@keyframes qbpRingDraw {
  to { stroke-dashoffset: 0; }
}
@keyframes qbpTickDraw {
  to { stroke-dashoffset: 60; }
}
@keyframes qbpDotPulse {
  0%, 80%, 100% { transform: scale(0.55); opacity: 0.35; }
  40%           { transform: scale(1);    opacity: 1; }
}
@keyframes qbpShieldFloat {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-6px); }
}

/* ── Header ─────────────────────────────────────────── */
.qbp-header {
  text-align: center;
  padding: 28px 0 20px;
}
.qbp-logo {
  font-size: 42px;
  display: block;
  margin-bottom: 10px;
  animation: qbpPop 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards;
}
.qbp-header h1 {
  font-size: 24px;
  font-weight: 800;
  color: var(--theme-text-main, #f0f0f0);
  margin: 0 0 6px;
}
.qbp-header p {
  font-size: 13px;
  color: var(--theme-text-muted, #888);
  margin: 0;
}

/* ── Method Cards ───────────────────────────────────── */
.qbp-methods {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}
.qbp-method {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 15px 16px;
  background: var(--theme-bg-secondary, #1c1c1c);
  border: 2px solid var(--theme-border, #2e2e2e);
  border-radius: 16px;
  cursor: pointer;
  transition: border-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  position: relative;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
}
.qbp-method:active { transform: scale(0.98); }
.qbp-method.selected {
  border-color: #ffcc00;
  box-shadow: 0 0 0 3px rgba(255,204,0,0.12);
}
.qbp-method-icon {
  font-size: 26px;
  width: 46px;
  height: 46px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--theme-bg-primary, #111);
  border-radius: 13px;
  flex-shrink: 0;
  transition: background 0.2s;
}
.qbp-method.selected .qbp-method-icon {
  background: rgba(255,204,0,0.1);
}
.qbp-method-info { flex: 1; min-width: 0; }
.qbp-method-title {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: var(--theme-text-main, #f0f0f0);
  margin-bottom: 2px;
}
.qbp-method-sub {
  display: block;
  font-size: 11.5px;
  color: var(--theme-text-muted, #888);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.qbp-method-radio {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 2px solid var(--theme-border, #3a3a3a);
  flex-shrink: 0;
  transition: all 0.2s cubic-bezier(0.34,1.56,0.64,1);
  display: flex;
  align-items: center;
  justify-content: center;
}
.qbp-method.selected .qbp-method-radio {
  background: #ffcc00;
  border-color: #ffcc00;
}
.qbp-method.selected .qbp-method-radio::after {
  content: '';
  width: 7px;
  height: 11px;
  border: 2.5px solid #1a1a1a;
  border-top: none;
  border-left: none;
  transform: rotate(42deg) translateY(-1px);
  display: block;
}

/* ── Secure badge ───────────────────────────────────── */
.qbp-secure-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 11.5px;
  font-weight: 600;
  color: var(--theme-text-muted, #666);
  margin-bottom: 16px;
  letter-spacing: 0.3px;
}
.qbp-secure-badge::before,
.qbp-secure-badge::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--theme-border, #2a2a2a);
}

/* ── Buttons ────────────────────────────────────────── */
.qbp-btn {
  width: 100%;
  padding: 15px 20px;
  background: #ffcc00;
  color: #1a1a1a;
  border: none;
  border-radius: 14px;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.22s cubic-bezier(0.34,1.56,0.64,1);
  letter-spacing: 0.1px;
  display: block;
}
.qbp-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: none !important;
}
.qbp-btn:not(:disabled):hover {
  background: #ffd700;
  transform: translateY(-2px);
  box-shadow: 0 6px 22px rgba(255,204,0,0.38);
}
.qbp-btn:not(:disabled):active { transform: scale(0.97); }

.qbp-btn-ghost {
  width: 100%;
  padding: 13px 20px;
  background: transparent;
  color: var(--theme-text-muted, #888);
  border: 1.5px solid var(--theme-border, #2e2e2e);
  border-radius: 14px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  margin-top: 10px;
  display: block;
  transition: all 0.2s;
}
.qbp-btn-ghost:hover {
  border-color: #ffcc00;
  color: var(--theme-text-main, #f0f0f0);
}

/* ── Back button ────────────────────────────────────── */
.qbp-back {
  background: none;
  border: none;
  color: var(--theme-text-muted, #888);
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  padding: 0;
  margin-bottom: 22px;
  display: flex;
  align-items: center;
  gap: 5px;
  transition: color 0.2s;
}
.qbp-back:hover { color: var(--theme-text-main, #f0f0f0); }

/* ── Step titles ────────────────────────────────────── */
.qbp-step-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--theme-text-main, #f0f0f0);
  margin: 0 0 6px;
}
.qbp-step-sub {
  font-size: 13.5px;
  color: var(--theme-text-muted, #888);
  margin: 0 0 20px;
  line-height: 1.55;
}

/* ── QR image ───────────────────────────────────────── */
.qbp-qr-wrap {
  background: #fff;
  border-radius: 20px;
  padding: 14px;
  margin: 18px 0 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 32px rgba(0,0,0,0.22);
  animation: qbpFadeUp 0.4s ease 0.1s both;
}
.qbp-qr-img {
  width: 100%;
  max-width: 300px;
  height: auto;
  display: block;
  border-radius: 8px;
}

/* ── Inputs ─────────────────────────────────────────── */
.qbp-field {
  margin-bottom: 18px;
}
.qbp-label {
  display: block;
  font-size: 11.5px;
  font-weight: 700;
  color: var(--theme-text-muted, #888);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.6px;
}
.qbp-input {
  width: 100%;
  padding: 13px 16px;
  background: var(--theme-bg-secondary, #1c1c1c);
  border: 1.5px solid var(--theme-border, #2e2e2e);
  border-radius: 12px;
  color: var(--theme-text-main, #f0f0f0);
  font-size: 16px;
  font-weight: 600;
  transition: border-color 0.2s, box-shadow 0.2s;
  box-sizing: border-box;
  display: block;
}
.qbp-input::placeholder { color: var(--theme-text-muted, #555); font-weight: 400; }
.qbp-input:focus {
  outline: none;
  border-color: #ffcc00;
  box-shadow: 0 0 0 3px rgba(255,204,0,0.1);
}
.qbp-phone-row {
  display: flex;
  gap: 8px;
  align-items: stretch;
}
.qbp-phone-prefix {
  padding: 13px 14px;
  background: var(--theme-bg-secondary, #1c1c1c);
  border: 1.5px solid var(--theme-border, #2e2e2e);
  border-radius: 12px;
  color: var(--theme-text-main, #f0f0f0);
  font-size: 15px;
  font-weight: 700;
  white-space: nowrap;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}
.qbp-phone-row .qbp-input { flex: 1; }

/* ── Verify step ────────────────────────────────────── */
.qbp-verify-emoji {
  font-size: 50px;
  text-align: center;
  display: block;
  margin-bottom: 10px;
  animation: qbpPop 0.5s cubic-bezier(0.34,1.56,0.64,1);
}
.qbp-txn-box {
  background: var(--theme-bg-secondary, #1c1c1c);
  border: 2px solid #ffcc00;
  border-radius: 14px;
  padding: 18px 20px;
  font-size: 19px;
  font-weight: 800;
  color: #ffcc00;
  text-align: center;
  letter-spacing: 1.5px;
  margin: 16px 0 10px;
  word-break: break-all;
  animation: qbpFadeUp 0.3s ease 0.1s both;
}
.qbp-verify-note {
  font-size: 12.5px;
  color: var(--theme-text-muted, #777);
  text-align: center;
  margin: 0 0 24px;
  line-height: 1.5;
}

/* ── SVG Success Animation ──────────────────────────── */
.qbp-anim-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28px 0 12px;
}
.qbp-svg {
  width: 96px;
  height: 96px;
}
.qbp-ring {
  fill: none;
  stroke: #22c55e;
  stroke-width: 4;
  stroke-dasharray: 226;
  stroke-dashoffset: 226;
  stroke-linecap: round;
  transform-origin: center;
  animation: qbpRingDraw 0.65s cubic-bezier(0.65,0,0.35,1) 0.1s forwards;
}
.qbp-tick {
  fill: none;
  stroke: #22c55e;
  stroke-width: 4.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: 60;
  stroke-dashoffset: -60;
  animation: qbpTickDraw 0.38s cubic-bezier(0.65,0,0.35,1) 0.72s forwards;
}
.qbp-anim-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--theme-text-main, #f0f0f0);
  text-align: center;
  margin: 14px 0 6px;
  animation: qbpSlideUp 0.4s ease 0.88s both;
}
.qbp-anim-sub {
  font-size: 13.5px;
  color: var(--theme-text-muted, #888);
  text-align: center;
  margin: 0 0 28px;
  line-height: 1.5;
  animation: qbpSlideUp 0.4s ease 1s both;
}

/* ── Phone section ──────────────────────────────────── */
.qbp-phone-section {
  animation: qbpSlideUp 0.4s ease 1.15s both;
}
.qbp-phone-section .qbp-btn { margin-top: 14px; }

/* ── COD secured ────────────────────────────────────── */
.qbp-cod-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 0 8px;
}
.qbp-shield-icon {
  font-size: 52px;
  display: block;
  animation: qbpShieldFloat 2.5s ease-in-out infinite, qbpPop 0.5s cubic-bezier(0.34,1.56,0.64,1);
  margin-bottom: 10px;
}
.qbp-cod-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--theme-text-main, #f0f0f0);
  text-align: center;
  margin: 14px 0 6px;
}
.qbp-cod-sub {
  font-size: 13.5px;
  color: var(--theme-text-muted, #888);
  text-align: center;
  margin: 0 0 26px;
  line-height: 1.55;
  max-width: 320px;
}

/* ── Final redirect ─────────────────────────────────── */
.qbp-final-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 0 24px;
  text-align: center;
}
.qbp-final-emoji {
  font-size: 60px;
  display: block;
  animation: qbpPop 0.5s cubic-bezier(0.34,1.56,0.64,1);
  margin-bottom: 16px;
}
.qbp-final-title {
  font-size: 24px;
  font-weight: 800;
  color: var(--theme-text-main, #f0f0f0);
  margin: 0 0 8px;
}
.qbp-final-sub {
  font-size: 14px;
  color: var(--theme-text-muted, #888);
  margin: 0 0 24px;
}
.qbp-dots {
  display: flex;
  gap: 8px;
  justify-content: center;
}
.qbp-dots span {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: #ffcc00;
  animation: qbpDotPulse 1.3s ease-in-out infinite;
}
.qbp-dots span:nth-child(2) { animation-delay: 0.22s; }
.qbp-dots span:nth-child(3) { animation-delay: 0.44s; }
</style>

<!-- ══════════════════════════════════════════════════════
     QuickBee Payment Page — v2 (customer name, no txn ID)
     ══════════════════════════════════════════════════════ -->
<div class="qbp-page">
  <div class="qbp-wrap">

    <!-- ─── STEP 1: Choose Method ─────────────────────── -->
    <div class="qbp-step" id="qbpStep1">
      <div class="qbp-header">
        <span class="qbp-logo">🐝</span>
        <h1>Choose Payment</h1>
        <p>Select how you'd like to pay for your order</p>
      </div>

      <!-- Cart total display -->
      <div id="qbpCartSummary" style="background:rgba(244,180,0,0.08);border:1.5px solid rgba(244,180,0,0.2);border-radius:14px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;">
        <span style="font-size:13px;font-weight:700;color:#888;">Order Total</span>
        <span id="qbpCartTotal" style="font-size:22px;font-weight:900;color:#F4B400;letter-spacing:-0.5px;">Loading…</span>
      </div>

      <div class="qbp-methods">
        <div class="qbp-method" data-method="qr" id="qbpM_qr">
          <div class="qbp-method-icon">📱</div>
          <div class="qbp-method-info">
            <span class="qbp-method-title">Online QR Payment</span>
            <span class="qbp-method-sub">Fonepay · eSewa · Khalti · Bank QR</span>
          </div>
          <div class="qbp-method-radio"></div>
        </div>

        <div class="qbp-method" data-method="card" id="qbpM_card">
          <div class="qbp-method-icon">💳</div>
          <div class="qbp-method-info">
            <span class="qbp-method-title">Card on Delivery</span>
            <span class="qbp-method-sub">Debit/credit card paid when delivered</span>
          </div>
          <div class="qbp-method-radio"></div>
        </div>

        <div class="qbp-method" data-method="cash" id="qbpM_cash">
          <div class="qbp-method-icon">💵</div>
          <div class="qbp-method-info">
            <span class="qbp-method-title">Cash on Delivery</span>
            <span class="qbp-method-sub">Pay in cash when your order arrives</span>
          </div>
          <div class="qbp-method-radio"></div>
        </div>
      </div>

      <div class="qbp-secure-badge">🔒 SSL Encrypted &amp; Secure</div>
      <button class="qbp-btn" id="qbpContinueBtn" disabled>Continue →</button>
    </div>

    <!-- ─── STEP 2: QR Scan & Pay ─────────────────────── -->
    <div class="qbp-step hidden" id="qbpStepQR">
      <button class="qbp-back" id="qbpBackQR">← Back</button>
      <h2 class="qbp-step-title">Scan &amp; Pay</h2>
      <p class="qbp-step-sub">Open Fonepay, eSewa, Khalti or your bank app → scan the QR → pay the exact amount shown.</p>

      <!-- Amount chip -->
      <div style="text-align:center;margin:-4px 0 4px;">
        <span style="display:inline-block;background:rgba(244,180,0,0.15);border:1.5px solid rgba(244,180,0,0.3);border-radius:999px;padding:6px 18px;font-size:16px;font-weight:900;color:#F4B400;" id="qbpQRAmount">Rs —</span>
      </div>

      <div class="qbp-qr-wrap" style="position:relative;min-height:220px;">
        <!-- Loading spinner shown while QR generates -->
        <div id="qbpQRLoader" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;">
          <svg width="40" height="40" viewBox="0 0 40 40" style="animation:qbpSpin 0.8s linear infinite;"><circle cx="20" cy="20" r="16" fill="none" stroke="#F4B400" stroke-width="4" stroke-dasharray="60 40" stroke-linecap="round"/></svg>
          <span style="font-size:13px;color:#888;">Generating your QR…</span>
        </div>
        <img src="" alt="QuickBee Payment QR Code" class="qbp-qr-img" id="qbpQRImage" style="display:none;">
      </div>

      <!-- Customer name (instead of transaction ID) -->
      <div class="qbp-field">
        <label class="qbp-label" for="qbpNameInput">Your Name <span style="color:#ef4444">*</span></label>
        <input type="text" id="qbpNameInput" class="qbp-input" placeholder="e.g. Ramesh Sharma" autocomplete="name" autocorrect="off" spellcheck="false">
      </div>
      <div class="qbp-field">
        <label class="qbp-label" for="qbpPhoneQR">Phone Number (for delivery updates)</label>
        <div class="qbp-phone-row">
          <span class="qbp-phone-prefix">+977</span>
          <input type="tel" id="qbpPhoneQR" class="qbp-input" placeholder="98XXXXXXXX" maxlength="10" inputmode="numeric">
        </div>
      </div>

      <button class="qbp-btn" id="qbpPaidBtn" disabled>I Have Paid →</button>
    </div>

    <!-- ─── STEP 3: QR Submitted Success ─────────────── -->
    <div class="qbp-step hidden" id="qbpStepSuccess">
      <div class="qbp-anim-wrap">
        <svg class="qbp-svg" viewBox="0 0 80 80" aria-hidden="true">
          <circle class="qbp-ring" cx="40" cy="40" r="36"/>
          <polyline class="qbp-tick" points="22,40 34,52 58,28"/>
        </svg>
      </div>
      <p class="qbp-anim-title">Payment Request Sent!</p>
      <p class="qbp-anim-sub">Our team will verify and confirm your order within 5–10 minutes. Proceeding to checkout… 🎉</p>
    </div>

    <!-- ─── STEP COD/Card: Secured ───────────────────── -->
    <div class="qbp-step hidden" id="qbpStepCOD">
      <div class="qbp-cod-wrap">
        <span class="qbp-shield-icon">🔒</span>
        <svg class="qbp-svg" viewBox="0 0 80 80" aria-hidden="true">
          <circle class="qbp-ring" cx="40" cy="40" r="36"/>
          <polyline class="qbp-tick" points="22,40 34,52 58,28"/>
        </svg>
        <p class="qbp-cod-title">Order Confirmed ✓</p>
        <p class="qbp-cod-sub" id="qbpCODDesc">Your order will be delivered. Please have payment ready.</p>
      </div>

      <div class="qbp-field">
        <label class="qbp-label" for="qbpNameCOD">Your Name <span style="color:#ef4444">*</span></label>
        <input type="text" id="qbpNameCOD" class="qbp-input" placeholder="e.g. Ramesh Sharma" autocomplete="name">
      </div>
      <div class="qbp-field">
        <label class="qbp-label" for="qbpPhoneCOD">Phone Number (for delivery updates)</label>
        <div class="qbp-phone-row">
          <span class="qbp-phone-prefix">+977</span>
          <input type="tel" id="qbpPhoneCOD" class="qbp-input" placeholder="98XXXXXXXX" maxlength="10" inputmode="numeric">
        </div>
      </div>
      <button class="qbp-btn" id="qbpCODCheckoutBtn">Confirm &amp; Checkout →</button>
    </div>

    <!-- ─── FINAL: Redirect ───────────────────────────── -->
    <div class="qbp-step hidden" id="qbpStepFinal">
      <div class="qbp-final-center">
        <span class="qbp-final-emoji">🎉</span>
        <h2 class="qbp-final-title">All Set!</h2>
        <p class="qbp-final-sub">Taking you to checkout…</p>
        <div class="qbp-dots">
          <span></span><span></span><span></span>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
(function () {
  'use strict';

  var selectedMethod  = null;
  var cartTotal       = 0;
  var activeQRString  = '';
  var RAILWAY_API     = 'https://quickbee-fonepay-qr-production.up.railway.app';

  /* ── helpers ────────────────────────────────── */
  function show(id) {
    document.querySelectorAll('.qbp-step').forEach(function (s) { s.classList.add('hidden'); });
    var el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('hidden');
    el.querySelectorAll('.qbp-ring, .qbp-tick').forEach(function (n) {
      n.style.animation = 'none'; void n.offsetHeight; n.style.animation = '';
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function cartNote(note) {
    return fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ note: note })
    });
  }

  function goCheckout() {
    show('qbpStepFinal');
    setTimeout(function () { window.location.href = '/checkout'; }, 2200);
  }

  /* ── Load cart total on page load ──────────── */
  fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function (r) { return r.json(); })
    .then(function (cart) {
      cartTotal = cart.total_price || 0;
      var totalEl = document.getElementById('qbpCartTotal');
      if (totalEl) totalEl.textContent = 'Rs ' + Math.round(cartTotal / 100);
      var amtEl = document.getElementById('qbpQRAmount');
      if (amtEl) amtEl.textContent = 'Rs ' + Math.round(cartTotal / 100);
      /* If cart is empty, auto-redirect to checkout */
      if (cartTotal === 0) { window.location.href = '/checkout'; }
    })
    .catch(function () {
      var totalEl = document.getElementById('qbpCartTotal');
      if (totalEl) totalEl.textContent = '—';
    });

  /* ── Method selection ───────────────────────── */
  document.querySelectorAll('.qbp-method').forEach(function (card) {
    card.addEventListener('click', function () {
      document.querySelectorAll('.qbp-method').forEach(function (c) { c.classList.remove('selected'); });
      card.classList.add('selected');
      selectedMethod = card.getAttribute('data-method');
      var btn = document.getElementById('qbpContinueBtn');
      if (btn) { btn.disabled = false; btn.textContent = 'Continue →'; }
    });
  });

  /* ── Continue button ────────────────────────── */
  var continueBtn = document.getElementById('qbpContinueBtn');
  if (continueBtn) {
    continueBtn.addEventListener('click', function (e) {
      e.preventDefault();
      if (!selectedMethod) return;
      if (selectedMethod === 'qr') {
        show('qbpStepQR');
        /* ── Fetch dynamic QR from Railway ── */
        var qrImg    = document.getElementById('qbpQRImage');
        var qrLoader = document.getElementById('qbpQRLoader');
        var amtRs    = Math.round(cartTotal / 100);
        if (qrImg && amtRs > 0) {
          if (qrLoader) qrLoader.style.display = 'flex';
          qrImg.style.display = 'none';
          fetch(RAILWAY_API + '/api/generate-qr?amount=' + amtRs)
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (data.success && data.qr_image) {
                activeQRString = data.qr_string || '';
                qrImg.src = data.qr_image;
                qrImg.style.display = 'block';
                if (qrLoader) qrLoader.style.display = 'none';
              }
            })
            .catch(function () {
              /* Fallback to static QR if API fails */
              qrImg.src = '{{ "PAYMENTSQRONLINE.png" | asset_url }}';
              qrImg.style.display = 'block';
              if (qrLoader) qrLoader.style.display = 'none';
            });
        }
      } else {
        var desc = document.getElementById('qbpCODDesc');
        if (desc) desc.textContent = selectedMethod === 'card'
          ? 'Pay with your debit or credit card when delivery arrives.'
          : 'Pay in cash when your order is delivered. Keep exact change ready!';
        show('qbpStepCOD');
      }
    });
  }

  /* ── Back from QR ───────────────────────────── */
  var backQR = document.getElementById('qbpBackQR');
  if (backQR) backQR.addEventListener('click', function () { show('qbpStep1'); });

  /* ── QR: enable "I Have Paid" when name filled ── */
  var nameInput = document.getElementById('qbpNameInput');
  var paidBtn   = document.getElementById('qbpPaidBtn');
  if (nameInput && paidBtn) {
    nameInput.addEventListener('input', function () {
      paidBtn.disabled = nameInput.value.trim().length < 2;
    });
  }

  /* ── "I Have Paid" button ───────────────────── */
  if (paidBtn) {
    paidBtn.addEventListener('click', function (e) {
      e.preventDefault();
      var name  = nameInput ? nameInput.value.trim() : '—';
      var phone = document.getElementById('qbpPhoneQR');
      var num   = phone ? phone.value.trim() : '';
      if (name.length < 2) { nameInput && nameInput.focus(); return; }

      paidBtn.disabled = true;
      paidBtn.textContent = 'Submitting…';

      var amtRs   = Math.round(cartTotal / 100);
      var noteStr = 'Payment Method: Online QR | Name: ' + name + ' | Phone: +977' + num + ' | Amount: Rs ' + amtRs;

      /* Submit to Railway for order tracking + save cart note */
      var railwaySubmit = fetch(RAILWAY_API + '/api/submit-payment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          amount: amtRs,
          customer_name: name,
          customer_phone: '+977' + num,
          qr_string: activeQRString,
          cart_token: ''
        })
      }).catch(function () { /* ignore if Railway unavailable */ });

      Promise.all([cartNote(noteStr), railwaySubmit])
        .finally(function () {
          show('qbpStepSuccess');
          /* Auto-forward to checkout after 3s */
          setTimeout(goCheckout, 3000);
        });
    });
  }

  /* ── COD/Card: enable Checkout when name filled ── */
  var nameCOD  = document.getElementById('qbpNameCOD');
  var codBtn   = document.getElementById('qbpCODCheckoutBtn');
  if (nameCOD && codBtn) {
    nameCOD.addEventListener('input', function () {
      codBtn.disabled = nameCOD.value.trim().length < 2;
    });
    codBtn.disabled = true; /* start disabled */
  }

  /* ── COD/Card Checkout ──────────────────────── */
  if (codBtn) {
    codBtn.addEventListener('click', function (e) {
      e.preventDefault();
      var name  = nameCOD ? nameCOD.value.trim() : '—';
      var phone = document.getElementById('qbpPhoneCOD');
      var num   = phone ? phone.value.trim() : '';
      var method = selectedMethod === 'card' ? 'Card on Delivery' : 'Cash on Delivery';
      if (name.length < 2) { nameCOD && nameCOD.focus(); return; }

      codBtn.disabled = true;
      codBtn.textContent = 'Processing…';

      var noteStr = 'Payment Method: ' + method + ' | Name: ' + name + ' | Phone: +977' + num;
      cartNote(noteStr).finally(goCheckout);
    });
  }

})();
</script>

{% schema %}
{
  "name": "QuickBee Payment",
  "settings": [],
  "presets": [
    { "name": "QuickBee Payment" }
  ]
}
{% endschema %}
