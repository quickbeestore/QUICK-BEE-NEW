{% comment %} QuickBee Payment QR Page {% endcomment %}

<style>
.qbpay-page {
  background: #0f0f0f;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 40px 20px 80px;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: #f0f0f0;
}
.qbpay-header {
  text-align: center; margin-bottom: 32px;
}
.qbpay-logo {
  font-size: 14px; font-weight: 700; color: #fbbf24;
  letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px;
}
.qbpay-title {
  font-size: 28px; font-weight: 900; color: #fff; margin: 0 0 8px;
}
.qbpay-sub { font-size: 14px; color: #666; }

.qbpay-card {
  background: #1a1a1a; border: 1px solid rgba(255,255,255,0.08);
  border-radius: 24px; padding: 32px; max-width: 380px; width: 100%;
  text-align: center;
}
.qbpay-label {
  font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
  color: #fbbf24; font-weight: 600; margin-bottom: 16px;
}
.qbpay-qr-wrap {
  background: #fff; border-radius: 16px; padding: 16px;
  display: inline-block; margin-bottom: 20px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}
.qbpay-qr-wrap img {
  width: 220px; height: 220px; display: block;
}
.qbpay-qr-placeholder {
  width: 220px; height: 220px;
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 10px;
}
.qbpay-qr-spinner {
  width: 36px; height: 36px;
  border: 3px solid rgba(0,0,0,0.1);
  border-top-color: #fbbf24;
  border-radius: 50%;
  animation: qbpaySpinner 0.8s linear infinite;
}
@keyframes qbpaySpinner { to { transform: rotate(360deg); } }
.qbpay-qr-loading-txt { font-size: 12px; color: #999; }

.qbpay-merchant {
  font-size: 14px; color: #aaa; margin-bottom: 6px;
}
.qbpay-merchant strong { color: #fff; }
.qbpay-amount-row {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  margin: 12px 0 20px;
}
.qbpay-amount-label { font-size: 13px; color: #666; }
.qbpay-amount-val { font-size: 28px; font-weight: 900; color: #fbbf24; }
.qbpay-currency { font-size: 14px; color: #888; font-weight: 400; }

.qbpay-divider { border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 20px 0; }

.qbpay-steps { text-align: left; }
.qbpay-steps-title { font-size: 12px; color: #666; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 12px; }
.qbpay-step {
  display: flex; align-items: flex-start; gap: 12px; margin-bottom: 10px;
}
.qbpay-step-num {
  width: 22px; height: 22px; background: rgba(251,191,36,0.15); border: 1px solid rgba(251,191,36,0.3);
  color: #fbbf24; border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; flex-shrink: 0; margin-top: 1px;
}
.qbpay-step-text { font-size: 13px; color: #aaa; line-height: 1.5; }

.qbpay-confirm-btn {
  display: block; width: 100%; margin-top: 20px; padding: 16px;
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: #000; border: none; border-radius: 14px;
  font-size: 15px; font-weight: 800; cursor: pointer;
  transition: opacity 0.2s, transform 0.1s;
  font-family: inherit;
}
.qbpay-confirm-btn:hover { opacity: 0.9; }
.qbpay-confirm-btn:active { transform: scale(0.98); }

.qbpay-support {
  margin-top: 24px; font-size: 12px; color: #555; text-align: center;
}
.qbpay-support a { color: #fbbf24; text-decoration: none; }
</style>

<div class="qbpay-page">
  <div class="qbpay-header">
    <div class="qbpay-logo">Hill Top Husbandry</div>
    <h1 class="qbpay-title">Scan to Pay</h1>
    <p class="qbpay-sub">Quick and secure payment via QR code</p>
  </div>

  <div class="qbpay-card">
    <div class="qbpay-label">Payment QR Code</div>

    <div class="qbpay-qr-wrap">
      <!-- Static fallback QR image shown immediately -->
      <img id="qbpayQrImg"
        src="{{ section.settings.static_qr_image | default: collection.image | img_url: '440x440' }}"
        alt="Payment QR Code"
        onerror="this.style.display='none';document.getElementById('qbpayQrFallback').style.display='flex'">
      <div id="qbpayQrFallback" class="qbpay-qr-placeholder" style="display:none">
        <div class="qbpay-qr-spinner"></div>
        <div class="qbpay-qr-loading-txt">Loading QR…</div>
      </div>
    </div>

    <div class="qbpay-merchant">Merchant: <strong>Hill Top Husbandry</strong></div>

    <div class="qbpay-amount-row" id="qbpayAmountRow" style="display:none">
      <span class="qbpay-amount-label">Amount:</span>
      <span class="qbpay-amount-val" id="qbpayAmountVal">0</span>
      <span class="qbpay-currency">NPR</span>
    </div>

    <hr class="qbpay-divider">

    <div class="qbpay-steps">
      <div class="qbpay-steps-title">How to pay</div>
      <div class="qbpay-step"><div class="qbpay-step-num">1</div><div class="qbpay-step-text">Open your banking app or eSewa / Khalti</div></div>
      <div class="qbpay-step"><div class="qbpay-step-num">2</div><div class="qbpay-step-text">Tap "Scan QR" and scan the code above</div></div>
      <div class="qbpay-step"><div class="qbpay-step-num">3</div><div class="qbpay-step-text">Enter the exact amount shown and confirm</div></div>
      <div class="qbpay-step"><div class="qbpay-step-num">4</div><div class="qbpay-step-text">Take a screenshot and click the button below</div></div>
    </div>

    <button class="qbpay-confirm-btn" onclick="qbpayConfirm()">
      ✓ I've Completed the Payment
    </button>
  </div>

  <div class="qbpay-support">
    Need help? Contact us on <a href="https://wa.me/9779800000000">WhatsApp</a> or call <a href="tel:+977-1-0000000">01-000-0000</a>
  </div>
</div>

<script>
(function(){
  // Try to get cart total to show amount
  fetch('/cart.js').then(function(r){ return r.json(); }).then(function(cart){
    if(cart.total_price > 0){
      var amt = (cart.total_price / 100).toLocaleString();
      document.getElementById('qbpayAmountVal').textContent = amt;
      document.getElementById('qbpayAmountRow').style.display = 'flex';
    }
  }).catch(function(){});

  // Try dynamic QR fetch (8s timeout fallback handled via onerror on img)
  var qrFetched = false;
  var timeout = setTimeout(function(){
    if(!qrFetched){
      var fb = document.getElementById('qbpayQrFallback');
      if(fb && fb.style.display === 'flex'){
        fb.innerHTML = '<div style="font-size:13px;color:#999;padding:20px;text-align:center">QR code not available.<br>Please contact support.</div>';
      }
    }
  }, 8000);

  window.qbpayConfirm = function(){
    var btn = document.querySelector('.qbpay-confirm-btn');
    btn.textContent = '✓ Payment Confirmed!';
    btn.style.background = '#16a34a';
    btn.style.color = '#fff';
    btn.disabled = true;
    setTimeout(function(){
      window.location.href = '/';
    }, 2000);
  };
})();
</script>

{% schema %}
{
  "name": "QuickBee Payment",
  "settings": [
    {
      "type": "image_picker",
      "id": "static_qr_image",
      "label": "Static QR Code Image"
    }
  ]
}
{% endschema %}
