<!-- Toast -->
<div class="qb-flash-toast" id="qb-toast-flash" role="alert" aria-live="polite"></div>

<script>
(function () {
  'use strict';

  /* ── State ── */
  var qty = 1;
  var maxQty = 3;
  var selectedVariantId = null;
  var isExpired = false;
  var PRODUCT_ID = '{{ product.id }}';

  /* ── DOM refs ── */
  var qtyEl        = document.getElementById('qbf-qty');
  var plusBtn       = document.getElementById('qbf-plus');
  var minusBtn      = document.getElementById('qbf-minus');
  var atcBtn        = document.getElementById('qbf-atc');
  var priceEl       = document.getElementById('qbf-price');
  var variantsWrap  = document.getElementById('qbf-variants');
  var toast         = document.getElementById('qb-toast-flash');
  var fillEl        = document.getElementById('qbf-fill');
  var pctEl         = document.getElementById('qbf-pct');
  var stockEl       = document.getElementById('qbf-stock');
  var expiredEl     = document.getElementById('qbf-expired');
  var ddEl          = document.getElementById('qbf-dd');
  var hhEl          = document.getElementById('qbf-hh');
  var mmEl          = document.getElementById('qbf-mm');
  var ssEl          = document.getElementById('qbf-ss');
  var waBtn         = document.getElementById('qbf-share-wa');
  var copyBtn       = document.getElementById('qbf-copy-link');

  if (atcBtn) {
    selectedVariantId = atcBtn.dataset.defaultVariant;
  }

  /* ── Random progress bar (60–90%) ── */
  (function initProgress() {
    var pct = Math.floor(Math.random() * 31) + 60;
    setTimeout(function () {
      if (fillEl) fillEl.style.width = pct + '%';
      if (pctEl) pctEl.textContent = pct + '% claimed';
    }, 300);
  })();

  /* ── Random stock (3–12) ── */
  if (stockEl) {
    stockEl.textContent = Math.floor(Math.random() * 10) + 3;
  }

  /* ── Countdown Timer ── */
  (function initTimer() {
    var storageKey = 'qb_flash_deal_end_' + PRODUCT_ID;
    var endTime = null;

    try {
      var saved = localStorage.getItem(storageKey);
      if (saved) {
        endTime = parseInt(saved, 10);
        if (isNaN(endTime) || endTime <= Date.now()) {
          /* Deal was expired — set new 23:59:59 window */
          endTime = Date.now() + (23 * 3600 + 59 * 60 + 59) * 1000;
          localStorage.setItem(storageKey, endTime);
        }
      } else {
        endTime = Date.now() + (23 * 3600 + 59 * 60 + 59) * 1000;
        localStorage.setItem(storageKey, endTime);
      }
    } catch (e) {
      endTime = Date.now() + (23 * 3600 + 59 * 60 + 59) * 1000;
    }

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function handleExpiry() {
      if (isExpired) return;
      isExpired = true;
      if (ddEl) ddEl.textContent = '00';
      if (hhEl) hhEl.textContent = '00';
      if (mmEl) mmEl.textContent = '00';
      if (ssEl) ssEl.textContent = '00';
      if (atcBtn) {
        atcBtn.disabled = true;
        atcBtn.classList.add('expired');
        atcBtn.textContent = 'Deal Expired';
      }
      if (expiredEl) expiredEl.classList.add('visible');
    }

    function tick() {
      var diff = endTime - Date.now();
      if (diff <= 0) {
        handleExpiry();
        return;
      }
      var days = Math.floor(diff / 86400000);
      var hours = Math.floor((diff % 86400000) / 3600000);
      var mins  = Math.floor((diff % 3600000) / 60000);
      var secs  = Math.floor((diff % 60000) / 1000);
      if (ddEl) ddEl.textContent = pad(days);
      if (hhEl) hhEl.textContent = pad(hours);
      if (mmEl) mmEl.textContent = pad(mins);
      if (ssEl) ssEl.textContent = pad(secs);
    }

    tick();
    setInterval(tick, 1000);
  })();

  /* ── Quantity stepper ── */
  if (plusBtn) {
    plusBtn.addEventListener('click', function () {
      if (qty < maxQty) { qty++; qtyEl.textContent = qty; }
    });
  }

  if (minusBtn) {
    minusBtn.addEventListener('click', function () {
      if (qty > 1) { qty--; qtyEl.textContent = qty; }
    });
  }

  /* ── Variant pills ── */
  if (variantsWrap) {
    variantsWrap.addEventListener('click', function (e) {
      var pill = e.target.closest('.qb-flash__variant-pill');
      if (!pill) return;
      variantsWrap.querySelectorAll('.qb-flash__variant-pill').forEach(function (p) {
        p.classList.remove('active');
      });
      pill.classList.add('active');
      selectedVariantId = pill.dataset.variantId;
      if (priceEl) priceEl.textContent = 'Rs ' + pill.dataset.variantPrice;
    });
  }

  /* ── Toast helper ── */
  var toastTimer = null;
  function showToast(msg, isError) {
    if (!toast) return;
    clearTimeout(toastTimer);
    toast.textContent = msg;
    toast.classList.toggle('error', !!isError);
    toast.classList.add('show');
    toastTimer = setTimeout(function () { toast.classList.remove('show'); }, 3000);
  }

  /* ── Add to cart ── */
  if (atcBtn && atcBtn.dataset.defaultVariant) {
    atcBtn.addEventListener('click', function () {
      if (atcBtn.disabled || isExpired) return;
      var varId = selectedVariantId || atcBtn.dataset.defaultVariant;
      if (!varId) { showToast('Please select an option', true); return; }

      atcBtn.disabled = true;
      atcBtn.textContent = 'Adding…';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: parseInt(varId, 10),
          quantity: qty,
          properties: { 'Deal Type': 'Flash Deal', 'Max Per Customer': '3' }
        })
      })
      .then(function (res) {
        if (!res.ok) return res.json().then(function (d) { throw new Error(d.description || 'Error'); });
        return res.json();
      })
      .then(function () {
        atcBtn.classList.add('added');
        atcBtn.textContent = '✓ Grabbed!';
        showToast('Flash deal grabbed! ⚡');
        window.dispatchEvent(new CustomEvent('cart:updated'));
        setTimeout(function () {
          atcBtn.classList.remove('added');
          atcBtn.disabled = false;
          atcBtn.textContent = 'GRAB DEAL NOW ⚡';
        }, 1500);
      })
      .catch(function (err) {
        atcBtn.disabled = false;
        atcBtn.textContent = 'GRAB DEAL NOW ⚡';
        showToast(err.message || 'Could not add to cart', true);
      });
    });
  }

  /* ── WhatsApp share ── */
  if (waBtn) {
    waBtn.addEventListener('click', function (e) {
      e.preventDefault();
      var url = window.location.href;
      var text = encodeURIComponent('⚡ Flash Deal! Check this out: ' + url);
      window.open('https://wa.me/?text=' + text, '_blank', 'noopener,noreferrer');
    });
  }

  /* ── Copy link ── */
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      var url = window.location.href;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(function () {
          showToast('Link copied! 📋');
        }).catch(function () {
          fallbackCopy(url);
        });
      } else {
        fallbackCopy(url);
      }
    });
  }

  function fallbackCopy(text) {
    try {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showToast('Link copied! 📋');
    } catch (e) {
      showToast('Could not copy link', true);
    }
  }

})();
</script>

