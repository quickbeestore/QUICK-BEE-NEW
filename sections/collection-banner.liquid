{% comment %}
  Collection Banner Section
  Automatically displays promotional banners for each collection based on collection handle
{% endcomment %}

{% liquid
  assign banner_image = ''
  assign collection_handle = collection.handle | default: ''

  case collection_handle
    when 'groceries'
      assign banner_image = 'assets-20000-products-and-services.png'
    when 'clothes-washing', 'laundry'
      assign banner_image = 'banner-clothes-washing.png'
    when 'vegetables', 'fresh-vegetables'
      assign banner_image = 'assets-fresh-vegetables-and-fruits.png'
    when 'dairy', 'dairy-products'
      assign banner_image = 'banner-dairy.png'
    when 'drinks', 'beverages'
      assign banner_image = 'assets-cold-domestic-beer.png'
    else
      assign banner_image = 'assets-20000-products-and-services.png'
  endcase
%}

<div class="collection-banner">
  {% if banner_image %}
    <div class="collection-banner-image">
      <img
        src="{{ banner_image | asset_url }}"
        alt="{{ collection.title }} Promotion"
        loading="lazy"
        class="banner-img"
        style="width: 100%; height: auto; display: block;"
      />
    </div>
  {% endif %}
</div>

<style>
  .collection-banner {
    position: relative;
    margin-bottom: 1rem;
    height: 120px;
    overflow: hidden;
  }

  .collection-banner-image {
    overflow: hidden;
    height: 100%;
  }

  .banner-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

{% schema %}
{
  "name": "Collection Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "banner_link",
      "label": "Banner Link (optional)"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "View Collection"
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}
