{%- comment -%}
  =====================================================================================
  Newari Heritage Feature Section
  =====================================================================================
  * A split-screen section to highlight cultural heritage with an image and text.
  * Responsive design that stacks on mobile devices.
  * Editable via the Shopify Theme Editor with a full schema.

  **Settings:**
  - Image: For the main visual.
  - Eyebrow Text: A small heading with an accent color.
  - Heading: The main section heading.
  - Body Text: The main paragraph content.
  - Image Position: Allows switching the image from left to right.
  - Colors: Background and accent color pickers for full control.
{%- endcomment -%}

{%- liquid
  assign image = section.settings.image
  assign eyebrow_text = section.settings.eyebrow_text
  assign heading = section.settings.heading
  assign text = section.settings.text
  assign image_position = section.settings.image_position
  assign background_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color

  assign text_alignment = section.settings.text_alignment
  
  assign section_style = '--background-color: ' | append: background_color | append: ';'
  assign section_style = section_style | append: '--text-color: ' | append: text_color | append: ';'
  assign section_style = section_style | append: '--accent-color: ' | append: accent_color | append: ';'
-%}

<style>
  .nh-section {
    background-color: var(--background-color);
    color: var(--text-color);
    /* For a subtle texture, you could add a background image like this: */
    /* background-image: url('{{ "your-pattern.png" | asset_url }}'); */
    /* background-repeat: repeat; */
    /* background-size: 400px; */
    /* background-blend-mode: multiply; */
  }

  .nh-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    max-width: 1440px;
    margin: 0 auto;
  }

  .nh-grid__text-col {
    padding: 4rem 5rem;
  }

  .nh-grid--image-right .nh-grid__text-col {
    order: 1;
  }
  
  .nh-grid--image-right .nh-grid__image-col {
    order: 2;
  }

  .nh-grid--image-left .nh-grid__text-col {
    order: 2;
  }
  
  .nh-grid--image-left .nh-grid__image-col {
    order: 1;
  }

  .nh-grid__image-col {
    position: relative;
    overflow: hidden;
    height: 100%;
    min-height: 400px;
  }

  .nh-grid__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .nh-grid__image-col:hover .nh-grid__image {
    transform: scale(1.05);
  }

  .nh-text__eyebrow {
    color: var(--accent-color);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
  }

  .nh-text__heading {
    /* For a sophisticated serif font, this should be replaced with your theme's heading font variable if available. */
    font-family: "Lora", "Georgia", serif; 
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
    line-height: 1.1;
    margin: 0 0 1.5rem;
  }

  .nh-text__body {
    font-size: 1rem;
    line-height: 1.7;
    max-width: 60ch; /* Limits line length for readability */
  }

  .nh-text__body p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .nh-grid {
      grid-template-columns: 1fr;
    }

    .nh-grid__text-col {
      padding: 3rem 1.5rem;
      order: 2 !important; /* Ensure text is always after the image on mobile */
    }

    .nh-grid__image-col {
      order: 1 !important; /* Ensure image is always first on mobile */
      min-height: 300px;
    }

    .nh-text__heading {
      font-size: 2.25rem;
    }
  }
</style>

<section class="nh-section" style="{{ section_style }}">
  <div class="nh-grid nh-grid--image-{{ image_position }}">
    <div class="nh-grid__image-col">
      {%- if image != blank -%}
        <img 
          src="{{ image | image_url: width: 1200 }}" 
          alt="{{ image.alt | escape }}" 
          class="nh-grid__image"
          width="{{ image.width }}"
          height="{{ image.height }}"
          loading="lazy">
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'nh-grid__image placeholder' }}
      {%- endif -%}
    </div>

    <div class="nh-grid__text-col">
      {%- if eyebrow_text != blank -%}
        <span class="nh-text__eyebrow">{{ eyebrow_text }}</span>
      {%- endif -%}

      {%- if heading != blank -%}
        <h2 class="nh-text__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if text != blank -%}
        <div class="nh-text__body rte">
          {{ text }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newari Heritage Feature",
  "tag": "section",
  "class": "newari-heritage-feature-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "✦ OUR HERITAGE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A Taste of Newari Culture"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>Pachali Bhairab Food Court brings you the authentic flavors of Kathmandu. Our dishes celebrate the rich culinary traditions of the Newari people, passed down through generations.</p>"
    },
    {
      "type": "header",
      "content": "Layout & Style"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FDF9F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Eyebrow)",
      "default": "#A84C32"
    }
  ],
  "presets": [
    {
      "name": "Newari Heritage Feature"
    }
  ]
}
{% endschema %}
