<!-- sections/delivery-rider-application.liquid -->
<section class="qb-apply-section" id="rider-application">
  <div class="qb-apply-container">
    <div class="qb-apply-header animate-fade-in">
      <h1>Join Quickbee Delivery Team</h1>
      <p>Earn with flexible hours. Apply now.</p>
    </div>

    {%- form 'contact', id: 'RiderApplicationForm', class: 'qb-apply-form animate-fade-in' -%}
      {%- if form.posted_successfully? -%}
        <div class="qb-apply-success">
          <div class="success-icon">✅</div>
          <h2>Application sent successfully</h2>
          <p>Thank you for your interest. We will review your details and get back to you.</p>
          <button type="button" onclick="window.location.href='/'" class="qb-btn-secondary">Back to Home</button>
        </div>
      {%- else -%}
        
        <!-- Hidden email field required by Shopify to send the form -->
        <input type="hidden" name="contact[email]" value="rider-apply@quickbee.store">

        <div class="qb-form-body">
          <!-- Personal Info -->
          <div class="qb-field">
            <label for="ApplyName">Full Name</label>
            <input type="text" id="ApplyName" name="contact[Full_Name]" placeholder="Your name">
          </div>

          <div class="qb-field">
            <label for="ApplyPhone">Phone Number *</label>
            <input type="tel" id="ApplyPhone" name="contact[phone]" placeholder="e.g. 98XXXXXXXX" required>
          </div>

          <div class="qb-field">
            <label for="ApplyLocation">Current Location</label>
            <input type="text" id="ApplyLocation" name="contact[Location]" placeholder="City / Area">
          </div>

          <div class="qb-field">
            <label for="ApplyAge">Age</label>
            <input type="text" id="ApplyAge" name="contact[Age]" placeholder="Your age">
          </div>

          <!-- Vehicle & Experience -->
          <div class="qb-field">
            <label for="ApplyVehicle">Vehicle Type</label>
            <input type="text" id="ApplyVehicle" name="contact[Vehicle_Type]" placeholder="e.g. Bike, Scooter, or None">
          </div>

          <div class="qb-field">
            <label for="ApplyVehicleNum">Vehicle Number</label>
            <input type="text" id="ApplyVehicleNum" name="contact[Vehicle_Number]" placeholder="Vehicle plate number">
          </div>

          <div class="qb-field">
            <label for="ApplyLicense">License Status</label>
            <input type="text" id="ApplyLicense" name="contact[License_Status]" placeholder="Do you have a license?">
          </div>

          <div class="qb-field">
            <label for="ApplyExperience">Experience</label>
            <input type="text" id="ApplyExperience" name="contact[Experience]" placeholder="Any previous delivery work?">
          </div>

          <!-- Work Preferences -->
          <div class="qb-field">
            <label for="ApplyAreas">Areas Covered</label>
            <input type="text" id="ApplyAreas" name="contact[Areas_Covered]" placeholder="Areas you can work in">
          </div>

          <div class="qb-field">
            <label for="ApplyTime">Available Time</label>
            <input type="text" id="ApplyTime" name="contact[Available_Time]" placeholder="e.g. 9am to 6pm, or Any time">
          </div>

          <div class="qb-field">
            <label for="ApplyNote">Notes / Message</label>
            <textarea id="ApplyNote" name="contact[body]" rows="4" placeholder="Anything else you want to tell us?"></textarea>
          </div>
        </div>

        <div class="qb-apply-footer">
          <button type="submit" class="qb-submit-btn">Send Application</button>
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

<style>
:root {
  --qb-purple: #7a14ac;
  --qb-black: #111111;
  --qb-light: #f4f4f4;
  --qb-border: #e0e0e0;
}

.qb-apply-section {
  padding: 40px 16px 120px;
  background: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

.qb-apply-container {
  max-width: 500px;
  margin: 0 auto;
}

.qb-apply-header {
  text-align: center;
  margin-bottom: 32px;
}

.qb-apply-header h1 {
  font-size: 24px;
  font-weight: 800;
  color: var(--qb-black);
  margin-bottom: 8px;
}

.qb-apply-header p {
  font-size: 15px;
  color: #666;
}

.qb-form-body {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.qb-field label {
  display: block;
  font-size: 13px;
  font-weight: 700;
  color: var(--qb-black);
  margin-bottom: 6px;
}

.qb-field input, 
.qb-field textarea {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid var(--qb-border);
  border-radius: 10px;
  font-size: 15px;
  background: var(--qb-light);
  transition: all 0.2s ease;
  color: var(--qb-black);
  -webkit-appearance: none;
}

.qb-field input:focus, 
.qb-field textarea:focus {
  outline: none;
  border-color: var(--qb-purple);
  background: #fff;
}

.qb-apply-success {
  text-align: center;
  padding: 40px 20px;
  background: #f9f9f9;
  border-radius: 20px;
}

.success-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.qb-btn-secondary {
  margin-top: 20px;
  padding: 10px 20px;
  background: var(--qb-black);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 700;
  cursor: pointer;
}

.qb-apply-footer {
  margin-top: 32px;
}

@media (max-width: 767px) {
  .qb-apply-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px;
    background: white;
    border-top: 1px solid var(--qb-border);
    z-index: 1000;
  }
}

.qb-submit-btn {
  width: 100%;
  padding: 16px;
  background: var(--qb-purple);
  color: white;
  border: none;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
}

.animate-fade-in {
  animation: fadeIn 0.5s ease-out forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>

{% schema %}
{
  "name": "Rider Application Form",
  "settings": [],
  "presets": [
    {
      "name": "Rider Application Form"
    }
  ]
}
{% endschema %}