<!-- sections/delivery-rider-application.liquid -->
<div class="rider-page">

  <!-- ── Hero ── -->
  <div class="rider-hero">
    <div class="rider-hero-bg"></div>
    <div class="rider-hero-content">
      <div class="rider-hero-tag">🛵 Now Hiring</div>
      <h1 class="rider-hero-title">Ride with<br><span class="rider-hero-accent">QuickBee</span></h1>
      <p class="rider-hero-sub">Earn great money on your own schedule. Apply in under 2 minutes.</p>
    </div>
    <div class="rider-perks">
      <div class="rider-perk">
        <div class="rider-perk-icon">💰</div>
        <div class="rider-perk-label">Up to Rs 40K/mo</div>
      </div>
      <div class="rider-perk-divider"></div>
      <div class="rider-perk">
        <div class="rider-perk-icon">🕐</div>
        <div class="rider-perk-label">Flexible Hours</div>
      </div>
      <div class="rider-perk-divider"></div>
      <div class="rider-perk">
        <div class="rider-perk-icon">⚡</div>
        <div class="rider-perk-label">Weekly Payout</div>
      </div>
    </div>
  </div>

  <!-- ── Form ── -->
  <div class="rider-form-wrap">

    {%- form 'contact', id: 'RiderApplicationForm', class: 'rider-form' -%}
      {%- if form.posted_successfully? -%}

        <div class="rider-success">
          <div class="rider-success-emoji">🎉</div>
          <h2>Application Received!</h2>
          <p>We've got your details. Our team will reach out within <strong>24–48 hours</strong>. Get ready to ride!</p>
          <a href="/" class="rider-back-btn">Back to Home</a>
        </div>

      {%- else -%}

        <input type="hidden" name="contact[email]" id="HiddenEmail" value="rider-{{ "now" | date: "%H%M%S" }}@quickbee.store">

        <!-- Section 1: Personal Info -->
        <div class="rider-section">
          <div class="rider-section-head">
            <span class="rider-section-num">01</span>
            <div>
              <div class="rider-section-title">Personal Info</div>
              <div class="rider-section-sub">Tell us a bit about yourself</div>
            </div>
          </div>
          <div class="rider-fields">
            <div class="rider-field">
              <label for="ApplyName">Full Name</label>
              <input type="text" id="ApplyName" name="contact[Full_Name]" placeholder="Your full name">
            </div>
            <div class="rider-field">
              <label for="ApplyPhone">Phone Number <span class="req">*</span></label>
              <input type="tel" id="ApplyPhone" name="contact[phone]" placeholder="98XXXXXXXX" required>
            </div>
            <div class="rider-field-row">
              <div class="rider-field">
                <label for="ApplyAge">Age</label>
                <input type="text" id="ApplyAge" name="contact[Age]" placeholder="Your age">
              </div>
              <div class="rider-field">
                <label for="ApplyLocation">Location</label>
                <input type="text" id="ApplyLocation" name="contact[Location]" placeholder="City / Area">
              </div>
            </div>
          </div>
        </div>

        <!-- Section 2: Vehicle Info -->
        <div class="rider-section">
          <div class="rider-section-head">
            <span class="rider-section-num">02</span>
            <div>
              <div class="rider-section-title">Vehicle Details</div>
              <div class="rider-section-sub">What are you riding?</div>
            </div>
          </div>
          <div class="rider-fields">
            <div class="rider-field">
              <label>Vehicle Type</label>
              <div class="rider-vehicle-picker">
                <label class="vehicle-option">
                  <input type="radio" name="contact[Vehicle_Type]" value="Bike">
                  <span>🏍️ Bike</span>
                </label>
                <label class="vehicle-option">
                  <input type="radio" name="contact[Vehicle_Type]" value="Scooter">
                  <span>🛵 Scooter</span>
                </label>
                <label class="vehicle-option">
                  <input type="radio" name="contact[Vehicle_Type]" value="Electric">
                  <span>⚡ Electric</span>
                </label>
                <label class="vehicle-option">
                  <input type="radio" name="contact[Vehicle_Type]" value="Other">
                  <span>🚗 Other</span>
                </label>
              </div>
            </div>
            <div class="rider-field-row">
              <div class="rider-field">
                <label for="ApplyVehicleNum">Plate Number</label>
                <input type="text" id="ApplyVehicleNum" name="contact[Vehicle_No]" placeholder="BA 1 PA 1234">
              </div>
              <div class="rider-field">
                <label for="ApplyLicenseNum">License No.</label>
                <input type="text" id="ApplyLicenseNum" name="contact[License_No]" placeholder="License number">
              </div>
            </div>
          </div>
        </div>

        <!-- Section 3: Delivery IQ -->
        <div class="rider-section rider-iq-section">
          <div class="rider-section-head">
            <span class="rider-section-num iq-num">🧠</span>
            <div>
              <div class="rider-section-title">Delivery IQ Check</div>
              <div class="rider-section-sub">3 quick questions — no wrong answers, just honest ones</div>
            </div>
          </div>
          <div class="rider-fields">

            <div class="rider-iq-q">
              <p class="iq-question">1. A customer doesn't answer the door or phone for 10 minutes. What do you do?</p>
              <div class="iq-options">
                <label class="iq-option"><input type="radio" name="contact[IQ_Q1]" value="Leave at door and go"><span>Leave it at the door and go</span></label>
                <label class="iq-option"><input type="radio" name="contact[IQ_Q1]" value="Call Support and wait for instructions"><span>Call support and wait for instructions</span></label>
                <label class="iq-option"><input type="radio" name="contact[IQ_Q1]" value="Take the food and finish shift"><span>Take the food home</span></label>
              </div>
            </div>

            <div class="rider-iq-q">
              <p class="iq-question">2. A drink spills slightly inside the bag. Best action?</p>
              <div class="iq-options">
                <label class="iq-option"><input type="radio" name="contact[IQ_Q2]" value="Wipe it and deliver silently"><span>Wipe it and deliver without saying anything</span></label>
                <label class="iq-option"><input type="radio" name="contact[IQ_Q2]" value="Inform customer, apologize, and contact support"><span>Tell the customer, apologize & contact support</span></label>
                <label class="iq-option"><input type="radio" name="contact[IQ_Q2]" value="Tell the customer it was the restaurant's fault"><span>Blame the restaurant</span></label>
              </div>
            </div>

            <div class="rider-iq-q">
              <p class="iq-question">3. The most important part of being a QuickBee rider is?</p>
              <div class="iq-options">
                <label class="iq-option"><input type="radio" name="contact[IQ_Q3]" value="Speed - Driving as fast as possible"><span>Driving as fast as possible</span></label>
                <label class="iq-option"><input type="radio" name="contact[IQ_Q3]" value="Safety - Delivering items in perfect condition"><span>Delivering safely and in perfect condition</span></label>
                <label class="iq-option"><input type="radio" name="contact[IQ_Q3]" value="Earnings - Completing most orders by any means"><span>Completing the most orders, any way possible</span></label>
              </div>
            </div>

          </div>
        </div>

        <!-- Section 4: Availability -->
        <div class="rider-section">
          <div class="rider-section-head">
            <span class="rider-section-num">03</span>
            <div>
              <div class="rider-section-title">Availability & Pay</div>
              <div class="rider-section-sub">When can you ride?</div>
            </div>
          </div>
          <div class="rider-fields">
            <div class="rider-field">
              <label for="ApplyAreas">Areas You Know Best</label>
              <input type="text" id="ApplyAreas" name="contact[Areas_Covered]" placeholder="e.g. Thamel, Baneshwor, Lalitpur">
            </div>
            <div class="rider-field-row">
              <div class="rider-field">
                <label for="ApplyTime">Availability</label>
                <input type="text" id="ApplyTime" name="contact[Available_Time]" placeholder="Full Time / Morning…">
              </div>
              <div class="rider-field">
                <label for="ApplySalary">Expected Salary</label>
                <input type="text" id="ApplySalary" name="contact[Expected_Salary]" placeholder="Rs. 20,000 + fuel">
              </div>
            </div>
            <div class="rider-field">
              <label for="ApplyNote">Anything else to add?</label>
              <textarea id="ApplyNote" name="contact[body]" rows="3" placeholder="Optional message..."></textarea>
            </div>
          </div>
        </div>

        <!-- Submit -->
        <div class="rider-submit-wrap">
          <button type="submit" class="rider-submit-btn" id="SubmitBtn">
            <span id="SubmitBtnText">Send Application 🚀</span>
          </button>
          <p class="rider-submit-note">By applying you agree to QuickBee's rider terms & conditions.</p>
        </div>

      {%- endif -%}
    {%- endform -%}
  </div>

</div>

<script>
  // ── Web3Forms key (same key as location modal) ──
  // Get yours free at https://web3forms.com
  var RIDER_W3F_KEY = 'WEB3FORMS_KEY'; // ← paste your key here

  document.addEventListener('DOMContentLoaded', function () {
    var form    = document.getElementById('RiderApplicationForm');
    var btn     = document.getElementById('SubmitBtn');
    var btnText = document.getElementById('SubmitBtnText');

    if (form && btn) {
      form.addEventListener('submit', function (e) {
        e.preventDefault(); // stop Shopify's throttled /contact submission

        if (btnText) btnText.innerHTML = 'Sending… ⏳';
        btn.disabled = true;
        btn.style.opacity = '0.75';

        // Collect all form fields into an object
        var fd = new FormData(form);
        var payload = { access_key: RIDER_W3F_KEY, subject: 'New QuickBee Rider Application' };
        fd.forEach(function (val, key) {
          // Clean up Shopify's contact[field] naming → just field
          var cleanKey = key.replace(/^contact\[/, '').replace(/\]$/, '');
          if (cleanKey !== 'email') payload[cleanKey] = val; // skip the generated hidden email
        });
        payload['Timestamp'] = new Date().toLocaleString();

        function trySubmit(attempt) {
          fetch('https://api.web3forms.com/submit', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body:    JSON.stringify(payload)
          })
          .then(function (r) { return r.json(); })
          .then(function (res) {
            if (res.success) {
              // Show the Liquid success block by replacing form HTML
              form.innerHTML = '<div class="rider-success">' +
                '<div class="rider-success-emoji">🎉</div>' +
                '<h2>Application Received!</h2>' +
                '<p>We\'ve got your details. Our team will reach out within <strong>24–48 hours</strong>. Get ready to ride!</p>' +
                '<a href="/" class="rider-back-btn">Back to Home</a>' +
                '</div>';
            } else {
              throw new Error(res.message || 'Submission failed');
            }
          })
          .catch(function (err) {
            if (attempt < 1) {
              setTimeout(function () { trySubmit(1); }, 1200);
            } else {
              if (btnText) btnText.innerHTML = 'Submit Application 🚀';
              btn.disabled = false;
              btn.style.opacity = '1';
              alert('Submission failed. Please check your connection and try again.');
              console.warn('[QB Rider] Submit failed:', err);
            }
          });
        }

        trySubmit(0);
      });
    }

    // Vehicle type card highlight
    document.querySelectorAll('.vehicle-option input').forEach(function(radio) {
      radio.addEventListener('change', function() {
        document.querySelectorAll('.vehicle-option').forEach(function(el) { el.classList.remove('selected'); });
        if (radio.checked) radio.closest('.vehicle-option').classList.add('selected');
      });
    });

    // IQ option highlight
    document.querySelectorAll('.iq-option input').forEach(function(radio) {
      radio.addEventListener('change', function() {
        var group = radio.closest('.iq-options');
        group.querySelectorAll('.iq-option').forEach(function(el) { el.classList.remove('selected'); });
        if (radio.checked) radio.closest('.iq-option').classList.add('selected');
      });
    });
  });
</script>

<style>
/* ──────────────────────────────────────
   BASE
────────────────────────────────────── */
.rider-page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120px;
}
[data-theme="dark"] .rider-page { background: #111; }

/* ──────────────────────────────────────
   HERO
────────────────────────────────────── */
.rider-hero {
  position: relative;
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 40px 20px 0;
  overflow: hidden;
}

.rider-hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 90% 10%, rgba(244,180,0,0.18) 0%, transparent 55%),
    radial-gradient(ellipse at 10% 80%, rgba(244,180,0,0.10) 0%, transparent 50%);
  pointer-events: none;
}

.rider-hero-content {
  position: relative;
  z-index: 2;
  max-width: 500px;
  margin: 0 auto;
  padding-bottom: 32px;
}

.rider-hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(244,180,0,0.18);
  border: 1px solid rgba(244,180,0,0.4);
  color: #F4B400;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.05em;
  padding: 5px 14px;
  border-radius: 999px;
  margin-bottom: 16px;
  text-transform: uppercase;
}

.rider-hero-title {
  font-size: 2.8rem;
  font-weight: 900;
  color: #fff;
  line-height: 1.05;
  margin: 0 0 12px;
  letter-spacing: -0.03em;
}

.rider-hero-accent {
  color: #F4B400;
  position: relative;
}

.rider-hero-sub {
  font-size: 15px;
  color: rgba(255,255,255,0.65);
  margin: 0;
  line-height: 1.5;
  max-width: 340px;
}

/* Perks strip */
.rider-perks {
  position: relative;
  z-index: 2;
  max-width: 500px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.1);
  border-bottom: none;
  border-radius: 20px 20px 0 0;
  padding: 16px 20px;
}

.rider-perk {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.rider-perk-icon { font-size: 22px; line-height: 1; }

.rider-perk-label {
  font-size: 11px;
  font-weight: 700;
  color: rgba(255,255,255,0.75);
  text-align: center;
  letter-spacing: 0.02em;
  white-space: nowrap;
}

.rider-perk-divider {
  width: 1px;
  height: 32px;
  background: rgba(255,255,255,0.15);
}

/* ──────────────────────────────────────
   FORM WRAP
────────────────────────────────────── */
.rider-form-wrap {
  max-width: 500px;
  margin: 0 auto;
  padding: 0 16px;
}

.rider-form { display: flex; flex-direction: column; gap: 12px; }

/* ──────────────────────────────────────
   SECTION CARDS
────────────────────────────────────── */
.rider-section {
  background: #fff;
  border-radius: 20px;
  padding: 24px 20px 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  margin-top: 12px;
}
[data-theme="dark"] .rider-section {
  background: #1c1c1c;
  box-shadow: 0 2px 12px rgba(0,0,0,0.3);
}

.rider-section-head {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
}

.rider-section-num {
  width: 36px;
  height: 36px;
  min-width: 36px;
  background: #F4B400;
  color: #000;
  font-size: 13px;
  font-weight: 900;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: -0.5px;
}

.iq-num { font-size: 18px; }

.rider-section-title {
  font-size: 15px;
  font-weight: 800;
  color: #111;
  line-height: 1.2;
}
[data-theme="dark"] .rider-section-title { color: #f0f0f0; }

.rider-section-sub {
  font-size: 12px;
  color: #888;
  margin-top: 2px;
}
[data-theme="dark"] .rider-section-sub { color: #666; }

/* ──────────────────────────────────────
   FIELDS
────────────────────────────────────── */
.rider-fields { display: flex; flex-direction: column; gap: 14px; }

.rider-field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.rider-field label {
  display: block;
  font-size: 12px;
  font-weight: 700;
  color: #555;
  margin-bottom: 7px;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}
[data-theme="dark"] .rider-field label { color: #888; }

.req { color: #F4B400; }

.rider-field input[type="text"],
.rider-field input[type="tel"],
.rider-field textarea {
  width: 100%;
  padding: 13px 15px;
  border: 1.5px solid #e8e8e8;
  border-radius: 12px;
  font-size: 15px;
  background: #fafafa;
  color: #111;
  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  box-sizing: border-box;
  -webkit-appearance: none;
}

.rider-field input:focus,
.rider-field textarea:focus {
  outline: none;
  border-color: #F4B400;
  background: #fff;
  box-shadow: 0 0 0 4px rgba(244,180,0,0.1);
}

[data-theme="dark"] .rider-field input[type="text"],
[data-theme="dark"] .rider-field input[type="tel"],
[data-theme="dark"] .rider-field textarea {
  background: #242424;
  border-color: #333;
  color: #f0f0f0;
}

[data-theme="dark"] .rider-field input::placeholder,
[data-theme="dark"] .rider-field textarea::placeholder {
  color: #555;
}

[data-theme="dark"] .rider-field input:focus,
[data-theme="dark"] .rider-field textarea:focus {
  background: #2a2a2a;
  border-color: #F4B400;
  box-shadow: 0 0 0 4px rgba(244,180,0,0.1);
}

/* ──────────────────────────────────────
   VEHICLE PICKER
────────────────────────────────────── */
.rider-vehicle-picker {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.vehicle-option {
  display: flex;
  cursor: pointer;
}

.vehicle-option input { display: none; }

.vehicle-option span {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  padding: 12px 10px;
  border: 1.5px solid #e8e8e8;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
  color: #555;
  background: #fafafa;
  transition: all 0.2s;
}

.vehicle-option.selected span,
.vehicle-option input:checked + span {
  border-color: #F4B400;
  background: #FFF8E1;
  color: #111;
}

[data-theme="dark"] .vehicle-option span {
  background: #242424;
  border-color: #333;
  color: #888;
}

[data-theme="dark"] .vehicle-option.selected span,
[data-theme="dark"] .vehicle-option input:checked + span {
  border-color: #F4B400;
  background: rgba(244,180,0,0.1);
  color: #F4B400;
}

/* ──────────────────────────────────────
   IQ SECTION
────────────────────────────────────── */
.rider-iq-section {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%) !important;
  box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
}

[data-theme="dark"] .rider-iq-section {
  background: linear-gradient(135deg, #0d0d1a 0%, #0f1929 100%) !important;
}

.rider-iq-section .rider-section-head { margin-bottom: 16px; }
.rider-iq-section .rider-section-title { color: #fff !important; }
.rider-iq-section .rider-section-sub { color: rgba(255,255,255,0.45) !important; }

.rider-iq-q { margin-bottom: 4px; }

.iq-question {
  font-size: 13px;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
  margin: 0 0 10px;
  line-height: 1.5;
}

.iq-options {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 16px;
}

.iq-option {
  display: flex;
  align-items: center;
  cursor: pointer;
}

.iq-option input { display: none; }

.iq-option span {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 11px 14px;
  border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 11px;
  font-size: 13px;
  font-weight: 500;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.05);
  transition: all 0.2s;
  line-height: 1.4;
}

.iq-option span::before {
  content: '';
  width: 16px;
  height: 16px;
  min-width: 16px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.3);
  margin-right: 10px;
  transition: all 0.2s;
}

.iq-option.selected span,
.iq-option input:checked + span {
  border-color: #F4B400;
  background: rgba(244,180,0,0.12);
  color: #F4B400;
}

.iq-option.selected span::before,
.iq-option input:checked + span::before {
  border-color: #F4B400;
  background: #F4B400;
  box-shadow: 0 0 0 3px rgba(244,180,0,0.2);
}

/* ──────────────────────────────────────
   SUBMIT
────────────────────────────────────── */
.rider-submit-wrap {
  padding: 8px 0 16px;
  text-align: center;
}

.rider-submit-btn {
  width: 100%;
  padding: 17px;
  background: #F4B400;
  color: #000;
  border: none;
  border-radius: 16px;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  box-shadow: 0 6px 20px rgba(244,180,0,0.35);
  transition: all 0.2s ease;
  -webkit-appearance: none;
  appearance: none;
  letter-spacing: -0.2px;
}

.rider-submit-btn:hover { box-shadow: 0 8px 28px rgba(244,180,0,0.45); transform: translateY(-1px); }
.rider-submit-btn:active { transform: scale(0.98); box-shadow: none; }

.rider-submit-note {
  font-size: 11px;
  color: #aaa;
  margin-top: 10px;
}
[data-theme="dark"] .rider-submit-note { color: #555; }

/* ──────────────────────────────────────
   SUCCESS STATE
────────────────────────────────────── */
.rider-success {
  background: #fff;
  border-radius: 24px;
  padding: 48px 24px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  margin-top: 12px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.07);
  animation: riderSuccessIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

[data-theme="dark"] .rider-success { background: #1c1c1c; }

.rider-success-emoji { font-size: 64px; line-height: 1; }

.rider-success h2 {
  font-size: 24px;
  font-weight: 900;
  color: #111;
  margin: 0;
  letter-spacing: -0.5px;
}
[data-theme="dark"] .rider-success h2 { color: #f0f0f0; }

.rider-success p {
  font-size: 15px;
  color: #555;
  margin: 0;
  line-height: 1.6;
  max-width: 300px;
}
[data-theme="dark"] .rider-success p { color: #777; }

.rider-back-btn {
  margin-top: 8px;
  display: inline-block;
  padding: 14px 36px;
  background: #F4B400;
  color: #000;
  border-radius: 14px;
  font-size: 15px;
  font-weight: 800;
  text-decoration: none;
  transition: opacity 0.2s;
}
.rider-back-btn:hover { opacity: 0.85; }

@keyframes riderSuccessIn {
  from { opacity: 0; transform: scale(0.9) translateY(20px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

/* ──────────────────────────────────────
   RESPONSIVE
────────────────────────────────────── */
@media (max-width: 400px) {
  .rider-hero-title { font-size: 2.2rem; }
  .rider-field-row { grid-template-columns: 1fr; }
  .rider-vehicle-picker { grid-template-columns: 1fr 1fr; }
}
