<section class="testimonials-section">
  <h2>{{ section.settings.title }}</h2>
  <p>{{ section.settings.description }}</p>
  {% if section.settings.show_stats %}
    <div class="testimonials-stats">
      <div class="stat">⭐ {{ section.settings.average_rating }}/5</div>
      <div class="stat">{{ section.settings.total_reviews }} reviews</div>
      <div class="stat">✓ {{ section.settings.verified_buyers }} verified</div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Product Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "See what customers say about our products"
    },
    {
      "type": "text",
      "id": "total_reviews",
      "label": "Total Reviews",
      "default": "1000+"
    },
    {
      "type": "text",
      "id": "average_rating",
      "label": "Average Rating",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "verified_buyers",
      "label": "Verified Buyers %",
      "default": "95%"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show Statistics",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Testimonials"
    }
  ]
}
{% endschema %}
