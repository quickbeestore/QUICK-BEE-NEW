      </div>
      <div class="ses-trust-item">
        <span class="ses-trust-item__icon">🍯</span>
        <span class="ses-trust-item__title">Fresh Made</span>
        <span class="ses-trust-item__sub">Crafted for the season</span>
      </div>
      <div class="ses-trust-item">
        <span class="ses-trust-item__icon">🚀</span>
        <span class="ses-trust-item__title">Timely Delivery</span>
        <span class="ses-trust-item__sub">Before the occasion</span>
      </div>
      <div class="ses-trust-item">
        <span class="ses-trust-item__icon">✅</span>
