<script>
(function () {
  'use strict';

  /* ── Active variant tracking ── */
  var activeVariantId = {{ product.selected_or_first_available_variant.id }};

  /* ── Variant pills ── */
  var pills = document.querySelectorAll('.ses-variant-pill');
  var priceEl   = document.getElementById('ses-price-current');
  var compareEl = document.getElementById('ses-price-compare');
  var saveEl    = document.getElementById('ses-price-save');

  pills.forEach(function(pill){
    pill.addEventListener('click', function(){
      pills.forEach(function(p){ p.classList.remove('is-active'); p.setAttribute('aria-pressed','false'); });
      this.classList.add('is-active');
      this.setAttribute('aria-pressed','true');
      activeVariantId = parseInt(this.dataset.variantId, 10);
      if(priceEl)   priceEl.textContent   = this.dataset.price;
      var cRaw = parseInt(this.dataset.compareRaw || '0', 10);
      var pRaw = parseInt(this.dataset.priceRaw   || '0', 10);
      if(cRaw > pRaw){
        if(compareEl){ compareEl.textContent = this.dataset.compare; compareEl.style.display = ''; }
        if(saveEl){
          var diff = ((cRaw - pRaw)/100).toFixed(2);
          saveEl.textContent = 'Save ₹' + diff; saveEl.style.display = '';
        }
      } else {
        if(compareEl) compareEl.style.display = 'none';
        if(saveEl)    saveEl.style.display    = 'none';
      }
    }.bind(pill));
  });

  /* ── Quantity stepper ── */
  var qtyInput = document.getElementById('ses-qty');
  var minusBtn = document.getElementById('ses-qty-minus');
  var plusBtn  = document.getElementById('ses-qty-plus');
  var QTY_MAX  = 10;

  function updateQtyBtns(){
    var v = parseInt(qtyInput.value, 10);
    minusBtn.disabled = v <= 1;
    plusBtn.disabled  = v >= QTY_MAX;
  }
  updateQtyBtns();

  minusBtn.addEventListener('click', function(){
    var v = parseInt(qtyInput.value, 10);
    if(v > 1){ qtyInput.value = v - 1; updateQtyBtns(); }
  });
  plusBtn.addEventListener('click', function(){
    var v = parseInt(qtyInput.value, 10);
    if(v < QTY_MAX){ qtyInput.value = v + 1; updateQtyBtns(); }
  });

  /* ── Add to cart ── */
  var addBtn    = document.getElementById('ses-add-btn');
  var feedback  = document.getElementById('ses-feedback');
  var giftEl    = document.getElementById('ses-giftwrap');
  var msgEl     = document.getElementById('ses-message');

  addBtn.addEventListener('click', function(){
    var qty      = parseInt(qtyInput.value, 10);
    var giftWrap = giftEl && giftEl.checked ? 'Yes' : 'No';
    var message  = msgEl ? msgEl.value.trim() : '';
    var season   = addBtn.dataset.season || '';

    var payload = {
      id:         activeVariantId,
      quantity:   qty,
      properties: {
        'Season':    season,
        'Gift Wrap': giftWrap,
        'Message':   message
      }
    };

    addBtn.disabled    = true;
    addBtn.textContent = 'Adding…';
    feedback.className = 'ses-feedback';
    feedback.textContent = '';

    fetch('/cart/add.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body:    JSON.stringify(payload)
    })
    .then(function(r){
      if(!r.ok) return r.json().then(function(d){ throw new Error(d.description || 'Error adding to cart'); });
      return r.json();
    })
    .then(function(){
      feedback.className   = 'ses-feedback is-success';
      feedback.textContent = '🎉 Added to cart! Your festive treat is waiting.';
      addBtn.textContent   = '✓ ADDED!';
      setTimeout(function(){
        addBtn.disabled    = false;
        addBtn.textContent = '🛒 ADD TO CART';
      }, 2400);
      document.dispatchEvent(new CustomEvent('cart:updated'));
    })
    .catch(function(err){
      feedback.className   = 'ses-feedback is-error';
      feedback.textContent = '⚠ ' + err.message;
      addBtn.disabled      = false;
      addBtn.textContent   = '🛒 ADD TO CART';
    });
  });
})();
</script>

