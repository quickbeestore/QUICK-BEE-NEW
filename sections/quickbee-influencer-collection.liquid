{% comment %} QuickBee Influencer Application Form {% endcomment %}

<style>
.qbif-page {
  background: #0a0a0a;
  min-height: 100vh;
  color: #f0f0f0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  overflow-x: hidden;
}

/* HERO */
.qbif-hero {
  background: linear-gradient(160deg, #0a0a0a 0%, #1a1033 50%, #0a1a1a 100%);
  padding: 60px 20px 48px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.qbif-hero::before {
  content: '';
  position: absolute;
  top: -60px; left: 50%; transform: translateX(-50%);
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(251,191,36,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.qbif-hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(251,191,36,0.12); border: 1px solid rgba(251,191,36,0.3);
  color: #fbbf24; padding: 8px 18px; border-radius: 24px;
  font-size: 13px; font-weight: 600; letter-spacing: 0.5px; margin-bottom: 20px;
}
.qbif-hero-title {
  font-size: clamp(28px, 7vw, 52px); font-weight: 900; line-height: 1.1;
  background: linear-gradient(135deg, #fff 0%, #fbbf24 50%, #f59e0b 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  margin: 0 0 14px;
}
.qbif-hero-sub {
  font-size: 16px; color: #888; max-width: 560px; margin: 0 auto 32px; line-height: 1.7;
}
.qbif-stats {
  display: flex; gap: 24px; justify-content: center; flex-wrap: wrap;
}
.qbif-stat {
  background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px; padding: 14px 24px; text-align: center;
}
.qbif-stat-val { font-size: 22px; font-weight: 800; color: #fbbf24; }
.qbif-stat-lbl { font-size: 11px; color: #666; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }

/* FORM CONTAINER */
.qbif-container {
  max-width: 720px; margin: 0 auto; padding: 40px 20px 80px;
}
.qbif-card {
  background: #111; border: 1px solid rgba(255,255,255,0.08);
  border-radius: 20px; padding: 32px 28px; margin-bottom: 20px;
}
@media(max-width: 600px){ .qbif-card { padding: 24px 20px; } }
.qbif-section-title {
  font-size: 16px; font-weight: 800; color: #fbbf24; margin: 0 0 24px;
  display: flex; align-items: center; gap: 8px;
}
.qbif-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media(max-width: 520px){ .qbif-row { grid-template-columns: 1fr; } }
.qbif-field { margin-bottom: 18px; }
.qbif-label {
  display: block; font-size: 12px; font-weight: 600; color: #aaa;
  text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;
}
.qbif-label span { color: #ef4444; }
.qbif-input, .qbif-select, .qbif-textarea {
  width: 100%; padding: 13px 16px; background: #1a1a1a; border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 12px; color: #f0f0f0; font-size: 14px; font-family: inherit;
  transition: border-color 0.2s, box-shadow 0.2s; box-sizing: border-box; outline: none;
}
.qbif-input:focus, .qbif-select:focus, .qbif-textarea:focus {
  border-color: #fbbf24; box-shadow: 0 0 0 3px rgba(251,191,36,0.12);
}
.qbif-select { appearance: none; cursor: pointer; }
.qbif-textarea { resize: vertical; min-height: 100px; line-height: 1.6; }

/* PLATFORM CHECKBOXES */
.qbif-platforms { display: flex; flex-wrap: wrap; gap: 10px; }
.qbif-platform-cb { position: absolute; opacity: 0; pointer-events: none; }
.qbif-platform-lbl {
  display: flex; align-items: center; gap: 7px;
  background: #1a1a1a; border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 24px; padding: 8px 16px; font-size: 13px; font-weight: 600; cursor: pointer;
  transition: all 0.2s; user-select: none;
}
.qbif-platform-lbl:hover { border-color: rgba(251,191,36,0.4); }
.qbif-platform-cb:checked + .qbif-platform-lbl {
  background: rgba(251,191,36,0.12); border-color: #fbbf24; color: #fbbf24;
}

/* HANDLES TABLE */
.qbif-handles { display: none; margin-top: 20px; }
.qbif-handles.qbif-show { display: block; }
.qbif-handle-row {
  display: flex; align-items: center; gap: 10px; margin-bottom: 12px;
}
.qbif-handle-icon { font-size: 18px; width: 28px; text-align: center; flex-shrink: 0; }
.qbif-handle-prefix { font-size: 13px; color: #666; }

/* FOLLOWER RANGE BUTTONS */
.qbif-ranges { display: flex; flex-wrap: wrap; gap: 10px; }
.qbif-range-radio { position: absolute; opacity: 0; pointer-events: none; }
.qbif-range-lbl {
  background: #1a1a1a; border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 10px; padding: 10px 16px; font-size: 13px; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.qbif-range-lbl:hover { border-color: rgba(251,191,36,0.4); }
.qbif-range-radio:checked + .qbif-range-lbl {
  background: rgba(251,191,36,0.12); border-color: #fbbf24; color: #fbbf24;
}

/* SUBMIT BTN */
.qbif-submit-wrap { text-align: center; margin-top: 10px; }
.qbif-submit {
  display: inline-flex; align-items: center; gap: 10px;
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: #000; border: none; padding: 18px 48px;
  border-radius: 50px; font-size: 16px; font-weight: 800;
  cursor: pointer; transition: transform 0.15s, box-shadow 0.2s;
  box-shadow: 0 8px 32px rgba(251,191,36,0.3); letter-spacing: 0.3px;
}
.qbif-submit:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(251,191,36,0.45); }
.qbif-submit:active { transform: scale(0.97); }
.qbif-submit:disabled { background: #333; color: #666; cursor: default; transform: none; box-shadow: none; }
.qbif-disclaimer {
  font-size: 12px; color: #555; margin-top: 14px; line-height: 1.6;
  max-width: 440px; margin-left: auto; margin-right: auto;
}

/* PERKS */
.qbif-perks { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 32px; }
@media(max-width: 520px){ .qbif-perks { grid-template-columns: 1fr 1fr; } }
.qbif-perk {
  background: rgba(251,191,36,0.06); border: 1px solid rgba(251,191,36,0.15);
  border-radius: 14px; padding: 18px 14px; text-align: center;
}
.qbif-perk-icon { font-size: 28px; margin-bottom: 8px; }
.qbif-perk-title { font-size: 13px; font-weight: 700; color: #fbbf24; margin-bottom: 4px; }
.qbif-perk-desc { font-size: 11px; color: #666; line-height: 1.5; }
</style>

<div class="qbif-page">

  <!-- HERO -->
  <div class="qbif-hero">
    <div class="qbif-hero-badge">⭐ Creator Program</div>
    <h1 class="qbif-hero-title">Become a QuickBee<br>Influencer</h1>
    <p class="qbif-hero-sub">Partner with Nepal's fastest-growing delivery platform. Share exclusive deals, earn commissions, and grow your audience with QuickBee.</p>
    <div class="qbif-stats">
      <div class="qbif-stat"><div class="qbif-stat-val">500+</div><div class="qbif-stat-lbl">Creators</div></div>
      <div class="qbif-stat"><div class="qbif-stat-val">2M+</div><div class="qbif-stat-lbl">Combined Reach</div></div>
      <div class="qbif-stat"><div class="qbif-stat-val">20%</div><div class="qbif-stat-lbl">Commission</div></div>
    </div>
  </div>

  <div class="qbif-container">

    <!-- PERKS -->
    <div class="qbif-perks">
      <div class="qbif-perk">
        <div class="qbif-perk-icon">💰</div>
        <div class="qbif-perk-title">Earn Cash</div>
        <div class="qbif-perk-desc">Commission on every order through your code</div>
      </div>
      <div class="qbif-perk">
        <div class="qbif-perk-icon">🎁</div>
        <div class="qbif-perk-title">Free Products</div>
        <div class="qbif-perk-desc">Monthly gifting from our partner brands</div>
      </div>
      <div class="qbif-perk">
        <div class="qbif-perk-icon">📊</div>
        <div class="qbif-perk-title">Analytics</div>
        <div class="qbif-perk-desc">Real-time dashboard and performance insights</div>
      </div>
      <div class="qbif-perk">
        <div class="qbif-perk-icon">🚀</div>
        <div class="qbif-perk-title">Early Access</div>
        <div class="qbif-perk-desc">First to know about launches and deals</div>
      </div>
      <div class="qbif-perk">
        <div class="qbif-perk-icon">🤝</div>
        <div class="qbif-perk-title">Collabs</div>
        <div class="qbif-perk-desc">Brand partnerships and paid campaigns</div>
      </div>
      <div class="qbif-perk">
        <div class="qbif-perk-icon">🏆</div>
        <div class="qbif-perk-title">Recognition</div>
        <div class="qbif-perk-desc">Featured on QuickBee's official channels</div>
      </div>
    </div>

    <form id="qbifForm" onsubmit="qbifSubmit(event)">

      <!-- PERSONAL INFO -->
      <div class="qbif-card">
        <div class="qbif-section-title">👤 Personal Information</div>
        <div class="qbif-row">
          <div class="qbif-field">
            <label class="qbif-label">Full Name <span>*</span></label>
            <input type="text" class="qbif-input" id="qbif-name" placeholder="Your full name" required>
          </div>
          <div class="qbif-field">
            <label class="qbif-label">Phone / WhatsApp <span>*</span></label>
            <input type="tel" class="qbif-input" id="qbif-phone" placeholder="98XXXXXXXX" required>
          </div>
        </div>
        <div class="qbif-row">
          <div class="qbif-field">
            <label class="qbif-label">Email Address <span>*</span></label>
            <input type="email" class="qbif-input" id="qbif-email" placeholder="you@email.com" required>
          </div>
          <div class="qbif-field">
            <label class="qbif-label">City / Location <span>*</span></label>
            <input type="text" class="qbif-input" id="qbif-city" placeholder="Kathmandu, Pokhara..." required>
          </div>
        </div>
      </div>

      <!-- SOCIAL PLATFORMS -->
      <div class="qbif-card">
        <div class="qbif-section-title">📲 Social Media Platforms</div>
        <div class="qbif-field">
          <label class="qbif-label">Active On <span>*</span></label>
          <div class="qbif-platforms">
            <label><input type="checkbox" class="qbif-platform-cb" name="platform" value="Instagram" id="pl-ig" onchange="qbifToggleHandles()"><span class="qbif-platform-lbl">📸 Instagram</span></label>
            <label><input type="checkbox" class="qbif-platform-cb" name="platform" value="TikTok" id="pl-tt" onchange="qbifToggleHandles()"><span class="qbif-platform-lbl">🎵 TikTok</span></label>
            <label><input type="checkbox" class="qbif-platform-cb" name="platform" value="YouTube" id="pl-yt" onchange="qbifToggleHandles()"><span class="qbif-platform-lbl">▶️ YouTube</span></label>
            <label><input type="checkbox" class="qbif-platform-cb" name="platform" value="Facebook" id="pl-fb" onchange="qbifToggleHandles()"><span class="qbif-platform-lbl">👥 Facebook</span></label>
            <label><input type="checkbox" class="qbif-platform-cb" name="platform" value="Twitter" id="pl-tw" onchange="qbifToggleHandles()"><span class="qbif-platform-lbl">𝕏 Twitter</span></label>
            <label><input type="checkbox" class="qbif-platform-cb" name="platform" value="Snapchat" id="pl-sc" onchange="qbifToggleHandles()"><span class="qbif-platform-lbl">👻 Snapchat</span></label>
          </div>
        </div>
        <div class="qbif-handles" id="qbifHandles">
          <label class="qbif-label" style="margin-bottom:14px">Your Handles</label>
          <div id="qbif-handle-rows"></div>
        </div>
      </div>

      <!-- REACH & NICHE -->
      <div class="qbif-card">
        <div class="qbif-section-title">📈 Your Reach</div>
        <div class="qbif-field">
          <label class="qbif-label">Total Followers (across all platforms) <span>*</span></label>
          <div class="qbif-ranges">
            <label><input type="radio" class="qbif-range-radio" name="followers" value="Under 1K" required><span class="qbif-range-lbl">Under 1K</span></label>
            <label><input type="radio" class="qbif-range-radio" name="followers" value="1K – 5K"><span class="qbif-range-lbl">1K – 5K</span></label>
            <label><input type="radio" class="qbif-range-radio" name="followers" value="5K – 20K"><span class="qbif-range-lbl">5K – 20K</span></label>
            <label><input type="radio" class="qbif-range-radio" name="followers" value="20K – 100K"><span class="qbif-range-lbl">20K – 100K</span></label>
            <label><input type="radio" class="qbif-range-radio" name="followers" value="100K – 500K"><span class="qbif-range-lbl">100K – 500K</span></label>
            <label><input type="radio" class="qbif-range-radio" name="followers" value="500K+"><span class="qbif-range-lbl">500K+</span></label>
          </div>
        </div>
        <div class="qbif-row" style="margin-top:16px">
          <div class="qbif-field">
            <label class="qbif-label">Content Niche <span>*</span></label>
            <select class="qbif-select" id="qbif-niche" required>
              <option value="" disabled selected>Select your niche</option>
              <option>Food & Lifestyle</option>
              <option>Travel & Adventure</option>
              <option>Fashion & Beauty</option>
              <option>Fitness & Health</option>
              <option>Tech & Gaming</option>
              <option>Entertainment & Comedy</option>
              <option>Business & Finance</option>
              <option>Education</option>
              <option>Other</option>
            </select>
          </div>
          <div class="qbif-field">
            <label class="qbif-label">Expected Rate (NPR/post)</label>
            <input type="text" class="qbif-input" id="qbif-rate" placeholder="e.g. 5,000 or Negotiable">
          </div>
        </div>
      </div>

      <!-- ABOUT YOU -->
      <div class="qbif-card">
        <div class="qbif-section-title">✍️ About You</div>
        <div class="qbif-field">
          <label class="qbif-label">Short Bio <span>*</span></label>
          <textarea class="qbif-textarea" id="qbif-bio" placeholder="Tell us about yourself, your content style, and your audience..." required></textarea>
        </div>
        <div class="qbif-field">
          <label class="qbif-label">Why QuickBee? <span>*</span></label>
          <textarea class="qbif-textarea" id="qbif-why" placeholder="Why do you want to partner with QuickBee? What value can you bring?" required style="min-height:80px"></textarea>
        </div>
        <div class="qbif-field">
          <label class="qbif-label">Preferred Collaboration Type</label>
          <select class="qbif-select" id="qbif-collab">
            <option value="" disabled selected>Select type</option>
            <option>Paid Promotions</option>
            <option>Product Reviews</option>
            <option>Affiliate / Commission Only</option>
            <option>Brand Ambassador</option>
            <option>All of the above</option>
          </select>
        </div>
      </div>

      <!-- SUBMIT -->
      <div class="qbif-submit-wrap">
        <button type="submit" class="qbif-submit" id="qbifSubmitBtn">
          🚀 Submit Application
        </button>
        <p class="qbif-disclaimer">By submitting, you agree that QuickBee may contact you at the details provided. Applications are reviewed within 3–5 business days.</p>
      </div>

    </form>
  </div>
</div>

<script>
(function(){
  var platformIcons = {
    'Instagram': { icon: '📸', prefix: '@' },
    'TikTok':    { icon: '🎵', prefix: '@' },
    'YouTube':   { icon: '▶️', prefix: '' },
    'Facebook':  { icon: '👥', prefix: '' },
    'Twitter':   { icon: '𝕏', prefix: '@' },
    'Snapchat':  { icon: '👻', prefix: '@' }
  };

  window.qbifToggleHandles = function(){
    var checked = [];
    document.querySelectorAll('.qbif-platform-cb:checked').forEach(function(cb){ checked.push(cb.value); });
    var container = document.getElementById('qbif-handle-rows');
    var handlesWrap = document.getElementById('qbifHandles');
    if(checked.length === 0){
      handlesWrap.classList.remove('qbif-show');
      container.innerHTML = '';
      return;
    }
    handlesWrap.classList.add('qbif-show');
    var html = '';
    checked.forEach(function(p){
      var info = platformIcons[p] || { icon: '🔗', prefix: '' };
      var existing = document.getElementById('qbif-handle-' + p);
      var val = existing ? existing.value : '';
      html += '<div class="qbif-handle-row">' +
        '<span class="qbif-handle-icon">' + info.icon + '</span>' +
        '<span class="qbif-handle-prefix">' + info.prefix + '</span>' +
        '<input type="text" class="qbif-input" id="qbif-handle-' + p + '" data-platform="' + p + '" placeholder="' + p + ' username" value="' + val + '" style="margin:0">' +
        '</div>';
    });
    container.innerHTML = html;
  };

  window.qbifSubmit = function(e){
    e.preventDefault();
    var btn = document.getElementById('qbifSubmitBtn');

    // Collect platforms
    var platforms = [];
    document.querySelectorAll('.qbif-platform-cb:checked').forEach(function(cb){ platforms.push(cb.value); });
    if(platforms.length === 0){
      alert('Please select at least one social platform.');
      return;
    }

    // Collect handles
    var handleLines = '';
    document.querySelectorAll('[id^="qbif-handle-"]').forEach(function(inp){
      var p = inp.dataset.platform;
      var val = inp.value.trim();
      if(val){
        var info = platformIcons[p] || { icon: '🔗', prefix: '' };
        handleLines += '\n' + p + ': ' + info.prefix + val;
      }
    });

    // Followers
    var followers = '';
    var followerRadio = document.querySelector('.qbif-range-radio:checked');
    if(followerRadio) followers = followerRadio.value;

    var name    = document.getElementById('qbif-name').value.trim();
    var phone   = document.getElementById('qbif-phone').value.trim();
    var email   = document.getElementById('qbif-email').value.trim();
    var city    = document.getElementById('qbif-city').value.trim();
    var niche   = document.getElementById('qbif-niche').value;
    var bio     = document.getElementById('qbif-bio').value.trim();
    var why     = document.getElementById('qbif-why').value.trim();
    var collab  = document.getElementById('qbif-collab').value || 'Not specified';
    var rate    = document.getElementById('qbif-rate').value.trim() || 'Not specified';
    var now     = new Date().toLocaleString('en-NP', { timeZone: 'Asia/Kathmandu' });

    var note = [
      '━━━ QUICKBEE INFLUENCER APPLICATION ━━━',
      '',
      '👤 PERSONAL',
      'Name: ' + name,
      'Phone: ' + phone,
      'Email: ' + email,
      'City: ' + city,
      '',
      '📲 SOCIAL PLATFORMS',
      'Active On: ' + platforms.join(', '),
      handleLines.trim() ? handleLines : '(no handles provided)',
      '',
      '📈 REACH & NICHE',
      'Followers: ' + followers,
      'Niche: ' + niche,
      'Rate: NPR ' + rate,
      '',
      '✍️ ABOUT',
      'Bio: ' + bio,
      'Why QB: ' + why,
      'Collab Type: ' + collab,
      '',
      '📅 Applied: ' + now
    ].join('\n');

    btn.disabled = true;
    btn.innerHTML = '⏳ Submitting…';

    // Add product to cart then set note and redirect
    {% assign qbif_product = all_products['quick-bee-influencer'] %}
    {% if qbif_product and qbif_product.variants.first %}
      var variantId = {{ qbif_product.variants.first.id }};
    {% else %}
      var variantId = null;
    {% endif %}

    function setNoteAndCheckout(){
      fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ note: note })
      }).then(function(){
        window.location.href = '/cart';
      }).catch(function(){
        window.location.href = '/cart';
      });
    }

    if(variantId){
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      }).then(setNoteAndCheckout).catch(setNoteAndCheckout);
    } else {
      setNoteAndCheckout();
    }
  };
})();
</script>
