{% stylesheet %}
  .hero-honeybee {
    background: linear-gradient(135deg, #8B4513 0%, #6B4423 100%);
    color: white;
    padding: 100px 40px;
    border-radius: 16px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border: 3px solid #FDB913;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }

  .hero-honeybee::before {
    content: '🐝';
    position: absolute;
    font-size: 200px;
    opacity: 0.1;
    top: -40px;
    right: -40px;
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(5deg); }
  }

  .hero-honeybee h1 {
    font-size: 56px;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
    font-weight: 800;
  }

  .hero-honeybee p {
    font-size: 20px;
    opacity: 0.95;
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }

  .hero-honeybee .button {
    display: inline-block;
    padding: 14px 40px;
    background: #FDB913;
    color: #8B4513;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 700;
    transition: all 0.3s;
    border: 2px solid #FDB913;
    cursor: pointer;
    font-size: 14px;
  }

  .hero-honeybee .button:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 16px rgba(253, 185, 19, 0.4);
    background: white;
  }

  @media (max-width: 768px) {
    .hero-honeybee {
      padding: 60px 20px;
    }
    .hero-honeybee h1 {
      font-size: 36px;
    }
  }
{% endstylesheet %}

<div class="hero-honeybee">
  <h1>{{ section.settings.title }}</h1>
  <p>{{ section.settings.subtitle }}</p>
  {% if section.settings.show_cta %}
    <a href="{{ section.settings.cta_link }}" class="button">{{ section.settings.cta_text }}</a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Honey Bee Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Welcome to QuickBee"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Busy as a bee, shopping made easy!"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Start Exploring"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    }
  ]
}
{% endschema %}
