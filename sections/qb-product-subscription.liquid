      </div>
    </div>

  </div><!-- /sp-body -->
</div><!-- /sp-root -->

<!-- Toast -->
<div class="sp-toast" id="spToast"></div>

<script>
(function() {
  'use strict';

  /* ── Elements ── */
  var form      = document.getElementById('spForm');
  var varPills  = document.querySelectorAll('.sp-var-pill');
  var varIdInp  = document.getElementById('spVariantId');
  var priceVal  = document.getElementById('spPriceVal');
  var compareEl = document.getElementById('spComparePrice');
  var saveTag   = document.getElementById('spSaveTag');
  var qtyMinus  = document.getElementById('spQtyMinus');
  var qtyPlus   = document.getElementById('spQtyPlus');
  var qtyVal    = document.getElementById('spQtyVal');
  var formQty   = document.getElementById('spFormQty');
  var dateInp   = document.getElementById('spStartDate');
  var formDate  = document.getElementById('spFormDate');
  var subBtn    = document.getElementById('spSubBtn');
  var btnTxt    = document.getElementById('spBtnTxt');
  var toast     = document.getElementById('spToast');

  /* ── Default start date = tomorrow ── */
  var tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate() + 1);
  var yyyy = tomorrow.getFullYear();
  var mm   = String(tomorrow.getMonth()+1).padStart(2,'0');
  var dd   = String(tomorrow.getDate()).padStart(2,'0');
  if(dateInp) { dateInp.value = yyyy+'-'+mm+'-'+dd; dateInp.min = yyyy+'-'+mm+'-'+dd; }
  if(formDate) formDate.value = yyyy+'-'+mm+'-'+dd;
  if(dateInp) dateInp.addEventListener('change', function(){ if(formDate) formDate.value = dateInp.value; });

  /* ── date color-scheme sync ── */
  function syncDateScheme() {
    var dark = (document.documentElement.getAttribute('data-theme')||'dark') === 'dark';
    if(dateInp) dateInp.style.colorScheme = dark ? 'dark' : 'light';
  }
  syncDateScheme();
  document.documentElement.addEventListener && document.documentElement.addEventListener('themechange', syncDateScheme);

  /* ── Variant pills ── */
  varPills.forEach(function(pill) {
    pill.addEventListener('click', function() {
      varPills.forEach(function(p){ p.classList.remove('sel'); });
      pill.classList.add('sel');

      var vid   = pill.getAttribute('data-variant-id');
      var price = pill.getAttribute('data-price');
      var cmp   = pill.getAttribute('data-compare');

      if(varIdInp) varIdInp.value = vid;
      if(priceVal) priceVal.textContent = price;

      if(cmp && parseInt(cmp) > parseInt(price)) {
        if(compareEl){ compareEl.textContent = 'Was Rs '+cmp; compareEl.style.display='block'; }
        var saving = Math.round((1 - parseInt(price)/parseInt(cmp))*100);
        if(saveTag){ saveTag.textContent = 'Save '+saving+'%'; saveTag.style.display='inline-block'; }
      } else {
        if(compareEl) compareEl.style.display='none';
        if(saveTag)   saveTag.style.display='none';
      }
    });
  });

  /* ── Quantity stepper ── */
  var qty = 4;
  function setQty(n) {
    qty = Math.max(1, Math.min(52, n));
    if(qtyVal)  qtyVal.textContent = qty;
    if(formQty) formQty.value      = qty;
  }
  if(qtyMinus) qtyMinus.addEventListener('click', function(){ setQty(qty - 1); });
  if(qtyPlus)  qtyPlus.addEventListener('click',  function(){ setQty(qty + 1); });

  /* ── Toast ── */
  var toastTimer;
  function showToast(msg) {
    if(!toast) return;
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function(){ toast.classList.remove('show'); }, 2800);
  }

  /* ── Add to Cart ── */
  if(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if(!varIdInp || !varIdInp.value) { showToast('Please select an option first'); return; }

      subBtn.classList.add('loading');
      btnTxt.textContent = 'Adding…';

      var payload = {
        id:         parseInt(varIdInp.value),
        quantity:   qty,
        properties: {
          'Subscription':  '{{ p.title | escape }}',
          'Start Date':    dateInp ? dateInp.value : '',
          'Plan Weeks':    qty + ' weeks',
          'Product Type':  '{{ p.type | escape }}'
        }
      };

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if(data.status) {
          showToast('⚠️ ' + (data.description || 'Could not add to cart'));
          subBtn.classList.remove('loading');
          btnTxt.textContent = 'Subscribe Now';
        } else {
          subBtn.classList.remove('loading');
          subBtn.classList.add('success');
          btnTxt.textContent = '✓ Added to Cart!';
          showToast('✅ Subscription added to cart!');
          window.dispatchEvent(new CustomEvent('cart:updated'));
          setTimeout(function(){
            subBtn.classList.remove('success');
            btnTxt.textContent = 'Subscribe Now';
          }, 2000);
        }
      })
      .catch(function() {
        showToast('⚠️ Something went wrong. Try again.');
        subBtn.classList.remove('loading');
        btnTxt.textContent = 'Subscribe Now';
      });
    });
  }

  /* ── FAQ accordion ── */
  document.querySelectorAll('.sp-faq-q').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.sp-faq-item');
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.sp-faq-item').forEach(function(i){ i.classList.remove('open'); });
      if(!isOpen) item.classList.add('open');
    });
  });

  /* ── Set compare price on page load from first variant ── */
  var firstCmp   = {{ first_variant.compare_at_price | divided_by: 100 | floor | json }};
  var firstPrice = {{ first_variant.price | divided_by: 100 | floor | json }};
  if(firstCmp && firstCmp > firstPrice) {
    if(compareEl){ compareEl.textContent = 'Was Rs '+firstCmp; compareEl.style.display='block'; }
    var initSaving = Math.round((1 - firstPrice/firstCmp)*100);
    if(saveTag){ saveTag.textContent = 'Save '+initSaving+'%'; saveTag.style.display='inline-block'; }
  }

})();
</script>

