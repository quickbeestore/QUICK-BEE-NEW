<!-- Service Detail Hero Section -->
<section class="qb-service-detail-hero">
  <style>
    :root {
      --qb-primary: #F4B400;
      --qb-danger: #FF6B6B;
      --qb-dark: #1a1a1a;
      --qb-text: #333;
      --qb-text-light: #666;
      --qb-border: #e8e8e8;
      --qb-bg: #f8f9fa;
      --qb-white: #ffffff;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    .qb-service-detail-hero {
      background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%);
      color: white;
      padding: 60px 20px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .qb-service-detail-hero::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(255, 193, 7, 0.1), transparent);
      animation: rotate 15s linear infinite;
    }

    @keyframes rotate {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .qb-service-hero-content {
      max-width: 800px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .qb-service-hero-icon {
      font-size: 80px;
      margin-bottom: 20px;
      display: block;
      animation: bounce 2s ease-in-out infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }

    .qb-service-hero-title {
      font-size: 48px;
      font-weight: 900;
      margin-bottom: 16px;
      letter-spacing: -1px;
    }

    .qb-service-hero-subtitle {
      font-size: 18px;
      color: #FFD700;
      margin-bottom: 24px;
      font-weight: 600;
    }

    .qb-service-hero-description {
      font-size: 16px;
      color: #e0e0e0;
      line-height: 1.8;
      margin-bottom: 32px;
    }

    .qb-service-hero-cta {
      display: inline-block;
      background: linear-gradient(135deg, #FFD700 0%, #FFC107 100%);
      color: #000;
      padding: 16px 40px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 800;
      font-size: 16px;
      transition: all 0.3s ease;
      border: none;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      box-shadow: 0 8px 24px rgba(255, 193, 7, 0.3);
    }

    .qb-service-hero-cta:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(255, 193, 7, 0.5);
      background: linear-gradient(135deg, #FFC107 0%, #FFB300 100%);
    }

    @media (max-width: 768px) {
      .qb-service-detail-hero {
        padding: 40px 16px;
      }

      .qb-service-hero-title {
        font-size: 32px;
      }

      .qb-service-hero-subtitle {
        font-size: 16px;
      }

      .qb-service-hero-description {
        font-size: 14px;
      }

      .qb-service-hero-icon {
        font-size: 60px;
      }
    }
  </style>

  <div class="qb-service-hero-content">
    <span class="qb-service-hero-icon">{{ section.settings.icon }}</span>
    <h1 class="qb-service-hero-title">{{ section.settings.title }}</h1>
    <p class="qb-service-hero-subtitle">{{ section.settings.subtitle }}</p>
    <p class="qb-service-hero-description">{{ section.settings.description }}</p>
    <a href="/pages/book-service" class="qb-service-hero-cta">Book Service Now</a>
  </div>
</section>

{% schema %}
{
  "name": "Service Detail Hero",
  "settings": [
    {
      "type": "text",
      "id": "icon",
      "label": "Service Icon (Emoji)",
      "default": "🔧"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Service Title",
      "default": "Service Name"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Service Tagline",
      "default": "Professional Service Tagline"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Service Description",
      "default": "Detailed description of the service and what makes it special."
    }
  ],
  "presets": [
    {
      "name": "Service Detail Hero",
      "settings": {}
    }
  ]
}
{% endschema %}
