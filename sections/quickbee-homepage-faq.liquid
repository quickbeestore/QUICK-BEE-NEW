<!-- FAQ Accordion Section -->
<style>
.qb-faq-section {
  padding: 40px 16px;
  background: #0A0A0A !important;
  border-top: 1px solid rgba(255,255,255,0.05);
}

@media (min-width: 1024px) {
  .qb-faq-section {
    padding: 60px 48px;
  }
}

.qb-faq-header {
  text-align: center;
  margin-bottom: 40px;
}

.qb-faq-header h2 {
  font-size: 24px;
  font-weight: 900;
  color: #F0F0F0;
  margin: 0 0 12px 0;
}

@media (min-width: 1024px) {
  .qb-faq-header h2 {
    font-size: 32px;
  }
}

.qb-faq-header p {
  font-size: 15px;
  color: #999;
  margin: 0;
}

.qb-faq-container {
  max-width: 800px;
  margin: 0 auto;
}

.qb-faq-item {
  border: 1.5px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  margin-bottom: 16px;
  overflow: hidden;
  transition: all 0.3s ease;
  background: #111;
}

.qb-faq-item:hover {
  border-color: rgba(244,180,0,0.3);
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}

.qb-faq-question {
  width: 100%;
  padding: 24px;
  background: #111;
  border: none;
  cursor: pointer;
  text-align: left;
  font-size: 17px;
  font-weight: 700;
  color: #F0F0F0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.3s ease;
  font-family: inherit;
}

.qb-faq-question:hover {
  background: #181818;
  color: #F4B400;
}

.qb-faq-question.active {
  background: #181818;
  color: #F4B400;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.qb-faq-icon {
  font-size: 20px;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 28px;
  color: #F4B400;
}

.qb-faq-question.active .qb-faq-icon {
  transform: rotate(180deg);
}

.qb-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  background: #111;
}

.qb-faq-answer.active {
  max-height: 600px;
}

.qb-faq-answer-content {
  padding: 0 24px 24px 24px;
  color: #999;
  line-height: 1.7;
  font-size: 15px;
  margin-top: 10px;
}

.qb-faq-support {
  text-align: center;
  margin-top: 48px;
  padding: 32px;
  background: #111;
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
}

.qb-faq-support p {
  font-size: 16px;
  color: #F0F0F0;
  margin: 0;
  font-weight: 600;
}

.qb-faq-support a {
  color: #F4B400;
  text-decoration: none;
  font-weight: 700;
  transition: all 0.3s ease;
  margin-left: 5px;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

.qb-faq-support a:hover {
  color: #FFD700;
  text-decoration: underline;
  transform: translateX(3px);
}
</style>

<section class="qb-faq-section">
  <div class="qb-faq-header">
    <h2>Frequently Asked Questions</h2>
    <p>Find answers to common questions about QuickBee</p>
  </div>

  <div class="qb-faq-container">
    <!-- FAQ Item 1 -->
    <div class="qb-faq-item">
      <button class="qb-faq-question active" data-faq-btn="0">
        <span>How long does delivery take?</span>
        <span class="qb-faq-icon">▼</span>
      </button>
      <div class="qb-faq-answer active" data-faq-answer="0">
        <div class="qb-faq-answer-content">
          We deliver incredibly fast! In the Kathmandu metro area, most orders arrive within ~20 minutes. For areas outside the metro, delivery typically takes 30-45 minutes depending on the location. You'll be able to track your delivery in real-time once your order is confirmed.
        </div>
      </div>
    </div>

    <!-- FAQ Item 2 -->
    <div class="qb-faq-item">
      <button class="qb-faq-question" data-faq-btn="1">
        <span>What is your return policy?</span>
        <span class="qb-faq-icon">▼</span>
      </button>
      <div class="qb-faq-answer" data-faq-answer="1">
        <div class="qb-faq-answer-content">
          We stand behind every product. If you're not satisfied with your purchase, we offer a 30-day money-back guarantee. Simply contact our support team with details about your order, and we'll process your refund quickly and hassle-free. Your satisfaction is our priority.
        </div>
      </div>
    </div>

    <!-- FAQ Item 3 -->
    <div class="qb-faq-item">
      <button class="qb-faq-question" data-faq-btn="2">
        <span>Are your products authentic?</span>
        <span class="qb-faq-icon">▼</span>
      </button>
      <div class="qb-faq-answer" data-faq-answer="2">
        <div class="qb-faq-answer-content">
          Absolutely! We source all our products from genuine, authorized distributors and brands. Every product sold on QuickBee is 100% authentic. We have strict quality control processes to ensure you receive only genuine items. We take product authenticity very seriously.
        </div>
      </div>
    </div>

    <!-- FAQ Item 4 -->
    <div class="qb-faq-item">
      <button class="qb-faq-question" data-faq-btn="3">
        <span>Can I track my order?</span>
        <span class="qb-faq-icon">▼</span>
      </button>
      <div class="qb-faq-answer" data-faq-answer="3">
        <div class="qb-faq-answer-content">
          Yes! Once your order is confirmed, you'll receive a tracking link via email or SMS. Our real-time tracking system shows you the exact location of your delivery agent and estimated arrival time. You can also track your order directly from your account dashboard.
        </div>
      </div>
    </div>

    <!-- FAQ Item 5 -->
    <div class="qb-faq-item">
      <button class="qb-faq-question" data-faq-btn="4">
        <span>Do you offer customer support?</span>
        <span class="qb-faq-icon">▼</span>
      </button>
      <div class="qb-faq-answer" data-faq-answer="4">
        <div class="qb-faq-answer-content">
          We provide 24/7 customer support to assist you with any questions or issues. You can reach our support team via email, phone, or live chat on our website. Our dedicated team is always ready to help and typically responds within a few minutes. We're here for you, always!
        </div>
      </div>
    </div>

    <!-- FAQ Item 6 -->
    <div class="qb-faq-item">
      <button class="qb-faq-question" data-faq-btn="5">
        <span>What payment methods do you accept?</span>
        <span class="qb-faq-icon">▼</span>
      </button>
      <div class="qb-faq-answer" data-faq-answer="5">
        <div class="qb-faq-answer-content">
          We accept multiple payment methods for your convenience including credit cards, debit cards, digital wallets (Apple Pay, Google Pay), UPI transfers, and bank transfers. All transactions are secured with SSL encryption to protect your sensitive financial information.
        </div>
      </div>
    </div>

    <!-- Support CTA -->
    <div class="qb-faq-support">
      <p>Still have questions? <a href="/pages/contact">Contact our support team →</a></p>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const faqButtons = document.querySelectorAll('.qb-faq-question');
  const faqAnswers = document.querySelectorAll('.qb-faq-answer');

  faqButtons.forEach((button) => {
    button.addEventListener('click', function() {
      const index = this.getAttribute('data-faq-btn');
      const answer = document.querySelector(`[data-faq-answer="${index}"]`);

      // Close all other FAQs
      faqButtons.forEach((btn, idx) => {
        if (idx !== parseInt(index)) {
          btn.classList.remove('active');
          document.querySelector(`[data-faq-answer="${idx}"]`).classList.remove('active');
        }
      });

      // Toggle current FAQ
      this.classList.toggle('active');
      answer.classList.toggle('active');
    });
  });
});
</script>
