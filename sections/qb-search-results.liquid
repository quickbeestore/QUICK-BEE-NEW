{%- comment -%}
  QuickBEE Modern Search Results
  Modern product grid for search results with improved UX
{%- endcomment -%}

<script src="{{ 'results-list.js' | asset_url }}" type="module" fetchpriority="low"></script>

<style>
  .qb-search-results {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px 16px;
  }

  .qb-search-header {
    margin-bottom: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .qb-search-title {
    font-size: 24px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
  }

  .qb-search-count {
    font-size: 14px;
    color: #666;
    font-weight: 500;
  }

  .qb-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .qb-product-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s ease;
    cursor: pointer;
    height: 100%;
    position: relative;
  }

  .qb-product-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }

  .qb-product-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background: #f5f5f5;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .qb-product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.3s ease;
  }

  .qb-product-card:hover .qb-product-image {
    transform: scale(1.05);
  }

  .qb-product-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: #c41e3a;
    color: white;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    z-index: 10;
  }

  .qb-product-info {
    flex: 1;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .qb-product-title {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .qb-product-price-wrap {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .qb-product-price {
    font-size: 14px;
    font-weight: 700;
    color: #c41e3a;
  }

  .qb-product-price-original {
    font-size: 12px;
    color: #999;
    text-decoration: line-through;
  }

  .qb-product-button {
    width: 100%;
    padding: 8px 12px;
    background: #c41e3a;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: auto;
  }

  .qb-product-button:hover {
    background: #a01730;
    transform: scale(1.02);
  }

  .qb-product-button:active {
    transform: scale(0.98);
  }

  .qb-empty-state {
    text-align: center;
    padding: 60px 20px;
  }

  .qb-empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .qb-empty-title {
    font-size: 20px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 8px;
  }

  .qb-empty-text {
    font-size: 14px;
    color: #666;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .qb-search-results {
      padding: 16px 12px;
    }

    .qb-search-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 20px;
    }

    .qb-search-title {
      font-size: 20px;
    }

    .qb-product-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 10px;
    }

    .qb-product-info {
      padding: 10px;
      gap: 6px;
    }

    .qb-product-title {
      font-size: 12px;
    }

    .qb-product-button {
      padding: 6px 10px;
      font-size: 11px;
    }
  }

  @media (min-width: 768px) {
    .qb-search-results {
      padding: 32px 24px;
    }

    .qb-product-grid {
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 16px;
    }

    .qb-product-info {
      padding: 14px;
      gap: 10px;
    }

    .qb-product-title {
      font-size: 14px;
    }

    .qb-search-title {
      font-size: 28px;
    }
  }

  @media (min-width: 1024px) {
    .qb-product-grid {
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
    }

    .qb-product-info {
      padding: 16px;
    }
  }
</style>

<div class="qb-search-results" section-id="{{ section.id }}">
  {% if search.results_count > 0 %}
    <div class="qb-search-header">
      <div>
        <h1 class="qb-search-title">Search Results</h1>
        <p class="qb-search-count">{{ search.results_count }} items found</p>
      </div>
    </div>

    <ul class="qb-product-grid">
      {% for result in search.results %}
        {% if result.object_type == 'product' %}
          {% assign product = result %}
          <li class="qb-product-card">
            <a href="{{ product.url }}" class="qb-product-link" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%;">
              <div class="qb-product-image-wrap">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 300 }}"
                    alt="{{ product.featured_image.alt | default: product.title }}"
                    class="qb-product-image"
                    loading="lazy"
                  >
                {% else %}
                  <div style="width: 100%; height: 100%; background: #f0f0f0; display: flex; align-items: center; justify-content: center; color: #ccc;">
                    No image
                  </div>
                {% endif %}

                {% if product.compare_at_price > product.price %}
                  <span class="qb-product-badge">Sale</span>
                {% endif %}
              </div>

              <div class="qb-product-info">
                <h3 class="qb-product-title">{{ product.title }}</h3>

                <div class="qb-product-price-wrap">
                  <span class="qb-product-price">₹{{ product.price | money_without_currency }}</span>
                  {% if product.compare_at_price > product.price %}
                    <span class="qb-product-price-original">₹{{ product.compare_at_price | money_without_currency }}</span>
                  {% endif %}
                </div>

                <button class="qb-product-button" onclick="event.preventDefault(); event.stopPropagation(); alert('Add to cart: {{ product.title }}');">
                  Add to Cart
                </button>
              </div>
            </a>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  {% else %}
    <div class="qb-empty-state">
      <div class="qb-empty-icon">🔍</div>
      <h2 class="qb-empty-title">No products found</h2>
      <p class="qb-empty-text">Try different keywords or browse our categories</p>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "QuickBEE Search Results",
  "settings": [
    {
      "type": "paragraph",
      "content": "Modern search results layout with improved product cards"
    }
  ],
  "presets": []
}
{% endschema %}
