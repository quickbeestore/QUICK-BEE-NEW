{%- comment -%} QuickBEE Search Results — Professional Redesign {%- endcomment -%}

<style>
/* ══════════════════════════════════════════════
   QB SEARCH RESULTS — SWIGGY/BLINKIT STYLE
   ══════════════════════════════════════════════ */

/* Hide default search header */
.search-page__header { display: none !important; }

/* ── Variables ── */
.qbsr-page {
  --sr-bg:        #0b0b0b;
  --sr-surface:   #141414;
  --sr-card:      #1a1a1a;
  --sr-border:    #242424;
  --sr-text:      #f0f0f0;
  --sr-muted:     #777;
  --sr-muted2:    #555;
  --sr-accent:    #F4B400;
  --sr-accent2:   #e06600;
  --sr-green:     #22c55e;
  --sr-red:       #ef4444;
  --sr-radius:    16px;
}

[data-theme="light"] .qbsr-page,
:root:not([data-theme="dark"]) .qbsr-page {
  --sr-bg:       #f5f5f5;
  --sr-surface:  #ffffff;
  --sr-card:     #ffffff;
  --sr-border:   #e8e8e8;
  --sr-text:     #111827;
  --sr-muted:    #6b7280;
  --sr-muted2:   #9ca3af;
}

.qbsr-page {
  background: var(--sr-bg);
  color: var(--sr-text);
  min-height: 100vh;
  padding-bottom: 110px;
}

/* ── Sticky top bar ── */
.qbsr-topbar {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--sr-bg);
  padding: 14px 16px 12px;
  border-bottom: 1px solid var(--sr-border);
  backdrop-filter: blur(12px);
}

/* ── Search bar in results ── */
.qbsr-form {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--sr-surface);
  border: 1.5px solid var(--sr-border);
  border-radius: 999px;
  padding: 0 14px 0 18px;
  height: 52px;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.qbsr-form:focus-within {
  border-color: var(--sr-accent);
  box-shadow: 0 0 0 3px rgba(244,180,0,0.12);
}

.qbsr-form-icon {
  color: var(--sr-muted);
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.qbsr-input {
  all: unset;
  flex: 1;
  font-size: 16px;
  font-weight: 600;
  color: var(--sr-text);
  min-width: 0;
}

.qbsr-input::placeholder {
  color: var(--sr-muted2);
  font-weight: 400;
}

.qbsr-form-btn {
  height: 36px;
  padding: 0 16px;
  border-radius: 999px;
  background: var(--sr-accent);
  border: none;
  color: #111;
  font-size: 13px;
  font-weight: 800;
  cursor: pointer;
  flex-shrink: 0;
  transition: transform 0.15s, background 0.15s;
}

.qbsr-form-btn:hover { background: #ffd700; transform: scale(1.03); }

/* ── Meta row ── */
.qbsr-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
  padding: 14px 16px 0;
}

.qbsr-meta-left {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.qbsr-query-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--sr-muted);
}

.qbsr-query-term {
  font-size: 22px;
  font-weight: 900;
  color: var(--sr-text);
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.qbsr-count-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 12px;
  background: rgba(244,180,0,0.12);
  border: 1px solid rgba(244,180,0,0.2);
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
  color: var(--sr-accent);
  white-space: nowrap;
}

/* ── Filter chips ── */
.qbsr-filters {
  display: flex;
  gap: 8px;
  padding: 12px 16px 0;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.qbsr-filters::-webkit-scrollbar { display: none; }

.qbsr-filter {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 7px 14px;
  border-radius: 999px;
  border: 1.5px solid var(--sr-border);
  background: var(--sr-surface);
  color: var(--sr-muted);
  font-size: 12px;
  font-weight: 700;
  white-space: nowrap;
  cursor: pointer;
  text-decoration: none;
  transition: border-color 0.18s, color 0.18s, background 0.18s;
  flex-shrink: 0;
}

.qbsr-filter:hover,
.qbsr-filter.active {
  border-color: var(--sr-accent);
  color: var(--sr-accent);
  background: rgba(244,180,0,0.08);
}

/* ── Grid ── */
.qbsr-grid-wrap {
  padding: 16px 12px 0;
}

.qbsr-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  list-style: none;
  margin: 0;
  padding: 0;
}

@media (min-width: 600px) {
  .qbsr-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
}

@media (min-width: 900px) {
  .qbsr-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; }
  .qbsr-topbar { padding: 14px 24px 12px; }
  .qbsr-meta  { padding: 16px 24px 0; }
  .qbsr-filters { padding: 12px 24px 0; }
  .qbsr-grid-wrap { padding: 16px 20px 0; }
}

@media (min-width: 1200px) {
  .qbsr-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); }
}

/* ── Card ── */
.qbsr-card {
  background: var(--sr-card);
  border: 1px solid var(--sr-border);
  border-radius: var(--sr-radius);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: border-color 0.2s, transform 0.18s, box-shadow 0.2s;
}

.qbsr-card:hover {
  border-color: rgba(244,180,0,0.3);
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(0,0,0,0.3);
}

.qbsr-card-link {
  display: flex;
  flex-direction: column;
  flex: 1;
  text-decoration: none;
  color: inherit;
}

/* Image */
.qbsr-img-wrap {
  position: relative;
  aspect-ratio: 1 / 1;
  background: #fff;
  overflow: hidden;
}

.qbsr-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  padding: 10px;
  transition: transform 0.25s ease;
}

.qbsr-card:hover .qbsr-img { transform: scale(1.04); }

.qbsr-no-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  background: var(--sr-surface);
  color: var(--sr-muted2);
}

/* Badges */
.qbsr-sale-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  padding: 4px 8px;
  background: var(--sr-red);
  color: #fff;
  font-size: 9px;
  font-weight: 900;
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  z-index: 2;
}

.qbsr-time-badge {
  position: absolute;
  bottom: 8px;
  left: 8px;
  padding: 3px 8px;
  background: rgba(0,0,0,0.65);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  border-radius: 999px;
  z-index: 2;
  backdrop-filter: blur(4px);
}

/* Card body */
.qbsr-card-body {
  padding: 10px 10px 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
}

.qbsr-card-name {
  font-size: 13px;
  font-weight: 700;
  line-height: 1.35;
  color: var(--sr-text);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 2.7em;
  margin: 0;
}

.qbsr-price-row {
  display: flex;
  align-items: center;
  gap: 7px;
  flex-wrap: wrap;
}

.qbsr-price {
  font-size: 16px;
  font-weight: 900;
  color: var(--sr-text);
  letter-spacing: -0.02em;
}

.qbsr-compare {
  font-size: 11px;
  color: var(--sr-muted);
  text-decoration: line-through;
}

/* ADD button */
.qbsr-add-btn {
  margin-top: auto;
  width: 100%;
  height: 36px;
  border: none;
  border-radius: 10px;
  background: var(--sr-accent);
  color: #111;
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.03em;
  cursor: pointer;
  transition: background 0.18s, transform 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  position: relative;
  overflow: hidden;
}

.qbsr-add-btn:hover { background: #ffd700; transform: scale(1.02); }

.qbsr-add-btn.loading {
  background: var(--sr-border);
  pointer-events: none;
  color: var(--sr-muted);
}

.qbsr-add-btn.success {
  background: var(--sr-green);
  color: #fff;
  pointer-events: none;
}

.qbsr-add-btn.error {
  background: rgba(239,68,68,0.15);
  color: var(--sr-red);
  border: 1px solid rgba(239,68,68,0.3);
  pointer-events: none;
}

/* ── Toast ── */
.qbsr-toast {
  position: fixed;
  bottom: 88px;
  left: 50%;
  transform: translateX(-50%) translateY(12px);
  background: var(--sr-green);
  color: #fff;
  padding: 10px 22px;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 700;
  z-index: 9999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s, transform 0.25s;
  white-space: nowrap;
  box-shadow: 0 6px 20px rgba(34,197,94,0.4);
}

.qbsr-toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.qbsr-toast.error {
  background: var(--sr-red);
  box-shadow: 0 6px 20px rgba(239,68,68,0.4);
}

/* ── Empty state ── */
.qbsr-empty {
  text-align: center;
  padding: 64px 24px 32px;
}

.qbsr-empty-icon { font-size: 58px; margin-bottom: 16px; }
.qbsr-empty-title {
  font-size: 26px;
  font-weight: 900;
  letter-spacing: -0.03em;
  margin: 0 0 10px;
  color: var(--sr-text);
}

.qbsr-empty-sub {
  font-size: 14px;
  color: var(--sr-muted);
  line-height: 1.6;
  max-width: 32ch;
  margin: 0 auto 28px;
}

.qbsr-suggestions-label {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--sr-muted);
  margin-bottom: 12px;
}

.qbsr-suggestion-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
}

.qbsr-suggestion-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 9px 16px;
  background: var(--sr-surface);
  border: 1.5px solid var(--sr-border);
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  color: var(--sr-text);
  text-decoration: none;
  transition: border-color 0.18s, color 0.18s, background 0.18s;
}

.qbsr-suggestion-chip:hover {
  border-color: var(--sr-accent);
  color: var(--sr-accent);
  background: rgba(244,180,0,0.08);
}

/* ── Pagination ── */
.qbsr-pagination {
  display: flex;
  justify-content: center;
  gap: 8px;
  padding: 28px 16px 0;
  flex-wrap: wrap;
}

.qbsr-page-btn {
  padding: 9px 18px;
  border-radius: 10px;
  background: var(--sr-surface);
  border: 1.5px solid var(--sr-border);
  color: var(--sr-text);
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  transition: border-color 0.18s, color 0.18s;
  cursor: pointer;
}

.qbsr-page-btn:hover,
.qbsr-page-btn.current {
  border-color: var(--sr-accent);
  color: var(--sr-accent);
  background: rgba(244,180,0,0.08);
}
</style>

<div class="qbsr-page" id="qbsr">

  <!-- ── Sticky top bar ── -->
  <div class="qbsr-topbar">
    <form action="/search" method="get" class="qbsr-form" role="search">
      <span class="qbsr-form-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><circle cx="11" cy="11" r="7.5"/><path d="m20 20-3.8-3.8"/></svg>
      </span>
      <input
        type="search"
        name="q"
        class="qbsr-input"
        id="qbsrInput"
        placeholder="Search products…"
        value="{{ search.terms | escape }}"
        autocomplete="off"
        aria-label="Search products"
      >
      <button type="submit" class="qbsr-form-btn">Search</button>
    </form>
  </div>

  <!-- ── Meta ── -->
  {% if search.terms != blank or search.results_count > 0 %}
  <div class="qbsr-meta">
    <div class="qbsr-meta-left">
      {% if search.terms != blank %}
        <span class="qbsr-query-label">Results for</span>
        <span class="qbsr-query-term">"{{ search.terms | escape }}"</span>
      {% else %}
        <span class="qbsr-query-term">All Products</span>
      {% endif %}
    </div>
    <span class="qbsr-count-badge">
      ⚡ {{ search.results_count | default: 0 }} found
    </span>
  </div>

  <!-- ── Filter chips ── -->
  <div class="qbsr-filters" id="qbsrFilters">
    {% assign base_q = search.terms | escape %}
    <a href="/search?q={{ base_q }}&type=product" class="qbsr-filter active">🛍️ All</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Beer" class="qbsr-filter">🍺 Beer</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Food" class="qbsr-filter">🍔 Food</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Drinks" class="qbsr-filter">🥤 Drinks</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Snacks" class="qbsr-filter">🍟 Snacks</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Grocery" class="qbsr-filter">🥦 Grocery</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Cigarettes" class="qbsr-filter">🚬 Smokes</a>
  </div>
  {% endif %}

  <!-- ── Grid ── -->
  {% assign product_results = search.results | where: 'object_type', 'product' %}

  {% if product_results.size > 0 %}
    {% paginate search.results by 24 %}
    <div class="qbsr-grid-wrap">
      <ul class="qbsr-grid" id="qbsrGrid">
        {% for product in product_results %}
          {%- assign sale = false -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign sale = true -%}
            {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}

          <li class="qbsr-card">
            <a href="{{ product.url }}" class="qbsr-card-link">
              <div class="qbsr-img-wrap">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 480 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    class="qbsr-img"
                    loading="lazy"
                    width="480"
                    height="480"
                  >
                {% else %}
                  <div class="qbsr-no-img">🐝</div>
                {% endif %}

                {% if sale %}
                  <span class="qbsr-sale-badge">{{ discount }}% OFF</span>
                {% endif %}
                <span class="qbsr-time-badge qbsr-time-sync">⚡ 20 mins</span>
              </div>

              <div class="qbsr-card-body">
                <h3 class="qbsr-card-name">{{ product.title }}</h3>

                <div class="qbsr-price-row">
                  <span class="qbsr-price">Rs {{ product.price | money_without_currency }}</span>
                  {% if sale %}
                    <span class="qbsr-compare">Rs {{ product.compare_at_price | money_without_currency }}</span>
                  {% endif %}
                </div>
              </div>
            </a>

            <div style="padding: 0 10px 12px;">
              <button
                class="qbsr-add-btn"
                data-variant="{{ product.first_available_variant.id }}"
                data-name="{{ product.title | escape }}"
                aria-label="Add {{ product.title | escape }} to cart"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                ADD
              </button>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>

    <!-- Pagination -->
    {% if paginate.pages > 1 %}
    <div class="qbsr-pagination">
      {% if paginate.previous %}
        <a href="{{ paginate.previous.url }}" class="qbsr-page-btn">← Prev</a>
      {% endif %}

      {% for part in paginate.parts %}
        {% if part.is_link %}
          <a href="{{ part.url }}" class="qbsr-page-btn">{{ part.title }}</a>
        {% else %}
          <span class="qbsr-page-btn current">{{ part.title }}</span>
        {% endif %}
      {% endfor %}

      {% if paginate.next %}
        <a href="{{ paginate.next.url }}" class="qbsr-page-btn">Next →</a>
      {% endif %}
    </div>
    {% endif %}
    {% endpaginate %}

  {% else %}
    <!-- ── Empty state ── -->
    <div class="qbsr-empty">
      <div class="qbsr-empty-icon">🔎</div>
      <h2 class="qbsr-empty-title">
        {% if search.terms != blank %}No results for "{{ search.terms | escape }}"
        {% else %}What are you looking for?{% endif %}
      </h2>
      <p class="qbsr-empty-sub">
        {% if search.terms != blank %}
          Try a shorter word, check spelling, or browse a category below.
        {% else %}
          Search across groceries, drinks, snacks, beer and more.
        {% endif %}
      </p>

      <p class="qbsr-suggestions-label">Try these</p>
      <div class="qbsr-suggestion-chips">
        <a href="/search?q=beer&type=product"           class="qbsr-suggestion-chip">🍺 Beer</a>
        <a href="/search?q=cold+drinks&type=product"    class="qbsr-suggestion-chip">🥤 Cold Drinks</a>
        <a href="/search?q=chips&type=product"          class="qbsr-suggestion-chip">🍟 Chips</a>
        <a href="/search?q=noodles&type=product"        class="qbsr-suggestion-chip">🍜 Noodles</a>
        <a href="/search?q=vodka&type=product"          class="qbsr-suggestion-chip">🥃 Vodka</a>
        <a href="/search?q=cigarette&type=product"      class="qbsr-suggestion-chip">🚬 Cigarettes</a>
        <a href="/search?q=juice&type=product"          class="qbsr-suggestion-chip">🧃 Juice</a>
        <a href="/search?q=chocolate&type=product"      class="qbsr-suggestion-chip">🍫 Chocolate</a>
      </div>
    </div>
  {% endif %}

</div>

<!-- ── Toast ── -->
<div class="qbsr-toast" id="qbsrToast"></div>

<script>
(function () {
  /* ── Delivery time badge sync ── */
  function syncTime() {
    var range = (window.QB_DELIVERY_TIME && window.QB_DELIVERY_TIME.range) || '20 mins';
    document.querySelectorAll('.qbsr-time-sync').forEach(function (b) {
      b.textContent = '⚡ ' + range;
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', syncTime);
  } else {
    syncTime();
  }
  window.addEventListener('locationSelected', function () { setTimeout(syncTime, 50); });

  /* ── Toast ── */
  function showToast(msg, isError) {
    var t = document.getElementById('qbsrToast');
    if (!t) return;
    t.textContent = msg;
    t.className = 'qbsr-toast show' + (isError ? ' error' : '');
    clearTimeout(t._timer);
    t._timer = setTimeout(function () { t.classList.remove('show'); }, 2600);
  }

  /* ── Add to cart ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.qbsr-add-btn');
    if (!btn || btn.classList.contains('loading') || btn.classList.contains('success')) return;

    var variantId = btn.getAttribute('data-variant');
    var name      = btn.getAttribute('data-name') || 'Item';
    if (!variantId || variantId === '') {
      showToast('⚠️ Out of stock', true);
      return;
    }

    btn.classList.add('loading');
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (d.id) {
        btn.classList.remove('loading');
        btn.classList.add('success');
        btn.innerHTML = '✓ Added';
        showToast('✅ ' + name + ' added to cart!');
        /* update cart count */
        fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (c) {
            var countEl = document.getElementById('cart-count');
            if (countEl) countEl.textContent = c.item_count;
          });
        /* reset after 2s */
        setTimeout(function () {
          btn.classList.remove('success');
          btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> ADD';
        }, 2200);
      } else {
        throw new Error(d.description || 'Failed');
      }
    })
    .catch(function (err) {
      btn.classList.remove('loading');
      btn.classList.add('error');
      btn.innerHTML = '✗ Error';
      showToast('⚠️ Could not add item', true);
      setTimeout(function () {
        btn.classList.remove('error');
        btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> ADD';
      }, 2000);
    });
  });
})();
</script>

