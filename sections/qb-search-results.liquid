{%- comment -%} QuickBEE Search Results — God-Level Mobile-First UI {%- endcomment -%}

<style>
/* ══════════════════════════════════════════════════
   QB SEARCH RESULTS — GOD LEVEL MOBILE-FIRST DESIGN
   ══════════════════════════════════════════════════ */

/* Hide default Shopify search header */
.search-page__header,
.shopify-section-search-header,
#shopify-section-search { display: none !important; }

/* ── Root Variables ── */
.qbsr-page {
  --sr-bg:        #0b0b0b;
  --sr-surface:   #141414;
  --sr-card:      #1a1a1a;
  --sr-card2:     #202020;
  --sr-border:    #2e2e2e;
  --sr-border2:   #3a3a3a;
  --sr-text:      #f0f0f0;
  --sr-text2:     #c0c0c0;
  --sr-muted:     #777;
  --sr-muted2:    #4a4a4a;
  --sr-accent:    #F4B400;
  --sr-accent-bg: rgba(244,180,0,0.10);
  --sr-accent-bd: rgba(244,180,0,0.22);
  --sr-magenta:   #C2185B;
  --sr-green:     #22c55e;
  --sr-red:       #ef4444;
  --sr-radius:    16px;
  --sr-img-bg:    #1e1e1e;
}

html:not([data-theme="dark"]) .qbsr-page,
[data-theme="light"] .qbsr-page {
  --sr-bg:        #F7F3EE;
  --sr-surface:   #FFFFFF;
  --sr-card:      #FFFFFF;
  --sr-card2:     #F5EFE4;
  --sr-border:    #E0D8CE;
  --sr-border2:   #D0C8BE;
  --sr-text:      #111827;
  --sr-text2:     #374151;
  --sr-muted:     #6B5E50;
  --sr-muted2:    #B0A090;
  --sr-accent-bg: rgba(244,180,0,0.09);
  --sr-accent-bd: rgba(244,180,0,0.20);
  --sr-img-bg:    #F5EFE4;
}

/* ── Base ── */
.qbsr-page {
  background: var(--sr-bg);
  color: var(--sr-text);
  min-height: 100vh;
  padding-bottom: 120px;
}

/* ══════════════════════════════════
   HERO SECTION
   ══════════════════════════════════ */
.qbsr-hero {
  padding: 24px 16px 0;
  position: relative;
}

.qbsr-hero-eyebrow {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--sr-muted);
  margin: 0 0 6px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.qbsr-hero-eyebrow::before {
  content: '';
  display: inline-block;
  width: 16px;
  height: 2px;
  background: var(--sr-accent);
  border-radius: 2px;
}

.qbsr-hero-title {
  font-size: clamp(26px, 7vw, 36px);
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin: 0 0 16px;
  color: var(--sr-text);
  word-break: break-word;
}

.qbsr-hero-title .qbsr-query-highlight {
  color: var(--sr-accent);
}

.qbsr-hero-stats {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

.qbsr-stat-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.02em;
}

.qbsr-stat-pill.products {
  background: var(--sr-accent-bg);
  border: 1px solid var(--sr-accent-bd);
  color: var(--sr-accent);
}

.qbsr-stat-pill.subs {
  background: rgba(194,24,91,0.10);
  border: 1px solid rgba(194,24,91,0.20);
  color: #E91E8C;
}

.qbsr-stat-pill.services {
  background: rgba(34,197,94,0.10);
  border: 1px solid rgba(34,197,94,0.20);
  color: var(--sr-green);
}

/* ══════════════════════════════════
   FILTER CHIPS
   ══════════════════════════════════ */
.qbsr-filters {
  display: flex;
  gap: 8px;
  padding: 0 16px 20px;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.qbsr-filters::-webkit-scrollbar { display: none; }

.qbsr-filter {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 8px 16px;
  border-radius: 999px;
  border: 1.5px solid var(--sr-border);
  background: var(--sr-surface);
  color: var(--sr-muted);
  font-size: 12px;
  font-weight: 700;
  white-space: nowrap;
  cursor: pointer;
  text-decoration: none;
  transition: border-color 0.18s, color 0.18s, background 0.18s;
  flex-shrink: 0;
}

.qbsr-filter:hover,
.qbsr-filter.active {
  border-color: var(--sr-accent);
  color: var(--sr-accent);
  background: var(--sr-accent-bg);
}

/* ══════════════════════════════════
   SECTION HEADERS
   ══════════════════════════════════ */
.qbsr-section {
  margin-bottom: 32px;
}

.qbsr-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px 12px;
}

.qbsr-section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  font-weight: 900;
  letter-spacing: -0.01em;
  color: var(--sr-text);
  margin: 0;
}

.qbsr-section-icon {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
}

.qbsr-section-icon.gold  { background: rgba(244,180,0,0.15); }
.qbsr-section-icon.pink  { background: rgba(194,24,91,0.12); }
.qbsr-section-icon.green { background: rgba(34,197,94,0.12); }

.qbsr-count-chip {
  font-size: 11px;
  font-weight: 800;
  padding: 3px 9px;
  border-radius: 999px;
  background: var(--sr-card2);
  color: var(--sr-muted);
}

/* Divider line */
.qbsr-divider {
  height: 1px;
  background: var(--sr-border);
  margin: 0 16px 20px;
  opacity: 0.6;
}

/* ══════════════════════════════════
   PRODUCTS GRID
   ══════════════════════════════════ */
.qbsr-grid-wrap {
  padding: 0 10px;
}

.qbsr-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  list-style: none;
  margin: 0;
  padding: 0;
}

@media (min-width: 540px) {
  .qbsr-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
}
@media (min-width: 900px) {
  .qbsr-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; }
  .qbsr-hero { padding: 28px 24px 0; }
  .qbsr-filters { padding: 0 24px 20px; }
  .qbsr-section-head { padding: 0 24px 12px; }
  .qbsr-divider { margin: 0 24px 20px; }
  .qbsr-grid-wrap { padding: 0 20px; }
  .qbsr-subs-scroll { padding: 0 20px 8px; }
  .qbsr-services-wrap { padding: 0 20px; }
}
@media (min-width: 1200px) {
  .qbsr-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); }
}

/* Product Card */
.qbsr-card {
  background: var(--sr-card);
  border: 1px solid var(--sr-border);
  border-radius: var(--sr-radius);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: border-color 0.2s, transform 0.18s, box-shadow 0.2s;
}

.qbsr-card:hover {
  border-color: rgba(244,180,0,0.35);
  transform: translateY(-2px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.25);
}

html:not([data-theme="dark"]) .qbsr-card:hover {
  box-shadow: 0 12px 32px rgba(0,0,0,0.10);
}

.qbsr-card-link {
  display: flex;
  flex-direction: column;
  flex: 1;
  text-decoration: none;
  color: inherit;
}

/* Image */
.qbsr-img-wrap {
  position: relative;
  aspect-ratio: 1 / 1;
  background: var(--sr-img-bg);
  overflow: hidden;
}

.qbsr-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  padding: 10px;
  transition: transform 0.28s ease;
}

.qbsr-card:hover .qbsr-img { transform: scale(1.05); }

.qbsr-no-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  background: var(--sr-surface);
  color: var(--sr-muted2);
}

/* Badges on image */
.qbsr-sale-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  padding: 3px 8px;
  background: var(--sr-red);
  color: #fff;
  font-size: 9px;
  font-weight: 900;
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  z-index: 2;
}

.qbsr-time-badge {
  position: absolute;
  bottom: 8px;
  right: 8px;
  padding: 3px 8px;
  background: rgba(0,0,0,0.65);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  border-radius: 999px;
  z-index: 2;
  backdrop-filter: blur(4px);
}

html:not([data-theme="dark"]) .qbsr-time-badge {
  background: rgba(0,0,0,0.55);
}

/* Card body */
.qbsr-card-body {
  padding: 10px 10px 4px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.qbsr-card-name {
  font-size: 12px;
  font-weight: 700;
  line-height: 1.35;
  color: var(--sr-text);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 2.7em;
  margin: 0;
}

.qbsr-price-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.qbsr-price {
  font-size: 15px;
  font-weight: 900;
  color: var(--sr-accent);
  letter-spacing: -0.02em;
}

.qbsr-compare {
  font-size: 11px;
  color: var(--sr-muted);
  text-decoration: line-through;
}

/* ADD button */
.qbsr-add-btn {
  margin: 8px 10px 10px;
  width: calc(100% - 20px);
  height: 36px;
  border: none;
  border-radius: 10px;
  background: var(--sr-magenta);
  color: #fff;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.05em;
  cursor: pointer;
  transition: background 0.18s, transform 0.15s, box-shadow 0.18s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  flex-shrink: 0;
}

.qbsr-add-btn:hover {
  background: #D81B60;
  transform: scale(1.02);
  box-shadow: 0 4px 14px rgba(194,24,91,0.35);
}

.qbsr-add-btn.loading {
  background: var(--sr-border);
  pointer-events: none;
  color: var(--sr-muted);
}

.qbsr-add-btn.success {
  background: var(--sr-green);
  color: #fff;
  pointer-events: none;
}

.qbsr-add-btn.error {
  background: rgba(239,68,68,0.15);
  color: var(--sr-red);
  border: 1px solid rgba(239,68,68,0.3);
  pointer-events: none;
}

/* ══════════════════════════════════
   SUBSCRIPTIONS SECTION
   ══════════════════════════════════ */
.qbsr-subs-scroll {
  display: flex;
  gap: 12px;
  padding: 0 10px 8px;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.qbsr-subs-scroll::-webkit-scrollbar { display: none; }

.qbsr-sub-card {
  flex-shrink: 0;
  width: 220px;
  background: var(--sr-card);
  border: 1px solid var(--sr-border);
  border-radius: var(--sr-radius);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: border-color 0.2s, transform 0.18s, box-shadow 0.2s;
  position: relative;
}

.qbsr-sub-card:hover {
  border-color: rgba(194,24,91,0.4);
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(194,24,91,0.12);
}

.qbsr-sub-card-img {
  aspect-ratio: 16/9;
  background: var(--sr-img-bg);
  overflow: hidden;
  position: relative;
}

.qbsr-sub-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.28s ease;
}

.qbsr-sub-card:hover .qbsr-sub-card-img img { transform: scale(1.04); }

.qbsr-sub-card-no-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  background: rgba(194,24,91,0.08);
}

.qbsr-sub-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  padding: 3px 8px;
  background: #C2185B;
  color: #fff;
  font-size: 9px;
  font-weight: 900;
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  z-index: 2;
}

.qbsr-sub-card-body {
  padding: 10px 12px 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
}

.qbsr-sub-name {
  font-size: 13px;
  font-weight: 800;
  color: var(--sr-text);
  line-height: 1.3;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.qbsr-sub-price {
  font-size: 14px;
  font-weight: 900;
  color: #E91E8C;
  letter-spacing: -0.01em;
}

.qbsr-sub-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  padding: 8px 12px;
  background: rgba(194,24,91,0.10);
  border: 1.5px solid rgba(194,24,91,0.25);
  border-radius: 10px;
  color: #C2185B;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  transition: background 0.18s, border-color 0.18s;
  margin-top: auto;
  text-decoration: none;
}

.qbsr-sub-card:hover .qbsr-sub-cta {
  background: rgba(194,24,91,0.18);
  border-color: rgba(194,24,91,0.5);
}

/* ══════════════════════════════════
   SERVICES SECTION
   ══════════════════════════════════ */
.qbsr-services-wrap {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 0 10px;
}

@media (min-width: 640px) {
  .qbsr-services-wrap {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
}

.qbsr-svc-card {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--sr-card);
  border: 1px solid var(--sr-border);
  border-radius: var(--sr-radius);
  padding: 16px;
  text-decoration: none;
  color: inherit;
  transition: border-color 0.2s, transform 0.18s, box-shadow 0.2s;
  position: relative;
  overflow: hidden;
}

.qbsr-svc-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 60%, rgba(34,197,94,0.04));
  pointer-events: none;
}

.qbsr-svc-card:hover {
  border-color: rgba(34,197,94,0.35);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(34,197,94,0.10);
}

.qbsr-svc-icon-wrap {
  flex-shrink: 0;
  width: 52px;
  height: 52px;
  border-radius: 14px;
  background: rgba(34,197,94,0.10);
  border: 1px solid rgba(34,197,94,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.qbsr-svc-info {
  flex: 1;
  min-width: 0;
}

.qbsr-svc-name {
  font-size: 14px;
  font-weight: 800;
  color: var(--sr-text);
  margin: 0 0 3px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.qbsr-svc-desc {
  font-size: 12px;
  color: var(--sr-muted);
  line-height: 1.4;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.qbsr-svc-arrow {
  flex-shrink: 0;
  color: var(--sr-muted2);
  transition: transform 0.2s, color 0.2s;
}

.qbsr-svc-card:hover .qbsr-svc-arrow {
  transform: translateX(3px);
  color: var(--sr-green);
}

/* ══════════════════════════════════
   TOAST
   ══════════════════════════════════ */
.qbsr-toast {
  position: fixed;
  bottom: 92px;
  left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: #111;
  border: 1px solid var(--sr-border2);
  color: #fff;
  padding: 11px 24px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  z-index: 9999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.22s, transform 0.22s;
  white-space: nowrap;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5);
}

.qbsr-toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.qbsr-toast.error { border-color: rgba(239,68,68,0.4); }

/* ══════════════════════════════════
   EMPTY STATE
   ══════════════════════════════════ */
.qbsr-empty {
  text-align: center;
  padding: 56px 24px 32px;
}

.qbsr-empty-icon { font-size: 56px; margin-bottom: 16px; line-height: 1; }

.qbsr-empty-title {
  font-size: clamp(22px, 6vw, 28px);
  font-weight: 900;
  letter-spacing: -0.03em;
  margin: 0 0 10px;
  color: var(--sr-text);
}

.qbsr-empty-sub {
  font-size: 14px;
  color: var(--sr-muted);
  line-height: 1.6;
  max-width: 30ch;
  margin: 0 auto 28px;
}

.qbsr-suggestions-label {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--sr-muted);
  margin-bottom: 12px;
}

.qbsr-suggestion-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
}

.qbsr-suggestion-chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 9px 16px;
  background: var(--sr-surface);
  border: 1.5px solid var(--sr-border);
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  color: var(--sr-text);
  text-decoration: none;
  transition: border-color 0.18s, color 0.18s;
}

.qbsr-suggestion-chip:hover {
  border-color: var(--sr-accent);
  color: var(--sr-accent);
}

/* ══════════════════════════════════
   PAGINATION
   ══════════════════════════════════ */
.qbsr-pagination {
  display: flex;
  justify-content: center;
  gap: 8px;
  padding: 28px 16px 0;
  flex-wrap: wrap;
}

.qbsr-page-btn {
  padding: 9px 18px;
  border-radius: 10px;
  background: var(--sr-surface);
  border: 1.5px solid var(--sr-border);
  color: var(--sr-text);
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  transition: border-color 0.18s, color 0.18s;
  cursor: pointer;
}

.qbsr-page-btn:hover,
.qbsr-page-btn.current {
  border-color: var(--sr-accent);
  color: var(--sr-accent);
  background: var(--sr-accent-bg);
}

/* ══════════════════════════════════
   ACCESSIBILITY
   ══════════════════════════════════ */
@media (prefers-reduced-motion: reduce) {
  .qbsr-card, .qbsr-sub-card, .qbsr-svc-card,
  .qbsr-add-btn, .qbsr-img, .qbsr-sub-card-img img {
    transition: none !important;
    transform: none !important;
  }
}
</style>

<div class="qbsr-page" id="qbsr">

  {%- assign product_results = search.results | where: 'object_type', 'product' -%}
  {%- assign sub_collection = collections['subscriptions'] -%}

  <!-- ══════════════════════════════════
       HERO
       ══════════════════════════════════ -->
  <div class="qbsr-hero">
    <p class="qbsr-hero-eyebrow">Search results</p>
    <h1 class="qbsr-hero-title">
      {%- if search.terms != blank -%}
        "<span class="qbsr-query-highlight">{{ search.terms | escape }}</span>"
      {%- else -%}
        Browse everything
      {%- endif -%}
    </h1>

    <div class="qbsr-hero-stats">
      {%- if product_results.size > 0 -%}
        <span class="qbsr-stat-pill products">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          {{ product_results.size }} product{{ product_results.size | pluralize: '', 's' }}
        </span>
      {%- endif -%}
      {%- if sub_collection and sub_collection.products_count > 0 -%}
        <span class="qbsr-stat-pill subs">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          {{ sub_collection.products_count }} subscription{{ sub_collection.products_count | pluralize: '', 's' }}
        </span>
      {%- endif -%}
      <span class="qbsr-stat-pill services">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        Services
      </span>
    </div>
  </div>

  <!-- ══════════════════════════════════
       FILTER CHIPS
       ══════════════════════════════════ -->
  {%- if search.terms != blank or product_results.size > 0 -%}
  <div class="qbsr-filters" id="qbsrFilters">
    {%- assign base_q = search.terms | escape -%}
    <a href="/search?q={{ base_q }}&type=product" class="qbsr-filter active">🛍️ All</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Beer" class="qbsr-filter">🍺 Beer</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Drinks" class="qbsr-filter">🥤 Drinks</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Snacks" class="qbsr-filter">🍟 Snacks</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Food" class="qbsr-filter">🍔 Food</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Grocery" class="qbsr-filter">🥦 Grocery</a>
    <a href="/search?q={{ base_q }}&type=product&filter.p.type=Cigarettes" class="qbsr-filter">🚬 Smokes</a>
  </div>
  {%- endif -%}

  {%- if product_results.size > 0 or sub_collection.products_count > 0 -%}

    <!-- ══════════════════════════════════
         PRODUCTS SECTION
         ══════════════════════════════════ -->
    {%- if product_results.size > 0 -%}
    <div class="qbsr-section">
      <div class="qbsr-section-head">
        <h2 class="qbsr-section-title">
          <span class="qbsr-section-icon gold">🛍️</span>
          Products
        </h2>
        <span class="qbsr-count-chip">{{ product_results.size }}</span>
      </div>

      {%- paginate search.results by 24 -%}
      <div class="qbsr-grid-wrap">
        <ul class="qbsr-grid" id="qbsrGrid">
          {%- for product in product_results -%}
            {%- assign sale = false -%}
            {%- if product.compare_at_price > product.price -%}
              {%- assign sale = true -%}
              {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
            {%- endif -%}

            <li class="qbsr-card">
              <a href="{{ product.url }}" class="qbsr-card-link">
                <div class="qbsr-img-wrap">
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 480 }}"
                      alt="{{ product.featured_image.alt | default: product.title | escape }}"
                      class="qbsr-img"
                      loading="lazy"
                      width="480"
                      height="480"
                    >
                  {%- else -%}
                    <div class="qbsr-no-img">🐝</div>
                  {%- endif -%}

                  {%- if sale -%}
                    <span class="qbsr-sale-badge">{{ discount }}% OFF</span>
                  {%- endif -%}
                  <span class="qbsr-time-badge qbsr-time-sync">⚡ 20 mins</span>
                </div>

                <div class="qbsr-card-body">
                  <h3 class="qbsr-card-name">{{ product.title }}</h3>
                  <div class="qbsr-price-row">
                    <span class="qbsr-price">Rs {{ product.price | money_without_currency }}</span>
                    {%- if sale -%}
                      <span class="qbsr-compare">Rs {{ product.compare_at_price | money_without_currency }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </a>

              <button
                class="qbsr-add-btn"
                data-variant="{{ product.first_available_variant.id }}"
                data-name="{{ product.title | escape }}"
                aria-label="Add {{ product.title | escape }} to cart"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                ADD
              </button>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      {%- if paginate.pages > 1 -%}
      <div class="qbsr-pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="qbsr-page-btn">← Prev</a>
        {%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}" class="qbsr-page-btn">{{ part.title }}</a>
          {%- else -%}
            <span class="qbsr-page-btn current">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="qbsr-page-btn">Next →</a>
        {%- endif -%}
      </div>
      {%- endif -%}
      {%- endpaginate -%}
    </div>
    {%- endif -%}

    <!-- ══════════════════════════════════
         SUBSCRIPTIONS SECTION
         ══════════════════════════════════ -->
    {%- if sub_collection and sub_collection.products_count > 0 -%}
    <div class="qbsr-section">
      <div class="qbsr-divider"></div>
      <div class="qbsr-section-head">
        <h2 class="qbsr-section-title">
          <span class="qbsr-section-icon pink">📦</span>
          Subscriptions
        </h2>
        <span class="qbsr-count-chip">{{ sub_collection.products_count }}</span>
      </div>

      <div class="qbsr-subs-scroll">
        {%- for product in sub_collection.products limit: 10 -%}
          <a href="{{ product.url }}" class="qbsr-sub-card">
            <div class="qbsr-sub-card-img">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 440 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="440"
                  height="248"
                >
              {%- else -%}
                <div class="qbsr-sub-card-no-img">📦</div>
              {%- endif -%}
              <span class="qbsr-sub-badge">SUBSCRIBE</span>
            </div>
            <div class="qbsr-sub-card-body">
              <h3 class="qbsr-sub-name">{{ product.title }}</h3>
              <p class="qbsr-sub-price">From Rs {{ product.price | money_without_currency }}</p>
              <span class="qbsr-sub-cta">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                Subscribe & Save
              </span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

  {%- else -%}

    <!-- ══════════════════════════════════
         EMPTY STATE
         ══════════════════════════════════ -->
    <div class="qbsr-empty">
      <div class="qbsr-empty-icon">🔎</div>
      <h2 class="qbsr-empty-title">
        {%- if search.terms != blank -%}
          No results for "{{ search.terms | escape }}"
        {%- else -%}
          What are you craving?
        {%- endif -%}
      </h2>
      <p class="qbsr-empty-sub">
        {%- if search.terms != blank -%}
          Try a shorter word, check spelling, or browse a category below.
        {%- else -%}
          Search across groceries, drinks, snacks, beer and more.
        {%- endif -%}
      </p>
      <p class="qbsr-suggestions-label">Try these</p>
      <div class="qbsr-suggestion-chips">
        <a href="/search?q=beer&type=product"           class="qbsr-suggestion-chip">🍺 Beer</a>
        <a href="/search?q=cold+drinks&type=product"    class="qbsr-suggestion-chip">🥤 Cold Drinks</a>
        <a href="/search?q=chips&type=product"          class="qbsr-suggestion-chip">🍟 Chips</a>
        <a href="/search?q=noodles&type=product"        class="qbsr-suggestion-chip">🍜 Noodles</a>
        <a href="/search?q=vodka&type=product"          class="qbsr-suggestion-chip">🥃 Vodka</a>
        <a href="/search?q=cigarette&type=product"      class="qbsr-suggestion-chip">🚬 Cigarettes</a>
        <a href="/search?q=juice&type=product"          class="qbsr-suggestion-chip">🧃 Juice</a>
        <a href="/search?q=chocolate&type=product"      class="qbsr-suggestion-chip">🍫 Chocolate</a>
      </div>
    </div>

  {%- endif -%}

  <!-- ══════════════════════════════════
       SERVICES SECTION (always shown)
       ══════════════════════════════════ -->
  <div class="qbsr-section" style="margin-top: 8px;">
    <div class="qbsr-divider"></div>
    <div class="qbsr-section-head">
      <h2 class="qbsr-section-title">
        <span class="qbsr-section-icon green">⚡</span>
        Our Services
      </h2>
    </div>

    <div class="qbsr-services-wrap">
      <a href="/pages/subscription" class="qbsr-svc-card">
        <div class="qbsr-svc-icon-wrap">📦</div>
        <div class="qbsr-svc-info">
          <p class="qbsr-svc-name">Daily Subscriptions</p>
          <p class="qbsr-svc-desc">Get fresh products delivered every day — milk, eggs, bread & more.</p>
        </div>
        <svg class="qbsr-svc-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M9 18l6-6-6-6"/></svg>
      </a>

      <a href="/pages/party-order" class="qbsr-svc-card">
        <div class="qbsr-svc-icon-wrap">🎉</div>
        <div class="qbsr-svc-info">
          <p class="qbsr-svc-name">Party & Bulk Orders</p>
          <p class="qbsr-svc-desc">Planning a party? Order in bulk and we'll sort you out fast.</p>
        </div>
        <svg class="qbsr-svc-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M9 18l6-6-6-6"/></svg>
      </a>

      <a href="/pages/beer-delivery" class="qbsr-svc-card">
        <div class="qbsr-svc-icon-wrap">🍺</div>
        <div class="qbsr-svc-info">
          <p class="qbsr-svc-name">Beer on Demand</p>
          <p class="qbsr-svc-desc">Cold beer in under 22 minutes. No compromise, no waiting.</p>
        </div>
        <svg class="qbsr-svc-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M9 18l6-6-6-6"/></svg>
      </a>

      <a href="/pages/contact" class="qbsr-svc-card">
        <div class="qbsr-svc-icon-wrap">💬</div>
        <div class="qbsr-svc-info">
          <p class="qbsr-svc-name">Talk to Us</p>
          <p class="qbsr-svc-desc">Questions, special requests, or feedback — we're always here.</p>
        </div>
        <svg class="qbsr-svc-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M9 18l6-6-6-6"/></svg>
      </a>
    </div>
  </div>

</div>

<!-- Toast -->
<div class="qbsr-toast" id="qbsrToast"></div>

<script>
(function () {
  /* ── Delivery time sync ── */
  function syncTime() {
    var range = (window.QB_DELIVERY_TIME && window.QB_DELIVERY_TIME.range) || '20 mins';
    document.querySelectorAll('.qbsr-time-sync').forEach(function (b) {
      b.textContent = '⚡ ' + range;
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', syncTime);
  } else {
    syncTime();
  }
  window.addEventListener('locationSelected', function () { setTimeout(syncTime, 50); });

  /* ── Toast ── */
  function showToast(msg, isError) {
    var t = document.getElementById('qbsrToast');
    if (!t) return;
    t.textContent = msg;
    t.className = 'qbsr-toast show' + (isError ? ' error' : '');
    clearTimeout(t._timer);
    t._timer = setTimeout(function () { t.classList.remove('show'); }, 2600);
  }

  /* ── Add to cart ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.qbsr-add-btn');
    if (!btn || btn.classList.contains('loading') || btn.classList.contains('success')) return;

    var variantId = btn.getAttribute('data-variant');
    var name = btn.getAttribute('data-name') || 'Item';
    if (!variantId || variantId === 'null' || variantId === '') {
      showToast('Out of stock', true);
      return;
    }

    btn.classList.add('loading');
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
    })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (d.id) {
        btn.classList.remove('loading');
        btn.classList.add('success');
        btn.innerHTML = '✓ Added';
        showToast('✅ ' + name + ' added!');
        document.dispatchEvent(new CustomEvent('cart:updated'));
        fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (c) {
            var el = document.getElementById('cart-count');
            if (el) el.textContent = c.item_count;
          });
        setTimeout(function () {
          btn.classList.remove('success');
          btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> ADD';
        }, 2200);
      } else {
        throw new Error(d.description || 'Failed');
      }
    })
    .catch(function () {
      btn.classList.remove('loading');
      btn.classList.add('error');
      btn.innerHTML = '✗ Error';
      showToast('Could not add item', true);
      setTimeout(function () {
        btn.classList.remove('error');
        btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> ADD';
      }, 2000);
    });
  });
})();
</script>

