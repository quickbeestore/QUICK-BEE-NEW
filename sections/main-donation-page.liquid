{%- style -%}
  .donation-page {
    --color-primary: #0056b3;
    --color-primary-light: #e6f0ff;
    --color-text: #333;
    --color-white: #ffffff;
    --border-radius: 12px;
    --shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background-color: #f8fbff;
    color: var(--color-text);
    padding: 40px 20px;
    max-width: 800px;
    margin: 0 auto;
    border-radius: var(--border-radius);
  }

  .donation-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .donation-header h1 {
    color: var(--color-primary);
    font-size: 2.5rem;
    margin-bottom: 10px;
    font-weight: 700;
  }

  .donation-header p {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 5px;
  }

  .donation-header .powered-by {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #999;
    font-weight: 600;
  }

  .donation-form-wrapper {
    background: var(--color-white);
    padding: 30px;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow);
  }

  .form-group {
    margin-bottom: 20px;
    position: relative;
  }

  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-primary);
  }

  .input-with-icon {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-with-icon .icon {
    position: absolute;
    left: 15px;
    width: 20px;
    height: 20px;
    fill: var(--color-primary);
    opacity: 0.6;
    pointer-events: none;
  }

  .donation-form-wrapper input,
  .donation-form-wrapper select,
  .donation-form-wrapper textarea {
    width: 100%;
    padding: 12px 15px 12px 45px;
    border: 1.5px solid #e1e8f0;
    border-radius: 10px;
    font-size: 1rem;
    transition: all 0.3s ease;
    background-color: #fdfdfd;
  }

  .donation-form-wrapper textarea {
    min-height: 100px;
    resize: vertical;
  }

  .donation-form-wrapper input:focus,
  .donation-form-wrapper select:focus,
  .donation-form-wrapper textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px var(--color-primary-light);
    background-color: #fff;
  }

  .submit-btn {
    width: 100%;
    background-color: var(--color-primary);
    color: white;
    border: none;
    padding: 16px;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
  }

  .submit-btn:hover {
    background-color: #004494;
    transform: translateY(-2px);
    box-shadow: 0 6px 15px rgba(0, 86, 179, 0.3);
  }

  .submit-btn:active {
    transform: translateY(0);
  }

  .info-section {
    margin-top: 40px;
    text-align: center;
    background: var(--color-primary-light);
    padding: 20px;
    border-radius: var(--border-radius);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .trust-badges {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 15px;
    margin-top: 30px;
  }

  .badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .badge-icon {
    color: #28a745;
    font-size: 1.2rem;
  }

  .footer-cta {
    text-align: center;
    margin-top: 40px;
    font-style: italic;
    color: #666;
  }

  .qr-section {
    margin-top: 40px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .success-message {
    display: none;
    text-align: center;
    padding: 40px 20px;
  }

  .success-message h2 {
    color: #28a745;
    margin-bottom: 15px;
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-color: #25d366;
    color: white;
    padding: 12px 25px;
    border-radius: 30px;
    text-decoration: none;
    font-weight: 600;
    margin-top: 20px;
    transition: transform 0.3s ease;
  }

  .whatsapp-btn:hover {
    transform: scale(1.05);
  }

  /* Loading Animation */
  .loader {
    display: none;
    border: 3px solid #f3f3f3;
    border-top: 3px solid var(--color-primary);
    border-radius: 50%;
    width: 20px;
    height: 20px;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @media (max-width: 600px) {
    .donation-page {
      padding: 20px 15px;
    }
    .donation-header h1 {
      font-size: 1.8rem;
    }
    .trust-badges {
      flex-direction: column;
      align-items: flex-start;
      padding-left: 20%;
    }
  }
{%- endstyle -%}

<div class="donation-page">
  <header class="donation-header">
    <h1>Donate Your Old Clothes</h1>
    <p>We’ll wash, iron, and distribute to the needful</p>
    <div class="powered-by">Powered by KapadaWash × Nepal Youth Club</div>
  </header>

  <div class="donation-form-wrapper" id="donationFormContainer">
    {%- form 'contact', id: 'donationForm' -%}
      <input type="hidden" name="contact[subject]" value="New Clothes Donation Request">
      <input type="hidden" name="contact[email]" value="sanilmaharjn@gmail.com">

      <div class="form-group">
        <label for="FullName">Full Name</label>
        <div class="input-with-icon">
          <span class="icon">{%- render 'icon-account' -%}</span>
          <input type="text" id="FullName" name="contact[name]" placeholder="Enter your full name" required>
        </div>
      </div>

      <div class="form-group">
        <label for="PhoneNumber">Phone Number</label>
        <div class="input-with-icon">
          <span class="icon">{%- render 'icon-available' -%}</span>
          <input type="tel" id="PhoneNumber" name="contact[phone]" placeholder="e.g. 98XXXXXXXX" required pattern="[0-9]{10}">
        </div>
      </div>

      <div class="form-group">
        <label for="Location">Location Area</label>
        <div class="input-with-icon">
          <span class="icon">{%- render 'icon-filter' -%}</span>
          <select id="Location" name="contact[location]" required>
            <option value="" disabled selected>Select your area</option>
            <option value="Kathmandu">Kathmandu</option>
            <option value="Lalitpur">Lalitpur</option>
            <option value="Bhaktapur">Bhaktapur</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="Address">Pickup Address</label>
        <div class="input-with-icon">
          <span class="icon" style="top: 15px;">{%- render 'icon-search' -%}</span>
          <textarea id="Address" name="contact[address]" placeholder="Detailed pickup address" required></textarea>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
        <div class="form-group">
          <label for="PickupDate">Preferred Date</label>
          <div class="input-with-icon">
            <span class="icon">{%- render 'icon-checkmark' -%}</span>
            <input type="date" id="PickupDate" name="contact[pickup_date]" required>
          </div>
        </div>

        <div class="form-group">
          <label for="TimeSlot">Time Slot</label>
          <div class="input-with-icon">
            <span class="icon">{%- render 'icon-available' -%}</span>
            <select id="TimeSlot" name="contact[time_slot]" required>
              <option value="Morning">Morning</option>
              <option value="Afternoon">Afternoon</option>
              <option value="Evening">Evening</option>
            </select>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label for="ClothesCount">Number of Clothes</label>
        <div class="input-with-icon">
          <span class="icon">{%- render 'icon-orders' -%}</span>
          <select id="ClothesCount" name="contact[clothes_count]" required>
            <option value="5-10">5 – 10</option>
            <option value="10-20">10 – 20</option>
            <option value="20-50">20 – 50</option>
            <option value="50+">50+</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="Notes">Special Notes (Optional)</label>
        <div class="input-with-icon">
          <span class="icon" style="top: 15px;">{%- render 'icon-info' -%}</span>
          <textarea id="Notes" name="contact[notes]" placeholder="Any instructions for our team?"></textarea>
        </div>
      </div>

      <button type="submit" class="submit-btn" id="submitBtn">
        <span>Schedule Donation Pickup</span>
        <div class="loader" id="btnLoader"></div>
      </button>

      {%- if form.posted_successfully? -%}
        <script>
          window.location.hash = '#success';
        </script>
      {%- endif -%}
    {%- endform -%}
  </div>

  <div class="success-message" id="successMessage">
    <h2>Thank you!</h2>
    <p>Your request has been received. Our team will contact you shortly.</p>
    <a href="https://wa.me/9779800000000?text=I%20just%20submitted%20a%20donation%20request%20on%20KapadaWash" class="whatsapp-btn" target="_blank">
      <span>Chat with us on WhatsApp</span>
    </a>
  </div>

  <section class="info-section">
    Your clothes will be professionally cleaned by <strong>KapadaWash</strong> and distributed by <strong>Nepal Youth Club</strong> to people in need. We ensure every garment is handled with care and respect.
  </section>

  <div class="trust-badges">
    <div class="badge"><span class="badge-icon">✔</span> Cleaned Professionally</div>
    <div class="badge"><span class="badge-icon">✔</span> Donated Responsibly</div>
    <div class="badge"><span class="badge-icon">✔</span> Free Pickup</div>
  </div>

  <div class="footer-cta">
    “Make a difference today”
  </div>

  <div class="qr-section">
    <p style="font-size: 0.8rem; color: #888;">Scan to share this page</p>
    <qr-code-image 
      data-identifier="https://kapadawash.com/pages/donate-clothes" 
      width="100" 
      height="100"
    ></qr-code-image>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('donationForm');
    const submitBtn = document.getElementById('submitBtn');
    const loader = document.getElementById('btnLoader');
    const formContainer = document.getElementById('donationFormContainer');
    const successMessage = document.getElementById('successMessage');

    // Check if redirected after success
    if (window.location.hash === '#success') {
      formContainer.style.display = 'none';
      successMessage.style.display = 'block';
      successMessage.scrollIntoView({ behavior: 'smooth' });
    }

    if (form) {
      form.addEventListener('submit', function() {
        submitBtn.querySelector('span').textContent = 'Processing...';
        loader.style.display = 'block';
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';
        submitBtn.style.cursor = 'not-allowed';
      });
    }

    // Set minimum date to today
    const dateInput = document.getElementById('PickupDate');
    if (dateInput) {
      const today = new Date().toISOString().split('T')[0];
      dateInput.setAttribute('min', today);
    }
  });
</script>

{% schema %}
{
  "name": "Donation Page",
  "settings": [],
  "presets": [
    {
      "name": "Donation Page"
    }
  ]
}
{% endschema %}
