{%- style -%}
  .donation-page-container {
    --primary-color: #0056b3;
    --primary-hover: #004494;
    --bg-light: #f8fbff;
    --text-main: #1f2937;
    --text-muted: #6b7280;
    --border-color: #e5e7eb;
    --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    --focus-ring: #F472B6;
    
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background-color: var(--bg-light);
    color: var(--text-main);
    padding: 24px 16px;
    max-width: 800px;
    margin: 0 auto;
  }

  [data-theme="dark"] .donation-page-container {
    --bg-light: #111827;
    --text-main: #f9fafb;
    --text-muted: #9ca3af;
    --border-color: #374151;
    --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  /* Partnership Header */
  .partnership-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
    padding: 12px;
  }

  .partner-logo {
    max-width: 120px;
    height: auto;
    object-fit: contain;
  }

  .partner-divider {
    font-size: 20px;
    font-weight: 600;
    color: var(--text-muted);
    opacity: 0.5;
  }

  /* Form Card */
  .donation-card {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: var(--card-shadow);
    padding: 24px;
    margin-bottom: 32px;
  }

  [data-theme="dark"] .donation-card {
    background: #1f2937;
  }

  .donation-header {
    text-align: center;
    margin-bottom: 24px;
  }

  .donation-header h1 {
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 8px;
    color: var(--primary-color);
  }

  .donation-header p {
    font-size: 14px;
    color: var(--text-muted);
  }

  /* Form Layout */
  .donation-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 6px;
    display: block;
    color: var(--text-main);
  }

  .input-wrapper {
    position: relative;
  }

  .donation-form input,
  .donation-form select,
  .donation-form textarea {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0 16px;
    font-size: 16px;
    background-color: transparent;
    color: var(--text-main);
    transition: all 0.2s ease;
    box-sizing: border-box;
  }

  .donation-form textarea {
    padding: 12px 16px;
    min-height: 100px;
    resize: vertical;
  }

  .donation-form input:focus,
  .donation-form select:focus,
  .donation-form textarea:focus {
    outline: none;
    border-color: var(--focus-ring);
    box-shadow: 0 0 0 2px rgba(244, 114, 182, 0.2);
  }

  /* Desktop Grid Progressive Enhancement */
  @media (min-width: 768px) {
    .grid-2-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    
    .donation-page-container {
      padding: 48px 20px;
    }
    
    .donation-header h1 {
      font-size: 32px;
    }
  }

  /* Submit Button */
  .submit-btn {
    width: 100%;
    background-color: var(--primary-color);
    color: #ffffff;
    border: none;
    min-height: 54px;
    padding: 12px 24px;
    font-size: 16px;
    font-weight: 700;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
  }

  .submit-btn:hover {
    background-color: var(--primary-hover);
    transform: translateY(-1px);
  }

  .submit-btn:active {
    transform: translateY(0);
  }

  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  /* Extra sections */
  .info-section {
    text-align: center;
    padding: 24px;
    background: rgba(0, 86, 179, 0.05);
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .trust-badges {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 32px;
  }

  .badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--primary-color);
  }

  .badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: var(--primary-color);
    color: white;
    border-radius: 50%;
    font-size: 10px;
  }

  .success-message {
    display: none;
    text-align: center;
    padding: 40px 20px;
  }

  .success-message h2 {
    color: #10b981;
    margin-bottom: 16px;
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-color: #25d366;
    color: white;
    padding: 12px 24px;
    border-radius: 30px;
    text-decoration: none;
    font-weight: 600;
    margin-top: 24px;
  }

  .qr-section {
    text-align: center;
    margin-top: 40px;
    opacity: 0.8;
  }

  /* Loader */
  .loader {
    display: none;
    width: 20px;
    height: 20px;
    border: 2px solid #ffffff;
    border-bottom-color: transparent;
    border-radius: 50%;
    animation: rotation 1s linear infinite;
  }

  @keyframes rotation {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
{%- endstyle -%}

<div class="donation-page-container">
  
  <header class="partnership-header">
    <img src="{{ 'kapadawash.png' | asset_img_url: 'master' }}" alt="KapadaWash Logo" class="partner-logo" width="120" height="40" loading="lazy">
    <span class="partner-divider">x</span>
    <img src="{{ 'nepalyouthclub.png' | asset_img_url: 'master' }}" alt="Nepal Youth Club Logo" class="partner-logo" width="120" height="40" loading="lazy">
  </header>

  <div class="donation-card" id="donationFormContainer">
    <div class="donation-header">
      <h1>Donate Your Old Clothes</h1>
      <p>We’ll wash, iron, and distribute them to those in need.</p>
    </div>

    {%- form 'contact', id: 'donationForm', class: 'donation-form' -%}
      <input type="hidden" name="contact[subject]" value="New Clothes Donation Request">
      <input type="hidden" name="contact[target_email]" value="sanilmaharjn@gmail.com">

      <div class="form-group">
        <label for="FullName">Full Name</label>
        <input type="text" id="FullName" name="contact[name]" placeholder="Enter your full name" required>
      </div>

      <div class="form-group">
        <label for="PhoneNumber">Phone Number</label>
        <input type="tel" id="PhoneNumber" name="contact[phone]" placeholder="e.g. 98XXXXXXXX" required pattern="[0-9]{10}">
      </div>

      <div class="form-group">
        <label for="Location">Location Area</label>
        <select id="Location" name="contact[location]" required>
          <option value="" disabled selected>Select your area</option>
          <option value="Kathmandu">Kathmandu</option>
          <option value="Lalitpur">Lalitpur</option>
          <option value="Bhaktapur">Bhaktapur</option>
        </select>
      </div>

      <div class="form-group">
        <label for="Address">Pickup Address</label>
        <textarea id="Address" name="contact[address]" placeholder="Enter detailed pickup address" required></textarea>
      </div>

      <div class="grid-2-col">
        <div class="form-group">
          <label for="PickupDate">Preferred Date</label>
          <input type="date" id="PickupDate" name="contact[pickup_date]" required>
        </div>

        <div class="form-group">
          <label for="TimeSlot">Time Slot</label>
          <select id="TimeSlot" name="contact[time_slot]" required>
            <option value="Morning">Morning (9 AM – 12 PM)</option>
            <option value="Afternoon">Afternoon (12 PM – 4 PM)</option>
            <option value="Evening">Evening (4 PM – 7 PM)</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="ClothesCount">Number of Clothes (Approx.)</label>
        <select id="ClothesCount" name="contact[clothes_count]" required>
          <option value="5-10">5 – 10 items</option>
          <option value="10-20">10 – 20 items</option>
          <option value="20-50">20 – 50 items</option>
          <option value="50+">50+ items</option>
        </select>
      </div>

      <div class="form-group">
        <label for="Notes">Special Notes (Optional)</label>
        <textarea id="Notes" name="contact[notes]" placeholder="Any specific instructions for our team?"></textarea>
      </div>

      <button type="submit" class="submit-btn" id="submitBtn">
        <span>Schedule Donation Pickup</span>
        <div class="loader" id="btnLoader"></div>
      </button>

      {%- if form.posted_successfully? -%}
        <script>
          window.location.hash = '#success';
        </script>
      {%- endif -%}
    {%- endform -%}
  </div>

  <div class="success-message" id="successMessage">
    <h2>Thank You! ❤️</h2>
    <p>Your donation request has been received successfully. Our team will contact you shortly to coordinate the pickup.</p>
    <a href="https://wa.me/9779800000000?text=I%20just%20submitted%20a%20donation%20request%20on%20KapadaWash" class="whatsapp-btn" target="_blank">
      <span>Chat with us on WhatsApp</span>
    </a>
  </div>

  <section class="info-section">
    Your clothes will be professionally cleaned by <strong>KapadaWash</strong> and distributed by <strong>Nepal Youth Club</strong> to people in need. We ensure every garment is handled with care and respect.
  </section>

  <div class="trust-badges">
    <div class="badge"><span class="badge-icon">✓</span> Cleaned Professionally</div>
    <div class="badge"><span class="badge-icon">✓</span> Donated Responsibly</div>
    <div class="badge"><span class="badge-icon">✓</span> Free Pickup</div>
  </div>

  <div class="qr-section">
    <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 12px;">Scan to share this page</p>
    <qr-code-image 
      data-identifier="{{ shop.url }}{{ page.url }}" 
      width="100" 
      height="100"
    ></qr-code-image>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('donationForm');
    const submitBtn = document.getElementById('submitBtn');
    const loader = document.getElementById('btnLoader');
    const formContainer = document.getElementById('donationFormContainer');
    const successMessage = document.getElementById('successMessage');

    // Check if success hash is present
    if (window.location.hash === '#success') {
      formContainer.style.display = 'none';
      successMessage.style.display = 'block';
      successMessage.scrollIntoView({ behavior: 'smooth' });
    }

    if (form) {
      form.addEventListener('submit', function() {
        submitBtn.querySelector('span').textContent = 'Processing...';
        loader.style.display = 'block';
        submitBtn.disabled = true;
      });
    }

    // Set min date to today
    const dateInput = document.getElementById('PickupDate');
    if (dateInput) {
      const today = new Date().toISOString().split('T')[0];
      dateInput.setAttribute('min', today);
    }
  });
</script>

{% schema %}
{
  "name": "Donation Page",
  "settings": [],
  "presets": [
    {
      "name": "Donation Page"
    }
  ]
}
{% endschema %}
