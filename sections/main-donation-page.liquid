{%- style -%}
  .donation-page {
    --brand-primary: #0056b3;
    --brand-accent: #F472B6;
    
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background-color: transparent;
    padding: 40px 20px;
    max-width: 800px;
    margin: 0 auto;
    transition: background-color 0.3s ease;
  }

  /* Partnership Header */
  .partnership-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 32px;
  }

  .partnership-header img {
    max-height: 50px;
    max-width: 120px;
    object-fit: contain;
  }

  .partnership-header .divider {
    font-size: 24px;
    color: var(--theme-border);
    font-weight: 300;
  }

  .donation-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .donation-header h1 {
    color: var(--theme-text-main);
    font-size: 2rem;
    margin-bottom: 8px;
    font-weight: 800;
  }

  .donation-header p {
    font-size: 1.1rem;
    color: var(--theme-text-muted);
    line-height: 1.5;
  }

  /* Form Card Layout */
  .donation-form-wrapper {
    background: var(--theme-bg-primary);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    padding: 24px;
    margin-bottom: 32px;
    border: 1px solid var(--theme-border);
    transition: all 0.3s ease;
  }

  .donation-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    margin-bottom: 6px;
    font-size: 0.95rem;
    color: var(--theme-text-main);
  }

  /* Inputs & Selects */
  .donation-form-wrapper input,
  .donation-form-wrapper select,
  .donation-form-wrapper textarea {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--theme-border);
    border-radius: 8px;
    padding: 0 16px;
    font-size: 16px; 
    background-color: var(--theme-bg-secondary);
    color: var(--theme-text-main);
    transition: all 0.2s ease;
    box-sizing: border-box;
  }

  .donation-form-wrapper textarea {
    padding: 12px 16px;
    min-height: 100px;
    resize: vertical;
  }

  .donation-form-wrapper input:focus,
  .donation-form-wrapper select:focus,
  .donation-form-wrapper textarea:focus {
    outline: 2px solid var(--brand-accent);
    outline-offset: -1px;
    border-color: transparent;
    background-color: var(--theme-bg-primary);
  }

  /* Desktop Grid */
  @media screen and (min-width: 768px) {
    .form-grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    
    .donation-header h1 {
      font-size: 2.5rem;
    }
    
    .donation-form-wrapper {
      padding: 40px;
    }
  }

  /* Submit Button */
  .submit-btn {
    width: 100%;
    min-height: 54px;
    background-color: var(--brand-primary);
    color: white !important; 
    border: none;
    padding: 16px;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
  }

  .submit-btn:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(0, 86, 179, 0.2);
  }

  .submit-btn:active {
    transform: translateY(0);
  }

  /* Success UI */
  .success-message {
    display: none;
    text-align: center;
    padding: 40px 20px;
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-color: #25d366;
    color: white !important;
    padding: 14px 28px;
    border-radius: 30px;
    text-decoration: none;
    font-weight: 700;
    margin-top: 24px;
    transition: transform 0.2s ease;
  }

  .whatsapp-btn:hover {
    transform: scale(1.03);
  }

  .loader {
    display: none;
    border: 3px solid rgba(255,255,255,0.3);
    border-top: 3px solid #ffffff;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .info-section {
    margin-top: 40px;
    text-align: center;
    color: var(--theme-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    padding: 0 20px;
  }

  /* --- DARK MODE OVERRIDES --- */
  [data-theme="dark"] .donation-page,
  body.dark-theme .donation-page {
    background-color: transparent !important;
    color: #F9FAFB !important;
  }

  [data-theme="dark"] .donation-header h1,
  body.dark-theme .donation-header h1 {
    color: #F9FAFB !important;
  }

  [data-theme="dark"] .donation-header p,
  body.dark-theme .donation-header p {
    color: #9CA3AF !important;
  }

  [data-theme="dark"] .donation-form-wrapper,
  body.dark-theme .donation-form-wrapper {
    background-color: #1E1E1E !important;
    border: 1px solid #333333 !important;
    box-shadow: none !important;
  }

  [data-theme="dark"] .form-group label,
  body.dark-theme .form-group label {
    color: #E5E7EB !important;
  }

  [data-theme="dark"] .donation-form-wrapper input,
  [data-theme="dark"] .donation-form-wrapper select,
  [data-theme="dark"] .donation-form-wrapper textarea,
  body.dark-theme .donation-form-wrapper input,
  body.dark-theme .donation-form-wrapper select,
  body.dark-theme .donation-form-wrapper textarea {
    background-color: #2A2A2A !important;
    border: 1px solid #4B5563 !important;
    color: #FFFFFF !important;
  }

  /* Standardize placeholders */
  [data-theme="dark"] .donation-form-wrapper input::placeholder,
  [data-theme="dark"] .donation-form-wrapper textarea::placeholder,
  body.dark-theme .donation-form-wrapper input::placeholder,
  body.dark-theme .donation-form-wrapper textarea::placeholder {
    color: #9CA3AF !important;
  }

  /* Fix focus state in dark mode */
  [data-theme="dark"] .donation-form-wrapper input:focus,
  [data-theme="dark"] .donation-form-wrapper select:focus,
  [data-theme="dark"] .donation-form-wrapper textarea:focus,
  body.dark-theme .donation-form-wrapper input:focus,
  body.dark-theme .donation-form-wrapper select:focus,
  body.dark-theme .donation-form-wrapper textarea:focus {
    background-color: #2A2A2A !important;
    outline-color: var(--brand-accent) !important;
  }

  [data-theme="dark"] .partnership-header .divider,
  body.dark-theme .partnership-header .divider {
    color: #F9FAFB !important;
  }
  
  [data-theme="dark"] .success-message h2,
  body.dark-theme .success-message h2 {
    color: #F9FAFB !important;
  }
  
  [data-theme="dark"] .success-message p,
  body.dark-theme .success-message p {
    color: #9CA3AF !important;
  }

  [data-theme="dark"] .info-section,
  body.dark-theme .info-section {
    color: #9CA3AF !important;
  }
{%- endstyle -%}

<div class="donation-page">
  <div class="partnership-header">
    <img src="{{ 'kapadawash.png' | asset_img_url: 'master' }}" alt="KapadaWash" loading="lazy">
    <span class="divider">×</span>
    <img src="{{ 'nepalyouthclub.png' | asset_img_url: 'master' }}" alt="Nepal Youth Club" loading="lazy">
  </div>

  <header class="donation-header">
    <h1>Donate Your Old Clothes</h1>
    <p>Give your clothes a second life. We’ll wash, iron, and distribute them to those in need.</p>
  </header>

<div class="donation-form-wrapper" id="donationFormContainer">
    {%- form 'contact', id: 'donationForm', class: 'donation-form' -%}

      {% if form.posted_successfully? %}
        <div class="success-message" id="successMessage">
          <div style="font-size: 4rem; margin-bottom: 20px;">🐝</div>
          <h2 style="color: var(--theme-text-main); font-size: 2rem; margin-bottom: 12px;">Pickup Scheduled Successfully!</h2>
          <p style="color: var(--theme-text-muted); font-size: 1.1rem; max-width: 450px; margin: 0 auto 24px;">Thank you for giving your clothes a second life. Please share this initiative with your friends!</p>
          <div class="success-actions" style="display: flex; flex-direction: column; gap: 12px; max-width: 300px; margin: 0 auto;">
            <button type="button" class="submit-btn" id="copyLinkBtn" style="background-color: var(--brand-accent);">
              <span>Copy Form Link to Clipboard</span>
            </button>
            <a href="/" class="submit-btn" style="background-color: var(--brand-primary); text-decoration: none;">Visit Home</a>
          </div>
        </div>
      {% else %}
        {{ form.errors | default_errors }}

        <input type="hidden" name="contact[subject]" value="New Clothes Donation Request">

        <div class="form-grid-2">
          <div class="form-group">
            <label for="FullName">Full Name</label>
            <input type="text" id="FullName" name="contact[Full Name]" placeholder="Enter your full name" required>
          </div>

          <div class="form-group">
            <label for="ContactForm-email">Email Address</label>
            <input 
              type="email" 
              id="ContactForm-email" 
              name="contact[email]" 
              placeholder="Enter your email" 
              required
            >
          </div>
        </div>
        
        <div class="form-group">
          <label for="PhoneNumber">Phone Number</label>
          <input type="tel" id="PhoneNumber" name="contact[Phone Number]" placeholder="e.g. 98XXXXXXXX" required pattern="[0-9]{10}">
        </div>

        <div class="form-group">
          <label for="Location">Location Area</label>
          <select id="Location" name="contact[Location Area]" required>
            <option value="" disabled selected>Select your area</option>
            <option value="Kathmandu">Kathmandu</option>
            <option value="Lalitpur">Lalitpur</option>
            <option value="Bhaktapur">Bhaktapur</option>
          </select>
        </div>

        <div class="form-group">
          <label for="Address">Pickup Address</label>
          <textarea id="Address" name="contact[Pickup Address]" placeholder="Street name, house number, landmarks..." required></textarea>
        </div>

        <div class="form-grid-2">
          <div class="form-group">
            <label for="PickupDate">Preferred Pickup Date</label>
            <input type="date" id="PickupDate" name="contact[Preferred Pickup Date]" required>
          </div>

          <div class="form-group">
            <label for="TimeSlot">Preferred Time Slot</label>
            <select id="TimeSlot" name="contact[Preferred Time Slot]" required>
              <option value="Morning">Morning (8 AM - 12 PM)</option>
              <option value="Afternoon">Afternoon (12 PM - 4 PM)</option>
              <option value="Evening">Evening (4 PM - 8 PM)</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="ClothesCount">Approx. Number of Clothes</label>
          <select id="ClothesCount" name="contact[Approx. Number of Clothes]" required>
            <option value="5-10">5 – 10 clothes</option>
            <option value="10-20">10 – 20 clothes</option>
            <option value="20-50">20 – 50 clothes</option>
            <option value="50+">50+ clothes</option>
          </select>
        </div>

        <div class="form-group">
          <label for="Notes">Special Notes (Optional)</label>
          <textarea id="Notes" name="contact[Special Notes]" placeholder="Gate code, specific instructions, etc."></textarea>
        </div>

        <button type="submit" class="submit-btn" id="submitBtn">
          <span>Schedule Pickup</span>
          <div class="loader" id="btnLoader"></div>
        </button>
      {% endif %}
    {%- endform -%}
  </div>
  <footer class="info-section">
    <p>Your clothes will be professionally cleaned by <strong>KapadaWash</strong> and distributed by <strong>Nepal Youth Club</strong> to people in need.</p>
    <p style="margin-top: 12px; font-weight: 600; color: var(--brand-primary);">“Make a difference today”</p>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const copyLinkBtn = document.getElementById('copyLinkBtn');

    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', function() {
        const pageUrl = window.location.origin + window.location.pathname;
        navigator.clipboard.writeText(pageUrl).then(function() {
          const btnSpan = copyLinkBtn.querySelector('span');
          btnSpan.textContent = 'Copied!';
          setTimeout(() => {
            btnSpan.textContent = 'Copy Form Link to Clipboard';
          }, 2000);
        });
      });
    }

    const form = document.getElementById('donationForm');
    const submitBtn = document.getElementById('submitBtn');

    if (form && submitBtn) {
      form.addEventListener('submit', function() {
        const btnText = submitBtn.querySelector('span');
        const loader = document.getElementById('btnLoader');
        if (btnText) btnText.textContent = 'Scheduling...';
        if (loader) loader.style.display = 'block';
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.8';
      });
    }

    const dateInput = document.getElementById('PickupDate');
    if (dateInput) {
      const today = new Date().toISOString().split('T')[0];
      dateInput.setAttribute('min', today);
    }
  });
</script>
{% schema %}
{
  "name": "Donation Page",
  "settings": [],
  "presets": [
    {
      "name": "Donation Page"
    }
  ]
}
{% endschema %}
