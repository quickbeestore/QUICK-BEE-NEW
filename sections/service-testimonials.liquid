<!-- Service Testimonials & Reviews -->
<section class="qb-service-testimonials">
  <style>
    .qb-service-testimonials {
      background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
      padding: 60px 20px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .qb-testimonials-header {
      text-align: center;
      margin-bottom: 48px;
    }

    .qb-testimonials-title {
      font-size: 36px;
      font-weight: 900;
      color: #1a1a1a;
      margin-bottom: 12px;
    }

    .qb-testimonials-subtitle {
      font-size: 16px;
      color: #666;
      max-width: 600px;
      margin: 0 auto;
    }

    .qb-testimonials-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      margin-bottom: 40px;
    }

    .qb-testimonial-card {
      background: white;
      border: 2px solid #e8e8e8;
      border-radius: 16px;
      padding: 28px;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .qb-testimonial-card::before {
      content: '"';
      position: absolute;
      top: -20px;
      left: 16px;
      font-size: 80px;
      color: #F4B400;
      opacity: 0.2;
    }

    .qb-testimonial-card:hover {
      border-color: #F4B400;
      transform: translateY(-8px);
      box-shadow: 0 16px 40px rgba(244, 180, 0, 0.2);
    }

    .qb-testimonial-stars {
      margin-bottom: 16px;
      font-size: 18px;
      letter-spacing: 4px;
    }

    .qb-testimonial-text {
      font-size: 14px;
      color: #555;
      line-height: 1.8;
      margin-bottom: 20px;
      position: relative;
      z-index: 1;
      font-style: italic;
    }

    .qb-testimonial-author {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .qb-author-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, #F4B400 0%, #FFB300 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 800;
      font-size: 18px;
    }

    .qb-author-info {
      flex: 1;
    }

    .qb-author-name {
      font-size: 14px;
      font-weight: 800;
      color: #1a1a1a;
      margin: 0;
    }

    .qb-author-role {
      font-size: 12px;
      color: #666;
      margin: 2px 0 0;
    }

    .qb-testimonials-stats {
      background: white;
      border-radius: 16px;
      padding: 32px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 24px;
      text-align: center;
      border: 2px solid #e8e8e8;
    }

    .qb-stat-item {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .qb-stat-number {
      font-size: 36px;
      font-weight: 900;
      color: #F4B400;
    }

    .qb-stat-label {
      font-size: 14px;
      color: #666;
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .qb-service-testimonials {
        padding: 40px 16px;
      }

      .qb-testimonials-title {
        font-size: 28px;
      }

      .qb-testimonials-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .qb-testimonials-stats {
        grid-template-columns: 1fr;
        padding: 24px;
      }

      .qb-testimonial-card {
        padding: 20px;
      }
    }
  </style>

  <div class="qb-testimonials-header">
    <h2 class="qb-testimonials-title">What Our Customers Say</h2>
    <p class="qb-testimonials-subtitle">Real reviews from satisfied clients</p>
  </div>

  <div class="qb-testimonials-grid">
    {% for block in section.blocks %}
      {% if block.type == 'testimonial' %}
        <div class="qb-testimonial-card">
          <div class="qb-testimonial-stars">
            {% if block.settings.rating == 5 %}⭐⭐⭐⭐⭐{% elsif block.settings.rating == 4 %}⭐⭐⭐⭐☆{% elsif block.settings.rating == 3 %}⭐⭐⭐☆☆{% endif %}
          </div>
          <p class="qb-testimonial-text">"{{ block.settings.review }}"</p>
          <div class="qb-testimonial-author">
            <div class="qb-author-avatar">{{ block.settings.author | slice: 0 | upcase }}</div>
            <div class="qb-author-info">
              <p class="qb-author-name">{{ block.settings.author }}</p>
              <p class="qb-author-role">{{ block.settings.role }}</p>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="qb-testimonials-stats">
      <div class="qb-stat-item">
        <div class="qb-stat-number">{{ section.blocks | size }}k+</div>
        <div class="qb-stat-label">Happy Customers</div>
      </div>
      <div class="qb-stat-item">
        <div class="qb-stat-number">4.8</div>
        <div class="qb-stat-label">Average Rating</div>
      </div>
      <div class="qb-stat-item">
        <div class="qb-stat-number">98%</div>
        <div class="qb-stat-label">Satisfaction Rate</div>
      </div>
      <div class="qb-stat-item">
        <div class="qb-stat-number">24/7</div>
        <div class="qb-stat-label">Customer Support</div>
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Service Testimonials",
  "settings": [],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Customer Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review",
          "label": "Review Text",
          "default": "Great service and professional team. Highly recommended!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Customer Name",
          "default": "John Doe"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Customer Title",
          "default": "Homeowner"
        },
        {
          "type": "select",
          "id": "rating",
          "label": "Rating",
          "options": [
            { "label": "5 Stars", "value": 5 },
            { "label": "4 Stars", "value": 4 },
            { "label": "3 Stars", "value": 3 }
          ],
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Testimonials",
      "settings": {},
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "review": "Absolutely fantastic service! The team was professional, punctual, and did an excellent job. Couldn't ask for better.",
            "author": "Sarah Anderson",
            "role": "Homeowner",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "review": "Great experience from start to finish. They explained everything clearly and the work was completed on time.",
            "author": "Michael Chen",
            "role": "Business Owner",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "review": "Professional, reliable, and affordable. Definitely recommend to anyone looking for quality service.",
            "author": "Emma Rodriguez",
            "role": "Property Manager",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
