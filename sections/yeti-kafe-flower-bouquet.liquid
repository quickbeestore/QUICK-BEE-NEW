    font-size: 14px;
    color: #888;
    margin: 8px 0 0 0;
  }

  /* Tabs */
  .flower-tabs {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .flower-tab-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: white;
    border: 2px solid #ffb3d9;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 600;
    color: #c2185b;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .flower-tab-btn:hover {
    background: #ffe0ec;
    transform: translateY(-2px);
  }

  .flower-tab-btn.active {
    background: linear-gradient(135deg, #ec407a 0%, #c2185b 100%);
    color: white;
    border-color: #c2185b;
  }

  .tab-icon {
    font-size: 20px;
  }

