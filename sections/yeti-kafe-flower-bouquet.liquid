</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Tab Switching
    const tabBtns = document.querySelectorAll('.flower-tab-btn');
    const tabContents = document.querySelectorAll('.flower-tab-content');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabName = btn.dataset.tab;

        tabBtns.forEach(b => b.classList.remove('active'));
        tabContents.forEach(c => c.classList.remove('active'));

        btn.classList.add('active');
        document.getElementById(tabName + '-tab').classList.add('active');
      });
    });

    // Custom Builder Logic
    const qtyBtns = document.querySelectorAll('.qty-btn');
    const qtyInputs = document.querySelectorAll('.qty-input');
    const packagingOptions = document.querySelectorAll('input[name="packaging"]');

    const flowerPrices = {
      'rose': 99,
      'colored-rose': 120,
      'carnation': 80,
      'gerbera': 60,
      'sunflower': 450,
      'lily': 650
    };

    const packagingPrices = {
      'standard': 250,
      'premium': 350
    };

    function updateCustomTotal() {
      let total = 0;
      const summaryItems = document.getElementById('summary-items');
      summaryItems.innerHTML = '';

      Object.keys(flowerPrices).forEach(flower => {
        const input = document.querySelector(`input[data-flower="${flower}"]`);
        const qty = parseInt(input.value) || 0;
        if (qty > 0) {
          const price = flowerPrices[flower] * qty;
          total += price;

          const item = document.createElement('div');
          item.className = 'summary-item';
          item.innerHTML = `<span>${flower.replace('-', ' ').toUpperCase()} × ${qty}</span><span>Rs ${price}</span>`;
          summaryItems.appendChild(item);
        }
      });

      const selectedPackaging = document.querySelector('input[name="packaging"]:checked').value;
      const packagingPrice = packagingPrices[selectedPackaging];

      document.getElementById('flowers-total').textContent = `Rs ${total}`;
      document.getElementById('packaging-total').textContent = `Rs ${packagingPrice}`;
      document.getElementById('custom-total').textContent = `Rs ${total + packagingPrice}`;

      if (total === 0) {
        summaryItems.innerHTML = '<div class="summary-empty">👈 Select flowers to get started</div>';
      }
    }

    qtyBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const flower = btn.dataset.flower;
        const input = document.querySelector(`input[data-flower="${flower}"]`);
        let qty = parseInt(input.value) || 0;

        if (btn.dataset.action === 'increase') {
          qty++;
        } else if (btn.dataset.action === 'decrease' && qty > 0) {
          qty--;
        }

        input.value = qty;
        updateCustomTotal();
      });
    });

    qtyInputs.forEach(input => {
      input.addEventListener('change', () => {
        let qty = parseInt(input.value) || 0;
        if (qty < 0) qty = 0;
        input.value = qty;
        updateCustomTotal();
      });
    });

    packagingOptions.forEach(option => {
      option.addEventListener('change', updateCustomTotal);
    });

    // Add to Cart Handlers
    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const bouquet = btn.dataset.bouquet;
        const price = btn.dataset.price;
        alert(`Added ${bouquet} bouquet to cart! Total: Rs ${price}`);
        // Integrate with your cart here
      });
    });

    document.querySelector('.add-custom-btn').addEventListener('click', () => {
      const total = document.getElementById('custom-total').textContent;
      alert(`Added custom bouquet to cart! ${total}`);
      // Integrate with your cart here
    });
  });
</script>
