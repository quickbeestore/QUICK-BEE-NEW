  .flower-tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
  }

  .flower-tab-content.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

