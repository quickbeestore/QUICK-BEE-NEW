<!-- Service Features & Benefits Section -->
<section class="qb-service-features">
  <style>
    .qb-service-features {
      background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
      padding: 60px 20px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .qb-features-header {
      text-align: center;
      margin-bottom: 48px;
    }

    .qb-features-title {
      font-size: 36px;
      font-weight: 900;
      color: #1a1a1a;
      margin-bottom: 12px;
      letter-spacing: -0.5px;
    }

    .qb-features-subtitle {
      font-size: 16px;
      color: #666;
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .qb-features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      margin-bottom: 40px;
    }

    .qb-feature-card {
      background: white;
      border: 2px solid #e8e8e8;
      border-radius: 16px;
      padding: 28px;
      text-align: center;
      transition: all 0.3s ease;
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }

    .qb-feature-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(244, 180, 0, 0.08) 0%, transparent 100%);
      transition: left 0.3s ease;
    }

    .qb-feature-card:hover {
      border-color: #F4B400;
      transform: translateY(-8px);
      box-shadow: 0 16px 40px rgba(244, 180, 0, 0.2);
    }

    .qb-feature-card:hover::before {
      left: 100%;
    }

    .qb-feature-icon {
      font-size: 48px;
      margin-bottom: 16px;
      display: block;
      position: relative;
      z-index: 1;
    }

    .qb-feature-name {
      font-size: 18px;
      font-weight: 800;
      color: #1a1a1a;
      margin-bottom: 12px;
      position: relative;
      z-index: 1;
    }

    .qb-feature-description {
      font-size: 14px;
      color: #666;
      line-height: 1.6;
      position: relative;
      z-index: 1;
    }

    .qb-features-highlights {
      background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
      border-radius: 16px;
      padding: 40px;
      color: white;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 32px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .qb-features-highlights::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(244, 180, 0, 0.1), transparent);
      animation: rotate 15s linear infinite;
    }

    @keyframes rotate {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .qb-highlight-item {
      position: relative;
      z-index: 1;
    }

    .qb-highlight-icon {
      font-size: 40px;
      margin-bottom: 12px;
      display: block;
    }

    .qb-highlight-text {
      font-size: 16px;
      font-weight: 700;
      color: #FFD700;
    }

    .qb-highlight-subtext {
      font-size: 13px;
      color: #d0d0d0;
      margin-top: 6px;
    }

    @media (max-width: 768px) {
      .qb-service-features {
        padding: 40px 16px;
      }

      .qb-features-title {
        font-size: 28px;
      }

      .qb-features-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .qb-features-highlights {
        padding: 28px 20px;
        gap: 20px;
      }

      .qb-feature-card {
        padding: 20px;
      }
    }
  </style>

  <div class="qb-features-header">
    <h2 class="qb-features-title">Why Choose Our Service?</h2>
    <p class="qb-features-subtitle">Professional, reliable, and affordable solutions tailored to your needs</p>
  </div>

  <div class="qb-features-grid">
    {% for block in section.blocks %}
      {% if block.type == 'feature_card' %}
        <div class="qb-feature-card">
          <span class="qb-feature-icon">{{ block.settings.icon }}</span>
          <h3 class="qb-feature-name">{{ block.settings.title }}</h3>
          <p class="qb-feature-description">{{ block.settings.description }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="qb-features-highlights">
      <div class="qb-highlight-item">
        <span class="qb-highlight-icon">⚡</span>
        <div class="qb-highlight-text">Fast Service</div>
        <div class="qb-highlight-subtext">Quick turnaround times</div>
      </div>
      <div class="qb-highlight-item">
        <span class="qb-highlight-icon">✅</span>
        <div class="qb-highlight-text">Guaranteed Quality</div>
        <div class="qb-highlight-subtext">100% satisfaction assured</div>
      </div>
      <div class="qb-highlight-item">
        <span class="qb-highlight-icon">💰</span>
        <div class="qb-highlight-text">Affordable Pricing</div>
        <div class="qb-highlight-subtext">Best rates in the market</div>
      </div>
      <div class="qb-highlight-item">
        <span class="qb-highlight-icon">🛡️</span>
        <div class="qb-highlight-text">Insured & Certified</div>
        <div class="qb-highlight-subtext">Professional team</div>
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Service Features",
  "settings": [],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji)",
          "default": "✨"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "Feature Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature Description",
          "default": "Describe what makes this feature special and beneficial to customers."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Features",
      "settings": {},
      "blocks": [
        {
          "type": "feature_card",
          "settings": {
            "icon": "🔧",
            "title": "Expert Professionals",
            "description": "Highly trained and certified specialists with years of experience"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon": "⏰",
            "title": "Flexible Scheduling",
            "description": "Book appointments at times that work best for you"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon": "💵",
            "title": "Transparent Pricing",
            "description": "No hidden fees, upfront quotes before work begins"
          }
        }
      ]
    }
  ]
}
{% endschema %}
