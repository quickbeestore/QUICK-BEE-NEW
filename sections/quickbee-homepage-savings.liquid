<!-- QuickBee Savings Calculator Section -->
<style>
.qb-savings-section {
  background: #0A0A0A !important;
  padding: 40px 16px;
  border-top: 1px solid rgba(255,255,255,0.05);
}

@media(min-width: 1024px) {
  .qb-savings-section {
    padding: 60px 48px;
  }
}

.qb-savings-container {
  max-width: 1000px;
  margin: 0 auto;
}

.qb-savings-header {
  text-align: center;
  margin-bottom: 40px;
}

.qb-savings-header h2 {
  font-size: 28px;
  font-weight: 900;
  color: #F0F0F0;
  margin: 0 0 12px 0;
}

@media(min-width: 1024px) {
  .qb-savings-header h2 {
    font-size: 36px;
  }
}

.qb-savings-header p {
  font-size: 16px;
  color: #999;
  margin: 0;
}

.qb-savings-content {
  background: #111;
  border-radius: 24px;
  padding: 32px 20px;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  position: relative;
  overflow: hidden;
}

.qb-savings-content::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0; height: 4px;
  background: linear-gradient(90deg, #F4B400, #FFD700);
}

@media(min-width: 1024px) {
  .qb-savings-content {
    padding: 48px;
  }
}

.qb-savings-inputs {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
  margin-bottom: 40px;
}

@media(min-width: 768px) {
  .qb-savings-inputs {
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
}

.qb-input-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.qb-input-group label {
  font-size: 13px;
  font-weight: 700;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.qb-input-group input {
  padding: 14px 18px;
  background: #181818;
  border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  font-size: 16px;
  color: #fff;
  transition: all 0.3s ease;
  font-family: inherit;
}

.qb-input-group input:focus {
  outline: none;
  border-color: #F4B400;
  background: #1c1c1c;
  box-shadow: 0 0 0 4px rgba(244, 180, 0, 0.1);
}

.qb-savings-divider {
  height: 1px;
  background: rgba(255,255,255,0.08);
  margin: 40px 0;
}

.qb-savings-results {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

@media(min-width: 768px) {
  .qb-savings-results {
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
}

.qb-savings-box {
  background: #181818;
  border-radius: 16px;
  padding: 24px;
  text-align: center;
  border: 1px solid rgba(255,255,255,0.05);
  transition: all 0.3s ease;
}

.qb-savings-box:hover {
  transform: translateY(-5px);
  border-color: rgba(244,180,0,0.3);
  box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}

.qb-savings-label {
  font-size: 12px;
  font-weight: 600;
  color: #666;
  margin-bottom: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.qb-savings-value {
  font-size: 32px;
  font-weight: 900;
  color: #F4B400;
  margin: 0;
  line-height: 1;
  text-shadow: 0 0 15px rgba(244,180,0,0.2);
}

@media(min-width: 1024px) {
  .qb-savings-value {
    font-size: 38px;
  }
}

.qb-savings-cta {
  display: flex;
  justify-content: center;
  margin-top: 40px;
}

.qb-savings-btn {
  background: #F4B400;
  border: none;
  padding: 16px 36px;
  border-radius: 30px;
  font-size: 16px;
  font-weight: 800;
  color: #111111;
  cursor: pointer;
  transition: all 0.3s ease;
}

.qb-savings-btn:hover {
  background: #FFD700;
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(244, 180, 0, 0.4);
}
</style>

<section class="qb-savings-section">
  <div class="qb-savings-container">
    <div class="qb-savings-header">
      <h2>💰 See How Much You Save</h2>
      <p>Calculate your savings with QuickBee's everyday low prices</p>
    </div>

    <div class="qb-savings-content">
      <div class="qb-savings-inputs">
        <div class="qb-input-group">
          <label for="items-count">Items per week</label>
          <input
            type="number"
            id="items-count"
            min="1"
            max="100"
            value="15"
            placeholder="Enter items per week"
          />
        </div>

        <div class="qb-input-group">
          <label for="item-price">Avg item price ($)</label>
          <input
            type="number"
            id="item-price"
            min="1"
            max="1000"
            step="0.01"
            value="25"
            placeholder="Enter average price"
          />
        </div>

        <div class="qb-input-group">
          <label for="discount-percent">Discount %</label>
          <input
            type="number"
            id="discount-percent"
            min="0"
            max="100"
            value="20"
            placeholder="Enter discount percentage"
          />
        </div>
      </div>

      <div class="qb-savings-divider"></div>

      <div class="qb-savings-results">
        <div class="qb-savings-box">
          <div class="qb-savings-label">Weekly Savings</div>
          <div class="qb-savings-value" id="weekly-savings">$75</div>
        </div>

        <div class="qb-savings-box">
          <div class="qb-savings-label">Monthly Savings</div>
          <div class="qb-savings-value" id="monthly-savings">$325</div>
        </div>

        <div class="qb-savings-box">
          <div class="qb-savings-label">Yearly Savings</div>
          <div class="qb-savings-value" id="yearly-savings">$1,560</div>
        </div>
      </div>

      <div class="qb-savings-cta">
        <button class="qb-savings-btn">Start Saving Now →</button>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Get input elements
  const itemsCountInput = document.getElementById('items-count');
  const itemPriceInput = document.getElementById('item-price');
  const discountPercentInput = document.getElementById('discount-percent');

  // Get result elements
  const weeklySavingsDisplay = document.getElementById('weekly-savings');
  const monthlySavingsDisplay = document.getElementById('monthly-savings');
  const yearlySavingsDisplay = document.getElementById('yearly-savings');

  // Function to calculate and update savings
  function calculateSavings() {
    const items = parseFloat(itemsCountInput.value) || 0;
    const price = parseFloat(itemPriceInput.value) || 0;
    const discount = parseFloat(discountPercentInput.value) || 0;

    // Calculate weekly savings: (items × price × discount) / 100
    const weeklySavings = (items * price * discount) / 100;

    // Calculate monthly: weekly × 4.33
    const monthlySavings = weeklySavings * 4.33;

    // Calculate yearly: weekly × 52
    const yearlySavings = weeklySavings * 52;

    // Update display with formatting
    weeklySavingsDisplay.textContent = '$' + weeklySavings.toFixed(0);
    monthlySavingsDisplay.textContent = '$' + monthlySavings.toFixed(0);
    yearlySavingsDisplay.textContent = '$' + yearlySavings.toFixed(0);
  }

  // Add event listeners for real-time calculation
  itemsCountInput.addEventListener('input', calculateSavings);
  itemPriceInput.addEventListener('input', calculateSavings);
  discountPercentInput.addEventListener('input', calculateSavings);

  // Initial calculation
  calculateSavings();
});
</script>
