{%- doc -%}
  Best Sellers - Showcase top-selling products with badges, pricing, and quick add-to-cart.
{%- enddoc -%}

<div
  class="best-sellers-section"
  data-section-id="{{ section.id }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}">
    <div class="best-sellers-header">
      <h2 class="best-sellers-title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="best-sellers-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="best-sellers-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          <div class="product-card">
            <!-- Product Image -->
            <div class="product-image-wrapper">
              {%- if block.settings.image -%}
                <img
                  src="{{ block.settings.image | image_url: width: 300 }}"
                  alt="{{ block.settings.product_name }}"
                  class="product-image"
                  loading="lazy"
                />
              {%- else -%}
                <div class="image-placeholder"></div>
              {%- endif -%}

              <!-- Badges -->
              <div class="product-badges">
                {%- if block.settings.show_best_seller -%}
                  <span class="badge badge-bestseller">🔥 Best Seller</span>
                {%- endif -%}
                {%- if block.settings.discount_percentage != blank -%}
                  <span class="badge badge-discount">-{{ block.settings.discount_percentage }}%</span>
                {%- endif -%}
                {%- if block.settings.show_new -%}
                  <span class="badge badge-new">NEW</span>
                {%- endif -%}
              </div>

              <!-- Quick View Button -->
              <button class="quick-view-btn" data-product="{{ block.settings.product_name }}">
                Quick View
              </button>
            </div>

            <!-- Product Info -->
            <div class="product-info">
              <h3 class="product-name">{{ block.settings.product_name }}</h3>

              <!-- Rating -->
              {%- if block.settings.show_rating -%}
                <div class="product-rating">
                  <div class="stars">
                    {%- for i in (1..5) -%}
                      <span class="star {% if i <= block.settings.rating %}filled{% endif %}">★</span>
                    {%- endfor -%}
                  </div>
                  <span class="rating-value">({{ block.settings.review_count | default: '120' }} reviews)</span>
                </div>
              {%- endif -%}

              <!-- Price -->
              <div class="product-pricing">
                <span class="current-price">Rs {{ block.settings.current_price }}</span>
                {%- if block.settings.original_price != blank -%}
                  <span class="original-price">Rs {{ block.settings.original_price }}</span>
                {%- endif -%}
              </div>

              <!-- Category -->
              {%- if block.settings.category != blank -%}
                <span class="product-category">{{ block.settings.category }}</span>
              {%- endif -%}

              <!-- Description -->
              {%- if block.settings.description != blank -%}
                <p class="product-description">{{ block.settings.description }}</p>
              {%- endif -%}

              <!-- Stock Status -->
              <div class="stock-status">
                {%- if block.settings.in_stock -%}
                  <span class="in-stock">✓ In Stock</span>
                {%- else -%}
                  <span class="out-of-stock">✗ Out of Stock</span>
                {%- endif -%}
              </div>

              <!-- CTA -->
              <button class="add-to-cart-btn" {% unless block.settings.in_stock %}disabled{% endunless %}>
                Add to Cart
              </button>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- View All Products -->
    {%- if section.settings.show_cta -%}
      <div class="view-all-cta">
        <a href="{{ section.settings.cta_url }}" class="cta-link">
          View All Products →
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .best-sellers-section {
    background: var(--color-background);
  }

  .best-sellers-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .best-sellers-title {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 800;
    color: #222;
    margin: 0 0 12px 0;
  }

  .best-sellers-subtitle {
    font-size: 16px;
    color: #666;
    margin: 0;
  }

  .best-sellers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .product-card {
    background: white;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    border-color: #2563eb;
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.15);
    transform: translateY(-4px);
  }

  .product-image-wrapper {
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
    aspect-ratio: 1;
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-image {
    transform: scale(1.08);
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f0f0f0 0%, #e5e5e5 100%);
  }

  .product-badges {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    text-align: center;
  }

  .badge-bestseller {
    background: #ff6b35;
    color: white;
  }

  .badge-discount {
    background: #10b981;
    color: white;
  }

  .badge-new {
    background: #2563eb;
    color: white;
  }

  .quick-view-btn {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%) translateY(50px);
    padding: 8px 16px;
    background: white;
    border: 1.5px solid #2563eb;
    color: #2563eb;
    border-radius: 4px;
    font-weight: 600;
    font-size: 12px;
    cursor: pointer;
    opacity: 0;
    transition: all 0.3s ease;
  }

  .product-card:hover .quick-view-btn {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  .product-info {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-name {
    font-size: 14px;
    font-weight: 600;
    color: #222;
    margin: 0 0 8px 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
  }

  .stars {
    display: flex;
    gap: 2px;
  }

  .star {
    font-size: 12px;
    color: #ddd;
  }

  .star.filled {
    color: #fbbf24;
  }

  .rating-value {
    font-size: 11px;
    color: #999;
  }

  .product-pricing {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 4px;
  }

  .current-price {
    font-size: 16px;
    font-weight: 700;
    color: #2563eb;
  }

  .original-price {
    font-size: 13px;
    color: #999;
    text-decoration: line-through;
  }

  .product-category {
    display: inline-block;
    font-size: 11px;
    color: #666;
    background: #f5f5f5;
    padding: 3px 8px;
    border-radius: 3px;
    margin-bottom: 8px;
    width: fit-content;
  }

  .product-description {
    font-size: 12px;
    color: #666;
    margin: 0 0 8px 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .stock-status {
    margin-bottom: 12px;
  }

  .in-stock {
    color: #10b981;
    font-size: 12px;
    font-weight: 600;
  }

  .out-of-stock {
    color: #ef4444;
    font-size: 12px;
    font-weight: 600;
  }

  .add-to-cart-btn {
    width: 100%;
    padding: 10px;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 4px;
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .add-to-cart-btn:hover:not(:disabled) {
    background: #1d4ed8;
  }

  .add-to-cart-btn:disabled {
    background: #ddd;
    cursor: not-allowed;
  }

  .view-all-cta {
    text-align: center;
  }

  .cta-link {
    display: inline-block;
    padding: 12px 32px;
    color: #2563eb;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    border: 2px solid #2563eb;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .cta-link:hover {
    background: #2563eb;
    color: white;
  }

  @media screen and (max-width: 749px) {
    .best-sellers-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .product-info {
      padding: 12px;
    }

    .product-name {
      font-size: 13px;
    }

    .current-price {
      font-size: 14px;
    }
  }

  @media (prefers-color-scheme: dark) {
    .product-card {
      background: #222;
      border-color: #444;
    }

    .product-card:hover {
      border-color: #5b9ff5;
    }

    .product-name {
      color: #fff;
    }

    .product-description,
    .rating-value {
      color: #aaa;
    }

    .image-placeholder {
      background: linear-gradient(135deg, #333 0%, #222 100%);
    }

    .product-category {
      background: #1a1a1a;
      color: #aaa;
    }

    .quick-view-btn {
      background: #222;
      border-color: #5b9ff5;
      color: #5b9ff5;
    }
  }
</style>

<script>
  (function() {
    const addToCartBtns = document.querySelectorAll('.add-to-cart-btn');
    const quickViewBtns = document.querySelectorAll('.quick-view-btn');

    addToCartBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        btn.textContent = '✓ Added!';
        setTimeout(() => {
          btn.textContent = 'Add to Cart';
        }, 2000);
      });
    });

    quickViewBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const productName = btn.dataset.product;
        alert(`Quick view for: ${productName}\n\nFull product page would open here.`);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Best Sellers This Month"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Top products loved by our customers"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show 'View All' CTA",
      "default": true
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page Width" },
        { "value": "full-width", "label": "Full Width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "text",
          "id": "product_name",
          "label": "Product Name",
          "default": "Premium Headphones"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Electronics"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "High-quality sound with noise cancellation"
        },
        {
          "type": "text",
          "id": "current_price",
          "label": "Current Price",
          "default": "4,999"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original Price",
          "default": "7,999"
        },
        {
          "type": "text",
          "id": "discount_percentage",
          "label": "Discount %",
          "default": "37"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 0.5,
          "default": 4.5
        },
        {
          "type": "text",
          "id": "review_count",
          "label": "Review Count",
          "default": "120"
        },
        {
          "type": "checkbox",
          "id": "show_rating",
          "label": "Show Rating",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_best_seller",
          "label": "Show Best Seller Badge",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_new",
          "label": "Show New Badge",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "in_stock",
          "label": "In Stock",
          "default": true
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  /* ── Dark / Light Theme Overrides ── */
  [data-theme="dark"] .best-sellers-section {
    background: #0a0a0f !important;
    color: #f0f0f8 !important;
  }
  [data-theme="dark"] .bs-card,
  [data-theme="dark"] .bs-item,
  [data-theme="dark"] .bs-box {
    background: #1a1a26 !important;
    border-color: rgba(255,255,255,0.10) !important;
    color: #f0f0f8 !important;
  }
  [data-theme="dark"] .bs-title,
  [data-theme="dark"] .bs-name {
    color: #f0f0f8 !important;
  }
  [data-theme="dark"] .bs-desc,
  [data-theme="dark"] .bs-sub {
    color: #aaa !important;
  }
  [data-theme="dark"] .bs-price {
    color: #F4B400 !important;
  }
  html:not([data-theme="dark"]) .best-sellers-section {
    background: #fff !important;
    color: #1a1a1a !important;
  }
</style>
