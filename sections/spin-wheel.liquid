var N = SEG.length; /* 13 */
var LS_KEY     = 'qbsw_last';
var LS_HISTORY = 'qbsw_history';
var LS_STATS   = 'qbsw_stats';

/* ═══════════════════════════════════════════
   DOM
═══════════════════════════════════════════ */
var canvas   = document.getElementById('swCanvas');
var ctx      = canvas.getContext('2d');
var btn      = document.getElementById('swBtn');
var zone     = document.getElementById('swZone');
var overlay  = document.getElementById('swOverlay');
var confetti = document.getElementById('swConfetti');
var cctx     = confetti.getContext('2d');
var hint1    = document.getElementById('swHintRing1');
var hint2    = document.getElementById('swHintRing2');

/* ═══════════════════════════════════════════
   SIZING — fills screen perfectly on mobile
═══════════════════════════════════════════ */
var SIZE=0,R=0,CX=0,CY=0,CENTER_R=0;

function resize(){
  var vw=window.innerWidth,vh=window.innerHeight;
  var headerH=document.querySelector('.sw-header').offsetHeight||60;
  var titleH =document.querySelector('.sw-title-block').offsetHeight||80;
  var prevH  =document.getElementById('swPrevWins').offsetHeight||30;
  var avail  =Math.min(vw-24, vh-headerH-titleH-prevH-40);
  SIZE=Math.max(220,Math.min(avail,520));
  R=SIZE/2; CX=R; CY=R;
  CENTER_R=R*0.175;

  canvas.width=canvas.height=SIZE;
  canvas.style.width=canvas.style.height=SIZE+'px';

  var or=document.getElementById('swRingOuter');
  var outer=SIZE+40;
  or.style.cssText='width:'+outer+'px;height:'+outer+'px;'+
    'left:'+(-20)+'px;top:'+(-20)+'px;';

  /* Position hint rings */
  var hr=CENTER_R+12;
  [hint1,hint2].forEach(function(h){
    h.style.width=h.style.height=(hr*2)+'px';
    h.style.marginLeft=h.style.marginTop=(-hr)+'px';
  });

  /* Size center button */
  var cb=document.getElementById('swBtn');
  var cs=CENTER_R*2;
  cb.style.width=cb.style.height=cs+'px';
  cb.style.boxShadow='0 0 0 '+(R*0.022)+'px #080600,'+
    '0 0 0 '+(R*0.042)+'px rgba(244,180,0,0.35),'+
    '0 6px 20px rgba(0,0,0,.7)';
  document.getElementById('swBtnIcon').style.fontSize=(cs*0.35)+'px';
  document.getElementById('swBtnLabel').style.fontSize=(cs*0.17)+'px';

  /* Pointer position */
  var ptr=document.getElementById('swPointer');
  ptr.style.top=(-SIZE/2-14)+'px';

  drawWheel(currentAngle);
}

/* ═══════════════════════════════════════════
   DRAW WHEEL
═══════════════════════════════════════════ */
var currentAngle=0;

function drawWheel(angle){
  ctx.clearRect(0,0,SIZE,SIZE);
  var slice=(Math.PI*2)/N;

  /* Draw segments */
  SEG.forEach(function(s,i){
    var a0=angle+slice*i-Math.PI/2;
    var a1=a0+slice;
    var mid=a0+slice/2;

    /* Segment fill */
    var grd=ctx.createRadialGradient(CX,CY,R*0.08,CX,CY,R*0.97);
    grd.addColorStop(0,s.c2);
    grd.addColorStop(1,s.c1);
    ctx.beginPath();
    ctx.moveTo(CX,CY);
    ctx.arc(CX,CY,R-7,a0,a1);
    ctx.closePath();
    ctx.fillStyle=grd;
    ctx.fill();

    /* Subtle lighter edge at arc */
    ctx.beginPath();
    ctx.moveTo(CX,CY);
    ctx.arc(CX,CY,R-7,a0,a1);
    ctx.closePath();
    ctx.strokeStyle='rgba(255,255,255,0.06)';
    ctx.lineWidth=1;
    ctx.stroke();

    /* Gold separator lines */
    ctx.save();
    ctx.translate(CX,CY);
    ctx.rotate(a0);
    ctx.beginPath();
    ctx.moveTo(CENTER_R+4,0);
    ctx.lineTo(R-8,0);
    ctx.strokeStyle='rgba(244,180,0,0.35)';
    ctx.lineWidth=1.2;
    ctx.stroke();
    ctx.restore();

    /* Text */
    ctx.save();
    ctx.translate(CX,CY);
    ctx.rotate(mid);

    /* Emoji */
    var emojiSize=Math.max(12,Math.min(R*0.115,20));
    ctx.font=emojiSize+'px serif';
    ctx.textAlign='center';
    ctx.textBaseline='middle';
    ctx.fillText(s.emoji, R*0.68, 0);

    /* Label */
    var fontSize=Math.max(8,Math.min(R*0.072,13));
    ctx.font='700 '+fontSize+'px -apple-system,sans-serif';
    ctx.fillStyle='#fff';
    ctx.shadowColor='rgba(0,0,0,0.9)';
    ctx.shadowBlur=3;
    var lines=s.label.split('\n');
    var lh=fontSize+2.5;
    var tx=R*0.33;
    lines.forEach(function(ln,li){
      ctx.fillText(ln,tx,(li-(lines.length-1)/2)*lh);
    });
    ctx.restore();
  });

  /* Outer ring — thick gold */
  ctx.beginPath();
  ctx.arc(CX,CY,R-4,0,Math.PI*2);
  ctx.strokeStyle='#F4B400';
  ctx.lineWidth=7;
  ctx.shadowColor='rgba(244,180,0,0.7)';
  ctx.shadowBlur=14;
  ctx.stroke();
  ctx.shadowBlur=0;

  /* Outer ring inner accent */
  ctx.beginPath();
  ctx.arc(CX,CY,R-8,0,Math.PI*2);
  ctx.strokeStyle='rgba(255,255,255,0.12)';
  ctx.lineWidth=1;
  ctx.stroke();

  /* Tick dots on ring */
  SEG.forEach(function(_,i){
    var a=angle+((Math.PI*2)/N)*i-Math.PI/2;
    var tx=CX+(R-2)*Math.cos(a);
    var ty=CY+(R-2)*Math.sin(a);
    ctx.beginPath();
    ctx.arc(tx,ty,3,0,Math.PI*2);
    ctx.fillStyle='rgba(0,0,0,0.5)';
    ctx.fill();
  });

  /* Center hub */
  var hubGrd=ctx.createRadialGradient(CX-CENTER_R*0.2,CY-CENTER_R*0.2,0,CX,CY,CENTER_R);
  hubGrd.addColorStop(0,'#1a1200');
  hubGrd.addColorStop(1,'#0a0800');
  ctx.beginPath();
  ctx.arc(CX,CY,CENTER_R+6,0,Math.PI*2);
  ctx.fillStyle='#080600';
  ctx.fill();
  ctx.beginPath();
  ctx.arc(CX,CY,CENTER_R+4,0,Math.PI*2);
  ctx.strokeStyle='rgba(244,180,0,0.6)';
  ctx.lineWidth=2.5;
  ctx.shadowColor='rgba(244,180,0,0.4)';
  ctx.shadowBlur=8;
  ctx.stroke();
  ctx.shadowBlur=0;
}

/* ═══════════════════════════════════════════
   IDLE ROTATION
═══════════════════════════════════════════ */
var idleRAF=null;
var idleSpeed=0.0005;
function idleRotate(){
  currentAngle+=idleSpeed;
  drawWheel(currentAngle);
  idleRAF=requestAnimationFrame(idleRotate);
}

/* ═══════════════════════════════════════════
   SPIN ENGINE
═══════════════════════════════════════════ */
var isSpinning=false;
var spinStart=null,spinFrom=0,spinTarget=0,winIdx=0;
var DURATION=6000;
var lastTickSeg=-1;
var audioCtx=null;

function getAC(){
  if(!audioCtx) try{audioCtx=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}
  return audioCtx;
}
function tick(freq){
  var ac=getAC(); if(!ac) return;
  try{
    var o=ac.createOscillator(),g=ac.createGain();
    o.connect(g);g.connect(ac.destination);
    o.frequency.value=freq||700;o.type='sine';
    g.gain.setValueAtTime(0.1,ac.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+0.05);
    o.start();o.stop(ac.currentTime+0.06);
  }catch(e){}
}

function easeOut(t){return 1-Math.pow(1-t,4);}

function animSpin(ts){
  if(!spinStart) spinStart=ts;
  var p=Math.min((ts-spinStart)/DURATION,1);
  var e=easeOut(p);
  currentAngle=spinFrom+(spinTarget-spinFrom)*e;
  drawWheel(currentAngle);

  /* Tick */
  var slice=(Math.PI*2)/N;
  var norm=((currentAngle%(Math.PI*2))+(Math.PI*2))%(Math.PI*2);
  var seg=Math.floor(norm/slice)%N;
  if(seg!==lastTickSeg){
    var spd=1-p;
    if(spd>0.05) tick(600+spd*500);
    try{if(navigator.vibrate&&spd>0.3) navigator.vibrate(10);}catch(e){}
    lastTickSeg=seg;
  }

  if(p<1){ requestAnimationFrame(animSpin); }
  else { onSpinEnd(); }
}

function spin(){
  if(isSpinning) return;

  /* Daily limit check */
  var last=''; try{last=localStorage.getItem(LS_KEY)||'';}catch(e){}
  if(last===new Date().toDateString()){ showAlreadySpun(); return; }

  if(idleRAF){ cancelAnimationFrame(idleRAF); idleRAF=null; }
  isSpinning=true;
  btn.disabled=true;
  document.getElementById('swBtnIcon').textContent='⏳';
  document.getElementById('swBtnLabel').textContent='...';
  zone.classList.add('spinning');
  /* Hide hint rings */
  hint1.style.display='none'; hint2.style.display='none';

  spinStart=null;
  spinFrom=currentAngle;

  winIdx=weightedRandom();
  var slice=(Math.PI*2)/N;
  /* Target: winning segment midpoint lands at top pointer (angle=-PI/2) */
  var segMid=slice*winIdx+slice/2;
  var target=((( -Math.PI/2-segMid)%(Math.PI*2))+(Math.PI*2))%(Math.PI*2);
  var spins=7+Math.floor(Math.random()*4);
  spinTarget=spinFrom-(spinFrom%(Math.PI*2))+Math.PI*2*spins+target;
  if(spinTarget-spinFrom<Math.PI*2*5) spinTarget+=Math.PI*2*5;

  requestAnimationFrame(animSpin);
}

function weightedRandom(){
  var tot=SEG.reduce(function(a,s){return a+s.wt;},0);
  var r=Math.random()*tot,acc=0;
  for(var i=0;i<SEG.length;i++){acc+=SEG[i].wt;if(r<=acc)return i;}
  return SEG.length-1;
}

function onSpinEnd(){
  isSpinning=false;
  zone.classList.remove('spinning');
  var s=SEG[winIdx];
  /* Save */
  try{localStorage.setItem(LS_KEY,new Date().toDateString());}catch(e){}
  saveHistory(s);
  updateStats(s);
  updateChip();
  updatePrevWins();

  /* Vibrate win pattern */
  try{if(navigator.vibrate) navigator.vibrate(s.type==='win'?[50,30,80,30,120]:[100]);}catch(e){}

  if(s.type==='win'){
    launchConfetti();
    showSheet(s,false);
  } else {
    showSheet(s,true);
  }
}

