  var claimLabel=win?(todayWins.length>1?'🎁 Claim All '+todayWins.length+' Prizes on WhatsApp':'🎁 Claim Prize on WhatsApp'):'💬 Order on WhatsApp';
  document.getElementById('lwClaimTxt').textContent=claimLabel;
