  var b=this;
  var done=function(){b.textContent='✓ Copied!';b.classList.add('done');
    setTimeout(function(){b.textContent='Copy';b.classList.remove('done');},2200);};
  if(navigator.clipboard) navigator.clipboard.writeText(code).then(done).catch(function(){fbCopy(code);done();});
  else{fbCopy(code);done();}
  try{if(navigator.vibrate)navigator.vibrate(30);}catch(e){}
});
function fbCopy(t){
  var ta=document.createElement('textarea');ta.value=t;
  ta.style.cssText='position:fixed;opacity:0;top:0;left:0;';
  document.body.appendChild(ta);ta.select();
  try{document.execCommand('copy');}catch(e){}
  document.body.removeChild(ta);
}

/* ═══════════════════════════════════════════
   CONFETTI
═══════════════════════════════════════════ */
var CP=[],cRAF=null;
var CC=['#F4B400','#FFD700','#ff6b6b','#4ade80','#60a5fa','#f472b6','#fb923c','#fff','#a78bfa'];
function launchConfetti(){
  confetti.width=window.innerWidth;confetti.height=window.innerHeight;
  CP=[];
  for(var i=0;i<140;i++){
    CP.push({
      x:Math.random()*confetti.width,y:-20-Math.random()*60,
      w:5+Math.random()*9,h:9+Math.random()*12,
      c:CC[Math.floor(Math.random()*CC.length)],
      vx:-4+Math.random()*8,vy:1.5+Math.random()*5,
      rot:Math.random()*360,rv:-6+Math.random()*12,
      life:1,shape:Math.random()>.5?'rect':'circle'
    });
  }
  if(cRAF)cancelAnimationFrame(cRAF);
  animConfetti();
}
function animConfetti(){
  cctx.clearRect(0,0,confetti.width,confetti.height);
  var alive=false;
  CP.forEach(function(p){
    if(p.y>confetti.height+20||p.life<=0)return;
    alive=true;
    p.x+=p.vx;p.y+=p.vy;p.vy+=0.1;p.rot+=p.rv;p.life-=0.005;
    cctx.save();
    cctx.translate(p.x,p.y);
    cctx.rotate(p.rot*Math.PI/180);
    cctx.globalAlpha=Math.min(1,p.life*4);
    cctx.fillStyle=p.c;
    if(p.shape==='circle'){cctx.beginPath();cctx.arc(0,0,p.w/2,0,Math.PI*2);cctx.fill();}
    else cctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
    cctx.restore();
  });
  if(alive)cRAF=requestAnimationFrame(animConfetti);
  else stopConfetti();
}
function stopConfetti(){if(cRAF){cancelAnimationFrame(cRAF);cRAF=null;}cctx.clearRect(0,0,confetti.width,confetti.height);}

/* ═══════════════════════════════════════════
   HISTORY & STATS
═══════════════════════════════════════════ */
function getHistory(){ try{return JSON.parse(localStorage.getItem(LS_HISTORY)||'[]');}catch(e){return[];} }
function saveHistory(s){
  if(s.type!=='win')return;
  var h=getHistory();
  h.unshift({emoji:s.emoji,prize:s.prize,code:s.code,date:new Date().toLocaleDateString()});
  if(h.length>20)h=h.slice(0,20);
  try{localStorage.setItem(LS_HISTORY,JSON.stringify(h));}catch(e){}
}
function getStats(){ try{return JSON.parse(localStorage.getItem(LS_STATS)||'{"spins":0,"wins":0,"saved":0}');}catch(e){return{spins:0,wins:0,saved:0};} }
function updateStats(s){
  var st=getStats();
  st.spins++;
  if(s.type==='win'){st.wins++;st.saved+=(s.saved||0);}
  try{localStorage.setItem(LS_STATS,JSON.stringify(st));}catch(e){}
}
function updateChip(){
  var last='';try{last=localStorage.getItem(LS_KEY)||'';}catch(e){}
  var chip=document.getElementById('swChip'),txt=document.getElementById('swChipText');
  if(last===new Date().toDateString()){
    chip.className='sw-chip used';
    txt.textContent='✓ Spin used — Resets at midnight';
    btn.disabled=true;
    document.getElementById('swBtnIcon').textContent='🔒';
    document.getElementById('swBtnLabel').textContent='DONE';
    hint1.style.display='none';hint2.style.display='none';
  } else {
    chip.className='sw-chip available';
    txt.textContent='1 Free Spin Available!';
  }
}
function updatePrevWins(){
  var h=getHistory();
  var pw=document.getElementById('swPrevWins');
  /* Clear old pills */
  var pills=pw.querySelectorAll('.sw-prev-pill');
  pills.forEach(function(p){p.remove();});
  if(!h.length) return;
  h.slice(0,4).forEach(function(item){
    var pill=document.createElement('span');
    pill.className='sw-prev-pill';
    pill.textContent=item.emoji+' '+item.prize;
    pw.appendChild(pill);
  });
}

/* ═══════════════════════════════════════════
   STARS
═══════════════════════════════════════════ */
(function(){
  var root=document.getElementById('swRoot');
  for(var i=0;i<70;i++){
    var s=document.createElement('div');s.className='sw-star';
    var sz=(Math.random()*2.5+0.4).toFixed(1);
    s.style.cssText='width:'+sz+'px;height:'+sz+'px;top:'+Math.random()*100+'%;'+
      'left:'+Math.random()*100+'%;--d:'+(2+Math.random()*5).toFixed(1)+'s;'+
      '--dl:'+(Math.random()*5).toFixed(1)+'s;opacity:'+(Math.random()*.5).toFixed(2)+';';
    root.appendChild(s);
  }
})();

/* ═══════════════════════════════════════════
   HEX HELPER
═══════════════════════════════════════════ */
function hexToRgb(hex){
  var r=/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
  return r?parseInt(r[1],16)+','+parseInt(r[2],16)+','+parseInt(r[3],16):'244,180,0';
}

/* ═══════════════════════════════════════════
   EVENTS
═══════════════════════════════════════════ */
btn.addEventListener('click',spin,{passive:true});
canvas.addEventListener('click',spin,{passive:true});
/* Touch swipe on canvas */
var swipeStartY=0;
canvas.addEventListener('touchstart',function(e){swipeStartY=e.touches[0].clientY;},{passive:true});
canvas.addEventListener('touchend',function(e){
  var dy=swipeStartY-e.changedTouches[0].clientY;
  if(Math.abs(dy)>30) spin();
},{passive:true});

document.getElementById('swCloseBtn').addEventListener('click',closeSheet);
overlay.addEventListener('click',function(e){if(e.target===overlay)closeSheet();});

/* ── Claim & Checkout flow ── */
var currentWinSeg=null; /* set when sheet opens */

document.getElementById('swCtaBtn').addEventListener('click',function(){
  if(!currentWinSeg) return;
  var s=currentWinSeg;

  /* If "Try Again" / no code — just go to collections */
  if(s.type==='lose'||!s.code){
    closeSheet();
    window.location.href='/collections/all';
    return;
  }

  /* Start loading state */
  var btn=document.getElementById('swCtaBtn');
  btn.disabled=true;
  document.getElementById('swCtaIcon').textContent='⏳';
  document.getElementById('swCtaText').textContent='Processing…';

  /* Step 1 — fetch spin-the-wheel product to get variant ID */
  fetch('/products/spin-the-wheel.js')
    .then(function(r){return r.json();})
    .then(function(prod){
      var variantId=prod.variants[0].id;

      /* Step 2 — add to cart with prize as line item property */
      return fetch('/cart/add.js',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          items:[{
            id:variantId,
            quantity:1,
            properties:{
              '🎁 Prize Won':s.prize,
              '🏷️ Coupon Code':s.code,
              '📅 Won On':new Date().toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}),
              '_source':'QuickBee Lucky Wheel'
            }
          }]
        })
      });
    })
    .then(function(r){return r.json();})
    .then(function(){
      /* Step 3 — update cart note with prize details */
      var noteExtra='\n\n🎰 LUCKY WHEEL WIN\n'
        +'  Prize  : '+s.prize+'\n'
        +'  Code   : '+s.code+'\n'
        +'  Won On : '+new Date().toLocaleString('en-IN',{dateStyle:'medium',timeStyle:'short'});

      return fetch('/cart/update.js',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({note:noteExtra})
      });
    })
    .then(function(){
      document.getElementById('swCtaIcon').textContent='✓';
      document.getElementById('swCtaText').textContent='Redirecting to checkout…';
      /* Step 4 — go to checkout with discount code pre-applied */
      setTimeout(function(){
        window.location.href='/checkout?discount='+encodeURIComponent(s.code);
      },400);
    })
    .catch(function(err){
      console.error('Spin claim error:',err);
      /* Fallback: just go to checkout with discount */
      window.location.href='/checkout?discount='+encodeURIComponent(s.code);
    });
});

/* ═══════════════════════════════════════════
   INIT
═══════════════════════════════════════════ */
resize();
idleRotate();
updateChip();
updatePrevWins();
window.addEventListener('resize',resize,{passive:true});

})();
</script>

