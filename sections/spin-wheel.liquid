document.getElementById('qbswCopyBtn').addEventListener('click', function(){
  var code = document.getElementById('qbswCouponCode').textContent;
  var btn2 = this;
  try{
    navigator.clipboard.writeText(code).then(function(){
      btn2.textContent = 'Copied!';
      btn2.classList.add('copied');
      setTimeout(function(){ btn2.textContent='Copy'; btn2.classList.remove('copied'); },2000);
    });
  }catch(e){
    /* fallback */
    var ta = document.createElement('textarea');
    ta.value = code; ta.style.position='fixed'; ta.style.opacity='0';
    document.body.appendChild(ta); ta.select();
    document.execCommand('copy'); document.body.removeChild(ta);
    btn2.textContent = 'Copied!'; btn2.classList.add('copied');
    setTimeout(function(){ btn2.textContent='Copy'; btn2.classList.remove('copied'); },2000);
  }
});

/* ─────────────────────────────────────────
   CONFETTI
───────────────────────────────────────── */
var confettiParts = [];
var confettiRAF = null;
var COLORS = ['#F4B400','#FFD700','#ff6b6b','#4ade80','#60a5fa','#a78bfa','#fb923c','#fff'];

function launchConfetti(){
  confetti.width  = window.innerWidth;
  confetti.height = window.innerHeight;
  confettiParts = [];
  for(var i=0;i<120;i++){
    confettiParts.push({
      x: Math.random()*confetti.width,
      y: -10 - Math.random()*40,
      w: 6+Math.random()*8, h: 10+Math.random()*10,
      color: COLORS[Math.floor(Math.random()*COLORS.length)],
      vx: -3+Math.random()*6, vy: 2+Math.random()*5,
      rot: Math.random()*360, rotV: -5+Math.random()*10,
      life: 1
    });
  }
  if(confettiRAF) cancelAnimationFrame(confettiRAF);
  animateConfetti();
}

function animateConfetti(){
  cctx.clearRect(0,0,confetti.width,confetti.height);
  var alive = false;
  confettiParts.forEach(function(p){
    if(p.y > confetti.height + 20 || p.life<=0) return;
    alive = true;
    p.x += p.vx; p.y += p.vy; p.vy += 0.12;
    p.rot += p.rotV; p.life -= 0.006;
    cctx.save();
    cctx.translate(p.x,p.y);
    cctx.rotate(p.rot*Math.PI/180);
    cctx.globalAlpha = Math.min(1, p.life*3);
    cctx.fillStyle = p.color;
    cctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
    cctx.restore();
  });
  if(alive) confettiRAF = requestAnimationFrame(animateConfetti);
  else stopConfetti();
}

function stopConfetti(){
  if(confettiRAF){ cancelAnimationFrame(confettiRAF); confettiRAF=null; }
  cctx.clearRect(0,0,confetti.width,confetti.height);
}

