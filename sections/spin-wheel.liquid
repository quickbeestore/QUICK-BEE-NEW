  document.getElementById('lwBtnIcon').style.fontSize=(cs*0.33)+'px';
  document.getElementById('lwBtnLabel').style.fontSize=(cs*0.15)+'px';
  document.getElementById('lwPointer').style.top=(-SIZE/2-10)+'px';

  drawWheel(currentAngle);
}

/* ── DRAW ── */
function drawWheel(angle){
  ctx.clearRect(0,0,SIZE,SIZE);
  var slice=(Math.PI*2)/N;

  SEG.forEach(function(s,i){
    var a0=angle+slice*i-Math.PI/2;
    var a1=a0+slice;
    var mid=a0+slice/2;

    /* Segment fill */
    var grd=ctx.createRadialGradient(CX,CY,R*0.06,CX,CY,R*0.96);
    grd.addColorStop(0,s.c2);grd.addColorStop(1,s.c1);
    ctx.beginPath();ctx.moveTo(CX,CY);ctx.arc(CX,CY,R-5,a0,a1);ctx.closePath();
    ctx.fillStyle=grd;ctx.fill();

    /* Edge highlight */
    ctx.beginPath();ctx.moveTo(CX,CY);ctx.arc(CX,CY,R-5,a0,a1);ctx.closePath();
    ctx.strokeStyle='rgba(255,255,255,0.04)';ctx.lineWidth=0.5;ctx.stroke();

    /* Separator */
    ctx.save();ctx.translate(CX,CY);ctx.rotate(a0);
    ctx.beginPath();ctx.moveTo(CR+3,0);ctx.lineTo(R-6,0);
    ctx.strokeStyle='rgba(255,255,255,0.06)';ctx.lineWidth=0.8;ctx.stroke();
    ctx.restore();

    /* Emoji + text */
    ctx.save();ctx.translate(CX,CY);ctx.rotate(mid);
    var eSz=Math.max(10,Math.min(R*0.1,15));
    ctx.font=eSz+'px serif';ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(s.emoji,R*0.73,0);

    var fSz=Math.max(6,Math.min(R*0.06,9.5));
    ctx.font='800 '+fSz+'px -apple-system,sans-serif';
    ctx.fillStyle='rgba(255,255,255,0.92)';ctx.shadowColor='rgba(0,0,0,1)';ctx.shadowBlur=5;
    var lines=s.label.split('\n'),lh=fSz+2.5,tx=R*0.38;
    lines.forEach(function(ln,li){ctx.fillText(ln,tx,(li-(lines.length-1)/2)*lh);});
    ctx.restore();
  });

  /* Neon outer ring */
  ctx.beginPath();ctx.arc(CX,CY,R-2,0,Math.PI*2);
  ctx.strokeStyle='rgba(0,245,255,0.7)';ctx.lineWidth=2.5;
  ctx.shadowColor='rgba(0,245,255,0.9)';ctx.shadowBlur=12;ctx.stroke();
  ctx.beginPath();ctx.arc(CX,CY,R-5,0,Math.PI*2);
  ctx.strokeStyle='rgba(123,47,255,0.4)';ctx.lineWidth=1;ctx.shadowBlur=0;ctx.stroke();

  /* Tick dots */
  for(var i=0;i<N;i++){
    var a=angle+((Math.PI*2)/N)*i-Math.PI/2;
    var tx=CX+(R-1)*Math.cos(a),ty=CY+(R-1)*Math.sin(a);
    ctx.beginPath();ctx.arc(tx,ty,2,0,Math.PI*2);
    ctx.fillStyle='rgba(0,245,255,0.6)';ctx.fill();
  }

  /* Hub */
  var hg=ctx.createRadialGradient(CX-CR*0.2,CY-CR*0.25,0,CX,CY,CR+4);
  hg.addColorStop(0,'#150030');hg.addColorStop(1,'#050010');
  ctx.beginPath();ctx.arc(CX,CY,CR+6,0,Math.PI*2);ctx.fillStyle='#050008';ctx.fill();
  ctx.beginPath();ctx.arc(CX,CY,CR+4,0,Math.PI*2);
  ctx.strokeStyle='rgba(0,245,255,0.5)';ctx.lineWidth=1.5;
  ctx.shadowColor='rgba(0,245,255,0.5)';ctx.shadowBlur=8;ctx.stroke();ctx.shadowBlur=0;
  ctx.beginPath();ctx.arc(CX,CY,CR+2,0,Math.PI*2);
  ctx.strokeStyle='rgba(123,47,255,0.3)';ctx.lineWidth=1;ctx.stroke();
}

/* ── IDLE ── */
function idleRotate(){currentAngle+=0.0003;drawWheel(currentAngle);idleRAF=requestAnimationFrame(idleRotate);}

/* ── EASE ── */
function easeOut(t){return 1-Math.pow(1-t,4);}

/* ── ANIM ── */
function animSpin(ts){
  if(!spinStart)spinStart=ts;
  var p=Math.min((ts-spinStart)/DURATION,1);
  currentAngle=spinFrom+(spinTarget-spinFrom)*easeOut(p);
  drawWheel(currentAngle);

  var slice=(Math.PI*2)/N;
  var norm=((currentAngle%(Math.PI*2))+(Math.PI*2))%(Math.PI*2);
  var seg=Math.floor(norm/slice)%N;
  if(seg!==lastTickSeg){
    var spd=1-p;
    if(spd>0.06) playTick(500+spd*600,0.05+spd*0.04);
    try{if(navigator.vibrate&&spd>0.4)navigator.vibrate(6);}catch(e){}
    lastTickSeg=seg;
  }
  if(p<1){requestAnimationFrame(animSpin);}else{onSpinEnd();}
}

/* ── SPIN ── */
function spin(){
  if(isSpinning)return;
  var used=getUsed();
  if(used>=MAX)return;

  /* Unlock audio */
  getAC();

  if(idleRAF){cancelAnimationFrame(idleRAF);idleRAF=null;}
  isSpinning=true;
  btn.disabled=true;
  zone.classList.add('spinning');
  hint1.style.display='none';hint2.style.display='none';
  document.getElementById('lwBtnIcon').textContent='🌀';
  document.getElementById('lwBtnLabel').textContent='GO!';

  spinStart=null;spinFrom=currentAngle;
  winIdx=pickSeg();
  var slice=(Math.PI*2)/N;
  var segMid=slice*winIdx+slice/2;
  var target=(((-Math.PI/2-segMid)%(Math.PI*2))+(Math.PI*2))%(Math.PI*2);
  var spins=7+Math.floor(Math.random()*4);
  spinTarget=spinFrom-(spinFrom%(Math.PI*2))+Math.PI*2*spins+target;
  if(spinTarget-spinFrom<Math.PI*2*5)spinTarget+=Math.PI*2*5;

  requestAnimationFrame(animSpin);
}

/* ── SPIN END ── */
function onSpinEnd(){
  isSpinning=false;zone.classList.remove('spinning');
  var s=SEG[winIdx];currentSeg=s;

  var used=getUsed();
  setUsed(used+1);
  addHist(s);
  addTodayWin(s);
  updateUI();
  updateRecent();

  try{if(navigator.vibrate)navigator.vibrate(s.type==='win'?[60,40,100,40,150]:[120,60,120]);}catch(e){}
  if(s.type==='win'){playWin();launchConfetti();}
  else{playLose();}

  var left=MAX-(used+1);

  /* Re-enable btn if spins remain (for after sheet close) */
  if(left>0){
    document.getElementById('lwBtnIcon').textContent='🎰';
    document.getElementById('lwBtnLabel').textContent='SPIN';
    btn.disabled=false;
    if(!idleRAF)idleRotate();
    hint1.style.display='';hint2.style.display='';
  }

  showSheet(s,left);
}

/* ── SHOW SHEET ── */
function showSheet(s,spinsLeft){
  var win=s.type==='win';

  document.getElementById('lwSheetGlow').style.background=
    win?'radial-gradient(ellipse,rgba(0,245,255,0.15) 0%,transparent 70%)':
        'radial-gradient(ellipse,rgba(255,255,255,0.04) 0%,transparent 70%)';

  var pb=document.getElementById('lwPrizeBg');
  pb.style.background=win?'linear-gradient(135deg,rgba(0,245,255,0.12),rgba(123,47,255,0.15))':'rgba(30,30,30,0.4)';
  pb.style.border=win?'1px solid rgba(0,245,255,0.25)':'1px solid rgba(255,255,255,0.06)';

  document.getElementById('lwPrizeEmoji').textContent=s.emoji;
  document.getElementById('lwSheetStatus').textContent=win?'🎉 YOU WON!':'😅 TRY AGAIN!';
  document.getElementById('lwSheetStatus').style.color=win?'var(--neon)':'rgba(255,255,255,0.25)';
  document.getElementById('lwSheetHeading').textContent=win?'Congratulations!':'Not This Time!';
  document.getElementById('lwSheetPrize').textContent=s.prize;
  document.getElementById('lwSheetDesc').textContent=s.desc;

  var codeCard=document.getElementById('lwCodeCard');
  var screenshot=document.getElementById('lwScreenshot');
  if(win&&s.code){
    codeCard.style.display='block';
    screenshot.style.display='flex';
    document.getElementById('lwCodeVal').textContent=s.code;
  }else{
    codeCard.style.display='none';
    screenshot.style.display='none';
  }

  /* WA message — all today's wins combined */
  var msg=buildWAMsg(s);
  document.getElementById('lwClaimWa').href='https://wa.me/'+WA+'?text='+encodeURIComponent(msg);
  var todayWins=getTodayWins();
  var claimLabel=win?(todayWins.length>1?'🎁 Claim All '+todayWins.length+' Prizes on WhatsApp':'🎁 Claim Prize on WhatsApp'):'💬 Order on WhatsApp';
  document.getElementById('lwClaimTxt').textContent=claimLabel;

  /* Spin Again button */
  var spinAgainBtn=document.getElementById('lwSpinAgainBtn');
  if(spinsLeft>0){
    spinAgainBtn.style.display='flex';
    spinAgainBtn.className='lw-btn-spin-again'+(win?'':' pulse');
    document.getElementById('lwSpinsLeftTxt').textContent=spinsLeft+' LEFT';
  }else{
    spinAgainBtn.style.display='none';
  }

  overlay.classList.add('show');
}

function closeSheet(){
  overlay.classList.remove('show');
}

/* ── SPIN AGAIN from sheet ── */
document.getElementById('lwSpinAgainBtn').addEventListener('click',function(){
  closeSheet();
  setTimeout(function(){spin();},300);
});

/* ── COPY ── */
document.getElementById('lwCopyBtn').addEventListener('click',function(){
  var code=document.getElementById('lwCodeVal').textContent;
  try{navigator.clipboard.writeText(code);}catch(e){var t=document.createElement('textarea');t.value=code;document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t);}
  this.textContent='✓ COPIED';this.className='lw-copy-btn copied';
  var self=this;setTimeout(function(){self.textContent='COPY';self.className='lw-copy-btn';},2000);
});

/* ── CONFETTI ── */
var particles=[];
function launchConfetti(){
  particles=[];
  var colors=['#00f5ff','#7b2fff','#ff2d78','#F4B400','#FFD700','#25D366','#fff'];
  for(var i=0;i<150;i++){
    particles.push({
      x:Math.random()*confEl.width,y:-20,
      vx:(Math.random()-0.5)*8,vy:Math.random()*5+2,
      r:Math.random()*5+2,
      color:colors[Math.floor(Math.random()*colors.length)],
      rot:Math.random()*360,vrot:(Math.random()-0.5)*10,
      life:1,shape:Math.random()>0.5?'rect':'circle'
    });
  }
  animConf();
}
function animConf(){
  cctx.clearRect(0,0,confEl.width,confEl.height);
  var alive=false;
  particles.forEach(function(p){
    p.x+=p.vx;p.y+=p.vy;p.vy+=0.15;p.rot+=p.vrot;p.life-=0.013;
    if(p.life<=0||p.y>confEl.height+20)return;
    alive=true;
    cctx.save();cctx.globalAlpha=Math.min(p.life,1);
    cctx.translate(p.x,p.y);cctx.rotate(p.rot*Math.PI/180);
    cctx.fillStyle=p.color;
    if(p.shape==='circle'){cctx.beginPath();cctx.arc(0,0,p.r,0,Math.PI*2);cctx.fill();}
    else{cctx.fillRect(-p.r,-p.r/2,p.r*2,p.r);}
    cctx.restore();
  });
  if(alive)requestAnimationFrame(animConf);
  else cctx.clearRect(0,0,confEl.width,confEl.height);
}

/* ── RECENT ── */
function updateRecent(){
  var h=getHist(),pills=document.getElementById('lwRecentPills');
  pills.innerHTML='';
  h.slice(0,4).forEach(function(item){
    var p=document.createElement('span');p.className='lw-recent-pill';
    p.textContent=item.emoji+' '+item.prize;pills.appendChild(p);
  });
}

/* ── STARS ── */
(function(){
  var root=document.getElementById('lwRoot');
  for(var i=0;i<60;i++){
    var s=document.createElement('div');s.className='lw-star';
    var sz=(Math.random()*2+0.4).toFixed(1);
    s.style.cssText='width:'+sz+'px;height:'+sz+'px;top:'+Math.random()*100+'%;left:'+Math.random()*100+'%;--d:'+(2+Math.random()*6).toFixed(1)+'s;--dl:'+(Math.random()*6).toFixed(1)+'s;';
    root.appendChild(s);
  }
})();

/* ── EVENTS ── */
btn.addEventListener('click',spin,{passive:true});
canvas.addEventListener('click',spin,{passive:true});
var swY=0;
canvas.addEventListener('touchstart',function(e){swY=e.touches[0].clientY;},{passive:true});
canvas.addEventListener('touchend',function(e){if(Math.abs(swY-e.changedTouches[0].clientY)>25)spin();},{passive:true});
document.getElementById('lwCloseBtn').addEventListener('click',closeSheet);
overlay.addEventListener('click',function(e){if(e.target===overlay)closeSheet();});

/* ── INIT ── */
resize();
idleRotate();
updateUI();
updateRecent();
window.addEventListener('resize',resize,{passive:true});

})();
</script>

