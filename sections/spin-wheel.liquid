        <button class="am-btn-close" id="amCloseBtn">Maybe later</button>
      </div>
    </div>
  </div>
</div>

<canvas id="amConfetti"></canvas>

<script>
(function(){
'use strict';

var WA = '9779704015190';
var MAX_SPINS = 5;
var LS_KEY = 'amsw_day';      /* date string */
var LS_USED = 'amsw_used';    /* spins used today */
var LS_HIST = 'amsw_hist';

/* ── SEGMENTS: only Pachali Bhairav & Typical Taste food/drinks ── */
var SEG = [
  /* Typical Taste */
  {label:'Chicken\nBiryani\n10% Off',emoji:'🍛',c1:'#6B1010',c2:'#a82020',code:'FOOD10',prize:'10% Off Food — Typical Taste',desc:'10% off Chicken Biryani & all food from Typical Taste. Hot, fresh, delivered in 20 mins!',wt:10,type:'win'},
  {label:'Leg Piece\n10% Off',emoji:'🍗',c1:'#3A0F6E',c2:'#6420b8',code:'LEGPIECE10',prize:'10% Off Leg Piece — Typical Taste',desc:'10% off Chicken Leg Piece from Typical Taste. Crispy & juicy — delivered fast!',wt:9,type:'win'},

  /* Pachali Bhairav */
  {label:'Samay\nBaji Free',emoji:'🥘',c1:'#7A3B00',c2:'#b85800',code:'SAMAYBAJI',prize:'Free Samay Baji Set',desc:'Get a FREE Samay Baji Set from Pachali Bhaira Food Court with any order above Rs 400!',wt:4,type:'win'},
  {label:'Buff\nChoila 10%',emoji:'🥩',c1:'#4A0000',c2:'#800000',code:'PACHALI10',prize:'10% Off Pachali Bhaira',desc:'10% off all food from Pachali Bhaira Food Court — Buff Choila, Chatamari, Momo & more!',wt:9,type:'win'},
  {label:'Aila\nRs 50 Off',emoji:'🍶',c1:'#1A0A3E',c2:'#3a1880',code:'AILA50',prize:'Rs 50 Off Aila — Pachali',desc:'Rs 50 off on Aila 1L from Pachali Bhaira Food Court. The real deal!',wt:8,type:'win'},
  {label:'Chicken\nMomo 10%',emoji:'🥟',c1:'#003A1A',c2:'#006030',code:'FOOD10',prize:'10% Off Momo — Typical Taste',desc:'10% off Chicken Momo from Typical Taste. Juicy momos, delivered steaming hot!',wt:10,type:'win'},
  {label:'Buff\nMomo 10%',emoji:'🫕',c1:'#2A1A00',c2:'#4a3000',code:'PACHALI10',prize:'10% Off Buff Momo — Pachali',desc:'10% off Buff Momo & Newari food from Pachali Bhaira Food Court!',wt:9,type:'win'},
  {label:'Chyang\nRs 30 Off',emoji:'🍺',c1:'#0A2A3E',c2:'#1a4a6e',code:'CHYANG30',prize:'Rs 30 Off Chyang — Pachali',desc:'Rs 30 off on Chyang Tho 1L from Pachali Bhaira Food Court. Traditional Newari brew!',wt:8,type:'win'},
  {label:'FREE\nDelivery',emoji:'🎁',c1:'#0D5C2E',c2:'#1a8f48',code:'FREE28',prize:'FREE Delivery',desc:'Free delivery on your next order — any amount, any time! Use FREE28 at checkout.',wt:10,type:'win'},
  {label:'Rs 150\nOff Order',emoji:'🏆',c1:'#2E1A00',c2:'#5a3800',code:'QB150WIN',prize:'Rs 150 Off Any Order',desc:'Rs 150 off any order above Rs 800. Biggest prize on the wheel! Use QB150WIN at checkout.',wt:3,type:'win'},

  /* Try Again — always 1-2 per spin via algorithm */
  {label:'Try\nAgain',emoji:'😅',c1:'#141414',c2:'#1e1e1e',code:null,prize:'Not This Time!',desc:'So close! Come back and spin again — you have more spins left today!',wt:0,type:'lose'},
  {label:'Try\nAgain',emoji:'🔄',c1:'#0f0f0f',c2:'#181818',code:null,prize:'Better Luck!',desc:'Almost! Spin again — your prize is waiting. Don\'t give up!',wt:0,type:'lose'},
];

var N = SEG.length;

/* ── DOM ── */
var canvas  = document.getElementById('amCanvas');
var ctx     = canvas.getContext('2d');
var btn     = document.getElementById('amBtn');
var zone    = document.getElementById('amZone');
var overlay = document.getElementById('amOverlay');
var hint1   = document.getElementById('amHint1');
var hint2   = document.getElementById('amHint2');
var confEl  = document.getElementById('amConfetti');
var cctx    = confEl.getContext('2d');

/* ── SPIN STATE ── */
var SIZE=0,R=0,CX=0,CY=0,CR=0;
var currentAngle=0,isSpinning=false;
var spinStart=null,spinFrom=0,spinTarget=0,winIdx=0;
var DURATION=5500,lastTickSeg=-1,idleRAF=null,audioCtx=null;
var currentSeg=null;

/* ── STORAGE HELPERS ── */
function today(){ return new Date().toDateString(); }
function getUsed(){
  try{
    if(localStorage.getItem(LS_KEY)!==today()) return 0;
    return parseInt(localStorage.getItem(LS_USED)||'0',10);
  }catch(e){return 0;}
}
function setUsed(n){
  try{localStorage.setItem(LS_KEY,today());localStorage.setItem(LS_USED,String(n));}catch(e){}
}
function getHistory(){try{return JSON.parse(localStorage.getItem(LS_HIST)||'[]');}catch(e){return[];}}
function addHistory(s){
  var h=getHistory();
  h.unshift({emoji:s.emoji,prize:s.prize,ts:Date.now()});
  if(h.length>20)h=h.slice(0,20);
  try{localStorage.setItem(LS_HIST,JSON.stringify(h));}catch(e){}
}

/* ── SPIN COUNT UI ── */
function updateSpinsUI(){
  var used=getUsed(), left=MAX_SPINS-used;
  document.getElementById('amSpinsTxt').textContent=left>0?left+' spin'+(left===1?'':'s')+' left':'No spins left';
  for(var i=0;i<5;i++){
    var d=document.getElementById('amDot'+i);
    if(i<used) d.className='am-dot used';
    else if(i===used&&left>0) d.className='am-dot active';
    else d.className='am-dot';
  }
  if(left===0){
    btn.disabled=true;
    document.getElementById('amBtnIcon').textContent='🔒';
    document.getElementById('amBtnLabel').textContent='DONE';
    hint1.style.display='none';hint2.style.display='none';
  }
}

/* ── WEIGHTED PICK — guarantees Try Again on spin 2 or 3 ── */
function pickSegment(spinNum){
  var used=getUsed();
  /* Force try-again on spin 2 or spin 4 (50% chance each) */
  var forceLose = (used===1)||(used===3&&Math.random()>0.5);
  if(forceLose){
    var loseIdx=[10,11];
    return loseIdx[Math.floor(Math.random()*2)];
  }
  /* Weighted random from win segments (0–9) */
  var wins=SEG.slice(0,10);
  var tot=wins.reduce(function(a,s){return a+s.wt;},0);
  var r=Math.random()*tot,acc=0;
  for(var i=0;i<wins.length;i++){acc+=wins[i].wt;if(r<=acc)return i;}
  return 0;
}

/* ── AUDIO ── */
function getAC(){if(!audioCtx)try{audioCtx=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}return audioCtx;}
function tick(freq){
  var ac=getAC();if(!ac)return;
  try{var o=ac.createOscillator(),g=ac.createGain();o.connect(g);g.connect(ac.destination);
    o.frequency.value=freq||700;o.type='sine';
    g.gain.setValueAtTime(0.08,ac.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+0.04);
    o.start();o.stop(ac.currentTime+0.05);}catch(e){}
}

/* ── SIZING ── */
function resize(){
  var vw=window.innerWidth,vh=window.innerHeight;
  var hH=document.querySelector('.am-header').offsetHeight||54;
  var heroH=document.querySelector('.am-hero').offsetHeight||70;
  var recentH=document.getElementById('amRecent').offsetHeight||24;
  var waH=document.querySelector('.am-wa-bar').offsetHeight||60;
  var avail=Math.min(vw-20,vh-hH-heroH-recentH-waH-20);
  SIZE=Math.max(200,Math.min(avail,480));
  R=SIZE/2;CX=R;CY=R;CR=R*0.17;

  canvas.width=canvas.height=SIZE;
  canvas.style.width=canvas.style.height=SIZE+'px';
  confEl.width=window.innerWidth;confEl.height=window.innerHeight;

  var gr=document.getElementById('amGlowRing');
  var go=SIZE+60;
  gr.style.cssText='width:'+go+'px;height:'+go+'px;';

  var hintR=CR+14;
  [hint1,hint2].forEach(function(h){h.style.width=h.style.height=(hintR*2)+'px';h.style.marginLeft=h.style.marginTop=(-hintR)+'px';});

  var cs=CR*2;
  btn.style.width=btn.style.height=cs+'px';
  btn.style.boxShadow='0 0 0 '+(R*0.02)+'px #0a0500,'+'0 0 0 '+(R*0.04)+'px rgba(192,57,43,0.4),'+'0 6px 20px rgba(0,0,0,.7)';
  document.getElementById('amBtnIcon').style.fontSize=(cs*0.34)+'px';
  document.getElementById('amBtnLabel').style.fontSize=(cs*0.16)+'px';

  var ptr=document.getElementById('amPointer');
  ptr.style.top=(-SIZE/2-12)+'px';

  drawWheel(currentAngle);
}

/* ── DRAW ── */
function drawWheel(angle){
  ctx.clearRect(0,0,SIZE,SIZE);
  var slice=(Math.PI*2)/N;

  SEG.forEach(function(s,i){
    var a0=angle+slice*i-Math.PI/2;
    var a1=a0+slice;
    var mid=a0+slice/2;

    /* Segment */
    var grd=ctx.createRadialGradient(CX,CY,R*0.06,CX,CY,R*0.96);
    grd.addColorStop(0,s.c2);
    grd.addColorStop(1,s.c1);
    ctx.beginPath();ctx.moveTo(CX,CY);ctx.arc(CX,CY,R-6,a0,a1);ctx.closePath();
    ctx.fillStyle=grd;ctx.fill();

    /* Separator */
    ctx.save();ctx.translate(CX,CY);ctx.rotate(a0);
    ctx.beginPath();ctx.moveTo(CR+3,0);ctx.lineTo(R-7,0);
    ctx.strokeStyle='rgba(255,255,255,0.08)';ctx.lineWidth=1;ctx.stroke();
    ctx.restore();

    /* Text */
    ctx.save();ctx.translate(CX,CY);ctx.rotate(mid);
    var emojiSz=Math.max(10,Math.min(R*0.1,16));
    ctx.font=emojiSz+'px serif';ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(s.emoji,R*0.72,0);

    var fSz=Math.max(6.5,Math.min(R*0.062,10));
    ctx.font='700 '+fSz+'px -apple-system,sans-serif';
    ctx.fillStyle='#fff';ctx.shadowColor='rgba(0,0,0,1)';ctx.shadowBlur=4;
    var lines=s.label.split('\n');
    var lh=fSz+2;
    var tx=R*0.38;
    lines.forEach(function(ln,li){ctx.fillText(ln,tx,(li-(lines.length-1)/2)*lh);});
    ctx.restore();
  });

  /* Outer gold ring */
  ctx.beginPath();ctx.arc(CX,CY,R-3,0,Math.PI*2);
  ctx.strokeStyle='#C0392B';ctx.lineWidth=6;
  ctx.shadowColor='rgba(192,57,43,0.8)';ctx.shadowBlur=14;ctx.stroke();

  /* Gold accent ring */
  ctx.beginPath();ctx.arc(CX,CY,R-7,0,Math.PI*2);
  ctx.strokeStyle='rgba(244,180,0,0.4)';ctx.lineWidth=1.5;ctx.shadowBlur=0;ctx.stroke();

  /* Tick dots */
  SEG.forEach(function(_,i){
    var a=angle+((Math.PI*2)/N)*i-Math.PI/2;
    var tx=CX+(R-1)*Math.cos(a),ty=CY+(R-1)*Math.sin(a);
    ctx.beginPath();ctx.arc(tx,ty,2.5,0,Math.PI*2);
    ctx.fillStyle='rgba(244,180,0,0.6)';ctx.fill();
  });

  /* Hub */
  var hubG=ctx.createRadialGradient(CX-CR*0.2,CY-CR*0.2,0,CX,CY,CR);
  hubG.addColorStop(0,'#1e0800');hubG.addColorStop(1,'#0a0500');
  ctx.beginPath();ctx.arc(CX,CY,CR+5,0,Math.PI*2);ctx.fillStyle='#0a0500';ctx.fill();
  ctx.beginPath();ctx.arc(CX,CY,CR+3,0,Math.PI*2);
  ctx.strokeStyle='rgba(192,57,43,0.6)';ctx.lineWidth=2;
  ctx.shadowColor='rgba(192,57,43,0.4)';ctx.shadowBlur=8;ctx.stroke();ctx.shadowBlur=0;
}

/* ── IDLE ── */
var idleSpeed=0.0004;
function idleRotate(){currentAngle+=idleSpeed;drawWheel(currentAngle);idleRAF=requestAnimationFrame(idleRotate);}

/* ── EASE ── */
function easeOut(t){return 1-Math.pow(1-t,4);}

/* ── SPIN ANIM ── */
function animSpin(ts){
  if(!spinStart)spinStart=ts;
  var p=Math.min((ts-spinStart)/DURATION,1);
  currentAngle=spinFrom+(spinTarget-spinFrom)*easeOut(p);
  drawWheel(currentAngle);

  var slice=(Math.PI*2)/N;
  var norm=((currentAngle%(Math.PI*2))+(Math.PI*2))%(Math.PI*2);
  var seg=Math.floor(norm/slice)%N;
  if(seg!==lastTickSeg){
    var spd=1-p;
    if(spd>0.05)tick(550+spd*450);
    try{if(navigator.vibrate&&spd>0.3)navigator.vibrate(8);}catch(e){}
    lastTickSeg=seg;
  }
  if(p<1){requestAnimationFrame(animSpin);}else{onSpinEnd();}
}

/* ── SPIN ── */
function spin(){
  if(isSpinning)return;
  var used=getUsed();
  if(used>=MAX_SPINS)return;

  if(idleRAF){cancelAnimationFrame(idleRAF);idleRAF=null;}
  isSpinning=true;btn.disabled=true;
  document.getElementById('amBtnIcon').textContent='⏳';
  document.getElementById('amBtnLabel').textContent='…';
  zone.classList.add('spinning');
  hint1.style.display='none';hint2.style.display='none';

  spinStart=null;spinFrom=currentAngle;
  winIdx=pickSegment(used);
  var slice=(Math.PI*2)/N;
  var segMid=slice*winIdx+slice/2;
  var target=(((-Math.PI/2-segMid)%(Math.PI*2))+(Math.PI*2))%(Math.PI*2);
  var spins=6+Math.floor(Math.random()*4);
  spinTarget=spinFrom-(spinFrom%(Math.PI*2))+Math.PI*2*spins+target;
  if(spinTarget-spinFrom<Math.PI*2*5)spinTarget+=Math.PI*2*5;

  requestAnimationFrame(animSpin);
}

/* ── SPIN END ── */
function onSpinEnd(){
  isSpinning=false;zone.classList.remove('spinning');
  var s=SEG[winIdx];
  currentSeg=s;

  var used=getUsed();
  setUsed(used+1);
  addHistory(s);
  updateSpinsUI();
  updateRecent();

  try{if(navigator.vibrate)navigator.vibrate(s.type==='win'?[50,30,80,30,120]:[100]);}catch(e){}

  var left=MAX_SPINS-(used+1);
  if(s.type==='win'){launchConfetti();}

  /* Re-enable btn if spins left */
  if(left>0&&s.type!=='win'){
    setTimeout(function(){
      btn.disabled=false;
      document.getElementById('amBtnIcon').textContent='🎰';
      document.getElementById('amBtnLabel').textContent='SPIN';
      hint1.style.display='';hint2.style.display='';
      idleRotate();
    },500);
    showSheet(s);
  } else {
    showSheet(s);
  }
}

/* ── SHEET ── */
function showSheet(s){
  currentSeg=s;
  var win=s.type==='win';

  /* Glow */
  document.getElementById('amSheetGlow').style.background=
    win?'radial-gradient(ellipse,rgba(192,57,43,0.25) 0%,transparent 70%)':
        'radial-gradient(ellipse,rgba(100,100,100,0.1) 0%,transparent 70%)';

  /* Icon bg */
  var ib=document.getElementById('amPrizeIconBg');
  ib.style.background=win?'linear-gradient(135deg,'+s.c2+'33,'+s.c1+'66)':'rgba(50,50,50,0.3)';
  ib.style.border=win?'1px solid '+s.c2+'66':'1px solid rgba(255,255,255,0.07)';

  document.getElementById('amPrizeEmoji').textContent=s.emoji;
  document.getElementById('amSheetTag').textContent=win?'🎉 You Won!':'😅 Try Again!';
  document.getElementById('amSheetTag').style.color=win?'#F4B400':'rgba(255,255,255,0.3)';
  document.getElementById('amSheetTitle').textContent=win?'Congratulations!':'Not This Time!';
  document.getElementById('amSheetPrize').textContent=s.prize;
  document.getElementById('amSheetDesc').textContent=s.desc;

  var codeBox=document.getElementById('amCodeBox');
  var screenshotRow=document.getElementById('amScreenshotRow');
  if(win&&s.code){
    codeBox.style.display='flex';
    screenshotRow.style.display='flex';
    document.getElementById('amCodeVal').textContent=s.code;
  } else {
    codeBox.style.display='none';
    screenshotRow.style.display='none';
  }

  /* WA link */
  var date=new Date().toLocaleString('en-IN',{dateStyle:'medium',timeStyle:'short'});
  var msg=win?
    '🎰 I won on the Aila Madira Lucky Wheel!\n\n🏆 Prize: '+s.prize+'\n🏷️ Code: '+s.code+'\n📅 Won: '+date+'\n\nPlease help me claim! (Screenshot attached 📸)':
    'Hi Aila Madira! I just spun the Lucky Wheel. Can I order food directly? 🍶';
  document.getElementById('amClaimWa').href='https://wa.me/'+WA+'?text='+encodeURIComponent(msg);

  var waLabel=document.querySelector('#amClaimWa span');
  waLabel.textContent=win?'🎁 Claim Prize on WhatsApp':'💬 Order on WhatsApp';

  overlay.classList.add('show');
  document.getElementById('amSheet').classList.toggle('lose',!win);
}

function closeSheet(){
  overlay.classList.remove('show');
  var used=getUsed(),left=MAX_SPINS-used;
  if(left>0&&!isSpinning){
    if(!idleRAF)idleRotate();
  }
}

/* ── COPY ── */
document.getElementById('amCopyBtn').addEventListener('click',function(){
  var code=document.getElementById('amCodeVal').textContent;
  try{navigator.clipboard.writeText(code).then(function(){});}catch(e){
    var t=document.createElement('textarea');t.value=code;document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t);
  }
  this.textContent='Copied!';this.className='am-copy-btn copied';
  var self=this;setTimeout(function(){self.textContent='Copy';self.className='am-copy-btn';},2000);
});

/* ── CONFETTI ── */
var confParticles=[];
function launchConfetti(){
  confParticles=[];
  for(var i=0;i<120;i++){
    confParticles.push({
      x:Math.random()*confEl.width,y:-10,
      vx:(Math.random()-0.5)*6,vy:Math.random()*4+2,
      r:Math.random()*5+3,
      color:['#C0392B','#F4B400','#FFD700','#25D366','#fff','#e74c3c'][Math.floor(Math.random()*6)],
      rot:Math.random()*360,vrot:(Math.random()-0.5)*8,
      life:1
    });
  }
  animConfetti();
}
function animConfetti(){
  cctx.clearRect(0,0,confEl.width,confEl.height);
  var alive=false;
  confParticles.forEach(function(p){
    p.x+=p.vx;p.y+=p.vy;p.vy+=0.12;p.rot+=p.vrot;p.life-=0.012;
    if(p.life<=0||p.y>confEl.height+20)return;
    alive=true;
    cctx.save();cctx.globalAlpha=Math.min(p.life,1);
    cctx.translate(p.x,p.y);cctx.rotate(p.rot*Math.PI/180);
    cctx.fillStyle=p.color;
    cctx.fillRect(-p.r,-p.r/2,p.r*2,p.r);
    cctx.restore();
  });
  if(alive)requestAnimationFrame(animConfetti);
  else cctx.clearRect(0,0,confEl.width,confEl.height);
}

/* ── RECENT ── */
function updateRecent(){
  var h=getHistory(),pills=document.getElementById('amRecentPills');
  pills.innerHTML='';
  h.slice(0,4).forEach(function(item){
    var p=document.createElement('span');p.className='am-recent-pill';
    p.textContent=item.emoji+' '+item.prize;pills.appendChild(p);
  });
}

/* ── STARS ── */
(function(){
  var root=document.getElementById('amRoot');
  for(var i=0;i<55;i++){
    var s=document.createElement('div');s.className='am-star';
    var sz=(Math.random()*2+0.4).toFixed(1);
    s.style.cssText='width:'+sz+'px;height:'+sz+'px;top:'+Math.random()*100+'%;left:'+Math.random()*100+'%;--d:'+(2+Math.random()*5).toFixed(1)+'s;--dl:'+(Math.random()*5).toFixed(1)+'s;';
    root.appendChild(s);
  }
})();

/* ── EVENTS ── */
btn.addEventListener('click',spin,{passive:true});
canvas.addEventListener('click',spin,{passive:true});
var swY=0;
canvas.addEventListener('touchstart',function(e){swY=e.touches[0].clientY;},{passive:true});
canvas.addEventListener('touchend',function(e){if(Math.abs(swY-e.changedTouches[0].clientY)>25)spin();},{passive:true});
document.getElementById('amCloseBtn').addEventListener('click',closeSheet);
overlay.addEventListener('click',function(e){if(e.target===overlay)closeSheet();});

/* ── INIT ── */
resize();
idleRotate();
updateSpinsUI();
updateRecent();
window.addEventListener('resize',resize,{passive:true});

})();
</script>

