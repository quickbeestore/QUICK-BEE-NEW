{% comment %} QuickBee — Spin The Wheel Premium Mobile Edition 2026 {% endcomment %}
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{overflow:hidden!important;height:100%;background:#000!important;touch-action:none;}
#shopify-section-header,.site-header,header[class*="header"],
#shopify-section-footer,.site-footer,footer[class*="footer"],
.qb-ticker,.qb-trust-bar,#qbsc-root,.qb-timebox,
[class*="announcement"],[id*="announcement"]{display:none!important;}

/* ═══════════════════════════════════════════
   ROOT
═══════════════════════════════════════════ */
.sw{
  position:fixed;inset:0;
  background:#000;
  display:flex;flex-direction:column;align-items:center;
  font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display','Segoe UI',sans-serif;
  z-index:9999;overflow:hidden;
  user-select:none;-webkit-user-select:none;
}

/* Animated bg */
.sw-bg{
  position:absolute;inset:0;pointer-events:none;
  background:
    radial-gradient(ellipse 80% 50% at 50% -10%,rgba(244,180,0,0.18) 0%,transparent 70%),
    radial-gradient(ellipse 60% 40% at 50% 110%,rgba(244,180,0,0.08) 0%,transparent 60%),
    #080600;
}
.sw-bg-pulse{
  position:absolute;width:300px;height:300px;border-radius:50%;
  background:radial-gradient(circle,rgba(244,180,0,0.06) 0%,transparent 70%);
  top:50%;left:50%;transform:translate(-50%,-50%);
  animation:swPulse 3s ease-in-out infinite;
}
@keyframes swPulse{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.5}50%{transform:translate(-50%,-50%) scale(1.4);opacity:1}}

/* Stars */
.sw-star{
  position:absolute;border-radius:50%;background:#fff;pointer-events:none;
  animation:swTwinkle var(--d) var(--dl) ease-in-out infinite alternate;
}
@keyframes swTwinkle{0%{opacity:.05}100%{opacity:.7}}

/* ═══════════════════════════════════════════
   HEADER BAR
═══════════════════════════════════════════ */
.sw-header{
  width:100%;padding:env(safe-area-inset-top,12px) 20px 0;
  display:flex;align-items:center;justify-content:space-between;
  position:relative;z-index:5;flex-shrink:0;
  padding-top:calc(env(safe-area-inset-top,0px) + 12px);
}
.sw-header-brand{
  display:flex;align-items:center;gap:7px;
}
.sw-header-bee{font-size:22px;line-height:1;}
.sw-header-name{
  font-size:16px;font-weight:900;letter-spacing:-0.3px;
  background:linear-gradient(135deg,#FFD700,#F4B400);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.sw-header-badge{
  font-size:10px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;
  color:#0a0600;background:#F4B400;border-radius:99px;
  padding:3px 9px;
}

/* ═══════════════════════════════════════════
   TITLE SECTION
═══════════════════════════════════════════ */
.sw-title-block{
  text-align:center;flex-shrink:0;
  padding:10px 20px 6px;position:relative;z-index:5;
}
.sw-title{
  font-size:clamp(24px,6vw,34px);font-weight:900;letter-spacing:-0.5px;line-height:1;
  background:linear-gradient(135deg,#FFFFFF 0%,#FFD700 50%,#F4B400 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.sw-subtitle{
  font-size:12px;color:rgba(255,255,255,0.38);margin-top:4px;letter-spacing:0.04em;
}

/* ═══════════════════════════════════════════
   SPIN AVAILABILITY CHIP
═══════════════════════════════════════════ */
.sw-chip{
  display:inline-flex;align-items:center;gap:6px;
  padding:6px 14px;border-radius:99px;
  font-size:11px;font-weight:800;letter-spacing:0.04em;
  margin:4px 0 0;
  transition:all .3s;
}
.sw-chip.available{
  background:rgba(74,222,128,0.12);border:1px solid rgba(74,222,128,0.3);color:#4ade80;
}
.sw-chip.used{
  background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.35);
}
.sw-chip-dot{
  width:6px;height:6px;border-radius:50%;flex-shrink:0;
}
.sw-chip.available .sw-chip-dot{background:#4ade80;animation:swDotPulse 1.2s ease infinite;}
.sw-chip.used .sw-chip-dot{background:rgba(255,255,255,0.2);}
@keyframes swDotPulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.5);opacity:.6}}

/* ═══════════════════════════════════════════
   WHEEL ZONE
═══════════════════════════════════════════ */
.sw-wheel-zone{
  flex:1;display:flex;align-items:center;justify-content:center;
  position:relative;width:100%;min-height:0;
  padding:4px 0;
}

/* Outer decorative ring with tick marks */
.sw-ring-outer{
  position:absolute;border-radius:50%;pointer-events:none;
  border:2px solid rgba(244,180,0,0.15);
  box-shadow:
    0 0 0 1px rgba(244,180,0,0.06),
    inset 0 0 0 1px rgba(244,180,0,0.06),
    0 0 50px 10px rgba(244,180,0,0.12),
    0 0 100px 30px rgba(244,180,0,0.06);
}

/* Pointer */
.sw-pointer{
  position:absolute;z-index:20;pointer-events:none;
  top:0;left:50%;transform:translateX(-50%) translateY(-2px);
  filter:drop-shadow(0 0 10px rgba(244,180,0,1)) drop-shadow(0 2px 6px rgba(0,0,0,.8));
}

/* Canvas */
#swCanvas{
  display:block;border-radius:50%;position:relative;z-index:3;
  transition:filter .3s;
  touch-action:none;cursor:pointer;
}
.sw-wheel-zone.spinning #swCanvas{
  filter:drop-shadow(0 0 30px rgba(244,180,0,.5));
}

/* Center button */
.sw-center{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  z-index:15;border-radius:50%;border:none;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;touch-action:manipulation;
  background:radial-gradient(circle at 38% 32%,#ffe566 0%,#F4B400 45%,#c8930a 75%,#a07000 100%);
  transition:transform .1s,filter .1s,box-shadow .1s;
  -webkit-tap-highlight-color:transparent;
}
.sw-center:active{transform:translate(-50%,-50%) scale(0.91)!important;}
.sw-center:disabled{
  background:radial-gradient(circle,#3a3a3a,#1a1a1a);cursor:not-allowed;
  filter:none!important;
}
.sw-center-icon{line-height:1;display:block;}
.sw-center-label{
  font-weight:900;color:#0a0600;letter-spacing:0.08em;text-transform:uppercase;
  display:block;line-height:1;margin-top:2px;
}
.sw-center:disabled .sw-center-icon,.sw-center:disabled .sw-center-label{opacity:.35;}

/* "Tap to spin" hint ring animation */
.sw-hint-ring{
  position:absolute;top:50%;left:50%;border-radius:50%;
  border:2px solid rgba(244,180,0,0.4);pointer-events:none;z-index:14;
  animation:swHintRing 2s ease-out infinite;
  transform:translate(-50%,-50%) scale(1);
}
@keyframes swHintRing{
  0%{transform:translate(-50%,-50%) scale(1);opacity:.8}
  100%{transform:translate(-50%,-50%) scale(1.9);opacity:0}
}
.sw-hint-ring:nth-child(2){animation-delay:.7s;}

/* Swipe hint */
.sw-swipe-hint{
  position:absolute;bottom:8px;left:0;right:0;
  text-align:center;font-size:10px;color:rgba(255,255,255,.2);
  letter-spacing:0.06em;pointer-events:none;z-index:5;
}

/* ═══════════════════════════════════════════
   BOTTOM SHEET MODAL
═══════════════════════════════════════════ */
.sw-sheet-overlay{
  position:fixed;inset:0;z-index:10000;
  background:rgba(0,0,0,0);pointer-events:none;
  transition:background .35s;
}
.sw-sheet-overlay.show{
  background:rgba(0,0,0,0.75);pointer-events:all;
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
}
.sw-sheet{
  position:absolute;bottom:0;left:0;right:0;
  background:linear-gradient(180deg,#111000 0%,#0a0800 100%);
  border-radius:28px 28px 0 0;
  border-top:1px solid rgba(244,180,0,0.2);
  border-left:1px solid rgba(244,180,0,0.08);
  border-right:1px solid rgba(244,180,0,0.08);
  padding:0 0 env(safe-area-inset-bottom,20px);
  transform:translateY(110%);
  transition:transform .45s cubic-bezier(0.34,1.4,0.64,1);
  box-shadow:0 -20px 80px rgba(0,0,0,.9),0 -4px 30px rgba(244,180,0,.08);
  overflow:hidden;
  max-height:92vh;
  display:flex;flex-direction:column;
}
.sw-sheet-overlay.show .sw-sheet{transform:translateY(0);}

/* Handle bar */
.sw-sheet-handle{
  width:36px;height:4px;border-radius:2px;
  background:rgba(255,255,255,0.15);
  margin:12px auto 0;flex-shrink:0;
}

/* Sheet top glow */
.sw-sheet-glow{
  position:absolute;top:-60px;left:50%;transform:translateX(-50%);
  width:200px;height:120px;border-radius:50%;
  background:radial-gradient(ellipse,rgba(244,180,0,0.25) 0%,transparent 70%);
  pointer-events:none;
}

.sw-sheet-scroll{overflow-y:auto;flex:1;}

/* ── Prize header ── */
.sw-sheet-hero{
  text-align:center;padding:20px 24px 16px;position:relative;
}
.sw-sheet-emoji-wrap{
  width:80px;height:80px;border-radius:24px;
  margin:0 auto 14px;display:flex;align-items:center;justify-content:center;
  font-size:44px;line-height:1;
  position:relative;
}
.sw-sheet-emoji-bg{
  position:absolute;inset:0;border-radius:inherit;
  animation:swEmojiPop .5s .1s cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes swEmojiPop{0%{transform:scale(0.3) rotate(-20deg);opacity:0}100%{transform:scale(1) rotate(0deg);opacity:1}}
.sw-sheet-emoji{position:relative;z-index:1;animation:swEmojiPop .5s .15s cubic-bezier(0.34,1.56,0.64,1) both;}

.sw-sheet-tag{
  font-size:10px;font-weight:800;letter-spacing:0.15em;text-transform:uppercase;
  margin-bottom:5px;
}
.sw-sheet-heading{
  font-size:26px;font-weight:900;letter-spacing:-0.4px;line-height:1.1;
  background:linear-gradient(135deg,#FFD700,#F4B400);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:4px;
}
.sw-sheet-prize{
  font-size:17px;font-weight:800;color:#fff;margin-bottom:4px;
}
.sw-sheet-desc{
  font-size:12px;color:rgba(255,255,255,0.38);line-height:1.55;
}

/* ── Voucher card ── */
.sw-voucher{
  margin:12px 20px;border-radius:20px;overflow:hidden;
  position:relative;
}
.sw-voucher-inner{
  background:linear-gradient(135deg,rgba(244,180,0,0.12),rgba(244,180,0,0.05));
  border:1.5px dashed rgba(244,180,0,0.4);
  border-radius:20px;padding:16px 18px;
  display:flex;align-items:center;gap:12px;
  position:relative;
}
/* Notch effect */
.sw-voucher-inner::before,.sw-voucher-inner::after{
  content:'';position:absolute;width:20px;height:20px;border-radius:50%;
  background:#0a0800;top:50%;transform:translateY(-50%);
}
.sw-voucher-inner::before{left:-10px;}
.sw-voucher-inner::after{right:-10px;}

.sw-voucher-left{flex:1;min-width:0;}
.sw-voucher-label{
  font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;
  color:rgba(244,180,0,0.55);margin-bottom:4px;
}
.sw-voucher-code{
  font-size:24px;font-weight:900;color:#F4B400;
  font-family:'SF Mono',Menlo,monospace;letter-spacing:0.06em;
  line-height:1;
}
.sw-voucher-valid{
  font-size:10px;color:rgba(255,255,255,0.3);margin-top:3px;
}
.sw-copy-btn{
  flex-shrink:0;padding:10px 16px;border-radius:12px;
  background:rgba(244,180,0,0.15);border:1.5px solid rgba(244,180,0,0.3);
  font-size:12px;font-weight:800;color:#F4B400;cursor:pointer;
  transition:all .15s;touch-action:manipulation;white-space:nowrap;
}
.sw-copy-btn.done{
  background:rgba(74,222,128,0.1);border-color:rgba(74,222,128,0.35);color:#4ade80;
}

/* ── Stats row ── */
.sw-stats{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:8px;margin:0 20px 16px;
}
.sw-stat-card{
  background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);
  border-radius:14px;padding:11px 8px;text-align:center;
}
.sw-stat-val{
  font-size:16px;font-weight:900;color:#F4B400;line-height:1;margin-bottom:2px;
}
.sw-stat-lbl{font-size:9px;color:rgba(255,255,255,0.3);font-weight:600;letter-spacing:0.05em;}

/* ── Action buttons ── */
.sw-actions{padding:0 20px 8px;display:flex;flex-direction:column;gap:10px;}
.sw-btn-primary{
  display:flex;align-items:center;justify-content:center;gap:8px;
  padding:16px;border-radius:16px;border:none;
  background:linear-gradient(135deg,#F4B400 0%,#e8a800 100%);
  color:#0a0600;font-size:16px;font-weight:900;cursor:pointer;
  letter-spacing:0.02em;
  box-shadow:0 4px 24px rgba(244,180,0,0.35),0 1px 0 rgba(255,255,255,0.2) inset;
  transition:transform .1s,box-shadow .1s;
  text-decoration:none;touch-action:manipulation;
}
.sw-btn-primary:active{transform:scale(0.97);box-shadow:0 2px 12px rgba(244,180,0,0.2);}
.sw-btn-secondary{
  display:flex;align-items:center;justify-content:center;
  padding:13px;border-radius:14px;border:1px solid rgba(255,255,255,0.1);
  background:rgba(255,255,255,0.04);
  color:rgba(255,255,255,0.45);font-size:13px;font-weight:700;cursor:pointer;
  transition:all .15s;touch-action:manipulation;
  text-decoration:none;
}
.sw-btn-secondary:active{background:rgba(255,255,255,0.08);}

/* ── Win history pill row ── */
.sw-history{
  padding:4px 20px 16px;
}
.sw-history-label{
  font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
  color:rgba(255,255,255,0.2);margin-bottom:8px;
}
.sw-history-row{display:flex;gap:6px;flex-wrap:wrap;}
.sw-history-pill{
  display:flex;align-items:center;gap:4px;
  background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);
  border-radius:99px;padding:4px 10px;
  font-size:10px;color:rgba(255,255,255,0.35);font-weight:600;
}

/* ── Try Again variant ── */
.sw-sheet-overlay.tryagain .sw-sheet{
  background:linear-gradient(180deg,#0d0d0d 0%,#080808 100%);
  border-top-color:rgba(255,255,255,0.08);
}
.sw-sheet-overlay.tryagain .sw-sheet-heading{
  background:linear-gradient(135deg,#aaa,#777);
  -webkit-background-clip:text;background-clip:text;
}
.sw-sheet-overlay.tryagain .sw-btn-primary{
  background:linear-gradient(135deg,#444,#333);color:#fff;
  box-shadow:none;
}

/* ═══════════════════════════════════════════
   CONFETTI
═══════════════════════════════════════════ */
#swConfetti{position:fixed;inset:0;pointer-events:none;z-index:11000;}

/* ═══════════════════════════════════════════
   PREV WINS STRIP (bottom of wheel zone)
═══════════════════════════════════════════ */
.sw-prev-wins{
  display:flex;align-items:center;gap:6px;
  padding:0 16px 8px;flex-shrink:0;
  overflow-x:auto;scrollbar-width:none;position:relative;z-index:5;
}
.sw-prev-wins::-webkit-scrollbar{display:none;}
.sw-prev-label{
  font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
  color:rgba(255,255,255,0.18);white-space:nowrap;flex-shrink:0;
}
.sw-prev-pill{
  display:flex;align-items:center;gap:3px;
  background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);
  border-radius:99px;padding:3px 9px;white-space:nowrap;
  font-size:10px;color:rgba(255,255,255,0.3);font-weight:600;flex-shrink:0;
}
</style>

<!-- Root -->
<div class="sw" id="swRoot">
  <div class="sw-bg"><div class="sw-bg-pulse"></div></div>
  <div id="swStars"></div>

  <!-- Header -->
  <div class="sw-header">
    <div class="sw-header-brand">
      <span class="sw-header-bee">🐝</span>
      <span class="sw-header-name">QuickBee</span>
    </div>
    <span class="sw-header-badge">Spin & Win</span>
  </div>

  <!-- Title -->
  <div class="sw-title-block">
    <div class="sw-title">🎰 Lucky Wheel</div>
    <div class="sw-subtitle">Real prizes · Instant coupon · Delivered to you</div>
    <div class="sw-chip available" id="swChip">
      <span class="sw-chip-dot"></span>
      <span id="swChipText">1 Free Spin Available!</span>
    </div>
  </div>

  <!-- Wheel Zone -->
  <div class="sw-wheel-zone" id="swZone">
    <div class="sw-ring-outer" id="swRingOuter"></div>
    <!-- Pointer -->
    <div class="sw-pointer" id="swPointer">
      <svg width="32" height="42" viewBox="0 0 32 42" fill="none">
        <path d="M16 42 L0 8 Q16 0 32 8 Z" fill="#F4B400"/>
        <path d="M16 36 L5 12 Q16 6 27 12 Z" fill="#FFD700" opacity="0.6"/>
        <circle cx="16" cy="6" r="4" fill="#FFD700"/>
      </svg>
    </div>
    <!-- Canvas -->
    <canvas id="swCanvas" aria-label="Spin the wheel"></canvas>
    <!-- Hint rings -->
    <div class="sw-hint-ring" id="swHintRing1"></div>
    <div class="sw-hint-ring" id="swHintRing2"></div>
    <!-- Center button -->
    <button class="sw-center" id="swBtn" aria-label="Spin">
      <span class="sw-center-icon" id="swBtnIcon">🎰</span>
      <span class="sw-center-label" id="swBtnLabel">SPIN</span>
    </button>
    <div class="sw-swipe-hint">Tap wheel or button to spin</div>
  </div>

  <!-- Previous wins strip -->
  <div class="sw-prev-wins" id="swPrevWins">
    <span class="sw-prev-label">Recent Wins</span>
  </div>
</div>

<!-- Bottom Sheet Modal -->
<div class="sw-sheet-overlay" id="swOverlay">
  <div class="sw-sheet" id="swSheet">
    <div class="sw-sheet-glow" id="swSheetGlow"></div>
    <div class="sw-sheet-handle"></div>
    <div class="sw-sheet-scroll">
      <!-- Hero -->
      <div class="sw-sheet-hero">
        <div class="sw-sheet-emoji-wrap">
          <div class="sw-sheet-emoji-bg" id="swEmojiBg"></div>
          <span class="sw-sheet-emoji" id="swSheetEmoji">🎁</span>
        </div>
        <div class="sw-sheet-tag" id="swSheetTag" style="color:#F4B400">🎉 You Won!</div>
        <div class="sw-sheet-heading" id="swSheetHeading">Congratulations!</div>
        <div class="sw-sheet-prize" id="swSheetPrize">Free Delivery</div>
        <div class="sw-sheet-desc" id="swSheetDesc">Use your code at checkout</div>
      </div>

      <!-- Voucher -->
      <div class="sw-voucher" id="swVoucherWrap">
        <div class="sw-voucher-inner">
          <div class="sw-voucher-left">
            <div class="sw-voucher-label">Your Coupon Code</div>
            <div class="sw-voucher-code" id="swVoucherCode">FREE28</div>
            <div class="sw-voucher-valid">Valid for 24 hours · One use only</div>
          </div>
          <button class="sw-copy-btn" id="swCopyBtn">Copy</button>
        </div>
      </div>

      <!-- Stats -->
      <div class="sw-stats" id="swStats">
        <div class="sw-stat-card">
          <div class="sw-stat-val" id="swStatSpins">1</div>
          <div class="sw-stat-lbl">Total Spins</div>
        </div>
        <div class="sw-stat-card">
          <div class="sw-stat-val" id="swStatWins">0</div>
          <div class="sw-stat-lbl">Wins</div>
        </div>
        <div class="sw-stat-card">
          <div class="sw-stat-val" id="swStatSaved">Rs 0</div>
          <div class="sw-stat-lbl">Saved</div>
        </div>
      </div>

      <!-- Actions -->
      <div class="sw-actions">
        <button class="sw-btn-primary" id="swCtaBtn" type="button">
          <span id="swCtaIcon">🎁</span><span id="swCtaText">Claim Reward &amp; Checkout →</span>
        </button>
        <button class="sw-btn-secondary" id="swCloseBtn">Close</button>
      </div>
      <!-- History in sheet -->
      <div class="sw-history" id="swHistoryBlock" style="display:none">
        <div class="sw-history-label">Your Win History</div>
        <div class="sw-history-row" id="swHistoryRow"></div>
      </div>
    </div>
  </div>
</div>

<!-- Confetti canvas -->
<canvas id="swConfetti"></canvas>

<script>
(function(){
'use strict';

/* ═══════════════════════════════════════════
   PRIZE DATA — 12 segments
═══════════════════════════════════════════ */
var SEG = [
  {
    label:'FREE\nDelivery',emoji:'🎁',
    c1:'#0D5C2E',c2:'#1a8f48',
    code:'FREE28',
    prize:'FREE Delivery',
    desc:'Enter FREE28 at checkout. Free delivery on your next order — any amount, any time!',
    cta:'/collections/all',ctaTxt:'Claim Free Delivery →',
    saved:50,type:'win',wt:12
  },
  {
    label:'Food\n10% Off',emoji:'🍛',
    c1:'#6B1010',c2:'#a82020',
    code:'FOOD10',
    prize:'10% Off All Food',
    desc:'Use FOOD10 for 10% off all food from Typical Taste. Biryani, momos, and more — delivered hot!',
    cta:'/collections/typical-taste',ctaTxt:'Order Food Now →',
    saved:60,type:'win',wt:9
