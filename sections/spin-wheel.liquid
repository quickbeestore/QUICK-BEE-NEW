/* ── DRAW WHEEL — full casino realness ── */
function drawWheel(angle){
  ctx.clearRect(0,0,SIZE,SIZE);
  var slice=(Math.PI*2)/N;

  /* ── Shadow behind entire wheel disk ── */
  ctx.save();
  ctx.beginPath();ctx.arc(CX+3,CY+5,R+2,0,Math.PI*2);
  ctx.fillStyle='rgba(0,0,0,0.7)';ctx.fill();
  ctx.restore();

  /* ── SEGMENTS ── */
  SEG.forEach(function(s,i){
    var a0=angle+slice*i-Math.PI/2;
    var a1=a0+slice;
    var mid=a0+slice/2;

    /* Base fill — radial gradient from dark center to vivid edge */
    ctx.save();
    var grd=ctx.createRadialGradient(CX,CY,CR*0.8,CX,CY,R-8);
    grd.addColorStop(0,s.c2);
    grd.addColorStop(0.55,s.c2);
    grd.addColorStop(1,s.c1);
    ctx.beginPath();ctx.moveTo(CX,CY);ctx.arc(CX,CY,R-10,a0,a1);ctx.closePath();
    ctx.fillStyle=grd;ctx.fill();
    ctx.restore();

    /* Radial sheen — bright wedge near center for felt-table depth */
    ctx.save();
    var sg=ctx.createLinearGradient(
      CX+Math.cos(mid)*CR*0.5, CY+Math.sin(mid)*CR*0.5,
      CX+Math.cos(mid)*R*0.7,  CY+Math.sin(mid)*R*0.7
    );
    sg.addColorStop(0,'rgba(255,255,255,0.18)');
    sg.addColorStop(0.4,'rgba(255,255,255,0.06)');
    sg.addColorStop(1,'rgba(255,255,255,0)');
    ctx.beginPath();ctx.moveTo(CX,CY);ctx.arc(CX,CY,R-10,a0,a1);ctx.closePath();
    ctx.fillStyle=sg;ctx.fill();
    ctx.restore();

    /* Segment highlight arc near outer edge */
    ctx.save();
    ctx.beginPath();ctx.arc(CX,CY,R-11,a0,a1);
    ctx.strokeStyle=s.hl;ctx.lineWidth=R*0.18;ctx.stroke();
    ctx.restore();

    /* Gold separator lines — sharp, opaque */
    ctx.save();ctx.translate(CX,CY);ctx.rotate(a0);
    ctx.beginPath();ctx.moveTo(CR*1.6,0);ctx.lineTo(R-10,0);
    ctx.strokeStyle='rgba(201,168,76,1)';ctx.lineWidth=1.2;
    ctx.shadowColor='rgba(255,215,0,0.6)';ctx.shadowBlur=3;
    ctx.stroke();ctx.shadowBlur=0;
    ctx.restore();

    /* ── TEXT — correct orientation for bottom-half segments ── */
    ctx.save();ctx.translate(CX,CY);ctx.rotate(mid);
    var normMid=((mid%(Math.PI*2))+(Math.PI*2))%(Math.PI*2);
    var flip=normMid>Math.PI/2&&normMid<Math.PI*3/2;
    if(flip)ctx.rotate(Math.PI);
    var dir=flip?-1:1;

    /* Emoji */
    var eSz=Math.max(13,Math.min(R*0.12,19));
    ctx.font=eSz+'px serif';
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.shadowColor='rgba(0,0,0,0.8)';ctx.shadowBlur=4;
    ctx.fillText(s.emoji,dir*R*0.75,0);

    /* Label text */
    var fSz=Math.max(7.5,Math.min(R*0.065,10.5));
    ctx.font='900 '+fSz+'px Lato,-apple-system,sans-serif';
    ctx.fillStyle='#fff';
    ctx.shadowColor='rgba(0,0,0,1)';ctx.shadowBlur=6;ctx.shadowOffsetY=1;
    var lines=s.label.split('\n'),lh=fSz+3;
    lines.forEach(function(ln,li){ctx.fillText(ln,dir*R*0.39,(li-(lines.length-1)/2)*lh);});
    ctx.shadowOffsetY=0;ctx.shadowBlur=0;
    ctx.restore();
  });

  /* ── OUTER RIM — 5-layer metallic gold ── */
  ctx.shadowBlur=0;
  /* Black drop shadow ring */
  ctx.beginPath();ctx.arc(CX,CY,R+1,0,Math.PI*2);
  ctx.strokeStyle='rgba(0,0,0,1)';ctx.lineWidth=14;
  ctx.shadowColor='rgba(0,0,0,1)';ctx.shadowBlur=20;ctx.stroke();ctx.shadowBlur=0;
  /* Darkest gold base — gives depth */
  ctx.beginPath();ctx.arc(CX,CY,R,0,Math.PI*2);
  ctx.strokeStyle='#3D2200';ctx.lineWidth=10;ctx.stroke();
  /* Mid dark gold */
  ctx.beginPath();ctx.arc(CX,CY,R,0,Math.PI*2);
  ctx.strokeStyle='#7A4F00';ctx.lineWidth=7;ctx.stroke();
  /* Rich amber gold */
  ctx.beginPath();ctx.arc(CX,CY,R-0.5,0,Math.PI*2);
  ctx.strokeStyle='#C9A84C';ctx.lineWidth=4.5;
  ctx.shadowColor='rgba(201,168,76,0.5)';ctx.shadowBlur=8;ctx.stroke();ctx.shadowBlur=0;
  /* Bright gold */
  ctx.beginPath();ctx.arc(CX,CY,R-1,0,Math.PI*2);
  ctx.strokeStyle='#FFD700';ctx.lineWidth=2;
  ctx.shadowColor='rgba(255,215,0,0.9)';ctx.shadowBlur=12;ctx.stroke();ctx.shadowBlur=0;
  /* White specular highlight (upper-left arc) */
  ctx.beginPath();ctx.arc(CX,CY,R-1.5,Math.PI*1.1,Math.PI*1.9);
  ctx.strokeStyle='rgba(255,255,240,0.65)';ctx.lineWidth=1;ctx.stroke();
  /* Inner rim line */
  ctx.beginPath();ctx.arc(CX,CY,R-10,0,Math.PI*2);
  ctx.strokeStyle='rgba(201,168,76,0.35)';ctx.lineWidth=0.8;ctx.stroke();

  /* ── GOLD STUDS at every segment boundary ── */
  for(var i=0;i<N;i++){
    var sa=angle+slice*i-Math.PI/2;
    var sx=CX+(R-5)*Math.cos(sa),sy=CY+(R-5)*Math.sin(sa);
    /* Stud shadow */
    ctx.beginPath();ctx.arc(sx+0.5,sy+0.8,3.5,0,Math.PI*2);
    ctx.fillStyle='rgba(0,0,0,0.6)';ctx.fill();
    /* Stud body */
    var sg2=ctx.createRadialGradient(sx-0.8,sy-0.8,0,sx,sy,3.5);
    sg2.addColorStop(0,'#FFFACD');sg2.addColorStop(0.4,'#FFD700');sg2.addColorStop(1,'#8B6914');
    ctx.beginPath();ctx.arc(sx,sy,3.5,0,Math.PI*2);
    ctx.fillStyle=sg2;
    ctx.shadowColor='rgba(255,215,0,0.8)';ctx.shadowBlur=6;
    ctx.fill();ctx.shadowBlur=0;
  }

  /* ── DECORATIVE INNER RING — casino bezel ── */
  ctx.beginPath();ctx.arc(CX,CY,R*0.88,0,Math.PI*2);
  ctx.strokeStyle='rgba(201,168,76,0.15)';ctx.lineWidth=1;ctx.stroke();

  /* ── HUB — deep casino chip ── */
  var hubR=CR+9;
  /* Hub outer shadow */
  ctx.beginPath();ctx.arc(CX+2,CY+3,hubR,0,Math.PI*2);
  ctx.fillStyle='rgba(0,0,0,0.7)';ctx.fill();
  /* Hub felt-green base */
  var hfg=ctx.createRadialGradient(CX-hubR*0.2,CY-hubR*0.25,0,CX,CY,hubR);
  hfg.addColorStop(0,'#1a3a20');hfg.addColorStop(0.6,'#0d2010');hfg.addColorStop(1,'#050a08');
  ctx.beginPath();ctx.arc(CX,CY,hubR,0,Math.PI*2);ctx.fillStyle=hfg;ctx.fill();
  /* Hub gold ring — outer bright */
  ctx.beginPath();ctx.arc(CX,CY,hubR,0,Math.PI*2);
  ctx.strokeStyle='#C9A84C';ctx.lineWidth=2.5;
  ctx.shadowColor='rgba(255,215,0,0.9)';ctx.shadowBlur=12;ctx.stroke();ctx.shadowBlur=0;
  /* Hub gold ring — edge highlight */
  ctx.beginPath();ctx.arc(CX,CY,hubR,0,Math.PI*2);
  ctx.strokeStyle='rgba(255,240,160,0.4)';ctx.lineWidth=1;ctx.stroke();
  /* Hub inner accent ring */
  ctx.beginPath();ctx.arc(CX,CY,hubR-5,0,Math.PI*2);
  ctx.strokeStyle='rgba(201,168,76,0.2)';ctx.lineWidth=0.8;ctx.stroke();
  /* Hub center dot */
  var hdg=ctx.createRadialGradient(CX-2,CY-2,0,CX,CY,6);
  hdg.addColorStop(0,'#FFFACD');hdg.addColorStop(0.5,'#FFD700');hdg.addColorStop(1,'#8B6914');
  ctx.beginPath();ctx.arc(CX,CY,6,0,Math.PI*2);
  ctx.fillStyle=hdg;ctx.shadowColor='rgba(255,215,0,0.8)';ctx.shadowBlur=8;ctx.fill();ctx.shadowBlur=0;
}

/* ── IDLE ── */
function idleRotate(){currentAngle+=0.00025;drawWheel(currentAngle);idleRAF=requestAnimationFrame(idleRotate);}

/* ── EASE ── */
function easeOut(t){return 1-Math.pow(1-t,4);}

/* ── ANIM ── */
function animSpin(ts){
  if(!spinStart)spinStart=ts;
  var p=Math.min((ts-spinStart)/DURATION,1);
  currentAngle=spinFrom+(spinTarget-spinFrom)*easeOut(p);
  drawWheel(currentAngle);
  var slice=(Math.PI*2)/N;
  var norm=((currentAngle%(Math.PI*2))+(Math.PI*2))%(Math.PI*2);
  var seg=Math.floor(norm/slice)%N;
  if(seg!==lastTickSeg){
    var spd=1-p;
    if(spd>0.06)playTick(500+spd*600,0.05+spd*0.04);
    try{if(navigator.vibrate&&spd>0.4)navigator.vibrate(6);}catch(e){}
    lastTickSeg=seg;
  }
  if(p<1){requestAnimationFrame(animSpin);}else{onSpinEnd();}
}

/* ── SPIN ── */
function spin(){
  if(isSpinning)return;
  var used=getUsed();
  if(used>=MAX)return;
  getAC();
  if(idleRAF){cancelAnimationFrame(idleRAF);idleRAF=null;}
  isSpinning=true;btn.disabled=true;
  zone.classList.add('spinning');
  hint1.style.display='none';hint2.style.display='none';
  document.getElementById('lwBtnIcon').textContent='🌀';
  document.getElementById('lwBtnLabel').textContent='GO!';
  spinStart=null;spinFrom=currentAngle;
  winIdx=pickSeg();
  var slice=(Math.PI*2)/N;
  var segMid=slice*winIdx+slice/2;
  var target=(((-Math.PI/2-segMid)%(Math.PI*2))+(Math.PI*2))%(Math.PI*2);
  var spins=7+Math.floor(Math.random()*4);
  spinTarget=spinFrom-(spinFrom%(Math.PI*2))+Math.PI*2*spins+target;
  if(spinTarget-spinFrom<Math.PI*2*5)spinTarget+=Math.PI*2*5;
  requestAnimationFrame(animSpin);
}

/* ── SPIN END ── */
function onSpinEnd(){
  isSpinning=false;zone.classList.remove('spinning');
  var s=SEG[winIdx];currentSeg=s;
  var used=getUsed();
  setUsed(used+1);addHist(s);addTodayWin(s);updateUI();updateRecent();
  try{if(navigator.vibrate)navigator.vibrate(s.type==='win'?[60,40,100,40,150]:[120,60,120]);}catch(e){}
  if(s.type==='win'){playWin();launchConfetti();}else{playLose();}
  var left=MAX-(used+1);
  if(left>0){
    document.getElementById('lwBtnIcon').textContent='🎰';
    document.getElementById('lwBtnLabel').textContent='SPIN';
    btn.disabled=false;
    if(!idleRAF)idleRotate();
    hint1.style.display='';hint2.style.display='';
  }
  showSheet(s,left);
  if(left===0){setTimeout(function(){if(!overlay.classList.contains('show'))showTimer();},500);}
}

