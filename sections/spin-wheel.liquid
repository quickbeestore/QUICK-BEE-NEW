/* ── CONFETTI — gold casino chips ── */
var particles=[];
function launchConfetti(){
  particles=[];
  var colors=['#FFD700','#C9A84C','#FFF0A0','#FF2222','#22BB44','#2255DD','#fff','#FF8800'];
  for(var i=0;i<200;i++){
    particles.push({
      x:Math.random()*confEl.width,y:-20,
      vx:(Math.random()-0.5)*9,vy:Math.random()*6+2,
      r:Math.random()*6+2,
      color:colors[Math.floor(Math.random()*colors.length)],
      rot:Math.random()*360,vrot:(Math.random()-0.5)*12,
      life:1,shape:Math.random()>0.4?'rect':'circle'
    });
  }
  animConf();
}
function animConf(){
  cctx.clearRect(0,0,confEl.width,confEl.height);
  var alive=false;
  particles.forEach(function(p){
    p.x+=p.vx;p.y+=p.vy;p.vy+=0.14;p.rot+=p.vrot;p.life-=0.012;
    if(p.life<=0||p.y>confEl.height+20)return;
    alive=true;
    cctx.save();cctx.globalAlpha=Math.min(p.life,1);
    cctx.translate(p.x,p.y);cctx.rotate(p.rot*Math.PI/180);
    cctx.fillStyle=p.color;
    if(p.shape==='circle'){cctx.beginPath();cctx.arc(0,0,p.r,0,Math.PI*2);cctx.fill();}
    else{cctx.fillRect(-p.r,-p.r/2,p.r*2,p.r);}
    cctx.restore();
  });
  if(alive)requestAnimationFrame(animConf);
  else cctx.clearRect(0,0,confEl.width,confEl.height);
}

/* ── RECENT ── */
function updateRecent(){
  var h=getHist(),pills=document.getElementById('lwRecentPills');
  pills.innerHTML='';
  h.slice(0,4).forEach(function(item){
    var p=document.createElement('span');p.className='lw-recent-pill';
    p.textContent=item.emoji+' '+item.prize;pills.appendChild(p);
  });
}

/* ── GOLD DUST PARTICLES ── */
(function(){
  var root=document.getElementById('lwRoot');
  for(var i=0;i<30;i++){
    var s=document.createElement('div');s.className='lw-dust';
    var sz=(Math.random()*2+0.5).toFixed(1);
    s.style.cssText='width:'+sz+'px;height:'+sz+'px;top:'+Math.random()*100+'%;left:'+Math.random()*100+'%;--d:'+(4+Math.random()*8).toFixed(1)+'s;--dl:'+(Math.random()*8).toFixed(1)+'s;opacity:0;';
    root.appendChild(s);
  }
})();

/* ── EVENTS ── */
btn.addEventListener('click',spin,{passive:true});
canvas.addEventListener('click',spin,{passive:true});
var swY=0;
canvas.addEventListener('touchstart',function(e){swY=e.touches[0].clientY;},{passive:true});
canvas.addEventListener('touchend',function(e){if(Math.abs(swY-e.changedTouches[0].clientY)>25)spin();},{passive:true});
document.getElementById('lwCloseBtn').addEventListener('click',closeSheet);
overlay.addEventListener('click',function(e){if(e.target===overlay)closeSheet();});

/* ── COUNTDOWN TIMER ── */
var timerInterval=null;
function pad(n){return n<10?'0'+n:String(n);}
function getMidnightMs(){var now=new Date();return new Date(now.getFullYear(),now.getMonth(),now.getDate()+1,0,0,0,0)-now;}
function updateTimerDisplay(){
  var ms=getMidnightMs();
  if(ms<=0){clearInterval(timerInterval);hideTimer();updateUI();if(!idleRAF)idleRotate();return;}
  var totalSecs=Math.floor(ms/1000);
  document.getElementById('lwTimerH').textContent=pad(Math.floor(totalSecs/3600));
  document.getElementById('lwTimerM').textContent=pad(Math.floor((totalSecs%3600)/60));
  document.getElementById('lwTimerS').textContent=pad(totalSecs%60);
  var dayMs=24*60*60*1000;
  var pct=(dayMs-ms)/dayMs;
  var circumference=201.1;
  document.getElementById('lwProgressRing').style.strokeDashoffset=circumference*(1-pct);
}
function showTimer(){
  var wins=getTodayWins();
  var winsBlock=document.getElementById('lwTimerWins');
  var winsList=document.getElementById('lwTimerWinsList');
  if(wins.length){
    winsList.innerHTML='';
    wins.forEach(function(w){
      var row=document.createElement('div');row.className='lw-timer-win-row';
      row.innerHTML='<div class="lw-timer-win-emoji">'+w.emoji+'</div><div class="lw-timer-win-info"><div class="lw-timer-win-prize">'+w.prize+'</div><div class="lw-timer-win-code">'+w.code+'</div></div>';
      winsList.appendChild(row);
    });
    winsBlock.style.display='block';
    var msg=buildWAMsg(null);
    document.getElementById('lwTimerWa').href='https://wa.me/'+WA+'?text='+encodeURIComponent(msg);
    document.getElementById('lwTimerWaTxt').textContent=wins.length>1?'🎁 Claim All '+wins.length+' Prizes on WhatsApp':'🎁 Claim Prize on WhatsApp';
  }else{
    winsBlock.style.display='none';
    document.getElementById('lwTimerWaTxt').textContent='💬 Order on WhatsApp While You Wait';
  }
  updateTimerDisplay();
  document.getElementById('lwTimer').classList.add('show');
  timerInterval=setInterval(updateTimerDisplay,1000);
  try{if(navigator.vibrate)navigator.vibrate([30]);}catch(e){}
}
function hideTimer(){
  document.getElementById('lwTimer').classList.remove('show');
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
}

/* ── INIT ── */
resize();
idleRotate();
updateUI();
updateRecent();
window.addEventListener('resize',resize,{passive:true});
if(getUsed()>=MAX){showTimer();}

})();
</script>

