<style>
  :root {
    --sw-gold: #D4AF37;
    --sw-dark-gold: #B8860B;
    --sw-black: #1A1A1A;
    --sw-dark-gray: #222222;
    --sw-wheel-size: clamp(320px, 90vmin, 550px);
    --sw-segments: 8;
    --sw-segment-angle: calc(360deg / var(--sw-segments));
  }

  /* --- Base Setup & Full-Screen Container --- */
  .spin-wheel-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: var(--sw-black);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    overflow: hidden;
    z-index: 100;
  }
  
  /* Hide theme header/footer for a truly full-screen experience */
  #shopify-section-header, 
  #shopify-section-footer,
  .shopify-section-header,
  .shopify-section-footer {
    display: none !important;
  }
  body {
    overflow: hidden !important;
  }

  /* --- Wheel Wrapper & Pointer --- */
  .sw-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sw-pointer {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 20px solid transparent;
    border-right: 20px solid transparent;
    border-top: 30px solid var(--sw-gold);
    z-index: 10;
    filter: drop-shadow(0px 2px 3px rgba(0,0,0,0.5));
  }

  /* --- The Wheel --- */
  .sw-wheel {
    width: var(--sw-wheel-size);
    height: var(--sw-wheel-size);
    position: relative;
    border-radius: 50%;
    border: 10px solid var(--sw-gold);
    box-shadow: 0 0 25px rgba(0,0,0,0.7), inset 0 0 20px rgba(0,0,0,0.5);
    background: conic-gradient(
      from 0deg,
      var(--sw-dark-gray) 0deg var(--sw-segment-angle),
      var(--sw-black) var(--sw-segment-angle) calc(var(--sw-segment-angle) * 2),
      var(--sw-dark-gray) calc(var(--sw-segment-angle) * 2) calc(var(--sw-segment-angle) * 3),
      var(--sw-black) calc(var(--sw-segment-angle) * 3) calc(var(--sw-segment-angle) * 4),
      var(--sw-dark-gray) calc(var(--sw-segment-angle) * 4) calc(var(--sw-segment-angle) * 5),
      var(--sw-black) calc(var(--sw-segment-angle) * 5) calc(var(--sw-segment-angle) * 6),
      var(--sw-dark-gray) calc(var(--sw-segment-angle) * 6) calc(var(--sw-segment-angle) * 7),
      var(--sw-black) calc(var(--sw-segment-angle) * 7) calc(var(--sw-segment-angle) * 8)
    );
    transition: transform 6s cubic-bezier(0.1, 0.7, 0.3, 1);
  }

  /* --- Segments & Text --- */
  .sw-segment {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
  }

  .sw-segment-label {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    color: #fff;
    font-weight: bold;
    font-size: clamp(12px, 3.5vmin, 18px);
    text-align: center;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.7);
    max-width: 80%;
    word-wrap: break-word;
  }

  /* --- Spin Button --- */
  .sw-spin-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 20%;
    height: 20%;
    border-radius: 50%;
    background: var(--sw-dark-gold);
    border: 5px solid var(--sw-gold);
    color: white;
    font-weight: bold;
    font-size: clamp(16px, 5vmin, 28px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    z-index: 5;
    transition: background-color 0.2s, transform 0.2s;
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.5), inset 0 0 10px rgba(0,0,0,0.5);
  }

  .sw-spin-btn:hover:not(:disabled) {
    background: var(--sw-gold);
  }
  
  .sw-spin-btn:active:not(:disabled) {
    transform: translate(-50%, -50%) scale(0.95);
  }

  .sw-spin-btn:disabled {
    cursor: not-allowed;
    background: #555;
    color: #999;
    border-color: #777;
    box-shadow: none;
  }
  
  .sw-wheel.spinning {
      transition-timing-function: cubic-bezier(0.2, 0.8, 0.7, 1);
  }

  /* --- Result Modal --- */
  .sw-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 101;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
  }

  .sw-modal-overlay.visible {
    opacity: 1;
    visibility: visible;
  }
  
  .sw-modal-content {
    background: var(--sw-black);
    border: 3px solid var(--sw-gold);
    border-radius: 10px;
    padding: 40px;
    text-align: center;
    box-shadow: 0 0 30px rgba(212, 175, 55, 0.3);
    transform: scale(0.8);
    transition: transform 0.3s ease-out;
  }

  .sw-modal-overlay.visible .sw-modal-content {
    transform: scale(1);
  }

  .sw-modal-content h2 {
    color: var(--sw-gold);
    font-size: 2em;
    margin: 0 0 10px 0;
  }

  .sw-modal-content p {
    font-size: 1.2em;
    margin: 0 0 25px 0;
  }

  .sw-modal-close-btn {
    background: var(--sw-gold);
    border: none;
    color: var(--sw-black);
    padding: 10px 25px;
    border-radius: 5px;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .sw-modal-close-btn:hover {
    background: var(--sw-dark-gold);
  }
</style>

<div class="spin-wheel-container">
  <div class="sw-wrapper">
    <div class="sw-pointer"></div>
    <div class="sw-wheel" id="spin-wheel">
      <!-- Segments will be populated by JavaScript -->
    </div>
    <button class="sw-spin-btn" id="spin-button">SPIN</button>
  </div>
</div>

<div class="sw-modal-overlay" id="result-modal">
  <div class="sw-modal-content">
    <h2 id="modal-title">Congratulations!</h2>
    <p>You won: <strong id="modal-prize"></strong></p>
    <button class="sw-modal-close-btn" id="modal-close-button">Claim Prize</button>
  </div>
</div>


<script>
document.addEventListener('DOMContentLoaded', () => {
  const wheel = document.getElementById('spin-wheel');
  const spinBtn = document.getElementById('spin-button');
  const resultModal = document.getElementById('result-modal');
  const modalPrize = document.getElementById('modal-prize');
  const modalTitle = document.getElementById('modal-title');
  const modalCloseBtn = document.getElementById('modal-close-button');

  const rewards = [
    "Free Delivery",
    "Biryani",
    "Leg Piece x2",
    "Tuborg 650ml",
    "Gorkha 650ml",
    "JD Shot",
    "Jager Shot",
    "Try Again"
  ];
  
  const numSegments = rewards.length;
  const segmentAngle = 360 / numSegments;
  let currentRotation = 0;
  let isSpinning = false;

  // --- Populate Wheel Segments ---
  rewards.forEach((reward, i) => {
    const angle = segmentAngle * i;
    const segment = document.createElement('div');
    segment.className = 'sw-segment';
    
    const label = document.createElement('span');
    label.className = 'sw-segment-label';
    label.textContent = reward;
    
    // Rotate the segment container and the text inside
    const rotation = `rotate(${angle + segmentAngle / 2}deg)`;
    segment.style.transform = rotation;
    
    segment.appendChild(label);
    wheel.appendChild(segment);
  });

  // --- Spin Logic ---
  spinBtn.addEventListener('click', () => {
    if (isSpinning) return;
    isSpinning = true;
    spinBtn.disabled = true;
    wheel.classList.add('spinning');

    // Calculate a new random rotation
    // Add multiple full spins for visual effect + random final position
    const randomDegrees = Math.random() * 360;
    const fullSpins = 5;
    const spinAmount = (fullSpins * 360) + randomDegrees;
    currentRotation += spinAmount;

    wheel.style.transform = `rotate(${currentRotation}deg)`;
  });

  // --- Handle End of Spin ---
  wheel.addEventListener('transitionend', () => {
    isSpinning = false;
    spinBtn.disabled = false;
    wheel.classList.remove('spinning');

    const finalAngle = currentRotation % 360;
    // We align the pointer at the top (0deg), so we need to find what segment lands there
    const normalizedAngle = (360 - finalAngle) % 360;
    const winningIndex = Math.floor(normalizedAngle / segmentAngle);
    const prize = rewards[winningIndex];

    showResult(prize);
  });
  
  // --- Modal Logic ---
  function showResult(prize) {
    modalPrize.textContent = prize;
    if (prize === "Try Again") {
      modalTitle.textContent = "Better Luck Next Time!";
    } else {
      modalTitle.textContent = "Congratulations!";
    }
    resultModal.classList.add('visible');
  }

  modalCloseBtn.addEventListener('click', () => {
    resultModal.classList.remove('visible');
  });

  resultModal.addEventListener('click', (e) => {
    if (e.target === resultModal) {
      resultModal.classList.remove('visible');
    }
  });
});
</script>

{% schema %}
{
  "name": "Spin Wheel",
  "settings": []
}
{% endschema %}
