{% comment %} Aila Madira — Lucky Wheel NEON EDITION 2026 {% endcomment %}
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{overflow:hidden!important;height:100%;background:#050008!important;touch-action:none;}
#shopify-section-header,.site-header,header[class*="header"],
#shopify-section-footer,.site-footer,footer[class*="footer"],
.qb-ticker,.qb-trust-bar,#qbsc-root,.qb-timebox,
[class*="announcement"],[id*="announcement"]{display:none!important;}

:root{
  --neon:#00f5ff;--neon2:#7b2fff;--neon3:#ff2d78;
  --gold:#F4B400;--gold2:#FFD700;
  --wa:#25D366;--wa2:#128C7E;
  --bg:#050008;--bg2:#0a000f;
  --card:rgba(255,255,255,0.04);
  --border:rgba(255,255,255,0.07);
}

/* ── FONTS ── */
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&display=swap');

/* ── ROOT ── */
.lw{
  position:fixed;inset:0;
  background:var(--bg);
  display:flex;flex-direction:column;align-items:center;
  font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display','Segoe UI',sans-serif;
  z-index:9999;overflow:hidden;
  user-select:none;-webkit-user-select:none;
}

/* ── ANIMATED BG ── */
.lw-bg{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.lw-bg-mesh{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 90% 50% at 50% -5%,rgba(0,245,255,0.07) 0%,transparent 60%),
    radial-gradient(ellipse 70% 40% at 20% 80%,rgba(123,47,255,0.08) 0%,transparent 55%),
    radial-gradient(ellipse 60% 40% at 80% 70%,rgba(255,45,120,0.06) 0%,transparent 50%),
    #050008;
}
.lw-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(0,245,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,245,255,0.025) 1px,transparent 1px);
  background-size:40px 40px;
  animation:gridMove 20s linear infinite;
}
@keyframes gridMove{0%{background-position:0 0}100%{background-position:40px 40px}}
.lw-orb{position:absolute;border-radius:50%;filter:blur(80px);pointer-events:none;}
.lw-orb1{width:350px;height:350px;top:-100px;left:-80px;background:rgba(0,245,255,0.06);animation:orbA 12s ease-in-out infinite;}
.lw-orb2{width:250px;height:250px;bottom:-60px;right:-60px;background:rgba(123,47,255,0.08);animation:orbB 15s ease-in-out infinite;}
.lw-orb3{width:180px;height:180px;top:40%;left:60%;background:rgba(255,45,120,0.05);animation:orbC 10s ease-in-out infinite;}
@keyframes orbA{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(40px,30px) scale(1.1)}}
@keyframes orbB{0%,100%{transform:translate(0,0)}50%{transform:translate(-30px,-40px)}}
@keyframes orbC{0%,100%{transform:translate(0,0)}50%{transform:translate(-20px,20px)}}

/* Stars */
.lw-star{position:absolute;border-radius:50%;pointer-events:none;animation:twk var(--d) var(--dl) ease-in-out infinite alternate;}
@keyframes twk{0%{opacity:.02}100%{opacity:.6}}

/* ── HEADER ── */
.lw-header{
  width:100%;padding:calc(env(safe-area-inset-top,0px) + 10px) 18px 0;
  display:flex;align-items:center;justify-content:space-between;
  position:relative;z-index:5;flex-shrink:0;
}
.lw-brand{display:flex;align-items:center;gap:9px;}
.lw-brand-icon{
  width:36px;height:36px;border-radius:12px;
  background:linear-gradient(135deg,#1a0030,#2d0055);
  border:1px solid rgba(123,47,255,0.4);
  display:flex;align-items:center;justify-content:center;
  font-size:19px;
  box-shadow:0 0 12px rgba(123,47,255,0.3),inset 0 1px 0 rgba(255,255,255,0.1);
}
.lw-brand-name{
  font-family:'Orbitron',sans-serif;
  font-size:14px;font-weight:900;letter-spacing:0.05em;
  background:linear-gradient(135deg,#fff 0%,var(--neon) 60%,var(--neon2) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  text-shadow:none;
}
.lw-brand-sub{font-size:9px;color:rgba(255,255,255,0.25);letter-spacing:0.12em;text-transform:uppercase;display:block;margin-top:-1px;}
.lw-spin-badge{
  display:flex;align-items:center;gap:5px;
  background:rgba(0,245,255,0.06);
  border:1px solid rgba(0,245,255,0.2);
  border-radius:99px;padding:5px 11px;
}
.lw-spin-badge-dot{
  width:6px;height:6px;border-radius:50%;background:var(--neon);
  box-shadow:0 0 6px var(--neon);
  animation:badgePulse 1.2s ease infinite;
}
@keyframes badgePulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}
.lw-spin-badge-txt{font-size:11px;font-weight:800;color:var(--neon);letter-spacing:0.03em;}

/* ── HERO ── */
.lw-hero{
  text-align:center;padding:8px 20px 4px;
  position:relative;z-index:5;flex-shrink:0;
}
.lw-hero-title{
  font-family:'Orbitron',sans-serif;
  font-size:clamp(18px,4.5vw,26px);font-weight:900;letter-spacing:0.02em;line-height:1.1;
  color:#fff;
}
.lw-hero-title em{
  font-style:normal;
  background:linear-gradient(90deg,var(--neon),var(--neon2),var(--neon3));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation:titleShift 4s ease-in-out infinite;
}
@keyframes titleShift{0%,100%{filter:hue-rotate(0deg)}50%{filter:hue-rotate(30deg)}}
.lw-hero-sub{font-size:11px;color:rgba(255,255,255,0.3);margin-top:4px;letter-spacing:0.05em;}

/* Spin dots */
.lw-dots{display:flex;align-items:center;justify-content:center;gap:7px;margin-top:8px;}
.lw-dot{
  width:10px;height:10px;border-radius:50%;
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.1);
  transition:all .3s;position:relative;
}
.lw-dot.used{
  background:var(--neon2);border-color:var(--neon2);
  box-shadow:0 0 8px rgba(123,47,255,0.7);
}
.lw-dot.active{
  background:var(--neon);border-color:var(--neon);
  box-shadow:0 0 12px var(--neon),0 0 24px rgba(0,245,255,0.4);
  animation:activeDot .9s ease infinite;
}
@keyframes activeDot{0%,100%{transform:scale(1)}50%{transform:scale(1.5)}}

/* ── WHEEL ZONE ── */
.lw-wheel-zone{
  flex:1;display:flex;align-items:center;justify-content:center;
  position:relative;width:100%;min-height:0;padding:0;
}
.lw-aura{
  position:absolute;border-radius:50%;pointer-events:none;
  animation:auraPulse 2.5s ease-in-out infinite;
}
@keyframes auraPulse{0%,100%{opacity:.4;transform:scale(1)}50%{opacity:.8;transform:scale(1.02)}}
.lw-pointer{
  position:absolute;z-index:20;pointer-events:none;
  top:0;left:50%;transform:translateX(-50%) translateY(-3px);
  filter:drop-shadow(0 0 10px var(--neon)) drop-shadow(0 2px 8px rgba(0,0,0,1));
}
#lwCanvas{
  display:block;border-radius:50%;position:relative;z-index:3;
  touch-action:none;cursor:pointer;
  transition:filter .3s;
}
.lw-wheel-zone.spinning #lwCanvas{
  filter:drop-shadow(0 0 30px rgba(0,245,255,0.4)) drop-shadow(0 0 60px rgba(123,47,255,0.2));
}

/* Center spin button */
.lw-spin-btn{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  z-index:15;border-radius:50%;border:none;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;touch-action:manipulation;
  background:radial-gradient(circle at 35% 30%,#2a0050 0%,#160030 50%,#0a001a 100%);
  transition:transform .12s,filter .12s;
  -webkit-tap-highlight-color:transparent;
  overflow:hidden;
}
.lw-spin-btn::before{
  content:'';position:absolute;inset:0;border-radius:50%;
  border:2px solid transparent;
  background:linear-gradient(135deg,var(--neon),var(--neon2),var(--neon3),var(--neon)) border-box;
  -webkit-mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);
  -webkit-mask-composite:destination-out;mask-composite:exclude;
  animation:btnBorder 3s linear infinite;
}
@keyframes btnBorder{0%{filter:hue-rotate(0deg)}100%{filter:hue-rotate(360deg)}}
.lw-spin-btn::after{
  content:'';position:absolute;inset:-2px;border-radius:50%;
  background:conic-gradient(transparent 300deg,rgba(0,245,255,0.3) 360deg);
  animation:spinRing 1s linear infinite;
  opacity:0;transition:opacity .3s;
}
.lw-wheel-zone.spinning .lw-spin-btn::after{opacity:1;}
@keyframes spinRing{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
.lw-spin-btn:active{transform:translate(-50%,-50%) scale(0.88)!important;}
.lw-spin-btn:disabled{cursor:not-allowed;}
.lw-spin-btn:disabled::before{animation:none;border-color:rgba(255,255,255,0.1);}
.lw-btn-inner{display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;z-index:1;}
.lw-btn-icon{line-height:1;display:block;transition:transform .3s;}
.lw-btn-label{
  font-family:'Orbitron',sans-serif;
  font-weight:900;color:#fff;letter-spacing:0.12em;text-transform:uppercase;
  display:block;line-height:1;margin-top:3px;
  text-shadow:0 0 10px var(--neon);
}
.lw-spin-btn:disabled .lw-btn-label{color:rgba(255,255,255,0.2);text-shadow:none;}
.lw-spin-btn:disabled .lw-btn-icon{opacity:.2;}

/* Hint rings */
.lw-hint-ring{
  position:absolute;top:50%;left:50%;border-radius:50%;
  border:1.5px solid rgba(0,245,255,0.3);pointer-events:none;z-index:14;
  animation:hintRing 2.2s ease-out infinite;
}
@keyframes hintRing{0%{transform:translate(-50%,-50%) scale(1);opacity:.7}100%{transform:translate(-50%,-50%) scale(2.2);opacity:0}}
.lw-hint-ring:nth-child(2){animation-delay:.9s;}

/* ── WA BAR ── */
.lw-wa-bar{
  width:100%;padding:8px 16px;
  padding-bottom:calc(env(safe-area-inset-bottom,0px)+8px);
  flex-shrink:0;position:relative;z-index:5;
}
.lw-wa-btn{
  display:flex;align-items:center;justify-content:center;gap:10px;
  width:100%;padding:14px 20px;border-radius:18px;border:none;
  background:linear-gradient(135deg,#25D366 0%,#128C7E 100%);
  color:#fff;font-size:14px;font-weight:900;cursor:pointer;
  text-decoration:none;touch-action:manipulation;
  box-shadow:0 4px 24px rgba(37,211,102,0.3),0 0 0 1px rgba(255,255,255,0.1) inset;
  letter-spacing:0.02em;transition:transform .1s,box-shadow .1s;
  position:relative;overflow:hidden;
}
.lw-wa-btn::before{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);animation:waSheen 3s ease-in-out infinite;}
@keyframes waSheen{0%{left:-100%}50%,100%{left:150%}}
.lw-wa-btn:active{transform:scale(0.97);}
.lw-wa-icon{width:26px;height:26px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.lw-wa-icon svg{width:16px;height:16px;}
.lw-wa-texts{display:flex;flex-direction:column;align-items:flex-start;}
.lw-wa-main{font-size:14px;font-weight:900;line-height:1.1;}
.lw-wa-mini{font-size:10px;font-weight:600;opacity:0.75;letter-spacing:0.04em;}

/* ── BOTTOM SHEET ── */
.lw-overlay{
  position:fixed;inset:0;z-index:10000;
  background:rgba(0,0,0,0);pointer-events:none;
  transition:background .35s;
}
.lw-overlay.show{
  background:rgba(0,0,0,0.88);pointer-events:all;
  backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
}
.lw-sheet{
  position:absolute;bottom:0;left:0;right:0;
  background:linear-gradient(180deg,#0d0020 0%,#060010 100%);
  border-radius:28px 28px 0 0;
  border-top:1px solid rgba(123,47,255,0.3);
  border-left:1px solid rgba(123,47,255,0.08);
  border-right:1px solid rgba(123,47,255,0.08);
  padding:0 0 env(safe-area-inset-bottom,20px);
  transform:translateY(110%);
  transition:transform .5s cubic-bezier(0.34,1.4,0.64,1);
  box-shadow:0 -20px 80px rgba(0,0,0,.98),0 -4px 40px rgba(123,47,255,.15);
  overflow:hidden;max-height:90vh;display:flex;flex-direction:column;
}
.lw-overlay.show .lw-sheet{transform:translateY(0);}
.lw-sheet-handle{width:40px;height:4px;border-radius:2px;background:rgba(255,255,255,0.1);margin:14px auto 0;flex-shrink:0;}
.lw-sheet-scroll{overflow-y:auto;flex:1;}

/* Neon top line on sheet */
.lw-sheet-neon-line{
  height:1px;width:100%;
  background:linear-gradient(90deg,transparent,var(--neon2),var(--neon),var(--neon2),transparent);
  animation:neonLine 3s ease-in-out infinite;
  flex-shrink:0;
}
@keyframes neonLine{0%,100%{opacity:.4}50%{opacity:.9}}

/* Sheet hero */
.lw-sheet-hero{text-align:center;padding:18px 24px 12px;position:relative;}
.lw-sheet-glow{position:absolute;top:-50px;left:50%;transform:translateX(-50%);width:200px;height:120px;border-radius:50%;pointer-events:none;}
.lw-prize-wrap{
  width:82px;height:82px;border-radius:24px;
  margin:0 auto 14px;display:flex;align-items:center;justify-content:center;
  font-size:42px;position:relative;
}
.lw-prize-bg{
  position:absolute;inset:0;border-radius:inherit;
  animation:prizeIn .55s .1s cubic-bezier(0.34,1.6,0.64,1) both;
}
@keyframes prizeIn{0%{transform:scale(0.1) rotate(-20deg);opacity:0}100%{transform:scale(1) rotate(0);opacity:1}}
.lw-prize-em{position:relative;z-index:1;animation:prizeIn .55s .15s cubic-bezier(0.34,1.6,0.64,1) both;display:block;}
.lw-sheet-status{font-size:10px;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:5px;}
.lw-sheet-heading{
  font-family:'Orbitron',sans-serif;
  font-size:20px;font-weight:900;color:#fff;letter-spacing:0.02em;margin-bottom:4px;
}
.lw-sheet-prize{font-size:14px;font-weight:700;color:var(--neon);margin-bottom:6px;}
.lw-sheet-desc{font-size:12px;color:rgba(255,255,255,0.35);line-height:1.55;padding:0 8px;}

/* Code card */
.lw-code-card{
  margin:12px 18px;padding:14px 16px;
  background:linear-gradient(135deg,rgba(0,245,255,0.05),rgba(123,47,255,0.05));
  border:1px solid rgba(0,245,255,0.18);border-radius:18px;
  position:relative;overflow:hidden;
}
.lw-code-card::before{
  content:'';position:absolute;top:-1px;left:10%;right:10%;height:1px;
  background:linear-gradient(90deg,transparent,var(--neon),transparent);
}
.lw-code-inner{display:flex;align-items:center;justify-content:space-between;gap:12px;}
.lw-code-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.25);margin-bottom:4px;}
.lw-code-val{
  font-family:'Orbitron',sans-serif;
  font-size:18px;font-weight:900;color:var(--neon);letter-spacing:0.1em;
  text-shadow:0 0 10px rgba(0,245,255,0.4);
}
.lw-code-exp{font-size:9px;color:rgba(255,255,255,0.2);margin-top:3px;}
.lw-copy-btn{
  padding:9px 14px;border-radius:10px;
  border:1px solid rgba(0,245,255,0.25);
  background:rgba(0,245,255,0.07);
  color:var(--neon);font-size:12px;font-weight:800;cursor:pointer;
  white-space:nowrap;transition:all .15s;flex-shrink:0;
  font-family:'Orbitron',sans-serif;letter-spacing:0.05em;
}
.lw-copy-btn.copied{background:rgba(37,211,102,0.12);border-color:rgba(37,211,102,0.35);color:#4ade80;}

/* Screenshot hint */
.lw-screenshot{
  margin:0 18px 12px;padding:10px 14px;
  background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);
  border-radius:14px;display:flex;align-items:center;gap:10px;
}
.lw-screenshot-icon{font-size:24px;flex-shrink:0;}
.lw-screenshot-txt{font-size:11px;color:rgba(255,255,255,0.35);line-height:1.45;}
.lw-screenshot-txt strong{color:rgba(255,255,255,0.65);display:block;margin-bottom:1px;}

/* Actions */
.lw-sheet-actions{padding:4px 18px 16px;display:flex;flex-direction:column;gap:9px;}
.lw-btn-claim{
  display:flex;align-items:center;justify-content:center;gap:10px;
  padding:16px;border-radius:18px;border:none;
  background:linear-gradient(135deg,var(--wa),var(--wa2));
  color:#fff;font-size:15px;font-weight:900;cursor:pointer;
  text-decoration:none;touch-action:manipulation;
  box-shadow:0 4px 24px rgba(37,211,102,0.35);
  transition:transform .1s,box-shadow .1s;position:relative;overflow:hidden;
}
.lw-btn-claim::before{content:'';position:absolute;top:0;left:-100%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);animation:waSheen 2.5s ease-in-out infinite;}
.lw-btn-claim:active{transform:scale(0.97);}
.lw-wa-circle{width:28px;height:28px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.lw-wa-circle svg{width:17px;height:17px;}
/* SPIN AGAIN button */
.lw-btn-spin-again{
  display:flex;align-items:center;justify-content:center;gap:8px;
  padding:15px;border-radius:18px;border:none;
  background:linear-gradient(135deg,rgba(0,245,255,0.12),rgba(123,47,255,0.12));
  color:#fff;font-size:14px;font-weight:900;cursor:pointer;
  text-decoration:none;touch-action:manipulation;
  border:1px solid rgba(0,245,255,0.25);
  font-family:'Orbitron',sans-serif;letter-spacing:0.05em;
  transition:all .15s;
  box-shadow:0 0 20px rgba(0,245,255,0.08);
}
.lw-btn-spin-again:active{transform:scale(0.97);}
.lw-btn-spin-again.pulse{animation:spinAgainPulse 1.5s ease-in-out infinite;}
@keyframes spinAgainPulse{0%,100%{box-shadow:0 0 20px rgba(0,245,255,0.08),0 0 0 0 rgba(0,245,255,0.2)}50%{box-shadow:0 0 30px rgba(0,245,255,0.2),0 0 0 6px rgba(0,245,255,0)}}
.lw-btn-close{
  padding:12px;border-radius:14px;border:none;
  background:transparent;color:rgba(255,255,255,0.2);
  font-size:12px;font-weight:700;cursor:pointer;letter-spacing:0.04em;
}

/* Confetti */
#lwConfetti{position:fixed;inset:0;pointer-events:none;z-index:11000;}

/* Recent wins */
.lw-recent{
  width:100%;padding:5px 16px 0;flex-shrink:0;
  display:flex;align-items:center;gap:8px;overflow:hidden;
  position:relative;z-index:5;
}
.lw-recent-lbl{font-size:8px;font-weight:800;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.15);white-space:nowrap;flex-shrink:0;}
.lw-recent-pills{display:flex;gap:5px;overflow:hidden;}
.lw-recent-pill{
  font-size:10px;font-weight:700;color:rgba(0,245,255,0.5);
  background:rgba(0,245,255,0.04);border:1px solid rgba(0,245,255,0.1);
  border-radius:99px;padding:3px 8px;white-space:nowrap;flex-shrink:0;
}
</style>

<!-- ROOT -->
<div class="lw" id="lwRoot">
  <div class="lw-bg">
    <div class="lw-bg-mesh"></div>
    <div class="lw-grid"></div>
    <div class="lw-orb lw-orb1"></div>
    <div class="lw-orb lw-orb2"></div>
    <div class="lw-orb lw-orb3"></div>
  </div>
  <div id="lwStars"></div>

  <!-- HEADER -->
  <div class="lw-header">
    <div class="lw-brand">
      <div class="lw-brand-icon">🍶</div>
      <div>
        <div class="lw-brand-name">AILA MADIRA</div>
        <span class="lw-brand-sub">Lucky Wheel</span>
      </div>
    </div>
    <div class="lw-spin-badge" id="lwBadge">
      <div class="lw-spin-badge-dot" id="lwBadgeDot"></div>
      <span class="lw-spin-badge-txt" id="lwBadgeTxt">5 LEFT</span>
    </div>
  </div>

  <!-- HERO -->
  <div class="lw-hero">
    <div class="lw-hero-title">Win <em>Free Food & Drinks</em></div>
    <div class="lw-hero-sub">Spin · Screenshot · Order on WhatsApp · Enjoy!</div>
    <div class="lw-dots">
      <div class="lw-dot" id="lwDot0"></div>
      <div class="lw-dot" id="lwDot1"></div>
      <div class="lw-dot" id="lwDot2"></div>
      <div class="lw-dot" id="lwDot3"></div>
      <div class="lw-dot" id="lwDot4"></div>
    </div>
  </div>

  <!-- WHEEL -->
  <div class="lw-wheel-zone" id="lwZone">
    <div class="lw-aura" id="lwAura"></div>
    <div class="lw-pointer" id="lwPointer">
