/* ── STORAGE ── */
function today(){return new Date().toDateString();}
function getUsed(){try{if(localStorage.getItem(LS_KEY)!==today())return 0;return parseInt(localStorage.getItem(LS_USED)||'0',10);}catch(e){return 0;}}
