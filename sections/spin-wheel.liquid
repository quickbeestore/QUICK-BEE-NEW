{% comment %} Aaila Madira — CASINO ROYALE Lucky Wheel 2026 {% endcomment %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Cinzel:wght@700;900&family=Lato:wght@400;700;900&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{overflow:hidden!important;height:100%;touch-action:none;}
#shopify-section-header,.site-header,header[class*="header"],
#shopify-section-footer,.site-footer,footer[class*="footer"],
.qb-mobile-footer,.qb-ticker,.qb-trust-bar,#qbsc-root,.qb-timebox,
[class*="announcement"],[id*="announcement"]{display:none!important;}

:root{
  --gold:#C9A84C;--gold2:#FFD700;--gold3:#8B6914;--gold-light:#FFF0A0;
  --crimson:#8B0000;--crimson2:#C41E3A;
  --felt:#0A2A1A;--felt2:#0D3520;
  --wa:#25D366;--wa2:#128C7E;
  --cream:#F5E6C8;--cream2:#EDD9A3;
}

/* ── ROOT — deep casino felt ── */
.lw{
  position:fixed;inset:0;
  background:radial-gradient(ellipse 120% 80% at 50% 0%,#1a0a00 0%,#0D1A0A 35%,#050D05 70%,#020802 100%);
  display:flex;flex-direction:column;align-items:center;
  font-family:'Lato',sans-serif;
  z-index:9999;overflow:hidden;
  user-select:none;-webkit-user-select:none;
}

/* Felt texture overlay */
.lw::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background-image:
    repeating-linear-gradient(45deg,rgba(0,0,0,0.03) 0px,rgba(0,0,0,0.03) 1px,transparent 1px,transparent 8px),
    repeating-linear-gradient(-45deg,rgba(0,0,0,0.03) 0px,rgba(0,0,0,0.03) 1px,transparent 1px,transparent 8px);
  z-index:0;
}

/* Ambient casino glow */
.lw-bg{position:absolute;inset:0;pointer-events:none;z-index:0;}
.lw-bg-glow{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 40% at 50% 0%,rgba(201,168,76,0.08) 0%,transparent 60%),
    radial-gradient(ellipse 50% 60% at 0% 50%,rgba(139,0,0,0.06) 0%,transparent 50%),
    radial-gradient(ellipse 50% 60% at 100% 50%,rgba(139,0,0,0.06) 0%,transparent 50%),
    radial-gradient(ellipse 60% 40% at 50% 100%,rgba(10,42,26,0.4) 0%,transparent 60%);
}

/* Gold dust particles */
.lw-dust{position:absolute;border-radius:50%;pointer-events:none;background:var(--gold2);animation:dustFloat var(--d) var(--dl) ease-in-out infinite alternate;}
@keyframes dustFloat{0%{opacity:0;transform:translateY(0) scale(1)}50%{opacity:.4}100%{opacity:0.05;transform:translateY(-60px) scale(0.5)}}

/* ── HEADER ── */
.lw-header{
  width:100%;
  padding:calc(env(safe-area-inset-top,0px) + 10px) 16px 0;
  display:flex;align-items:center;justify-content:space-between;
  position:relative;z-index:5;flex-shrink:0;
}

/* Gold ornate top border */
.lw-header::after{
  content:'';position:absolute;bottom:-8px;left:10%;right:10%;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold),rgba(255,215,0,0.8),var(--gold),transparent);
}

.lw-brand{display:flex;align-items:center;gap:10px;}
.lw-brand-logo{
  width:48px;height:48px;border-radius:10px;
  overflow:hidden;flex-shrink:0;position:relative;
  background:#000;
  border:1.5px solid var(--gold);
  box-shadow:0 0 12px rgba(201,168,76,0.5),0 0 28px rgba(201,168,76,0.2),inset 0 0 8px rgba(0,0,0,0.6);
}
.lw-brand-logo img{width:100%;height:100%;object-fit:contain;display:block;}
.lw-brand-logo::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,215,0,0.15) 0%,transparent 50%);
  z-index:1;pointer-events:none;
}
.lw-brand-name{
  font-family:'Cinzel',serif;
  font-size:14px;font-weight:900;letter-spacing:0.12em;
  background:linear-gradient(180deg,#FFF0A0 0%,#FFD700 40%,#C9A84C 70%,#8B6914 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  line-height:1.1;text-transform:uppercase;
}
.lw-brand-sub{
  font-size:7.5px;letter-spacing:0.2em;text-transform:uppercase;display:block;margin-top:2px;
  color:rgba(201,168,76,0.55);font-family:'Lato',sans-serif;
}

/* Spins badge — casino chip style */
.lw-spin-badge{
  display:flex;align-items:center;gap:5px;
  background:radial-gradient(circle at 40% 35%,#2a0a0a,#1a0505);
  border:1.5px solid var(--gold);
  border-radius:99px;padding:5px 13px;
  box-shadow:0 0 10px rgba(201,168,76,0.3),inset 0 1px 0 rgba(255,215,0,0.2);
}
.lw-spin-badge-dot{
  width:6px;height:6px;border-radius:50%;background:var(--gold2);
  box-shadow:0 0 6px var(--gold2);
  animation:badgePulse 1.5s ease infinite;
}
@keyframes badgePulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)}}
.lw-spin-badge-txt{
  font-family:'Cinzel',serif;
  font-size:10px;font-weight:700;color:var(--gold2);letter-spacing:0.08em;
}

/* ── HERO ── */
.lw-hero{
  text-align:center;padding:10px 20px 2px;
  position:relative;z-index:5;flex-shrink:0;
}
.lw-hero-title{
  font-family:'Cinzel',serif;
  font-size:clamp(16px,4vw,22px);font-weight:900;letter-spacing:0.04em;
  color:#fff;line-height:1.15;
  text-shadow:0 2px 20px rgba(201,168,76,0.3);
}
.lw-hero-title em{
  font-style:normal;
  background:linear-gradient(135deg,#FFF0A0 0%,#FFD700 35%,#C9A84C 65%,#FFD700 100%);
  background-size:200% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation:goldShimmer 4s linear infinite;
}
@keyframes goldShimmer{0%{background-position:0% center}100%{background-position:200% center}}
.lw-hero-sub{font-size:10.5px;color:rgba(201,168,76,0.45);margin-top:3px;letter-spacing:0.08em;font-family:'Lato',sans-serif;}

/* Spin dots — casino chip dots */
.lw-dots{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:8px;}
.lw-dot{
  width:9px;height:9px;border-radius:50%;
  background:rgba(201,168,76,0.1);
  border:1px solid rgba(201,168,76,0.25);
  transition:all .3s;
}
.lw-dot.used{
  background:var(--crimson2);border-color:var(--crimson);
  box-shadow:0 0 6px rgba(196,30,58,0.6);
}
.lw-dot.active{
  background:var(--gold2);border-color:var(--gold);
  box-shadow:0 0 10px rgba(255,215,0,0.8),0 0 20px rgba(255,215,0,0.3);
  animation:activeDot 1s ease infinite;
}
@keyframes activeDot{0%,100%{transform:scale(1)}50%{transform:scale(1.6)}}

/* ── WHEEL ZONE ── */
.lw-wheel-zone{
  flex:1;display:flex;align-items:center;justify-content:center;
  position:relative;width:100%;min-height:0;padding:0;
}

/* Casino table felt ring behind wheel */
.lw-aura{
  position:absolute;border-radius:50%;pointer-events:none;
  background:radial-gradient(circle,rgba(13,53,32,0.6) 0%,transparent 70%);
  animation:auraPulse 3s ease-in-out infinite;
}
@keyframes auraPulse{0%,100%{opacity:.6;transform:scale(1)}50%{opacity:1;transform:scale(1.015)}}

/* Pointer — ornate gold arrow */
.lw-pointer{
  position:absolute;z-index:20;pointer-events:none;
  top:0;left:50%;transform:translateX(-50%) translateY(-4px);
  filter:drop-shadow(0 0 8px rgba(255,215,0,0.9)) drop-shadow(0 3px 10px rgba(0,0,0,1));
}

#lwCanvas{
  display:block;border-radius:50%;position:relative;z-index:3;
  touch-action:none;cursor:pointer;
}
.lw-wheel-zone.spinning #lwCanvas{
  filter:drop-shadow(0 0 40px rgba(255,215,0,0.3)) drop-shadow(0 0 80px rgba(139,0,0,0.2));
}

/* Center SPIN button — royal casino chip */
.lw-spin-btn{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  z-index:15;border-radius:50%;border:none;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;touch-action:manipulation;
  background:radial-gradient(circle at 38% 32%,#5a0a0a 0%,#2a0505 45%,#120202 100%);
  overflow:hidden;
  -webkit-tap-highlight-color:transparent;
  transition:transform .12s,filter .12s;
}
/* Outer gold ring */
.lw-spin-btn::before{
  content:'';position:absolute;inset:-2px;border-radius:50%;
  background:conic-gradient(
    #FFD700 0deg, #8B6914 60deg, #FFF0A0 120deg,
    #C9A84C 180deg, #FFD700 240deg, #8B6914 300deg, #FFD700 360deg
  );
  z-index:-1;
  animation:rimSpin 8s linear infinite;
}
@keyframes rimSpin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
/* Inner shadow inset */
.lw-spin-btn::after{
  content:'';position:absolute;inset:3px;border-radius:50%;
  background:radial-gradient(circle at 38% 30%,#6a1010 0%,#2a0505 50%,#0d0202 100%);
  box-shadow:inset 0 3px 12px rgba(0,0,0,0.9),inset 0 -2px 6px rgba(255,215,0,0.1);
  z-index:0;
}
.lw-spin-btn:active{transform:translate(-50%,-50%) scale(0.88)!important;}
.lw-spin-btn:disabled{cursor:not-allowed;opacity:0.6;}
.lw-spin-btn:disabled::before{animation:none;}
.lw-btn-inner{display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;z-index:1;}
.lw-btn-icon{line-height:1;display:block;transition:transform .3s;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.8));}
.lw-btn-label{
  font-family:'Cinzel',serif;
  font-weight:900;letter-spacing:0.15em;text-transform:uppercase;
  display:block;line-height:1;margin-top:3px;
  background:linear-gradient(180deg,#FFF0A0 0%,#FFD700 50%,#C9A84C 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  text-shadow:none;
  filter:drop-shadow(0 1px 3px rgba(0,0,0,1));
}
.lw-spin-btn:disabled .lw-btn-label{color:rgba(255,255,255,0.2);-webkit-text-fill-color:rgba(255,255,255,0.2);filter:none;}
.lw-spin-btn:disabled .lw-btn-icon{opacity:.2;}

/* Hint rings — gold pulsing */
.lw-hint-ring{
  position:absolute;top:50%;left:50%;border-radius:50%;
  border:1.5px solid rgba(201,168,76,0.4);pointer-events:none;z-index:14;
  animation:hintRing 2.5s ease-out infinite;
}
@keyframes hintRing{0%{transform:translate(-50%,-50%) scale(1);opacity:.8}100%{transform:translate(-50%,-50%) scale(2.4);opacity:0}}
.lw-hint-ring:nth-child(2){animation-delay:1s;}

/* ── WA BAR ── */
.lw-wa-bar{
  width:100%;padding:6px 14px;
  padding-bottom:calc(env(safe-area-inset-bottom,0px)+8px);
  flex-shrink:0;position:relative;z-index:5;
}
/* Gold divider above WA bar */
.lw-wa-bar::before{
  content:'— ✦ —';display:block;text-align:center;
  color:rgba(201,168,76,0.35);font-size:9px;letter-spacing:0.3em;
  margin-bottom:5px;
}
.lw-wa-btn{
  display:flex;align-items:center;justify-content:center;gap:10px;
  width:100%;padding:13px 20px;border-radius:14px;border:none;
  background:linear-gradient(135deg,#1a6b35 0%,#128C7E 100%);
  color:#fff;font-size:14px;font-weight:900;cursor:pointer;
  text-decoration:none;touch-action:manipulation;
  box-shadow:0 4px 20px rgba(37,211,102,0.25),0 1px 0 rgba(255,255,255,0.1) inset;
  letter-spacing:0.02em;transition:transform .1s,box-shadow .1s;
  position:relative;overflow:hidden;
  border:1px solid rgba(37,211,102,0.35);
  font-family:'Lato',sans-serif;
}
.lw-wa-btn::before{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.1),transparent);animation:waSheen 3.5s ease-in-out infinite;}
@keyframes waSheen{0%{left:-100%}50%,100%{left:150%}}
.lw-wa-btn:active{transform:scale(0.97);}
.lw-wa-icon{width:26px;height:26px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.lw-wa-icon svg{width:16px;height:16px;}
.lw-wa-texts{display:flex;flex-direction:column;align-items:flex-start;}
.lw-wa-main{font-size:14px;font-weight:900;line-height:1.1;}
.lw-wa-mini{font-size:10px;font-weight:600;opacity:0.75;letter-spacing:0.04em;}

/* ── BOTTOM SHEET — casino card style ── */
.lw-overlay{
  position:fixed;inset:0;z-index:10000;
  background:rgba(0,0,0,0);pointer-events:none;
  transition:background .35s;
}
.lw-overlay.show{
  background:rgba(0,0,0,0.92);pointer-events:all;
  backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
}
.lw-sheet{
  position:absolute;bottom:0;left:0;right:0;
  background:linear-gradient(180deg,#1a0d05 0%,#0d0802 100%);
  border-radius:24px 24px 0 0;
  border-top:2px solid var(--gold);
  border-left:1px solid rgba(201,168,76,0.2);
  border-right:1px solid rgba(201,168,76,0.2);
  padding:0 0 env(safe-area-inset-bottom,20px);
  transform:translateY(110%);
  transition:transform .5s cubic-bezier(0.34,1.4,0.64,1);
  box-shadow:0 -30px 80px rgba(0,0,0,1),0 -4px 40px rgba(201,168,76,0.08);
  overflow:hidden;max-height:92vh;display:flex;flex-direction:column;
}
.lw-overlay.show .lw-sheet{transform:translateY(0);}

/* Gold top ornament line */
.lw-sheet-gold-line{
  height:2px;width:100%;flex-shrink:0;
  background:linear-gradient(90deg,transparent,var(--gold3),var(--gold),var(--gold2),var(--gold),var(--gold3),transparent);
  animation:goldLine 4s ease-in-out infinite;
}
@keyframes goldLine{0%,100%{opacity:.7}50%{opacity:1}}

.lw-sheet-handle{width:36px;height:3px;border-radius:2px;background:rgba(201,168,76,0.2);margin:12px auto 0;flex-shrink:0;}
.lw-sheet-scroll{overflow-y:auto;flex:1;}

/* Sheet hero */
.lw-sheet-hero{text-align:center;padding:16px 24px 10px;position:relative;}
.lw-sheet-glow{position:absolute;top:-50px;left:50%;transform:translateX(-50%);width:200px;height:120px;border-radius:50%;pointer-events:none;}
.lw-prize-wrap{
  width:80px;height:80px;border-radius:20px;
  margin:0 auto 12px;display:flex;align-items:center;justify-content:center;
  font-size:40px;position:relative;
}
.lw-prize-bg{
  position:absolute;inset:0;border-radius:inherit;
  animation:prizeIn .55s .1s cubic-bezier(0.34,1.6,0.64,1) both;
}
@keyframes prizeIn{0%{transform:scale(0.1) rotate(-20deg);opacity:0}100%{transform:scale(1) rotate(0);opacity:1}}
.lw-prize-em{position:relative;z-index:1;animation:prizeIn .55s .15s cubic-bezier(0.34,1.6,0.64,1) both;display:block;}

.lw-sheet-status{
  font-family:'Cinzel',serif;
  font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:5px;
}
.lw-sheet-heading{
  font-family:'Cinzel',serif;
  font-size:19px;font-weight:900;color:#fff;letter-spacing:0.04em;margin-bottom:4px;
}
.lw-sheet-prize{
  font-size:14px;font-weight:700;margin-bottom:5px;
  background:linear-gradient(135deg,#FFF0A0,#FFD700,#C9A84C);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  font-family:'Lato',sans-serif;
}
.lw-sheet-desc{font-size:12px;color:rgba(255,255,255,0.3);line-height:1.55;padding:0 8px;font-family:'Lato',sans-serif;}

/* Code card — casino ticket style */
.lw-code-card{
  margin:10px 16px;padding:14px 16px;
  background:linear-gradient(135deg,rgba(139,0,0,0.15),rgba(10,42,26,0.2));
  border:1px solid rgba(201,168,76,0.3);border-radius:14px;
  position:relative;overflow:hidden;
}
.lw-code-card::before{
  content:'';position:absolute;top:-1px;left:15%;right:15%;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold2),transparent);
}
.lw-code-inner{display:flex;align-items:center;justify-content:space-between;gap:12px;}
.lw-code-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:rgba(201,168,76,0.45);margin-bottom:4px;font-family:'Cinzel',serif;}
.lw-code-val{
  font-family:'Cinzel',serif;
  font-size:18px;font-weight:900;letter-spacing:0.12em;
  background:linear-gradient(135deg,#FFF0A0,#FFD700,#C9A84C);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.lw-code-exp{font-size:9px;color:rgba(255,255,255,0.18);margin-top:3px;font-family:'Lato',sans-serif;}
.lw-copy-btn{
  padding:9px 14px;border-radius:8px;
  border:1px solid rgba(201,168,76,0.4);
  background:rgba(201,168,76,0.08);
  color:var(--gold2);font-size:11px;font-weight:800;cursor:pointer;
  white-space:nowrap;transition:all .15s;flex-shrink:0;
  font-family:'Cinzel',serif;letter-spacing:0.06em;
}
.lw-copy-btn.copied{background:rgba(37,211,102,0.12);border-color:rgba(37,211,102,0.35);color:#4ade80;}

/* Screenshot hint */
.lw-screenshot{
  margin:0 16px 10px;padding:9px 13px;
  background:rgba(255,255,255,0.02);border:1px solid rgba(201,168,76,0.12);
  border-radius:12px;display:flex;align-items:center;gap:10px;
}
.lw-screenshot-icon{font-size:22px;flex-shrink:0;}
.lw-screenshot-txt{font-size:11px;color:rgba(255,255,255,0.3);line-height:1.45;font-family:'Lato',sans-serif;}
.lw-screenshot-txt strong{color:rgba(201,168,76,0.7);display:block;margin-bottom:1px;}

/* Actions */
.lw-sheet-actions{padding:4px 16px 14px;display:flex;flex-direction:column;gap:8px;}
.lw-btn-claim{
  display:flex;align-items:center;justify-content:center;gap:10px;
  padding:15px;border-radius:14px;border:none;
  background:linear-gradient(135deg,#1a6b35,#128C7E);
  color:#fff;font-size:15px;font-weight:900;cursor:pointer;
  text-decoration:none;touch-action:manipulation;
  box-shadow:0 4px 20px rgba(37,211,102,0.25);
  transition:transform .1s;position:relative;overflow:hidden;
  border:1px solid rgba(37,211,102,0.3);font-family:'Lato',sans-serif;
}
.lw-btn-claim::before{content:'';position:absolute;top:0;left:-100%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.12),transparent);animation:waSheen 2.5s ease-in-out infinite;}
.lw-btn-claim:active{transform:scale(0.97);}
.lw-wa-circle{width:28px;height:28px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.lw-wa-circle svg{width:17px;height:17px;}

/* Spin Again */
.lw-btn-spin-again{
  display:flex;align-items:center;justify-content:center;gap:8px;
  padding:14px;border-radius:14px;border:1.5px solid rgba(201,168,76,0.4);
  background:linear-gradient(135deg,rgba(139,0,0,0.25),rgba(90,0,0,0.15));
  color:var(--gold2);font-size:13px;font-weight:900;cursor:pointer;
  touch-action:manipulation;font-family:'Cinzel',serif;letter-spacing:0.08em;
  transition:all .15s;
  box-shadow:0 0 16px rgba(201,168,76,0.08);
}
.lw-btn-spin-again:active{transform:scale(0.97);}
.lw-btn-spin-again.pulse{animation:spinAgainPulse 1.5s ease-in-out infinite;}
@keyframes spinAgainPulse{0%,100%{box-shadow:0 0 16px rgba(201,168,76,0.08),0 0 0 0 rgba(201,168,76,0.2)}50%{box-shadow:0 0 24px rgba(201,168,76,0.2),0 0 0 6px rgba(201,168,76,0)}}
.lw-btn-close{
  padding:10px;border-radius:10px;border:none;
  background:transparent;color:rgba(255,255,255,0.15);
  font-size:11px;font-weight:700;cursor:pointer;letter-spacing:0.06em;
  font-family:'Lato',sans-serif;
}

/* Confetti */
#lwConfetti{position:fixed;inset:0;pointer-events:none;z-index:11000;}

/* ── COUNTDOWN TIMER — casino vault ── */
.lw-timer{
  position:fixed;inset:0;z-index:9998;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:rgba(3,1,0,0.97);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  pointer-events:none;opacity:0;
  transition:opacity .5s ease;
  padding:24px;
}
.lw-timer.show{opacity:1;pointer-events:all;}
.lw-timer-glow{
  position:absolute;inset:0;
  background:radial-gradient(ellipse 70% 50% at 50% 40%,rgba(139,0,0,0.1) 0%,transparent 65%),
             radial-gradient(ellipse 50% 30% at 50% 0%,rgba(201,168,76,0.06) 0%,transparent 50%);
  pointer-events:none;
}
