{% comment %} Aila Madira — Lucky Wheel 2026 {% endcomment %}
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{overflow:hidden!important;height:100%;background:#0a0500!important;touch-action:none;}
#shopify-section-header,.site-header,header[class*="header"],
#shopify-section-footer,.site-footer,footer[class*="footer"],
.qb-ticker,.qb-trust-bar,#qbsc-root,.qb-timebox,
[class*="announcement"],[id*="announcement"]{display:none!important;}

:root{
  --gold:#F4B400;--gold2:#FFD700;--gold3:#c8930a;
  --red:#C0392B;--red2:#e74c3c;
  --green:#25D366;--green2:#128C7E;
  --bg:#0a0500;--bg2:#120900;
  --radius:20px;
}

/* ── ROOT ── */
.am{
  position:fixed;inset:0;
  background:var(--bg);
  display:flex;flex-direction:column;align-items:center;
  font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display','Segoe UI',sans-serif;
  z-index:9999;overflow:hidden;
  user-select:none;-webkit-user-select:none;
}

/* ── BG LAYERS ── */
.am-bg{
  position:absolute;inset:0;pointer-events:none;
  background:
    radial-gradient(ellipse 100% 55% at 50% 0%,rgba(192,57,43,0.22) 0%,transparent 65%),
    radial-gradient(ellipse 70% 40% at 50% 105%,rgba(244,180,0,0.1) 0%,transparent 60%),
    #0a0500;
}
.am-bg-orb{
  position:absolute;border-radius:50%;pointer-events:none;filter:blur(60px);
}
.am-bg-orb1{width:280px;height:280px;top:-80px;left:-60px;background:rgba(192,57,43,0.12);animation:orbFloat1 8s ease-in-out infinite;}
.am-bg-orb2{width:200px;height:200px;bottom:-40px;right:-40px;background:rgba(244,180,0,0.08);animation:orbFloat2 10s ease-in-out infinite;}
@keyframes orbFloat1{0%,100%{transform:translate(0,0)}50%{transform:translate(30px,20px)}}
@keyframes orbFloat2{0%,100%{transform:translate(0,0)}50%{transform:translate(-20px,-30px)}}

/* Stars */
.am-star{position:absolute;border-radius:50%;background:#fff;pointer-events:none;animation:twinkle var(--d) var(--dl) ease-in-out infinite alternate;}
@keyframes twinkle{0%{opacity:.03}100%{opacity:.5}}

/* ── HEADER ── */
.am-header{
  width:100%;padding-top:calc(env(safe-area-inset-top,0px) + 10px);
  padding-left:16px;padding-right:16px;padding-bottom:0;
  display:flex;align-items:center;justify-content:space-between;
  position:relative;z-index:5;flex-shrink:0;
}
.am-logo{display:flex;align-items:center;gap:8px;}
.am-logo-icon{
  width:34px;height:34px;border-radius:10px;
  background:linear-gradient(135deg,var(--red),var(--red2));
  display:flex;align-items:center;justify-content:center;
  font-size:18px;
  box-shadow:0 2px 10px rgba(192,57,43,0.4);
}
.am-logo-text{
  font-size:17px;font-weight:900;letter-spacing:-0.3px;
  background:linear-gradient(135deg,#fff 0%,var(--gold2) 60%,var(--gold) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.am-logo-sub{font-size:9px;color:rgba(255,255,255,0.35);letter-spacing:0.08em;text-transform:uppercase;display:block;margin-top:-2px;}
.am-spins-left{
  display:flex;align-items:center;gap:5px;
  background:rgba(244,180,0,0.08);border:1px solid rgba(244,180,0,0.2);
  border-radius:99px;padding:5px 10px;
}
.am-spins-icon{font-size:13px;}
.am-spins-txt{font-size:11px;font-weight:800;color:var(--gold);letter-spacing:0.03em;}

/* ── HERO TEXT ── */
.am-hero{
  text-align:center;padding:8px 20px 4px;
  position:relative;z-index:5;flex-shrink:0;
}
.am-hero-title{
  font-size:clamp(22px,5.5vw,30px);font-weight:900;letter-spacing:-0.5px;line-height:1.05;
  color:#fff;
}
.am-hero-title span{
  background:linear-gradient(135deg,var(--gold2),var(--gold));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.am-hero-sub{font-size:11px;color:rgba(255,255,255,0.35);margin-top:3px;letter-spacing:0.04em;}

/* Spin counter pills */
.am-dots{display:flex;align-items:center;justify-content:center;gap:5px;margin-top:6px;}
.am-dot{
  width:8px;height:8px;border-radius:50%;
  background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.1);
  transition:all .3s;
}
.am-dot.used{background:var(--gold);border-color:var(--gold);box-shadow:0 0 6px rgba(244,180,0,0.6);}
.am-dot.active{background:var(--red2);border-color:var(--red2);box-shadow:0 0 8px rgba(231,76,60,0.8);animation:dotPulse .8s ease infinite;}
@keyframes dotPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.4)}}

/* ── WHEEL ZONE ── */
.am-wheel-zone{
  flex:1;display:flex;align-items:center;justify-content:center;
  position:relative;width:100%;min-height:0;padding:2px 0;
}
.am-glow-ring{
  position:absolute;border-radius:50%;pointer-events:none;
  box-shadow:0 0 60px 15px rgba(192,57,43,0.15),0 0 120px 40px rgba(244,180,0,0.06);
  animation:glowPulse 3s ease-in-out infinite;
}
@keyframes glowPulse{0%,100%{opacity:.6}50%{opacity:1}}
.am-pointer{
  position:absolute;z-index:20;pointer-events:none;
  top:0;left:50%;transform:translateX(-50%) translateY(-4px);
  filter:drop-shadow(0 0 12px var(--gold)) drop-shadow(0 2px 6px rgba(0,0,0,.8));
}
#amCanvas{
  display:block;border-radius:50%;position:relative;z-index:3;
  touch-action:none;cursor:pointer;
  transition:filter .3s;
}
.am-wheel-zone.spinning #amCanvas{filter:drop-shadow(0 0 40px rgba(192,57,43,0.5));}
.am-center{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  z-index:15;border-radius:50%;border:none;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;touch-action:manipulation;
  background:radial-gradient(circle at 35% 30%,#ff6b5b 0%,var(--red) 40%,#8b1a1a 80%,#5a0d0d 100%);
  transition:transform .12s,filter .12s,box-shadow .12s;
  -webkit-tap-highlight-color:transparent;
}
.am-center:active{transform:translate(-50%,-50%) scale(0.9)!important;}
.am-center:disabled{
  background:radial-gradient(circle,#2a2a2a,#1a1a1a);cursor:not-allowed;filter:none!important;
}
.am-center-icon{line-height:1;display:block;}
.am-center-label{
  font-weight:900;color:#fff;letter-spacing:0.08em;text-transform:uppercase;
  display:block;line-height:1;margin-top:2px;
}
.am-center:disabled .am-center-icon,.am-center:disabled .am-center-label{opacity:.3;}
.am-hint-ring{
  position:absolute;top:50%;left:50%;border-radius:50%;
  border:2px solid rgba(192,57,43,0.4);pointer-events:none;z-index:14;
  animation:hintRing 2s ease-out infinite;
}
@keyframes hintRing{0%{transform:translate(-50%,-50%) scale(1);opacity:.8}100%{transform:translate(-50%,-50%) scale(2);opacity:0}}
.am-hint-ring:nth-child(2){animation-delay:.8s;}

/* ── BOTTOM WA BAR ── */
.am-wa-bar{
  width:100%;padding:8px 16px;padding-bottom:calc(env(safe-area-inset-bottom,0px) + 8px);
  flex-shrink:0;position:relative;z-index:5;
}
.am-wa-btn{
  display:flex;align-items:center;justify-content:center;gap:10px;
  width:100%;padding:14px 20px;border-radius:16px;border:none;
  background:linear-gradient(135deg,#25D366 0%,#128C7E 100%);
  color:#fff;font-size:14px;font-weight:900;cursor:pointer;
  text-decoration:none;touch-action:manipulation;
  box-shadow:0 4px 24px rgba(37,211,102,0.35),0 1px 0 rgba(255,255,255,0.2) inset;
  letter-spacing:0.02em;
  transition:transform .1s,box-shadow .1s;
  position:relative;overflow:hidden;
}
.am-wa-btn::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.15) 0%,transparent 60%);
}
.am-wa-btn:active{transform:scale(0.97);box-shadow:0 2px 12px rgba(37,211,102,0.2);}
.am-wa-icon{
  width:26px;height:26px;flex-shrink:0;
  background:#fff;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
}
.am-wa-icon svg{width:16px;height:16px;}
.am-wa-texts{display:flex;flex-direction:column;align-items:flex-start;}
.am-wa-main{font-size:14px;font-weight:900;line-height:1.1;}
.am-wa-mini{font-size:10px;font-weight:600;opacity:0.8;letter-spacing:0.04em;}

/* ── BOTTOM SHEET ── */
.am-overlay{
  position:fixed;inset:0;z-index:10000;
  background:rgba(0,0,0,0);pointer-events:none;
  transition:background .35s;
}
.am-overlay.show{
  background:rgba(0,0,0,0.82);pointer-events:all;
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
}
.am-sheet{
  position:absolute;bottom:0;left:0;right:0;
  background:linear-gradient(180deg,#160800 0%,#0d0500 100%);
  border-radius:28px 28px 0 0;
  border-top:1px solid rgba(192,57,43,0.25);
  border-left:1px solid rgba(192,57,43,0.08);
  border-right:1px solid rgba(192,57,43,0.08);
  padding:0 0 env(safe-area-inset-bottom,20px);
  transform:translateY(110%);
  transition:transform .45s cubic-bezier(0.34,1.4,0.64,1);
  box-shadow:0 -20px 80px rgba(0,0,0,.95),0 -4px 30px rgba(192,57,43,.1);
  overflow:hidden;max-height:88vh;display:flex;flex-direction:column;
}
.am-overlay.show .am-sheet{transform:translateY(0);}
.am-sheet-handle{width:36px;height:4px;border-radius:2px;background:rgba(255,255,255,0.12);margin:12px auto 0;flex-shrink:0;}
.am-sheet-scroll{overflow-y:auto;flex:1;}

/* Sheet hero */
.am-sheet-hero{text-align:center;padding:16px 24px 12px;position:relative;}
.am-sheet-glow{
  position:absolute;top:-40px;left:50%;transform:translateX(-50%);
  width:180px;height:100px;border-radius:50%;pointer-events:none;
}
.am-prize-icon-wrap{
  width:76px;height:76px;border-radius:22px;
  margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:40px;
  position:relative;
}
.am-prize-icon-bg{
  position:absolute;inset:0;border-radius:inherit;
  animation:iconPop .5s .1s cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes iconPop{0%{transform:scale(0.2) rotate(-15deg);opacity:0}100%{transform:scale(1) rotate(0);opacity:1}}
.am-prize-icon-em{position:relative;z-index:1;animation:iconPop .5s .15s cubic-bezier(0.34,1.56,0.64,1) both;}
.am-sheet-tag{font-size:11px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px;}
.am-sheet-title{font-size:22px;font-weight:900;color:#fff;letter-spacing:-0.3px;margin-bottom:4px;}
.am-sheet-prize{font-size:15px;font-weight:700;color:var(--gold);margin-bottom:6px;}
.am-sheet-desc{font-size:12px;color:rgba(255,255,255,0.4);line-height:1.5;padding:0 10px;}

/* Code box */
.am-code-box{
  margin:12px 20px;padding:14px 16px;
  background:rgba(244,180,0,0.06);border:1px solid rgba(244,180,0,0.2);
  border-radius:16px;display:flex;align-items:center;justify-content:space-between;gap:12px;
}
.am-code-left{}
.am-code-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.3);margin-bottom:3px;}
.am-code-val{font-size:20px;font-weight:900;color:var(--gold);letter-spacing:0.08em;font-variant-numeric:tabular-nums;}
.am-code-exp{font-size:9px;color:rgba(255,255,255,0.25);margin-top:2px;}
.am-copy-btn{
  padding:8px 14px;border-radius:10px;border:1px solid rgba(244,180,0,0.3);
  background:rgba(244,180,0,0.08);color:var(--gold);font-size:12px;font-weight:800;
  cursor:pointer;white-space:nowrap;transition:all .15s;
}
.am-copy-btn.copied{background:rgba(74,222,128,0.15);border-color:rgba(74,222,128,0.4);color:#4ade80;}

/* Screenshot instruction */
.am-screenshot-row{
  margin:0 20px 10px;padding:10px 14px;
  background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);
  border-radius:12px;display:flex;align-items:center;gap:10px;
}
.am-screenshot-icon{font-size:22px;flex-shrink:0;}
.am-screenshot-txt{font-size:11px;color:rgba(255,255,255,0.45);line-height:1.4;}
.am-screenshot-txt strong{color:rgba(255,255,255,0.7);display:block;font-size:12px;margin-bottom:1px;}

/* Sheet actions */
.am-sheet-actions{padding:0 20px 16px;display:flex;flex-direction:column;gap:10px;}
.am-btn-wa{
  display:flex;align-items:center;justify-content:center;gap:10px;
  padding:15px;border-radius:16px;border:none;
  background:linear-gradient(135deg,#25D366,#128C7E);
  color:#fff;font-size:15px;font-weight:900;cursor:pointer;
  text-decoration:none;touch-action:manipulation;
  box-shadow:0 4px 24px rgba(37,211,102,0.4);
  transition:transform .1s,box-shadow .1s;
  position:relative;overflow:hidden;
}
.am-btn-wa::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.12) 0%,transparent 60%);}
.am-btn-wa:active{transform:scale(0.97);}
.am-btn-wa-icon{
  width:28px;height:28px;background:#fff;border-radius:50%;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.am-btn-wa-icon svg{width:17px;height:17px;}
.am-btn-close{
  padding:12px;border-radius:14px;border:1px solid rgba(255,255,255,0.08);
  background:rgba(255,255,255,0.03);color:rgba(255,255,255,0.35);
  font-size:13px;font-weight:700;cursor:pointer;
}

/* Lose sheet */
.am-sheet.lose .am-sheet-hero{opacity:.7;}

/* Confetti */
#amConfetti{position:fixed;inset:0;pointer-events:none;z-index:11000;}

/* Recent wins */
.am-recent{
  width:100%;padding:6px 16px;flex-shrink:0;
  display:flex;align-items:center;gap:8px;overflow:hidden;
  position:relative;z-index:5;
}
.am-recent-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.2);white-space:nowrap;flex-shrink:0;}
.am-recent-pills{display:flex;gap:6px;overflow:hidden;}
.am-recent-pill{
  font-size:10px;font-weight:700;color:rgba(255,255,255,0.4);
  background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.07);
  border-radius:99px;padding:3px 8px;white-space:nowrap;flex-shrink:0;
}
</style>

