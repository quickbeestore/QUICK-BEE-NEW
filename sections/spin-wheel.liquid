  if(hist.length){
    var hBlock=document.getElementById('swHistoryBlock');
    hBlock.style.display='block';
    document.getElementById('swHistoryRow').innerHTML=hist.slice(0,5).map(function(h){
      return '<span class="sw-history-pill">'+h.emoji+' '+h.prize+'</span>';
    }).join('');
  }

