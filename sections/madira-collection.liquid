{% comment %} Build product type map {% endcomment %}
{% assign has_whisky = false %}
{% assign has_rum = false %}
{% assign has_beer = false %}
{% assign has_vodka = false %}
{% assign has_wine = false %}
{% assign has_other = false %}

{% for product in collection.products %}
  {% assign ptype = product.type | downcase %}
  {% if ptype contains 'whisky' or ptype contains 'whiskey' %}
    {% assign has_whisky = true %}
  {% elsif ptype contains 'rum' %}
    {% assign has_rum = true %}
  {% elsif ptype contains 'beer' or ptype contains 'lager' or ptype contains 'ale' or ptype contains 'can' %}
    {% assign has_beer = true %}
  {% elsif ptype contains 'vodka' %}
    {% assign has_vodka = true %}
  {% elsif ptype contains 'wine' %}
    {% assign has_wine = true %}
  {% else %}
    {% assign has_other = true %}
  {% endif %}
{% endfor %}

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0f0f0f;
    --card: #1a1a1a;
    --gold: #f5b301;
    --white: #ffffff;
    --muted: #888888;
    --green: #22c55e;
    --blue: #3b82f6;
    --red: #ef4444;
    --border: rgba(255,255,255,0.08);
    --radius: 14px;
    --shadow: 0 4px 24px rgba(0,0,0,0.5);
  }

  #madira-section {
    background: var(--bg);
    min-height: 100vh;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: var(--white);
    padding-bottom: 120px;
  }

  /* ── STICKY HEADER ── */
  .md-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15,15,15,0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 14px 16px 10px;
  }
  .md-header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 4px;
  }
  .md-header-title {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
  }
  .md-header-sub {
    font-size: 13px;
    color: var(--gold);
    font-weight: 500;
    margin-bottom: 6px;
  }
  .md-open-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(34,197,94,0.15);
    border: 1px solid rgba(34,197,94,0.35);
    color: var(--green);
    font-size: 12px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
  }
  .md-open-dot {
    width: 7px;
    height: 7px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse-dot 1.5s infinite;
  }
  @keyframes pulse-dot {
    0%,100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.3); }
  }

  /* ── CATEGORY TABS ── */
  .md-tabs-wrap {
    position: sticky;
    top: 88px;
    z-index: 99;
    background: rgba(15,15,15,0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 16px;
  }
  .md-tabs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding: 10px 0;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .md-tabs::-webkit-scrollbar { display: none; }
  .md-tab {
    flex-shrink: 0;
    padding: 7px 18px;
    border-radius: 24px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .md-tab:hover { color: var(--white); border-color: rgba(255,255,255,0.25); }
  .md-tab.active {
    background: var(--gold);
    border-color: var(--gold);
    color: #000;
  }

  /* ── PRODUCT GRID ── */
  .md-grid {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── PRODUCT CARD ── */
  .md-card {
    background: var(--card);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    display: flex;
    align-items: stretch;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
  }
  .md-card:active { transform: scale(0.98); }
  .md-card.hidden { display: none; }

  .md-card-left {
    flex: 1;
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .md-card-right {
    width: 110px;
    flex-shrink: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 10px 10px 12px;
    background: rgba(255,255,255,0.03);
  }

  .md-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 6px;
    width: fit-content;
    letter-spacing: 0.2px;
  }
  .md-badge.gold { background: rgba(245,179,1,0.18); color: var(--gold); border: 1px solid rgba(245,179,1,0.3); }
  .md-badge.blue { background: rgba(59,130,246,0.18); color: var(--blue); border: 1px solid rgba(59,130,246,0.3); }
  .md-badge.green2 { background: rgba(34,197,94,0.18); color: var(--green); border: 1px solid rgba(34,197,94,0.3); }

  .md-card-name {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--white);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .md-card-volume {
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
  }
  .md-card-prices {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 2px;
  }
  .md-price {
    font-size: 17px;
    font-weight: 800;
    color: var(--gold);
  }
  .md-compare {
    font-size: 13px;
    color: var(--muted);
    text-decoration: line-through;
  }
  .md-savings {
    font-size: 11px;
    color: var(--green);
    font-weight: 600;
  }

  .md-product-img {
    width: 78px;
    height: 78px;
    object-fit: contain;
    border-radius: 8px;
    flex-shrink: 0;
  }
  .md-product-img-placeholder {
    width: 78px;
    height: 78px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
  }

  .md-add-btn {
    width: 100%;
    padding: 8px 0;
    background: var(--gold);
    color: #000;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    transition: transform 0.15s ease, opacity 0.15s;
    letter-spacing: 0.3px;
  }
  .md-add-btn:hover { opacity: 0.9; }
  .md-add-btn:active { transform: scale(0.93); }

  /* Stepper */
  .md-stepper {
    display: none;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: rgba(245,179,1,0.12);
    border: 1.5px solid var(--gold);
    border-radius: 8px;
    overflow: hidden;
  }
  .md-stepper.visible { display: flex; }
  .md-stepper-btn {
    width: 30px;
    height: 32px;
    background: transparent;
    border: none;
    color: var(--gold);
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .md-stepper-btn:hover { background: rgba(245,179,1,0.15); }
  .md-stepper-btn:active { transform: scale(0.85); }
  .md-stepper-qty {
    font-size: 14px;
    font-weight: 800;
    color: var(--white);
    min-width: 20px;
    text-align: center;
  }

  /* ── PEOPLE ALSO ORDERED ── */
  .md-also-section {
    padding: 8px 16px 16px;
  }
  .md-section-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .md-horiz-scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 4px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .md-horiz-scroll::-webkit-scrollbar { display: none; }
  .md-mini-card {
    flex-shrink: 0;
    width: 130px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    cursor: pointer;
    transition: transform 0.2s ease;
  }
  .md-mini-card:active { transform: scale(0.96); }
  .md-mini-card img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    border-radius: 6px;
  }
  .md-mini-card-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--white);
    text-align: center;
    line-height: 1.3;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    width: 100%;
  }
  .md-mini-card-price {
    font-size: 13px;
    font-weight: 800;
    color: var(--gold);
  }
  .md-mini-add-btn {
    width: 100%;
    padding: 5px 0;
    background: var(--gold);
    color: #000;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .md-mini-add-btn:hover { opacity: 0.88; }

  /* ── CART DRAWER ── */
  .md-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .md-backdrop.open { opacity: 1; pointer-events: all; }

  .md-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(420px, 100vw);
    background: #111111;
    border-left: 1px solid var(--border);
    z-index: 201;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    overflow: hidden;
  }
  .md-drawer.open { transform: translateX(0); }

  .md-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .md-drawer-title {
    font-size: 18px;
    font-weight: 800;
  }
  .md-drawer-close {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: none;
    color: var(--white);
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .md-drawer-close:hover { background: rgba(255,255,255,0.15); }

  .md-drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.1) transparent;
  }
  .md-drawer-body::-webkit-scrollbar { width: 4px; }
  .md-drawer-body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 2px; }

  .md-drawer-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 200px;
    gap: 12px;
    color: var(--muted);
    font-size: 14px;
  }
  .md-drawer-empty span:first-child { font-size: 48px; }

  /* Cart Items */
  .md-cart-items { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
  .md-cart-item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--card);
    border-radius: 12px;
    padding: 12px;
    border: 1px solid var(--border);
  }
  .md-cart-item-img {
    width: 52px;
    height: 52px;
    object-fit: contain;
    border-radius: 8px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.04);
  }
  .md-cart-item-info { flex: 1; min-width: 0; }
  .md-cart-item-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--white);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    margin-bottom: 3px;
  }
  .md-cart-item-variant { font-size: 11px; color: var(--muted); margin-bottom: 4px; }
  .md-cart-item-price { font-size: 14px; font-weight: 800; color: var(--gold); }
  .md-cart-item-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }
  .md-cart-remove {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 16px;
    padding: 2px;
    transition: color 0.2s;
  }
  .md-cart-remove:hover { color: var(--red); }
  .md-cart-stepper {
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .md-cart-stepper-btn {
    width: 28px;
    height: 28px;
    background: transparent;
    border: none;
    color: var(--gold);
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .md-cart-stepper-btn:hover { background: rgba(245,179,1,0.12); }
  .md-cart-stepper-qty {
    font-size: 13px;
    font-weight: 800;
    color: var(--white);
    min-width: 22px;
    text-align: center;
  }

  /* Upsell */
  .md-upsell-section { margin-bottom: 20px; }
  .md-upsell-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .md-upsell-scroll {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .md-upsell-scroll::-webkit-scrollbar { display: none; }
  .md-upsell-card {
    flex-shrink: 0;
    width: 110px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .md-upsell-card img {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: 6px;
  }
  .md-upsell-card-name {
    font-size: 11px;
    font-weight: 600;
    color: var(--white);
    text-align: center;
    line-height: 1.3;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    width: 100%;
  }
  .md-upsell-card-price { font-size: 12px; font-weight: 800; color: var(--gold); }
  .md-upsell-add-btn {
    width: 100%;
    padding: 5px 0;
    background: var(--gold);
    color: #000;
    border: none;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 800;
    cursor: pointer;
  }

  /* Combo Deals */
  .md-combo-section { margin-bottom: 20px; }
  .md-combo-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .md-combo-card {
    background: linear-gradient(135deg, rgba(245,179,1,0.1), rgba(245,179,1,0.04));
    border: 1px solid rgba(245,179,1,0.25);
    border-radius: 12px;
    padding: 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .md-combo-text { flex: 1; }
  .md-combo-name { font-size: 13px; font-weight: 700; color: var(--white); margin-bottom: 3px; }
  .md-combo-save { font-size: 12px; color: var(--green); font-weight: 600; }
  .md-combo-add-btn {
    padding: 8px 14px;
    background: var(--gold);
    color: #000;
    border: none;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 800;
    cursor: pointer;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }
  .md-combo-add-btn:hover { opacity: 0.88; }

  /* Totals */
  .md-totals {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 16px;
  }
  .md-totals-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: var(--muted);
    padding: 4px 0;
  }
  .md-totals-row.grand {
    font-size: 16px;
    font-weight: 800;
    color: var(--white);
    border-top: 1px solid var(--border);
    margin-top: 6px;
    padding-top: 10px;
  }
  .md-totals-row.grand span:last-child { color: var(--gold); }

  /* Checkout button in drawer */
  .md-checkout-btn {
    width: 100%;
    padding: 16px;
    background: linear-gradient(135deg, #f5b301, #e8a800);
    color: #000;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 800;
    cursor: pointer;
    letter-spacing: 0.2px;
    transition: opacity 0.2s, transform 0.15s;
    margin-bottom: 8px;
  }
  .md-checkout-btn:hover { opacity: 0.9; }
  .md-checkout-btn:active { transform: scale(0.97); }

  /* ── MINI CART BAR ── */
  .md-mini-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 150;
    background: linear-gradient(135deg, #1a1a1a, #111);
    border-top: 1px solid rgba(245,179,1,0.3);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    box-shadow: 0 -4px 24px rgba(0,0,0,0.6);
  }
  .md-mini-bar.visible { transform: translateY(0); }
  .md-mini-bar-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .md-mini-bar-info {
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
  }
  .md-mini-bar-items { font-size: 12px; color: var(--muted); }
  .md-mini-bar-btn {
    padding: 10px 22px;
    background: var(--gold);
    color: #000;
    border: none;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }
  .md-mini-bar-btn:hover { opacity: 0.88; }

  /* ── CHECKOUT OVERLAY ── */
  .md-checkout-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.9);
    z-index: 500;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .md-checkout-overlay.show { opacity: 1; pointer-events: all; }
  .md-spinner {
    width: 48px;
    height: 48px;
    border: 4px solid rgba(245,179,1,0.2);
    border-top: 4px solid var(--gold);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .md-overlay-text {
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
  }

  /* ── TOAST ── */
  .md-toast {
    position: fixed;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: #222;
    border: 1px solid var(--border);
    color: var(--white);
    font-size: 13px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 24px;
    z-index: 300;
    opacity: 0;
    transition: all 0.3s ease;
    white-space: nowrap;
    pointer-events: none;
  }
  .md-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* ── ANIMATIONS ── */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .md-card {
    animation: fadeSlideUp 0.3s ease forwards;
  }

  /* Stepper bounce */
  @keyframes stepBounce {
    0%,100% { transform: scale(1); }
    40% { transform: scale(1.15); }
    70% { transform: scale(0.92); }
  }
  .md-stepper-btn:active { animation: stepBounce 0.25s ease; }
</style>

<div id="madira-section">

  <!-- STICKY HEADER -->
  <div class="md-header">
    <div class="md-header-top">
      <div>
        <div class="md-header-title">🍾 Madira 24/7 Delivery</div>
        <div class="md-header-sub">⚡ 15 mins delivery in Kathmandu</div>
      </div>
      <div class="md-open-badge">
        <span class="md-open-dot"></span>
        Open Now
      </div>
    </div>
  </div>

  <!-- STICKY TABS -->
  <div class="md-tabs-wrap">
    <div class="md-tabs" id="md-tabs">
      <button class="md-tab active" data-filter="all">All</button>
      {% if has_whisky %}<button class="md-tab" data-filter="whisky">🥃 Whisky</button>{% endif %}
      {% if has_rum %}<button class="md-tab" data-filter="rum">🍫 Rum</button>{% endif %}
      {% if has_beer %}<button class="md-tab" data-filter="beer">🍺 Beer</button>{% endif %}
      {% if has_vodka %}<button class="md-tab" data-filter="vodka">🔵 Vodka</button>{% endif %}
      {% if has_wine %}<button class="md-tab" data-filter="wine">🍷 Wine</button>{% endif %}
      {% if has_other %}<button class="md-tab" data-filter="other">✨ Others</button>{% endif %}
    </div>
  </div>

  <!-- PRODUCT GRID -->
  <div class="md-grid" id="md-grid">
    {% for product in collection.products %}
      {% assign ptype_raw = product.type | downcase %}
      {% if ptype_raw contains 'whisky' or ptype_raw contains 'whiskey' %}
        {% assign ptype_slug = 'whisky' %}
      {% elsif ptype_raw contains 'rum' %}
        {% assign ptype_slug = 'rum' %}
      {% elsif ptype_raw contains 'beer' or ptype_raw contains 'lager' or ptype_raw contains 'ale' or ptype_raw contains 'can' %}
        {% assign ptype_slug = 'beer' %}
      {% elsif ptype_raw contains 'vodka' %}
        {% assign ptype_slug = 'vodka' %}
      {% elsif ptype_raw contains 'wine' %}
        {% assign ptype_slug = 'wine' %}
      {% else %}
        {% assign ptype_slug = 'other' %}
      {% endif %}

      {% assign idx_mod = forloop.index0 | modulo: 3 %}
      {% assign first_variant = product.variants.first %}
      {% assign price_display = first_variant.price | divided_by: 100 %}
      {% assign compare_display = first_variant.compare_at_price | divided_by: 100 %}

      <div class="md-card"
           data-type="{{ ptype_slug }}"
           data-product-id="{{ product.id }}"
           data-variant-id="{{ first_variant.id }}"
           style="animation-delay: {{ forloop.index0 | times: 40 }}ms;">

        <!-- LEFT -->
        <div class="md-card-left">
          {% if idx_mod == 0 %}
            <span class="md-badge gold">🔥 Best Seller</span>
          {% elsif idx_mod == 1 %}
            <span class="md-badge blue">⭐ Popular</span>
          {% else %}
            <span class="md-badge green2">💚 Deal</span>
          {% endif %}

          <div class="md-card-name">{{ product.title }}</div>

          {% if first_variant.title != 'Default Title' %}
            <div class="md-card-volume">{{ first_variant.title }}</div>
          {% endif %}

          <div class="md-card-prices">
            <span class="md-price">Rs {{ price_display }}</span>
            {% if first_variant.compare_at_price > first_variant.price %}
              <span class="md-compare">Rs {{ compare_display }}</span>
              {% assign saved = compare_display | minus: price_display %}
              <span class="md-savings">Save Rs {{ saved }}</span>
            {% endif %}
          </div>
        </div>

        <!-- RIGHT -->
        <div class="md-card-right">
          {% if product.featured_image %}
            <img class="md-product-img"
                 src="{{ product.featured_image | img_url: '160x160' }}"
                 alt="{{ product.title | escape }}"
                 loading="lazy">
          {% else %}
            <div class="md-product-img-placeholder">🍶</div>
          {% endif %}

          <button class="md-add-btn"
                  data-product-id="{{ product.id }}"
                  data-variant-id="{{ first_variant.id }}"
                  onclick="MDCart.addItem('{{ first_variant.id }}', this)">
            + ADD
          </button>
          <div class="md-stepper"
               id="stepper-{{ first_variant.id }}"
               data-variant-id="{{ first_variant.id }}">
            <button class="md-stepper-btn"
                    onclick="MDCart.decItem('{{ first_variant.id }}', this)">−</button>
            <span class="md-stepper-qty" id="qty-{{ first_variant.id }}">1</span>
            <button class="md-stepper-btn"
                    onclick="MDCart.incItem('{{ first_variant.id }}', this)">+</button>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <!-- PEOPLE ALSO ORDERED -->
  <div class="md-also-section" id="md-also-section">
    <div class="md-section-title">🍻 People Also Ordered</div>
    <div class="md-horiz-scroll" id="md-also-scroll"></div>
  </div>

</div>

<!-- CART BACKDROP -->
<div class="md-backdrop" id="md-backdrop" onclick="MDCart.closeDrawer()"></div>

<!-- CART DRAWER -->
<div class="md-drawer" id="md-drawer">
  <div class="md-drawer-header">
    <span class="md-drawer-title">🛒 Your Cart</span>
    <button class="md-drawer-close" onclick="MDCart.closeDrawer()">✕</button>
  </div>
  <div class="md-drawer-body" id="md-drawer-body">
    <div class="md-drawer-empty" id="md-empty-state">
      <span>🛒</span>
      <span>Your cart is empty</span>
    </div>

    <div id="md-cart-content" style="display:none">
      <!-- Cart Items -->
      <div class="md-cart-items" id="md-cart-items"></div>

      <!-- Upsell -->
      <div class="md-upsell-section" id="md-upsell-section">
        <div class="md-upsell-title">🔥 You may also like</div>
        <div class="md-upsell-scroll" id="md-upsell-scroll"></div>
      </div>

      <!-- Combo Deals -->
      <div class="md-combo-section" id="md-combo-section">
        <div class="md-combo-title">🍻 Combo Offer</div>
        <div id="md-combo-cards"></div>
      </div>

      <!-- Totals -->
      <div class="md-totals">
        <div class="md-totals-row">
          <span>Subtotal</span>
          <span id="md-subtotal">Rs 0</span>
        </div>
        <div class="md-totals-row">
          <span>Delivery</span>
          <span style="color:var(--green)">Rs 60</span>
        </div>
        <div class="md-totals-row grand">
          <span>Grand Total</span>
          <span id="md-grand-total">Rs 60</span>
        </div>
      </div>

      <button class="md-checkout-btn" onclick="MDCart.proceedCheckout()">
        Proceed to Checkout →
      </button>
    </div>
  </div>
</div>

<!-- MINI CART BAR -->
<div class="md-mini-bar" id="md-mini-bar">
  <div class="md-mini-bar-left">
    <div class="md-mini-bar-info" id="md-mini-bar-info">🛒 0 items | Rs 0</div>
    <div class="md-mini-bar-items" id="md-mini-bar-sub">Tap to view cart</div>
  </div>
  <button class="md-mini-bar-btn" onclick="MDCart.openDrawer()">View Cart</button>
</div>

<!-- CHECKOUT OVERLAY -->
<div class="md-checkout-overlay" id="md-checkout-overlay">
  <div class="md-spinner"></div>
  <div class="md-overlay-text">Placing your order...</div>
</div>

<!-- TOAST -->
<div class="md-toast" id="md-toast"></div>

<!-- EMBED ALL PRODUCTS AS JSON FOR JS -->
<script>
  window.MD_PRODUCTS = [
    {% for product in collection.products %}
      {
        "id": {{ product.id }},
        "title": {{ product.title | json }},
        "handle": {{ product.handle | json }},
        "type": {{ product.type | json }},
        "url": {{ product.url | json }},
        "image": {% if product.featured_image %}"{{ product.featured_image | img_url: '200x200' }}"{% else %}null{% endif %},
        "price": {{ product.variants.first.price }},
        "compare_at_price": {{ product.variants.first.compare_at_price | default: 0 }},
        "variant_id": {{ product.variants.first.id }},
        "variant_title": {{ product.variants.first.title | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];
</script>

<script>
(function() {
  'use strict';

  // ── UTILITIES ──────────────────────────────────────────────────────────────

  function fmtPrice(paise) {
    return 'Rs ' + Math.round(paise / 100);
  }

  function getTypeSlug(rawType) {
    var t = (rawType || '').toLowerCase();
    if (t.includes('whisky') || t.includes('whiskey')) return 'whisky';
    if (t.includes('rum')) return 'rum';
    if (t.includes('beer') || t.includes('lager') || t.includes('ale') || t.includes('can')) return 'beer';
    if (t.includes('vodka')) return 'vodka';
    if (t.includes('wine')) return 'wine';
    return 'other';
  }

  function showToast(msg) {
    var t = document.getElementById('md-toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(function() { t.classList.remove('show'); }, 2200);
  }

  // ── CART STATE ─────────────────────────────────────────────────────────────

  var cartState = { items: [], item_count: 0, total_price: 0 };

  function getVariantQtyFromCart(variantId) {
    for (var i = 0; i < cartState.items.length; i++) {
      if (String(cartState.items[i].variant_id) === String(variantId)) {
        return cartState.items[i].quantity;
      }
    }
    return 0;
  }

  // ── AJAX HELPERS ───────────────────────────────────────────────────────────

  function ajaxPost(url, data, cb) {
    var xhr = new XMLHttpRequest();
    xhr.open('POST', url, true);
    xhr.setRequestHeader('Content-Type', 'application/json');
    xhr.setRequestHeader('Accept', 'application/json');
    xhr.onreadystatechange = function() {
      if (xhr.readyState === 4) {
        try {
          var res = JSON.parse(xhr.responseText);
          cb(xhr.status, res);
        } catch(e) {
          cb(xhr.status, null);
        }
      }
    };
    xhr.send(JSON.stringify(data));
  }

  function ajaxGet(url, cb) {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', url, true);
    xhr.setRequestHeader('Accept', 'application/json');
    xhr.onreadystatechange = function() {
      if (xhr.readyState === 4) {
        try {
          var res = JSON.parse(xhr.responseText);
          cb(xhr.status, res);
        } catch(e) {
          cb(xhr.status, null);
        }
      }
    };
    xhr.send();
  }

  // ── CART OPERATIONS ────────────────────────────────────────────────────────

  window.MDCart = {

    openDrawer: function() {
      document.getElementById('md-drawer').classList.add('open');
      document.getElementById('md-backdrop').classList.add('open');
      document.body.style.overflow = 'hidden';
    },

    closeDrawer: function() {
      document.getElementById('md-drawer').classList.remove('open');
      document.getElementById('md-backdrop').classList.remove('open');
      document.body.style.overflow = '';
    },

    addItem: function(variantId, btn) {
      ajaxPost('/cart/add.js', { id: variantId, quantity: 1 }, function(status, res) {
        if (status === 200) {
          MDCart.fetchCart(function() {
            var qty = getVariantQtyFromCart(variantId);
            MDCart.syncCardUI(variantId, qty);
            showToast('✓ Added to cart!');
          });
        } else {
          showToast('⚠ Could not add item');
        }
      });
    },

    incItem: function(variantId, btn) {
      var qty = getVariantQtyFromCart(variantId);
      MDCart.updateItem(variantId, qty + 1);
    },

    decItem: function(variantId, btn) {
      var qty = getVariantQtyFromCart(variantId);
      MDCart.updateItem(variantId, Math.max(0, qty - 1));
    },

    updateItem: function(variantId, newQty) {
      ajaxPost('/cart/change.js', { id: String(variantId), quantity: newQty }, function(status, res) {
        if (status === 200) {
          cartState = res;
          var qty = getVariantQtyFromCart(variantId);
          MDCart.syncCardUI(variantId, qty);
          MDCart.renderDrawer();
          MDCart.updateMiniBar();
        }
      });
    },

    fetchCart: function(cb) {
      ajaxGet('/cart.js', function(status, res) {
        if (status === 200 && res) {
          cartState = res;
          MDCart.renderDrawer();
          MDCart.updateMiniBar();
          MDCart.restoreAllCardUIs();
        }
        if (cb) cb();
      });
    },

    syncCardUI: function(variantId, qty) {
      var addBtn = document.querySelector('[data-variant-id="' + variantId + '"].md-add-btn');
      var stepper = document.getElementById('stepper-' + variantId);
      var qtyEl = document.getElementById('qty-' + variantId);
      if (!addBtn || !stepper) return;
      if (qty > 0) {
        addBtn.style.display = 'none';
        stepper.classList.add('visible');
        if (qtyEl) qtyEl.textContent = qty;
      } else {
        addBtn.style.display = '';
        stepper.classList.remove('visible');
      }
    },

    restoreAllCardUIs: function() {
      if (!cartState.items) return;
      cartState.items.forEach(function(item) {
        MDCart.syncCardUI(item.variant_id, item.quantity);
      });
    },

    updateMiniBar: function() {
      var bar = document.getElementById('md-mini-bar');
      var info = document.getElementById('md-mini-bar-info');
      var sub = document.getElementById('md-mini-bar-sub');
      var count = cartState.item_count || 0;
      var total = cartState.total_price || 0;
      if (count > 0) {
        bar.classList.add('visible');
        info.textContent = '🛒 ' + count + (count === 1 ? ' item' : ' items') + ' | ' + fmtPrice(total);
        sub.textContent = 'Tap to view cart';
      } else {
        bar.classList.remove('visible');
      }
    },

    renderDrawer: function() {
      var items = cartState.items || [];
      var emptyEl = document.getElementById('md-empty-state');
      var contentEl = document.getElementById('md-cart-content');
      var itemsEl = document.getElementById('md-cart-items');

      if (items.length === 0) {
        emptyEl.style.display = '';
        contentEl.style.display = 'none';
        return;
      }

      emptyEl.style.display = 'none';
      contentEl.style.display = '';

      // Render items
      itemsEl.innerHTML = '';
      items.forEach(function(item) {
        var itemTotalPaise = item.price * item.quantity;
        var imgHtml = item.image
          ? '<img class="md-cart-item-img" src="' + item.image + '" alt="' + escHtml(item.title) + '">'
          : '<div class="md-cart-item-img" style="display:flex;align-items:center;justify-content:center;font-size:24px;background:rgba(255,255,255,0.04)">🍶</div>';
        var varTitle = (item.variant_title && item.variant_title !== 'Default Title') ? item.variant_title : '';
        itemsEl.insertAdjacentHTML('beforeend',
          '<div class="md-cart-item" data-variant="' + item.variant_id + '">' +
            imgHtml +
            '<div class="md-cart-item-info">' +
              '<div class="md-cart-item-name">' + escHtml(item.title) + '</div>' +
              (varTitle ? '<div class="md-cart-item-variant">' + escHtml(varTitle) + '</div>' : '') +
              '<div class="md-cart-item-price">' + fmtPrice(itemTotalPaise) + '</div>' +
            '</div>' +
            '<div class="md-cart-item-right">' +
              '<button class="md-cart-remove" onclick="MDCart.updateItem(' + item.variant_id + ', 0)">🗑</button>' +
              '<div class="md-cart-stepper">' +
                '<button class="md-cart-stepper-btn" onclick="MDCart.decItem(' + item.variant_id + ')">−</button>' +
                '<span class="md-cart-stepper-qty">' + item.quantity + '</span>' +
                '<button class="md-cart-stepper-btn" onclick="MDCart.incItem(' + item.variant_id + ')">+</button>' +
              '</div>' +
            '</div>' +
          '</div>'
        );
      });

      // Render upsell (3 products not in cart)
      var cartVariantIds = items.map(function(i) { return String(i.variant_id); });
      var notInCart = window.MD_PRODUCTS.filter(function(p) {
        return !cartVariantIds.includes(String(p.variant_id));
      });
      var upsellProds = shuffleArray(notInCart).slice(0, 3);
      var upsellEl = document.getElementById('md-upsell-scroll');
      upsellEl.innerHTML = '';
      if (upsellProds.length > 0) {
        document.getElementById('md-upsell-section').style.display = '';
        upsellProds.forEach(function(p) {
          var imgHtml = p.image
            ? '<img src="' + p.image + '" alt="' + escHtml(p.title) + '">'
            : '<div style="width:48px;height:48px;display:flex;align-items:center;justify-content:center;font-size:22px;background:rgba(255,255,255,0.05);border-radius:6px">🍶</div>';
          upsellEl.insertAdjacentHTML('beforeend',
            '<div class="md-upsell-card">' +
              imgHtml +
              '<div class="md-upsell-card-name">' + escHtml(p.title) + '</div>' +
              '<div class="md-upsell-card-price">' + fmtPrice(p.price) + '</div>' +
              '<button class="md-upsell-add-btn" onclick="MDCart.addItem(' + p.variant_id + ', this)">+ Add</button>' +
            '</div>'
          );
        });
      } else {
        document.getElementById('md-upsell-section').style.display = 'none';
      }

      // Render combo deals
      MDCart.renderCombos(items);

      // Totals
      var subtotal = cartState.total_price || 0;
      var grandTotal = subtotal + 6000; // Rs 60 delivery in paise
      document.getElementById('md-subtotal').textContent = fmtPrice(subtotal);
      document.getElementById('md-grand-total').textContent = fmtPrice(grandTotal);
    },

    renderCombos: function(items) {
      var comboSection = document.getElementById('md-combo-section');
      var comboCards = document.getElementById('md-combo-cards');

      var combos = [
        {
          name: 'Whisky + Beer Bundle',
          desc: 'Save Rs 200 on any Whisky + Beer combo',
          typeA: 'whisky',
          typeB: 'beer',
          save: 200
        },
        {
          name: 'Rum + Cola Mix',
          desc: 'Save Rs 150 on Rum + any mixer',
          typeA: 'rum',
          typeB: 'other',
          save: 150
        }
      ];

      comboCards.innerHTML = '';
      var shown = 0;
      combos.forEach(function(combo) {
        var prodA = window.MD_PRODUCTS.find(function(p) { return getTypeSlug(p.type) === combo.typeA; });
        var prodB = window.MD_PRODUCTS.find(function(p) { return getTypeSlug(p.type) === combo.typeB; });
        if (prodA && prodB) {
          shown++;
          comboCards.insertAdjacentHTML('beforeend',
            '<div class="md-combo-card" style="margin-bottom:10px">' +
              '<div class="md-combo-text">' +
                '<div class="md-combo-name">' + escHtml(combo.name) + '</div>' +
                '<div class="md-combo-save">💰 Save Rs ' + combo.save + '</div>' +
              '</div>' +
              '<button class="md-combo-add-btn" onclick="MDCart.addCombo(' + prodA.variant_id + ',' + prodB.variant_id + ')">Add Both</button>' +
            '</div>'
          );
        }
      });

      comboSection.style.display = shown > 0 ? '' : 'none';
    },

    addCombo: function(varIdA, varIdB) {
      ajaxPost('/cart/add.js', { id: varIdA, quantity: 1 }, function() {
        ajaxPost('/cart/add.js', { id: varIdB, quantity: 1 }, function() {
          MDCart.fetchCart(function() {
            showToast('🍻 Combo added to cart!');
          });
        });
      });
    },

    proceedCheckout: function() {
      var overlay = document.getElementById('md-checkout-overlay');
      overlay.classList.add('show');
      setTimeout(function() {
        window.location.href = '/checkout';
      }, 1500);
    }
  };

  // ── TAB FILTERING ──────────────────────────────────────────────────────────

  function initTabs() {
    var tabs = document.querySelectorAll('.md-tab');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        var filter = tab.getAttribute('data-filter');
        var cards = document.querySelectorAll('.md-card');
        cards.forEach(function(card) {
          if (filter === 'all' || card.getAttribute('data-type') === filter) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });
  }

  // ── PEOPLE ALSO ORDERED ────────────────────────────────────────────────────

  function renderAlsoOrdered() {
    var products = window.MD_PRODUCTS || [];
    if (products.length === 0) {
      document.getElementById('md-also-section').style.display = 'none';
      return;
    }
    var shuffled = shuffleArray(products.slice()).slice(0, 8);
    var scroll = document.getElementById('md-also-scroll');
    scroll.innerHTML = '';
    shuffled.forEach(function(p) {
      var imgHtml = p.image
        ? '<img src="' + p.image + '" alt="' + escHtml(p.title) + '" loading="lazy">'
        : '<div style="width:60px;height:60px;display:flex;align-items:center;justify-content:center;font-size:26px;background:rgba(255,255,255,0.05);border-radius:6px">🍶</div>';
      var card = document.createElement('div');
      card.className = 'md-mini-card';
      card.innerHTML =
        imgHtml +
        '<div class="md-mini-card-name">' + escHtml(p.title) + '</div>' +
        '<div class="md-mini-card-price">' + fmtPrice(p.price) + '</div>' +
        '<button class="md-mini-add-btn" onclick="MDCart.addItem(' + p.variant_id + ', this)">+ Add</button>';
      scroll.appendChild(card);
    });
  }

  // ── HELPERS ────────────────────────────────────────────────────────────────

  function shuffleArray(arr) {
    for (var i = arr.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = arr[i]; arr[i] = arr[j]; arr[j] = tmp;
    }
    return arr;
  }

  function escHtml(str) {
    var d = document.createElement('div');
    d.appendChild(document.createTextNode(str || ''));
    return d.innerHTML;
  }

  // ── INIT ───────────────────────────────────────────────────────────────────

  document.addEventListener('DOMContentLoaded', function() {
    initTabs();
    renderAlsoOrdered();
    MDCart.fetchCart();
  });

})();
</script>

{% schema %}
{
  "name": "Madira Collection",
  "settings": []
}
{% endschema %}
