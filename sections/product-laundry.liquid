            <div class="lb-svc-meta">
              <span class="lb-svc-unit">per pcs</span>
              <span>Suits, silk &amp; delicates</span>
            </div>
          </div>
          <div class="lb-svc-price-col">
            <div class="lb-svc-price" data-price>—</div>
            <div class="lb-svc-price-unit">/pcs</div>
          </div>
          <div class="lb-selected-check">✓</div>
        </div>

        <div class="lb-service-card" data-variant-title="Iron Only (pcs)" data-unit="pcs" tabindex="0" role="radio" aria-checked="false">
          <div class="lb-svc-icon-wrap">🔥</div>
          <div class="lb-svc-info">
            <div class="lb-svc-name">Iron Only</div>
            <div class="lb-svc-meta">
              <span class="lb-svc-unit">per pcs</span>
              <span>Press &amp; crease-free</span>
            </div>
          </div>
          <div class="lb-svc-price-col">
            <div class="lb-svc-price" data-price>—</div>
            <div class="lb-svc-price-unit">/pcs</div>
          </div>
          <div class="lb-selected-check">✓</div>
        </div>

        <div class="lb-service-card" data-variant-title="Bedsheets &amp; Linen (set)" data-unit="set" tabindex="0" role="radio" aria-checked="false">
          <div class="lb-svc-icon-wrap">🛏️</div>
          <div class="lb-svc-info">
            <div class="lb-svc-name">Bedsheets &amp; Linen</div>
            <div class="lb-svc-meta">
              <span class="lb-svc-unit">per set</span>
              <span>Sheets, covers &amp; pillows</span>
            </div>
          </div>
          <div class="lb-svc-price-col">
            <div class="lb-svc-price" data-price>—</div>
            <div class="lb-svc-price-unit">/set</div>
          </div>
          <div class="lb-selected-check">✓</div>
        </div>

      </div>
    </div>

    <!-- STEP 2: QUANTITY -->
    <div class="lb-section" style="margin-top:20px;">
      <div class="lb-section-title">② Quantity</div>
      <div class="lb-qty-box">
        <div class="lb-qty-label">
          <span class="lb-qty-label-main">How many <span id="lb-unit-label">units</span>?</span>
          <span class="lb-qty-label-sub" id="lb-qty-hint">Select a service first</span>
        </div>
        <div class="lb-qty-controls">
          <button class="lb-qty-btn" id="lb-qty-minus" aria-label="Decrease quantity" touch-action="manipulation">−</button>
          <div class="lb-qty-val" id="lb-qty-disp" aria-live="polite">1</div>
          <button class="lb-qty-btn" id="lb-qty-plus" aria-label="Increase quantity">+</button>
        </div>
      </div>
    </div>

    <!-- STEP 3: EXPRESS -->
    <div class="lb-section" style="margin-top:20px;">
      <div class="lb-section-title">③ Express Delivery</div>
      <div class="lb-express-box" id="lb-express" role="switch" aria-checked="false" tabindex="0">
        <div class="lb-express-icon">⚡</div>
        <div class="lb-express-text">
          <div class="lb-express-name">
            Express 6-Hour
            <span class="lb-express-badge">+Rs 80/unit</span>
          </div>
          <div class="lb-express-sub">Priority processing · Done in 6 hours</div>
        </div>
        <div class="lb-toggle"></div>
      </div>
    </div>

    <!-- STEP 4: NOTES -->
    <div class="lb-section" style="margin-top:20px;">
      <div class="lb-section-title">④ Special Instructions <span style="text-transform:none;letter-spacing:0;font-size:11px;color:var(--lb-muted);font-weight:500;">(optional)</span></div>
      <div class="lb-notes-box">
        <div class="lb-notes-top">
          <span class="lb-notes-icon">📝</span>
          <div class="lb-notes-label">Add a note <span>e.g. "Handle delicately"</span></div>
        </div>
        <textarea class="lb-notes-textarea" id="lb-notes" placeholder="Any special requests, stain details, fabric types..." rows="3" maxlength="250"></textarea>
      </div>
    </div>

    <!-- ORDER SUMMARY -->
    <div class="lb-section" style="margin-top:20px;">
      <div class="lb-section-title">Order Summary</div>
      <div class="lb-summary">
        <div class="lb-summary-hdr">Booking Details</div>
        <div class="lb-summary-row">
          <span class="lb-summary-label">Service</span>
          <span class="lb-summary-value" id="lb-sum-service">—</span>
        </div>
        <div class="lb-summary-row">
          <span class="lb-summary-label">Quantity</span>
          <span class="lb-summary-value" id="lb-sum-qty">—</span>
        </div>
        <div class="lb-summary-row">
          <span class="lb-summary-label">Unit Price</span>
          <span class="lb-summary-value" id="lb-sum-unit-price">—</span>
        </div>
        <div class="lb-express-surcharge-row" id="lb-sum-express-row">
          <span>⚡ Express surcharge</span>
          <span id="lb-sum-express-amt">—</span>
        </div>
        <div class="lb-summary-total">
          <span class="lb-summary-total-label">Total</span>
          <span class="lb-summary-total-price" id="lb-sum-total">Rs —</span>
        </div>
      </div>
    </div>

    <!-- DISCLAIMER -->
    <div class="lb-disclaimer">
      📦 Our team will pick up from your address. Final weight / piece count confirmed at pickup.<br>
      Payment collected after service is complete.
    </div>

  </div><!-- /.lb-content -->

</div><!-- /.lb-wrap -->

<!-- STICKY BOTTOM BAR -->
<div class="lb-sticky">
  <div class="lb-sticky-inner">
    <div class="lb-sticky-price">
      <div class="lb-sticky-price-main" id="lb-sticky-price">Rs —</div>
      <div class="lb-sticky-price-sub" id="lb-sticky-price-sub">Select service</div>
    </div>
    <button class="lb-add-btn" id="lb-add-btn" disabled aria-label="Confirm order and go to checkout">
      <span class="lb-add-btn-content">
        <span>✅</span>
        <span id="lb-btn-text">Confirm Order</span>
      </span>
    </button>
  </div>
</div>

<script>
(function () {
  'use strict';

  /* ── CONSTANTS ── */
  var EXPRESS_SURCHARGE = 80; // Rs per unit
  var MAX_QTY = 50;
  var MIN_QTY = 1;

  /* ── VARIANT DATA ── */
  var ALL_VARIANTS = {{ product.variants | json }};

  /* ── STATE ── */
  var state = {
    selectedVariant: null,
    selectedCard:    null,
    qty:             1,
    express:         false,
    notes:           ''
  };

  /* ── ELEMENTS ── */
  var els = {
    services:        document.getElementById('lb-services'),
    cards:           document.querySelectorAll('.lb-service-card'),
    qtyMinus:        document.getElementById('lb-qty-minus'),
    qtyPlus:         document.getElementById('lb-qty-plus'),
    qtyDisp:         document.getElementById('lb-qty-disp'),
    qtyHint:         document.getElementById('lb-qty-hint'),
    unitLabel:       document.getElementById('lb-unit-label'),
    expressBox:      document.getElementById('lb-express'),
    notes:           document.getElementById('lb-notes'),
    addBtn:          document.getElementById('lb-add-btn'),
    btnText:         document.getElementById('lb-btn-text'),
    feedback:        document.getElementById('lb-feedback'),
    stickyPrice:     document.getElementById('lb-sticky-price'),
    stickyPriceSub:  document.getElementById('lb-sticky-price-sub'),
    sumService:      document.getElementById('lb-sum-service'),
    sumQty:          document.getElementById('lb-sum-qty'),
    sumUnitPrice:    document.getElementById('lb-sum-unit-price'),
    sumExpressRow:   document.getElementById('lb-sum-express-row'),
    sumExpressAmt:   document.getElementById('lb-sum-express-amt'),
    sumTotal:        document.getElementById('lb-sum-total')
  };

  /* ══════════════════════════════════
     VARIANT LOOKUP
  ══════════════════════════════════ */
  function cleanStr(s) {
    return String(s)
      .replace(/&amp;/g, '&')
      .replace(/&nbsp;/g, ' ')
      .replace(/\s+/g, ' ')
      .trim()
      .toLowerCase();
  }
  function findVariant(titleMatch) {
    var needle = cleanStr(titleMatch);
    return ALL_VARIANTS.find(function (v) {
      return cleanStr(v.title) === needle ||
             cleanStr(v.option1 || '') === needle;
    }) || null;
  }

  /* ══════════════════════════════════
     PRICE FORMATTING
     Shopify Liquid JSON prices are in subunits (paisa × 100)
  ══════════════════════════════════ */
  function variantRs(variant) {
    if (!variant) return 0;
    // price from {{ product.variants | json }} is integer subunits (e.g. 9900 = Rs 99)
    return Math.round(parseFloat(variant.price) / 100);
  }

  /* Strip trailing unit suffix "(kg)" / "(pcs)" / "(set)" for display */
  function displayTitle(rawTitle) {
    return rawTitle
      .replace(/&amp;/g, '&')
      .replace(/\s*\((kg|pcs|set)\)\s*$/i, '')
      .trim();
  }

  /* ══════════════════════════════════
     INIT — populate prices on cards
  ══════════════════════════════════ */
  function initCards() {
    els.cards.forEach(function (card) {
      var title   = card.getAttribute('data-variant-title');
      var variant = findVariant(title);
      var priceEl = card.querySelector('[data-price]');
      if (variant && priceEl) {
        priceEl.textContent = 'Rs ' + variantRs(variant);
      } else if (priceEl) {
        priceEl.textContent = 'N/A';
      }
    });
  }

  /* ══════════════════════════════════
     SERVICE SELECTION
  ══════════════════════════════════ */
  function selectCard(card) {
    // Deselect all
    els.cards.forEach(function (c) {
      c.classList.remove('selected');
      c.setAttribute('aria-checked', 'false');
    });

    // Select clicked
    card.classList.add('selected');
    card.setAttribute('aria-checked', 'true');

    var title   = card.getAttribute('data-variant-title');
    var unit    = card.getAttribute('data-unit');
    var variant = findVariant(title);

    state.selectedVariant = variant;
    state.selectedCard    = card;

    // Update unit label
    var unitLabel = unit === 'kg' ? 'kg' : unit === 'pcs' ? 'pieces' : 'sets';
    els.unitLabel.textContent = unitLabel;
    els.qtyHint.textContent   = 'Min 1 ' + unit + (unit === 'kg' ? ' (≈ 5–6 garments per kg)' : '');

    // Reset qty to 1 when switching service
    state.qty = 1;
    els.qtyDisp.textContent = '1';

    hideFeedback();
    updateUI();
  }

  /* ══════════════════════════════════
     QUANTITY
  ══════════════════════════════════ */
  function setQty(n) {
    state.qty = Math.min(MAX_QTY, Math.max(MIN_QTY, n));
    els.qtyDisp.textContent = state.qty;
    els.qtyMinus.disabled   = state.qty <= MIN_QTY;
    updateUI();
  }

  /* ══════════════════════════════════
     EXPRESS TOGGLE
  ══════════════════════════════════ */
  function toggleExpress() {
    state.express = !state.express;
    els.expressBox.classList.toggle('active', state.express);
    els.expressBox.setAttribute('aria-checked', String(state.express));
    updateUI();
  }

  /* ══════════════════════════════════
     PRICE CALC
  ══════════════════════════════════ */
  function calcTotal() {
    if (!state.selectedVariant) return null;
    var base     = variantRs(state.selectedVariant) * state.qty;
    var express  = state.express ? EXPRESS_SURCHARGE * state.qty : 0;
    return { base: base, express: express, total: base + express };
  }

  /* ══════════════════════════════════
     UI UPDATE (reactive)
  ══════════════════════════════════ */
  function updateUI() {
    var p = calcTotal();
    var v = state.selectedVariant;
    var unit = state.selectedCard ? state.selectedCard.getAttribute('data-unit') : 'unit';

    if (!v || !p) {
      // No service selected
      els.stickyPrice.textContent    = 'Rs —';
      els.stickyPriceSub.textContent = 'Select service';
      els.addBtn.disabled            = true;
      els.sumService.textContent     = '—';
      els.sumQty.textContent         = '—';
      els.sumUnitPrice.textContent   = '—';
      els.sumTotal.textContent       = 'Rs —';
      els.sumExpressRow.classList.remove('show');
      return;
    }

    // Sticky bar
    els.stickyPrice.textContent    = 'Rs ' + p.total;
    els.stickyPriceSub.textContent = state.qty + ' ' + unit + (state.express ? ' · Express' : '');
    els.addBtn.disabled            = false;

    // Summary rows
    var rawTitle = state.selectedCard.getAttribute('data-variant-title');
    els.sumService.textContent   = displayTitle(rawTitle);
    els.sumQty.textContent       = state.qty + ' ' + unit;
    els.sumUnitPrice.textContent = 'Rs ' + variantRs(v) + '/' + unit;
    els.sumTotal.textContent     = 'Rs ' + p.total;

    if (state.express && p.express > 0) {
      els.sumExpressRow.classList.add('show');
      els.sumExpressAmt.textContent = '+Rs ' + p.express;
    } else {
      els.sumExpressRow.classList.remove('show');
    }
  }

  /* ══════════════════════════════════
     FEEDBACK
  ══════════════════════════════════ */
  function showFeedback(type, msg) {
    els.feedback.className = 'lb-feedback show ' + type;
    els.feedback.innerHTML = (type === 'error' ? '⚠️ ' : '✅ ') + msg;
    els.feedback.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function hideFeedback() {
    els.feedback.className = 'lb-feedback';
    els.feedback.textContent = '';
  }

  /* ══════════════════════════════════
     VALIDATION
  ══════════════════════════════════ */
  function validate() {
    if (!state.selectedVariant) {
      // Flash all cards
      els.cards.forEach(function (c) {
        c.classList.remove('error-flash');
        void c.offsetWidth; // reflow
        c.classList.add('error-flash');
      });
      showFeedback('error', 'Please select a laundry service first.');
      return false;
    }
    if (!state.qty || state.qty < MIN_QTY) {
      showFeedback('error', 'Please enter a valid quantity.');
      return false;
    }
    return true;
  }

  /* ══════════════════════════════════
     ADD TO CART
  ══════════════════════════════════ */
  function setLoading(on) {
    var btn = els.addBtn;
    if (on) {
      btn.classList.add('loading');
      btn.innerHTML = '<span class="lb-spinner"></span><span style="font-size:13px;font-weight:700;letter-spacing:0.3px;">Processing…</span>';
    } else {
      btn.classList.remove('loading');
      btn.innerHTML = '<span class="lb-add-btn-content"><span>✅</span><span id="lb-btn-text">Confirm Order</span></span>';
    }
  }

  function addToCart() {
    if (!validate()) return;

    var rawTitle = state.selectedCard.getAttribute('data-variant-title');
    var unit     = state.selectedCard.getAttribute('data-unit');
    var p        = calcTotal();
    var notes    = (els.notes.value || '').trim();

    var payload = {
      id:         state.selectedVariant.id,
      quantity:   state.qty,
      properties: {
        'Service':        displayTitle(rawTitle),
        'Quantity':       state.qty + ' ' + unit,
        'Express':        state.express ? 'Yes (+Rs ' + p.express + ')' : 'No',
        'Pickup Notes':   notes || 'None',
        '_unit_price_rs': variantRs(state.selectedVariant),
        '_total_rs':      p.total
      }
    };

    setLoading(true);
    hideFeedback();

    fetch('/cart/add.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body:    JSON.stringify(payload)
    })
    .then(function (res) {
      if (!res.ok) throw new Error('Server error ' + res.status);
      return res.json();
    })
    .then(function () {
      // Sync location data to cart note, then go straight to checkout
      if (typeof window.qbSyncCartNote === 'function') {
        window.qbSyncCartNote();
      }
      // Small delay to let cart note update before redirect
      setTimeout(function () {
        window.location.href = '/checkout';
      }, 120);
    })
    .catch(function (err) {
      setLoading(false);
      showFeedback('error', 'Something went wrong. Please try again.');
      console.error('[lb] cart add failed:', err);
    });
  }

  /* ══════════════════════════════════
     EVENT LISTENERS
  ══════════════════════════════════ */
  // Service cards — click & keyboard
  els.cards.forEach(function (card) {
    card.addEventListener('click', function () { selectCard(card); });
    card.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectCard(card); }
    });
  });

  // Qty
  els.qtyMinus.addEventListener('click', function () { setQty(state.qty - 1); });
  els.qtyPlus.addEventListener('click',  function () { setQty(state.qty + 1); });

  // Express
  els.expressBox.addEventListener('click', toggleExpress);
  els.expressBox.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleExpress(); }
  });

  // Notes — just track changes, no state needed beyond reading at submit
  // (reading directly from DOM at submit time)

  // Add to cart
  els.addBtn.addEventListener('click', addToCart);

  /* ══════════════════════════════════
     BOOT
  ══════════════════════════════════ */
  initCards();
  setQty(1); // sets disabled state on minus

})();
</script>

{% schema %}
{
  "name": "Laundry Booking",
  "settings": [],
  "presets": [{ "name": "Laundry Booking" }]
}
{% endschema %}
