          <div class="lb-svc-icon-wrap">🫧</div>
          <div class="lb-svc-info">
            <div class="lb-svc-name">Wash &amp; Fold</div>
            <div class="lb-svc-meta">
              <span class="lb-svc-unit">per kg</span>
              <span>Washed, dried &amp; folded</span>
            </div>
          </div>
          <div class="lb-svc-price-col">
