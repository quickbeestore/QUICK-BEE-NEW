          </div>
          <div class="lb-selected-check">✓</div>
        </div>

        <div class="lb-service-card" data-variant-title="Wash &amp; Fold + Iron (kg)" data-unit="kg" tabindex="0" role="radio" aria-checked="false">
          <div class="lb-svc-icon-wrap">♨️</div>
          <div class="lb-svc-info">
            <div class="lb-svc-name">Wash &amp; Fold + Iron</div>
            <div class="lb-svc-meta">
              <span class="lb-svc-unit">per kg</span>
              <span>Washed, dried &amp; ironed</span>
            </div>
          </div>
          <div class="lb-svc-price-col">
            <div class="lb-svc-price" data-price>—</div>
            <div class="lb-svc-price-unit">/kg</div>
          </div>
