<script>
(function () {
  'use strict';

  var EXPRESS_PER_UNIT = 80;
  var MAX_QTY = 50;
  var MIN_QTY = 1;
  var LS_KEY  = 'qb_laundry_order';

  var ALL_VARIANTS = {{ product.variants | json }};

  /* ── State: { variantTitle → { variant, unit, icon, qty, priceRs } } ── */
  var selections = {};
  var expressOn  = false;

  /* ── Helpers ── */
  function cleanStr(s) {
    return String(s).replace(/&amp;/g,'&').replace(/&nbsp;/g,' ').replace(/\s+/g,' ').trim().toLowerCase();
  }
  function findVariant(title) {
    var needle = cleanStr(title);
    return ALL_VARIANTS.find(function(v) {
      return cleanStr(v.title) === needle || cleanStr(v.option1||'') === needle;
    }) || null;
  }
  function variantRs(v) {
    return v ? Math.round(parseFloat(v.price) / 100) : 0;
  }
  function displayTitle(raw) {
    return raw.replace(/&amp;/g,'&').replace(/\s*\((kg|pcs|set)\)\s*$/i,'').trim();
  }
  function timeAgo(iso) {
    var diff = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
    if (diff < 1) return 'just now';
    if (diff < 60) return diff + ' min ago';
    return Math.floor(diff/60) + 'h ago';
  }

  /* ── localStorage ── */
  function saveOrder(data) {
    try { localStorage.setItem(LS_KEY, JSON.stringify(data)); } catch(_) {}
  }
  function loadOrder() {
    try { return JSON.parse(localStorage.getItem(LS_KEY)||'null'); } catch(_) { return null; }
  }
  function clearOrder() {
    try { localStorage.removeItem(LS_KEY); } catch(_) {}
  }

  /* ── Init: populate prices, wire up card events ── */
  document.querySelectorAll('.lb-service-card').forEach(function(card) {
    var title   = card.getAttribute('data-variant-title');
    var unit    = card.getAttribute('data-unit');
    var variant = findVariant(title);
    var priceEl = card.querySelector('[data-price]');

    if (variant && priceEl) {
      priceEl.innerHTML = 'Rs ' + variantRs(variant) + '<span class="lb-svc-price-unit">/' + unit + '</span>';
    } else if (priceEl) {
      priceEl.textContent = 'N/A';
    }

    /* Tap on card body (not on the stepper buttons) → add with qty 1 */
    card.addEventListener('click', function(e) {
      // Don't re-add if clicking stepper buttons
      if (e.target.closest('.lb-card-qty') || e.target.classList.contains('lb-svc-add-btn')) return;
      if (!card.classList.contains('selected')) {
        addService(card, title, unit, variant);
      }
    });

    /* "+" add button click */
    var addBtn = card.querySelector('.lb-svc-add-btn');
    if (addBtn) {
      addBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        addService(card, title, unit, variant);
      });
    }

    /* Stepper minus */
    var minusBtn = card.querySelector('.lb-cq-minus');
    if (minusBtn) {
      minusBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var key = cleanStr(title);
        if (!selections[key]) return;
        var newQty = selections[key].qty - 1;
        if (newQty < MIN_QTY) {
          // Remove this service
          removeService(card, key);
        } else {
          selections[key].qty = newQty;
          card.querySelector('.lb-card-qty-val').textContent = newQty;
          minusBtn.disabled = newQty <= MIN_QTY;
          updateLinePriceOnCard(card, selections[key]);
          updateSummary();
        }
      });
    }

    /* Stepper plus */
    var plusBtn = card.querySelector('.lb-cq-plus');
    if (plusBtn) {
      plusBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var key = cleanStr(title);
        if (!selections[key]) return;
        if (selections[key].qty >= MAX_QTY) return;
        selections[key].qty++;
        card.querySelector('.lb-card-qty-val').textContent = selections[key].qty;
        card.querySelector('.lb-cq-minus').disabled = false;
        updateLinePriceOnCard(card, selections[key]);
        updateSummary();
      });
    }

    /* keyboard */
    card.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        if (!card.classList.contains('selected')) addService(card, title, unit, variant);
      }
    });
  });

  function addService(card, title, unit, variant) {
    if (!variant) { showFeedback('error', 'Service unavailable. Please refresh.'); return; }
    var key = cleanStr(title);
    if (selections[key]) return; // already selected
    selections[key] = {
      card:         card,
      variant:      variant,
      unit:         unit,
      icon:         card.getAttribute('data-icon') || '🫧',
      displayTitle: displayTitle(title),
      qty:          1,
      priceRs:      variantRs(variant)
    };
    card.classList.add('selected');
    var qv = card.querySelector('.lb-card-qty-val');
    if (qv) qv.textContent = '1';
    var mb = card.querySelector('.lb-cq-minus');
    if (mb) mb.disabled = true; // can't go below 1 (tap minus to remove)
    updateLinePriceOnCard(card, selections[key]);
    hideFeedback();
    updateSummary();
    // Animate the summary panel in
    document.getElementById('lb-live-summary').style.display = 'block';
  }

  function removeService(card, key) {
    delete selections[key];
    card.classList.remove('selected');
    var qv = card.querySelector('.lb-card-qty-val');
    if (qv) qv.textContent = '1';
    var mb = card.querySelector('.lb-cq-minus');
    if (mb) mb.disabled = false;
    // Reset price display
    var variant = findVariant(card.getAttribute('data-variant-title'));
    var unit    = card.getAttribute('data-unit');
    var priceEl = card.querySelector('[data-price]');
    if (priceEl && variant) {
      priceEl.innerHTML = 'Rs ' + variantRs(variant) + '<span class="lb-svc-price-unit">/' + unit + '</span>';
    }
    updateSummary();
  }

  function updateLinePriceOnCard(card, sel) {
    // Show line total (qty × price) on card while selected
    var lineTotal = sel.qty * sel.priceRs;
    var priceEl = card.querySelector('[data-price]');
    if (priceEl) {
      priceEl.innerHTML = '<span style="font-size:11px;font-weight:500;color:var(--lb-muted);">' + sel.qty + ' × Rs ' + sel.priceRs + '</span><br>Rs ' + lineTotal;
    }
  }

  /* ── Express ── */
  var expressBox = document.getElementById('lb-express');
  expressBox.addEventListener('click', function() {
    expressOn = !expressOn;
    expressBox.classList.toggle('active', expressOn);
    expressBox.setAttribute('aria-checked', String(expressOn));
    updateSummary();
  });
  expressBox.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); expressBox.click(); }
  });

  /* ── Live Summary update ── */
  function calcTotals() {
    var subtotal = 0;
    Object.keys(selections).forEach(function(key) {
      var s = selections[key];
      subtotal += s.qty * s.priceRs;
    });
    var expressSurcharge = expressOn ? subtotal * 0 + Object.values(selections).reduce(function(acc, s) {
      return acc + s.qty * EXPRESS_PER_UNIT;
    }, 0) : 0;
    return { subtotal: subtotal, express: expressSurcharge, total: subtotal + expressSurcharge };
  }

  function updateSummary() {
    var keys   = Object.keys(selections);
    var totals = calcTotals();
    var count  = keys.length;

    var summaryEl   = document.getElementById('lb-live-summary');
    var itemsEl     = document.getElementById('lb-ls-items');
    var countEl     = document.getElementById('lb-ls-count');
    var expressRow  = document.getElementById('lb-ls-express-row');
    var expressAmt  = document.getElementById('lb-ls-express-amt');
    var totalEl     = document.getElementById('lb-ls-total');
    var stickyPrice = document.getElementById('lb-sticky-price');
    var stickySub   = document.getElementById('lb-sticky-price-sub');
    var addBtn      = document.getElementById('lb-add-btn');
    var btnText     = document.getElementById('lb-btn-text');

    if (count === 0) {
      summaryEl.style.display = 'none';
    } else {
      summaryEl.style.display = 'block';
    }

    // Count
    countEl.textContent = count + (count === 1 ? ' item' : ' items');

    // Build item rows
    itemsEl.innerHTML = '';
    keys.forEach(function(key) {
      var s   = selections[key];
      var row = document.createElement('div');
      row.className = 'lb-ls-item';
      row.innerHTML =
        '<span class="lb-ls-item-icon">' + s.icon + '</span>' +
        '<span class="lb-ls-item-name">' + s.displayTitle + '</span>' +
        '<span class="lb-ls-item-qty">' + s.qty + ' ' + s.unit + '</span>' +
        '<span class="lb-ls-item-price">Rs ' + (s.qty * s.priceRs) + '</span>' +
        '<button class="lb-ls-item-remove" data-key="' + key + '" type="button" aria-label="Remove">✕</button>';
      itemsEl.appendChild(row);
    });

    // Remove buttons in summary
    itemsEl.querySelectorAll('.lb-ls-item-remove').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var k = btn.getAttribute('data-key');
        if (selections[k]) removeService(selections[k].card, k);
      });
    });

    // Express row
    if (expressOn && totals.express > 0) {
      expressRow.classList.add('show');
      expressAmt.textContent = '+Rs ' + totals.express;
    } else {
      expressRow.classList.remove('show');
    }

    // Total
    totalEl.textContent = 'Rs ' + totals.total;

    // Sticky bar
    if (count === 0) {
      stickyPrice.textContent = 'Rs 0';
      stickySub.textContent   = 'Select services';
      addBtn.disabled = true;
    } else {
      stickyPrice.textContent = 'Rs ' + totals.total;
      stickySub.textContent   = count + (count===1?' service':' services') + (expressOn ? ' · Express' : '');
      addBtn.disabled = false;
    }

    // Button always says Confirm Order
    if (btnText) btnText.textContent = 'Confirm Order';
  }

  /* ── Feedback ── */
  function showFeedback(type, msg) {
    var el = document.getElementById('lb-feedback');
    el.className = 'lb-feedback show ' + type;
    el.innerHTML = (type==='error'?'⚠️ ':'✅ ') + msg;
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function hideFeedback() {
    var el = document.getElementById('lb-feedback');
    el.className = 'lb-feedback';
    el.textContent = '';
  }

  /* ── Add to Cart (bulk) ── */
  function removeCartKeys(keys, cb) {
    if (!keys || !keys.length) { cb(); return; }
    var promises = keys.map(function(key) {
      return fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: 0 })
      }).catch(function(){});
    });
    Promise.all(promises).then(cb).catch(cb);
  }

  function setLoading(on) {
    var btn = document.getElementById('lb-add-btn');
    if (on) {
      btn.classList.add('loading');
      btn.innerHTML = '<span class="lb-spinner"></span><span style="font-size:13px;font-weight:700;letter-spacing:0.3px;">Processing…</span>';
    } else {
      btn.classList.remove('loading');
      btn.innerHTML = '<span class="lb-add-btn-content"><span>✅</span><span id="lb-btn-text">Confirm Order</span></span>';
    }
  }

  function doCartAdd() {
    var keys = Object.keys(selections);
    if (!keys.length) { showFeedback('error', 'Please select at least one service.'); return; }

    var notes   = (document.getElementById('lb-notes').value || '').trim();
    var totals  = calcTotals();

    var items = keys.map(function(key) {
      var s = selections[key];
      return {
        id:         s.variant.id,
        quantity:   s.qty,
        properties: {
          'Service':      s.displayTitle,
          'Quantity':     s.qty + ' ' + s.unit,
          'Express':      expressOn ? 'Yes (+Rs ' + (s.qty * EXPRESS_PER_UNIT) + ')' : 'No',
          'Pickup Notes': notes || 'None'
        }
      };
    });

    fetch('/cart/add.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body:    JSON.stringify({ items: items })
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Server error ' + res.status);
      return res.json();
    })
    .then(function(data) {
      var addedItems = data.items || [];
      var cartKeys   = addedItems.map(function(i) { return i.key || ''; }).filter(Boolean);

      // Build saved items array for localStorage
      var savedItems = keys.map(function(key, idx) {
        var s = selections[key];
        return {
          variantTitle: key,
          displayTitle: s.displayTitle,
          unit:         s.unit,
          icon:         s.icon,
          qty:          s.qty,
          priceRs:      s.priceRs,
          lineTotal:    s.qty * s.priceRs
        };
      });

      saveOrder({
        version:   2,
        cartKeys:  cartKeys,
        items:     savedItems,
        express:   expressOn,
        expressTotal: totals.express,
        notes:     notes,
        subtotal:  totals.subtotal,
        total:     totals.total,
        addedAt:   new Date().toISOString()
      });

      if (typeof window.qbSyncCartNote === 'function') window.qbSyncCartNote();
      showSuccessOverlay(function() { window.location.href = '/checkout'; });
    })
    .catch(function(err) {
      setLoading(false);
      showFeedback('error', 'Something went wrong. Please try again.');
      console.error('[lb] cart add failed:', err);
    });
  }

  document.getElementById('lb-add-btn').addEventListener('click', function(e) {
    if (Object.keys(selections).length === 0) {
      document.querySelectorAll('.lb-service-card').forEach(function(c) {
        c.classList.remove('error-flash');
        void c.offsetWidth;
        c.classList.add('error-flash');
      });
      showFeedback('error', 'Please select at least one service first.');
      return;
    }

    // Ripple animation
    var btn = this;
    var ripple = document.createElement('span');
    ripple.className = 'lb-ripple';
    var rect = btn.getBoundingClientRect();
    ripple.style.left = (e.clientX - rect.left) + 'px';
    ripple.style.top  = (e.clientY - rect.top) + 'px';
    btn.appendChild(ripple);
    setTimeout(function() { if (ripple.parentNode) ripple.parentNode.removeChild(ripple); }, 600);

    hideFeedback();
    setLoading(true);

    // Silently clear any previous cart items before adding fresh ones
    var existing = loadOrder();
    if (existing && existing.cartKeys && existing.cartKeys.length) {
      removeCartKeys(existing.cartKeys, function() {
        clearOrder();
        doCartAdd();
      });
    } else {
      doCartAdd();
    }
  });

  /* ════════════════════════════════════
     SUCCESS OVERLAY ANIMATION
  ════════════════════════════════════ */
  function showSuccessOverlay(cb) {
    var overlay = document.getElementById('lb-success-overlay');
    var bar     = document.getElementById('lb-success-bar');
    if (!overlay) { setTimeout(cb, 400); return; }

    // Show overlay + animate card in
    overlay.classList.add('show');

    // Start progress bar fill slightly after overlay appears
    setTimeout(function() {
      if (bar) bar.style.width = '100%';
    }, 200);

    // Navigate once bar finishes (1.6s transition + 0.2s delay + small buffer)
    setTimeout(cb, 2100);
  }

  /* ── Boot ── */
  updateSummary();

})();
</script>

