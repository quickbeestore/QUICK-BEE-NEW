{% comment %} QuickBee — Laundry Service Booking Page v2 (Multi-Select) {% endcomment %}

{%- assign variants_json = product.variants | json -%}

<style>
/* ═══════════════════════════════════════════════
   LAUNDRY BOOKING v2 — Multi-Select + Live Summary
   QuickBee × KapadaWash
═══════════════════════════════════════════════ */
:root {
  --lb-red:      #C41E3A;
  --lb-red-dark: #9b1226;
  --lb-gold:     #F4B400;
  --lb-gold-dim: rgba(244,180,0,0.12);
  --lb-bg:       #f4f4f4;
  --lb-card:     #ffffff;
  --lb-border:   #e8e8e8;
  --lb-text:     #0d0d0d;
  --lb-muted:    #777;
  --lb-radius:   16px;
}
[data-theme="dark"] {
  --lb-bg:    #0a0a0a;
  --lb-card:  #141414;
  --lb-border:#222;
  --lb-text:  #f0f0f0;
  --lb-muted: #555;
}

.lb-wrap {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: var(--lb-bg);
  min-height: 100vh;
  padding-bottom: calc(145px + env(safe-area-inset-bottom));
  -webkit-tap-highlight-color: transparent;
  color: var(--lb-text);
}
.lb-wrap *, .lb-wrap *::before, .lb-wrap *::after {
  box-sizing: border-box; margin: 0; padding: 0;
}

/* ── HERO ── */
.lb-hero {
  background: linear-gradient(145deg, #0d0d0d 0%, #141414 55%, #1a1000 100%);
  padding: 36px 20px 52px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.lb-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 90% 70% at 50% 120%, rgba(244,180,0,0.22) 0%, transparent 65%);
  pointer-events: none;
}
.lb-hero-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--lb-gold-dim); border: 1px solid rgba(244,180,0,0.3);
  color: var(--lb-gold); font-size: 11px; font-weight: 700;
  letter-spacing: 0.8px; text-transform: uppercase;
  padding: 5px 14px; border-radius: 20px; margin-bottom: 16px;
  position: relative; z-index: 1;
}
.lb-hero-icon {
  font-size: 58px; display: block; margin-bottom: 12px;
  position: relative; z-index: 1;
  animation: lb-float 3.5s ease-in-out infinite;
}
@keyframes lb-float {
  0%,100% { transform: translateY(0) rotate(-4deg); }
  50%      { transform: translateY(-8px) rotate(4deg); }
}
.lb-hero-title {
  font-size: 26px; font-weight: 900; color: #fff;
  line-height: 1.15; letter-spacing: -0.5px;
  position: relative; z-index: 1; margin-bottom: 8px;
}
.lb-hero-title span { color: var(--lb-gold); }
.lb-hero-sub {
  font-size: 13px; color: rgba(255,255,255,0.55);
  position: relative; z-index: 1; line-height: 1.5;
}

/* ── TRUST PILLS ── */
.lb-trust-row {
  display: flex; gap: 8px; overflow-x: auto;
  padding: 14px 16px; scrollbar-width: none;
}
.lb-trust-row::-webkit-scrollbar { display: none; }
.lb-trust-pill {
  flex-shrink: 0; display: inline-flex; align-items: center; gap: 5px;
  background: var(--lb-card); border: 1px solid var(--lb-border);
  border-radius: 20px; padding: 6px 12px; font-size: 11px;
  font-weight: 600; color: var(--lb-text); white-space: nowrap;
}

/* ── SECTION LABEL ── */
.lb-section { padding: 0 16px; margin-bottom: 16px; }
.lb-section-title {
  font-size: 13px; font-weight: 800; color: var(--lb-muted);
  text-transform: uppercase; letter-spacing: 0.7px; margin-bottom: 12px;
  display: flex; align-items: center; gap: 6px;
}
.lb-section-title::after {
  content: ''; flex: 1; height: 1px; background: var(--lb-border);
}

/* ════════════════════════════════════
   SERVICE CARDS — Multi-select with inline qty
════════════════════════════════════ */
.lb-services-grid {
  display: flex; flex-direction: column; gap: 10px;
}
.lb-service-card {
  display: flex; align-items: center; gap: 12px;
  background: var(--lb-card); border: 2px solid var(--lb-border);
  border-radius: var(--lb-radius); padding: 12px 14px;
  cursor: pointer; transition: border-color 0.18s ease, transform 0.15s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.18s ease;
  -webkit-tap-highlight-color: transparent; user-select: none;
  position: relative; overflow: hidden;
}
.lb-service-card::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(244,180,0,0) 0%, rgba(244,180,0,0.04) 100%);
  opacity: 0; transition: opacity 0.2s ease; pointer-events: none;
}
.lb-service-card:active { transform: scale(0.97); }
.lb-service-card.selected {
  border-color: var(--lb-gold);
  box-shadow: 0 0 0 3px rgba(244,180,0,0.15), 0 4px 16px rgba(0,0,0,0.1);
}
.lb-service-card.selected::before { opacity: 1; }
[data-theme="dark"] .lb-service-card.selected {
  box-shadow: 0 0 0 3px rgba(244,180,0,0.2), 0 4px 20px rgba(0,0,0,0.5);
}
.lb-service-card.selected .lb-svc-icon-wrap {
  background: var(--lb-gold); color: #000;
}
.lb-service-card.error-flash {
  animation: lb-error-flash 0.5s ease;
}
@keyframes lb-error-flash {
  0%,100% { border-color: var(--lb-border); }
  25%,75%  { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,0.2); }
}

.lb-svc-icon-wrap {
  width: 46px; height: 46px; background: var(--lb-gold-dim);
  border-radius: 13px; display: flex; align-items: center;
  justify-content: center; font-size: 22px; flex-shrink: 0;
  transition: background 0.2s, color 0.2s;
}
.lb-svc-info { flex: 1; min-width: 0; }
.lb-svc-name {
  font-size: 14px; font-weight: 800; color: var(--lb-text);
  margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.lb-svc-meta {
  font-size: 11px; color: var(--lb-muted);
  display: flex; align-items: center; gap: 6px;
}
.lb-svc-unit {
  background: var(--lb-gold-dim); color: var(--lb-gold);
  padding: 2px 7px; border-radius: 8px;
  font-weight: 700; font-size: 10px;
}

/* ── Right side of card (price + add/qty) ── */
.lb-svc-right {
  display: flex; flex-direction: column;
  align-items: flex-end; gap: 6px; flex-shrink: 0;
}
.lb-svc-price-line {
  font-size: 15px; font-weight: 900; color: var(--lb-text);
  line-height: 1; text-align: right;
}
.lb-svc-price-unit {
  font-size: 10px; color: var(--lb-muted); font-weight: 500;
}

/* ── ADD button (shown when unselected) ── */
.lb-svc-add-btn {
  width: 34px; height: 34px;
  background: var(--lb-gold); color: #000;
  border: none; border-radius: 50%;
  font-size: 22px; font-weight: 300; line-height: 1;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), background 0.15s;
  flex-shrink: 0;
}
.lb-svc-add-btn:active { transform: scale(0.9); }
.lb-service-card.selected .lb-svc-add-btn { display: none; }

/* ── Inline qty stepper (shown when selected) ── */
.lb-card-qty {
  display: none; /* hidden by default */
  align-items: center;
  background: rgba(244,180,0,0.1);
  border: 1.5px solid rgba(244,180,0,0.35);
  border-radius: 12px;
  overflow: hidden;
}
.lb-service-card.selected .lb-card-qty { display: flex; }

.lb-card-qty-btn {
  width: 34px; height: 34px; background: transparent; border: none;
  font-size: 20px; font-weight: 400; color: #c68a00;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: background 0.15s;
  touch-action: manipulation; -webkit-tap-highlight-color: transparent;
  flex-shrink: 0;
}
[data-theme="dark"] .lb-card-qty-btn { color: var(--lb-gold); }
.lb-card-qty-btn:active { background: rgba(244,180,0,0.2); }
.lb-card-qty-btn:disabled { opacity: 0.35; cursor: not-allowed; }
.lb-card-qty-val {
  min-width: 28px; text-align: center;
  font-size: 15px; font-weight: 900; color: var(--lb-text);
  line-height: 34px; user-select: none;
  border-left: 1px solid rgba(244,180,0,0.3);
  border-right: 1px solid rgba(244,180,0,0.3);
}

/* Selected price shows line total */
.lb-service-card.selected .lb-svc-price-line {
  color: var(--lb-gold);
}

/* ════════════════════════════════════
   LIVE ORDER SUMMARY
════════════════════════════════════ */
.lb-live-summary {
  margin: 0 16px 4px;
  border-radius: var(--lb-radius);
  overflow: hidden;
  border: 1.5px solid rgba(34,197,94,0.35);
  background: var(--lb-card);
  animation: lb-co-in 0.35s cubic-bezier(0.4,0,0.2,1) both;
  transition: all 0.25s ease;
}
@keyframes lb-co-in {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Header row */
.lb-ls-header {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 14px;
  background: rgba(34,197,94,0.07);
  border-bottom: 1px solid rgba(34,197,94,0.2);
}
.lb-ls-dot {
  width: 8px; height: 8px; background: #22c55e; border-radius: 50%;
  flex-shrink: 0; animation: lb-co-pulse 2s ease-in-out infinite;
}
@keyframes lb-co-pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
  50%      { box-shadow: 0 0 0 5px rgba(34,197,94,0); }
}
.lb-ls-title {
  font-size: 12px; font-weight: 800; color: #16a34a;
  text-transform: uppercase; letter-spacing: 0.5px; flex: 1;
}
[data-theme="dark"] .lb-ls-title { color: #4ade80; }
.lb-ls-count {
  font-size: 11px; font-weight: 700;
  background: rgba(34,197,94,0.15); color: #16a34a;
  padding: 2px 8px; border-radius: 10px;
}
[data-theme="dark"] .lb-ls-count { color: #4ade80; background: rgba(34,197,94,0.1); }

/* Empty state */
.lb-ls-empty {
  padding: 16px 14px;
  font-size: 13px; color: var(--lb-muted);
  text-align: center; line-height: 1.5;
}

/* Item rows */
.lb-ls-items { padding: 2px 0; }
.lb-ls-item {
  display: flex; align-items: center; gap: 8px;
  padding: 9px 14px;
  border-bottom: 1px solid var(--lb-border);
  animation: lb-item-in 0.25s cubic-bezier(0.4,0,0.2,1) both;
  transition: opacity 0.2s, transform 0.2s;
}
@keyframes lb-item-in {
  from { opacity: 0; transform: translateX(-8px); }
  to   { opacity: 1; transform: translateX(0); }
}
.lb-ls-item:last-child { border-bottom: none; }
.lb-ls-item-icon { font-size: 18px; flex-shrink: 0; }
.lb-ls-item-name {
  flex: 1; font-size: 13px; font-weight: 700; color: var(--lb-text);
}
.lb-ls-item-qty {
  font-size: 11px; color: var(--lb-muted); font-weight: 500;
}
.lb-ls-item-price {
  font-size: 14px; font-weight: 900; color: var(--lb-text); text-align: right;
}
.lb-ls-item-remove {
  background: none; border: none; cursor: pointer;
  color: #ef4444; font-size: 14px; padding: 2px 4px;
  opacity: 0.6; transition: opacity 0.15s;
  flex-shrink: 0;
}
.lb-ls-item-remove:hover { opacity: 1; }

/* Express + Total rows */
.lb-ls-express-row {
  display: none; padding: 8px 14px;
  border-top: 1px solid var(--lb-border);
}
.lb-ls-express-row.show {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 12px; color: #f97316; font-weight: 600;
}
.lb-ls-total-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12px 14px;
  background: var(--lb-gold-dim);
  border-top: 1.5px solid rgba(244,180,0,0.25);
}
.lb-ls-total-label {
  font-size: 13px; font-weight: 800; color: var(--lb-text);
}
.lb-ls-total-price {
  font-size: 22px; font-weight: 900; color: var(--lb-text);
  letter-spacing: -0.5px;
}

/* ── BUTTON RIPPLE ── */
.lb-ripple {
  position: absolute;
  width: 12px; height: 12px;
  background: rgba(255,255,255,0.45);
  border-radius: 50%;
  transform: translate(-50%, -50%) scale(0);
  animation: lb-ripple-expand 0.55s ease-out forwards;
  pointer-events: none;
}
@keyframes lb-ripple-expand {
  to { transform: translate(-50%, -50%) scale(22); opacity: 0; }
}

/* ── CONFIRM SUCCESS OVERLAY ── */
.lb-success-overlay {
  position: fixed; inset: 0; z-index: 99999;
  background: rgba(0,0,0,0);
  display: flex; align-items: center; justify-content: center;
  pointer-events: none;
  transition: background 0.38s ease, backdrop-filter 0.38s ease;
}
.lb-success-overlay.show {
  background: rgba(0,0,0,0.6);
  pointer-events: all;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.lb-success-card {
  background: #fff;
  border-radius: 28px;
  padding: 40px 28px 32px;
  text-align: center;
  max-width: 292px; width: 88%;
  transform: scale(0.72) translateY(28px);
  opacity: 0;
  transition: transform 0.48s cubic-bezier(0.34,1.56,0.64,1) 0.08s,
              opacity 0.3s ease 0.08s;
  box-shadow: 0 28px 72px rgba(0,0,0,0.35);
}
[data-theme="dark"] .lb-success-card {
  background: #141414;
  border: 1px solid #2a2a2a;
}
.lb-success-overlay.show .lb-success-card {
  transform: scale(1) translateY(0);
  opacity: 1;
}
.lb-success-bee {
  font-size: 70px; display: block; line-height: 1;
  transform: scale(0) rotate(-15deg);
  transition: transform 0.6s cubic-bezier(0.34,1.56,0.64,1) 0.25s;
}
.lb-success-overlay.show .lb-success-bee {
  transform: scale(1) rotate(0deg);
}
.lb-success-rings {
  position: relative; display: inline-block;
  margin-bottom: 4px;
}
.lb-success-rings::before, .lb-success-rings::after {
  content: '';
  position: absolute; inset: -8px;
  border-radius: 50%; border: 2px solid rgba(34,197,94,0.3);
  animation: none;
}
.lb-success-overlay.show .lb-success-rings::before {
  animation: lb-ring-expand 1.4s ease-out 0.5s infinite;
}
.lb-success-overlay.show .lb-success-rings::after {
  animation: lb-ring-expand 1.4s ease-out 0.8s infinite;
}
@keyframes lb-ring-expand {
  0%   { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(2.2); opacity: 0; }
}
.lb-success-title {
  font-size: 22px; font-weight: 900;
  color: #0d0d0d; margin: 16px 0 6px; letter-spacing: -0.4px;
  opacity: 0; transform: translateY(8px);
  transition: opacity 0.35s ease 0.42s, transform 0.4s ease 0.42s;
}
[data-theme="dark"] .lb-success-title { color: #f0f0f0; }
.lb-success-overlay.show .lb-success-title {
  opacity: 1; transform: translateY(0);
}
.lb-success-sub {
  font-size: 13px; color: #777; margin-bottom: 22px;
  font-weight: 500;
  opacity: 0;
  transition: opacity 0.35s ease 0.52s;
}
.lb-success-overlay.show .lb-success-sub { opacity: 1; }
.lb-success-bar-wrap {
  height: 5px; background: #f0f0f0; border-radius: 3px; overflow: hidden;
}
[data-theme="dark"] .lb-success-bar-wrap { background: #222; }
.lb-success-bar {
  height: 100%; width: 0%;
  background: linear-gradient(90deg, #22c55e, #16a34a);
  border-radius: 3px;
  transition: width 1.6s cubic-bezier(0.4, 0, 0.2, 1) 0.45s;
}

/* ── EXPRESS TOGGLE ── */
.lb-express-box {
  background: var(--lb-card); border: 1.5px solid var(--lb-border);
  border-radius: var(--lb-radius); padding: 14px 16px;
  display: flex; align-items: center; gap: 14px;
  cursor: pointer; transition: border-color 0.2s ease;
  -webkit-tap-highlight-color: transparent; user-select: none;
}
.lb-express-box.active {
  border-color: #f97316; background: rgba(249,115,22,0.04);
}
[data-theme="dark"] .lb-express-box.active { background: rgba(249,115,22,0.06); }
.lb-express-icon {
  width: 44px; height: 44px; background: rgba(249,115,22,0.1);
  border-radius: 12px; display: flex; align-items: center;
  justify-content: center; font-size: 22px; flex-shrink: 0; transition: background 0.2s;
}
.lb-express-box.active .lb-express-icon { background: #f97316; }
.lb-express-text { flex: 1; }
.lb-express-name {
  font-size: 14px; font-weight: 800; color: var(--lb-text);
  display: flex; align-items: center; gap: 6px; margin-bottom: 2px;
}
.lb-express-badge {
  font-size: 10px; font-weight: 700; background: #f97316;
  color: #fff; padding: 2px 7px; border-radius: 8px; letter-spacing: 0.3px;
}
.lb-express-sub { font-size: 11px; color: var(--lb-muted); }
.lb-toggle {
  width: 48px; height: 26px; background: #ddd; border-radius: 13px;
  position: relative; flex-shrink: 0; transition: background 0.2s ease; pointer-events: none;
}
[data-theme="dark"] .lb-toggle { background: #333; }
.lb-express-box.active .lb-toggle { background: #f97316; }
.lb-toggle::after {
  content: ''; position: absolute; top: 3px; left: 3px;
  width: 20px; height: 20px; background: #fff; border-radius: 50%;
  transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1);
  box-shadow: 0 1px 4px rgba(0,0,0,0.2);
}
.lb-express-box.active .lb-toggle::after { transform: translateX(22px); }

/* ── NOTES ── */
.lb-notes-box {
  background: var(--lb-card); border: 1.5px solid var(--lb-border);
  border-radius: var(--lb-radius); overflow: hidden; transition: border-color 0.2s;
}
.lb-notes-box:focus-within {
  border-color: var(--lb-gold); box-shadow: 0 0 0 3px rgba(244,180,0,0.1);
}
.lb-notes-top {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 16px; border-bottom: 1px solid var(--lb-border);
}
.lb-notes-icon { font-size: 18px; flex-shrink: 0; }
.lb-notes-label { font-size: 13px; font-weight: 700; color: var(--lb-text); }
.lb-notes-label span { font-size: 11px; font-weight: 500; color: var(--lb-muted); margin-left: 4px; }
.lb-notes-textarea {
  width: 100%; padding: 12px 16px; background: transparent; border: none;
  font-size: 13px; color: var(--lb-text); line-height: 1.5; resize: none;
  min-height: 80px; font-family: inherit;
}
.lb-notes-textarea:focus { outline: none; }
.lb-notes-textarea::placeholder { color: var(--lb-muted); }

/* ── FEEDBACK ── */
.lb-feedback {
  border-radius: 12px; padding: 12px 14px; font-size: 13px;
  font-weight: 600; display: none; align-items: center; gap: 8px;
}
.lb-feedback.show { display: flex; }
.lb-feedback.error {
  background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444;
}
.lb-feedback.success {
  background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: #22c55e;
}

/* ── STICKY BOTTOM BAR ── */
.lb-sticky {
  position: fixed; bottom: calc(65px + env(safe-area-inset-bottom));
  left: 0; right: 0; z-index: 10001;
  padding: 12px 16px; background: #fff;
  border-top: 1.5px solid #ebebeb;
  box-shadow: 0 -8px 32px rgba(0,0,0,0.08);
}
[data-theme="dark"] .lb-sticky {
  background: #111; border-top-color: #222;
  box-shadow: 0 -8px 32px rgba(0,0,0,0.5);
}
.lb-sticky-inner {
  display: flex; align-items: center; gap: 14px;
  max-width: 640px; margin: 0 auto;
}
.lb-sticky-price { flex-shrink: 0; min-width: 90px; }
.lb-sticky-price-main {
  font-size: 21px; font-weight: 900; color: var(--lb-text);
  letter-spacing: -0.5px; line-height: 1;
}
.lb-sticky-price-sub {
  font-size: 10.5px; color: var(--lb-muted); margin-top: 3px; font-weight: 500;
}
.lb-add-btn {
  flex: 1; height: 54px;
  background: linear-gradient(135deg, #ff1f35 0%, #C41E3A 55%, #9b1226 100%);
  color: #fff; border: none; border-radius: 16px; font-size: 15px;
  font-weight: 900; letter-spacing: 0.6px; text-transform: uppercase;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  gap: 8px; position: relative; overflow: hidden;
  box-shadow: 0 6px 20px rgba(196,30,58,0.4), inset 0 1px 0 rgba(255,255,255,0.15);
  transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease;
  -webkit-tap-highlight-color: transparent;
}
.lb-add-btn::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 45%;
  background: linear-gradient(to bottom, rgba(255,255,255,0.18), transparent);
  border-radius: 16px 16px 0 0; pointer-events: none;
}
.lb-add-btn::after {
  content: ''; position: absolute; top: 0; left: -80%; width: 55%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  animation: lb-btn-shine 3s ease 0.6s infinite; pointer-events: none;
}
@keyframes lb-btn-shine { 0% { left: -60%; } 55%,100% { left: 120%; } }
.lb-add-btn:not(:disabled) { animation: lb-btn-ready 2.5s ease-in-out infinite; }
@keyframes lb-btn-ready {
  0%,100% { box-shadow: 0 6px 20px rgba(196,30,58,0.4), inset 0 1px 0 rgba(255,255,255,0.15); }
  50%      { box-shadow: 0 8px 28px rgba(196,30,58,0.6), inset 0 1px 0 rgba(255,255,255,0.15); }
}
.lb-add-btn:active:not(:disabled) { transform: scale(0.97); animation: none; }
.lb-add-btn:disabled {
  background: #d0d0d0; box-shadow: none; cursor: not-allowed; animation: none; opacity: 1;
}
[data-theme="dark"] .lb-add-btn:disabled { background: #2a2a2a; color: #555; }
.lb-add-btn.loading { pointer-events: none; animation: none; opacity: 0.9; }
.lb-spinner {
  width: 18px; height: 18px;
  border: 2.5px solid rgba(255,255,255,0.35); border-top-color: #fff;
  border-radius: 50%; animation: lb-spin 0.7s linear infinite;
}
@keyframes lb-spin { to { transform: rotate(360deg); } }

/* ── DISCLAIMER ── */
.lb-disclaimer {
  padding: 0 16px 16px; font-size: 11px; color: var(--lb-muted);
  text-align: center; line-height: 1.5;
}

