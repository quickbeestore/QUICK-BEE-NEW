<script>
(function() {
  var qbDonateQty = 3;
  var qbDonateVariantId = {{ product.variants.first.id | json }};

  // Set tomorrow as default date
  (function() {
    try {
      var tomorrow = new Date();
      tomorrow.setDate(tomorrow.getDate() + 1);
      var y = tomorrow.getFullYear();
      var m = String(tomorrow.getMonth() + 1).padStart(2, '0');
      var d = String(tomorrow.getDate()).padStart(2, '0');
      var dateEl = document.getElementById('qb-donate-date');
      if (dateEl) {
        dateEl.value = y + '-' + m + '-' + d;
        dateEl.min = y + '-' + m + '-' + d;
      }
    } catch (e) {}
  })();

  function qbDonateUpdateImpact() {
    var families = Math.max(1, Math.floor(qbDonateQty / 3));
    document.getElementById('qb-donate-qty').textContent = qbDonateQty;
    document.getElementById('qb-donate-impact-text').innerHTML =
      'Your <strong>' + qbDonateQty + ' item' + (qbDonateQty !== 1 ? 's' : '') + '</strong> will help approximately <strong>' + families + ' famil' + (families !== 1 ? 'ies' : 'y') + '</strong> in your community.';
    document.getElementById('qb-donate-impact-hint').textContent =
      'Will help ~' + families + ' famil' + (families !== 1 ? 'ies' : 'y');
  }

  window.qbDonateStep = function(delta) {
    qbDonateQty = Math.max(1, qbDonateQty + delta);
    qbDonateUpdateImpact();
  };

  window.qbDonateSelectVariant = function(btn) {
    document.querySelectorAll('.qb-donate-type-card').forEach(function(b) { b.classList.remove('selected'); });
    btn.classList.add('selected');
    qbDonateVariantId = btn.dataset.variantId;
  };

  window.qbDonateAddToCart = function() {
    var btn = document.getElementById('qb-donate-add-btn');
    var errEl = document.getElementById('qb-donate-error');
    var date = document.getElementById('qb-donate-date').value;
    var time = document.getElementById('qb-donate-time').value;
    var name = document.getElementById('qb-donate-name').value.trim();
    var message = document.getElementById('qb-donate-message').value.trim();

    errEl.style.display = 'none';

    if (!date) {
      errEl.textContent = 'Please select a pickup date.';
      errEl.style.display = 'block';
      document.getElementById('qb-donate-date').focus();
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Scheduling...';

    var families = Math.max(1, Math.floor(qbDonateQty / 3));

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id: parseInt(qbDonateVariantId, 10),
        quantity: qbDonateQty,
        properties: {
          'Number of Items': qbDonateQty,
          'Pickup Date': date,
          'Pickup Time': time,
          'Donor Name': name || 'Anonymous',
          'Donor Message': message || '',
          'Estimated Families Helped': families
        }
      })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.status) {
        errEl.textContent = data.description || 'Could not schedule. Please try again.';
        errEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'SCHEDULE DONATION PICKUP';
      } else {
        btn.textContent = '✓ Pickup Scheduled! Thank you!';
        document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true }));
        setTimeout(function() {
          btn.disabled = false;
          btn.textContent = 'SCHEDULE DONATION PICKUP';
        }, 2800);
      }
    })
    .catch(function() {
      errEl.textContent = 'Something went wrong. Please try again.';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'SCHEDULE DONATION PICKUP';
    });
  };

  // Init impact text on load
  qbDonateUpdateImpact();
})();
</script>

