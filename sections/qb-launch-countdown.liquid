}
.qblc-live-badge.show { display: flex; }
@keyframes qblcLivePulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.3); }
  50%     { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
}
.qblc-live-dot {
  width: 6px; height: 6px;
  background: #22c55e;
  border-radius: 50%;
  animation: qblcDotPulse 1s ease-in-out infinite;
}

/* ── Light mode overrides ── */
html:not([data-theme="dark"]) .qblc-next-name { color: #fff; }
html:not([data-theme="dark"]) .qblc-title { color: #F4B400; }
