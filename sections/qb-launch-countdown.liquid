<script>
(function() {
  'use strict';

  /* ── Nepal Time = UTC + 5h 45m ── */
  var NST_OFFSET_MS = (5 * 60 + 45) * 60 * 1000;

  function getNSTDate() {
    return new Date(Date.now() + NST_OFFSET_MS - new Date().getTimezoneOffset() * 60000 + new Date().getTimezoneOffset() * 60000);
  }

  function getNSTNow() {
    // Returns a date representing current NST
    var utc = Date.now() + new Date().getTimezoneOffset() * 60000; // UTC ms
    return new Date(utc + NST_OFFSET_MS);
  }

  /* ── Pad zero ── */
  function pad(n) { return String(Math.max(0, n)).padStart(2, '0'); }

  /* ── Next launch day calculation ──
     Launch days: 0=Sun, 2=Tue, 5=Fri  at 21:00 NST
  */
  var LAUNCH_DAYS = [0, 2, 5]; // Sun, Tue, Fri
  var LAUNCH_HOUR = 21;        // 9 PM NST
  var DAY_NAMES   = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  var DAY_SHORT   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

  function getNextLaunch(fromDate) {
    // fromDate is a Date in NST
    var now    = fromDate;
    var nowDay = now.getDay();     // 0–6
    var nowH   = now.getHours();
    var nowM   = now.getMinutes();
    var nowS   = now.getSeconds();

    // find next slot in the week
    for (var offset = 0; offset <= 7; offset++) {
      var candidateDay = (nowDay + offset) % 7;
      if (LAUNCH_DAYS.indexOf(candidateDay) === -1) continue;

      // same day — only valid if launch time hasn't passed yet
      if (offset === 0) {
        var launchMs = (LAUNCH_HOUR * 3600 + 0) * 1000;
        var nowMs    = (nowH * 3600 + nowM * 60 + nowS) * 1000;
        if (nowMs >= launchMs) continue; // already passed today
      }

      // Build target Date in NST
      var target = new Date(now);
      target.setDate(target.getDate() + offset);
      target.setHours(LAUNCH_HOUR, 0, 0, 0);
      return target;
    }
    // fallback: next Sunday
    var fallback = new Date(now);
    fallback.setDate(fallback.getDate() + 7);
    fallback.setHours(LAUNCH_HOUR, 0, 0, 0);
    return fallback;
  }

  function isLiveWindow(nstNow) {
    // Returns true if we're within 2h AFTER a launch slot
    var d = nstNow.getDay();
    var h = nstNow.getHours();
    var m = nstNow.getMinutes();
    var minsPastMidnight = h * 60 + m;
    var launchMinutes    = LAUNCH_HOUR * 60;
    if (LAUNCH_DAYS.indexOf(d) !== -1 &&
        minsPastMidnight >= launchMinutes &&
        minsPastMidnight < launchMinutes + 120) {
      return true;
    }
    return false;
  }

  /* ── Digit rendering with flip animation ── */
  var prevVals = { 1: {}, 2: {} };

  function setDigit(id, val, cardN) {
    var el = document.getElementById(id);
    if (!el) return;
    if (prevVals[cardN][id] !== val) {
      el.textContent = val;
      el.classList.remove('flip');
      void el.offsetWidth; // reflow
      el.classList.add('flip');
      prevVals[cardN][id] = val;
    }
  }

  function renderCountdown(cardN, ms) {
    var totalSec = Math.max(0, Math.floor(ms / 1000));
    var days  = Math.floor(totalSec / 86400);
    var hours = Math.floor((totalSec % 86400) / 3600);
    var mins  = Math.floor((totalSec % 3600) / 60);
    var secs  = totalSec % 60;

    var d2 = pad(days);
    var h2 = pad(hours);
    var m2 = pad(mins);
    var s2 = pad(secs);
    var n  = cardN;

    setDigit('qblc' + n + '-d0', d2[0], n);
    setDigit('qblc' + n + '-d1', d2[1], n);
    setDigit('qblc' + n + '-h0', h2[0], n);
    setDigit('qblc' + n + '-h1', h2[1], n);
    setDigit('qblc' + n + '-m0', m2[0], n);
    setDigit('qblc' + n + '-m1', m2[1], n);
    setDigit('qblc' + n + '-s0', s2[0], n);
    setDigit('qblc' + n + '-s1', s2[1], n);
  }

  /* ── Update next-day label ── */
  function updateDayLabel(id, targetDate, nstNow) {
    var el = document.getElementById(id);
    if (!el) return;
    var diffDays = Math.round((targetDate - nstNow) / 86400000);
    var dayName  = DAY_NAMES[targetDate.getDay()];
    var prefix   = diffDays === 0 ? 'Today' : diffDays === 1 ? 'Tomorrow' : 'This ' + dayName;
    // Format: "This Sunday · Apr 6 · 9:00 PM"
    var months   = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var dateStr  = months[targetDate.getMonth()] + ' ' + targetDate.getDate();
    el.textContent = prefix + ' · ' + dateStr + ' · 9:00 PM';
  }

  /* ── Highlight active pill ── */
  function highlightPills(nstNow) {
    document.querySelectorAll('.qblc-schedule-pills .qblc-pill').forEach(function(pill) {
      var day = parseInt(pill.getAttribute('data-day'));
      pill.classList.toggle('active', day === nstNow.getDay());
    });
  }

  /* ── Main tick ── */
  function tick() {
    var nstNow = getNSTNow();

    /* Live clock */
    var tEl = document.getElementById('qblcLiveTime');
    if (tEl) {
      var hh = pad(nstNow.getHours());
      var mm = pad(nstNow.getMinutes());
      var ss = pad(nstNow.getSeconds());
      tEl.textContent = hh + ':' + mm + ':' + ss;
    }

    /* Both countdown cards use the same next launch time */
    var nextLaunch   = getNextLaunch(nstNow);
    var msRemaining  = nextLaunch - nstNow;
    var live         = isLiveWindow(nstNow);

    renderCountdown(1, msRemaining);
    renderCountdown(2, msRemaining);
    updateDayLabel('qblcDay1', nextLaunch, nstNow);
    updateDayLabel('qblcDay2', nextLaunch, nstNow);
    highlightPills(nstNow);

    /* Live badge */
    var lv1 = document.getElementById('qblcLive1');
    var lv2 = document.getElementById('qblcLive2');
    if (lv1) lv1.classList.toggle('show', live);
    if (lv2) lv2.classList.toggle('show', live);

    /* If live, hide timer */
    var t1 = document.getElementById('qblcTimer1');
    var t2 = document.getElementById('qblcTimer2');
    if (t1) t1.style.opacity = live ? '0.3' : '1';
    if (t2) t2.style.opacity = live ? '0.3' : '1';
  }

  /* Boot */
  tick();
  setInterval(tick, 1000);
})();
</script>

