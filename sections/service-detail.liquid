    beauty: {
      icon: '💅',
      title: 'Beauty Services',
      subtitle: 'Hair, makeup, and beauty treatments at home or salon',
      description: 'Professional beauty services including hair, makeup, and beauty treatments. Expert stylists and beauticians ready to serve.'
    },
    fitness: {
      icon: '💪',
      title: 'Fitness Training Services',
      subtitle: 'Personal training sessions and fitness coaching programs',
      description: 'Professional fitness training and coaching programs. Expert trainers helping you achieve your fitness goals.'
    },
    cooking: {
      icon: '👨‍🍳',
      title: 'Cooking Services',
      subtitle: 'Professional cooking, catering, and meal preparation services',
      description: 'Professional cooking and catering services. Expert chefs preparing delicious meals for all occasions.'
    },
    'custom-magazine': {
      icon: '📰',
      title: 'Custom Magazine',
      subtitle: 'Create personalized magazines with custom designs and premium quality printing',
      description: 'Create beautiful custom magazines with personalized designs and premium quality printing. Perfect for portfolios, portfolios, or special publications.'
    }
  };

  // Load service data
  const service = services[serviceId] || services.plumbing;

  document.getElementById('serviceIcon').textContent = service.icon;
  document.getElementById('serviceBigIcon').textContent = service.icon;
  document.getElementById('serviceTitle').textContent = service.title;
  document.getElementById('serviceSubtitle').textContent = service.subtitle;
  document.getElementById('serviceDescription').textContent = service.description;

  // Book service function
  function bookService() {
    alert(`Booking ${service.title}... This would redirect to booking form.`);
    // In production, redirect to /pages/booking?service=serviceId
  }

  // FAQ toggle
  document.querySelectorAll('.faq-item').forEach(item => {
    item.addEventListener('click', function() {
      this.classList.toggle('open');
    });
  });

  // Handle service detail visibility
  function setupServiceDisplay() {
    const urlParams = new URLSearchParams(window.location.search);
    const serviceId = urlParams.get('service');

    if (serviceId) {
      // Show service detail
      const detailWrapper = document.querySelector('.service-detail-wrapper');
      if (detailWrapper) {
        detailWrapper.style.display = 'block';
      }

      // Hide services showcase - look for it in parent sections
      const allSections = document.querySelectorAll('section, [data-type], [class*="showcase"]');
      allSections.forEach(section => {
        if (section.querySelector('.qb-services-container-pro') ||
            section.classList.contains('qb-services-container-pro') ||
            section.textContent.includes('OUR SERVICES')) {
          section.style.display = 'none';
        }
      });

      // Scroll to detail
      const detailSection = document.querySelector('.service-detail-wrapper');
      if (detailSection) {
        setTimeout(() => {
          detailSection.scrollIntoView({ behavior: 'smooth' });
        }, 100);
      }
    }
  }

  // Run on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupServiceDisplay);
  } else {
    setupServiceDisplay();
  }
</script>

