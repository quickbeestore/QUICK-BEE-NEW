<script>
(function() {
  // Trending pill active state
  const pills = document.querySelectorAll('.qsh-trend-pill');
  pills.forEach(pill => {
    pill.addEventListener('click', function() {
      pills.forEach(p => p.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // Future-ready: programmatically update service status
  window.qshSetServiceStatus = function(serviceHandle, status) {
    document.querySelectorAll(`[href*="${serviceHandle}"]`).forEach(card => {
      const badge = card.querySelector('.qsh-badge');
      if (!badge) return;
      if (status === 'live') {
        badge.className = 'qsh-badge live-badge'; badge.textContent = 'LIVE';
        card.classList.remove('soon');
      } else if (status === 'soon') {
        badge.className = 'qsh-badge soon-badge'; badge.textContent = 'SOON';
        card.classList.add('soon');
      } else if (status === 'fast') {
        badge.className = 'qsh-badge fast-badge'; badge.textContent = 'FAST';
      } else if (status === 'hot') {
        badge.className = 'qsh-badge hot-badge'; badge.textContent = 'HOT';
      }
    });
  };

  // Future-ready: update service pricing dynamically
  window.qshSetServicePrice = function(serviceHandle, price) {
    document.querySelectorAll(`[href*="${serviceHandle}"] .qsh-price`).forEach(el => {
      el.textContent = price;
    });
  };
})();
</script>

