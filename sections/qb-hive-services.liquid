        <div class="qsh-soon-sub">Music, GPS &amp; more</div>
        <span class="qsh-soon-lock">🔒 Soon</span>
      </div>

      <div class="qsh-soon-card">
        <span class="qsh-soon-icon">✂️</span>
        <div class="qsh-soon-name">Beauty &amp; Salon</div>
        <div class="qsh-soon-sub">Haircut &amp; grooming</div>
        <span class="qsh-soon-lock">🔒 Soon</span>
      </div>

      <div class="qsh-soon-card">
        <span class="qsh-soon-icon">🏠</span>
        <div class="qsh-soon-name">Home Cleaning</div>
        <div class="qsh-soon-sub">Deep clean &amp; sanitize</div>
