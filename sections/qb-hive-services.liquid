/* ── LIGHT MODE explicit overrides (for when site is in light mode) ── */
html:not([data-theme="dark"]) .qsh-page { background:#FFF9EE; }
html:not([data-theme="dark"]) .qsh-section-txt { color:#111; }
</style>

<script>
(function() {
  /* Tap ripple feedback on LIVE cards */
  document.querySelectorAll('.qsh-card.live').forEach(function(card) {
    card.addEventListener('touchstart', function() {
      this.style.transition = 'transform .08s ease';
    }, { passive: true });
    card.addEventListener('touchend', function() {
      this.style.transition = 'transform .18s cubic-bezier(.34,1.56,.64,1), box-shadow .18s ease';
    }, { passive: true });
  });

  /* Future hook: location-based availability toggle
     Usage: window.qshSetServiceStatus('alcohol', 'disabled') */
  window.qshSetServiceStatus = function(handle, status) {
    var card = document.querySelector('[data-service="' + handle + '"]');
    if (!card) return;
    if (status === 'disabled') {
      card.classList.remove('live');
      card.classList.add('soon');
      card.removeAttribute('href');
      card.style.pointerEvents = 'none';
    } else if (status === 'live') {
      card.classList.remove('soon');
      card.classList.add('live');
    }
  };

  /* Future hook: set per-service delivery time
     Usage: window.qshSetDeliveryTime('alcohol', '25 mins') */
  window.qshSetDeliveryTime = function(handle, time) {
    var card = document.querySelector('[data-service="' + handle + '"]');
    if (!card) return;
    var foot = card.querySelector('.qsh-card-foot');
    if (foot) foot.textContent = '⚡ ' + time;
  };
})();
</script>

