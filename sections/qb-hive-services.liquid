<style>
/* ════════════════════════════════════════════════
   QSH — Quick Service Hub  (mobile-first)
════════════════════════════════════════════════ */
.qsh-page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: #FFFBF0;
  min-height: 100vh;
  padding-bottom: 100px;
  overflow-x: hidden;
}
[data-theme="dark"] .qsh-page { background: #0A0A0A; }

/* ── HERO ── */
.qsh-hero {
  position: relative;
  padding: 40px 20px 52px;
  text-align: center;
  overflow: hidden;
  background: linear-gradient(160deg, #111 0%, #1a1200 60%, #2a1800 100%);
}
/* warm glow blob */
.qsh-hero-glow {
  position: absolute;
  top: -60px; left: 50%; transform: translateX(-50%);
  width: 420px; height: 280px;
  background: radial-gradient(ellipse, rgba(244,180,0,.35) 0%, transparent 70%);
  pointer-events: none;
}
/* floating orbs */
.qsh-orb {
  position: absolute; border-radius: 50%;
  background: rgba(244,180,0,.08);
  pointer-events: none;
  animation: qshFloat 6s ease-in-out infinite;
}
.qsh-orb1 { width:160px; height:160px; top:-40px; right:-30px; animation-delay:0s; }
.qsh-orb2 { width:90px;  height:90px;  bottom:20px; left:-20px; animation-delay:-3s; }
@keyframes qshFloat {
  0%,100%{ transform:translateY(0) scale(1); }
  50%{ transform:translateY(-12px) scale(1.05); }
}

.qsh-hero-inner { position:relative; z-index:2; }
.qsh-hero-badge {
  display:inline-flex; align-items:center; gap:5px;
  background:rgba(244,180,0,.18); border:1px solid rgba(244,180,0,.35);
  color:#F4B400; font-size:11px; font-weight:800;
  letter-spacing:1.2px; text-transform:uppercase;
  padding:5px 14px; border-radius:999px; margin-bottom:14px;
}
.qsh-title {
  font-size: clamp(2.4rem, 8vw, 4rem);
  font-weight: 900; color:#fff; margin:0 0 10px;
  letter-spacing: -0.04em; line-height:1.05;
  text-shadow: 0 2px 20px rgba(244,180,0,.2);
}
.qsh-title span {
  background: linear-gradient(135deg, #F4B400, #FB923C);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.qsh-sub { font-size:14px; color:rgba(255,255,255,.65); margin:0 0 20px; font-weight:500; }
.qsh-hero-meta { display:flex; gap:8px; justify-content:center; flex-wrap:wrap; }
.qsh-meta-pill {
  background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.15);
  color:rgba(255,255,255,.85); font-size:12px; font-weight:600;
  padding:6px 14px; border-radius:999px; backdrop-filter:blur(6px);
}

/* ── TRENDING STRIP ── */
.qsh-trending-wrap {
  background: #fff; border-bottom: 1px solid #f0e8d0;
  padding: 10px 16px;
  position: sticky; top: 0; z-index: 20;
}
[data-theme="dark"] .qsh-trending-wrap { background:#111; border-bottom-color:#222; }
.qsh-trending-inner { display:flex; align-items:center; gap:10px; max-width:900px; margin:0 auto; }
.qsh-trending-label { font-size:12px; font-weight:800; color:#F4B400; white-space:nowrap; flex-shrink:0; }
.qsh-trending-scroll {
  display:flex; gap:7px; overflow-x:auto; -webkit-overflow-scrolling:touch;
  scrollbar-width:none; padding:2px 0;
}
.qsh-trending-scroll::-webkit-scrollbar { display:none; }
.qsh-tpill {
  white-space:nowrap; padding:6px 14px;
  background:#FFF9EE; border:1px solid #FBBF24;
  color:#92400E; font-size:12px; font-weight:700;
  border-radius:999px; text-decoration:none; flex-shrink:0;
  transition:all .15s;
}
.qsh-tpill:hover { background:#FEF3C7; transform:scale(1.03); }
[data-theme="dark"] .qsh-tpill { background:#1a1500; border-color:#3d2e00; color:#F4B400; }
[data-theme="dark"] .qsh-tpill:hover { background:#231c00; }

/* ── SECTION HEADERS ── */
.qsh-section-head {
  display:flex; align-items:center; gap:8px;
  padding:20px 20px 10px; max-width:900px; margin:0 auto;
}
.qsh-section-dot {
  width:8px; height:8px; border-radius:50%; flex-shrink:0;
}
.qsh-section-dot.live { background:#10B981; box-shadow:0 0 8px #10B981; animation:qshLivePulse 1.8s ease-in-out infinite; }
.qsh-section-dot.soon { background:#6B7280; }
@keyframes qshLivePulse {
  0%,100%{ box-shadow:0 0 0 0 rgba(16,185,129,.6); }
  50%{ box-shadow:0 0 0 6px rgba(16,185,129,0); }
}
.qsh-section-txt { font-size:13px; font-weight:800; color:#111; }
[data-theme="dark"] .qsh-section-txt { color:#f0f0f0; }
.qsh-section-txt.muted { color:#9CA3AF; }
.qsh-fastest-badge {
  margin-left:auto; background:rgba(244,180,0,.12); border:1px solid rgba(244,180,0,.3);
  color:#D97706; font-size:11px; font-weight:800; padding:3px 10px; border-radius:999px;
}
[data-theme="dark"] .qsh-fastest-badge { color:#F4B400; background:rgba(244,180,0,.1); }

/* ── GRID ── */
.qsh-grid {
  display:grid;
  grid-template-columns: repeat(2, 1fr);
  gap:12px; padding:4px 16px 16px;
  max-width:900px; margin:0 auto;
}
@media(min-width:600px){ .qsh-grid { grid-template-columns: repeat(3,1fr); gap:14px; } }
@media(min-width:900px){ .qsh-grid { grid-template-columns: repeat(4,1fr); gap:16px; } }
.qsh-grid-soon { grid-template-columns: repeat(3,1fr); gap:10px; }
@media(min-width:600px){ .qsh-grid-soon { grid-template-columns: repeat(3,1fr); } }

/* ── CARD BASE ── */
.qsh-card {
  position: relative; overflow: hidden;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 22px 12px 14px;
  border-radius: 20px; text-align: center;
  text-decoration: none; cursor: pointer;
  transition: transform .18s cubic-bezier(.34,1.56,.64,1), box-shadow .18s ease;
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  gap: 6px;
}
.qsh-card:active { transform: scale(0.93) !important; }

/* LIVE card */
.qsh-card.live {
  background: linear-gradient(145deg, #FEF3C7 0%, #FDE68A 40%, #FBBF24 100%);
  border: 1px solid rgba(245,158,11,.3);
  box-shadow: 0 4px 16px rgba(245,158,11,.18), 0 1px 3px rgba(0,0,0,.08);
  color: #111;
}
.qsh-card.live:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 12px 28px rgba(245,158,11,.32), 0 2px 6px rgba(0,0,0,.1);
}
/* featured LIVE (Custom Delivery) */
.qsh-card.live.featured {
  background: linear-gradient(145deg, #FFF7ED 0%, #FED7AA 40%, #FB923C 100%);
  border-color: rgba(249,115,22,.3);
  box-shadow: 0 4px 16px rgba(249,115,22,.2);
}
/* Shine sweep on LIVE cards */
.qsh-card-shine {
  position:absolute; inset:0; border-radius:inherit;
  background:linear-gradient(115deg, transparent 30%, rgba(255,255,255,.35) 50%, transparent 70%);
  background-size:200% 100%;
  background-position:200% 0;
  transition:background-position .5s;
  pointer-events:none;
}
.qsh-card.live:hover .qsh-card-shine { background-position:-100% 0; }

/* SOON card */
.qsh-card.soon {
  background: #F5F5F5; border:1px solid #E5E7EB;
  color:#9CA3AF; opacity:.65; pointer-events:none;
}
.qsh-card.soon .qsh-emoji { filter:grayscale(1); }
[data-theme="dark"] .qsh-card.soon { background:#1A1A1A; border-color:#2A2A2A; }

/* ── BADGE ── */
.qsh-badge {
  position: absolute; top: 10px; right: 10px;
  font-size: 9px; font-weight: 900; letter-spacing: .8px;
  text-transform: uppercase; padding: 3px 8px;
  border-radius: 999px; display:flex; align-items:center; gap:4px;
}
.qsh-badge.live { background:rgba(16,185,129,.15); color:#059669; border:1px solid rgba(16,185,129,.3); }
.qsh-badge.fast { background:rgba(245,158,11,.18); color:#B45309; border:1px solid rgba(245,158,11,.35); }
.qsh-badge.soon { background:rgba(0,0,0,.08); color:#9CA3AF; }
[data-theme="dark"] .qsh-badge.soon { background:rgba(255,255,255,.06); }

/* pulsing live dot inside LIVE badge */
.qsh-live-dot {
  width:5px; height:5px; border-radius:50%;
  background:#10B981; flex-shrink:0;
  animation:qshDotPulse 1.6s ease-in-out infinite;
}
@keyframes qshDotPulse {
  0%,100%{ opacity:1; transform:scale(1); }
  50%{ opacity:.4; transform:scale(1.4); }
}

/* ── CARD CONTENT ── */
.qsh-emoji {
  font-size: 2.4rem; line-height:1;
  transition: transform .2s cubic-bezier(.34,1.56,.64,1);
}
.qsh-card.live:hover .qsh-emoji { transform:scale(1.18) rotate(-5deg); }
.qsh-card-body { display:flex; flex-direction:column; gap:3px; }
.qsh-name {
  font-size:13px; font-weight:800; line-height:1.2; color:inherit;
}
.qsh-desc {
  font-size:10px; font-weight:500; opacity:.65; line-height:1.3; color:inherit;
}
.qsh-card-foot {
  font-size:10px; font-weight:700; color:#B45309;
  background:rgba(0,0,0,.07); padding:3px 10px;
  border-radius:999px; margin-top:4px;
}
.qsh-card.soon .qsh-card-foot { color:#9CA3AF; background:rgba(0,0,0,.04); }
.qsh-card-foot.muted { color:#aaa; }
[data-theme="dark"] .qsh-card-foot { color:#D97706; background:rgba(0,0,0,.2); }

/* ── BOTTOM CTA ── */
.qsh-cta-bar {
  margin: 16px 16px 0; max-width:868px; /* 900-16-16 */
  margin-left:auto; margin-right:auto;
}
.qsh-cta-inner {
  display:flex; align-items:center; justify-content:space-between;
  gap:12px; padding:16px 20px;
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  border-radius:20px;
  border:1px solid rgba(245,158,11,.3);
  box-shadow:0 4px 16px rgba(245,158,11,.12);
}
[data-theme="dark"] .qsh-cta-inner {
  background:linear-gradient(135deg,#1a1200,#221800);
  border-color:rgba(244,180,0,.2);
}
.qsh-cta-left { display:flex; align-items:center; gap:12px; }
.qsh-cta-emoji { font-size:28px; flex-shrink:0; animation:qshFloat 3s ease-in-out infinite; }
.qsh-cta-title { font-size:13px; font-weight:800; color:#111; }
[data-theme="dark"] .qsh-cta-title { color:#F4B400; }
.qsh-cta-sub { font-size:11px; color:#92400E; margin-top:2px; }
[data-theme="dark"] .qsh-cta-sub { color:#aaa; }
.qsh-cta-btn {
  flex-shrink:0; background:linear-gradient(135deg,#F4B400,#F59E0B);
  color:#000 !important; font-size:12px; font-weight:900;
  padding:10px 18px; border-radius:14px; text-decoration:none;
  box-shadow:0 4px 14px rgba(244,180,0,.4);
  transition:transform .18s,box-shadow .18s;
