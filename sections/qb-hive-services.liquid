{%- doc -%}
  QuickBee Services Hub — Live: Laundry & Vendor Registration.
  All other services show "Coming Soon" locked state.
{%- enddoc -%}

<style>
/* ═══════════════════════════════════════
   QSH — QuickBee Services Hub v4
   Live: Laundry | Vendor Registration
   Locked: Everything else
═══════════════════════════════════════ */
:root {
  --qsh-gold:   #F4B400;
  --qsh-spring: cubic-bezier(0.34,1.56,0.64,1);
  --qsh-smooth: cubic-bezier(0.4,0,0.2,1);
  --qsh-blue:   #3B82F6;
  --qsh-green:  #22c55e;
}

/* ── Wrap ── */
.qsh-wrap {
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  overflow-x: hidden;
  padding-bottom: 120px;
}
[data-theme="dark"] .qsh-wrap { background: #0a0a0a; }
html:not([data-theme="dark"]) .qsh-wrap { background: #f0f0f0; }

/* ══════════════════════════════════════
   HERO — Full-width laundry identity
══════════════════════════════════════ */
.qsh-hero {
  position: relative;
  padding: 44px 20px 40px;
  overflow: hidden;
  text-align: center;
}
[data-theme="dark"] .qsh-hero {
  background: linear-gradient(160deg, #0a0a0a 0%, #0d1a2e 50%, #0a0a0a 100%);
  border-bottom: 1px solid rgba(59,130,246,0.15);
}
html:not([data-theme="dark"]) .qsh-hero {
  background: linear-gradient(160deg, #0f172a 0%, #1e3a5f 50%, #0f172a 100%);
  border-bottom: 1px solid rgba(59,130,246,0.2);
}
/* Radial glow */
.qsh-hero::before {
  content: '';
  position: absolute;
  top: -40px; left: 50%; transform: translateX(-50%);
  width: 600px; height: 300px;
  background: radial-gradient(ellipse, rgba(59,130,246,0.18) 0%, transparent 70%);
  pointer-events: none;
}
/* Floating orbs */
.qsh-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  animation: qshOrbFloat 8s ease-in-out infinite;
}
.qsh-orb-1 { width: 220px; height: 220px; background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%); top: -60px; right: -40px; animation-delay: 0s; }
.qsh-orb-2 { width: 140px; height: 140px; background: radial-gradient(circle, rgba(244,180,0,0.1) 0%, transparent 70%); bottom: -20px; left: 5%; animation-delay: 3.5s; }
.qsh-orb-3 { width: 80px;  height: 80px;  background: radial-gradient(circle, rgba(34,197,94,0.1) 0%, transparent 70%);  top: 30%;  left: -20px; animation-delay: 2s; }
@keyframes qshOrbFloat {
  0%,100% { transform: translateY(0) scale(1); }
  50%      { transform: translateY(-18px) scale(1.06); }
}

/* Pill badge */
.qsh-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: rgba(34,197,94,0.12);
  border: 1px solid rgba(34,197,94,0.3);
  color: #22c55e;
  font-size: 10px;
  font-weight: 800;
  padding: 5px 14px;
  border-radius: 20px;
  margin-bottom: 18px;
  letter-spacing: 1px;
  text-transform: uppercase;
}
.qsh-live-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #22c55e;
  animation: qshLivePulse 1.6s ease-in-out infinite;
}
@keyframes qshLivePulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.7); }
  60%      { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
}

.qsh-hero-icon {
  font-size: 52px;
  display: block;
  margin: 0 auto 14px;
  filter: drop-shadow(0 0 20px rgba(59,130,246,0.4));
  animation: qshIconBob 3s ease-in-out infinite;
}
@keyframes qshIconBob {
  0%,100% { transform: translateY(0) rotate(-3deg); }
  50%      { transform: translateY(-6px) rotate(3deg); }
}

.qsh-hero-title {
  font-size: clamp(28px, 7vw, 44px);
  font-weight: 900;
  color: #fff;
  line-height: 1.1;
  letter-spacing: -0.8px;
  margin: 0 0 12px;
}
.qsh-hero-title .accent { color: #3B82F6; }
.qsh-hero-title .gold   { color: #F4B400; }

.qsh-hero-sub {
  font-size: 14px;
  color: rgba(255,255,255,0.5);
  line-height: 1.65;
  max-width: 380px;
  margin: 0 auto 28px;
}

/* Stats row */
.qsh-stats {
  display: flex;
  justify-content: center;
  gap: 28px;
  flex-wrap: wrap;
  margin-bottom: 28px;
}
.qsh-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}
.qsh-stat-num {
  font-size: 22px;
  font-weight: 900;
  color: #3B82F6;
}
.qsh-stat-num.gold { color: #F4B400; }
.qsh-stat-label {
  font-size: 9px;
  color: rgba(255,255,255,0.35);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

/* Book CTA */
.qsh-hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: linear-gradient(135deg, #2563eb 0%, #3B82F6 100%);
  color: #fff !important;
  font-size: 14px;
  font-weight: 800;
  padding: 14px 30px;
  border-radius: 50px;
  text-decoration: none;
  transition: transform 0.2s var(--qsh-spring), box-shadow 0.2s ease;
  box-shadow: 0 8px 24px rgba(59,130,246,0.35);
  letter-spacing: 0.2px;
}
.qsh-hero-cta:hover {
  transform: translateY(-3px) scale(1.03);
  box-shadow: 0 14px 32px rgba(59,130,246,0.45);
}
.qsh-hero-cta-arrow { transition: transform 0.2s ease; }
.qsh-hero-cta:hover .qsh-hero-cta-arrow { transform: translateX(4px); }

/* ══════════════════════════════════════
   TRUST CHIPS
══════════════════════════════════════ */
.qsh-trust-row {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding: 14px 16px;
  scrollbar-width: none;
}
.qsh-trust-row::-webkit-scrollbar { display: none; }
[data-theme="dark"] .qsh-trust-row {
  background: #111;
  border-bottom: 1px solid #1c1c1c;
}
html:not([data-theme="dark"]) .qsh-trust-row {
  background: #fff;
  border-bottom: 1px solid #e8e8e8;
}
.qsh-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  padding: 7px 13px;
  border-radius: 20px;
  white-space: nowrap;
  flex-shrink: 0;
}
.qsh-chip-blue {
  background: rgba(59,130,246,0.1);
  border: 1px solid rgba(59,130,246,0.25);
  color: #3B82F6;
}
.qsh-chip-green {
  background: rgba(34,197,94,0.1);
  border: 1px solid rgba(34,197,94,0.25);
  color: #22c55e;
}
.qsh-chip-gold {
  background: rgba(244,180,0,0.1);
  border: 1px solid rgba(244,180,0,0.25);
  color: #F4B400;
}
html:not([data-theme="dark"]) .qsh-chip-blue { color: #2563eb; }
html:not([data-theme="dark"]) .qsh-chip-gold { color: #c98b00; }

/* ══════════════════════════════════════
   LAUNDRY — BIG FLAGSHIP CARD
══════════════════════════════════════ */
.qsh-flagship-wrap {
  padding: 20px 14px 6px;
}
.qsh-section-label {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
}
.qsh-section-label-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
  animation: qshLivePulse 2s ease-in-out infinite;
  flex-shrink: 0;
}
.qsh-section-label-text {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  color: #22c55e;
}

/* Big laundry card */
.qsh-flagship {
  position: relative;
  border-radius: 22px;
  overflow: hidden;
  text-decoration: none;
  display: block;
  transition: transform 0.25s var(--qsh-spring), box-shadow 0.25s ease;
}
[data-theme="dark"] .qsh-flagship {
  background: linear-gradient(145deg, #0d1a2e 0%, #0a1525 100%);
  border: 1px solid rgba(59,130,246,0.18);
  box-shadow: 0 4px 30px rgba(0,0,0,0.4);
}
html:not([data-theme="dark"]) .qsh-flagship {
  background: linear-gradient(145deg, #1e3a5f 0%, #162d4a 100%);
  border: 1px solid rgba(59,130,246,0.25);
  box-shadow: 0 4px 24px rgba(30,58,95,0.3);
}
.qsh-flagship:hover {
  transform: translateY(-4px) scale(1.01);
  box-shadow: 0 16px 48px rgba(59,130,246,0.25);
}
.qsh-flagship::before {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 180px; height: 180px;
  background: radial-gradient(circle, rgba(59,130,246,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.qsh-flagship-body {
  padding: 24px 20px 22px;
  position: relative;
}
.qsh-flagship-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 14px;
}
.qsh-flagship-emoji {
  font-size: 44px;
  line-height: 1;
  filter: drop-shadow(0 0 12px rgba(59,130,246,0.5));
}
.qsh-flagship-live-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(34,197,94,0.12);
  border: 1px solid rgba(34,197,94,0.3);
  color: #22c55e;
  font-size: 10px;
  font-weight: 800;
  padding: 5px 10px;
  border-radius: 20px;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}
.qsh-flagship-live-badge .dot {
  width: 6px; height: 6px;
  background: #22c55e;
  border-radius: 50%;
  animation: qshLivePulse 1.6s ease-in-out infinite;
}

.qsh-flagship-name {
  font-size: 24px;
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.4px;
  line-height: 1.15;
  margin-bottom: 6px;
}
.qsh-flagship-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  line-height: 1.6;
  margin-bottom: 18px;
}

/* Feature pills */
.qsh-flagship-features {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-bottom: 20px;
}
.qsh-ff-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  font-weight: 700;
  padding: 5px 11px;
  border-radius: 20px;
  background: rgba(59,130,246,0.1);
  border: 1px solid rgba(59,130,246,0.2);
  color: rgba(255,255,255,0.75);
}

/* Price + CTA row */
.qsh-flagship-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.qsh-flagship-price {
  display: flex;
  flex-direction: column;
}
.qsh-flagship-price-from {
  font-size: 10px;
  color: rgba(255,255,255,0.4);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.qsh-flagship-price-val {
  font-size: 26px;
  font-weight: 900;
  color: #F4B400;
  line-height: 1.1;
}
.qsh-flagship-price-unit {
  font-size: 11px;
  color: rgba(255,255,255,0.35);
  font-weight: 600;
}
.qsh-flagship-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: linear-gradient(135deg, #2563eb 0%, #3B82F6 100%);
  color: #fff;
  font-size: 13px;
  font-weight: 800;
  padding: 12px 20px;
  border-radius: 50px;
  box-shadow: 0 6px 20px rgba(59,130,246,0.4);
  transition: transform 0.2s var(--qsh-spring), box-shadow 0.2s ease;
  letter-spacing: 0.1px;
}
.qsh-flagship:hover .qsh-flagship-btn {
  transform: scale(1.04);
  box-shadow: 0 10px 28px rgba(59,130,246,0.5);
}

/* Service mini-grid inside laundry card */
.qsh-laundry-services {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.05);
  border-top: 1px solid rgba(59,130,246,0.12);
  border-radius: 0 0 22px 22px;
  overflow: hidden;
}
.qsh-ls-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 14px 8px;
  background: rgba(0,0,0,0.2);
  font-size: 10px;
  font-weight: 700;
  color: rgba(255,255,255,0.5);
  text-align: center;
}
.qsh-ls-item:hover { background: rgba(59,130,246,0.08); color: rgba(255,255,255,0.8); }
.qsh-ls-icon { font-size: 20px; }

/* ══════════════════════════════════════
   VENDOR REGISTRATION CARD
══════════════════════════════════════ */
.qsh-vendor-wrap {
  padding: 16px 14px 8px;
}
.qsh-vendor-card {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  text-decoration: none;
  display: block;
  transition: transform 0.25s var(--qsh-spring), box-shadow 0.25s ease;
}
[data-theme="dark"] .qsh-vendor-card {
  background: linear-gradient(145deg, #1a0f00 0%, #120c00 100%);
  border: 1px solid rgba(244,180,0,0.15);
  box-shadow: 0 4px 24px rgba(0,0,0,0.35);
}
html:not([data-theme="dark"]) .qsh-vendor-card {
  background: linear-gradient(145deg, #2a1e00 0%, #1a1300 100%);
  border: 1px solid rgba(244,180,0,0.2);
  box-shadow: 0 4px 20px rgba(42,30,0,0.3);
}
.qsh-vendor-card:hover {
  transform: translateY(-3px) scale(1.01);
  box-shadow: 0 14px 40px rgba(244,180,0,0.18);
}
.qsh-donation-card:hover {
  box-shadow: 0 14px 40px rgba(34,197,94,0.18);
}
.qsh-vendor-card::before {
  content: '';
  position: absolute;
  top: -30px; right: -30px;
  width: 160px; height: 160px;
  background: radial-gradient(circle, rgba(244,180,0,0.12) 0%, transparent 70%);
  pointer-events: none;
}

.qsh-vendor-body {
  padding: 22px 20px 20px;
  display: flex;
  align-items: center;
  gap: 18px;
}
.qsh-vendor-icon-wrap {
  width: 56px; height: 56px;
  border-radius: 16px;
  background: rgba(244,180,0,0.12);
  border: 1px solid rgba(244,180,0,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  flex-shrink: 0;
}
.qsh-vendor-info { flex: 1; }
.qsh-vendor-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(244,180,0,0.12);
  border: 1px solid rgba(244,180,0,0.25);
  color: #F4B400;
  font-size: 9px;
  font-weight: 800;
  padding: 4px 9px;
  border-radius: 20px;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.qsh-vendor-name {
  font-size: 18px;
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.3px;
  margin-bottom: 4px;
}
.qsh-vendor-desc {
  font-size: 12px;
  color: rgba(255,255,255,0.45);
  line-height: 1.5;
}
.qsh-vendor-arrow {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: rgba(244,180,0,0.1);
  border: 1px solid rgba(244,180,0,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #F4B400;
  font-size: 16px;
  flex-shrink: 0;
  transition: transform 0.2s var(--qsh-spring), background 0.2s ease;
}
.qsh-vendor-card:hover .qsh-vendor-arrow {
  transform: translateX(3px) scale(1.1);
  background: rgba(244,180,0,0.18);
}

/* ══════════════════════════════════════
   COMING SOON DIVIDER
══════════════════════════════════════ */
.qsh-soon-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 32px 16px 16px;
}
.qsh-soon-divider-line {
  flex: 1;
  height: 1px;
}
[data-theme="dark"] .qsh-soon-divider-line { background: rgba(255,255,255,0.06); }
html:not([data-theme="dark"]) .qsh-soon-divider-line { background: rgba(0,0,0,0.08); }
.qsh-soon-divider-label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #555;
  padding: 5px 14px;
  border-radius: 20px;
  white-space: nowrap;
}
[data-theme="dark"] .qsh-soon-divider-label {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  color: #555;
}
html:not([data-theme="dark"]) .qsh-soon-divider-label {
  background: rgba(0,0,0,0.04);
  border: 1px solid rgba(0,0,0,0.08);
  color: #888;
}

/* ══════════════════════════════════════
   COMING SOON GRID
══════════════════════════════════════ */
.qsh-soon-grid-wrap {
  padding: 0 14px 16px;
}
.qsh-soon-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}
@media (min-width: 480px) {
  .qsh-soon-grid { grid-template-columns: repeat(3, 1fr); }
}

.qsh-soon-card {
  position: relative;
  border-radius: 18px;
  padding: 18px 14px 16px;
  overflow: hidden;
  cursor: not-allowed;
  user-select: none;
}
[data-theme="dark"] .qsh-soon-card {
  background: #111;
  border: 1px solid rgba(255,255,255,0.05);
}
html:not([data-theme="dark"]) .qsh-soon-card {
  background: #fff;
  border: 1px solid rgba(0,0,0,0.07);
}

/* frosted locked overlay */
.qsh-soon-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 18px;
  z-index: 2;
}
[data-theme="dark"] .qsh-soon-card::before { background: rgba(10,10,10,0.55); }
html:not([data-theme="dark"]) .qsh-soon-card::before { background: rgba(240,240,240,0.6); }

.qsh-soon-icon {
  font-size: 30px;
  margin-bottom: 8px;
  display: block;
  filter: grayscale(60%) opacity(0.6);
  position: relative;
  z-index: 1;
}
.qsh-soon-name {
  font-size: 13px;
  font-weight: 800;
  margin-bottom: 3px;
  position: relative;
  z-index: 1;
}
[data-theme="dark"] .qsh-soon-name { color: rgba(255,255,255,0.35); }
html:not([data-theme="dark"]) .qsh-soon-name { color: rgba(0,0,0,0.3); }
.qsh-soon-sub {
  font-size: 10px;
  color: #444;
  margin-bottom: 10px;
  position: relative;
  z-index: 1;
}
html:not([data-theme="dark"]) .qsh-soon-sub { color: #aaa; }

/* Lock badge */
.qsh-soon-lock {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 9px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  padding: 4px 9px;
  border-radius: 20px;
  position: relative;
  z-index: 3;
}
[data-theme="dark"] .qsh-soon-lock {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  color: #444;
}
html:not([data-theme="dark"]) .qsh-soon-lock {
  background: rgba(0,0,0,0.05);
  border: 1px solid rgba(0,0,0,0.1);
  color: #bbb;
}

/* ══════════════════════════════════════
   APP DOWNLOAD FOOTER BANNER
══════════════════════════════════════ */
.qsh-app-banner {
  margin: 24px 14px 0;
  border-radius: 20px;
  padding: 22px 20px;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 16px;
}
[data-theme="dark"] .qsh-app-banner {
  background: linear-gradient(135deg, #111 0%, #0d0d0d 100%);
  border: 1px solid rgba(255,255,255,0.06);
}
html:not([data-theme="dark"]) .qsh-app-banner {
  background: linear-gradient(135deg, #1e2124 0%, #16181a 100%);
  border: 1px solid rgba(255,255,255,0.1);
}
.qsh-app-banner-icon { font-size: 40px; flex-shrink: 0; }
.qsh-app-banner-info { flex: 1; }
.qsh-app-banner-title {
  font-size: 15px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 3px;
}
.qsh-app-banner-sub {
  font-size: 11px;
  color: rgba(255,255,255,0.4);
  line-height: 1.5;
}
.qsh-app-banner-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(244,180,0,0.1);
  border: 1px solid rgba(244,180,0,0.2);
  color: #F4B400;
  font-size: 9px;
  font-weight: 800;
  padding: 4px 10px;
  border-radius: 20px;
  margin-top: 7px;
  text-transform: uppercase;
  letter-spacing: 0.6px;
}

/* Animations */
@keyframes qshFadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
.qsh-anim { animation: qshFadeUp 0.45s ease both; }
.qsh-anim-d1 { animation-delay: 0.05s; }
.qsh-anim-d2 { animation-delay: 0.12s; }
.qsh-anim-d3 { animation-delay: 0.20s; }
.qsh-anim-d4 { animation-delay: 0.28s; }
</style>

<div class="qsh-wrap">

  <!-- ══ HERO ══ -->
  <div class="qsh-hero">
    <div class="qsh-orb qsh-orb-1"></div>
    <div class="qsh-orb qsh-orb-2"></div>
    <div class="qsh-orb qsh-orb-3"></div>

    <div class="qsh-anim qsh-anim-d1">
      <div class="qsh-hero-badge">
        <span class="qsh-live-dot"></span>
        Now Available in Kathmandu
      </div>
    </div>

    <span class="qsh-hero-icon qsh-anim qsh-anim-d1">👕</span>

    <div class="qsh-hero-title qsh-anim qsh-anim-d2">
      Professional<br><span class="accent">Laundry</span> at Your<br><span class="gold">Doorstep</span>
    </div>
    <div class="qsh-hero-sub qsh-anim qsh-anim-d2">
      Fresh, clean &amp; neatly folded — picked up and delivered right to you. No hassle, just sparkling results.
    </div>

    <div class="qsh-stats qsh-anim qsh-anim-d3">
      <div class="qsh-stat">
        <span class="qsh-stat-num">2K+</span>
        <span class="qsh-stat-label">Orders Done</span>
      </div>
      <div class="qsh-stat">
        <span class="qsh-stat-num gold">4.9★</span>
        <span class="qsh-stat-label">Rating</span>
      </div>
      <div class="qsh-stat">
        <span class="qsh-stat-num">24hr</span>
        <span class="qsh-stat-label">Turnaround</span>
      </div>
      <div class="qsh-stat">
        <span class="qsh-stat-num gold">Free</span>
        <span class="qsh-stat-label">Pickup &amp; Drop</span>
      </div>
    </div>

    <a href="/pages/laundry" class="qsh-hero-cta qsh-anim qsh-anim-d4">
      Book Laundry Now <span class="qsh-hero-cta-arrow">→</span>
    </a>
  </div>

  <!-- ══ TRUST CHIPS ══ -->
  <div class="qsh-trust-row">
    <div class="qsh-chip qsh-chip-green">✅ Verified Cleaners</div>
    <div class="qsh-chip qsh-chip-blue">🚚 Free Pickup &amp; Drop</div>
    <div class="qsh-chip qsh-chip-gold">⚡ 24hr Express Option</div>
    <div class="qsh-chip qsh-chip-green">♻️ Eco-Friendly Detergent</div>
    <div class="qsh-chip qsh-chip-blue">🔒 Safe Packaging</div>
    <div class="qsh-chip qsh-chip-gold">📦 Item-by-Item Tracking</div>
  </div>

  <!-- ══ LAUNDRY FLAGSHIP CARD ══ -->
  <div class="qsh-flagship-wrap qsh-anim qsh-anim-d2">
    <div class="qsh-section-label">
      <div class="qsh-section-label-dot"></div>
      <span class="qsh-section-label-text">Live Service</span>
    </div>

    <a href="/pages/laundry" class="qsh-flagship">
      <div class="qsh-flagship-body">
        <div class="qsh-flagship-top">
          <span class="qsh-flagship-emoji">🧺</span>
          <div class="qsh-flagship-live-badge">
            <span class="dot"></span> Live
          </div>
        </div>

        <div class="qsh-flagship-name">Laundry Services</div>
        <div class="qsh-flagship-desc">Wash, dry, iron &amp; fold — handled by professionals. We pick up from your door and deliver back fresh.</div>

        <div class="qsh-flagship-features">
          <span class="qsh-ff-pill">👕 Wash &amp; Fold</span>
          <span class="qsh-ff-pill">🔥 Dry Cleaning</span>
          <span class="qsh-ff-pill">👔 Steam Iron</span>
          <span class="qsh-ff-pill">🛏️ Bedsheets</span>
          <span class="qsh-ff-pill">🏠 Pickup &amp; Drop</span>
        </div>

        <div class="qsh-flagship-bottom">
          <div class="qsh-flagship-price">
            <span class="qsh-flagship-price-from">Starting from</span>
            <span class="qsh-flagship-price-val">Rs 99</span>
            <span class="qsh-flagship-price-unit">per kg</span>
          </div>
          <div class="qsh-flagship-btn">
            Book Now <span>→</span>
          </div>
        </div>
      </div>

      <!-- Mini service tiles -->
      <div class="qsh-laundry-services">
        <div class="qsh-ls-item">
          <span class="qsh-ls-icon">👕</span>
          Wash &amp; Fold
        </div>
        <div class="qsh-ls-item">
          <span class="qsh-ls-icon">🧥</span>
          Dry Clean
        </div>
        <div class="qsh-ls-item">
          <span class="qsh-ls-icon">👔</span>
          Steam Iron
        </div>
        <div class="qsh-ls-item">
          <span class="qsh-ls-icon">🛏️</span>
          Bedsheets
        </div>
      </div>
    </a>
  </div>

  <!-- ══ VENDOR REGISTRATION ══ -->
  <div class="qsh-vendor-wrap qsh-anim qsh-anim-d3">
    <div class="qsh-section-label">
      <div class="qsh-section-label-dot" style="background:#F4B400;box-shadow:0 0 0 3px rgba(244,180,0,0.2);animation:none;"></div>
      <span class="qsh-section-label-text" style="color:#F4B400;">For Businesses</span>
    </div>

    <a href="/pages/vendor-registration" class="qsh-vendor-card">
      <div class="qsh-vendor-body">
        <div class="qsh-vendor-icon-wrap">🏪</div>
        <div class="qsh-vendor-info">
          <div class="qsh-vendor-badge">
            ✦ Open Registration
          </div>
          <div class="qsh-vendor-name">Vendor Registration</div>
          <div class="qsh-vendor-desc">Partner with QuickBee. List your services, grow your business &amp; reach thousands of customers in your area.</div>
        </div>
        <div class="qsh-vendor-arrow">→</div>
      </div>
    </a>

    <!-- Clothes Donation -->
    <a href="/products/clothes-donation-pickup" class="qsh-vendor-card qsh-donation-card" style="margin-top:10px;">
      <div class="qsh-vendor-body">
        <div class="qsh-vendor-icon-wrap" style="background:rgba(34,197,94,0.1);border-color:rgba(34,197,94,0.2);font-size:26px;">👕</div>
        <div class="qsh-vendor-info">
          <div class="qsh-vendor-badge" style="background:rgba(34,197,94,0.1);border-color:rgba(34,197,94,0.25);color:#22c55e;">
            ♻️ Free Service
          </div>
          <div class="qsh-vendor-name">Clothes Donation Pickup</div>
          <div class="qsh-vendor-desc">Got clothes to donate? We'll pick them up from your door — free of charge. Help someone in need today.</div>
        </div>
        <div class="qsh-vendor-arrow" style="background:rgba(34,197,94,0.1);border-color:rgba(34,197,94,0.2);color:#22c55e;">→</div>
      </div>
    </a>
  </div>

  <!-- ══ COMING SOON DIVIDER ══ -->
  <div class="qsh-soon-divider">
    <div class="qsh-soon-divider-line"></div>
    <div class="qsh-soon-divider-label">
      🔒 Coming Soon
    </div>
    <div class="qsh-soon-divider-line"></div>
  </div>

  <!-- ══ COMING SOON GRID ══ -->
  <div class="qsh-soon-grid-wrap">
    <div class="qsh-soon-grid">

      <div class="qsh-soon-card">
        <span class="qsh-soon-icon">🔧</span>
        <div class="qsh-soon-name">Plumbing</div>
