    <span class="hive-label-dot active-dot"></span>
    <span>Live Now</span>
    <span class="hive-label-divider">·</span>
    <span class="hive-label-dot soon-dot"></span>
    <span>Coming Soon</span>
  </div>

  <!-- Honeycomb Grid -->
  <div class="hive-grid-outer">
    <div class="hive-grid">

      <!-- Row 1 (2 cells — active services featured) -->
      <div class="hive-row">
        <a href="/pages/service-laundry" class="hex-wrap active">
          <div class="hex-cell">
            <span class="hex-glow"></span>
            <span class="hex-icon">🧺</span>
            <span class="hex-name">Laundry</span>
            <span class="hex-badge live">Live</span>
