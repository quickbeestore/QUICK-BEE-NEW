    <!-- Coming Soon Services -->
    <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">🔧</div>
      <div class="service-name">Plumbing</div>
    </div>
    <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">🎨</div>
      <div class="service-name">Painting</div>
    </div>
    <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">🏠</div>
      <div class="service-name">Cleaning</div>
    </div>
    <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">❄️</div>
      <div class="service-name">HVAC</div>
    </div>
    <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">🪲</div>
      <div class="service-name">Pest Control</div>
    </div>
    <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">🔒</div>
      <div class="service-name">Locksmith</div>
    </div>
     <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">💇</div>
      <div class="service-name">Beauty</div>
    </div>
    <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">🌿</div>
      <div class="service-name">Landscaping</div>
    </div>
    <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">💪</div>
      <div class="service-name">Fitness</div>
    </div>
    <div class="service-card soon">
      <div class="service-badge soon">SOON</div>
      <div class="service-icon">👨‍🍳</div>
      <div class="service-name">Cooking</div>
    </div>
  </div>
</div>

<style>
  /* ── Page Base ── */
  .qb-hive-page {
    background: #FFFBF0;
    min-height: 100vh;
    overflow-x: hidden;
    font-family: 'Segoe UI', Arial, sans-serif;
    padding-bottom: 120px; /* For sticky nav */
  }

  [data-theme="dark"] .qb-hive-page {
    background: #121212;
  }

  /* ── Hero ── */
  .hive-hero {
    position: relative;
    background: linear-gradient(145deg, #F4B400 0%, #F59E0B 60%, #D97706 100%);
    padding: 36px 20px 56px;
    text-align: center;
    overflow: hidden;
  }

  .hive-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 20% 50%, rgba(255,255,255,0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .hive-hero-inner {
    position: relative;
    z-index: 2;
  }

  .hive-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(0,0,0,0.14);
    backdrop-filter: blur(8px);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 5px 14px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.25);
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .hive-title {
    font-size: 2.4rem;
    font-weight: 900;
    color: #fff;
    margin: 0 0 8px;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 12px rgba(0,0,0,0.18);
    line-height: 1.1;
  }

  .hive-subtitle {
    font-size: 14px;
    font-weight: 500;
    color: rgba(255,255,255,0.88);
    margin: 0;
    letter-spacing: 0.01em;
  }

  /* ── Service Grid ── */
  .service-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    padding: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Service Card ── */
  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    border-radius: 16px;
    text-align: center;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .service-icon {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 12px;
  }

  .service-name {
    font-weight: bold;
    font-size: 1rem;
    color: inherit;
  }

  .service-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    font-size: 0.7rem;
    font-weight: 900;
    padding: 4px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  /* Active Cards */
  .service-card.active {
    background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
    color: #000;
    box-shadow: 0 8px 16px rgba(245, 158, 11, 0.2);
  }

  .service-card.active:hover {
    transform: scale(1.03);
    box-shadow: 0 12px 24px rgba(245, 158, 11, 0.3);
  }

  .service-card.active .service-badge.live {
    background: #fff;
    color: #000;
  }

  /* Soon Cards */
  .service-card.soon {
    background-color: #F3F4F6;
    border: 1px solid #E5E7EB;
    color: #6B7280;
    opacity: 0.6;
    pointer-events: none;
  }

  .service-card.soon .service-icon {
    filter: grayscale(100%);
  }

  .service-card.soon .service-badge.soon {
    background: #D1D5DB;
    color: #4B5563;
  }
  
  /* Dark Mode Soon Cards */
  [data-theme="dark"] .service-card.soon {
    background-color: #1E1E1E;
    border: 1px solid #333333;
    color: #9CA3AF;
  }

  [data-theme="dark"] .service-card.soon .service-badge.soon {
    background: #4B5563;
    color: #1E1E1E;
  }

  /* ── Desktop Layout ── */
  @media (min-width: 768px) {
    .service-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .service-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Hive Services",
  "settings": [],
  "presets": [
    {
      "name": "Hive Services"
    }
  ]
}
{% endschema %}
