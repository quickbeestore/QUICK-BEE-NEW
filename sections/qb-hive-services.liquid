{%- doc -%}
  QuickBee Services Hub — Professional home, tech & vehicle services.
  Pure service bookings only (no products).
{%- enddoc -%}

<style>
/* ═══════════════════════════════════════
   QSH — QuickBee Services Hub v3
═══════════════════════════════════════ */
:root {
  --qsh-gold: #F4B400;
  --qsh-spring: cubic-bezier(0.34,1.56,0.64,1);
  --qsh-smooth: cubic-bezier(0.4,0,0.2,1);
}

.qsh-wrap {
  background: #0a0a0a;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  overflow-x: hidden;
  padding-bottom: 100px;
}

/* ── Hero Banner ── */
.qsh-hero {
  position: relative;
  background: linear-gradient(135deg, #0f0f0f 0%, #1a1200 50%, #0f0f0f 100%);
  padding: 40px 20px 36px;
  overflow: hidden;
  border-bottom: 1px solid rgba(244,180,0,0.12);
}
.qsh-hero::before {
  content: '';
  position: absolute;
  top: -60px; left: 50%; transform: translateX(-50%);
  width: 500px; height: 220px;
  background: radial-gradient(ellipse, rgba(244,180,0,0.14) 0%, transparent 70%);
  pointer-events: none;
}
.qsh-hero-orb {
  position: absolute;
  border-radius: 50%;
  opacity: 0.07;
  pointer-events: none;
  animation: qshFloat 7s ease-in-out infinite;
}
.qsh-hero-orb:nth-child(1) { width: 200px; height: 200px; background: #F4B400; top: -60px; right: -40px; animation-delay: 0s; }
.qsh-hero-orb:nth-child(2) { width: 120px; height: 120px; background: #FF6B35; bottom: -30px; left: 10%; animation-delay: 3s; }
@keyframes qshFloat {
  0%,100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-14px) scale(1.05); }
}

.qsh-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(244,180,0,0.12);
  border: 1px solid rgba(244,180,0,0.3);
  color: #F4B400;
  font-size: 11px;
  font-weight: 800;
  padding: 5px 12px;
  border-radius: 20px;
  margin-bottom: 14px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}
.qsh-hero-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #F4B400;
  animation: qshDotPulse 1.5s ease-in-out infinite;
}
@keyframes qshDotPulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(244,180,0,0.7); }
  50% { box-shadow: 0 0 0 5px rgba(244,180,0,0); }
}

.qsh-hero-title {
  font-size: clamp(26px, 7vw, 40px);
  font-weight: 900;
  color: #fff;
  line-height: 1.1;
  letter-spacing: -0.5px;
  margin: 0 0 10px 0;
}
.qsh-hero-title span { color: #F4B400; }

.qsh-hero-sub {
  font-size: 14px;
  color: rgba(255,255,255,0.55);
  line-height: 1.6;
  max-width: 480px;
  margin: 0 0 24px 0;
}

.qsh-hero-stats {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}
.qsh-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.qsh-stat-num {
  font-size: 20px;
  font-weight: 900;
  color: #F4B400;
  line-height: 1;
}
.qsh-stat-label {
  font-size: 10px;
  color: rgba(255,255,255,0.4);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

/* ── Trending Strip ── */
.qsh-trending {
  background: #111;
  border-bottom: 1px solid #1e1e1e;
  padding: 0;
  overflow: hidden;
}
.qsh-trending-inner {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding: 10px 14px;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  white-space: nowrap;
}
.qsh-trending-inner::-webkit-scrollbar { display: none; }
.qsh-trend-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  color: #bbb;
  font-size: 11px;
  font-weight: 600;
  padding: 6px 12px;
  border-radius: 20px;
  white-space: nowrap;
  cursor: pointer;
  transition: all 0.2s ease;
  text-decoration: none;
  flex-shrink: 0;
}
.qsh-trend-pill:hover, .qsh-trend-pill.active {
  background: rgba(244,180,0,0.12);
  border-color: rgba(244,180,0,0.35);
  color: #F4B400;
}

/* ── Section Title ── */
.qsh-section-title {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 28px 16px 14px;
}
.qsh-section-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.qsh-section-dot.live {
  background: #22c55e;
  box-shadow: 0 0 0 2px rgba(34,197,94,0.25);
  animation: qshLivePulse 2s ease-in-out infinite;
}
.qsh-section-dot.soon { background: #888; }
@keyframes qshLivePulse {
  0%,100% { box-shadow: 0 0 0 2px rgba(34,197,94,0.25); }
  50% { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
}
.qsh-section-label {
  font-size: 15px;
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.2px;
  text-transform: uppercase;
}
.qsh-section-count {
  margin-left: auto;
  font-size: 11px;
  font-weight: 700;
  color: #555;
}

/* ── Service Grid ── */
.qsh-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  padding: 0 12px 8px;
}
@media (min-width: 640px) { .qsh-grid { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 900px) { .qsh-grid { grid-template-columns: repeat(4, 1fr); } }
@media (min-width: 1200px) { .qsh-grid { grid-template-columns: repeat(5, 1fr); } }

/* ── Service Card ── */
.qsh-card {
  background: linear-gradient(155deg, #1c1c1c 0%, #141414 100%);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16px;
  padding: 16px 14px 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  cursor: pointer;
  text-decoration: none;
  transition: transform 0.22s var(--qsh-spring), box-shadow 0.22s ease, border-color 0.22s ease;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 18px rgba(0,0,0,0.45);
}
.qsh-card::before {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
  transition: left 0.5s ease;
  pointer-events: none;
}
.qsh-card:hover::before { left: 150%; }
.qsh-card:hover {
  transform: translateY(-5px) scale(1.02);
  border-color: rgba(244,180,0,0.3);
  box-shadow: 0 14px 38px rgba(0,0,0,0.55), 0 0 0 1px rgba(244,180,0,0.12), 0 4px 14px rgba(244,180,0,0.06);
}
.qsh-card.soon {
  opacity: 0.6;
  cursor: not-allowed;
  pointer-events: none;
}

/* Card header row */
.qsh-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

/* Icon */
.qsh-icon {
  width: 48px; height: 48px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px;
  background: rgba(244,180,0,0.08);
  flex-shrink: 0;
  transition: transform 0.2s var(--qsh-spring);
}
.qsh-card:hover .qsh-icon { transform: scale(1.1) rotate(-4deg); }

/* Badges */
.qsh-badge {
  font-size: 9px;
  font-weight: 900;
  padding: 3px 8px;
  border-radius: 20px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  flex-shrink: 0;
}
.qsh-badge.live-badge {
  background: rgba(34,197,94,0.15);
  color: #4ade80;
  border: 1px solid rgba(34,197,94,0.3);
}
.qsh-badge.fast-badge {
  background: rgba(244,180,0,0.15);
  color: #F4B400;
  border: 1px solid rgba(244,180,0,0.3);
}
.qsh-badge.soon-badge {
  background: rgba(120,120,120,0.1);
  color: #777;
  border: 1px solid rgba(120,120,120,0.2);
}
.qsh-badge.new-badge {
  background: rgba(139,92,246,0.15);
  color: #a78bfa;
  border: 1px solid rgba(139,92,246,0.3);
}
.qsh-badge.hot-badge {
  background: rgba(239,68,68,0.15);
  color: #f87171;
  border: 1px solid rgba(239,68,68,0.3);
}

/* Service name */
.qsh-name {
  font-size: 12px;
  font-weight: 800;
  color: #f0f0f0;
  line-height: 1.3;
  letter-spacing: -0.1px;
}

/* Description */
.qsh-desc {
  font-size: 10px;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Price */
.qsh-price {
  font-size: 13px;
  font-weight: 900;
  color: #F4B400;
  letter-spacing: -0.2px;
}
.qsh-price-label {
  font-size: 9px;
  color: #555;
  font-weight: 600;
}

/* Book button */
.qsh-book-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  width: 100%;
  padding: 9px 0;
  background: rgba(244,180,0,0.1);
  border: 1px solid rgba(244,180,0,0.25);
  border-radius: 10px;
  color: #F4B400;
  font-size: 11px;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.2s ease;
  margin-top: auto;
  text-decoration: none;
}
.qsh-book-btn:hover {
  background: rgba(244,180,0,0.18);
  border-color: rgba(244,180,0,0.5);
  transform: translateY(-1px);
}

/* ── Category divider ── */
.qsh-cat-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 24px 16px 12px;
}
.qsh-cat-icon { font-size: 20px; }
.qsh-cat-info { flex: 1; }
.qsh-cat-name {
  font-size: 16px;
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.3px;
}
.qsh-cat-sub {
  font-size: 11px;
  color: #555;
  margin-top: 2px;
}
.qsh-cat-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, rgba(244,180,0,0.2) 0%, transparent 100%);
}

/* ── Coming Soon Section ── */
.qsh-soon-section {
  padding: 20px 12px;
  background: linear-gradient(180deg, #0f0f0f 0%, #0a0a0a 100%);
  border-top: 1px solid rgba(255,255,255,0.04);
  margin-top: 16px;
}
.qsh-soon-title {
  font-size: 13px;
  font-weight: 800;
  color: #444;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  text-align: center;
  margin-bottom: 14px;
}
.qsh-soon-grid {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  padding-bottom: 4px;
  scrollbar-width: none;
}
.qsh-soon-grid::-webkit-scrollbar { display: none; }
.qsh-soon-card {
  flex: 0 0 130px;
  background: rgba(255,255,255,0.02);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 14px;
  padding: 16px 12px;
  display: flex; flex-direction: column;
  align-items: center; gap: 8px;
  opacity: 0.5;
}
.qsh-soon-icon { font-size: 28px; }
.qsh-soon-name { font-size: 11px; font-weight: 700; color: #555; text-align: center; }
.qsh-soon-badge {
  font-size: 9px; font-weight: 800;
  color: #444; background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  padding: 3px 8px; border-radius: 20px;
}

/* ── Bottom CTA ── */
.qsh-bottom-cta {
  background: linear-gradient(135deg, #1a1100 0%, #0f0f0f 50%, #001a0a 100%);
  border: 1px solid rgba(244,180,0,0.12);
  border-radius: 20px;
  margin: 16px 12px 24px;
  padding: 28px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.qsh-bottom-cta::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, #F4B400, transparent);
  opacity: 0.5;
}
.qsh-cta-title {
  font-size: 18px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 6px;
  letter-spacing: -0.3px;
}
.qsh-cta-sub {
  font-size: 13px;
  color: rgba(255,255,255,0.4);
  margin-bottom: 18px;
}
.qsh-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, #F4B400, #FFD700);
  color: #000;
  font-size: 13px;
  font-weight: 900;
  padding: 12px 28px;
  border-radius: 12px;
  text-decoration: none;
  transition: all 0.2s ease;
  box-shadow: 0 4px 16px rgba(244,180,0,0.38);
}
.qsh-cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(244,180,0,0.52);
}

/* ── Vendor badge strip ── */
.qsh-vendor-strip {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 16px;
  background: rgba(255,255,255,0.02);
  border-bottom: 1px solid rgba(255,255,255,0.04);
  overflow-x: auto;
  scrollbar-width: none;
}
.qsh-vendor-strip::-webkit-scrollbar { display: none; }
.qsh-vendor-tag {
  flex-shrink: 0;
  font-size: 10px;
  font-weight: 700;
  color: #555;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  padding: 4px 10px;
  border-radius: 20px;
  white-space: nowrap;
}
.qsh-vendor-label {
  font-size: 10px;
  font-weight: 700;
  color: #333;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  white-space: nowrap;
  flex-shrink: 0;
}
</style>

