      </div>

      <div class="qsh-soon-card">
        <span class="qsh-soon-icon">🛻</span>
        <div class="qsh-soon-name">Moving &amp; Shifting</div>
        <div class="qsh-soon-sub">Furniture &amp; boxes</div>
        <span class="qsh-soon-lock">🔒 Soon</span>
      </div>

      <div class="qsh-soon-card">
        <span class="qsh-soon-icon">🔩</span>
