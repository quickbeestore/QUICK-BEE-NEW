<!-- QuickBee Collection Page - Professional Dark Theme -->
<style>
:root {
  --qb-gold: #F4B400;
  --qb-black: #0A0A0A;
  --qb-dark2: #111111;
  --qb-dark3: #181818;
  --qb-border: rgba(255,255,255,0.08);
  --qb-text: #F0F0F0;
  --qb-text2: #999999;
  --qb-success: #4ADE80;
  --qb-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

.qb-collection {
  background: var(--qb-black) !important;
  color: var(--qb-text);
  overflow-x: hidden;
}

/* Collection Header */
.qb-collection-header {
  padding: 40px 16px;
  background: linear-gradient(135deg, #1A1A1A 0%, #0A0A0A 100%);
  border-bottom: 1px solid var(--qb-border);
  position: relative;
}

.qb-collection-header::after {
  content: "";
  position: absolute;
  bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--qb-gold), transparent);
  opacity: 0.3;
}

@media(min-width: 1024px) {
  .qb-collection-header {
    padding: 60px 48px;
  }
}

.qb-collection-header h1 {
  font-size: 32px;
  font-weight: 900;
  color: #fff;
  margin: 0 0 12px 0;
  line-height: 1.2;
}

@media(min-width: 1024px) {
  .qb-collection-header h1 {
    font-size: 48px;
  }
}

.qb-collection-header p {
  font-size: 16px;
  color: var(--qb-text2);
  margin: 0;
  line-height: 1.6;
}

.qb-collection-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 24px;
  flex-wrap: wrap;
}

.qb-product-count {
  background: rgba(244, 180, 0, 0.1);
  color: var(--qb-gold);
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 800;
  border: 1px solid rgba(244, 180, 0, 0.3);
}

/* Main Container */
.qb-collection-container {
  display: flex;
  gap: 32px;
  padding: 24px 16px 100px;
}

@media(min-width: 1024px) {
  .qb-collection-container {
    padding: 60px 48px 100px;
  }
}

/* Sidebar */
.qb-collection-sidebar {
  display: none;
  flex-direction: column;
  gap: 24px;
  width: 100px;
  flex-shrink: 0;
}

@media(min-width: 1024px) {
  .qb-collection-sidebar {
    display: flex;
  }
}

.qb-filter-section {
  border: 1px solid var(--qb-border);
  border-radius: 20px;
  padding: 24px;
  background: var(--qb-dark2);
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}

.qb-filter-title {
  font-size: 13px;
  font-weight: 800;
  color: #fff;
  margin: 0 0 20px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}

.qb-filter-options {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.qb-filter-option {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  padding: 6px 0;
  transition: all 0.2s;
}

.qb-filter-option input {
  width: 20px;
  height: 20px;
  cursor: pointer;
  accent-color: var(--qb-gold);
}

.qb-filter-option label {
  font-size: 14px;
  color: var(--qb-text2);
  cursor: pointer;
  flex: 1;
}

.qb-filter-option:hover label {
  color: #fff;
}

.qb-filter-option input:checked + label {
  color: var(--qb-gold);
  font-weight: 700;
}

/* Content Area */
.qb-collection-content {
  flex: 1;
  min-width: 0;
  width: calc(100% - 100px);
}

/* Sort & Controls */
.qb-collection-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32px;
  gap: 16px;
  flex-wrap: wrap;
}

.qb-sort-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
}

.qb-sort-wrapper label {
  font-size: 14px;
  font-weight: 700;
  color: var(--qb-text2);
}

.qb-sort-select {
  padding: 10px 18px;
  background: var(--qb-dark2);
  border: 1.5px solid var(--qb-border);
  border-radius: 12px;
  font-size: 14px;
  color: #fff;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
}

.qb-sort-select:hover {
  border-color: var(--qb-gold);
  background: var(--qb-dark3);
}

/* Product Grid */
.qb-collection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 8px;
}
@media (min-width: 640px) {
  .qb-collection-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
}
@media (min-width: 1024px) {
  .qb-collection-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }
}

/* ── Product Card ── */
.qb-product {
  background: #1a1a1a;
  border: 1px solid #2a2a2a;
  border-radius: 16px;
  overflow: hidden;
  padding: 0;
  cursor: pointer;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.2s ease;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2px 8px rgba(0,0,0,0.4);
  position: relative;
}
[data-theme="dark"] .qb-product {
  background: #161616;
  border-color: #252525;
}
html:not([data-theme="dark"]) .qb-product {
  background: #ffffff !important;
  border-color: #e8e8e8 !important;
  box-shadow: 0 2px 12px rgba(0,0,0,0.07) !important;
}
.qb-product:hover {
  transform: translateY(-3px);
  border-color: #F4B400;
  box-shadow: 0 8px 28px rgba(244,180,0,0.18);
}

/* ── Image wrapper ── */
.qb-product-img {
  width: 100%;
  aspect-ratio: 1;
  position: relative;
  overflow: hidden;
  background: #f5f0e8;
  flex-shrink: 0;
}
.qb-product-img img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform 0.3s ease;
}
.qb-product:hover .qb-product-img img {
  transform: scale(1.04);
}

/* Discount badge */
.qb-off-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  background: #E53935;
  color: #fff;
  font-size: 10px;
  font-weight: 800;
  padding: 3px 7px;
  border-radius: 6px;
  z-index: 10;
  letter-spacing: 0.3px;
}

/* ── Info section ── */
.qb-product-info {
  padding: 10px 12px 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
}

/* Delivery badge */
.qb-product-delivery {
  font-size: 11px;
  font-weight: 700;
  color: #22c55e;
  display: flex;
  align-items: center;
  gap: 3px;
}
html:not([data-theme="dark"]) .qb-product-delivery {
  color: #16a34a;
}

/* Title */
.qb-product-title {
  font-size: 13px;
  font-weight: 700;
  color: #f0f0f0;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
html:not([data-theme="dark"]) .qb-product-title {
  color: #111111 !important;
}

/* Price */
.qb-product-pricing {
  display: flex;
  align-items: baseline;
  gap: 6px;
  margin-top: 2px;
}
.qb-product-price {
  font-size: 18px;
  font-weight: 900;
  color: #F4B400;
  letter-spacing: -0.3px;
  line-height: 1;
}
html:not([data-theme="dark"]) .qb-product-price {
  color: #1a1a1a !important;
}
.qb-product-original-price {
  font-size: 12px;
  color: #555;
  text-decoration: line-through;
}
html:not([data-theme="dark"]) .qb-product-original-price {
  color: #aaa !important;
}

/* ── Add to Cart button ── */
.qb-product-btn {
  margin-top: auto;
  width: 100%;
  padding: 10px;
  background: transparent;
  border: 1.5px solid #F4B400;
  border-radius: 10px;
  font-weight: 800;
  font-size: 13px;
  color: #F4B400;
  cursor: pointer;
  transition: all 0.18s ease;
  -webkit-appearance: none;
  appearance: none;
  letter-spacing: 0.3px;
}
.qb-product-btn:hover {
  background: #F4B400;
  color: #000;
}
.qb-product-btn:active {
  transform: scale(0.97);
}
html:not([data-theme="dark"]) .qb-product-btn {
  border-color: #1a1a1a !important;
  color: #1a1a1a !important;
}
html:not([data-theme="dark"]) .qb-product-btn:hover {
  background: #1a1a1a !important;
  color: #fff !important;
}

.qb-load-more {
  background: #F4B400;
  border: none;
  padding: 14px 36px;
  border-radius: 12px;
  font-weight: 800;
  font-size: 15px;
  color: #000;
  cursor: pointer;
  transition: all 0.2s ease;
  min-width: 200px;
  box-shadow: 0 4px 16px rgba(244,180,0,0.3);
}
.qb-load-more:hover {
  background: #FFD700;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(244,180,0,0.4);
}
</style>

<div class="qb-collection">
  <div class="qb-collection-header">
    <h1>{{ collection.title | default: 'Collection' }}</h1>
    <p>{{ collection.description | strip_html | truncate: 160 | default: 'Explore our premium selection of products delivered fast.' }}</p>
    <div class="qb-collection-meta">
      <div class="qb-product-count">📦 {{ collection.products_count | default: 0 }} Products</div>
    </div>
  </div>

  <div class="qb-collection-container">
    <aside class="qb-collection-sidebar">
      <!-- Filter Sections could be dynamic here -->
      <div class="qb-filter-section">
        <div class="qb-filter-title">Filters</div>
        <div class="qb-filter-options">
           <p style="color: var(--qb-text2); font-size: 13px;">Use the sort and filter options below to find exactly what you need.</p>
        </div>
      </div>
    </aside>

    <div class="qb-collection-content">
      <div class="qb-collection-controls">
        <div class="qb-sort-wrapper">
          <label for="sort-select">Sort By:</label>
          <select id="sort-select" class="qb-sort-select">
            <option value="popular">Most Popular</option>
            <option value="price-low">Price: Low to High</option>
            <option value="price-high">Price: High to Low</option>
            <option value="newest">Newest</option>
          </select>
        </div>
      </div>

      <div class="qb-collection-grid">
        {% for product in collection.products %}
          {%- assign has_discount = false -%}
          {%- assign discount_pct = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign has_discount = true -%}
            {%- assign savings = product.compare_at_price | minus: product.price -%}
            {%- assign discount_pct = savings | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}
          <a href="{{ product.url }}" class="qb-product">
            <div class="qb-product-img">
              {%- if has_discount -%}
                <div class="qb-off-badge">{{ discount_pct }}% OFF</div>
              {%- endif -%}
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
              {% else %}
                📦
              {% endif %}
            </div>
            <div class="qb-product-info">
              <div class="qb-product-title">{{ product.title }}</div>
              <div class="qb-product-delivery">⚡ 18-25 mins</div>
              <div class="qb-product-pricing">
                <span class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</span>
                {%- if has_discount -%}
                  <span class="qb-product-original-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                {%- endif -%}
              </div>
              <button class="qb-product-btn" onclick="event.preventDefault(); fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:[{id:{{ product.variants.first.id }},quantity:1}]})}).then(()=>{this.textContent='✓ Added';this.style.background='linear-gradient(135deg,#22c55e,#16a34a)';setTimeout(()=>{this.textContent='Add to Cart';this.style.background='';},1500)})">Add to Cart</button>
            </div>
          </a>
        {% endfor %}
      </div>

      {% if collection.products_count > 12 %}
      <div style="display: flex; justify-content: center; margin-top: 40px;">
        <button class="qb-load-more">Load More Products</button>
      </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "QuickBee Collection",
  "settings": [],
  "presets": [
    {
      "name": "QuickBee Collection"
    }
  ]
}
{% endschema %}
