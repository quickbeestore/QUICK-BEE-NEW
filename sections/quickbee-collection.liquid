<!-- QuickBee Collection Page - Professional Design -->
<style>
:root {
  --qb-gold: #F4B400;
  --qb-black: #111111;
  --qb-cream: #FFF8E8;
  --qb-light: #F5F5F5;
  --qb-success: #16A34A;
  --qb-shadow: 0 4px 16px rgba(0,0,0,0.08);
}

.qb-collection {
  background: #fff;
  overflow-x: hidden;
}

/* Collection Header */
.qb-collection-header {
  padding: 16px;
  background: linear-gradient(135deg, #FFF8E8 0%, #FFFBF0 100%);
  border-bottom: 1px solid #e8e8e8;
}

@media(min-width: 1024px) {
  .qb-collection-header {
    padding: 16px 48px;
  }
}

.qb-collection-header h1 {
  font-size: 32px;
  font-weight: 900;
  color: var(--qb-black);
  margin: 0 0 12px 0;
  line-height: 1.2;
}

@media(min-width: 1024px) {
  .qb-collection-header h1 {
    font-size: 48px;
  }
}

.qb-collection-header p {
  font-size: 16px;
  color: #666;
  margin: 0;
  line-height: 1.6;
}

.qb-collection-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 20px;
  flex-wrap: wrap;
}

.qb-product-count {
  background: var(--qb-gold);
  color: var(--qb-black);
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 700;
}

/* Main Container */
.qb-collection-container {
  display: flex;
  gap: 24px;
  padding: 0 16px;
}

@media(min-width: 1024px) {
  .qb-collection-container {
    padding: 0 48px;
  }
}

/* Sidebar */
.qb-collection-sidebar {
  display: none;
  flex-direction: column;
  gap: 24px;
  width: 280px;
  flex-shrink: 0;
}

@media(min-width: 1024px) {
  .qb-collection-sidebar {
    display: flex;
  }
}

.qb-filter-section {
  border: 1px solid #e8e8e8;
  border-radius: 12px;
  padding: 20px;
  background: #fff;
}

.qb-filter-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--qb-black);
  margin: 0 0 16px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.qb-filter-toggle {
  display: none;
  width: 20px;
  height: 20px;
  background: none;
  border: none;
  cursor: pointer;
  font-size: 16px;
}

@media(max-width: 1023px) {
  .qb-filter-toggle {
    display: block;
  }
}

.qb-filter-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.qb-filter-option {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  padding: 8px 0;
}

.qb-filter-option input {
  width: 18px;
  height: 18px;
  cursor: pointer;
  accent-color: var(--qb-gold);
}

.qb-filter-option label {
  font-size: 13px;
  color: #666;
  cursor: pointer;
  flex: 1;
}

.qb-filter-option input:checked + label {
  color: var(--qb-black);
  font-weight: 600;
}

/* Content Area */
.qb-collection-content {
  flex: 1;
  min-width: 0;
}

/* Sort & View Options */
.qb-collection-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 24px;
  gap: 16px;
  flex-wrap: wrap;
}

.qb-sort-wrapper {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
  flex-shrink: 0;
}

.qb-sort-wrapper label {
  font-size: 13px;
  font-weight: 600;
  color: var(--qb-black);
}

.qb-sort-select {
  padding: 8px 12px;
  border: 1.5px solid #e8e8e8;
  border-radius: 8px;
  font-size: 13px;
  background: #fff;
  color: var(--qb-black);
  cursor: pointer;
  font-weight: 500;
  transition: all 0.3s ease;
}

.qb-sort-select:hover {
  border-color: var(--qb-gold);
  box-shadow: 0 2px 8px rgba(244, 180, 0, 0.1);
}

.qb-sort-select:focus {
  outline: none;
  border-color: var(--qb-gold);
  box-shadow: 0 0 0 3px rgba(244, 180, 0, 0.1);
}

/* Product Grid */
.qb-collection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 32px;
}

@media(min-width: 768px) {
  .qb-collection-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
}

@media(min-width: 1024px) {
  .qb-collection-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
}

/* Product Card */
.qb-product {
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 12px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
}

.qb-product:hover {
  border-color: var(--qb-gold);
  box-shadow: var(--qb-shadow);
  transform: translateY(-4px);
}

.qb-product-img {
  width: 100%;
  aspect-ratio: 1;
  background: var(--qb-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  overflow: hidden;
}

.qb-product-info {
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}

.qb-product-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--qb-black);
  line-height: 1.3;
  min-height: 26px;
}

.qb-product-delivery {
  font-size: 11px;
  color: var(--qb-success);
  font-weight: 600;
}

.qb-product-pricing {
  display: flex;
  align-items: center;
  gap: 6px;
}

.qb-product-price {
  font-size: 16px;
  font-weight: 800;
  color: var(--qb-black);
}

.qb-product-original-price {
  font-size: 12px;
  color: #999;
  text-decoration: line-through;
}

.qb-product-badge {
  display: inline-block;
  background: var(--qb-gold);
  color: var(--qb-black);
  padding: 3px 8px;
  border-radius: 6px;
  font-size: 10px;
  font-weight: 700;
  margin-top: 6px;
}

.qb-product-btn {
  background: var(--qb-gold);
  border: none;
  padding: 10px;
  border-radius: 8px;
  font-weight: 700;
  font-size: 13px;
  color: var(--qb-black);
  cursor: pointer;
  transition: all 0.3s ease;
  margin-top: auto;
}

.qb-product-btn:hover {
  background: #E8A500;
  transform: scale(1.02);
}

/* Pagination */
.qb-collection-pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  margin-top: 40px;
}

.qb-load-more {
  background: var(--qb-gold);
  border: none;
  padding: 14px 32px;
  border-radius: 28px;
  font-weight: 700;
  font-size: 15px;
  color: var(--qb-black);
  cursor: pointer;
  transition: all 0.3s ease;
  min-width: 200px;
}

.qb-load-more:hover {
  background: #E8A500;
  transform: translateY(-2px);
  box-shadow: var(--qb-shadow);
}

.qb-pagination-numbers {
  display: flex;
  gap: 4px;
}

.qb-pagination-btn {
  width: 36px;
  height: 36px;
  border: 1.5px solid #e8e8e8;
  background: #fff;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  color: var(--qb-black);
  transition: all 0.3s ease;
}

.qb-pagination-btn:hover {
  border-color: var(--qb-gold);
  color: var(--qb-gold);
}

.qb-pagination-btn.active {
  background: var(--qb-gold);
  border-color: var(--qb-gold);
  color: var(--qb-black);
}

/* Empty State */
.qb-collection-empty {
  text-align: center;
  padding: 60px 20px;
}

.qb-collection-empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.qb-collection-empty h2 {
  font-size: 24px;
  font-weight: 900;
  color: var(--qb-black);
  margin: 0 0 12px 0;
}

.qb-collection-empty p {
  font-size: 14px;
  color: #666;
  margin: 0;
}

/* Mobile Filter Toggle */
.qb-mobile-filter-toggle {
  display: none;
  width: 100%;
  padding: 12px 16px;
  background: var(--qb-gold);
  border: none;
  border-radius: 8px;
  font-weight: 700;
  font-size: 14px;
  color: var(--qb-black);
  cursor: pointer;
  margin-bottom: 20px;
  transition: all 0.3s ease;
}

@media(max-width: 1023px) {
  .qb-mobile-filter-toggle {
    display: block;
  }
}

.qb-mobile-filter-toggle:hover {
  background: #E8A500;
  transform: translateY(-2px);
}

/* Responsive */
@media(max-width: 1023px) {
  .qb-collection-container {
    flex-direction: column;
    gap: 0;
  }

  .qb-collection-sidebar {
    order: -1;
    width: 100%;
  }

  .qb-filter-section {
    display: none;
  }

  .qb-filter-section.open {
    display: block;
  }
}
</style>

