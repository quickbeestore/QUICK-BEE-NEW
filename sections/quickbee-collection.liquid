<script>
// Mobile filter toggle
document.querySelector('.qb-mobile-filter-toggle')?.addEventListener('click', function() {
  const sidebar = document.querySelector('.qb-collection-sidebar');
  sidebar.style.display = sidebar.style.display === 'none' ? 'flex' : 'none';
});

// Filter section toggles
document.querySelectorAll('.qb-filter-toggle').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    const section = this.closest('.qb-filter-section');
    const options = section.querySelector('.qb-filter-options');
    options.style.display = options.style.display === 'none' ? 'flex' : 'none';
    this.textContent = options.style.display === 'none' ? '+' : '−';
  });
});

// Filter checkbox listeners
document.querySelectorAll('.qb-filter-option input').forEach(checkbox => {
  checkbox.addEventListener('change', function() {
    console.log('Filter applied:', this.value);
    // Add filtering logic here
  });
});

// Sort dropdown
document.getElementById('sort-select')?.addEventListener('change', function() {
  console.log('Sort changed:', this.value);
  // Add sorting logic here
});

// Load more button
document.querySelector('.qb-load-more')?.addEventListener('click', function() {
  console.log('Loading more products...');
  // Add pagination logic here
});

// Add to cart buttons
document.querySelectorAll('.qb-product-btn').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    const productName = this.closest('.qb-product-info').querySelector('.qb-product-title').textContent;
    console.log('Added to cart:', productName);
    // Add to cart logic here
  });
});
</script>
