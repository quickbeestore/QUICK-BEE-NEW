<!-- QuickBee Collection Page - Dual Theme (Dhido & The Grills) -->
<style>
/* ── CSS Variables ── */
:root {
  --qb-gold: #F4B400;
  --qb-bg: #2D1F12;
  --qb-bg2: #2A1F12;
  --qb-bg3: #1A140D;
  --qb-border: #3D2F1F;
  --qb-text: #F5EFE7;
  --qb-text2: #B89F7E;
  --qb-success: #4ADE80;
  --qb-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

/* ── Base ── */
.qb-collection {
  background: linear-gradient(135deg, #1A140D 0%, #2D1F12 100%);
  color: var(--qb-text);
  overflow-x: hidden;
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

/* ── Hero / Collection Header ── */
.dhido-collection-hero {
  padding: 40px 16px 36px;
  background: linear-gradient(135deg, #1A140D 0%, #2D1F12 100%);
  border-bottom: 1px solid var(--qb-border);
  position: relative;
  text-align: center;
  min-height: 280px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
[data-theme="dark"] .dhido-collection-hero {
  background: linear-gradient(135deg, #1A140D 0%, #2D1F12 100%) !important;
  border-bottom-color: #3D2F1F !important;
}
.dhido-collection-hero::after {
  content: "";
  position: absolute;
  bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--qb-gold), transparent);
  opacity: 0.5;
}

@media(min-width: 768px) {
  .dhido-collection-hero { min-height: 380px; padding: 50px 32px; }
}
@media(min-width: 1024px) {
  .dhido-collection-hero { min-height: 480px; padding: 60px 48px; }
}

/* ── Dual Logo ── */
.dhido-logo-wrap {
  margin-bottom: 12px;
}
.dhido-logo {
  display: block;
  width: 140px;
  max-width: 140px;
  height: auto;
  margin: 0 auto;
}
.dhido-logo-light { display: block; }
.dhido-logo-dark  { display: none;  }

[data-theme="dark"] .dhido-logo-light { display: none !important; }
[data-theme="dark"] .dhido-logo-dark  { display: block !important; }

@media(min-width: 768px) {
  .dhido-logo { width: 200px; max-width: 200px; }
}
@media(min-width: 1024px) {
  .dhido-logo { width: 280px; max-width: 280px; }
}

/* ── Grills text ── */
.dhido-grills-text {
  font-size: 36px;
  font-weight: 900;
  color: #D4A545;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin: 4px 0 8px;
  line-height: 1.1;
}
[data-theme="dark"] .dhido-grills-text {
  color: #F4B400 !important;
}
@media(min-width: 768px) {
  .dhido-grills-text { font-size: 48px; }
}
@media(min-width: 1024px) {
  .dhido-grills-text { font-size: 56px; }
}

/* ── Tagline ── */
.dhido-tagline {
  font-size: 14px;
  font-weight: 500;
  color: var(--qb-text2);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin: 0 0 20px;
}
@media(min-width: 768px) {
  .dhido-tagline { font-size: 16px; }
}

/* ── Meta (product count + badges) ── */
.qb-collection-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
}

.qb-product-count {
  background: rgba(212, 165, 69, 0.12);
  color: #D4A545;
  padding: 7px 16px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 800;
  border: 1px solid rgba(212, 165, 69, 0.35);
}
[data-theme="dark"] .qb-product-count {
  background: rgba(244, 180, 0, 0.1) !important;
  color: #F4B400 !important;
  border-color: rgba(244, 180, 0, 0.3) !important;
}

/* Legacy .qb-collection-header alias (keeps sidebar/controls unaffected) */
.qb-collection-header {
  padding: 0;
}

/* Collection subtitle if present */
.qb-collection-subtitle {
  font-size: 15px;
  color: var(--qb-text2);
  margin: 0 0 8px;
  line-height: 1.6;
}

/* Main Container */
.qb-collection-container {
  display: flex;
  gap: 32px;
  padding: 24px 16px 100px;
  flex-grow: 1;
}

@media(min-width: 1024px) {
  .qb-collection-container {
    padding: 60px 48px 100px;
  }
}

/* Sidebar */
.qb-collection-sidebar {
  display: none;
  flex-direction: column;
  gap: 24px;
  width: 280px;
  flex-shrink: 0;
  position: sticky;
  top: 20px;
  height: calc(100vh - 40px);
  overflow-y: auto;
  scrollbar-width: none;
}

.qb-collection-sidebar::-webkit-scrollbar {
  display: none;
}

@media(min-width: 1024px) {
  .qb-collection-sidebar {
    display: flex;
  }
}

.qb-filter-section {
  border: 1px solid var(--qb-border);
  border-radius: 20px;
  padding: 24px;
  background: var(--qb-bg2);
  box-shadow: var(--qb-shadow);
}

.qb-filter-title {
  font-size: 13px;
  font-weight: 800;
  color: var(--qb-text);
  margin: 0 0 20px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}

.qb-filter-options {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.qb-filter-option {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  padding: 6px 0;
  transition: all 0.2s;
}

.qb-filter-option input {
  width: 20px;
  height: 20px;
  cursor: pointer;
  accent-color: var(--qb-gold);
}

.qb-filter-option label {
  font-size: 14px;
  color: var(--qb-text2);
  cursor: pointer;
  flex: 1;
}

.qb-filter-option:hover label {
  color: var(--qb-text);
}

.qb-filter-option input:checked + label {
  color: var(--qb-gold);
  font-weight: 700;
}

/* Content Area */
.qb-collection-content {
  flex: 1;
  min-width: 0;
  width: calc(100% - 100px);
}

/* Sort & Controls */
.qb-collection-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32px;
  gap: 16px;
  flex-wrap: wrap;
}

.qb-sort-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
}

.qb-sort-wrapper label {
  font-size: 14px;
  font-weight: 700;
  color: var(--qb-text2);
}

.qb-sort-select {
  padding: 10px 18px;
  background: var(--qb-bg2);
  border: 1.5px solid var(--qb-border);
  border-radius: 12px;
  font-size: 14px;
  color: var(--qb-text);
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
}

.qb-sort-select:hover {
  border-color: var(--qb-gold);
  background: var(--qb-bg3);
}

/* Product Grid */
.qb-collection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 8px;
}
@media (min-width: 640px) {
  .qb-collection-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
}
@media (min-width: 1024px) {
  .qb-collection-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }
}

/* ── Product Card ── */
.qb-product {
  background: #FFFFFF;
  border: 1px solid #E8DCC8;
  border-radius: 16px;
  overflow: hidden;
  padding: 0;
  cursor: pointer;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.2s ease;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  box-shadow: 0 1px 6px rgba(44,36,18,0.06), 0 4px 16px rgba(44,36,18,0.04);
  position: relative;
}
[data-theme="dark"] .qb-product {
  background: #2A1F12 !important;
  border-color: #3D2F1F !important;
  box-shadow: 0 2px 8px rgba(0,0,0,0.4) !important;
}
.qb-product:hover {
  transform: translateY(-3px);
  border-color: var(--qb-gold);
  box-shadow: 0 8px 28px rgba(212,165,69,0.22);
}
[data-theme="dark"] .qb-product:hover {
  box-shadow: 0 8px 28px rgba(244,180,0,0.18) !important;
}

/* ── Image section ── */
.qb-product-img {
  width: 100%;
  aspect-ratio: 1;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  background: #F5EDE0;
  border-top-left-radius: 16px;
  border-top-right-radius: 16px;
}
[data-theme="dark"] .qb-product-img {
  background: #1E1510 !important;
}
.qb-product-img img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 4px;
  transition: transform 0.3s ease;
}
.qb-product:hover .qb-product-img img {
  transform: scale(1.04);
}

/* ── Info section ── */
.product-info-wrapper {
  padding: 8px 10px 12px 10px;
  display: flex;
  flex-direction: column;
  flex: 1;
  background: #FFFFFF;
}
[data-theme="dark"] .qb-product .product-info-wrapper {
  background: #2A1F12 !important;
}

/* Delivery badge */
.qb-product-delivery {
  font-size: 11px;
  font-weight: 600;
  color: #6B5D4F;
  display: flex;
  align-items: center;
  gap: 3px;
  margin-bottom: 4px;
}
[data-theme="dark"] .qb-product .qb-product-delivery {
  color: #B89F7E !important;
}

/* Title */
.qb-product-title {
  font-size: 13px;
  font-weight: 600;
  color: #2C2412;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 36px;
  margin-bottom: 8px;
}
[data-theme="dark"] .qb-product .qb-product-title {
  color: #F5EFE7 !important;
}

/* Price & Action Row */
.price-action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  gap: 4px;
}

.qb-price-column {
  display: flex;
  flex-direction: column;
}

/* Price */
.qb-product-pricing {
  display: flex;
  align-items: baseline;
  gap: 4px;
}
.qb-product-price {
  font-size: 15px;
  font-weight: 800;
  color: #2C2412;
  letter-spacing: -0.3px;
  line-height: 1;
}
[data-theme="dark"] .qb-product .qb-product-price {
  color: #F4B400 !important;
}
.qb-product-original-price {
  font-size: 11px;
  color: #A89888;
  text-decoration: line-through;
}
[data-theme="dark"] .qb-product .qb-product-original-price {
  color: #6B5D4F !important;
}

/* ── Add to Cart button ── */
.qb-product-btn {
  background: transparent !important;
  border: 1.5px solid #FF0055 !important;
  border-radius: 20px !important;
  padding: 6px 16px !important;
  font-weight: 700 !important;
  font-size: 13px !important;
  color: #FF0055 !important;
  cursor: pointer !important;
  transition: all 0.2s ease !important;
  -webkit-appearance: none !important;
  appearance: none !important;
  letter-spacing: 0.3px !important;
  width: auto !important;
  height: auto !important;
  line-height: 1 !important;
  margin: 0 !important;
}
.qb-product-btn:hover {
  background: rgba(255, 0, 85, 0.1) !important;
}
.qb-product-btn:active {
  transform: scale(0.95) !important;
  background: #FF0055 !important;
  color: #fff !important;
}


.qb-load-more {
  background: var(--qb-gold);
  border: none;
  padding: 14px 36px;
  border-radius: 12px;
  font-weight: 800;
  font-size: 15px;
  color: #2C2412;
  cursor: pointer;
  transition: all 0.2s ease;
  min-width: 200px;
  box-shadow: 0 4px 16px rgba(212,165,69,0.35);
}
[data-theme="dark"] .qb-load-more {
  color: #000 !important;
  box-shadow: 0 4px 16px rgba(244,180,0,0.3) !important;
}
.qb-load-more:hover {
  filter: brightness(1.1);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(212,165,69,0.45);
}
</style>

<div class="qb-collection">
  <div class="qb-collection-header">
    <div class="dhido-collection-hero">
      <div class="dhido-logo-wrap">
        <img src="{{ 'dhidoandthegrills-light.png' | asset_url }}" alt="Dhido and The Grills Logo" class="dhido-logo dhido-logo-light">
        <img src="{{ 'dhidoandthegrills-dark.png' | asset_url }}" alt="Dhido and The Grills Logo" class="dhido-logo dhido-logo-dark">
      </div>
      <div class="dhido-grills-text">THE GRILLS</div>
      <p class="dhido-tagline">The Essence of Nepal</p>
      {%- if collection.description != blank -%}
        <p class="qb-collection-subtitle">{{ collection.description | strip_html | truncate: 160 }}</p>
      {%- endif -%}
      <div class="qb-collection-meta">
        <div class="qb-product-count">📦 {{ collection.products_count | default: 0 }} Products</div>
      </div>
    </div>
  </div>

  <div class="qb-collection-container">
    <aside class="qb-collection-sidebar">
      <!-- Filter Sections could be dynamic here -->
      <div class="qb-filter-section">
        <div class="qb-filter-title">Filters</div>
        <div class="qb-filter-options">
           <p style="color: var(--qb-text2); font-size: 13px;">Use the sort and filter options below to find exactly what you need.</p>
        </div>
      </div>
    </aside>

    <div class="qb-collection-content">
      <div class="qb-collection-controls">
        <div class="qb-sort-wrapper">
          <label for="sort-select">Sort By:</label>
          <select id="sort-select" class="qb-sort-select">
            <option value="popular">Most Popular</option>
            <option value="price-low">Price: Low to High</option>
            <option value="price-high">Price: High to Low</option>
            <option value="newest">Newest</option>
          </select>
        </div>
      </div>

      <div class="qb-collection-grid">
        {% for product in collection.products %}
          {%- assign has_discount = false -%}
          {%- assign discount_pct = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign has_discount = true -%}
            {%- assign savings = product.compare_at_price | minus: product.price -%}
            {%- assign discount_pct = savings | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}
          <a href="{{ product.url }}" class="qb-product">
            <div class="qb-product-img">
              {%- if has_discount -%}
                <div class="qb-off-badge">{{ discount_pct }}% OFF</div>
              {%- endif -%}
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
              {% else %}
                📦
              {% endif %}
            </div>
            <div class="product-info-wrapper">
              <div class="qb-product-delivery">⚡ 18-25 mins</div>
              <div class="qb-product-title">{{ product.title }}</div>

              <div class="price-action-row">
                <div class="qb-price-column">
                  <div class="qb-product-pricing">
                    <span class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</span>
                    {%- if has_discount -%}
                      <span class="qb-product-original-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                    {%- endif -%}
                  </div>
                </div>
                <button class="qb-product-btn" onclick="event.preventDefault(); fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:[{id:{{ product.variants.first.id }},quantity:1}]})}).then(()=>{this.textContent='✓';this.style.background='#22c55e';this.style.borderColor='#22c55e';this.style.color='#fff';setTimeout(()=>{this.textContent='+ Add';this.style.background='';this.style.borderColor='';this.style.color='';},1500)})">+ Add</button>
              </div>
            </div>
          </a>
        {% endfor %}
      </div>

      {% if collection.products_count > 12 %}
      <div style="display: flex; justify-content: center; margin-top: 40px;">
        <button class="qb-load-more">Load More Products</button>
      </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
(function() {
  function applyDhidoTheme() {
    var isDark = document.documentElement.getAttribute('data-theme') === 'dark'
                 || document.body.classList.contains('dark-theme');

    /* --- Product cards --- */
    document.querySelectorAll('.qb-product-price').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#F4B400' : '#2C2412', 'important');
    });
    document.querySelectorAll('.qb-product-title').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#F5EFE7' : '#2C2412', 'important');
    });
    document.querySelectorAll('.qb-product-delivery').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#B89F7E' : '#6B5D4F', 'important');
    });
    document.querySelectorAll('.qb-product-original-price').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#6B5D4F' : '#A89888', 'important');
    });
    document.querySelectorAll('.qb-product').forEach(function(el) {
      el.style.setProperty('background', isDark ? '#2A1F12' : '#FFFFFF', 'important');
      el.style.setProperty('border-color', isDark ? '#3D2F1F' : '#E8DCC8', 'important');
    });
    document.querySelectorAll('.qb-product .product-info-wrapper').forEach(function(el) {
      el.style.setProperty('background', isDark ? '#2A1F12' : '#FFFFFF', 'important');
    });
    document.querySelectorAll('.qb-product-img').forEach(function(el) {
      el.style.setProperty('background', isDark ? '#1E1510' : '#F5EDE0', 'important');
    });

    /* --- Hero section --- */
    var hero = document.querySelector('.dhido-collection-hero');
    if (hero) {
      hero.style.setProperty('background',
        isDark ? 'linear-gradient(135deg, #1A140D 0%, #2D1F12 100%)'
               : 'linear-gradient(135deg, #FEFEF0 0%, #FFFBF0 100%)', 'important');
    }

    /* --- Collection wrapper --- */
    var coll = document.querySelector('.qb-collection');
    if (coll) {
      coll.style.setProperty('background',
        isDark ? 'linear-gradient(135deg, #1A140D 0%, #2D1F12 100%)'
               : 'linear-gradient(135deg, #FEFEF0 0%, #FFFBF0 100%)', 'important');
    }

    /* --- Logo swap (CSS handles via [data-theme] but JS ensures no flash) --- */
    document.querySelectorAll('.dhido-logo-light').forEach(function(el) {
      el.style.setProperty('display', isDark ? 'none' : 'block', 'important');
    });
    document.querySelectorAll('.dhido-logo-dark').forEach(function(el) {
      el.style.setProperty('display', isDark ? 'block' : 'none', 'important');
    });

    /* --- Grills text --- */
    document.querySelectorAll('.dhido-grills-text').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#F4B400' : '#D4A545', 'important');
    });

    /* --- Product count badge --- */
    document.querySelectorAll('.qb-product-count').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#F4B400' : '#D4A545', 'important');
      el.style.setProperty('background', isDark ? 'rgba(244,180,0,0.1)' : 'rgba(212,165,69,0.12)', 'important');
      el.style.setProperty('border-color', isDark ? 'rgba(244,180,0,0.3)' : 'rgba(212,165,69,0.35)', 'important');
    });
  }

  applyDhidoTheme();
  document.addEventListener('DOMContentLoaded', applyDhidoTheme);
  setTimeout(applyDhidoTheme, 100);
  setTimeout(applyDhidoTheme, 500);
  setTimeout(applyDhidoTheme, 1000);

  var observer = new MutationObserver(applyDhidoTheme);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  observer.observe(document.body, { attributes: true, attributeFilter: ['class'] });
})();
</script>

{% schema %}
{
  "name": "QuickBee Collection",
  "settings": [],
  "presets": [
    {
      "name": "QuickBee Collection"
    }
  ]
}
{% endschema %}
