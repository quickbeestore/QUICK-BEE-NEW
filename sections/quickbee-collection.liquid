<!-- QuickBee Collection Page - Professional Dark Theme -->
<style>
:root {
  --qb-gold: #F4B400;
  --qb-black: #0A0A0A;
  --qb-dark2: #111111;
  --qb-dark3: #181818;
  --qb-border: rgba(255,255,255,0.08);
  --qb-text: #F0F0F0;
  --qb-text2: #999999;
  --qb-success: #4ADE80;
  --qb-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

.qb-collection {
  background: var(--qb-black) !important;
  color: var(--qb-text);
  overflow-x: hidden;
}

/* Collection Header */
.qb-collection-header {
  padding: 40px 16px;
  background: linear-gradient(135deg, #1A1A1A 0%, #0A0A0A 100%);
  border-bottom: 1px solid var(--qb-border);
  position: relative;
}

.qb-collection-header::after {
  content: "";
  position: absolute;
  bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--qb-gold), transparent);
  opacity: 0.3;
}

@media(min-width: 1024px) {
  .qb-collection-header {
    padding: 60px 48px;
  }
}

.qb-collection-header h1 {
  font-size: 32px;
  font-weight: 900;
  color: #fff;
  margin: 0 0 12px 0;
  line-height: 1.2;
}

@media(min-width: 1024px) {
  .qb-collection-header h1 {
    font-size: 48px;
  }
}

.qb-collection-header p {
  font-size: 16px;
  color: var(--qb-text2);
  margin: 0;
  line-height: 1.6;
}

.qb-collection-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 24px;
  flex-wrap: wrap;
}

.qb-product-count {
  background: rgba(244, 180, 0, 0.1);
  color: var(--qb-gold);
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 800;
  border: 1px solid rgba(244, 180, 0, 0.3);
}

/* Main Container */
.qb-collection-container {
  display: flex;
  gap: 32px;
  padding: 24px 16px 100px;
}

@media(min-width: 1024px) {
  .qb-collection-container {
    padding: 60px 48px 100px;
  }
}

/* Sidebar */
.qb-collection-sidebar {
  display: none;
  flex-direction: column;
  gap: 24px;
  width: 100px;
  flex-shrink: 0;
}

@media(min-width: 1024px) {
  .qb-collection-sidebar {
    display: flex;
  }
}

.qb-filter-section {
  border: 1px solid var(--qb-border);
  border-radius: 20px;
  padding: 24px;
  background: var(--qb-dark2);
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}

.qb-filter-title {
  font-size: 13px;
  font-weight: 800;
  color: #fff;
  margin: 0 0 20px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}

.qb-filter-options {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.qb-filter-option {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  padding: 6px 0;
  transition: all 0.2s;
}

.qb-filter-option input {
  width: 20px;
  height: 20px;
  cursor: pointer;
  accent-color: var(--qb-gold);
}

.qb-filter-option label {
  font-size: 14px;
  color: var(--qb-text2);
  cursor: pointer;
  flex: 1;
}

.qb-filter-option:hover label {
  color: #fff;
}

.qb-filter-option input:checked + label {
  color: var(--qb-gold);
  font-weight: 700;
}

/* Content Area */
.qb-collection-content {
  flex: 1;
  min-width: 0;
  width: calc(100% - 100px);
}

/* Sort & Controls */
.qb-collection-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32px;
  gap: 16px;
  flex-wrap: wrap;
}

.qb-sort-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
}

.qb-sort-wrapper label {
  font-size: 14px;
  font-weight: 700;
  color: var(--qb-text2);
}

.qb-sort-select {
  padding: 10px 18px;
  background: var(--qb-dark2);
  border: 1.5px solid var(--qb-border);
  border-radius: 12px;
  font-size: 14px;
  color: #fff;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
}

.qb-sort-select:hover {
  border-color: var(--qb-gold);
  background: var(--qb-dark3);
}

/* Product Grid */
.qb-collection-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 20px;
  margin-bottom: 8px;
}

/* ── Product Card ── */
.qb-product {
  background: linear-gradient(175deg, #1e1e1e 0%, #141414 100%);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 18px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.28s cubic-bezier(0.34,1.2,0.64,1), box-shadow 0.28s ease, border-color 0.2s ease;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4px 16px rgba(0,0,0,0.45);
  position: relative;
}

.qb-product:hover {
  border-color: rgba(244,180,0,0.55);
  box-shadow: 0 12px 36px rgba(244,180,0,0.14), 0 4px 16px rgba(0,0,0,0.5);
  transform: translateY(-5px) scale(1.01);
}

/* Image area with warm radial glow */
.qb-product-img {
  width: 100%;
  aspect-ratio: 1;
  position: relative;
  overflow: hidden;
  background: var(--qb-dark2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  margin: 0;
  padding: 0;
}

.qb-product-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  margin: 0;
  padding: 0;
  transition: transform 0.35s ease;
}

.qb-product:hover .qb-product-img img {
  transform: scale(1.06);
}

/* Discount badge — top left */
.qb-off-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: linear-gradient(135deg, #FF3B3B, #CC0000);
  color: #fff;
  font-size: 9px;
  font-weight: 900;
  padding: 4px 9px;
  border-radius: 8px;
  letter-spacing: 0.4px;
  z-index: 10;
  box-shadow: 0 2px 8px rgba(204,0,0,0.45);
  text-transform: uppercase;
}

/* Thin gold shimmer line at top of card */
.qb-product::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent 0%, rgba(244,180,0,0.6) 50%, transparent 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 5;
}

.qb-product:hover::before {
  opacity: 1;
}

/* Info section */
.qb-product-info {
  padding: 13px 13px 14px;
  display: flex;
  flex-direction: column;
  gap: 7px;
  flex: 1;
  background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, transparent 100%);
}

.qb-product-title {
  font-size: 13px;
  font-weight: 700;
  color: #f2f2f2;
  line-height: 1.45;
  min-height: 54px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-word;
  letter-spacing: 0.1px;
}

/* Delivery row */
.qb-product-delivery {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 10px;
  font-weight: 700;
  color: #3DD68C;
  background: rgba(61,214,140,0.1);
  border: 1px solid rgba(61,214,140,0.2);
  padding: 3px 8px;
  border-radius: 20px;
  width: fit-content;
}

/* Price row */
.qb-product-pricing {
  display: flex;
  align-items: baseline;
  gap: 7px;
  margin-top: 2px;
}

.qb-product-price {
  font-size: 20px;
  font-weight: 900;
  color: #F4B400;
  letter-spacing: -0.5px;
  line-height: 1;
}

.qb-product-original-price {
  font-size: 12px;
  color: #444;
  text-decoration: line-through;
}

/* ADD TO CART button */
.qb-product-btn {
  background: linear-gradient(135deg, #F4B400 0%, #E09800 100%) !important;
  border: none;
  padding: 11px 12px;
  border-radius: 12px;
  font-weight: 900;
  font-size: 12px;
  color: #000 !important;
  cursor: pointer;
  transition: all 0.2s ease;
  width: 100%;
  margin-top: 4px;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  box-shadow: 0 4px 14px rgba(244,180,0,0.28);
  -webkit-appearance: none;
  appearance: none;
}

.qb-product-btn:hover {
  background: linear-gradient(135deg, #FFD000 0%, #F4B400 100%) !important;
  box-shadow: 0 6px 20px rgba(244,180,0,0.45);
  transform: translateY(-1px);
}

.qb-product-btn:active {
  transform: scale(0.97);
  box-shadow: none;
}

.qb-load-more {
  background: var(--qb-gold);
  border: none;
  padding: 16px 40px;
  border-radius: 30px;
  font-weight: 800;
  font-size: 16px;
  color: #000;
  cursor: pointer;
  transition: all 0.3s ease;
  min-width: 240px;
  box-shadow: 0 10px 20px rgba(244, 180, 0, 0.3);
}

.qb-load-more:hover {
  background: #FFD700;
  transform: translateY(-3px);
  box-shadow: 0 15px 30px rgba(244, 180, 0, 0.4);
}
</style>

<div class="qb-collection">
  <div class="qb-collection-header">
    <h1>{{ collection.title | default: 'Collection' }}</h1>
    <p>{{ collection.description | strip_html | truncate: 160 | default: 'Explore our premium selection of products delivered fast.' }}</p>
    <div class="qb-collection-meta">
      <div class="qb-product-count">📦 {{ collection.products_count | default: 0 }} Products</div>
    </div>
  </div>

  <div class="qb-collection-container">
    <aside class="qb-collection-sidebar">
      <!-- Filter Sections could be dynamic here -->
      <div class="qb-filter-section">
        <div class="qb-filter-title">Filters</div>
        <div class="qb-filter-options">
           <p style="color: var(--qb-text2); font-size: 13px;">Use the sort and filter options below to find exactly what you need.</p>
        </div>
      </div>
    </aside>

    <div class="qb-collection-content">
      <div class="qb-collection-controls">
        <div class="qb-sort-wrapper">
          <label for="sort-select">Sort By:</label>
          <select id="sort-select" class="qb-sort-select">
            <option value="popular">Most Popular</option>
            <option value="price-low">Price: Low to High</option>
            <option value="price-high">Price: High to Low</option>
            <option value="newest">Newest</option>
          </select>
        </div>
      </div>

      <div class="qb-collection-grid">
        {% for product in collection.products %}
          {%- assign has_discount = false -%}
          {%- assign discount_pct = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign has_discount = true -%}
            {%- assign savings = product.compare_at_price | minus: product.price -%}
            {%- assign discount_pct = savings | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}
          <a href="{{ product.url }}" class="qb-product">
            <div class="qb-product-img">
              {%- if has_discount -%}
                <div class="qb-off-badge">{{ discount_pct }}% OFF</div>
              {%- endif -%}
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
              {% else %}
                📦
              {% endif %}
            </div>
            <div class="qb-product-info">
              <div class="qb-product-title">{{ product.title }}</div>
              <div class="qb-product-delivery">⚡ 18-25 mins</div>
              <div class="qb-product-pricing">
                <span class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</span>
                {%- if has_discount -%}
                  <span class="qb-product-original-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                {%- endif -%}
              </div>
              <button class="qb-product-btn" onclick="event.preventDefault(); fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:[{id:{{ product.variants.first.id }},quantity:1}]})}).then(()=>{this.textContent='✓ Added';this.style.background='linear-gradient(135deg,#22c55e,#16a34a)';setTimeout(()=>{this.textContent='Add to Cart';this.style.background='';},1500)})">Add to Cart</button>
            </div>
          </a>
        {% endfor %}
      </div>

      {% if collection.products_count > 12 %}
      <div style="display: flex; justify-content: center; margin-top: 40px;">
        <button class="qb-load-more">Load More Products</button>
      </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "QuickBee Collection",
  "settings": [],
  "presets": [
    {
      "name": "QuickBee Collection"
    }
  ]
}
{% endschema %}
