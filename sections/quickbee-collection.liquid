<!-- QuickBee Collection Page - Professional Dark Theme -->
<style>
:root {
  --qb-gold: #F4B400;
  --qb-black: #0A0A0A;
  --qb-dark2: #111111;
  --qb-dark3: #181818;
  --qb-border: rgba(255,255,255,0.08);
  --qb-text: #F0F0F0;
  --qb-text2: #999999;
  --qb-success: #4ADE80;
  --qb-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

.qb-collection {
  background: var(--qb-black) !important;
  color: var(--qb-text);
  overflow-x: hidden;
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

/* Collection Header */
.qb-collection-header {
  padding: 40px 16px;
  background: linear-gradient(135deg, #1A1A1A 0%, #0A0A0A 100%);
  border-bottom: 1px solid var(--qb-border);
  position: relative;
}

.qb-collection-header::after {
  content: "";
  position: absolute;
  bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--qb-gold), transparent);
  opacity: 0.3;
}

@media(min-width: 1024px) {
  .qb-collection-header {
    padding: 60px 48px;
  }
}

.qb-collection-header h1 {
  font-size: 32px;
  font-weight: 900;
  color: #fff;
  margin: 0 0 12px 0;
  line-height: 1.2;
}

@media(min-width: 1024px) {
  .qb-collection-header h1 {
    font-size: 48px;
  }
}

.qb-collection-header p {
  font-size: 16px;
  color: var(--qb-text2);
  margin: 0;
  line-height: 1.6;
}

.qb-collection-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 24px;
  flex-wrap: wrap;
}

.qb-product-count {
  background: rgba(244, 180, 0, 0.1);
  color: var(--qb-gold);
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 800;
  border: 1px solid rgba(244, 180, 0, 0.3);
}

/* Main Container */
.qb-collection-container {
  display: flex;
  gap: 32px;
  padding: 24px 16px 100px;
  flex-grow: 1;
}

@media(min-width: 1024px) {
  .qb-collection-container {
    padding: 60px 48px 100px;
  }
}

/* Sidebar */
.qb-collection-sidebar {
  display: none;
  flex-direction: column;
  gap: 24px;
  width: 280px; /* Wider sidebar for filters */
  flex-shrink: 0;
  position: sticky;
  top: 20px; /* Adjust based on header height */
  height: calc(100vh - 40px); /* Full height minus top/bottom margin */
  overflow-y: auto;
  scrollbar-width: none; /* Firefox */
}

.qb-collection-sidebar::-webkit-scrollbar {
  display: none; /* Safari and Chrome */
}


@media(min-width: 1024px) {
  .qb-collection-sidebar {
    display: flex;
  }
}

.qb-filter-section {
  border: 1px solid var(--qb-border);
  border-radius: 20px;
  padding: 24px;
  background: var(--qb-dark2);
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}

.qb-filter-title {
  font-size: 13px;
  font-weight: 800;
  color: #fff;
  margin: 0 0 20px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}

.qb-filter-options {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.qb-filter-option {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  padding: 6px 0;
  transition: all 0.2s;
}

.qb-filter-option input {
  width: 20px;
  height: 20px;
  cursor: pointer;
  accent-color: var(--qb-gold);
}

.qb-filter-option label {
  font-size: 14px;
  color: var(--qb-text2);
  cursor: pointer;
  flex: 1;
}

.qb-filter-option:hover label {
  color: #fff;
}

.qb-filter-option input:checked + label {
  color: var(--qb-gold);
  font-weight: 700;
}

/* Content Area */
.qb-collection-content {
  flex: 1;
  min-width: 0;
  width: calc(100% - 100px);
}

/* Sort & Controls */
.qb-collection-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32px;
  gap: 16px;
  flex-wrap: wrap;
}

.qb-sort-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
}

.qb-sort-wrapper label {
  font-size: 14px;
  font-weight: 700;
  color: var(--qb-text2);
}

.qb-sort-select {
  padding: 10px 18px;
  background: var(--qb-dark2);
  border: 1.5px solid var(--qb-border);
  border-radius: 12px;
  font-size: 14px;
  color: #fff;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
}

.qb-sort-select:hover {
  border-color: var(--qb-gold);
  background: var(--qb-dark3);
}

/* Product Grid */
.qb-collection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 8px;
}
@media (min-width: 640px) {
  .qb-collection-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
}
@media (min-width: 1024px) {
  .qb-collection-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }
}

/* ── Product Card ── */
.qb-product {
  background: #1e1e1e;
  border: 1px solid #333;
  border-radius: 16px;
  overflow: hidden;
  padding: 0;
  cursor: pointer;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.2s ease;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2px 8px rgba(0,0,0,0.4);
  position: relative;
}
html:not([data-theme="dark"]) .qb-product {
  background: #ffffff !important;
  border-color: #ececec !important;
  box-shadow: 0 1px 6px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.04) !important;
}
[data-theme="dark"] .qb-product {
  background: #1e1e1e !important;
  border-color: #333 !important;
}
.qb-product:hover {
  transform: translateY(-3px);
  border-color: #F4B400;
  box-shadow: 0 8px 28px rgba(244,180,0,0.18);
}

/* ── Image section (Full Bleed) ── */
.qb-product-img {
  width: 100%;
  aspect-ratio: 1;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  background: #2a2a2a;
  border-top-left-radius: 16px;
  border-top-right-radius: 16px;
}
html:not([data-theme="dark"]) .qb-product-img {
  background: #f8f8f8 !important;
}
.qb-product-img img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 4px;
  transition: transform 0.3s ease;
}
.qb-product:hover .qb-product-img img {
  transform: scale(1.04);
}

/* ── Info section ── */
.product-info-wrapper {
  padding: 8px 10px 12px 10px;
  display: flex;
  flex-direction: column;
  flex: 1;
  background: inherit;
}
[data-theme="dark"] .qb-product .product-info-wrapper {
  background: #1e1e1e !important;
}
html:not([data-theme="dark"]) .qb-product .product-info-wrapper {
  background: #ffffff !important;
}

/* Delivery badge */
.qb-product-delivery {
  font-size: 11px;
  font-weight: 600;
  color: #999;
  display: flex;
  align-items: center;
  gap: 3px;
  margin-bottom: 4px;
}
html:not([data-theme="dark"]) .qb-product-delivery {
  color: #666 !important;
}
[data-theme="dark"] .qb-collection .qb-product-delivery,
[data-theme="dark"] .qb-product .qb-product-delivery {
  color: #aaa !important;
}

/* Title */
.qb-product-title {
  font-size: 13px;
  font-weight: 600;
  color: #f0f0f0;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 36px;
  margin-bottom: 8px;
}
html:not([data-theme="dark"]) .qb-product-title {
  color: #111111 !important;
}
[data-theme="dark"] .qb-collection .qb-product-title,
[data-theme="dark"] .qb-product .qb-product-title {
  color: #f0f0f0 !important;
}

/* Price & Action Row */
.price-action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  gap: 4px;
}

.qb-price-column {
  display: flex;
  flex-direction: column;
}

/* Price */
.qb-product-pricing {
  display: flex;
  align-items: baseline;
  gap: 4px;
}
.qb-product-price {
  font-size: 15px;
  font-weight: 800;
  color: #F4B400;
  letter-spacing: -0.3px;
  line-height: 1;
}
html:not([data-theme="dark"]) .qb-product-price {
  color: #1a1a1a !important;
}
[data-theme="dark"] .qb-collection .qb-product-price,
[data-theme="dark"] .qb-product .qb-product-price {
  color: #F4B400 !important;
}
.qb-product-original-price {
  font-size: 11px;
  color: #555;
  text-decoration: line-through;
}
html:not([data-theme="dark"]) .qb-product-original-price {
  color: #aaa !important;
}
[data-theme="dark"] .qb-collection .qb-product-original-price,
[data-theme="dark"] .qb-product .qb-product-original-price {
  color: #666 !important;
}

/* ── Add to Cart button ── */
.qb-product-btn {
  background: transparent !important;
  border: 1.5px solid #FF0055 !important;
  border-radius: 20px !important;
  padding: 6px 16px !important;
  font-weight: 700 !important;
  font-size: 13px !important;
  color: #FF0055 !important;
  cursor: pointer !important;
  transition: all 0.2s ease !important;
  -webkit-appearance: none !important;
  appearance: none !important;
  letter-spacing: 0.3px !important;
  width: auto !important;
  height: auto !important;
  line-height: 1 !important;
  margin: 0 !important;
}
.qb-product-btn:hover {
  background: rgba(255, 0, 85, 0.1) !important;
}
.qb-product-btn:active {
  transform: scale(0.95) !important;
  background: #FF0055 !important;
  color: #fff !important;
}


.qb-load-more {
  background: #F4B400;
  border: none;
  padding: 14px 36px;
  border-radius: 12px;
  font-weight: 800;
  font-size: 15px;
  color: #000;
  cursor: pointer;
  transition: all 0.2s ease;
  min-width: 200px;
  box-shadow: 0 4px 16px rgba(244,180,0,0.3);
}
.qb-load-more:hover {
  background: #FFD700;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(244,180,0,0.4);
}
</style>

<div class="qb-collection">
  <div class="qb-collection-header">
    <h1>{{ collection.title | default: 'Collection' }}</h1>
    <p>{{ collection.description | strip_html | truncate: 160 | default: 'Explore our premium selection of products delivered fast.' }}</p>
    <div class="qb-collection-meta">
      <div class="qb-product-count">📦 {{ collection.products_count | default: 0 }} Products</div>
    </div>
  </div>

  <div class="qb-collection-container">
    <aside class="qb-collection-sidebar">
      <!-- Filter Sections could be dynamic here -->
      <div class="qb-filter-section">
        <div class="qb-filter-title">Filters</div>
        <div class="qb-filter-options">
           <p style="color: var(--qb-text2); font-size: 13px;">Use the sort and filter options below to find exactly what you need.</p>
        </div>
      </div>
    </aside>

    <div class="qb-collection-content">
      <div class="qb-collection-controls">
        <div class="qb-sort-wrapper">
          <label for="sort-select">Sort By:</label>
          <select id="sort-select" class="qb-sort-select">
            <option value="popular">Most Popular</option>
            <option value="price-low">Price: Low to High</option>
            <option value="price-high">Price: High to Low</option>
            <option value="newest">Newest</option>
          </select>
        </div>
      </div>

      <div class="qb-collection-grid">
        {% for product in collection.products %}
          {%- assign has_discount = false -%}
          {%- assign discount_pct = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign has_discount = true -%}
            {%- assign savings = product.compare_at_price | minus: product.price -%}
            {%- assign discount_pct = savings | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}
          <a href="{{ product.url }}" class="qb-product">
            <div class="qb-product-img">
              {%- if has_discount -%}
                <div class="qb-off-badge">{{ discount_pct }}% OFF</div>
              {%- endif -%}
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
              {% else %}
                📦
              {% endif %}
            </div>
            <div class="product-info-wrapper">
              <div class="qb-product-delivery">⚡ 18-25 mins</div>
              <div class="qb-product-title">{{ product.title }}</div>

              <div class="price-action-row">
                <div class="qb-price-column">
                  <div class="qb-product-pricing">
                    <span class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</span>
                    {%- if has_discount -%}
                      <span class="qb-product-original-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                    {%- endif -%}
                  </div>
                </div>
                <button class="qb-product-btn" onclick="event.preventDefault(); fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:[{id:{{ product.variants.first.id }},quantity:1}]})}).then(()=>{this.textContent='✓';this.style.background='#22c55e';this.style.borderColor='#22c55e';this.style.color='#fff';setTimeout(()=>{this.textContent='+ Add';this.style.background='';this.style.borderColor='';this.style.color='';},1500)})">+ Add</button>
              </div>
            </div>
          </a>
        {% endfor %}
      </div>

      {% if collection.products_count > 12 %}
      <div style="display: flex; justify-content: center; margin-top: 40px;">
        <button class="qb-load-more">Load More Products</button>
      </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
(function() {
  function applyQBCardTheme() {
    var isDark = document.documentElement.getAttribute('data-theme') === 'dark'
                 || document.body.classList.contains('dark-theme');

    document.querySelectorAll('.qb-product-price').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#F4B400' : '#1a1a1a', 'important');
    });
    document.querySelectorAll('.qb-product-title').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#f0f0f0' : '#111111', 'important');
    });
    document.querySelectorAll('.qb-product-delivery').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#aaa' : '#666666', 'important');
    });
    document.querySelectorAll('.qb-product-original-price').forEach(function(el) {
      el.style.setProperty('color', isDark ? '#666' : '#aaaaaa', 'important');
    });
    document.querySelectorAll('.qb-product').forEach(function(el) {
      el.style.setProperty('background', isDark ? '#1e1e1e' : '#ffffff', 'important');
      el.style.setProperty('border-color', isDark ? '#333' : '#ececec', 'important');
    });
    document.querySelectorAll('.qb-product .product-info-wrapper').forEach(function(el) {
      el.style.setProperty('background', isDark ? '#1e1e1e' : '#ffffff', 'important');
    });
    document.querySelectorAll('.qb-product-img').forEach(function(el) {
      el.style.setProperty('background', isDark ? '#2a2a2a' : '#f8f8f8', 'important');
    });
  }

  // Run immediately and after DOM ready
  applyQBCardTheme();
  document.addEventListener('DOMContentLoaded', applyQBCardTheme);

  // Watch for theme toggle changes
  var observer = new MutationObserver(applyQBCardTheme);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  observer.observe(document.body, { attributes: true, attributeFilter: ['class'] });
})();
</script>

{% schema %}
{
  "name": "QuickBee Collection",
  "settings": [],
  "presets": [
    {
      "name": "QuickBee Collection"
    }
  ]
}
{% endschema %}
