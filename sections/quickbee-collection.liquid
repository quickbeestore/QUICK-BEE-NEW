<!-- QuickBee Collection Page - Professional Dark Theme -->
<style>
:root {
  --qb-gold: #F4B400;
  --qb-black: #0A0A0A;
  --qb-dark2: #111111;
  --qb-dark3: #181818;
  --qb-border: rgba(255,255,255,0.08);
  --qb-text: #F0F0F0;
  --qb-text2: #999999;
  --qb-success: #4ADE80;
  --qb-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

.qb-collection {
  background: var(--qb-black) !important;
  color: var(--qb-text);
  overflow-x: hidden;
  min-height: 100vh;
}

/* Collection Header */
.qb-collection-header {
  padding: 40px 16px;
  background: linear-gradient(135deg, #1A1A1A 0%, #0A0A0A 100%);
  border-bottom: 1px solid var(--qb-border);
  position: relative;
}

.qb-collection-header::after {
  content: "";
  position: absolute;
  bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--qb-gold), transparent);
  opacity: 0.3;
}

@media(min-width: 1024px) {
  .qb-collection-header {
    padding: 60px 48px;
  }
}

.qb-collection-header h1 {
  font-size: 32px;
  font-weight: 900;
  color: #fff;
  margin: 0 0 12px 0;
  line-height: 1.2;
}

@media(min-width: 1024px) {
  .qb-collection-header h1 {
    font-size: 48px;
  }
}

.qb-collection-header p {
  font-size: 16px;
  color: var(--qb-text2);
  margin: 0;
  line-height: 1.6;
}

.qb-collection-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 24px;
  flex-wrap: wrap;
}

.qb-product-count {
  background: rgba(244, 180, 0, 0.1);
  color: var(--qb-gold);
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 800;
  border: 1px solid rgba(244, 180, 0, 0.3);
}

/* Main Container */
.qb-collection-container {
  display: flex;
  gap: 32px;
  padding: 40px 16px;
}

@media(min-width: 1024px) {
  .qb-collection-container {
    padding: 60px 48px;
  }
}

/* Sidebar */
.qb-collection-sidebar {
  display: none;
  flex-direction: column;
  gap: 24px;
  width: 280px;
  flex-shrink: 0;
}

@media(min-width: 1024px) {
  .qb-collection-sidebar {
    display: flex;
  }
}

.qb-filter-section {
  border: 1px solid var(--qb-border);
  border-radius: 20px;
  padding: 24px;
  background: var(--qb-dark2);
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}

.qb-filter-title {
  font-size: 13px;
  font-weight: 800;
  color: #fff;
  margin: 0 0 20px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}

.qb-filter-options {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.qb-filter-option {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  padding: 6px 0;
  transition: all 0.2s;
}

.qb-filter-option input {
  width: 20px;
  height: 20px;
  cursor: pointer;
  accent-color: var(--qb-gold);
}

.qb-filter-option label {
  font-size: 14px;
  color: var(--qb-text2);
  cursor: pointer;
  flex: 1;
}

.qb-filter-option:hover label {
  color: #fff;
}

.qb-filter-option input:checked + label {
  color: var(--qb-gold);
  font-weight: 700;
}

/* Content Area */
.qb-collection-content {
  flex: 1;
  min-width: 0;
}

/* Sort & Controls */
.qb-collection-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32px;
  gap: 16px;
  flex-wrap: wrap;
}

.qb-sort-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
}

.qb-sort-wrapper label {
  font-size: 14px;
  font-weight: 700;
  color: var(--qb-text2);
}

.qb-sort-select {
  padding: 10px 18px;
  background: var(--qb-dark2);
  border: 1.5px solid var(--qb-border);
  border-radius: 12px;
  font-size: 14px;
  color: #fff;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
}

.qb-sort-select:hover {
  border-color: var(--qb-gold);
  background: var(--qb-dark3);
}

/* Product Grid */
.qb-collection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr) !important;
  gap: 16px;
  margin-bottom: 40px;
}

@media(min-width: 768px) {
  .qb-collection-grid {
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 20px;
  }
}

@media(min-width: 1200px) {
  .qb-collection-grid {
    grid-template-columns: repeat(4, 1fr) !important;
    gap: 24px;
  }
}

/* Product Card */
.qb-product {
  background: var(--qb-dark2);
  border: 1.5px solid var(--qb-border);
  border-radius: 20px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4px 15px rgba(0,0,0,0.2);
}

.qb-product:hover {
  border-color: var(--qb-gold);
  box-shadow: var(--qb-shadow);
  transform: translateY(-8px);
}

.qb-product-img {
  width: 100%;
  aspect-ratio: 1;
  background: var(--qb-dark3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  overflow: hidden;
}

.qb-product-info {
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

.qb-product-title {
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
  min-height: 40px;
}

.qb-product-delivery {
  font-size: 11px;
  color: var(--qb-success);
  font-weight: 700;
}

.qb-product-price {
  font-size: 18px;
  font-weight: 900;
  color: var(--qb-gold);
}

.qb-product-original-price {
  font-size: 13px;
  color: #666;
  text-decoration: line-through;
  margin-left: 6px;
}

.qb-product-btn {
  background: #C41E3A !important;
  border: none;
  padding: 12px;
  border-radius: 12px;
  font-weight: 900;
  font-size: 13px;
  color: white;
  cursor: pointer;
  transition: all 0.3s ease;
  width: 100%;
  margin-top: auto;
  text-transform: uppercase;
  letter-spacing: 1px;
  box-shadow: 0 4px 12px rgba(196, 30, 58, 0.3);
}

.qb-product-btn:hover {
  background: #E52E50 !important;
  transform: scale(1.02);
  box-shadow: 0 6px 16px rgba(196, 30, 58, 0.4);
}

.qb-load-more {
  background: var(--qb-gold);
  border: none;
  padding: 16px 40px;
  border-radius: 30px;
  font-weight: 800;
  font-size: 16px;
  color: #000;
  cursor: pointer;
  transition: all 0.3s ease;
  min-width: 240px;
  box-shadow: 0 10px 20px rgba(244, 180, 0, 0.3);
}

.qb-load-more:hover {
  background: #FFD700;
  transform: translateY(-3px);
  box-shadow: 0 15px 30px rgba(244, 180, 0, 0.4);
}
</style>

<div class="qb-collection">
  <div class="qb-collection-header">
    <h1>{{ collection.title | default: 'Collection' }}</h1>
    <p>{{ collection.description | strip_html | truncate: 160 | default: 'Explore our premium selection of products delivered fast.' }}</p>
    <div class="qb-collection-meta">
      <div class="qb-product-count">📦 {{ collection.products_count | default: 0 }} Products</div>
    </div>
  </div>

  <div class="qb-collection-container">
    <aside class="qb-collection-sidebar">
      <!-- Filter Sections could be dynamic here -->
      <div class="qb-filter-section">
        <div class="qb-filter-title">Filters</div>
        <div class="qb-filter-options">
           <p style="color: var(--qb-text2); font-size: 13px;">Use the sort and filter options below to find exactly what you need.</p>
        </div>
      </div>
    </aside>

    <div class="qb-collection-content">
      <div class="qb-collection-controls">
        <div class="qb-sort-wrapper">
          <label for="sort-select">Sort By:</label>
          <select id="sort-select" class="qb-sort-select">
            <option value="popular">Most Popular</option>
            <option value="price-low">Price: Low to High</option>
            <option value="price-high">Price: High to Low</option>
            <option value="newest">Newest</option>
          </select>
        </div>
      </div>

      <div class="qb-collection-grid">
        {% for product in collection.products %}
          <a href="{{ product.url }}" class="qb-product">
            <div class="qb-product-img">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" style="width:100%; height:100%; object-fit:contain; padding:12px;">
              {% else %}
                📦
              {% endif %}
            </div>
            <div class="qb-product-info">
              <div class="qb-product-title">{{ product.title | truncate: 50 }}</div>
              <div class="qb-product-delivery">⚡ 18-25 mins delivery</div>
              <div class="qb-product-pricing">
                <span class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="qb-product-original-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                {% endif %}
              </div>
              <button class="qb-product-btn">Add to Cart</button>
            </div>
          </a>
        {% endfor %}
      </div>

      {% if collection.products_count > 12 %}
      <div style="display: flex; justify-content: center; margin-top: 40px;">
        <button class="qb-load-more">Load More Products</button>
      </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "QuickBee Collection",
  "settings": [],
  "presets": [
    {
      "name": "QuickBee Collection"
    }
  ]
}
{% endschema %}
