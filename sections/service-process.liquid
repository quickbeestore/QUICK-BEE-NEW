<!-- Service Process - How It Works -->
<section class="qb-service-process">
  <style>
    .qb-service-process {
      background: white;
      padding: 60px 20px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .qb-process-header {
      text-align: center;
      margin-bottom: 48px;
    }

    .qb-process-title {
      font-size: 36px;
      font-weight: 900;
      color: #1a1a1a;
      margin-bottom: 12px;
    }

    .qb-process-subtitle {
      font-size: 16px;
      color: #666;
      max-width: 600px;
      margin: 0 auto;
    }

    .qb-steps-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 28px;
      margin-bottom: 40px;
      position: relative;
    }

    /* Connecting line for steps */
    .qb-steps-container::before {
      content: '';
      position: absolute;
      top: 40px;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #F4B400 0%, transparent 50%, transparent 100%);
      z-index: 0;
      display: none;
    }

    @media (min-width: 1024px) {
      .qb-steps-container::before {
        display: block;
      }
    }

    .qb-step-item {
      background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
      border: 2px solid #e8e8e8;
      border-radius: 16px;
      padding: 32px 24px;
      text-align: center;
      position: relative;
      transition: all 0.3s ease;
      cursor: pointer;
      z-index: 1;
    }

    .qb-step-item:hover {
      border-color: #F4B400;
      transform: translateY(-12px);
      box-shadow: 0 16px 40px rgba(244, 180, 0, 0.15);
    }

    .qb-step-number {
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, #F4B400 0%, #FFB300 100%);
      color: #1a1a1a;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      font-weight: 900;
      margin: 0 auto 16px;
      box-shadow: 0 4px 16px rgba(244, 180, 0, 0.3);
    }

    .qb-step-title {
      font-size: 18px;
      font-weight: 800;
      color: #1a1a1a;
      margin-bottom: 12px;
    }

    .qb-step-description {
      font-size: 14px;
      color: #666;
      line-height: 1.6;
    }

    .qb-process-cta {
      text-align: center;
      margin-top: 40px;
    }

    .qb-process-button {
      display: inline-block;
      background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
      color: white;
      padding: 16px 48px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 800;
      font-size: 16px;
      transition: all 0.3s ease;
      border: none;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    }

    .qb-process-button:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
      background: linear-gradient(135deg, #2a2a2a 0%, #3a3a3a 100%);
    }

    @media (max-width: 768px) {
      .qb-service-process {
        padding: 40px 16px;
      }

      .qb-process-title {
        font-size: 28px;
      }

      .qb-steps-container {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .qb-step-item {
        padding: 24px 16px;
      }
    }
  </style>

  <div class="qb-process-header">
    <h2 class="qb-process-title">How It Works</h2>
    <p class="qb-process-subtitle">Simple, transparent, and hassle-free process from start to finish</p>
  </div>

  <div class="qb-steps-container">
    {% for block in section.blocks %}
      {% if block.type == 'step' %}
        <div class="qb-step-item">
          <div class="qb-step-number">{{ forloop.index }}</div>
          <h3 class="qb-step-title">{{ block.settings.title }}</h3>
          <p class="qb-step-description">{{ block.settings.description }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="qb-process-cta">
    <a href="/pages/book-service" class="qb-process-button">Start Now</a>
  </div>
</section>

{% schema %}
{
  "name": "Service Process",
  "settings": [],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Step Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Describe what happens in this step of the process."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Process",
      "settings": {},
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Book Service",
            "description": "Browse services and select the date and time that works for you"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Confirm Details",
            "description": "Provide us with your location and specific requirements"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Get Quote",
            "description": "Receive an upfront quote with no hidden charges"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Service Delivered",
            "description": "Our professionals complete your service with excellence"
          }
        }
      ]
    }
  ]
}
{% endschema %}
