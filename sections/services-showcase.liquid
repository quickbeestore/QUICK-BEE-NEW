<script>
  document.querySelectorAll('.qb-service-button-pro').forEach(btn => {
    btn.addEventListener('click', function() {
      const service = this.closest('.qb-service-card-pro').querySelector('.qb-service-title-pro').textContent;
      alert(`🐝 Booking ${service}...`);
    });
  });

  document.querySelectorAll('.qb-ad-button-pro').forEach(btn => {
    btn.addEventListener('click', function() {
      const banner = this.closest('.qb-ad-banner-pro');
      const title = banner.querySelector('h3').textContent;
      alert(`🍯 ${title} - Starting your booking...`);
    });
  });
</script>

