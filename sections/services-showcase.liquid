  </div>
</section>

<script>
  document.querySelectorAll('.qb-service-button').forEach(btn => {
    btn.addEventListener('click', function() {
      const service = this.closest('.qb-service-card').querySelector('.qb-service-title').textContent;
      alert(`Booking ${service}...`);
    });
  });

  document.querySelectorAll('.qb-ad-button').forEach(btn => {
    btn.addEventListener('click', function() {
      const banner = this.closest('.qb-ad-banner');
      const title = banner.querySelector('h3').textContent;
      alert(`Clicked: ${title}`);
    });
  });
</script>

