        <button class="qb-ad-button">Claim Offer</button>
      </div>

      <div class="qb-ad-banner discount">
        <h3>📦 Bundle Deal</h3>
        <p>Book 2+ services and save 15% on total cost. Limited time!</p>
        <button class="qb-ad-button">See Bundles</button>
      </div>

      <div class="qb-ad-banner urgent">
        <h3>🚨 Emergency Support</h3>
        <p>24/7 emergency services available. Call now for immediate help!</p>
        <button class="qb-ad-button">Get Help</button>
      </div>
