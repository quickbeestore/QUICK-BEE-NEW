    }

    .qb-ad-banner.urgent .qb-ad-button {
      color: #fa709a;
    }

    @media(max-width: 768px) {
      .qb-services-header h2 {
        font-size: 28px;
      }

      .qb-services-grid {
        grid-template-columns: 1fr;
      }

      .qb-services-ads {
