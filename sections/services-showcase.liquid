<!-- Services Showcase - Professional Bee Hive Theme -->
<section class="qb-services-hive-pro">
  <style>
    .qb-services-hive-pro {
      background: #ffffff;
      padding: 80px 20px;
      margin: 0;
      position: relative;
    }

    .qb-services-container-pro {
      max-width: 1600px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    /* Header Section */
    .qb-services-header-pro {
      text-align: center;
      margin-bottom: 70px;
      animation: fadeInDown 0.8s ease;
    }

    .qb-services-header-pro h1 {
      font-size: 56px;
      font-weight: 900;
      color: #000000;
      margin-bottom: 8px;
      letter-spacing: -1px;
    }

    .qb-services-header-pro h1::before {
      content: '🐝 ';
      font-size: 52px;
      display: block;
      margin-bottom: 12px;
    }

    .qb-services-header-pro p {
      font-size: 18px;
      color: #333333;
      max-width: 700px;
      margin: 16px auto 0;
      line-height: 1.8;
      font-weight: 500;
    }

    .qb-services-header-pro::after {
      content: '🍯';
      display: block;
      font-size: 36px;
      margin-top: 24px;
      animation: bobbing 3s ease-in-out infinite;
    }

    /* Honeycomb Grid */
    .qb-services-grid-pro {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 32px;
      margin-bottom: 80px;
    }

    .qb-service-card-pro {
      background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;
      display: flex;
      flex-direction: column;
      height: 100%;
      border: 2px solid #FFC107;
      position: relative;
    }

    .qb-service-card-pro:hover {
      transform: translateY(-12px);
      box-shadow: 0 16px 40px rgba(255, 193, 7, 0.25);
      border-color: #C41E3A;
    }

    .qb-service-icon-pro {
      height: 160px;
      background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 72px;
      color: white;
      position: relative;
      overflow: hidden;
      border-bottom: 4px solid #FFC107;
    }

    .qb-service-icon-pro::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 30% 30%, rgba(255, 193, 7, 0.2), transparent);
      pointer-events: none;
    }

    .qb-service-content-pro {
      padding: 32px 28px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .qb-service-title-pro {
      font-size: 20px;
      font-weight: 800;
      margin-bottom: 12px;
      color: #000000;
      letter-spacing: -0.3px;
    }

    .qb-service-description-pro {
      font-size: 15px;
      color: #555555;
      line-height: 1.7;
      margin-bottom: 20px;
      flex: 1;
      font-weight: 500;
    }

    .qb-service-button-pro {
      background: linear-gradient(135deg, #C41E3A 0%, #A01830 100%);
      color: white;
      border: none;
      padding: 14px 28px;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      align-self: flex-start;
      box-shadow: 0 4px 12px rgba(196, 30, 58, 0.3);
    }

    .qb-service-button-pro:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(196, 30, 58, 0.5);
      background: linear-gradient(135deg, #A01830 0%, #8B1428 100%);
    }

    /* Section Title */
    .qb-services-title-pro {
      font-size: 40px;
      font-weight: 900;
      margin: 80px 0 50px;
      text-align: center;
      color: #000000;
    }

    .qb-services-title-pro::before {
      content: '🍯 ';
      margin-right: 12px;
    }

    /* Promotional Banners */
    .qb-services-ads-pro {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 28px;
      margin: 0 0 40px;
    }

    .qb-ad-banner-pro {
      background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%);
      padding: 48px 40px;
      border-radius: 24px;
      color: white;
      text-align: center;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
      transition: all 0.4s ease;
      position: relative;
      overflow: hidden;
      border: 2px solid #FFC107;
    }

    .qb-ad-banner-pro::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(255, 193, 7, 0.15), transparent);
      animation: rotate 8s linear infinite;
    }

    .qb-ad-banner-pro:hover {
      transform: translateY(-10px);
      box-shadow: 0 20px 60px rgba(196, 30, 58, 0.3);
      border-color: #C41E3A;
    }

    .qb-ad-banner-pro h3 {
      font-size: 28px;
      font-weight: 900;
      margin-bottom: 16px;
      position: relative;
      z-index: 1;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #FFC107;
    }

    .qb-ad-banner-pro p {
      font-size: 16px;
      margin-bottom: 28px;
      position: relative;
      z-index: 1;
      line-height: 1.8;
      font-weight: 500;
      color: #ffffff;
    }

    .qb-ad-banner-pro .qb-ad-button-pro {
      background: linear-gradient(135deg, #FFC107 0%, #FFB300 100%);
      color: #000000;
      border: none;
      padding: 14px 32px;
      border-radius: 10px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 1px;
      position: relative;
      z-index: 1;
    }

    .qb-ad-banner-pro .qb-ad-button-pro:hover {
      transform: scale(1.08);
      box-shadow: 0 8px 20px rgba(255, 193, 7, 0.4);
    }

    @keyframes fadeInDown {
      from {
        opacity: 0;
        transform: translateY(-30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes bobbing {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-12px); }
    }

    @keyframes rotate {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* Responsive */
    @media(max-width: 768px) {
      .qb-services-header-pro h1 {
        font-size: 36px;
      }

      .qb-services-grid-pro {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }

      .qb-service-icon-pro {
        height: 120px;
        font-size: 52px;
      }

      .qb-service-content-pro {
        padding: 20px 16px;
      }

      .qb-ad-banner-pro {
        padding: 32px 24px;
      }
    }

    @media(max-width: 480px) {
      .qb-services-hive-pro {
        padding: 40px 16px;
      }

      .qb-services-header-pro h1 {
        font-size: 28px;
      }

      .qb-services-grid-pro {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .qb-service-icon-pro {
        height: 100px;
        font-size: 40px;
      }
    }
  </style>

