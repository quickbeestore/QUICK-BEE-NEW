<!-- Services Showcase Section - Professional Design -->
<section class="qb-services-showcase">
  <style>
    .qb-services-showcase {
      background: linear-gradient(135deg, #ffffff 0%, #f9f7ff 100%);
      padding: 60px 20px;
      margin: 0;
    }

    .qb-services-container {
      max-width: 1600px;
      margin: 0 auto;
    }

    /* Header Section */
    .qb-services-header {
      text-align: center;
      margin-bottom: 60px;
      animation: fadeIn 0.6s ease;
    }

    .qb-services-header h1 {
      font-size: 48px;
      font-weight: 900;
      background: linear-gradient(135deg, #7a14ac 0%, #5a0d8c 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 16px;
      letter-spacing: -0.5px;
    }

    .qb-services-header p {
      font-size: 20px;
      color: #555;
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.6;
    }

    /* Services Grid */
    .qb-services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 28px;
      margin-bottom: 60px;
    }

    .qb-service-card {
      background: white;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;
      display: flex;
      flex-direction: column;
      height: 100%;
      border: 1px solid rgba(122, 20, 172, 0.1);
    }

    .qb-service-card:hover {
      transform: translateY(-12px);
      box-shadow: 0 16px 40px rgba(122, 20, 172, 0.2);
      border-color: rgba(122, 20, 172, 0.3);
    }

    .qb-service-icon {
      height: 140px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 64px;
      color: white;
      position: relative;
      overflow: hidden;
    }

    .qb-service-icon::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.3), transparent);
      pointer-events: none;
    }

    /* Color gradients for each service */
    .qb-service-card.plumbing .qb-service-icon { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .qb-service-card.electrician .qb-service-icon { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
    .qb-service-card.mechanic .qb-service-icon { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
    .qb-service-card.cleaning .qb-service-icon { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
    .qb-service-card.carpentry .qb-service-icon { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
    .qb-service-card.appliance .qb-service-icon { background: linear-gradient(135deg, #30cfd0 0%, #330867 100%); }
    .qb-service-card.pest .qb-service-icon { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }
    .qb-service-card.hvac .qb-service-icon { background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 100%); }
    .qb-service-card.locksmith .qb-service-icon { background: linear-gradient(135deg, #2e2e78 0%, #662d8c 100%); }
    .qb-service-card.painting .qb-service-icon { background: linear-gradient(135deg, #ffd89b 0%, #19547b 100%); }
    .qb-service-card.landscaping .qb-service-icon { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
    .qb-service-card.roofing .qb-service-icon { background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%); }
    .qb-service-card.flooring .qb-service-icon { background: linear-gradient(135deg, #8b5fbf 0%, #a855f7 100%); }
    .qb-service-card.glass .qb-service-icon { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .qb-service-card.solar .qb-service-icon { background: linear-gradient(135deg, #fbb034 0%, #ffde50 100%); }
    .qb-service-card.water .qb-service-icon { background: linear-gradient(135deg, #0093E9 0%, #80D0C7 100%); }
    .qb-service-card.security .qb-service-icon { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
    .qb-service-card.it .qb-service-icon { background: linear-gradient(135deg, #30cfd0 0%, #330867 100%); }
    .qb-service-card.tutoring .qb-service-icon { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }
    .qb-service-card.beauty .qb-service-icon { background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 100%); }
    .qb-service-card.fitness .qb-service-icon { background: linear-gradient(135deg, #2e2e78 0%, #662d8c 100%); }
    .qb-service-card.cooking .qb-service-icon { background: linear-gradient(135deg, #ffd89b 0%, #19547b 100%); }
    .qb-service-card.laundry .qb-service-icon { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }

    .qb-service-content {
      padding: 28px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .qb-service-title {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 10px;
      color: #1a1a1a;
      letter-spacing: -0.3px;
    }

    .qb-service-description {
      font-size: 14px;
      color: #666;
      line-height: 1.6;
      margin-bottom: 16px;
      flex: 1;
    }

    .qb-service-button {
      background: linear-gradient(135deg, #7a14ac 0%, #5a0d8c 100%);
      color: white;
      border: none;
      padding: 12px 20px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      align-self: flex-start;
    }

    .qb-service-button:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(122, 20, 172, 0.3);
    }

    /* Promotional Banners Section */
    .qb-services-section-title {
      font-size: 28px;
      font-weight: 800;
      margin: 60px 0 40px;
      text-align: center;
      color: #1a1a1a;
    }

    .qb-services-ads {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      margin: 40px 0;
    }

    .qb-ad-banner {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 40px;
      border-radius: 16px;
      color: white;
      text-align: center;
      box-shadow: 0 8px 32px rgba(102, 126, 234, 0.3);
      transition: all 0.4s ease;
      position: relative;
      overflow: hidden;
    }

    .qb-ad-banner::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(255,255,255,0.2), transparent);
      animation: shimmer 3s infinite;
    }

    .qb-ad-banner:hover {
      transform: translateY(-8px);
      box-shadow: 0 16px 48px rgba(102, 126, 234, 0.4);
    }

    .qb-ad-banner h3 {
      font-size: 24px;
      font-weight: 800;
      margin-bottom: 12px;
      position: relative;
      z-index: 1;
    }

    .qb-ad-banner p {
      font-size: 15px;
      margin-bottom: 24px;
      opacity: 0.95;
      position: relative;
      z-index: 1;
      line-height: 1.6;
    }

    .qb-ad-banner .qb-ad-button {
      background: white;
      color: #667eea;
      border: none;
      padding: 12px 28px;
      border-radius: 8px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      position: relative;
      z-index: 1;
    }

    .qb-ad-banner .qb-ad-button:hover {
      transform: scale(1.08);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
    }

    .qb-ad-banner.discount {
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      box-shadow: 0 8px 32px rgba(245, 87, 108, 0.3);
    }

    .qb-ad-banner.discount .qb-ad-button {
      color: #f5576c;
    }

    .qb-ad-banner.urgent {
      background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
      box-shadow: 0 8px 32px rgba(250, 112, 154, 0.3);
    }

    .qb-ad-banner.urgent .qb-ad-button {
      color: #fa709a;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes shimmer {
      0% { transform: translate(0, 0); }
      100% { transform: translate(100%, 100%); }
    }

    /* Responsive Design */
    @media(max-width: 768px) {
      .qb-services-header h1 {
        font-size: 32px;
      }

      .qb-services-header p {
        font-size: 16px;
      }

      .qb-services-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
      }

      .qb-service-icon {
        height: 100px;
        font-size: 48px;
      }

      .qb-service-content {
        padding: 16px;
      }

      .qb-services-ads {
        grid-template-columns: 1fr;
      }

      .qb-ad-banner {
        padding: 30px;
      }
    }

    @media(max-width: 480px) {
      .qb-services-showcase {
        padding: 40px 16px;
      }

      .qb-services-header h1 {
        font-size: 24px;
      }

      .qb-services-header p {
        font-size: 14px;
      }

      .qb-services-grid {
        grid-template-columns: 1fr;
        gap: 12px;
      }

      .qb-service-card {
        border-radius: 12px;
      }

      .qb-service-icon {
        height: 80px;
        font-size: 40px;
      }

      .qb-service-title {
        font-size: 16px;
      }

      .qb-service-description {
        font-size: 13px;
      }

      .qb-ad-banner {
        padding: 24px;
        border-radius: 12px;
      }

      .qb-ad-banner h3 {
        font-size: 20px;
      }

      .qb-ad-banner p {
        font-size: 13px;
      }
    }
  </style>

