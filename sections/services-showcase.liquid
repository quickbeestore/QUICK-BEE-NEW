      <!-- Cleaning & Maintenance -->
      <div class="qb-service-card cleaning"><div class="qb-service-icon">🧹</div><div class="qb-service-content"><h3 class="qb-service-title">Cleaning</h3><p class="qb-service-description">Professional cleaning for homes and offices with eco-friendly products.</p><button class="qb-service-button">Book Now</button></div></div>

      <div class="qb-service-card laundry"><div class="qb-service-icon">👕</div><div class="qb-service-content"><h3 class="qb-service-title">Laundry</h3><p class="qb-service-description">Professional laundry and ironing services with quality care.</p><button class="qb-service-button">Book Now</button></div></div>

      <div class="qb-service-card pest"><div class="qb-service-icon">🦟</div><div class="qb-service-content"><h3 class="qb-service-title">Pest Control</h3><p class="qb-service-description">Safe and effective pest control for homes and commercial spaces.</p><button class="qb-service-button">Book Now</button></div></div>

