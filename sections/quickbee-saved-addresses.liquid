{% comment %}
  QuickBee Saved Addresses Section
  Shows saved delivery addresses and allows selection for checkout
{% endcomment %}

{% schema %}
{
  "name": "QuickBee Saved Addresses",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Your Delivery Addresses"
    }
  ],
  "presets": [
    {
      "name": "QuickBee Saved Addresses"
    }
  ]
}
{% endschema %}

<style>
  .qb-saved-addr-section {
    padding: 24px;
    background: #fff;
    border-radius: 8px;
    margin: 20px 0;
  }
  .qb-saved-addr-title {
    font-size: 18px;
    font-weight: 700;
    color: #222;
    margin-bottom: 16px;
  }
  .qb-saved-addr-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 12px;
  }
  .qb-saved-addr-card {
    border: 2px solid #e8e8e8;
    border-radius: 8px;
    padding: 14px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .qb-saved-addr-card:hover {
    border-color: #f5c518;
    box-shadow: 0 2px 8px rgba(245, 197, 24, 0.15);
  }
  .qb-saved-addr-card.selected {
    border-color: #f5c518;
    background: #fffbe6;
  }
  .qb-addr-label {
    font-size: 14px;
    font-weight: 700;
    color: #222;
    margin-bottom: 6px;
  }
  .qb-addr-text {
    font-size: 12px;
    color: #666;
    line-height: 1.4;
  }
  .qb-addr-btn {
    margin-top: 10px;
    padding: 8px 12px;
    background: #f5c518;
    border: none;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    color: #222;
    cursor: pointer;
    transition: background 0.2s;
    width: 100%;
  }
  .qb-addr-btn:hover { background: #e8b800; }
  .qb-empty-msg {
    text-align: center;
    padding: 24px;
    color: #999;
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .qb-saved-addr-section { padding: 16px; }
    .qb-saved-addr-list {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="qb-saved-addr-section">
  <div class="qb-saved-addr-title">{{ section.settings.section_title }}</div>

  <div id="qbSavedAddrContainer" class="qb-saved-addr-list">
    <div class="qb-empty-msg">No saved addresses yet. Use the location picker to save your first address!</div>
  </div>
</div>

<script>
(function () {
  var container = document.getElementById('qbSavedAddrContainer');
  if (!container) return;

  var savedAddresses = [];

  // Load saved addresses
  function loadAddresses() {
    try {
      var saved = localStorage.getItem('qb_saved_addresses');
      savedAddresses = saved ? JSON.parse(saved) : [];
      renderAddresses();
    } catch (e) {}
  }

  function renderAddresses() {
    if (!savedAddresses || savedAddresses.length === 0) {
      container.innerHTML = '<div class="qb-empty-msg">No saved addresses yet. Use the location picker to save your first address!</div>';
      return;
    }

    container.innerHTML = '';
    var currentLoc = null;
    try {
      var locStr = localStorage.getItem('qb_location_detail');
      currentLoc = locStr ? JSON.parse(locStr) : null;
    } catch (e) {}

    savedAddresses.forEach(function (addr) {
      var card = document.createElement('div');
      card.className = 'qb-saved-addr-card';
      if (currentLoc && currentLoc.address === addr.address) {
        card.classList.add('selected');
      }

      var label = addr.label || 'Saved Address';
      var addressPreview = addr.address.substring(0, 60) + (addr.address.length > 60 ? '…' : '');

      card.innerHTML =
        '<div class="qb-addr-label">' + escapeHtml(label) + '</div>' +
        '<div class="qb-addr-text">' + escapeHtml(addressPreview) + '</div>' +
        '<button type="button" class="qb-addr-btn">Use this address</button>';

      card.querySelector('.qb-addr-btn').addEventListener('click', function (e) {
        e.preventDefault();
        // Set as current location
        try {
          localStorage.setItem('qb_location_detail', JSON.stringify(addr));
          window.QB_LOCATION = addr;

          // Dispatch location change event for weather widget
          window.dispatchEvent(new Event('qb_location_changed'));

          // Update header display
          var headerLabel = document.getElementById('qbLocLabel');
          if (headerLabel) {
            headerLabel.textContent = addr.name;
          }
        } catch (err) {}
        // Highlight this card
        document.querySelectorAll('.qb-saved-addr-card').forEach(function (c) {
          c.classList.remove('selected');
        });
        card.classList.add('selected');
      });

      container.appendChild(card);
    });
  }

  function escapeHtml(text) {
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Load and render on page load
  loadAddresses();

  // Listen for storage changes (from other tabs/location picker)
  window.addEventListener('storage', function (e) {
    if (e.key === 'qb_saved_addresses') {
      loadAddresses();
    }
  });
})();
</script>
