{%- doc -%}
  Flash Deals - Limited-time offers with countdown timer, urgency badges,
  and stock indicators to drive immediate conversion and FOMO.
{%- enddoc -%}

<div
  class="flash-deals-section"
  data-section-id="{{ section.id }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}">
    <!-- Header with Countdown Timer -->
    <div class="flash-deals-header">
      <h2 class="flash-title">⚡ {{ section.settings.title }}</h2>
      <div class="countdown-timer" id="countdown-{{ section.id }}">
        <div class="timer-display">
          <div class="timer-unit">
            <span class="timer-value" id="hours-{{ section.id }}">23</span>
            <span class="timer-label">Hours</span>
          </div>
          <span class="timer-separator">:</span>
          <div class="timer-unit">
            <span class="timer-value" id="minutes-{{ section.id }}">59</span>
            <span class="timer-label">Min</span>
          </div>
          <span class="timer-separator">:</span>
          <div class="timer-unit">
            <span class="timer-value" id="seconds-{{ section.id }}">59</span>
            <span class="timer-label">Sec</span>
          </div>
        </div>
        <p class="timer-text">Offer Expires Soon!</p>
      </div>
    </div>

    <!-- Flash Deals Grid -->
    <div class="flash-deals-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'deal' -%}
          <div class="deal-card">
            <!-- Deal Image -->
            <div class="deal-image-wrapper">
              {%- if block.settings.image -%}
                <img
                  src="{{ block.settings.image | image_url: width: 300 }}"
                  alt="{{ block.settings.product_name }}"
                  class="deal-image"
                  loading="lazy"
                />
              {%- else -%}
                <div class="image-placeholder"></div>
              {%- endif -%}

              <!-- Discount Badge -->
              <div class="discount-badge">
                -{{ block.settings.discount_percentage }}%
              </div>

              <!-- Stock Indicator -->
              <div class="stock-indicator">
                <div class="stock-bar-wrapper">
                  <div class="stock-bar" style="width: {{ block.settings.stock_percentage }}%"></div>
                </div>
                <span class="stock-text">{{ block.settings.units_sold }} Sold</span>
              </div>
            </div>

            <!-- Deal Info -->
            <div class="deal-info">
              <h3 class="deal-product-name">{{ block.settings.product_name }}</h3>

              <!-- Pricing -->
              <div class="deal-pricing">
                <span class="original-price">Rs {{ block.settings.original_price }}</span>
                <span class="deal-price">Rs {{ block.settings.deal_price }}</span>
                <span class="savings-amount">Save Rs {{ block.settings.savings_amount }}</span>
              </div>

              <!-- Category -->
              {%- if block.settings.category != blank -%}
                <span class="deal-category">{{ block.settings.category }}</span>
              {%- endif -%}

              <!-- Stock Status -->
              <div class="stock-status">
                {%- if block.settings.in_stock -%}
                  <span class="status-in-stock">✓ In Stock (Limited)</span>
                {%- else -%}
                  <span class="status-out-of-stock">✗ Out of Stock</span>
                {%- endif -%}
              </div>

              <!-- CTA -->
              <button class="flash-cta-btn" {% unless block.settings.in_stock %}disabled{% endunless %}>
                Grab Deal Now
              </button>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- View All Deals CTA -->
    {%- if section.settings.show_view_all -%}
      <div class="flash-deals-cta">
        <a href="{{ section.settings.deals_page_url }}" class="cta-link">
          View All Flash Deals →
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .flash-deals-section {
    background: var(--color-background);
  }

  .flash-deals-header {
    text-align: center;
    margin-bottom: 40px;
    position: relative;
  }

  .flash-title {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 800;
    color: #ef4444;
    margin: 0 0 20px 0;
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.95;
      transform: scale(1.02);
    }
  }

  .countdown-timer {
    display: inline-block;
    background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
    padding: 20px 32px;
    border-radius: 12px;
    color: white;
  }

  .timer-display {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: center;
    margin-bottom: 8px;
  }

  .timer-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 50px;
  }

  .timer-value {
    font-size: 32px;
    font-weight: 800;
    line-height: 1;
  }

  .timer-label {
    font-size: 11px;
    margin-top: 4px;
    opacity: 0.9;
    font-weight: 600;
  }

  .timer-separator {
    font-size: 20px;
    font-weight: 700;
    margin: 0 4px;
  }

  .timer-text {
    font-size: 13px;
    margin: 0;
    opacity: 0.95;
    font-weight: 600;
  }

  .flash-deals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .deal-card {
    background: white;
    border: 2px solid #ffe5cc;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .deal-card:hover {
    border-color: #ff6b35;
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.2);
    transform: translateY(-4px);
  }

  .deal-image-wrapper {
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
    aspect-ratio: 1;
  }

  .deal-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .deal-card:hover .deal-image {
    transform: scale(1.08);
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f0f0f0 0%, #e5e5e5 100%);
  }

  .discount-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
    color: white;
    padding: 8px 14px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 700;
    box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
  }

  .stock-indicator {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 12px;
    background: rgba(255, 255, 255, 0.98);
    padding: 8px;
    border-radius: 6px;
  }

  .stock-bar-wrapper {
    width: 100%;
    height: 6px;
    background: #e5e5e5;
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .stock-bar {
    height: 100%;
    background: linear-gradient(90deg, #ff6b35 0%, #f7931e 100%);
    transition: width 0.3s ease;
  }

  .stock-text {
    font-size: 11px;
    color: #555;
    font-weight: 600;
  }

  .deal-info {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .deal-product-name {
    font-size: 14px;
    font-weight: 600;
    color: #222;
    margin: 0 0 10px 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .deal-pricing {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 10px;
  }

  .original-price {
    font-size: 13px;
    color: #999;
    text-decoration: line-through;
  }

  .deal-price {
    font-size: 18px;
    font-weight: 700;
    color: #ff6b35;
  }

  .savings-amount {
    font-size: 12px;
    color: #10b981;
    font-weight: 600;
  }

  .deal-category {
    display: inline-block;
    font-size: 11px;
    color: #666;
    background: #f5f5f5;
    padding: 3px 8px;
    border-radius: 3px;
    margin-bottom: 8px;
    width: fit-content;
  }

  .stock-status {
    margin-bottom: 12px;
  }

  .status-in-stock {
    color: #10b981;
    font-size: 12px;
    font-weight: 600;
  }

  .status-out-of-stock {
    color: #ef4444;
    font-size: 12px;
    font-weight: 600;
  }

  .flash-cta-btn {
    width: 100%;
    padding: 10px;
    background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .flash-cta-btn:hover:not(:disabled) {
    box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
    transform: translateY(-2px);
  }

  .flash-cta-btn:disabled {
    background: #ddd;
    cursor: not-allowed;
  }

  .flash-deals-cta {
    text-align: center;
  }

  .cta-link {
    display: inline-block;
    padding: 12px 32px;
    color: #ff6b35;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    border: 2px solid #ff6b35;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .cta-link:hover {
    background: #ff6b35;
    color: white;
  }

  @media screen and (max-width: 749px) {
    .flash-deals-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .deal-info {
      padding: 12px;
    }

    .deal-product-name {
      font-size: 13px;
    }

    .deal-price {
      font-size: 16px;
    }

    .timer-display {
      gap: 4px;
    }

    .timer-value {
      font-size: 24px;
    }

    .timer-unit {
      min-width: 40px;
    }
  }

  @media (prefers-color-scheme: dark) {
    .deal-card {
      background: #222;
      border-color: #3a2817;
    }

    .deal-card:hover {
      border-color: #ff6b35;
    }

    .deal-product-name {
      color: #fff;
    }

    .deal-category {
      background: #1a1a1a;
      color: #aaa;
    }

    .stock-indicator {
      background: rgba(34, 34, 34, 0.98);
    }

    .stock-text {
      color: #aaa;
    }
  }
</style>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const hoursEl = document.getElementById(`hours-${sectionId}`);
    const minutesEl = document.getElementById(`minutes-${sectionId}`);
    const secondsEl = document.getElementById(`seconds-${sectionId}`);
    const flashCtaBtns = document.querySelectorAll('.flash-cta-btn');

    if (!hoursEl || !minutesEl || !secondsEl) return;

    // Countdown timer
    function updateCountdown() {
      let hours = parseInt(hoursEl.textContent) || 23;
      let minutes = parseInt(minutesEl.textContent) || 59;
      let seconds = parseInt(secondsEl.textContent) || 59;

      const tick = setInterval(() => {
        seconds--;

        if (seconds < 0) {
          seconds = 59;
          minutes--;
        }

        if (minutes < 0) {
          minutes = 59;
          hours--;
        }

        if (hours < 0) {
          clearInterval(tick);
          hours = 0;
          minutes = 0;
          seconds = 0;
        }

        hoursEl.textContent = String(hours).padStart(2, '0');
        minutesEl.textContent = String(minutes).padStart(2, '0');
        secondsEl.textContent = String(seconds).padStart(2, '0');
      }, 1000);
    }

    updateCountdown();

    // Add to cart feedback
    flashCtaBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        btn.textContent = '✓ Added!';
        setTimeout(() => {
          btn.textContent = 'Grab Deal Now';
        }, 2000);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Flash Deals",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Flash Deals"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All Deals' CTA",
      "default": true
    },
    {
      "type": "url",
      "id": "deals_page_url",
      "label": "Deals Page URL",
      "default": "/collections/flash-deals"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        { "value": "page-width", "label": "Page Width" },
        { "value": "full-width", "label": "Full Width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "deal",
      "name": "Flash Deal",
      "settings": [
        {
          "type": "text",
          "id": "product_name",
          "label": "Product Name",
          "default": "Premium Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Electronics"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original Price",
          "default": "5,000"
        },
        {
          "type": "text",
          "id": "deal_price",
          "label": "Deal Price",
          "default": "3,500"
        },
        {
          "type": "text",
          "id": "savings_amount",
          "label": "Savings Amount",
          "default": "1,500"
        },
        {
          "type": "text",
          "id": "discount_percentage",
          "label": "Discount %",
          "default": "30"
        },
        {
          "type": "text",
          "id": "units_sold",
          "label": "Units Sold",
          "default": "245"
        },
        {
          "type": "range",
          "id": "stock_percentage",
          "label": "Stock Sold %",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 60
        },
        {
          "type": "checkbox",
          "id": "in_stock",
          "label": "In Stock",
          "default": true
        }
      ]
    }
  ]
}
{% endschema %}
