<section class="flash-deals-section">
  <h2>⚡ {{ section.settings.title }}</h2>
  <p>{{ section.settings.subtitle }}</p>
  <div class="flash-deals-grid">
    {% for block in section.blocks %}
      <div class="flash-deal-card">
        <div class="deal-header">
          <span class="discount-badge">{{ block.settings.discount_percentage }}% OFF</span>
          <span class="timer">⏱️ Limited Time</span>
        </div>
        <h3>{{ block.settings.product_name }}</h3>
        <div class="price-section">
          <span class="original-price">Rs {{ block.settings.original_price }}</span>
          <span class="deal-price">Rs {{ block.settings.deal_price }}</span>
        </div>
        <button class="grab-deal-btn">Grab Deal Now</button>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Flash Deals",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Flash Deals"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Limited time offers - Grab yours now!"
    }
  ],
  "blocks": [
    {
      "name": "Deal",
      "type": "deal",
      "settings": [
        {
          "type": "text",
          "id": "product_name",
          "label": "Product Name"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original Price"
        },
        {
          "type": "text",
          "id": "deal_price",
          "label": "Deal Price"
        },
        {
          "type": "text",
          "id": "discount_percentage",
          "label": "Discount %"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Flash Deals"
    }
  ]
}
{% endschema %}
