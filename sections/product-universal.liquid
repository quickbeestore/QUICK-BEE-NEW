  <!-- STICKY BAR (mobile) -->
  <div class="qbp-sticky">
    <div>
      <div class="qbp-sticky-price" id="qbp-s-price">Rs {{ product.price | divided_by: 100 }}</div>
      <div style="font-size:10px;color:var(--qb-sub);">⚡ Express Delivery</div>
    </div>
    <div class="qbp-qty" style="height:48px;">
      <button type="button" class="qbp-qty-btn" id="qbp-s-minus" style="width:40px;height:48px;font-size:20px;">−</button>
      <span class="qbp-qty-num" id="qbp-s-qty-disp" style="font-size:15px;">1</span>
      <button type="button" class="qbp-qty-btn" id="qbp-s-plus" style="width:40px;height:48px;font-size:20px;">+</button>
    </div>
    <button type="button" class="qbp-atc" id="qbp-s-atc" style="flex:1;height:50px;font-size:13px;border-radius:14px;" {% unless product.available %}disabled{% endunless %}>
      {% if product.available %}
        <span class="qbp-atc-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zM5.1 4H2V2H0v2h2l3.6 7.6L4.2 14c-.2.3-.2.7-.2 1 0 1.1.9 2 2 2h14v-2H6.4c-.1 0-.2-.1-.2-.2l.1-.3 1-1.7H19c.8 0 1.4-.4 1.8-1l3.4-6.2A1 1 0 0023.3 4H5.1z"/></svg></span>
        <span class="qbp-atc-txt">Add to Cart</span>
      {% else %}
        <span class="qbp-atc-txt">Out of Stock</span>
      {% endif %}
    </button>
  </div>

</div><!-- /.qbp -->

<script>
(function() {
  var qty = 1;
  var allVariants = {{ product.variants | json }};

  /* ══ QTY SYNC ══ */
  function setQty(n) {
    qty = Math.max(1, n);
    ['qbp-qty-disp','qbp-s-qty-disp'].forEach(function(id){
      var el = document.getElementById(id); if (el) el.textContent = qty;
    });
    var h = document.getElementById('qbp-qty-h'); if (h) h.value = qty;
  }
  ['qbp-minus','qbp-s-minus'].forEach(function(id){
    var b = document.getElementById(id);
    if (b) b.addEventListener('click', function(e){ e.preventDefault(); setQty(qty - 1); });
  });
  ['qbp-plus','qbp-s-plus'].forEach(function(id){
    var b = document.getElementById(id);
    if (b) b.addEventListener('click', function(e){ e.preventDefault(); setQty(qty + 1); });
  });

  /* sticky ATC submits form */
  var sAtc = document.getElementById('qbp-s-atc');
  var form = document.getElementById('qbp-form');
  if (sAtc && form) {
    sAtc.addEventListener('click', function(){
      var h = document.getElementById('qbp-qty-h'); if (h) h.value = qty;
      form.submit();
    });
  }

  /* main ATC add success flash */
  if (form) {
    form.addEventListener('submit', function(){
      var btn = document.getElementById('qbp-atc');
      if (!btn) return;
      var txt = btn.querySelector('.qbp-atc-txt');
      var ico = btn.querySelector('.qbp-atc-ico');
      btn.classList.add('added');
      if (txt) txt.textContent = '✓ Added!';
      if (ico) ico.style.display = 'none';
      setTimeout(function(){
        btn.classList.remove('added');
        if (txt) txt.textContent = 'Add to Cart';
        if (ico) ico.style.display = '';
      }, 2200);
    });
  }

  /* ══ DELIVERY TIME SYNC ══ */
  function syncDelivery(){
    var range = null;
    try { var s = localStorage.getItem('qb_delivery_time'); if (s){ var d = JSON.parse(s); if (d && d.range) range = d.range; } } catch(e){}
    if (!range && window.QB_DELIVERY_TIME && window.QB_DELIVERY_TIME.range) range = window.QB_DELIVERY_TIME.range;
    if (!range) range = '18–22 mins';
    var el = document.querySelector('.qbp-del-sync'); if (el) el.textContent = range;
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', syncDelivery);
  else syncDelivery();
  window.addEventListener('locationSelected', function(){ setTimeout(syncDelivery, 50); });
  window.addEventListener('qb_location_changed', function(){ setTimeout(syncDelivery, 50); });

  /* ══ VARIANT SYSTEM ══ */
  function getSelectedVals(){
    var vals = {};
    document.querySelectorAll('.qbp-pills').forEach(function(wrap){
      var opt = wrap.getAttribute('data-opt');
      var active = wrap.querySelector('.qbp-pill.active');
      if (active) vals[opt] = active.getAttribute('data-val');
    });
    document.querySelectorAll('[id^="qbp-opt-"]').forEach(function(sel){
      var opt = sel.id.replace('qbp-opt-','');
      vals[opt] = sel.value;
    });
    return vals;
  }

  function matchVariant(){
    var vals = getSelectedVals();
    var keys = Object.keys(vals);
    var matched = allVariants.find(function(v){
      return keys.every(function(k, i){ return v.options[i] === vals[k]; });
    });
    if (!matched) return;
    var vidEl = document.getElementById('qbp-vid');
    if (vidEl) vidEl.value = matched.id;
    /* update price */
    var priceEl = document.getElementById('qbp-price');
    var sPriceEl = document.getElementById('qbp-s-price');
    var price = 'Rs ' + Math.round(matched.price / 100);
    if (priceEl) priceEl.textContent = price;
    if (sPriceEl) sPriceEl.textContent = price;
    var wasEl = document.getElementById('qbp-was');
    if (wasEl) wasEl.style.display = (matched.compare_at_price && matched.compare_at_price > matched.price) ? '' : 'none';
    /* update atc */
    ['qbp-atc','qbp-s-atc'].forEach(function(id){
      var btn = document.getElementById(id); if (!btn) return;
      btn.disabled = !matched.available;
      var txt = btn.querySelector('.qbp-atc-txt');
      var ico = btn.querySelector('.qbp-atc-ico');
      if (txt) txt.textContent = matched.available ? 'Add to Cart' : 'Out of Stock';
      if (ico) ico.style.visibility = matched.available ? 'visible' : 'hidden';
    });
  }

  document.querySelectorAll('.qbp-pill').forEach(function(pill){
    pill.addEventListener('click', function(){
      var wrap = pill.closest('.qbp-pills');
      wrap.querySelectorAll('.qbp-pill').forEach(function(p){ p.classList.remove('active'); });
      pill.classList.add('active');
      /* update label */
      var opt = wrap.getAttribute('data-opt');
      var lbl = document.getElementById('qbp-sel-' + opt);
      if (lbl) lbl.textContent = '— ' + pill.getAttribute('data-val');
      matchVariant();
    });
  });
  document.querySelectorAll('[id^="qbp-opt-"]').forEach(function(sel){
    sel.addEventListener('change', matchVariant);
  });

  /* ══ IMAGE GALLERY SWIPE ══ */
  var gallery = document.getElementById('qbp-gallery');
  var track   = document.getElementById('qbp-track');
  if (gallery && track) {
    var slides = track.querySelectorAll('.qbp-gallery-slide');
    var total  = slides.length;
    var cur    = 0;
    var startX = 0, isDragging = false, startLeft = 0;

    function goSlide(n) {
      cur = (n + total) % total;
      track.style.transform = 'translateX(-' + (cur * 100) + '%)';
      /* dots */
      document.querySelectorAll('.qbp-gdot').forEach(function(d, i){ d.classList.toggle('active', i === cur); });
      /* thumbs */
      document.querySelectorAll('.qbp-thumb').forEach(function(t, i){ t.classList.toggle('active', i === cur); });
    }

    /* touch */
    gallery.addEventListener('touchstart', function(e){ startX = e.touches[0].clientX; isDragging = true; }, { passive: true });
    gallery.addEventListener('touchend', function(e){
      if (!isDragging) return; isDragging = false;
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 45) goSlide(cur + (dx < 0 ? 1 : -1));
    }, { passive: true });

    /* dot clicks */
    document.querySelectorAll('.qbp-gdot').forEach(function(dot){
      dot.addEventListener('click', function(){ goSlide(parseInt(dot.dataset.idx) || 0); });
    });

    /* thumb clicks */
    document.querySelectorAll('.qbp-thumb').forEach(function(thumb){
      thumb.addEventListener('click', function(){ goSlide(parseInt(thumb.dataset.idx) || 0); });
    });

    /* auto-slide (paused after interaction) */
    if (total > 1) {
      var autoSlide = setInterval(function(){ goSlide(cur + 1); }, 4500);
      gallery.addEventListener('touchstart', function(){ clearInterval(autoSlide); }, { passive: true, once: true });
    }
  }

  /* ══ ACCORDIONS ══ */
  [
    ['qbp-desc-btn', 'qbp-desc-body'],
    ['qbp-info-btn', 'qbp-info-body'],
    ['qbp-ship-btn', 'qbp-ship-body'],
  ].forEach(function(pair){
    var btn  = document.getElementById(pair[0]);
    var body = document.getElementById(pair[1]);
    if (btn && body) {
      btn.addEventListener('click', function(){
        var open = body.classList.contains('open');
        body.classList.toggle('open', !open);
        btn.classList.toggle('open', !open);
      });
    }
  });

  /* ══ FAQs ══ */
  document.querySelectorAll('.qbp-faq-q').forEach(function(btn){
    btn.addEventListener('click', function(){
      var body = this.nextElementSibling;
      var isOpen = body.classList.contains('open');
      document.querySelectorAll('.qbp-faq-a').forEach(function(b){ b.classList.remove('open'); });
      document.querySelectorAll('.qbp-faq-q').forEach(function(b){ b.classList.remove('open'); });
      if (!isOpen){ body.classList.add('open'); btn.classList.add('open'); }
    });
  });

  /* ══ SMOKES AUTO-SCROLL ══ */
  var smokesTrack = document.getElementById('qbp-smokes-track');
  if (smokesTrack && smokesTrack.children.length > 0) {
    var orig = Array.from(smokesTrack.children);
    orig.forEach(function(c){ smokesTrack.appendChild(c.cloneNode(true)); });
    var pos = 0, paused = false, halfW = 0;
    function calcHalf(){ halfW = 0; orig.forEach(function(c){ halfW += c.offsetWidth + 10; }); }
    function tick(){
      if (!paused){ pos += 0.45; if (pos >= halfW) pos -= halfW; smokesTrack.style.transform = 'translateX(-' + pos + 'px)'; }
      requestAnimationFrame(tick);
    }
    window.addEventListener('load', function(){ calcHalf(); tick(); });
    smokesTrack.parentElement.addEventListener('mouseenter', function(){ paused = true; });
    smokesTrack.parentElement.addEventListener('mouseleave', function(){ paused = false; });
    smokesTrack.parentElement.addEventListener('touchstart', function(){ paused = true; }, { passive: true });
    smokesTrack.parentElement.addEventListener('touchend', function(){ setTimeout(function(){ paused = false; }, 2000); });
  }

  /* ══ SHARE BUTTON ══ */
  var shareBtn = document.getElementById('qbp-share-btn');
  if (shareBtn) {
    shareBtn.addEventListener('click', function(){
      if (navigator.share) {
        navigator.share({ title: {{ product.title | json }}, text: 'Check this out on QuickBee!', url: window.location.href });
      } else {
        navigator.clipboard && navigator.clipboard.writeText(window.location.href);
        shareBtn.textContent = '✓';
        setTimeout(function(){ shareBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 16c-.8 0-1.5.3-2 .8l-7.3-4.2c.1-.3.1-.5.1-.8s0-.5-.1-.8L15.9 7c.6.5 1.3.8 2.1.8 1.7 0 3-1.3 3-3s-1.3-3-3-3-3 1.3-3 3c0 .3 0 .5.1.8L7.8 9.8C7.2 9.3 6.5 9 5.7 9c-1.7 0-3 1.3-3 3s1.3 3 3 3c.8 0 1.5-.3 2.1-.8l7.3 4.2c-.1.2-.1.4-.1.6 0 1.7 1.3 3 3 3s3-1.3 3-3-1.3-3-3-3z"/></svg>'; }, 2000);
      }
    });
  }

  /* ══ PROMO CODE COPY ══ */
  var promoChip = document.getElementById('qbp-promo');
  if (promoChip) {
    promoChip.addEventListener('click', function(){
      navigator.clipboard && navigator.clipboard.writeText('FREE28');
      var hint = promoChip.querySelector('span:last-child');
      if (hint){ hint.textContent = '✓ Copied!'; setTimeout(function(){ hint.textContent = 'Tap to copy'; }, 2500); }
    });
  }

})();
</script>
{% endif %}

