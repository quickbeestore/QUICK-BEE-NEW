      <div class="qt-header-sub">Sit back, we'll handle the rest</div>
    </div>
    <div class="qt-order-badge" id="qtOrderId">QB–…</div>
  </div>

  <!-- TIMER CARD -->
  <div class="qt-timer-card">
    <div class="qt-timer-pulse"></div>
    <div class="qt-timer-label-top">Delivering in</div>
