      <div class="qt-digit-block">
        <div class="qt-digit" id="qtMins">18</div>
        <div class="qt-digit-lbl">min</div>
      </div>
      <div class="qt-digit-sep">:</div>
      <div class="qt-digit-block">
        <div class="qt-digit" id="qtSecs">00</div>
        <div class="qt-digit-lbl">sec</div>
      </div>
    </div>
