    <button class="qt-cta-btn danger" id="qtCancelBtn" onclick="confirmCancel()">
      <span class="qt-cta-icon">✕</span>
      <span class="qt-cta-label">Cancel Order</span>
    </button>
  </div>

</div><!-- /qt-page -->

<!-- TAP TO PLAY BANNER -->
<div class="qt-tap-banner" id="qtTapBanner" onclick="userInitPlay()">
  🎵 Tap to play music while you wait
</div>

<!-- MUSIC PLAYER -->
<div class="qt-player" id="qtPlayer">
  <div class="qt-player-art" id="qtArt">🎵</div>
  <div class="qt-player-info">
    <div class="qt-player-track" id="qtTrackName">Loading…</div>
    <div class="qt-player-artist" id="qtArtistName">QuickBee Chill Vibes</div>
    <div class="qt-player-bar">
      <div class="qt-player-bar-fill" id="qtBarFill"></div>
    </div>
  </div>
  <div class="qt-player-controls">
    <button class="qt-ctrl-btn" id="qtPrevBtn" onclick="prevTrack()" title="Previous">⏮</button>
    <button class="qt-ctrl-btn play-btn" id="qtPlayBtn" onclick="togglePlay()" title="Play/Pause">▶</button>
    <button class="qt-ctrl-btn" id="qtNextBtn" onclick="nextTrack()" title="Next">⏭</button>
  </div>
</div>

<!-- Hidden audio element -->
<audio id="qtAudio" preload="none"></audio>


<script>
/* ═══════════════════════════════════════════════════
   QB ORDER TRACKING — Main Controller
═══════════════════════════════════════════════════ */
(function() {
  'use strict';

  /* ─────────────────────────────────────────────
     CONFIG — edit these values or pull from URL
  ───────────────────────────────────────────── */
  const CONFIG = {
    etaMinutes: 20,          // default ETA; override via ?eta=18 in URL
    riderPhone: '',          // set rider's phone: '98XXXXXXXX'
    autoAdvanceSteps: true,  // demo: auto-advance steps over time
  };

  /* ─────────────────────────────────────────────
     PLAYLIST — stream-safe / YouTube embed strategy
     Each track has: title, artist, emoji, src
     src = '' means YouTube embed (no direct audio file needed)
     Replace with real audio URLs if you have them
  ───────────────────────────────────────────── */
  const PLAYLIST = [
    {
      title: 'Chill Lo-Fi Beats',
      artist: 'QuickBee Radio',
      emoji: '🎸',
      // ── Option A: direct MP3 URL (royalty-free) ──
      // src: 'https://your-cdn.com/lofi-1.mp3',
      // ── Option B: Free stream from Pixabay / Chosic ──
      src: 'https://cdn.pixabay.com/audio/2022/05/27/audio_1808fbf07a.mp3'
    },
    {
      title: 'Peaceful Acoustic',
      artist: 'Morning Vibes',
      emoji: '🌿',
      src: 'https://cdn.pixabay.com/audio/2022/03/15/audio_8cb749a714.mp3'
    },
    {
      title: 'Happy Upbeat',
      artist: 'Feel Good FM',
      emoji: '🌞',
      src: 'https://cdn.pixabay.com/audio/2021/11/25/audio_5fe84cd20c.mp3'
    },
    {
      title: 'Soft Piano',
      artist: 'Relax & Wait',
      emoji: '🎹',
      src: 'https://cdn.pixabay.com/audio/2022/01/18/audio_d1f5b82538.mp3'
    }
  ];

  /* ─────────────────────────────────────────────
     ORDER STEPS
  ───────────────────────────────────────────── */
  const STEPS = [
    { icon: '✅', label: 'Order Confirmed',   sub: 'Just now',           state: 'done'    },
    { icon: '🏪', label: 'Preparing Order',   sub: 'In progress',        state: 'done'    },
    { icon: '🛵', label: 'Out for Delivery',  sub: 'Rider assigned',     state: 'active'  },
    { icon: '🏠', label: 'Delivered',         sub: 'Arriving soon…',     state: 'pending' }
  ];

  /* ─────────────────────────────────────────────
     LIVE FEED MESSAGES (rotate every ~8s)
  ───────────────────────────────────────────── */
  const FEED = [
    { icon: '⚡', text: 'Rider is on the way to your location' },
    { icon: '🛵', text: 'Your rider is 5 mins away from pickup' },
    { icon: '📦', text: 'Your order has been picked up' },
    { icon: '🗺️', text: 'Rider is navigating to your address' },
    { icon: '🤙', text: 'Rider will call you before arriving' },
    { icon: '⚡', text: 'Almost there — estimated 3 mins away' }
  ];

  /* ─────────────────────────────────────────────
     FUN FACTS
  ───────────────────────────────────────────── */
  const FACTS = [
    'QuickBee delivers to over 50 locations across Kathmandu Valley.',
    'The fastest QuickBee delivery ever was completed in just 7 minutes! ⚡',
    'Our riders cover an average of 80 km every single day.',
    'QuickBee was started to make instant delivery accessible for everyone in Nepal.',
    'Over 10,000 orders have been delivered by QuickBee riders so far! 🐝',
    'Did you know? Our name QuickBee is inspired by how bees are always buzzing and busy.',
    'QuickBee riders go through safety training before their first delivery.',
    'The most ordered item on QuickBee? Cold drinks during summer! 🥤'
  ];

  /* ═══════════════════════════════════════════
     1. INIT
  ═══════════════════════════════════════════ */
  function init() {
    readURLParams();
    renderOrderId();
    renderSteps();
    startTimer();
    startFeedRotation();
    startFactRotation();
    initPlayer();
  }

  /* ─────────────────────────────────────────────
     URL PARAMS — ?eta=18&order=QB-XXXXX&rider=98XXX
  ───────────────────────────────────────────── */
  function readURLParams() {
    const p = new URLSearchParams(window.location.search);
    if (p.get('eta'))    CONFIG.etaMinutes = parseInt(p.get('eta')) || CONFIG.etaMinutes;
    if (p.get('order'))  CONFIG._orderId   = p.get('order');
    if (p.get('rider'))  CONFIG.riderPhone = p.get('rider');
  }

  function renderOrderId() {
    const el = document.getElementById('qtOrderId');
    const id = CONFIG._orderId
      || sessionStorage.getItem('qb_last_order_id')
      || 'QB–ORDER';
    el.textContent = id;
  }

  /* ═══════════════════════════════════════════
     2. COUNTDOWN TIMER
  ═══════════════════════════════════════════ */
  let totalSeconds = CONFIG.etaMinutes * 60;
  let timerInterval;
  const minsEl  = document.getElementById('qtMins');
  const secsEl  = document.getElementById('qtSecs');

  // Also check sessionStorage for ETA set by checkout
  const storedEta = sessionStorage.getItem('qb_eta_seconds');
  if (storedEta) totalSeconds = parseInt(storedEta);

  function startTimer() {
    renderTimer();
    timerInterval = setInterval(() => {
      if (totalSeconds <= 0) {
        clearInterval(timerInterval);
        onDelivered();
        return;
      }
      totalSeconds--;
      renderTimer();
    }, 1000);
  }

  let prevMins = -1, prevSecs = -1;

  function renderTimer() {
    const m = Math.floor(totalSeconds / 60);
    const s = totalSeconds % 60;
    const mStr = String(m).padStart(2, '0');
    const sStr = String(s).padStart(2, '0');

    if (m !== prevMins) {
      minsEl.textContent = mStr;
      minsEl.classList.remove('flip');
      void minsEl.offsetWidth; // reflow
      minsEl.classList.add('flip');
      prevMins = m;
    }
    if (s !== prevSecs) {
      secsEl.textContent = sStr;
      secsEl.classList.remove('flip');
      void secsEl.offsetWidth;
      secsEl.classList.add('flip');
      prevSecs = s;
    }
  }

  function onDelivered() {
    // Advance to delivered state
    const stepEls = document.querySelectorAll('.qt-step');
    stepEls.forEach(el => {
      el.classList.remove('active', 'pending');
      el.classList.add('done');
    });
    setFeed('🏠', 'Your order has been delivered! Enjoy 🎉');
    document.getElementById('qtCancelBtn').style.display = 'none';
    document.getElementById('qtMins').textContent = '00';
    document.getElementById('qtSecs').textContent = '00';
    stopMusic();
  }

  /* ═══════════════════════════════════════════
     3. ORDER STEPS
  ═══════════════════════════════════════════ */
  function renderSteps() {
    const list = document.getElementById('qtStepsList');
    list.innerHTML = STEPS.map((step, i) => `
      <div class="qt-step ${step.state}" id="qtStep${i}">
        <div class="qt-step-icon-wrap">
          <div class="qt-step-icon">${step.state === 'done' ? '✅' : step.icon}</div>
        </div>
        <div class="qt-step-body">
          <div class="qt-step-name">${step.label}</div>
          <div class="qt-step-time">${step.sub}</div>
          ${step.state === 'active' ? '<span class="qt-step-active-tag">⚡ In Progress</span>' : ''}
        </div>
      </div>
    `).join('');

    // Auto-advance for demo (comment out in production)
    if (CONFIG.autoAdvanceSteps) {
      // Advance to "Delivered" when timer hits 0 — handled in onDelivered()
      // You can hook real status updates via polling your backend here
    }
  }

  /* ═══════════════════════════════════════════
     4. LIVE FEED ROTATION
  ═══════════════════════════════════════════ */
  let feedIdx = 0;

  function startFeedRotation() {
    setFeed(FEED[0].icon, FEED[0].text);
    setInterval(() => {
      feedIdx = (feedIdx + 1) % FEED.length;
      setFeed(FEED[feedIdx].icon, FEED[feedIdx].text);
    }, 9000);
  }

  function setFeed(icon, text) {
    const iconEl = document.getElementById('qtFeedIcon');
    const textEl = document.getElementById('qtFeedText');
    // Re-trigger animation
    textEl.style.animation = 'none';
    void textEl.offsetWidth;
    textEl.style.animation = '';
    iconEl.textContent = icon;
    textEl.textContent = text;
  }

  /* ═══════════════════════════════════════════
     5. FUN FACTS ROTATION
  ═══════════════════════════════════════════ */
  let factIdx = Math.floor(Math.random() * FACTS.length);

  function startFactRotation() {
    document.getElementById('qtFactText').textContent = FACTS[factIdx];
    setInterval(() => {
      const el = document.getElementById('qtFactText');
      el.style.opacity = '0';
      setTimeout(() => {
        factIdx = (factIdx + 1) % FACTS.length;
        el.textContent = FACTS[factIdx];
        el.style.opacity = '1';
      }, 300);
    }, 12000);
  }

  /* ═══════════════════════════════════════════
     6. MUSIC PLAYER
  ═══════════════════════════════════════════ */
  const audio    = document.getElementById('qtAudio');
  const playBtn  = document.getElementById('qtPlayBtn');
  const artEl    = document.getElementById('qtArt');
  const barFill  = document.getElementById('qtBarFill');
  let currentTrack = 0;
  let isPlaying    = false;
  let barInterval;

  function initPlayer() {
    loadTrack(currentTrack, false);

    // Attempt autoplay
    audio.play()
      .then(() => {
        isPlaying = true;
        playBtn.textContent = '⏸';
        artEl.classList.add('spinning');
        startBarProgress();
      })
      .catch(() => {
        // Autoplay blocked — show tap banner
        showTapBanner();
      });

    // Audio events
    audio.addEventListener('ended', nextTrack);
    audio.addEventListener('timeupdate', updateBar);
    audio.addEventListener('error', () => {
      // If this track fails to load, skip to next
      setTimeout(nextTrack, 1000);
    });
  }

  function loadTrack(idx, autoplay = true) {
    const t = PLAYLIST[idx];
    document.getElementById('qtTrackName').textContent  = t.title;
    document.getElementById('qtArtistName').textContent = t.artist;
    artEl.textContent = t.emoji;

    audio.src = t.src;
    audio.load();
    barFill.style.width = '0%';

    if (autoplay) {
      audio.play()
        .then(() => {
          isPlaying = true;
          playBtn.textContent = '⏸';
          artEl.classList.add('spinning');
          startBarProgress();
        })
        .catch(() => showTapBanner());
    }
  }

  window.togglePlay = function() {
    if (isPlaying) {
      audio.pause();
      isPlaying = false;
      playBtn.textContent = '▶';
      artEl.classList.remove('spinning');
      clearInterval(barInterval);
    } else {
      audio.play()
        .then(() => {
          isPlaying = true;
          playBtn.textContent = '⏸';
          artEl.classList.add('spinning');
          startBarProgress();
          hideTapBanner();
        })
        .catch(() => showTapBanner());
    }
  };

  window.nextTrack = function() {
    currentTrack = (currentTrack + 1) % PLAYLIST.length;
    loadTrack(currentTrack, isPlaying);
  };

  window.prevTrack = function() {
    currentTrack = (currentTrack - 1 + PLAYLIST.length) % PLAYLIST.length;
    loadTrack(currentTrack, isPlaying);
  };

  window.userInitPlay = function() {
    audio.play()
      .then(() => {
        isPlaying = true;
        playBtn.textContent = '⏸';
        artEl.classList.add('spinning');
        startBarProgress();
        hideTapBanner();
      })
      .catch(() => showTapBanner());
  };

  function updateBar() {
    if (audio.duration && audio.duration > 0) {
      barFill.style.width = ((audio.currentTime / audio.duration) * 100) + '%';
    }
  }

  function startBarProgress() {
    clearInterval(barInterval);
    barInterval = setInterval(updateBar, 500);
  }

  function stopMusic() {
    audio.pause();
    isPlaying = false;
    playBtn.textContent = '▶';
    artEl.classList.remove('spinning');
    clearInterval(barInterval);
  }

  function showTapBanner() {
    document.getElementById('qtTapBanner').classList.add('show');
  }

  function hideTapBanner() {
    document.getElementById('qtTapBanner').classList.remove('show');
    // Also hide after 3s automatically
    setTimeout(() => document.getElementById('qtTapBanner').classList.remove('show'), 3000);
  }

  /* ═══════════════════════════════════════════
     7. CTA ACTIONS
  ═══════════════════════════════════════════ */
  window.callRider = function() {
    if (CONFIG.riderPhone) {
      window.location.href = 'tel:' + CONFIG.riderPhone;
    } else {
      alert('Rider contact will be available once your order is picked up.');
    }
  };

  window.shareOrder = function() {
    const m   = Math.floor(totalSeconds / 60);
    const txt = `My QuickBee order arrives in ~${m} min! Track: ${window.location.href}`;
    if (navigator.share) {
      navigator.share({ title: 'QuickBee Order', text: txt, url: window.location.href })
        .catch(() => {});
    } else {
      navigator.clipboard?.writeText(txt)
        .then(() => alert('Link copied to clipboard!'))
        .catch(() => alert('Share this link: ' + window.location.href));
    }
  };

  window.confirmCancel = function() {
    if (confirm('Are you sure you want to cancel this order? This cannot be undone.')) {
      // Hook your cancel API here
      alert('Cancellation request sent. Our team will contact you shortly.');
      document.getElementById('qtCancelBtn').style.display = 'none';
    }
  };

  /* ── BOOT ── */
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();

})();
</script>
