<!-- QuickBee Blog Article Section — Premium Mobile UI -->

{%- assign current_article = article -%}

<article class="qb-article-page" itemscope itemtype="https://schema.org/BlogPosting">

  <!-- Hero Banner -->
  <div class="qb-article-hero">
    {% if article.image %}
      <div class="qb-article-hero-img">
        <img
          src="{{ article.image | img_url: '1200x800', crop: 'center' }}"
          alt="{{ article.title | escape }}"
          loading="eager"
          itemprop="image"
        >
        <div class="qb-article-hero-overlay"></div>
      </div>
    {% else %}
      <div class="qb-article-hero-img qb-article-hero-no-img">
        <div class="qb-article-hero-emoji">🐝</div>
      </div>
    {% endif %}
    
    <div class="qb-article-hero-content animate-fade-in">
      <div class="qb-article-breadcrumb">
        <a href="/blogs/{{ blog.handle }}">{{ blog.title }}</a>
        <span class="qb-chevron">›</span>
        <span>{{ article.title | truncate: 40 }}</span>
      </div>
      
      {% if article.tags.size > 0 %}
        <span class="qb-hero-tag">{{ article.tags.first }}</span>
      {% endif %}

      <h1 class="qb-article-title" itemprop="headline">{{ article.title }}</h1>
      
      <div class="qb-article-meta">
        <span class="qb-meta-item" itemprop="datePublished" content="{{ article.published_at | date: '%Y-%m-%d' }}">
          📅 {{ article.published_at | date: '%B %d, %Y' }}
        </span>
        <span class="qb-meta-divider">•</span>
        <span class="qb-meta-item" itemprop="author">✍️ {{ article.author }}</span>
        <span class="qb-meta-divider">•</span>
        <span class="qb-meta-item">⏱️ {{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
      </div>
    </div>
  </div>

  <!-- Main Content Body -->
  <div class="qb-article-body-wrapper">
    <div class="qb-article-body animate-fade-in" style="animation-delay: 0.2s">

      <!-- Article HTML Content -->
      <div class="qb-article-content" itemprop="articleBody">
        {{ article.content }}
      </div>

      <!-- Share Bar -->
      <div class="qb-article-share">
        <span class="qb-share-label">Share this guide:</span>
        <div class="qb-share-buttons">
          <a href="https://wa.me/?text={{ article.title | url_encode }}%20{{ shop.url }}{{ article.url | url_encode }}" target="_blank" class="qb-share-btn whatsapp">
            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg> WhatsApp
          </a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url | url_encode }}" target="_blank" class="qb-share-btn facebook">
            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg> Facebook
          </a>
        </div>
      </div>

      <!-- QuickBee CTA Card -->
      <div class="qb-article-cta">
        <div class="qb-cta-icon">🛍️</div>
        <div class="qb-cta-content">
          <h3>Get it delivered in 20 minutes</h3>
          <p>Shop from 20,000+ products — delivered fresh to your doorstep.</p>
        </div>
        <a href="/collections/all" class="qb-cta-btn">Shop Now</a>
      </div>

    </div>
  </div>

  <!-- Related Articles -->
  {% assign related_articles = blog.articles | where: 'id', '!= article.id' %}
  {% if blog.articles_count > 1 %}
    <div class="qb-article-related-section">
      <div class="qb-related-inner">
        <h2 class="qb-related-section-title">More from QuickBee</h2>
        <div class="qb-related-grid">
          {% assign shown = 0 %}
          {% for a in blog.articles %}
            {% unless a.id == article.id %}
              {% if shown < 3 %}
                <a href="{{ a.url }}" class="qb-related-card">
                  <div class="qb-related-img">
                    {% if a.image %}
                      <img src="{{ a.image | img_url: '400x250', crop: 'center' }}" alt="{{ a.title }}" loading="lazy">
                    {% else %}
                      <div class="qb-related-no-img">🐝</div>
                    {% endif %}
                  </div>
                  <div class="qb-related-info">
                    {% if a.tags.size > 0 %}
                      <span class="qb-related-tag">{{ a.tags.first }}</span>
                    {% endif %}
                    <h3 class="qb-related-title">{{ a.title | truncate: 60 }}</h3>
                    <span class="qb-related-date">{{ a.published_at | date: '%b %d, %Y' }}</span>
                  </div>
                </a>
                {% assign shown = shown | plus: 1 %}
              {% endif %}
            {% endunless %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

</article>

<style>
  :root {
    --qb-purple: #7a14ac;
    --qb-purple-hover: #5a0d8c;
    --qb-gold: #F4B400;
    --qb-black: #111111;
    --qb-text: #333333;
    --qb-bg: #f8f9fa;
  }

  .qb-article-page {
    background: var(--qb-bg);
    min-height: 100vh;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  /* ── Hero ── */
  .qb-article-hero {
    position: relative;
    min-height: 380px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--qb-black);
  }

  .qb-article-hero-img {
    position: absolute;
    inset: 0;
  }

  .qb-article-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .qb-article-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,0.2) 100%);
  }

  .qb-article-hero-no-img {
    background: linear-gradient(135deg, var(--qb-purple) 0%, #4a086c 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .qb-article-hero-emoji {
    font-size: 100px;
    opacity: 0.5;
  }

  .qb-article-hero-content {
    position: relative;
    z-index: 2;
    padding: 40px 20px;
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .qb-article-breadcrumb {
    font-size: 12px;
    color: rgba(255,255,255,0.7);
    margin-bottom: 16px;
    display: flex;
    gap: 8px;
    align-items: center;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .qb-article-breadcrumb a {
    color: var(--qb-gold);
    text-decoration: none;
  }

  .qb-hero-tag {
    display: inline-block;
    background: var(--qb-gold);
    color: var(--qb-black);
    font-size: 12px;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 12px;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .qb-article-title {
    font-size: 32px;
    font-weight: 900;
    color: #fff;
    line-height: 1.2;
    margin: 0 0 20px;
    letter-spacing: -0.5px;
  }

  .qb-article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    font-size: 13px;
    color: rgba(255,255,255,0.8);
    font-weight: 500;
  }

  .qb-meta-divider { color: rgba(255,255,255,0.3); }

  /* ── Body ── */
  .qb-article-body-wrapper {
    padding: 0 20px;
    margin-top: -30px;
    position: relative;
    z-index: 10;
  }

  .qb-article-body {
    max-width: 800px;
    margin: 0 auto;
    background: white;
    padding: 32px 24px;
    border-radius: 24px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.05);
  }

  /* ── Content Typography ── */
  .qb-article-content {
    font-size: 16px;
    line-height: 1.8;
    color: var(--qb-text);
  }

  .qb-article-content h2 {
    font-size: 24px;
    font-weight: 800;
    color: var(--qb-black);
    margin: 40px 0 16px;
    line-height: 1.3;
  }

  .qb-article-content h3 {
    font-size: 20px;
    font-weight: 800;
    color: var(--qb-black);
    margin: 32px 0 12px;
  }

  .qb-article-content p {
    margin: 0 0 20px;
  }

  .qb-article-content img {
    max-width: 100%;
    height: auto;
    border-radius: 16px;
    margin: 24px 0;
  }

  .qb-article-content ul,
  .qb-article-content ol {
    margin: 0 0 24px;
    padding-left: 24px;
  }

  .qb-article-content li {
    margin-bottom: 10px;
  }

  .qb-article-content a {
    color: var(--qb-purple);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid rgba(122, 20, 172, 0.3);
    transition: all 0.2s;
  }

  .qb-article-content a:hover {
    border-bottom-color: var(--qb-purple);
  }

  .qb-article-content blockquote {
    border-left: 4px solid var(--qb-purple);
    margin: 32px 0;
    padding: 20px 24px;
    background: #fdf7ff;
    border-radius: 0 16px 16px 0;
    font-style: italic;
    font-size: 18px;
    color: var(--qb-purple);
    font-weight: 600;
  }

  /* ── Share ── */
  .qb-article-share {
    margin: 40px 0;
    padding-top: 30px;
    border-top: 1px solid #eee;
  }

  .qb-share-label {
    display: block;
    font-size: 13px;
    font-weight: 800;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }

  .qb-share-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .qb-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s;
  }

  .qb-share-btn:hover { transform: translateY(-2px); }

  .qb-share-btn.whatsapp {
    background: #25D366;
    color: #fff;
  }

  .qb-share-btn.facebook {
    background: #1877F2;
    color: #fff;
  }

  /* ── CTA ── */
  .qb-article-cta {
    display: flex;
    align-items: center;
    gap: 20px;
    background: linear-gradient(135deg, var(--qb-purple) 0%, #4a086c 100%);
    border-radius: 16px;
    padding: 24px;
    color: white;
    flex-wrap: wrap;
    box-shadow: 0 10px 30px rgba(122, 20, 172, 0.2);
  }

  .qb-cta-icon { font-size: 40px; }

  .qb-cta-content { flex: 1; min-width: 200px; }

  .qb-cta-content h3 {
    font-size: 18px;
    font-weight: 800;
    margin: 0 0 6px;
  }

  .qb-cta-content p {
    font-size: 14px;
    color: rgba(255,255,255,0.8);
    margin: 0;
  }

  .qb-cta-btn {
    background: var(--qb-gold);
    color: var(--qb-black);
    font-weight: 800;
    font-size: 15px;
    padding: 12px 24px;
    border-radius: 12px;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.2s;
  }

  .qb-cta-btn:hover { transform: scale(1.05); }

  /* ── Related Articles ── */
  .qb-article-related-section {
    padding: 60px 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .qb-related-section-title {
    font-size: 24px;
    font-weight: 900;
    color: var(--qb-black);
    margin: 0 0 24px;
    text-align: center;
  }

  .qb-related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .qb-related-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    transition: transform 0.2s;
    border: 1px solid #f0f0f0;
  }

  .qb-related-card:hover { transform: translateY(-4px); }

  .qb-related-img {
    width: 100%;
    height: 180px;
    background: var(--qb-purple-light);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .qb-related-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .qb-related-no-img { font-size: 40px; }

  .qb-related-info { padding: 16px; }

  .qb-related-tag {
    display: inline-block;
    color: var(--qb-purple);
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .qb-related-title {
    font-size: 16px;
    font-weight: 800;
    color: var(--qb-black);
    line-height: 1.4;
    margin: 0 0 8px;
  }

  .qb-related-date {
    font-size: 12px;
    color: #888;
    font-weight: 500;
  }

  /* Animations */
  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (min-width: 768px) {
    .qb-article-title { font-size: 44px; }
    .qb-article-body { padding: 48px; }
    .qb-related-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

{% schema %}
{
  "name": "QuickBee Blog Article",
  "settings": [],
  "presets": [{ "name": "QuickBee Blog Article" }]
}
{% endschema %}