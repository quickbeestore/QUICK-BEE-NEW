<div class="video-banner-wrapper" style="width: 100%; overflow: hidden; margin: 15px 0;">
  <a href="/collections/beer" style="display: block; width: 100%; text-decoration: none;">
    <video 
      autoplay 
      loop 
      muted 
      playsinline 
      style="width: 100%; height: auto; display: block; object-fit: cover;"
    >
      <source src="{{ 'Below last banner.mp4' | asset_url }}" type="video/mp4">
