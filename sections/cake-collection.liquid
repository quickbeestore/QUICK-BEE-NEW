      <div class="bk-sec-head">
        <h2 class="bk-sec-title">✨ More from the Bakery</h2>
        <span class="bk-sec-sub">More delights from our kitchen</span>
        <div class="bk-sec-line"></div>
      </div>
      <div class="bk-grid">
        {%- for p in all_products -%}
          {%- assign pt = p.type | downcase | strip -%}
          {%- unless pt contains 'pound' or pt contains 'bento' or pt contains 'mini' -%}
            {%- assign vid = p.variants.first.id -%}
            {%- assign cp = p.compare_at_price_min -%}
            {%- assign pp = p.price -%}
            {%- assign pct = 0 -%}
            {%- if cp > pp -%}{%- assign diff = cp | minus: pp -%}{%- assign pct = diff | times: 100 | divided_by: cp -%}{%- endif -%}
            <div class="bk-card" data-vid="{{ vid }}" data-sec="others" data-title="{{ p.title | downcase | escape }}">
              <div class="bk-card-img-wrap">
                {%- if p.featured_image -%}
                  <img class="bk-card-img" src="{{ p.featured_image | img_url: '500x500', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
                {%- else -%}
                  <div class="bk-card-no-img">🍰</div>
                {%- endif -%}
                <div class="bk-card-badges">
                  {%- if p.tags contains 'popular' or p.tags contains 'Popular' or p.tags contains 'bestseller' -%}<span class="bk-badge bk-badge--bestseller">⭐ Best Seller</span>{%- endif -%}
                  {%- if p.tags contains 'new' or p.tags contains 'New' -%}<span class="bk-badge bk-badge--new">✨ New</span>{%- endif -%}
                  {%- if pct >= 10 -%}<span class="bk-badge bk-badge--deal">{{ pct }}% OFF</span>{%- endif -%}
                </div>
                <button class="bk-wishlist" aria-label="Save">🤍</button>
              </div>
              <div class="bk-card-body">
                <div class="bk-card-type">{{ p.type | default: 'Bakery' }}</div>
                <h3 class="bk-card-name">{{ p.title }}</h3>
                {%- unless p.description == blank -%}
                <p class="bk-card-desc">{{ p.description | strip_html | truncate: 65 }}</p>
                {%- endunless -%}
                <div class="bk-card-footer">
                  <div class="bk-price-wrap">
                    <span class="bk-price">Rs {{ pp | divided_by: 100 }}</span>
                    {%- if cp > pp -%}<span class="bk-price-compare">Rs {{ cp | divided_by: 100 }}</span>{%- endif -%}
                  </div>
                  <button class="bk-add-btn" data-vid="{{ vid }}">Add +</button>
                  <div class="bk-stepper" data-vid="{{ vid }}">
                    <button class="bk-stepper-btn bk-stepper-minus" data-vid="{{ vid }}">−</button>
                    <span class="bk-stepper-qty" data-vid="{{ vid }}">1</span>
                    <button class="bk-stepper-btn bk-stepper-plus" data-vid="{{ vid }}">+</button>
                  </div>
                </div>
              </div>
            </div>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

    {%- endif -%}
  </div>

  <!-- ── 7. TRUST SECTION ───────────────────────── -->
  <div class="bk-trust">
    <div class="bk-trust-inner">
      <div class="bk-trust-item">
        <div class="bk-trust-icon">🌸</div>
        <h4 class="bk-trust-title">Freshly Baked</h4>
        <p class="bk-trust-desc">Every cake made fresh daily with premium ingredients — no preservatives</p>
      </div>
      <div class="bk-trust-item">
        <div class="bk-trust-icon">⚡</div>
        <h4 class="bk-trust-title">Same-Day Delivery</h4>
        <p class="bk-trust-desc">Order before 2 PM for same-day delivery across Kathmandu Valley</p>
      </div>
      <div class="bk-trust-item">
        <div class="bk-trust-icon">🎨</div>
        <h4 class="bk-trust-title">Custom Orders</h4>
        <p class="bk-trust-desc">Personalized designs, messages & flavours — just for you</p>
      </div>
    </div>
  </div>

  <!-- ── 8. CAKE MESSAGE ────────────────────────── -->
  <div style="padding: 0 16px;">
    <div class="bk-message-section" id="bkMsgSection">
      <div class="bk-message-icon">✍️</div>
      <h3 class="bk-message-title">Write a Message on Your Cake</h3>
      <p class="bk-message-sub">Add a personal touch — we'll pipe it on with love 💕</p>
      <div class="bk-message-input-wrap">
        <input type="text" class="bk-message-input" id="bkCakeMsg" placeholder='e.g. "Happy Birthday Sarah! 🎂"' maxlength="40">
      </div>
      <div class="bk-message-char" id="bkMsgChar">0 / 40 characters</div>
      <button class="bk-message-btn" id="bkSaveMsgBtn">Save Message 🎀</button>
      <div class="bk-message-saved" id="bkMsgSaved">
        <span>✅</span> Message saved! It will be noted with your order.
      </div>
    </div>
  </div>

  <!-- ── 9. UPSELL ─────────────────────────────── -->
  {%- if all_products.size > 0 -%}
  <div class="bk-upsell" id="bkUpsell">
    <div class="bk-upsell-head">
      <h2 class="bk-upsell-title">You May Also <em>Love</em></h2>
    </div>
    <div class="bk-upsell-outer" id="bkUpsellOuter">
      <div class="bk-upsell-track" id="bkUpsellTrack">
        {%- for p in all_products limit: 12 -%}
          {%- assign vid = p.variants.first.id -%}
          <div class="bk-upsell-card" data-vid="{{ vid }}">
            <div class="bk-upsell-img">
              {%- if p.featured_image -%}
                <img src="{{ p.featured_image | img_url: '300x300', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
              {%- else -%}
                <div class="bk-upsell-no-img">🎂</div>
              {%- endif -%}
            </div>
            <div class="bk-upsell-body">
              <div class="bk-upsell-name">{{ p.title }}</div>
              <div class="bk-upsell-price">Rs {{ p.price | divided_by: 100 }}</div>
            </div>
            <button class="bk-upsell-add" data-vid="{{ vid }}">Add to Cart</button>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
  {%- endif -%}

  <!-- Sticky bar removed — universal qb-sticky-cart handles this -->

  <!-- Toast -->
  <div class="bk-toast" id="bkToast">Added to cart ✓</div>

</div>

<!-- Product prices for JS -->
<script type="application/json" id="bkProductData">
[
  {%- for p in all_products -%}
  { "id": {{ p.variants.first.id }}, "price": {{ p.price }} }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
</script>

<script>
(function () {
  'use strict';

  /* ── State ──────────────────────────────────── */
  var bkCart   = {};
  var bkPrices = {};
  var toastTimer = null;

  /* ── Price map ──────────────────────────────── */
  try {
    JSON.parse(document.getElementById('bkProductData').textContent)
      .forEach(function (p) { bkPrices[p.id] = p.price; });
  } catch(e) {}

  /* ── Restore cart ───────────────────────────── */
  fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function (r) { return r.json(); })
    .then(function (cart) {
      cart.items.forEach(function (item) {
        bkCart[item.variant_id] = item.quantity;
        if (!bkPrices[item.variant_id]) bkPrices[item.variant_id] = item.price;
      });
      Object.keys(bkCart).forEach(function (v) { renderVid(parseInt(v, 10)); });
      updateBar();
    }).catch(function () {});

  /* ── Render single variant ──────────────────── */
  function renderVid(vid) {
    var qty = bkCart[vid] || 0;
    document.querySelectorAll('.bk-add-btn[data-vid="' + vid + '"]').forEach(function (btn) {
      if (qty > 0) {
        btn.style.display = 'none';
      } else {
        btn.style.display = '';
        btn.classList.remove('loading', 'success');
        btn.removeAttribute('disabled');
        btn.textContent = 'Add +';
      }
    });
    document.querySelectorAll('.bk-stepper[data-vid="' + vid + '"]').forEach(function (s) {
      if (qty > 0) { s.classList.add('visible'); } else { s.classList.remove('visible'); }
    });
    document.querySelectorAll('.bk-stepper-qty[data-vid="' + vid + '"]').forEach(function (c) {
      c.textContent = qty;
    });
  }

  /* ── AJAX Add ───────────────────────────────── */
  function bkAdd(vid, qty, btn) {
    if (btn) { btn.classList.add('loading'); btn.setAttribute('disabled', true); }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: qty })
    }).then(function (r) { return r.json(); })
    .then(function () {
      bkCart[vid] = (bkCart[vid] || 0) + qty;
      if (btn) {
        btn.classList.remove('loading');
        btn.classList.add('success');
        btn.textContent = '✓';
        setTimeout(function () { renderVid(vid); updateBar(); showToast('Added to cart 🎂'); }, 300);
      } else { renderVid(vid); updateBar(); showToast('Added ✓'); }
    }).catch(function () {
      if (btn) { btn.classList.remove('loading'); btn.removeAttribute('disabled'); btn.textContent = 'Add +'; }
    });
  }

  /* ── AJAX Change qty ────────────────────────── */
  function bkChange(vid, newQty, btn) {
    if (btn) btn.classList.add('busy');
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: newQty })
    }).then(function (r) { return r.json(); })
    .then(function () {
      if (newQty <= 0) { delete bkCart[vid]; } else { bkCart[vid] = newQty; }
      if (btn) btn.classList.remove('busy');
      renderVid(vid);
      updateBar();
    }).catch(function () { if (btn) btn.classList.remove('busy'); });
  }

  /* ── Cart bar ───────────────────────────────── */
  function updateBar() {
    var totalQty = 0, totalPrice = 0;
    Object.keys(bkCart).forEach(function (v) {
      totalQty   += bkCart[v];
      totalPrice += (bkPrices[v] || 0) * bkCart[v];
    });
    var bar = document.getElementById('bkCartBar');
    var cnt = document.getElementById('bkBarCount');
    var tot = document.getElementById('bkBarTotal');
    if (cnt) cnt.textContent = totalQty;
    if (tot) tot.textContent = 'Rs ' + Math.round(totalPrice / 100);
    if (bar) {
      if (totalQty > 0) { bar.classList.add('visible'); } else { bar.classList.remove('visible'); }
    }
  }

  /* ── Toast ──────────────────────────────────── */
  function showToast(msg) {
    var t = document.getElementById('bkToast');
    if (!t) return;
    t.textContent = msg;
    t.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(function () { t.classList.remove('show'); }, 2000);
  }

  /* ── Cart bar click ─────────────────────────── */
  var cartBar = document.getElementById('bkCartBar');
  if (cartBar) { cartBar.addEventListener('click', function () { window.location.href = '/pages/payment'; }); }

  /* ── Event delegation: cards ────────────────── */
  var content = document.getElementById('bkContent');
  if (content) {
    content.addEventListener('click', function (e) {
      var t = e.target;
      if (t.classList.contains('bk-add-btn') && !t.classList.contains('loading') && !t.classList.contains('success')) {
        bkAdd(parseInt(t.getAttribute('data-vid'), 10), 1, t);
      }
      if (t.classList.contains('bk-stepper-minus') && !t.classList.contains('busy')) {
        var v = parseInt(t.getAttribute('data-vid'), 10);
        bkChange(v, Math.max(0, (bkCart[v] || 0) - 1), t);
      }
      if (t.classList.contains('bk-stepper-plus') && !t.classList.contains('busy')) {
        var v2 = parseInt(t.getAttribute('data-vid'), 10);
        bkChange(v2, (bkCart[v2] || 0) + 1, t);
      }
      if (t.classList.contains('bk-wishlist')) {
        t.textContent = t.textContent === '🤍' ? '❤️' : '🤍';
      }
    });
  }

  /* ── Upsell quick add ───────────────────────── */
  var upsell = document.getElementById('bkUpsell');
  if (upsell) {
    upsell.addEventListener('click', function (e) {
      var btn = e.target.closest('.bk-upsell-add');
      if (btn) {
        var vid = parseInt(btn.getAttribute('data-vid'), 10);
        bkAdd(vid, 1, null);
        btn.textContent = '✓ Added';
        btn.style.background = 'var(--bk-green)';
        btn.style.color = '#fff';
      }
    });
    /* Drag scroll upsell */
    var outer = document.getElementById('bkUpsellOuter');
    if (outer) {
      var isDown = false, startX, scrollLeft;
      outer.addEventListener('mousedown', function (e) { isDown = true; startX = e.pageX - outer.offsetLeft; scrollLeft = outer.scrollLeft; });
      outer.addEventListener('mouseleave', function () { isDown = false; });
      outer.addEventListener('mouseup', function () { isDown = false; });
      outer.addEventListener('mousemove', function (e) {
        if (!isDown) return;
        e.preventDefault();
        var x = e.pageX - outer.offsetLeft;
        outer.scrollLeft = scrollLeft - (x - startX);
      });
    }
  }

  /* ── Category pills ─────────────────────────── */
  var pillsWrap = document.getElementById('bkPills');
  if (pillsWrap) {
    pillsWrap.addEventListener('click', function (e) {
      var pill = e.target.closest('.bk-pill');
      if (!pill) return;
      document.querySelectorAll('.bk-pill').forEach(function (p) { p.classList.remove('active'); });
      pill.classList.add('active');
      var target = pill.getAttribute('data-target');
      if (target === 'all') {
        document.querySelectorAll('.bk-sec').forEach(function (s) { s.classList.remove('bk-hidden-sec'); });
      } else {
        document.querySelectorAll('.bk-sec').forEach(function (s) { s.classList.add('bk-hidden-sec'); });
        var sec = document.getElementById('bk-sec-' + target);
        if (sec) {
          sec.classList.remove('bk-hidden-sec');
          setTimeout(function () { sec.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 60);
        }
      }
    });
  }

  /* ── Cake message ───────────────────────────── */
  var msgInput = document.getElementById('bkCakeMsg');
  var msgChar  = document.getElementById('bkMsgChar');
  var msgBtn   = document.getElementById('bkSaveMsgBtn');
  var msgSaved = document.getElementById('bkMsgSaved');

  if (msgInput) {
    msgInput.addEventListener('input', function () {
      var len = msgInput.value.length;
      if (msgChar) msgChar.textContent = len + ' / 40 characters';
      if (msgSaved) msgSaved.classList.remove('show');
    });
  }
  if (msgBtn) {
    msgBtn.addEventListener('click', function () {
      var msg = msgInput ? msgInput.value.trim() : '';
      if (!msg) { if (msgInput) msgInput.focus(); return; }
      fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ note: '🎂 Cake Message: ' + msg })
      }).then(function () {
        if (msgSaved) msgSaved.classList.add('show');
        showToast('Cake message saved! 🎀');
      }).catch(function () {
        if (msgSaved) msgSaved.classList.add('show');
      });
    });
  }

})();
</script>

