<!-- ════════════════════════════════════════════════
     PREMIUM BAKERY COLLECTION PAGE
     ════════════════════════════════════════════════ -->
<div class="bk-wrap" id="bkWrap">

  <!-- ── 1. HERO ────────────────────────────────── -->
  <div class="bk-hero">
    <div class="bk-hero-bg"></div>
    {%- if collection.image -%}
    <div class="bk-hero-bg-img" style="background-image:url('{{ collection.image | img_url: '1600x600', crop: 'center' }}')"></div>
    <div class="bk-hero-overlay"></div>
    {%- endif -%}
    <div class="bk-hero-blob bk-hero-blob--1"></div>
    <div class="bk-hero-blob bk-hero-blob--2"></div>
    <div class="bk-hero-blob bk-hero-blob--3"></div>

    <div class="bk-hero-content">
      <div class="bk-hero-eyebrow">✦ Handcrafted with Love ✦</div>
      <h1 class="bk-hero-title">
        Fresh <em>Cakes</em><br>for Every Occasion
      </h1>
      <p class="bk-hero-sub">
        Artisan baked goods made fresh daily — delivered to your door across Kathmandu Valley
      </p>
      <div class="bk-hero-chips">
        <span class="bk-hero-chip">🎂 Custom Orders</span>
        <span class="bk-hero-chip">⚡ Same-Day Delivery</span>
        <span class="bk-hero-chip">👑 Premium Ingredients</span>
      </div>
    </div>

    <div class="bk-hero-wave">
      <svg viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path class="bk-wave-path" d="M0,48 C240,16 480,0 720,16 C960,32 1200,48 1440,24 L1440,48 Z" fill="#FEFBF6"/>
      </svg>
    </div>
  </div>

  <!-- ── 2. CATEGORY PILLS ──────────────────────── -->
  <div class="bk-pills-outer">
    <div class="bk-pills-inner" id="bkPills">
      <button class="bk-pill active" data-target="all">🎂 All <span class="bk-pill-count">{{ all_products.size }}</span></button>
      {%- if has_pound -%}
      <button class="bk-pill" data-target="pound">⚖️ Per Pound Cakes <span class="bk-pill-count">{{ pound_count }}</span></button>
      {%- endif -%}
      {%- if has_bento -%}
      <button class="bk-pill" data-target="bento">🎁 Mini Bento Cakes <span class="bk-pill-count">{{ bento_count }}</span></button>
      {%- endif -%}
      {%- if has_mini -%}
      <button class="bk-pill" data-target="mini">🍰 Mini Cakes <span class="bk-pill-count">{{ mini_count }}</span></button>
      {%- endif -%}
      {%- if has_others and all_products.size > 0 -%}
      <button class="bk-pill" data-target="others">✨ More <span class="bk-pill-count">{{ other_count }}</span></button>
      {%- endif -%}
    </div>
  </div>

  <!-- ── 3. PRODUCTS ────────────────────────────── -->
  <div class="bk-content" id="bkContent">

    {%- if all_products.size == 0 -%}
    <div class="bk-empty">
      <div class="bk-empty-icon">🎂</div>
      <h3 class="bk-empty-title">Baking something special…</h3>
      <p class="bk-empty-sub">Our collection is being updated. Check back very soon!</p>
    </div>

    {%- else -%}

    {%- comment -%} PER POUND CAKES {%- endcomment -%}
    {%- if has_pound -%}
    <div class="bk-sec" id="bk-sec-pound">
      <div class="bk-sec-head">
        <h2 class="bk-sec-title">⚖️ Per Pound Cakes</h2>
        <span class="bk-sec-sub">Priced by weight — perfect for celebrations</span>
        <div class="bk-sec-line"></div>
      </div>
      <div class="bk-grid">
        {%- for p in all_products -%}
          {%- assign pt = p.type | downcase | strip -%}
          {%- if pt contains 'pound' -%}
            {%- assign vid = p.variants.first.id -%}
            {%- assign cp = p.compare_at_price_min -%}
            {%- assign pp = p.price -%}
            {%- assign pct = 0 -%}
            {%- if cp > pp -%}{%- assign diff = cp | minus: pp -%}{%- assign pct = diff | times: 100 | divided_by: cp -%}{%- endif -%}
            <div class="bk-card" data-vid="{{ vid }}" data-sec="pound" data-title="{{ p.title | downcase | escape }}">
              <div class="bk-card-img-wrap">
                {%- if p.featured_image -%}
                  <img class="bk-card-img" src="{{ p.featured_image | img_url: '500x500', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
                {%- else -%}
                  <div class="bk-card-no-img">🎂</div>
                {%- endif -%}
                <div class="bk-card-badges">
                  {%- if p.tags contains 'popular' or p.tags contains 'Popular' or p.tags contains 'bestseller' -%}<span class="bk-badge bk-badge--bestseller">⭐ Best Seller</span>{%- endif -%}
                  {%- if p.tags contains 'new' or p.tags contains 'New' -%}<span class="bk-badge bk-badge--new">✨ New</span>{%- endif -%}
                  {%- if pct >= 10 -%}<span class="bk-badge bk-badge--deal">{{ pct }}% OFF</span>{%- endif -%}
                  {%- if p.tags contains 'custom' or p.tags contains 'Custom' -%}<span class="bk-badge bk-badge--custom">🎨 Custom</span>{%- endif -%}
                </div>
                <button class="bk-wishlist" aria-label="Save">🤍</button>
              </div>
              <div class="bk-card-body">
                <div class="bk-card-type">Per Pound Cake</div>
                <h3 class="bk-card-name">{{ p.title }}</h3>
                {%- unless p.description == blank -%}
                <p class="bk-card-desc">{{ p.description | strip_html | truncate: 65 }}</p>
                {%- endunless -%}
                <div class="bk-card-footer">
                  <div class="bk-price-wrap">
                    <span class="bk-price">Rs {{ pp | divided_by: 100 }}</span>
                    {%- if cp > pp -%}<span class="bk-price-compare">Rs {{ cp | divided_by: 100 }}</span>{%- endif -%}
                    {%- if pct >= 10 -%}<span class="bk-price-save">Save {{ pct }}%</span>{%- endif -%}
                  </div>
                  <button class="bk-add-btn" data-vid="{{ vid }}">Add +</button>
                  <div class="bk-stepper" data-vid="{{ vid }}">
                    <button class="bk-stepper-btn bk-stepper-minus" data-vid="{{ vid }}">−</button>
                    <span class="bk-stepper-qty" data-vid="{{ vid }}">1</span>
                    <button class="bk-stepper-btn bk-stepper-plus" data-vid="{{ vid }}">+</button>
                  </div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

    {%- comment -%} MINI BENTO CAKES {%- endcomment -%}
    {%- if has_bento -%}
    <div class="bk-sec" id="bk-sec-bento">
      <div class="bk-sec-head">
        <h2 class="bk-sec-title">🎁 Mini Bento Cakes</h2>
        <span class="bk-sec-sub">Adorable single-serving cakes — gift-ready</span>
        <div class="bk-sec-line"></div>
      </div>
      <div class="bk-grid">
        {%- for p in all_products -%}
          {%- assign pt = p.type | downcase | strip -%}
          {%- if pt contains 'bento' -%}
            {%- assign vid = p.variants.first.id -%}
            {%- assign cp = p.compare_at_price_min -%}
            {%- assign pp = p.price -%}
            {%- assign pct = 0 -%}
            {%- if cp > pp -%}{%- assign diff = cp | minus: pp -%}{%- assign pct = diff | times: 100 | divided_by: cp -%}{%- endif -%}
            <div class="bk-card" data-vid="{{ vid }}" data-sec="bento" data-title="{{ p.title | downcase | escape }}">
              <div class="bk-card-img-wrap">
                {%- if p.featured_image -%}
                  <img class="bk-card-img" src="{{ p.featured_image | img_url: '500x500', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
                {%- else -%}
                  <div class="bk-card-no-img">🎁</div>
                {%- endif -%}
                <div class="bk-card-badges">
                  {%- if p.tags contains 'popular' or p.tags contains 'Popular' or p.tags contains 'bestseller' -%}<span class="bk-badge bk-badge--bestseller">⭐ Best Seller</span>{%- endif -%}
                  {%- if p.tags contains 'new' or p.tags contains 'New' -%}<span class="bk-badge bk-badge--new">✨ New</span>{%- endif -%}
                  {%- if pct >= 10 -%}<span class="bk-badge bk-badge--deal">{{ pct }}% OFF</span>{%- endif -%}
                </div>
                <button class="bk-wishlist" aria-label="Save">🤍</button>
              </div>
              <div class="bk-card-body">
                <div class="bk-card-type">Mini Bento Cake</div>
                <h3 class="bk-card-name">{{ p.title }}</h3>
                {%- unless p.description == blank -%}
                <p class="bk-card-desc">{{ p.description | strip_html | truncate: 65 }}</p>
                {%- endunless -%}
                <div class="bk-card-footer">
                  <div class="bk-price-wrap">
                    <span class="bk-price">Rs {{ pp | divided_by: 100 }}</span>
                    {%- if cp > pp -%}<span class="bk-price-compare">Rs {{ cp | divided_by: 100 }}</span>{%- endif -%}
                  </div>
                  <button class="bk-add-btn" data-vid="{{ vid }}">Add +</button>
                  <div class="bk-stepper" data-vid="{{ vid }}">
                    <button class="bk-stepper-btn bk-stepper-minus" data-vid="{{ vid }}">−</button>
                    <span class="bk-stepper-qty" data-vid="{{ vid }}">1</span>
                    <button class="bk-stepper-btn bk-stepper-plus" data-vid="{{ vid }}">+</button>
                  </div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

    {%- comment -%} MINI CAKES {%- endcomment -%}
    {%- if has_mini -%}
    <div class="bk-sec" id="bk-sec-mini">
      <div class="bk-sec-head">
        <h2 class="bk-sec-title">🍰 Mini Cakes</h2>
        <span class="bk-sec-sub">Individually sized, big on flavour</span>
        <div class="bk-sec-line"></div>
      </div>
      <div class="bk-grid">
        {%- for p in all_products -%}
          {%- assign pt = p.type | downcase | strip -%}
          {%- if pt contains 'mini' -%}
            {%- assign vid = p.variants.first.id -%}
            {%- assign cp = p.compare_at_price_min -%}
            {%- assign pp = p.price -%}
            {%- assign pct = 0 -%}
            {%- if cp > pp -%}{%- assign diff = cp | minus: pp -%}{%- assign pct = diff | times: 100 | divided_by: cp -%}{%- endif -%}
            <div class="bk-card" data-vid="{{ vid }}" data-sec="mini" data-title="{{ p.title | downcase | escape }}">
              <div class="bk-card-img-wrap">
                {%- if p.featured_image -%}
                  <img class="bk-card-img" src="{{ p.featured_image | img_url: '500x500', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
                {%- else -%}
                  <div class="bk-card-no-img">🍰</div>
                {%- endif -%}
                <div class="bk-card-badges">
                  {%- if p.tags contains 'popular' or p.tags contains 'Popular' or p.tags contains 'bestseller' -%}<span class="bk-badge bk-badge--bestseller">⭐ Best Seller</span>{%- endif -%}
                  {%- if p.tags contains 'new' or p.tags contains 'New' -%}<span class="bk-badge bk-badge--new">✨ New</span>{%- endif -%}
