<script>
  // Dropdown Logic — Shopify Predictive Search
  (function() {
    var form     = document.querySelector('.qb-search-bar-wrap');
    var input    = document.getElementById('qbSearchInput');
    var dropdown = document.getElementById('qbSearchDropdown');
    var items    = document.getElementById('qbDropdownItems');
    var titleEl  = document.querySelector('.qb-dropdown-title');

    var TRENDS = [
      { label: 'Cold Drinks',     icon: '🥤' },
      { label: 'Instant Noodles', icon: '🍜' },
      { label: 'Chips & Snacks',  icon: '🛒' },
      { label: 'Fresh Fruits',    icon: '🍎' },
      { label: 'Domestic Beer',   icon: '🍺' },
      { label: 'Baby Care',       icon: '🍼' }
    ];

    if (!form || !input || !dropdown || !items) return;

    var debounce = null;
    var lastQuery = '';

    /* ── helpers ─────────────────────────────── */
    function setTitle(t) { if (titleEl) titleEl.textContent = t; }
    function show()  { dropdown.style.display = 'block'; }
    function hide()  { dropdown.style.display = 'none'; }

    function chip(icon, label, query, full) {
      var style = full ? 'grid-column:1/-1;' : '';
      return '<button type="button" class="qb-dropdown-item" data-query="' + query + '" style="' + style + '">'
        + '<span class="qb-dropdown-item-icon">' + icon + '</span>'
        + '<span class="qb-dropdown-item-label">' + label + '</span>'
        + '</button>';
    }

    /* ── render trends (no query) ─────────────── */
    function renderTrends() {
      setTitle('Popular Right Now');
      items.innerHTML = TRENDS.map(function(t) {
        return chip(t.icon, t.label, t.label, false);
      }).join('');
    }

    /* ── render live results ──────────────────── */
    function renderResults(query, products) {
      setTitle('Results for "' + query + '"');
      var html = '';

      products.slice(0, 5).forEach(function(p) {
        var imgHtml = p.featured_image
          ? '<img src="' + p.featured_image + '" style="width:28px;height:28px;object-fit:contain;border-radius:6px;background:#fff;" loading="lazy">'
          : '🛍️';
        var priceHtml = p.price
          ? '<span style="font-size:11px;font-weight:800;color:#F4B400;white-space:nowrap;flex-shrink:0;">Rs&nbsp;' + Math.round(p.price / 100) + '</span>'
          : '';
        html += '<a href="' + p.url + '" class="qb-dropdown-item" style="text-decoration:none;display:flex;align-items:center;gap:10px;">'
          + '<span class="qb-dropdown-item-icon" style="font-size:0;">' + imgHtml + '</span>'
          + '<span class="qb-dropdown-item-label" style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + escHtml(p.title) + '</span>'
          + priceHtml
          + '</a>';
      });

      /* always append "search all" row */
      html += chip('🔍',
        'See all results for <strong>' + escHtml(query) + '</strong> &nbsp;→',
        query, true);
      items.innerHTML = html;
    }

    /* ── render no-results ────────────────────── */
    function renderNoResults(query) {
      setTitle('No matches found');
      items.innerHTML = chip('🔍',
        'Search for <strong>' + escHtml(query) + '</strong> &nbsp;→',
        query, true);
    }

    /* ── render loading ───────────────────────── */
    function renderLoading() {
      setTitle('Searching…');
      items.innerHTML = '<div style="padding:10px 4px;color:var(--qb-text-muted,#888);font-size:13px;">Loading…</div>';
    }

    /* ── escape HTML ──────────────────────────── */
    function escHtml(s) {
      return String(s)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ── fetch Shopify predictive search ─────── */
    async function fetchProducts(query) {
      try {
        var url = '/search/suggest.json?q=' + encodeURIComponent(query)
          + '&resources[type]=product&resources[limit]=5'
          + '&resources[fields]=title,url,price,featured_image';
        var res  = await fetch(url);
        var data = await res.json();
        return (data && data.resources && data.resources.results && data.resources.results.products) || [];
      } catch(e) { return []; }
    }

    /* ── on input ─────────────────────────────── */
    function handleInput() {
      var query = input.value.trim();
      if (!query) { renderTrends(); show(); return; }

      renderLoading();
      show();
      clearTimeout(debounce);
      debounce = setTimeout(async function() {
        if (input.value.trim() !== query) return;
        lastQuery = query;
        var products = await fetchProducts(query);
        if (input.value.trim() !== query) return;
        if (products.length > 0) {
          renderResults(query, products);
        } else {
          renderNoResults(query);
        }
      }, 280);
    }

    /* ── events ───────────────────────────────── */
    input.addEventListener('focus', function() {
      if (input.value.trim()) { handleInput(); } else { renderTrends(); show(); }
    });
    input.addEventListener('input', handleInput);
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { hide(); input.blur(); }
    });

    items.addEventListener('click', function(e) {
      var item = e.target.closest('[data-query]');
      if (!item) return;
      e.preventDefault();
      input.value = item.getAttribute('data-query') || '';
      hide();
      form.submit();
    });

    document.addEventListener('click', function(e) {
      if (!form.contains(e.target) && !dropdown.contains(e.target)) hide();
    });
  })();
</script>
