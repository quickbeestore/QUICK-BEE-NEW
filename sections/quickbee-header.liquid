  .qb-loc-use-current button {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 12px 16px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    color: var(--qb-yellow);
    font-family: 'Segoe UI', Arial, sans-serif;
