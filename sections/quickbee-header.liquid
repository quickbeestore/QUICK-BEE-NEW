// Live weather updates with OpenWeather API

window.qbWeather = {
  // IMPORTANT: Add your OpenWeather API key here
  // Get free key from: https://openweathermap.org/api
  apiKey: '',  // Leave empty for graceful fallback
  cacheKey: 'qb_weather_cache',
  cacheExpiry: 600000, // 10 minutes

  init: function() {
    // Don't initialize if no API key (graceful fallback)
    if (!this.apiKey || this.apiKey.trim() === '') {
      console.log('⚠️ Weather: No API key configured. Using fallback.');
      return;
    }

    try {
      console.log('🌤️ Initializing Weather Widget...');
      this.loadWeather();

      // Refresh every 10 minutes
      setInterval(() => this.loadWeather(), 600000);

      // Listen for location changes to update weather immediately
      window.addEventListener('qb_location_changed', () => {
        console.log('📍 Location changed, updating weather...');
        this.loadWeather();
      });

      console.log('✅ Weather Widget Ready');
    } catch(e) {
      console.log('⚠️ Weather initialization error:', e);
    }
  },

  getCoords: function() {
    // Get location from QB_LOCATION object or default to Kathmandu
    const loc = window.QB_LOCATION;
    return {
      lat: loc?.lat || 27.7172,
      lon: loc?.lon || 85.3240
    };
  },

  loadWeather: function() {
    if (!this.apiKey) return;

    try {
      const coords = this.getCoords();
      const cacheData = JSON.parse(localStorage.getItem(this.cacheKey) || '{}');
      const now = Date.now();

      // Use cache if fresh (less than 10 minutes old)
      if (cacheData.timestamp && (now - cacheData.timestamp) < this.cacheExpiry) {
        console.log('💾 Using cached weather data');
        this.updateUI(cacheData.data);
        return;
      }

      // Fetch fresh weather from API
      const url = `https://api.openweathermap.org/data/2.5/weather?lat=${coords.lat}&lon=${coords.lon}&appid=${this.apiKey}&units=metric`;

      fetch(url)
        .then(res => {
          if (!res.ok) throw new Error(`API returned ${res.status}`);
          return res.json();
        })
        .then(data => {
          // Cache the response
          localStorage.setItem(this.cacheKey, JSON.stringify({
            data: data,
            timestamp: now
          }));

          console.log('🌤️ Weather fetched:', data.main.temp + '°C, ' + data.weather[0].main);
          this.updateUI(data);
        })
        .catch(err => {
          console.log('⚠️ Weather API error:', err);
          this.showFallback();
        });
    } catch(e) {
      console.log('⚠️ Weather load error:', e);
      this.showFallback();
    }
  },

  updateUI: function(data) {
    try {
      const tempEl = document.getElementById('qbWeatherTemp');
      const iconEl = document.getElementById('qbWeatherIcon');
      const condEl = document.querySelector('.qb-weather-condition');

      if (tempEl) {
        tempEl.innerHTML = `<span class="qb-temp-value">${Math.round(data.main.temp)}°C</span><span class="qb-temp-icon" id="qbWeatherIcon">${this.getWeatherIcon(data.weather[0].icon)}</span>`;
      }

      if (condEl) {
        condEl.textContent = data.weather[0].main;
      }
    } catch(e) {
      console.log('⚠️ UI update error:', e);
      this.showFallback();
    }
  },

  showFallback: function() {
    try {
      const tempEl = document.getElementById('qbWeatherTemp');
      const condEl = document.querySelector('.qb-weather-condition');

      if (tempEl) {
        tempEl.innerHTML = '<span class="qb-temp-value">--°C</span><span class="qb-temp-icon">🌤️</span>';
      }

      if (condEl) {
        condEl.textContent = 'Unavailable';
      }
    } catch(e) {
      // Fail silently
    }
  },

  getWeatherIcon: function(code) {
    // Map OpenWeather condition codes to emoji
    const iconMap = {
      '01d': '☀️', '01n': '🌙',
      '02d': '🌤️', '02n': '🌤️',
      '03d': '☁️', '03n': '☁️',
      '04d': '☁️', '04n': '☁️',
      '09d': '🌧️', '09n': '🌧️',
      '10d': '🌧️', '10n': '🌧️',
      '11d': '⛈️', '11n': '⛈️',
      '13d': '❄️', '13n': '❄️',
      '50d': '🌫️', '50n': '🌫️'
    };
    return iconMap[code] || '🌤️';
  }
};

