// Drum roll sound - plays continuously during spin
window.QB_DRUM_ROLL_STATE = { audioContext: null, isPlaying: false, oscillators: [] };

window.qbPlayDrumRoll = function() {
  try {
    if (!window.QB_DRUM_ROLL_STATE.audioContext) {
      window.QB_DRUM_ROLL_STATE.audioContext = new (window.AudioContext || window.webkitAudioContext)();
    }
    const ctx = window.QB_DRUM_ROLL_STATE.audioContext;

    if (window.QB_DRUM_ROLL_STATE.isPlaying) return;
    window.QB_DRUM_ROLL_STATE.isPlaying = true;

    // Drum roll: rapid tapping sound with varying pitch
    const playDrumBeat = () => {
      if (!window.QB_DRUM_ROLL_STATE.isPlaying) return;

      const now = ctx.currentTime;
      const beatFrequencies = [200, 250, 220]; // Drum roll frequencies

      beatFrequencies.forEach((freq, idx) => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();

        osc.connect(gain);
        gain.connect(ctx.destination);

        osc.frequency.setValueAtTime(freq, now + idx * 0.08);
        gain.gain.setValueAtTime(0.15, now + idx * 0.08);
        gain.gain.exponentialRampToValueAtTime(0.01, now + idx * 0.08 + 0.06);

        osc.start(now + idx * 0.08);
        osc.stop(now + idx * 0.08 + 0.06);
      });

      // Loop drum roll every 250ms
      if (window.QB_DRUM_ROLL_STATE.isPlaying) {
        setTimeout(playDrumBeat, 250);
      }
    };

    playDrumBeat();
  } catch (e) {
    // Fallback: silent if Web Audio API fails
  }
};

// Stop drum roll and play winning sound
window.qbStopDrumRoll = function() {
  window.QB_DRUM_ROLL_STATE.isPlaying = false;

  try {
    if (!window.QB_DRUM_ROLL_STATE.audioContext) {
      window.QB_DRUM_ROLL_STATE.audioContext = new (window.AudioContext || window.webkitAudioContext)();
    }
    const ctx = window.QB_DRUM_ROLL_STATE.audioContext;

    // Play winning celebration sound
    const notes = [800, 1000, 1200];
    let delay = 0;

    notes.forEach((freq) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();

      osc.connect(gain);
      gain.connect(ctx.destination);

      const now = ctx.currentTime + delay;
      osc.frequency.setValueAtTime(freq, now);
      gain.gain.setValueAtTime(0.2, now);
      gain.gain.exponentialRampToValueAtTime(0.01, now + 0.15);

      osc.start(now);
      osc.stop(now + 0.15);

      delay += 0.15;
    });
  } catch (e) {
    // Fallback
  }
};

