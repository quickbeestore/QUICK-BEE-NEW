    function attachLocationSelectors() {
      var districtSelect = document.getElementById('qbDistrict');
      var municipalitySelect = document.getElementById('qbMunicipality');
      var areaSelect = document.getElementById('qbArea');
      var subareaSelect = document.getElementById('qbSubArea');
      var selectBtn = document.getElementById('qbSelectBtn');

      if (!districtSelect || !municipalitySelect || !areaSelect || !subareaSelect || !selectBtn) {
        console.error('Location select elements not found');
        return;
      }

      districtSelect.addEventListener('change', function() {
      municipalitySelect.innerHTML = '<option value="">Select Municipality</option>';
      areaSelect.innerHTML = '<option value="">Select Area</option>';
      subareaSelect.innerHTML = '<option value="">Select Sub-Area</option>';
      municipalitySelect.disabled = true;
      areaSelect.disabled = true;
      subareaSelect.disabled = true;
      selectBtn.disabled = true;
      selectBtn.style.opacity = '0.5';
      selectBtn.style.cursor = 'not-allowed';

      if (this.value) {
        var municipalities = Object.keys(qbLocationData[this.value]);
        municipalities.forEach(function(m) {
          var opt = document.createElement('option');
          opt.value = m;
          opt.textContent = m;
          municipalitySelect.appendChild(opt);
        });
        municipalitySelect.disabled = false;
      }
    });

      municipalitySelect.addEventListener('change', function() {
        areaSelect.innerHTML = '<option value="">Select Area</option>';
        subareaSelect.innerHTML = '<option value="">Select Sub-Area</option>';
        areaSelect.disabled = true;
        subareaSelect.disabled = true;
        selectBtn.disabled = true;
        selectBtn.style.opacity = '0.5';
        selectBtn.style.cursor = 'not-allowed';

        if (this.value && districtSelect.value) {
          var areas = Object.keys(qbLocationData[districtSelect.value][this.value]);
          areas.forEach(function(a) {
            var opt = document.createElement('option');
            opt.value = a;
            opt.textContent = a;
            areaSelect.appendChild(opt);
          });
          areaSelect.disabled = false;
        }
      });

      areaSelect.addEventListener('change', function() {
        subareaSelect.innerHTML = '<option value="">Select Sub-Area</option>';
        subareaSelect.disabled = true;
        selectBtn.disabled = true;
        selectBtn.style.opacity = '0.5';
        selectBtn.style.cursor = 'not-allowed';

        if (this.value && districtSelect.value && municipalitySelect.value) {
          var subareas = qbLocationData[districtSelect.value][municipalitySelect.value][this.value];
          subareas.forEach(function(s) {
            var opt = document.createElement('option');
            opt.value = s;
            opt.textContent = s;
            subareaSelect.appendChild(opt);
          });
          subareaSelect.disabled = false;
        }
      });

      subareaSelect.addEventListener('change', function() {
        var deliveryTimeDisplay = document.getElementById('qbDeliveryTimeDisplay');
        var deliveryTimeValue = document.getElementById('qbDeliveryTimeValue');

        if (this.value) {
          var deliveryTime = qbDeliveryTimes[this.value] || 20;
          deliveryTimeValue.textContent = deliveryTime;
          deliveryTimeDisplay.style.display = 'block';
          selectBtn.disabled = false;
          selectBtn.style.opacity = '1';
          selectBtn.style.cursor = 'pointer';
        } else {
          deliveryTimeDisplay.style.display = 'none';
          selectBtn.disabled = true;
          selectBtn.style.opacity = '0.5';
          selectBtn.style.cursor = 'not-allowed';
        }
      });
    }

    function qbSelectLocation() {
      console.log('qbSelectLocation v5 - selecting location');
      var subareaSelect = document.getElementById('qbSubArea');
      if (!subareaSelect || !subareaSelect.value) {
        alert('Please select all location levels');
        return;
      }
      var landmark = subareaSelect.value;
      var deliveryTime = qbDeliveryTimes[landmark] || 20;

      localStorage.setItem('qb_location', landmark);
      localStorage.setItem('qb_delivery_time', deliveryTime);

      var titleEl = document.getElementById('qbLocTitle');
      var addressEl = document.getElementById('qbLocAddress');
      titleEl.textContent = landmark;
      titleEl.setAttribute('data-delivery-time', deliveryTime);
      addressEl.textContent = deliveryTime + ' mins';
      addressEl.style.fontSize = '12px';
      addressEl.style.color = '#666';

      var modal = document.getElementById('qbLocModal');
      modal.style.display = 'none';
      modal.style.visibility = 'hidden';
      modal.style.opacity = '0';
      modal.style.pointerEvents = 'none';
    }


    // Initialize district dropdown with options
    function initializeDistricts() {
      var districtSelect = document.getElementById('qbDistrict');
      if (!districtSelect) return;
      var districts = Object.keys(qbLocationData);
      districts.forEach(function(d) {
        var opt = document.createElement('option');
        opt.value = d;
        opt.textContent = d;
        districtSelect.appendChild(opt);
