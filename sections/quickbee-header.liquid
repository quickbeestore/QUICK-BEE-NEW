  @keyframes qb-spin { to { transform: rotate(360deg); } }

  /* Hierarchical Location Picker */
  .qb-hierarchy-wrapper {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px;
  }
  .qb-hierarchy-level {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .qb-hierarchy-label {
    font-size: 11px;
    font-weight: 700;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .qb-hierarchy-select {
    width: 100%;
    padding: 10px 12px;
    border: 1.5px solid #e0e0e0;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
    color: #222;
    background: #fff;
    cursor: pointer;
    transition: all 0.2s;
  }
  .qb-hierarchy-select:hover {
    border-color: var(--qb-yellow);
    background: #fffbe6;
  }
  .qb-hierarchy-select:focus {
    outline: none;
    border-color: var(--qb-yellow);
    box-shadow: 0 0 0 3px rgba(245, 197, 24, 0.1);
  }
  .qb-hierarchy-select:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background: #f5f5f5;
  }
  .qb-delivery-time {
    padding: 12px 14px;
    background: #fffbe6;
    border: 1px solid #ffd666;
    border-radius: 6px;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    color: #222;
    margin-top: 8px;
  }
  .qb-delivery-time strong {
    font-size: 16px;
    color: var(--qb-yellow);
  }
  .qb-delivery-time-label {
    font-size: 11px;
    color: #888;
    margin-top: 4px;
  }

  /* Modal Dialog Styles */
  .qb-location-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    visibility: hidden;
    opacity: 0;
  }

  .qb-modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    cursor: pointer;
  }

  .qb-modal-content {
    position: relative;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    max-width: 500px;
    width: 90%;
    max-height: 90vh;
    z-index: 10001;
  }

  .qb-modal-header {
    padding: 24px;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-shrink: 0;
  }

  .qb-modal-header h2 {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
    color: #222;
  }

  .qb-modal-close {
    background: none;
    border: none;
    font-size: 24px;
    color: #999;
    cursor: pointer;
    padding: 4px 8px;
    transition: color 0.2s;
  }

  .qb-modal-close:hover {
    color: #222;
  }

  .qb-breadcrumb {
    padding: 16px 24px;
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
    font-size: 13px;
    font-weight: 600;
    color: #999;
    background: #fafafa;
  }

  .qb-breadcrumb-item {
    color: #999;
    transition: color 0.2s;
  }

  .qb-breadcrumb-item.active {
    color: var(--qb-yellow);
  }

  .qb-breadcrumb-sep {
    color: #ddd;
  }

  .qb-progress-bar {
    height: 4px;
    background: #e0e0e0;
    width: 100%;
    flex-shrink: 0;
  }

  .qb-progress-fill {
    height: 100%;
    background: var(--qb-yellow);
    transition: width 0.3s ease;
    width: 0%;
  }

  .qb-modal-body {
    flex: 1;
    padding: 24px;
    overflow-y: auto;
  }

  .qb-modal-footer {
    padding: 24px;
    border-top: 1px solid #f0f0f0;
    display: flex;
    gap: 12px;
    flex-shrink: 0;
  }

  .qb-btn-primary,
  .qb-btn-cancel {
    flex: 1;
    padding: 12px 20px;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .qb-btn-primary {
    background: var(--qb-yellow);
    color: #222;
  }

  .qb-btn-primary:hover:not(:disabled) {
    background: #e8b800;
    box-shadow: 0 4px 12px rgba(245, 197, 24, 0.3);
  }

  .qb-btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .qb-btn-cancel {
    background: #f5f5f5;
    color: #222;
  }

  .qb-btn-cancel:hover {
    background: #e8e8e8;
  }

  /* Account & Cart (Top bar) */
  .qb-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
    margin-left: auto;
  }
  .qb-action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--qb-text-dark);
    font-size: 11px;
    font-weight: 600;
    font-family: inherit;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s;
    position: relative;
    padding: 4px;
  }
  .qb-action-btn:hover { color: var(--qb-nav-color); }
  .qb-action-btn svg { width: 18px; height: 18px; }
  .qb-action-btn.text-icon {
    flex-direction: column;
    gap: 2px;
  }

  /* Hide spacer to center search bar */
  .qb-header-top > div:empty {
    display: none !important;
  }

  .qb-cart-wrap { position: relative; }
  .qb-cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    background: linear-gradient(135deg, #f5c518 0%, #e8b800 100%);
