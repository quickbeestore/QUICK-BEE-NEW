// Splash Screen Handler - Show only on first visit
window.qbInitSplashScreen = function() {
  const splashScreen = document.getElementById('qbSplashScreen');
  if (!splashScreen) return;

  // Check if user has already seen splash screen
  const splashSeen = sessionStorage.getItem('qb_splash_shown');

  // If already seen in this session, hide immediately
  if (splashSeen) {
    splashScreen.classList.add('hidden');
    setTimeout(() => {
      if (splashScreen.parentNode) {
        splashScreen.parentNode.removeChild(splashScreen);
      }
    }, 100);
    return;
  }

  // First time - show splash screen for 2.5 seconds
  sessionStorage.setItem('qb_splash_shown', 'true');
  setTimeout(() => {
    if (splashScreen) {
      splashScreen.classList.add('hidden');
      // Ensure it's completely removed from DOM
      setTimeout(() => {
        if (splashScreen.parentNode) {
          splashScreen.parentNode.removeChild(splashScreen);
        }
      }, 200);
    }
  }, 2500);
};

// Initialize splash screen when DOM is ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', window.qbInitSplashScreen);
} else {
  window.qbInitSplashScreen();
}

