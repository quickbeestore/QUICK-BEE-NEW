// Update timer
window.qbUpdateTimerDisplay = function() {
  const data = JSON.parse(localStorage.getItem(window.QB_WHEEL_CONFIG.storageKey) || '{}');
  const timerDisplay = document.getElementById('qbTimerDisplay');
  const timerReadyMsg = document.getElementById('qbTimerReadyMsg');
  const spinBtn = document.getElementById('qbSpinBtn');
  const cooldownMsg = document.getElementById('qbCooldownMsg');

  if (!data.lastSpinTime) {
    timerDisplay.textContent = '∞';
    timerDisplay.classList.remove('ready');
    timerReadyMsg.style.display = 'none';
    spinBtn.disabled = false;
    cooldownMsg.style.display = 'none';
    return;
  }

  const remaining = (data.lastSpinTime + window.QB_WHEEL_CONFIG.cooldownMs) - Date.now();

  if (remaining <= 0) {
    timerDisplay.textContent = '∞';
    timerDisplay.classList.add('ready');
    timerReadyMsg.style.display = 'block';
    spinBtn.disabled = false;
    cooldownMsg.style.display = 'none';
    return;
  }

  const h = Math.floor(remaining / 3600000);
  const m = Math.floor((remaining % 3600000) / 60000);
  const s = Math.floor((remaining % 60000) / 1000);

  timerDisplay.textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  timerDisplay.classList.remove('ready');
  timerReadyMsg.style.display = 'none';
  spinBtn.disabled = true;
  cooldownMsg.style.display = 'block';
  cooldownMsg.innerHTML = `⏳ <strong>Come back in ${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}</strong>`;
};

// Spin wheel
window.qbSpinTheWheel = function() {
  if (window.QB_WHEEL_STATE.isSpinning) return;

  const data = JSON.parse(localStorage.getItem(window.QB_WHEEL_CONFIG.storageKey) || '{}');
  if (data.lastSpinTime && Date.now() < data.lastSpinTime + window.QB_WHEEL_CONFIG.cooldownMs) {
    alert('Already spun today! Come back later.');
    return;
  }

  window.QB_WHEEL_STATE.isSpinning = true;
  const wheel = document.getElementById('qbWheelMain');
  const spinBtn = document.getElementById('qbSpinBtn');
  const overlay = document.getElementById('qbWheelOverlay');
  spinBtn.disabled = true;

  // Show the wheel overlay
  if (overlay) {
    overlay.classList.add('show');
  }

  // Play drum roll sound - continues until result arrives
  window.qbPlayDrumRoll();

  const spins = 15 + Math.random() * 5;
  const extraDegrees = Math.random() * 360;
  const totalRotation = spins * 360 + extraDegrees;

  wheel.classList.add('spinning');
  wheel.style.transform = `rotate(${totalRotation}deg)`;

  const prizeIndex = Math.floor((360 - (extraDegrees % 360)) % 360 / (360 / window.QB_WHEEL_CONFIG.prizes.length));
  const prize = window.QB_WHEEL_CONFIG.prizes[prizeIndex];

  setTimeout(() => {
    wheel.classList.remove('spinning');

    // Lock the pointer on the winning prize
    const pointer = document.querySelector('.qb-wheel-pointer');
    if (pointer) {
      pointer.classList.add('locked');
    }

    const newData = {
      lastSpinTime: Date.now(),
      lastPrize: prize,
      totalSpins: (data.totalSpins || 0) + 1
    };
    localStorage.setItem(window.QB_WHEEL_CONFIG.storageKey, JSON.stringify(newData));

    window.qbShowResult(prize);
    window.QB_WHEEL_STATE.isSpinning = false;
    window.qbUpdateTimerDisplay();
  }, 16000);
};

// Show result
window.qbShowResult = function(prize) {
  document.getElementById('qbResultEmoji').textContent = prize.emoji;
  document.getElementById('qbResultLabel').textContent = prize.name;
  document.getElementById('qbResultText').textContent = prize.code;
  document.getElementById('qbResultCodeLabel').textContent = prize.code;
  document.getElementById('qbResultModal').classList.add('show');

  // Stop drum roll and play winning celebration sound
  window.qbStopDrumRoll();
};

// Copy code
window.qbCopyCode = function() {
  const code = document.getElementById('qbResultText').textContent;
  navigator.clipboard.writeText(code).then(() => {
    const btn = document.getElementById('qbCopyBtn');
    const originalText = btn.textContent;
    btn.textContent = '✓ COPIED!';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.textContent = originalText;
      btn.classList.remove('copied');
    }, 2000);
  });
};

window.qbUpdateTimerDisplay();
setInterval(window.qbUpdateTimerDisplay, 1000);
console.log('🎡 Premium Wheel Ready');
console.log('💰 Wallet Ready');

// Splash Screen Handler - Show only on first visit
window.qbInitSplashScreen = function() {
  const splashScreen = document.getElementById('qbSplashScreen');
  if (!splashScreen) return;

  // Check if user has already seen splash screen
  const splashSeen = sessionStorage.getItem('qb_splash_shown');

  // If already seen in this session, hide immediately
  if (splashSeen) {
    splashScreen.classList.add('hidden');
    setTimeout(() => {
      if (splashScreen.parentNode) {
        splashScreen.parentNode.removeChild(splashScreen);
      }
    }, 100);
    return;
  }

  // First time - show splash screen for 2.5 seconds
  sessionStorage.setItem('qb_splash_shown', 'true');
  setTimeout(() => {
    if (splashScreen) {
      splashScreen.classList.add('hidden');
      // Ensure it's completely removed from DOM
      setTimeout(() => {
        if (splashScreen.parentNode) {
          splashScreen.parentNode.removeChild(splashScreen);
        }
      }, 200);
    }
  }, 2500);
};

// Initialize splash screen when DOM is ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', window.qbInitSplashScreen);
} else {
  window.qbInitSplashScreen();
}

console.log('🐝 QuickBee Splash Screen Ready');
</script>
</script>

<script>
(function () {
  var wrap    = document.getElementById('qbLocationWrap');
  var btn     = document.getElementById('qbLocBtn');
  var dropdown= document.getElementById('qbLocDropdown');
  var input   = document.getElementById('qbLocInput');
  var clearBtn= document.getElementById('qbLocClear');
  var gpsBtn  = document.getElementById('qbLocGPS');
  var results = document.getElementById('qbLocResults');
  var titleEl = document.getElementById('qbLocTitle');
  var addressEl = document.getElementById('qbLocAddress');
  if (!btn) return;

  var debounceTimer, currentQuery = '', focusedIndex = -1;

  // Address management
  var currentSelectedPlace = null;
  var savedAddresses = [];
  var allowedCities = ['Kathmandu', 'Bhaktapur', 'Lalitpur'];
  var currentDeliveryTime = 22;

  // Generate random delivery time between 18-32 minutes
  function getRandomDeliveryTime() {
    return Math.floor(Math.random() * (32 - 18 + 1)) + 18;
  }

  // Check if location is in service area
  function isLocationInServiceArea(address) {
    if (!address) return false;
    return allowedCities.some(function(city) {
      return address.toUpperCase().includes(city.toUpperCase());
    });
  }

  // Show service area error popup
  function showServiceAreaError() {
    var modal = document.createElement('div');
    modal.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:10000';
    modal.innerHTML = '<div style="background:#fff;border-radius:12px;padding:24px;max-width:320px;text-align:center;box-shadow:0 10px 40px rgba(0,0,0,0.2)">' +
      '<div style="font-size:16px;font-weight:700;color:#222;margin-bottom:12px">Service Area</div>' +
      '<p style="font-size:14px;color:#666;margin-bottom:16px;line-height:1.5">Currently we only operate in <strong>Kathmandu, Bhaktapur</strong> and <strong>Lalitpur</strong>. Please enter a location inside these areas.</p>' +
      '<button style="background:#f5c518;border:none;padding:10px 24px;border-radius:6px;font-weight:600;cursor:pointer;font-size:14px;color:#222;width:100%;transition:background 0.2s" onclick="this.closest(\'div\').parentElement.remove()">OK, Got it</button>' +
      '</div>';
    document.body.appendChild(modal);
  }

  // Load saved addresses
  function loadSavedAddresses() {
    try {
      var saved = localStorage.getItem('qb_saved_addresses');
      savedAddresses = saved ? JSON.parse(saved) : [];
      updateSavedAddressesCount();
      renderSavedAddresses();
    } catch (e) {
      savedAddresses = [];
    }
  }

  function updateSavedAddressesCount() {
    var tab = Array.from(document.querySelectorAll('.qb-loc-tab')).find(function (t) {
      return t.textContent.includes('Saved');
    });
    if (tab) tab.textContent = 'Saved (' + savedAddresses.length + ')';
  }

  function saveSavedAddresses() {
    try {
      localStorage.setItem('qb_saved_addresses', JSON.stringify(savedAddresses));
    } catch (e) {}
  }

  // Restore current location
  try {
    var savedLoc = localStorage.getItem('qb_location_detail');
    if (savedLoc) {
      var locData = JSON.parse(savedLoc);
      updateLocationDisplay(locData);
      window.QB_LOCATION = locData; // expose to window for checkout
    }
  } catch (e) {}

  // Update location display (title and address)
  function updateLocationDisplay(locData) {
    if (titleEl && addressEl) {
      currentDeliveryTime = getRandomDeliveryTime();
      titleEl.textContent = 'Delivery in ' + currentDeliveryTime + ' mins';
      var addrParts = locData.address ? locData.address.split(',').slice(0, 2).map(p => p.trim()) : [];
      addressEl.textContent = addrParts.join(', ') || locData.name;
    }
  }

  // Tab switching for saved addresses
  var tabs = document.querySelectorAll('.qb-loc-tab');
  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      var tabName = tab.getAttribute('data-tab');
      var content = Array.from(document.querySelectorAll('.qb-loc-tab-content')).find(function (c) {
        return c.getAttribute('data-tab') === tabName;
      });
      if (content) {
        // Toggle or show
        var isVisible = !content.hidden;
        document.querySelectorAll('.qb-loc-tab-content').forEach(function (c) { c.hidden = true; });
        content.hidden = isVisible;
        tab.classList.toggle('active', !isVisible);
      }
    });
  });

  loadSavedAddresses();

  // Toggle dropdown
  btn.addEventListener('click', function () {
    var isOpen = !dropdown.hidden;
    toggleDropdown(!isOpen);
    // Focus input immediately when dropdown opens
    if (!isOpen) {
      setTimeout(function () {
        input.focus();
        input.select();
      }, 50);
    }
  });

  // Create or get backdrop
  var backdrop = document.querySelector('.qb-loc-backdrop') || (function() {
    var bd = document.createElement('div');
    bd.className = 'qb-loc-backdrop';
    document.body.appendChild(bd);
    return bd;
  })();

  function toggleDropdown(open) {
    dropdown.hidden = !open;
    btn.classList.toggle('open', open);
    btn.setAttribute('aria-expanded', String(open));
    backdrop.classList.toggle('show', open);

    // Position dropdown below location button, avoiding sidebar overlap
    if (open) {
      var btnRect = btn.getBoundingClientRect();
      var dropdownHeight = dropdown.offsetHeight || 300;
      var dropdownWidth = dropdown.offsetWidth || 320;
      var topPos = btnRect.bottom + 12;

      // Position to avoid left sidebar (80px wide) - start at 85px minimum
      var leftPos = Math.max(85, btnRect.left);

      // Ensure dropdown fits on screen horizontally
      if (leftPos + dropdownWidth > window.innerWidth) {
        leftPos = Math.max(85, window.innerWidth - dropdownWidth - 10);
      }

      // Ensure dropdown fits vertically
      if (topPos + dropdownHeight > window.innerHeight) {
        topPos = Math.max(70, window.innerHeight - dropdownHeight - 20);
      }

      dropdown.style.position = 'fixed';
      dropdown.style.top = topPos + 'px';
      dropdown.style.left = leftPos + 'px';
      dropdown.style.zIndex = '100001';
      dropdown.style.maxHeight = Math.min(70 * window.innerHeight / 100, window.innerHeight - topPos - 40) + 'px';
      dropdown.style.height = 'auto';
      dropdown.style.overflowY = 'auto';
      dropdown.style.overflowX = 'hidden';
      dropdown.style.width = dropdownWidth + 'px';
    }
  }

  // Close on outside click (but not if clicking inside dropdown or location wrap)
  document.addEventListener('click', function (e) {
    if (!wrap.contains(e.target) && !dropdown.contains(e.target)) {
      toggleDropdown(false);
    }
  });

  // Clear button
  clearBtn.addEventListener('click', function () {
    input.value = '';
    clearBtn.hidden = true;
    results.innerHTML = '';
    input.focus();
    currentQuery = '';
  });

  // Input → debounced Nominatim fetch
  input.addEventListener('input', function () {
    var q = input.value.trim();
    clearBtn.hidden = q.length === 0;
    clearTimeout(debounceTimer);
    if (q.length < 2) { results.innerHTML = ''; return; }
    if (q === currentQuery) return;
    currentQuery = q;
    debounceTimer = setTimeout(function () { fetchSuggestions(q); }, 420);
  });

  // Keyboard navigation
  input.addEventListener('keydown', function (e) {
    var items = results.querySelectorAll('.qb-loc-result-item');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      focusedIndex = Math.min(focusedIndex + 1, items.length - 1);
      updateFocus(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      focusedIndex = Math.max(focusedIndex - 1, -1);
      updateFocus(items);
    } else if (e.key === 'Enter' && focusedIndex >= 0 && items[focusedIndex]) {
      items[focusedIndex].click();
    } else if (e.key === 'Escape') {
      toggleDropdown(false);
    }
  });

  function updateFocus(items) {
    items.forEach(function (item, i) {
      item.classList.toggle('focused', i === focusedIndex);
    });
  }

  function fetchSuggestions(q) {
    results.innerHTML = '<li class="qb-loc-loading"><span class="qb-loc-spinner"></span>Searching…</li>';
    focusedIndex = -1;
    var url = 'https://nominatim.openstreetmap.org/search?q='
      + encodeURIComponent(q)
      + '&format=json&limit=6&addressdetails=1';
    fetch(url, { headers: { 'Accept-Language': 'en' } })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (input.value.trim() !== q) return; // stale response
        renderResults(data);
      })
      .catch(function () {
        results.innerHTML = '<li class="qb-loc-empty">Could not load suggestions.</li>';
      });
  }

  function renderResults(data) {
    results.innerHTML = '';
    if (!data || data.length === 0) {
      results.innerHTML = '<li class="qb-loc-empty">No results found.</li>';
      return;
    }
    data.forEach(function (place) {
      var addr  = place.address || {};
      var main  = addr.city || addr.town || addr.village || addr.suburb
                  || addr.county || addr.state || place.display_name.split(',')[0];
      var parts = place.display_name.split(',');
      var sub   = parts.slice(0, Math.min(3, parts.length)).join(', ').trim();

      // Build detailed address for checkout
      var detailedAddr = [
        addr.house_number || '',
        addr.road || '',
        addr.neighbourhood || '',
        addr.suburb || '',
        addr.city || addr.town || addr.village || '',
        addr.county || '',
        addr.state || '',
        addr.postcode || '',
        addr.country || ''
      ].filter(Boolean).join(', ');

      var li = document.createElement('li');
      li.className = 'qb-loc-result-item';
      li.setAttribute('role', 'option');
      li.innerHTML =
        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f5c518" stroke-width="2.5" stroke-linecap="round">'
        + '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>'
        + '<circle cx="12" cy="9" r="2" fill="#f5c518" stroke="none"/></svg>'
        + '<div><div class="qb-loc-result-main">' + esc(main) + '</div>'
        + '<div class="qb-loc-result-sub">' + esc(sub) + '</div></div>';

      li.addEventListener('click', function () {
        selectLocation({
          main: main,
          full: detailedAddr || place.display_name,
          lat: place.lat,
          lon: place.lon
        });
      });
      results.appendChild(li);
    });
  }

  function selectLocation(placeData) {
    // placeData can be a string (from GPS) or full object (from search)
    var name = typeof placeData === 'string' ? placeData : placeData.main;
    var fullAddress = typeof placeData === 'string' ? placeData : placeData.full;
    var lat = placeData.lat || null;
    var lon = placeData.lon || null;

    // Validate location is in service area
    if (!isLocationInServiceArea(fullAddress)) {
      showServiceAreaError();
      return;
    }

    currentSelectedPlace = { name: name, address: fullAddress, lat: lat, lon: lon };

    // Update display
    updateLocationDisplay(currentSelectedPlace);

    // Save to current location
    try {
      var locObj = {
        name: name,
        address: fullAddress,
        lat: lat,
        lon: lon,
        deliveryTime: currentDeliveryTime,
        savedAt: new Date().toISOString()
      };
      localStorage.setItem('qb_location_detail', JSON.stringify(locObj));
      window.QB_LOCATION = locObj;

      // Dispatch location change event for weather widget
      window.dispatchEvent(new Event('qb_location_changed'));
    } catch (e) {}

    // Show save form
    var saveForm = document.getElementById('qbLocSaveForm');
    if (saveForm) saveForm.hidden = false;

    input.value = '';
    results.innerHTML = '';
    clearBtn.hidden = true;
    currentQuery = '';
  }

  // Save address button handlers
  var saveButtons = document.querySelectorAll('.qb-loc-save-btn');
  saveButtons.forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      if (!currentSelectedPlace) return;
      var lbl = btn.getAttribute('data-label');
      var addressObj = Object.assign({}, currentSelectedPlace, {
        label: lbl,
        id: Date.now(),
        savedAt: new Date().toISOString()
      });
      savedAddresses.push(addressObj);
      saveSavedAddresses();
      updateSavedAddressesCount();
      renderSavedAddresses();
      document.getElementById('qbLocSaveForm').hidden = true;
      currentSelectedPlace = null;
      btn.textContent = '✓ Saved!';
      setTimeout(function () { btn.textContent = lbl; }, 1500);
    });
  });

  // Render saved addresses
  function renderSavedAddresses() {
    var listContainer = document.getElementById('qbLocSavedList');
    if (!listContainer) return;
    if (savedAddresses.length === 0) {
      listContainer.innerHTML = '<div style="padding:16px 14px;text-align:center;color:#aaa;font-size:13px">No saved addresses yet</div>';
      return;
    }
    listContainer.innerHTML = '';
    savedAddresses.forEach(function (addr, idx) {
      var item = document.createElement('div');
      item.className = 'qb-loc-saved-item';
      item.innerHTML =
        '<div class="qb-loc-saved-info">' +
        '<div class="qb-loc-saved-label">' + esc(addr.label) + '</div>' +
        '<div class="qb-loc-saved-address">' + esc(addr.address.substring(0, 50)) + (addr.address.length > 50 ? '…' : '') + '</div>' +
        '</div>' +
        '<button type="button" class="qb-loc-saved-delete" title="Delete">✕</button>';

      item.querySelector('.qb-loc-saved-info').addEventListener('click', function () {
        // Validate saved location is still in service area
        if (!isLocationInServiceArea(addr.address)) {
          showServiceAreaError();
          return;
        }

        // Update with new random delivery time
        updateLocationDisplay(addr);
        try {
          var updatedAddr = Object.assign({}, addr, { deliveryTime: currentDeliveryTime });
          localStorage.setItem('qb_location_detail', JSON.stringify(updatedAddr));
          window.QB_LOCATION = updatedAddr;

          // Dispatch location change event for weather widget
          window.dispatchEvent(new Event('qb_location_changed'));
        } catch (e) {}
        toggleDropdown(false);
      });

      item.querySelector('.qb-loc-saved-delete').addEventListener('click', function (e) {
        e.stopPropagation();
        savedAddresses.splice(idx, 1);
        saveSavedAddresses();
        updateSavedAddressesCount();
        renderSavedAddresses();
      });

      listContainer.appendChild(item);
    });
  }

  // GPS / reverse geocode
  gpsBtn.addEventListener('click', function () {
    if (!navigator.geolocation) {
      gpsBtn.textContent = 'Not supported';
      return;
    }
    var origHTML = gpsBtn.innerHTML;
    gpsBtn.innerHTML = '<span class="qb-loc-spinner" style="border-color:#2563eb;border-top-color:transparent"></span>Locating…';
    gpsBtn.disabled = true;

    navigator.geolocation.getCurrentPosition(
      function (pos) {
        fetch('https://nominatim.openstreetmap.org/reverse?lat=' + pos.coords.latitude
          + '&lon=' + pos.coords.longitude + '&format=json',
          { headers: { 'Accept-Language': 'en' } })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var addr = data.address || {};
            var name = addr.suburb || addr.neighbourhood || addr.city
                       || addr.town || addr.village || addr.county || 'Your location';

            // Build detailed address for checkout
            var detailedAddr = [
              addr.house_number || '',
              addr.road || '',
              addr.neighbourhood || '',
              addr.suburb || '',
              addr.city || addr.town || addr.village || '',
              addr.county || '',
              addr.state || '',
              addr.postcode || '',
              addr.country || ''
            ].filter(Boolean).join(', ');

            selectLocation({
              main: name,
              full: detailedAddr || data.display_name,
              lat: pos.coords.latitude,
              lon: pos.coords.longitude
            });
            gpsBtn.innerHTML = origHTML;
            gpsBtn.disabled = false;
          })
          .catch(function () {
            gpsBtn.innerHTML = origHTML;
            gpsBtn.disabled = false;
          });
      },
      function () {
        gpsBtn.innerHTML = origHTML;
        gpsBtn.disabled = false;
      },
      { timeout: 8000 }
    );
  });

  function esc(s) {
    return String(s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
})();

/* Mobile Footer Navigation */
(function () {
  var footer = document.getElementById('qbMobileFooter');
  var catBtn = document.getElementById('qbMFCategories');
  if (!footer || !catBtn) return;

  // Enable mobile footer on load
