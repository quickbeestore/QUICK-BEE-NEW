    <!-- Inline Search Bar Initialization -->
    <script>
      (function() {
        const searchInput = document.getElementById('qbSearchInput');
        const dropdown = document.getElementById('qbSearchDropdown');
        const dropdownItems = document.getElementById('qbDropdownItems');
        const dropdownHeader = document.getElementById('qbDropdownHeader');
        const dropdownTitle = document.getElementById('qbDropdownTitle');
        const dropdownEmpty = document.getElementById('qbDropdownEmpty');
        const clearBtn = document.getElementById('qbClearHistory');

        if (!searchInput || !dropdown) return;

        // Get history
        function getHistory() {
          try {
            return JSON.parse(localStorage.getItem('qb_search_history') || '[]');
          } catch {
            return [];
          }
        }

        // Add to history
        function addToHistory(query) {
          if (query.length < 2) return;
          let history = getHistory();
          history = history.filter(h => h !== query);
          history.unshift(query);
          history = history.slice(0, 10);
          localStorage.setItem('qb_search_history', JSON.stringify(history));
        }

        // Trending searches
        const trendingSearches = [
          { text: 'Dairy Products' },
          { text: 'Fresh Vegetables' },
          { text: 'Snacks & Sweets' },
          { text: 'Beverages' },
          { text: 'Frozen Foods' }
        ];

        // Show history or trending searches
        function showHistory() {
          const history = getHistory();
          dropdownItems.innerHTML = '';

          if (history.length > 0) {
            // Show history
            dropdownTitle.textContent = 'Recent Searches';
            dropdownHeader.hidden = false;
            clearBtn.hidden = false;
            dropdownEmpty.hidden = true;

            history.forEach(item => {
              const div = document.createElement('div');
              div.className = 'qb-dropdown-item';
              div.innerHTML = `<span>${item}</span><button class="qb-remove-item" type="button">×</button>`;

              div.addEventListener('click', (e) => {
                if (e.target.classList.contains('qb-remove-item')) return;
                searchInput.value = item;
                addToHistory(item);
                window.location = `/search?q=${encodeURIComponent(item)}`;
              });

              div.querySelector('.qb-remove-item').addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                let h = getHistory();
                h = h.filter(x => x !== item);
                localStorage.setItem('qb_search_history', JSON.stringify(h));
                showHistory();
              });

              dropdownItems.appendChild(div);
            });
          } else {
            // Show trending searches
            dropdownTitle.textContent = 'Trending Searches';
            dropdownHeader.hidden = false;
            clearBtn.hidden = true;
            dropdownEmpty.hidden = true;

            trendingSearches.forEach(trend => {
              const div = document.createElement('div');
              div.className = 'qb-dropdown-item qb-trending-item';
              div.innerHTML = `<span class="qb-item-icon">🔥</span><span class="qb-item-text">${trend.text}</span>`;

              div.addEventListener('click', () => {
                searchInput.value = trend.text;
                addToHistory(trend.text);
                window.location = `/search?q=${encodeURIComponent(trend.text)}`;
              });

              dropdownItems.appendChild(div);
            });
          }

          showDropdown();
        }

        // Show dropdown
        function showDropdown() {
          if (dropdown) {
            dropdown.removeAttribute('hidden');
            dropdown.style.display = 'block !important';
            dropdown.style.visibility = 'visible !important';
            dropdown.style.opacity = '1 !important';
          }
          positionDropdown();
        }

        // Hide dropdown
        function hideDropdown() {
          if (dropdown) {
            dropdown.setAttribute('hidden', '');
            dropdown.style.display = 'none';
            dropdown.style.visibility = 'hidden';
          }
        }

        // Position dropdown below search input
        function positionDropdown() {
          if (!dropdown) return;

          try {
            const rect = searchInput.getBoundingClientRect();
            const gap = 12;

            dropdown.style.position = 'fixed !important';
            dropdown.style.top = (rect.bottom + gap) + 'px';
            dropdown.style.left = rect.left + 'px';
            dropdown.style.width = rect.width + 'px';
            dropdown.style.zIndex = '999999 !important';
          } catch (e) {
            // Silently fail
          }
        }

        // Events
        searchInput.addEventListener('focus', showHistory);
        searchInput.addEventListener('blur', () => setTimeout(hideDropdown, 200));
        searchInput.addEventListener('input', (e) => {
          if (e.target.value.trim().length < 2) {
            showHistory();
          }
        });

        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            const query = searchInput.value.trim();
            if (query.length >= 2) {
              addToHistory(query);
              window.location = `/search?q=${encodeURIComponent(query)}`;
            }
          }
        });

        if (clearBtn) {
          clearBtn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            localStorage.removeItem('qb_search_history');
            showHistory();
          });
        }

        document.addEventListener('click', (e) => {
          const container = document.getElementById('qbSearchContainer');
          if (container && !container.contains(e.target) && dropdown && !dropdown.contains(e.target)) {
            hideDropdown();
          }
        });
      })();
    </script>

