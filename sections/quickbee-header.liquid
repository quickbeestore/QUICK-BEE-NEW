// Render prize list
window.qbRenderPrizes = function() {
  const list = document.getElementById('qbPrizesList');
  list.innerHTML = window.QB_WHEEL_CONFIG.prizes.map(p => `
    <div class="qb-prize-item">
      <div class="qb-prize-emoji">${p.emoji}</div>
      <div class="qb-prize-info">
        <div class="qb-prize-name">${p.name}</div>
        <div class="qb-prize-code">${p.code}</div>
      </div>
    </div>
  `).join('');

  // Render prize labels on wheel using SVG for proper circular layout
  const svg = document.getElementById('qbPrizeLabelsSvg');
  const centerX = 150;
  const centerY = 150;
  const radius = 100; // Distance from center where text will be placed

  svg.innerHTML = window.QB_WHEEL_CONFIG.prizes.map((p, i) => {
    // Calculate angle for this prize (8 items = 45 degrees each)
    const angle = (i * 360 / 8) - 90; // Start from top
    const radians = angle * Math.PI / 180;

    // Calculate position on circle
    const x = centerX + radius * Math.cos(radians);
    const y = centerY + radius * Math.sin(radians);

    // Calculate rotation for text (perpendicular to radius, facing outward)
    const textAngle = angle + 90;

    return `
      <g transform="translate(${x}, ${y}) rotate(${textAngle})">
        <text
          x="0"
          y="0"
          text-anchor="middle"
          dominant-baseline="middle"
          style="font-size: 16px; font-weight: 700; fill: #222; pointer-events: none;"
        >
          ${p.emoji}
        </text>
        <text
          x="0"
          y="14"
          text-anchor="middle"
          dominant-baseline="middle"
          style="font-size: 9px; font-weight: 600; fill: #222; pointer-events: none;"
        >
          ${p.name}
        </text>
      </g>
    `;
  }).join('');
};

