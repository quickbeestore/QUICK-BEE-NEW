<script>
window.QB_WHEEL_CONFIG = {
  prizes: [
    { name: '10% OFF', code: 'BEE10', emoji: '🐝' },
    { name: '15% OFF', code: 'SNE15', emoji: '✨' },
    { name: '12% OFF', code: 'SHI28', emoji: '⭐' },
    { name: 'FREE 9%', code: 'BIBI69', emoji: '🎉' },
    { name: 'FREE DELIVERY', code: 'FRE28', emoji: '🚀' },
    { name: '5% OFF', code: 'HIVE5', emoji: '🍯' },
    { name: 'Rs 100 OFF', code: 'QB100', emoji: '💰' },
    { name: 'Surprise Reward', code: 'LUCKYQB', emoji: '🎁' }
  ],
  cooldownMs: 280 * 60 * 1000,
  storageKey: 'qb_wheel_data',
  emailKey: 'qb_user_email'
};

window.QB_WHEEL_STATE = { isSpinning: false };

// Show wheel - first show email form
window.qbShowWheelPopup = function() {
  const emailModal = document.getElementById('qbEmailModal');
  const userEmail = localStorage.getItem(window.QB_WHEEL_CONFIG.emailKey);

  if (userEmail) {
    window.qbShowWheelNow();
  } else {
    emailModal.classList.add('show');
    document.getElementById('qbEmailInput').focus();
  }
};

// Submit email
window.qbSubmitEmail = function(e) {
  e.preventDefault();
  const email = document.getElementById('qbEmailInput').value;
  localStorage.setItem(window.QB_WHEEL_CONFIG.emailKey, email);

  // Send email using FormSubmit.co (working service)
  const formData = new FormData();
  formData.append('email', email);
  formData.append('message', 'New QuickBee Spin Wheel participant');
  formData.append('_captcha', 'false');

  fetch('https://formsubmit.co/kioda.np@gmail.com', {
    method: 'POST',
    body: formData
  }).catch(() => {});

  document.getElementById('qbEmailModal').classList.remove('show');
  window.qbShowWheelNow();
};

// Show wheel now
window.qbShowWheelNow = function() {
  const overlay = document.getElementById('qbWheelOverlay');
  overlay.classList.add('show');
  window.qbRenderPrizes();
  window.qbUpdateTimerDisplay();
};

// Render prize list
window.qbRenderPrizes = function() {
  const list = document.getElementById('qbPrizesList');
  list.innerHTML = window.QB_WHEEL_CONFIG.prizes.map(p => `
    <div class="qb-prize-item">
      <div class="qb-prize-emoji">${p.emoji}</div>
      <div class="qb-prize-info">
        <div class="qb-prize-name">${p.name}</div>
        <div class="qb-prize-code">${p.code}</div>
      </div>
    </div>
  `).join('');

  // Render prize labels on wheel using SVG for proper circular layout
  const svg = document.getElementById('qbPrizeLabelsSvg');
  const centerX = 150;
  const centerY = 150;
  const radius = 100; // Distance from center where text will be placed

  svg.innerHTML = window.QB_WHEEL_CONFIG.prizes.map((p, i) => {
    // Calculate angle for this prize (8 items = 45 degrees each)
    const angle = (i * 360 / 8) - 90; // Start from top
    const radians = angle * Math.PI / 180;

    // Calculate position on circle
    const x = centerX + radius * Math.cos(radians);
    const y = centerY + radius * Math.sin(radians);

    // Calculate rotation for text (perpendicular to radius, facing outward)
    const textAngle = angle + 90;

    return `
      <g transform="translate(${x}, ${y}) rotate(${textAngle})">
        <text
          x="0"
          y="0"
          text-anchor="middle"
          dominant-baseline="middle"
          style="font-size: 16px; font-weight: 700; fill: #222; pointer-events: none;"
        >
          ${p.emoji}
        </text>
        <text
          x="0"
          y="14"
          text-anchor="middle"
          dominant-baseline="middle"
          style="font-size: 9px; font-weight: 600; fill: #222; pointer-events: none;"
        >
          ${p.name}
        </text>
      </g>
    `;
  }).join('');
};

