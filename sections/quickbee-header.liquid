<script>
  (function() {
    const input = document.getElementById('qbSearchInput');
    if (!input) return;

    const phrases = [
      'Search groceries in 20 mins',
      'Search cold drinks near you',
      'Search snacks for tonight',
      'Search fruits, noodles, beer'
    ];

    let phraseIndex = 0;
    let charIndex = 0;
    let typingTimer = null;
    let paused = false;

    function queueNext(delay) {
      window.clearTimeout(typingTimer);
      typingTimer = window.setTimeout(typeNextChar, delay);
    }

    function typeNextChar() {
      if (paused || document.activeElement === input || input.value) {
        queueNext(500);
        return;
      }

      const phrase = phrases[phraseIndex];
      charIndex += 1;
      input.placeholder = phrase.slice(0, charIndex);

      if (charIndex < phrase.length) {
        queueNext(42);
        return;
      }

      window.setTimeout(() => {
        if (paused || document.activeElement === input || input.value) {
          return;
        }
        phraseIndex = (phraseIndex + 1) % phrases.length;
        charIndex = 0;
        input.placeholder = '';
        queueNext(220);
      }, 1100);
    }

    input.addEventListener('focus', () => {
      paused = true;
      input.placeholder = '';
    });

    input.addEventListener('blur', () => {
      paused = false;
      if (!input.value) {
        charIndex = 0;
        input.placeholder = '';
        queueNext(120);
      }
    });

    input.addEventListener('input', () => {
      if (input.value) {
        window.clearTimeout(typingTimer);
        input.placeholder = '';
      } else if (document.activeElement !== input) {
        paused = false;
        charIndex = 0;
        queueNext(120);
      }
    });

    queueNext(180);
  })();

  (function() {
    const button = document.querySelector('.qb-loc-btn');
    const title = document.getElementById('qbLocTitle');
    const address = document.getElementById('qbLocAddress');

    if (!button || !title || !address) {
      return;
    }

    function readSavedLocation() {
      const keys = ['qb_location_detail', 'qb_selected_location'];
      for (const key of keys) {
        const raw = localStorage.getItem(key);
        if (!raw) {
          continue;
        }

        try {
          const parsed = JSON.parse(raw);
          if (parsed && typeof parsed === 'object') {
            return parsed;
          }
        } catch (error) {
          console.warn(`Unable to parse ${key}`, error);
        }
      }

      return null;
    }

    function pickTitle(location) {
      if (location?.mode === 'someone_else') {
        return location?.recipient_name || 'Order for someone else';
      }

      return (
        location?.label ||
        location?.name ||
        location?.street ||
        location?.address ||
        location?.city ||
        location?.area ||
        location?.district ||
        'Set location'
      );
    }

    function readDeliveryTime() {
      const raw = localStorage.getItem('qb_delivery_time');
      if (!raw) {
        return '';
      }

      try {
        const parsed = JSON.parse(raw);
        return parsed?.range || '';
      } catch (error) {
        console.warn('Unable to parse qb_delivery_time', error);
        return '';
      }
    }

    function pickSubtitle(location) {
      if (location?.mode === 'someone_else') {
        return location?.recipient_name || '';
      }

      const deliveryRange = readDeliveryTime();
      if (deliveryRange) {
        return `⚡ ${deliveryRange}`;
      }

      const parts = [
        location?.address,
        location?.formatted_address,
        location?.street,
        location?.ward,
        location?.locality,
        location?.city,
      ].filter(Boolean);

      return [...new Set(parts)].join(', ');
    }

    function updateLocationButton(detail) {
      const location = detail || readSavedLocation();
      const nextTitle = pickTitle(location);
      const nextAddress = location ? pickSubtitle(location) : readDeliveryTime();

      title.textContent = nextTitle;
      address.textContent = nextAddress;
      button.dataset.hasAddress = nextAddress ? 'true' : 'false';
      button.setAttribute('aria-label', nextAddress ? `${nextTitle}, ${nextAddress}` : nextTitle);
    }

    button.addEventListener('click', () => {
      if (typeof window.showLocationModal === 'function') {
        window.showLocationModal();
      }
    });

    window.addEventListener('locationSelected', (event) => {
      const location = event.detail;
      if (location) {
        try {
          // This is the fix: ensure the selection is saved to the key the cart page expects.
          localStorage.setItem('qb_selected_location', JSON.stringify(location));
        } catch (e) {
          console.error('Failed to save selected location to localStorage:', e);
        }
      }
      updateLocationButton(location);
    });

    window.addEventListener('qb_location_changed', () => {
      updateLocationButton();
    });

    document.addEventListener('DOMContentLoaded', () => {
      updateLocationButton();
    });

    updateLocationButton();
  })();
</script>

