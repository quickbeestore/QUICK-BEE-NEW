    var CATEGORIES = [
      { label: '🥤 Drinks',    q: 'Cold Drinks'     },
      { label: '🍜 Noodles',   q: 'Instant Noodles' },
      { label: '🍎 Fruits',    q: 'Fresh Fruits'    },
      { label: '🛒 Snacks',    q: 'Chips & Snacks'  },
      { label: '🍺 Beer',      q: 'Domestic Beer'   },
      { label: '🍼 Baby',      q: 'Baby Care'       },
      { label: '🥚 Eggs',      q: 'Eggs'            },
      { label: '🥛 Dairy',     q: 'Milk Dairy'      },
    ];

    var TRENDS = [
      { label: 'Cold Drinks',     icon: '🥤', sub: 'Trending now'       },
      { label: 'Instant Noodles', icon: '🍜', sub: 'Quick meals'        },
      { label: 'Chips & Snacks',  icon: '🍟', sub: 'Late night cravings' },
      { label: 'Fresh Fruits',    icon: '🍎', sub: 'Seasonal picks'      },
      { label: 'Domestic Beer',   icon: '🍺', sub: 'Evening favourites'  },
      { label: 'Baby Care',       icon: '🍼', sub: 'Essential needs'     },
    ];

    var RECENT_KEY  = 'qb_recent_searches';
    var FREQ_KEY    = 'qb_frequent_searches';

    if (!form || !input || !dropdown || !inner) return;

    var debounce = null;
    var isOpen   = false;

    /* ── localStorage helpers ──── */
    function getRecent() {
      try { return JSON.parse(localStorage.getItem(RECENT_KEY) || '[]'); } catch(e) { return []; }
    }
    function getFrequent() {
      try { return JSON.parse(localStorage.getItem(FREQ_KEY) || '{}'); } catch(e) { return {}; }
    }
    function getTopFrequent(n) {
      var freq = getFrequent();
      return Object.keys(freq).sort(function(a,b){ return freq[b]-freq[a]; }).slice(0, n||4);
    }
    function addRecent(q) {
      if (!q || q.length < 2) return;
      try {
        /* Recent list */
        var list = getRecent().filter(function(x){ return x.toLowerCase() !== q.toLowerCase(); });
        list.unshift(q);
        localStorage.setItem(RECENT_KEY, JSON.stringify(list.slice(0, 8)));
        /* Frequency map */
        var freq = getFrequent();
        freq[q] = (freq[q] || 0) + 1;
        localStorage.setItem(FREQ_KEY, JSON.stringify(freq));
        /* Push into cart note */
        syncSearchNote();
      } catch(e) {}
    }
    function removeRecent(q) {
      try {
        var list = getRecent().filter(function(x){ return x !== q; });
        localStorage.setItem(RECENT_KEY, JSON.stringify(list));
      } catch(e) {}
    }
    /* ── push search data into cart note ──── */
    function syncSearchNote() {
      try {
        var recent = getRecent().slice(0,5).join(', ') || 'None';
        var top    = getTopFrequent(3).join(', ') || 'None';
        /* Read existing note then append search block */
        fetch('/cart.js').then(function(r){ return r.json(); }).then(function(cart){
          var base = (cart.note || '').replace(/\n🔍[\s\S]*$/, '');
          var note = base + '\n🔍 Recent Searches: ' + recent + '\n📊 Top Searches: ' + top;
          fetch('/cart/update.js',{method:'POST',headers:{'Content-Type':'application/json'},
            body:JSON.stringify({note:note.trim()})}).catch(function(){});
        }).catch(function(){});
      } catch(e) {}
    }

    /* ── escape ──── */
    function esc(s) {
      return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ── show / hide ──── */
    function show() {
      var rect = form.getBoundingClientRect();
      dropdown.style.top = rect.bottom + 'px';
      dropdown.style.display = 'block';
      if (backdrop) {
        backdrop.style.top = rect.bottom + 'px';
        backdrop.classList.add('open');
      }
      isOpen = true;
    }
    function hide() {
      dropdown.style.display = 'none';
      if (backdrop) backdrop.classList.remove('open');
      isOpen = false;
    }

    /* ── render helpers ──── */
    function catChips() {
      return '<div class="qb-sdrop-chips">'
        + CATEGORIES.map(function(c){
            return '<button type="button" class="qb-sdrop-chip" data-query="' + esc(c.q) + '">' + c.label + '</button>';
          }).join('')
        + '</div>';
    }

    function recentBlock() {
      var list = getRecent();
      if (!list.length) return '';
      return '<div class="qb-sdrop-label">Recent</div>'
        + '<div class="qb-sdrop-items" id="qbRecentList">'
        + list.map(function(q){
            return '<div class="qb-sdrop-recent-row" data-recent="' + esc(q) + '">'
              + '<span class="qb-sdrop-recent-ico">🕐</span>'
              + '<span class="qb-sdrop-recent-txt">' + esc(q) + '</span>'
              + '<button type="button" class="qb-sdrop-recent-del" data-del="' + esc(q) + '" aria-label="Remove">✕</button>'
              + '</div>';
          }).join('')
        + '</div><div class="qb-sdrop-divider"></div>';
    }

    /* ── render states ──── */
    function renderHome() {
      var topFreq = getTopFrequent(4);
      var freqBlock = '';
      if (topFreq.length) {
        freqBlock = '<div class="qb-sdrop-label">⚡ You Often Search</div>'
          + '<div class="qb-sdrop-chips" style="margin-bottom:6px;">'
          + topFreq.map(function(q){
              return '<button type="button" class="qb-sdrop-chip" style="border-color:rgba(244,180,0,0.3);background:rgba(244,180,0,0.07);color:#c98a00;" data-query="' + esc(q) + '">🔁 ' + esc(q) + '</button>';
            }).join('')
          + '</div>';
      }
      inner.innerHTML = catChips()
        + recentBlock()
        + freqBlock
        + '<div class="qb-sdrop-label">🔥 Popular Right Now</div>'
        + '<div class="qb-sdrop-items">'
        + TRENDS.map(function(t){
            return '<button type="button" class="qb-sdrop-item" data-query="' + esc(t.label) + '">'
              + '<div class="qb-sdrop-ico">' + t.icon + '</div>'
              + '<div class="qb-sdrop-body">'
                + '<div class="qb-sdrop-name">' + esc(t.label) + '</div>'
                + '<div class="qb-sdrop-sub">' + esc(t.sub) + '</div>'
              + '</div>'
              + '</button>';
          }).join('')
        + '</div>';
    }

    function renderLoading() {
      var skels = '';
      for (var i = 0; i < 4; i++) {
        skels += '<div class="qb-sdrop-skeleton">'
          + '<div class="qb-sdrop-sk-ico"></div>'
          + '<div class="qb-sdrop-sk-body">'
            + '<div class="qb-sdrop-sk-line w80"></div>'
            + '<div class="qb-sdrop-sk-line w50"></div>'
          + '</div></div>';
      }
      inner.innerHTML = catChips() + '<div class="qb-sdrop-label">Searching…</div>' + skels;
    }

    function renderResults(query, products) {
      var html = catChips();
      html += '<div class="qb-sdrop-label">Results for "' + esc(query) + '"</div>';
      html += '<div class="qb-sdrop-items">';

      products.slice(0, 6).forEach(function(p) {
        var imgEl = p.featured_image
          ? '<img class="qb-sdrop-img" src="' + esc(p.featured_image) + '" loading="lazy" alt="">'
          : '<div class="qb-sdrop-img-placeholder">🛍️</div>';
        var priceEl = p.price
          ? '<span class="qb-sdrop-price">Rs ' + Math.round(p.price / 100) + '</span>'
          : '';
        html += '<a href="' + esc(p.url) + '" class="qb-sdrop-item" data-product-query="' + esc(query) + '">'
          + imgEl
          + '<div class="qb-sdrop-body"><div class="qb-sdrop-name">' + esc(p.title) + '</div></div>'
          + priceEl
          + '</a>';
      });

      html += '<button type="button" class="qb-sdrop-seeall" data-query="' + esc(query) + '">'
        + '<span style="font-size:18px;">🔍</span>'
        + '<span>See all results for <strong>' + esc(query) + '</strong></span>'
        + '</button>';
      html += '</div>';
      inner.innerHTML = html;
    }

    function renderNoResults(query) {
      inner.innerHTML = catChips()
        + '<div class="qb-sdrop-empty">'
        + '<div class="qb-sdrop-empty-ico">🔍</div>'
        + '<div class="qb-sdrop-empty-txt">No results for "' + esc(query) + '"</div>'
        + '<div class="qb-sdrop-empty-sub">Try a different keyword or browse categories</div>'
        + '</div>'
        + '<div class="qb-sdrop-label">🔥 Popular</div>'
        + '<div class="qb-sdrop-items">'
        + TRENDS.slice(0,3).map(function(t){
            return '<button type="button" class="qb-sdrop-item" data-query="' + esc(t.label) + '">'
              + '<div class="qb-sdrop-ico">' + t.icon + '</div>'
              + '<div class="qb-sdrop-body"><div class="qb-sdrop-name">' + esc(t.label) + '</div></div>'
              + '</button>';
          }).join('')
        + '</div>';
    }

    /* ── fetch Shopify predictive search ──── */
    async function fetchProducts(query) {
      try {
        var url = '/search/suggest.json?q=' + encodeURIComponent(query)
          + '&resources[type]=product&resources[limit]=6'
          + '&resources[fields]=title,url,price,featured_image';
        var res  = await fetch(url);
        var data = await res.json();
        return (data && data.resources && data.resources.results && data.resources.results.products) || [];
      } catch(e) { return []; }
    }

    /* ── on input ──── */
    function handleInput() {
      var query = input.value.trim();
      if (!query || query.length < 2) { renderHome(); show(); return; }
      renderLoading(); show();
      clearTimeout(debounce);
      debounce = setTimeout(async function() {
        if (input.value.trim() !== query) return;
        var products = await fetchProducts(query);
        if (input.value.trim() !== query) return;
        if (products.length > 0) { renderResults(query, products); }
        else { renderNoResults(query); }
      }, 260);
    }

    /* ── delegate clicks inside dropdown ──── */
    inner.addEventListener('click', function(e) {
      /* Category chip */
      var chip = e.target.closest('[data-query].qb-sdrop-chip');
      if (chip) { input.value = chip.getAttribute('data-query'); hide(); form.submit(); return; }

      /* Trend / result item */
      var item = e.target.closest('[data-query].qb-sdrop-item, [data-query].qb-sdrop-seeall');
      if (item) {
        var q = item.getAttribute('data-query');
        if (q) { addRecent(q); input.value = q; hide(); form.submit(); }
        return;
      }

      /* Product result link */
      var pLink = e.target.closest('a.qb-sdrop-item[data-product-query]');
      if (pLink) {
        var pq = pLink.getAttribute('data-product-query');
        if (pq) addRecent(pq);
        hide();
        return;
      }

      /* Recent row click */
      var recentRow = e.target.closest('[data-recent]');
      if (recentRow && !e.target.closest('[data-del]')) {
        var rq = recentRow.getAttribute('data-recent');
        if (rq) { input.value = rq; hide(); form.submit(); }
        return;
      }

      /* Delete recent */
      var delBtn = e.target.closest('[data-del]');
      if (delBtn) {
        e.stopPropagation();
        var dq = delBtn.getAttribute('data-del');
        removeRecent(dq);
        var row = inner.querySelector('[data-recent="' + CSS.escape(dq) + '"]');
        if (row) row.remove();
        return;
      }
    });

    /* ── form submit: save recent ──── */
    form.addEventListener('submit', function() {
      var q = input.value.trim();
      if (q) addRecent(q);
    });

    /* ── focus / input events ──── */
    input.addEventListener('focus', function() {
      if (input.value.trim()) { handleInput(); } else { renderHome(); show(); }
    });
    input.addEventListener('input', handleInput);
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { hide(); input.blur(); }
    });

    /* ── close on outside click / backdrop tap ──── */
    document.addEventListener('click', function(e) {
      if (!form.contains(e.target) && !dropdown.contains(e.target)) hide();
    });
    if (backdrop) backdrop.addEventListener('click', function() { hide(); input.blur(); });

    /* ── reposition on scroll / resize ──── */
    function reposition() {
      if (isOpen) {
        var rect = form.getBoundingClientRect();
        dropdown.style.top = rect.bottom + 'px';
        if (backdrop) backdrop.style.top = rect.bottom + 'px';
      }
    }
    window.addEventListener('scroll', reposition, { passive: true });
    window.addEventListener('resize', reposition, { passive: true });
  })();
</script>
