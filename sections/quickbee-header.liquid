    width: 4px;
  }
  .qb-loc-tabs {
    display: flex;
    border-top: 1px solid #f0f0f0;
    background: #fafafa;
  }
  .qb-loc-tab {
    flex: 1;
    padding: 10px 14px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    color: #999;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }
  .qb-loc-tab:hover { color: #666; }
  .qb-loc-tab.active {
    color: var(--qb-text-dark);
    border-bottom-color: var(--qb-yellow);
  }
  .qb-loc-tab-content { display: none; }
  .qb-loc-tab-content:not([hidden]) { display: block; }
  .qb-loc-save-btn {
    flex: 1;
    min-width: 80px;
    padding: 8px 10px;
    border: 1.5px solid #e0e0e0;
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    color: #222;
    transition: all 0.2s;
  }
  .qb-loc-save-btn:hover {
    border-color: var(--qb-yellow);
    background: #fffbe6;
  }
  .qb-loc-results {
    list-style: none;
    max-height: 300px;
    overflow-y: auto;
    padding: 4px 0;
    min-height: 50px;
    display: block !important;
    visibility: visible !important;
  }
  .qb-loc-saved-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid #f0f0f0;
    cursor: pointer;
    transition: background 0.1s;
  }
  .qb-loc-saved-item:hover { background: #f9f9f9; }
  .qb-loc-saved-info { flex: 1; }
  .qb-loc-saved-label { font-size: 13px; font-weight: 600; color: #222; }
  .qb-loc-saved-address { font-size: 11px; color: #888; margin-top: 2px; }
  .qb-loc-saved-delete {
    background: none;
    border: none;
    color: #ccc;
    cursor: pointer;
    font-size: 16px;
    padding: 4px;
  }
  .qb-loc-saved-delete:hover { color: #ef4444; }
  .qb-loc-result-item {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 10px 14px; cursor: pointer; transition: background 0.1s;
  }
  .qb-loc-result-item:hover,
  .qb-loc-result-item.focused { background: #fffbe6; }
  .qb-loc-result-item svg { flex-shrink: 0; margin-top: 2px; }
  .qb-loc-result-main { font-size: 13px; font-weight: 600; color: #222; line-height: 1.3; }
  .qb-loc-result-sub  { font-size: 11px; color: #888; margin-top: 1px; line-height: 1.3; }
  .qb-loc-loading, .qb-loc-empty {
    padding: 16px 14px; font-size: 13px; color: #aaa; text-align: center;
  }
  .qb-loc-spinner {
    display: inline-block; width: 13px; height: 13px;
    border: 2px solid var(--qb-yellow); border-top-color: transparent;
