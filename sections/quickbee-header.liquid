{% schema %}
{
  "name": "QuickBee Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text_1",
      "label": "Announcement Text 1",
      "default": "⚡ Free Delivery on orders above Rs 1000!"
    },
    {
      "type": "text",
      "id": "announcement_text_2",
      "label": "Announcement Text 2",
      "default": "🕒 Anything delivered in ~20 minutes"
    },
    {
      "type": "text",
      "id": "announcement_text_3",
      "label": "Announcement Text 3",
      "default": "🎁 Spin the wheel for exclusive deals!"
    }
  ]
}
{% endschema %}

<style>
  /* ── Header Base ── */
  :root {
    --qb-header-bg: var(--theme-bg-primary);
    --qb-header-border: var(--theme-border);
    --qb-text-main: var(--theme-text-main);
    --qb-text-muted: var(--theme-text-muted);
    --qb-header-surface: var(--theme-bg-secondary);
    --qb-yellow: #F4B400;
  }

  .qb-header {
    background: var(--qb-header-bg);
    border-bottom: 1px solid var(--qb-header-border);
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
  }

  .qb-header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    gap: 16px;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ── Search Bar UI Overhaul ── */
  .qb-search-container {
    flex: 1;
    max-width: 560px;
    position: relative;
  }

  .qb-search-bar-wrap {
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    background: var(--qb-header-surface);
    border: 1px solid rgba(17, 24, 39, 0.08);
    border-radius: 999px;
    height: 44px;
    padding: 0 16px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease, background-color 0.3s ease;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
    animation: qb-search-float 4.8s ease-in-out infinite;
  }

  [data-theme="dark"] .qb-search-bar-wrap {
    background: rgba(24, 24, 27, 0.96);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 10px 24px rgba(0,0,0,0.28);
  }

  .qb-search-bar-wrap:focus-within {
    transform: translateY(0);
    animation-play-state: paused;
    background: var(--qb-header-bg);
    border-color: rgba(244, 180, 0, 0.55);
    box-shadow: 0 0 0 3px rgba(244, 180, 0, 0.16), 0 14px 28px rgba(15, 23, 42, 0.12);
  }

  [data-theme="dark"] .qb-search-bar-wrap:focus-within {
    box-shadow: 0 0 0 3px rgba(244, 180, 0, 0.2), 0 16px 30px rgba(0,0,0,0.34);
  }

  .qb-search-bar-wrap:hover {
    animation-play-state: paused;
    transform: translateY(-1px);
  }

  .qb-search-bar-wrap svg {
    color: #6B7280;
    margin-right: 10px;
    flex-shrink: 0;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .qb-search-bar-wrap:hover svg,
  .qb-search-bar-wrap:focus-within svg {
    color: var(--qb-text-main);
    transform: scale(1.03);
  }

  .qb-search-input {
    flex: 1;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    border: none;
    outline: none;
    box-shadow: none;
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    color: var(--qb-text-main);
    width: 100%;
    padding: 0;
    min-width: 0;
  }

  .qb-search-input::placeholder {
    color: #94A3B8;
    opacity: 1;
    transition: color 0.25s ease;
  }

  [data-theme="dark"] .qb-search-input::placeholder {
    color: rgba(226, 232, 240, 0.62);
  }

  .qb-search-input:focus::placeholder {
    color: rgba(148, 163, 184, 0.72);
  }

  .qb-search-input::-webkit-search-decoration,
  .qb-search-input::-webkit-search-cancel-button,
  .qb-search-input::-webkit-search-results-button,
  .qb-search-input::-webkit-search-results-decoration {
    -webkit-appearance: none;
    appearance: none;
    display: none;
  }

  @keyframes qb-search-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .qb-search-bar-wrap {
      animation: none;
    }
  }

  /* ── Floating Predictive Dropdown ── */
  .qb-search-dropdown {
    position: fixed;
    z-index: 999999;
    background: var(--qb-header-bg);
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.15);
    margin-top: 12px;
    overflow: hidden;
    display: none;
    animation: qb-dropdown-slide 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  [data-theme="dark"] .qb-search-dropdown {
    box-shadow: 0 10px 50px rgba(0,0,0,0.5);
  }

  @keyframes qb-dropdown-slide {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .qb-dropdown-header {
    padding: 16px 20px 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .qb-dropdown-title {
    font-size: 11px;
    font-weight: 800;
    color: #9CA3AF;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .qb-dropdown-item {
    padding: 12px 20px;
    display: flex;
    align-items: center;
    cursor: pointer;
    transition: all 0.2s ease;
    border-bottom: 1px solid #F9FAFB;
    color: var(--qb-text-main);
  }

  [data-theme="dark"] .qb-dropdown-item {
    border-bottom-color: #2A2A2A;
  }

  .qb-dropdown-item:hover {
    background-color: var(--qb-header-surface);
    padding-left: 26px;
  }

  [data-theme="dark"] .qb-dropdown-item:hover {
    background-color: #2A2A2A;
  }

  /* ── Location Button ── */
  .qb-loc-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: 1px solid var(--qb-header-border);
    border-radius: 999px;
    padding: 8px 16px;
    cursor: pointer;
    max-width: 240px;
    transition: all 0.2s;
  }

  .qb-loc-btn:hover {
    background: rgba(244, 180, 0, 0.05);
    border-color: var(--qb-yellow);
  }

  .qb-loc-content {
    text-align: left;
    overflow: hidden;
  }

  .qb-loc-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--qb-text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .qb-loc-address {
    font-size: 11px;
    color: var(--qb-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Announcement Bar ── */
  .qb-announcement {
    height: 32px;
    background: #000;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .qb-announcement-track {
    display: flex;
    white-space: nowrap;
    animation: qb-ann-scroll 30s linear infinite;
  }

  .qb-announcement-track span {
    padding: 0 40px;
    color: #FFF;
    font-size: 12px;
    font-weight: 600;
  }

  @keyframes qb-ann-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .qb-header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .qb-action-btn,
  .qb-theme-toggle {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--qb-text-main);
    background: transparent;
    border: 1px solid var(--qb-header-border);
    border-radius: 999px;
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    cursor: pointer;
  }

  .qb-action-btn:hover,
  .qb-theme-toggle:hover {
    background: color-mix(in srgb, var(--qb-yellow) 10%, transparent);
    border-color: var(--qb-yellow);
    transform: translateY(-1px);
  }

  .qb-action-btn svg,
  .qb-theme-toggle svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
  }

  /* ── Mobile Footer ── */
  .qb-mobile-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--qb-header-bg);
    height: 65px;
    display: flex;
    align-items: center;
    justify-content: space-around;
    z-index: 9999;
    box-shadow: 0 -4px 15px rgba(0,0,0,0.05);
    border-top: 1px solid #EEE;
  }

  [data-theme="dark"] .qb-mobile-footer {
    background: #121212;
    border-top-color: #333;
  }

  .qb-mobile-footer-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: #9CA3AF;
    text-decoration: none;
    font-size: 10px;
    font-weight: 700;
    flex: 1;
  }

  .qb-mobile-footer-item.active {
    color: var(--qb-yellow);
  }

  .qb-mobile-footer-item svg {
    width: 24px;
    height: 24px;
  }

  .qb-mobile-wallet-btn {
    width: 52px;
    height: 52px;
    background: var(--qb-yellow);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: #000;
    margin-top: -30px;
    box-shadow: 0 4px 15px rgba(244, 180, 0, 0.4);
    border: 4px solid var(--qb-header-bg);
  }

  [data-theme="dark"] .qb-mobile-wallet-btn {
    border-color: #121212;
  }

  /* ── Mobile Optimization ── */
  @media (max-width: 768px) {
    .qb-header-top {
      padding: 8px 12px;
      gap: 10px;
    }
    .qb-loc-btn {
      padding: 6px 12px;
      max-width: 140px;
    }
    .qb-search-bar-wrap {
      height: 40px;
      padding: 0 14px;
    }
    .qb-search-input {
      font-size: 13px;
    }
  }
</style>

<!-- Announcement Bar -->
<div class="qb-announcement">
  <div class="qb-announcement-track">
    <span>{{ section.settings.announcement_text_1 }}</span>
    <span>{{ section.settings.announcement_text_2 }}</span>
    <span>{{ section.settings.announcement_text_3 }}</span>
    <span>{{ section.settings.announcement_text_1 }}</span>
    <span>{{ section.settings.announcement_text_2 }}</span>
    <span>{{ section.settings.announcement_text_3 }}</span>
  </div>
</div>

<header class="qb-header">
  <div class="qb-header-top">
    <!-- Location -->
    <div class="qb-location-wrap">
      <button class="qb-loc-btn" onclick="qbOpenLocationModal()">
        <div class="qb-loc-content">
          <div class="qb-loc-title" id="qbLocTitle">Set location</div>
          <div class="qb-loc-address" id="qbLocAddress"></div>
        </div>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </div>

    <!-- Search -->
    <div class="qb-search-container">
      <form action="/search" method="get" class="qb-search-bar-wrap">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="search" name="q" class="qb-search-input" id="qbSearchInput" placeholder="Search products..." autocomplete="off">
      </form>

      <!-- Dropdown -->
      <div id="qbSearchDropdown" class="qb-search-dropdown">
        <div class="qb-dropdown-header">
          <span class="qb-dropdown-title">Recent Searches</span>
        </div>
        <div id="qbDropdownItems"></div>
      </div>
    </div>

    <div class="qb-header-actions">
      <button
        id="theme-toggle"
        class="theme-toggle-btn qb-theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
      >
        <svg
          class="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg
          class="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 3a6 6 0 0 0 9 9A9 9 0 1 1 12 3z"></path>
        </svg>
      </button>

      <!-- Cart -->
      <a href="/cart" class="qb-action-btn" aria-label="Cart">
        <div style="position: relative; padding: 8px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span id="cart-count" style="position: absolute; top: 0; right: 0; background: var(--qb-yellow); color: #000; font-size: 10px; font-weight: 800; border-radius: 50%; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; border: 2px solid var(--qb-header-bg);">{{ cart.item_count }}</span>
        </div>
      </a>
    </div>
  </div>
</header>

<!-- Mobile Nav -->
<div class="qb-mobile-footer">
  <a href="/" class="qb-mobile-footer-item active">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <span>Home</span>
  </a>
  <a href="/collections" class="qb-mobile-footer-item">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="18" r="3"/></svg>
    <span>Categories</span>
  </a>
  <a href="/pages/flash-deals" class="qb-mobile-wallet-btn">⚡</a>
  <a href="/pages/services" class="qb-mobile-footer-item">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 12c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2z"/><path d="M13 4c0-1.1.9-2 2-2s2 .9 2 2-.9 2-2 2-2-.9-2-2z"/><path d="M18 9h2c1.1 0 2 .9 2 2v2c0 1.1-.9 2-2 2h-2"/><path d="M4 9H2c-1.1 0-2 .9-2 2v2c0 1.1.9 2 2 2h2"/><path d="M12 17v3m-3-3c0-1.66 1.34-3 3-3s3 1.34 3 3"/><path d="M9 22h6c1.1 0 2 .9 2 2s-.9 2-2 2H9c-1.1 0-2-.9-2-2s.9-2 2-2z"/></svg>
    <span>Services</span>
  </a>
  <a href="/account" class="qb-mobile-footer-item">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
    <span>Account</span>
  </a>
</div>

<script>
  // Dropdown Logic
  (function() {
    const input = document.getElementById('qbSearchInput');
    const dropdown = document.getElementById('qbSearchDropdown');
    const items = document.getElementById('qbDropdownItems');
    const trends = ["Dairy Products", "Fresh Vegetables", "Snacks & Sweets", "Beverages"];

    function show() {
      items.innerHTML = trends.map(t => `<div class="qb-dropdown-item"><span>🔥 ${t}</span></div>`).join('');
      const rect = input.getBoundingClientRect();
      dropdown.style.display = 'block';
      dropdown.style.top = rect.bottom + 12 + 'px';
      dropdown.style.left = rect.left + 'px';
      dropdown.style.width = rect.width + 'px';
    }

    input.addEventListener('focus', show);
    document.addEventListener('click', (e) => {
      if (!input.contains(e.target) && !dropdown.contains(e.target)) dropdown.style.display = 'none';
    });
  })();
</script>
