    box-shadow: 0 4px 12px rgba(245, 197, 24, 0.4), 0 0 8px rgba(245, 197, 24, 0.2);
    animation: sweet-bounce 0.6s ease-in-out infinite;
    border: 2px solid #fff;
  }

  /* ── Navigation ── */
  .qb-nav {
    background: #fff;
    border-bottom: 2px solid #f5f5f5;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 2px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .qb-nav::-webkit-scrollbar { display: none; }
  .qb-nav-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 13px 14px;
    font-size: 13px;
    font-weight: 700;
    color: var(--qb-nav-color);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
    transition: border-color 0.2s, color 0.2s;
    font-family: 'Segoe UI', Arial, sans-serif;
  }
  .qb-nav-item:hover,
  .qb-nav-item.active {
    border-bottom-color: var(--qb-yellow);
    color: var(--qb-text-dark);
  }
  .qb-nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }

  /* ── Sticky Mobile Footer with Light Theme & Premium Design ── */
  .qb-mobile-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #fff !important;
    border-top: 1px solid #e8e8e8;
    display: flex !important;
    flex-direction: row;
    align-items: center;
    justify-content: space-around;
    z-index: 9998;
    box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
    width: 100%;
    height: 65px;
  }

  .qb-mobile-footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      repeating-linear-gradient(90deg, transparent, transparent 35px, rgba(220, 38, 38, 0.02) 35px, rgba(220, 38, 38, 0.02) 70px),
      repeating-linear-gradient(60deg, transparent, transparent 25px, rgba(220, 38, 38, 0.02) 25px, rgba(220, 38, 38, 0.02) 50px),
      repeating-linear-gradient(120deg, transparent, transparent 25px, rgba(220, 38, 38, 0.02) 25px, rgba(220, 38, 38, 0.02) 50px);
    pointer-events: none;
    animation: qb-gradient-pulse 20s ease-in-out infinite;
  }

  @keyframes qb-gradient-pulse {
    0%, 100% { opacity: 0.02; }
    50% { opacity: 0.04; }
  }

  .qb-mobile-footer-nav {
    display: flex;
    align-items: center;
    justify-content: space-evenly;
    height: 65px;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    z-index: 1;
    width: 100%;
    gap: 2px;
  }

  .qb-mobile-footer-nav li {
    flex: 1;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 55px;
  }

  /* Side Navigation Items Container */
  .qb-mobile-nav-side {
    display: flex;
    flex-direction: row;
    gap: 0;
    flex: 0 0 auto;
    height: 100%;
    align-items: center;
    justify-content: center;
  }

  .qb-mobile-footer-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    text-decoration: none;
    color: #374151;
    font-size: 11px;
    font-weight: 700;
    font-family: 'Segoe UI', Arial, sans-serif;
    cursor: pointer;
    border: none;
    background: transparent;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    padding: 8px 12px;
    border-radius: 12px;
    width: 100%;
    height: 100%;
    letter-spacing: 0.2px;
    text-align: center;
    flex: 1;
    max-width: 70px;
  }

  .qb-mobile-footer-item::before {
    content: '';
    position: absolute;
    inset: 2px;
    background: radial-gradient(circle at center, rgba(220, 38, 38, 0.1) 0%, transparent 70%);
    border-radius: 12px;
    opacity: 0;
    transition: all 0.3s ease;
    pointer-events: none;
    border: 1.5px solid rgba(220, 38, 38, 0);
  }

  .qb-mobile-footer-item:hover::before,
  .qb-mobile-footer-item:active::before,
  .qb-mobile-footer-item.active::before {
    opacity: 1;
    background: linear-gradient(135deg, rgba(220, 38, 38, 0.12) 0%, rgba(245, 197, 24, 0.08) 100%);
    border: 1.5px solid rgba(220, 38, 38, 0.3);
  }

  .qb-mobile-footer-item:hover,
  .qb-mobile-footer-item:active,
  .qb-mobile-footer-item.active {
    color: #dc2626;
    transform: translateY(-2px);
  }

  .qb-mobile-footer-item:active svg,
  .qb-mobile-footer-item.active svg,
  .qb-mobile-footer-item:hover svg {
    color: #dc2626;
    transform: scale(1.2) translateY(-2px);
    filter: drop-shadow(0 0 8px rgba(220, 38, 38, 0.4));
  }

  .qb-mobile-footer-item svg {
    width: 26px;
    height: 26px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    color: #374151;
  }

  .qb-mobile-footer-item img.qb-footer-icon {
    width: 40px;
    height: 40px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    object-fit: contain;
  }

  .qb-mobile-footer-item:hover img.qb-footer-icon,
  .qb-mobile-footer-item:active img.qb-footer-icon,
  .qb-mobile-footer-item.active img.qb-footer-icon {
    transform: scale(1.2) translateY(-2px);
    filter: drop-shadow(0 0 8px rgba(220, 38, 38, 0.4));
  }

  .qb-mobile-footer-item span {
    position: relative;
    z-index: 1;
    letter-spacing: 0.1px;
    line-height: 1.2;
    white-space: nowrap;
    font-weight: 600;
  }

  /* Center Wallet Button - Light Theme Premium */
  .qb-mobile-wallet-btn {
    position: relative;
    flex: 0 0 auto;
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #FFB800 0%, #F4B400 50%, #E8A500 100%);
    border: none;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow:
      0 4px 12px rgba(244, 180, 0, 0.3),
      inset 0 1px 4px rgba(255, 255, 255, 0.4);
    z-index: 100;
    margin: 0 2px;
    pointer-events: auto !important;
    user-select: none;
    -webkit-user-select: none;
  }

  .qb-mobile-wallet-btn:active {
    transform: scale(0.93);
  }

  .qb-mobile-wallet-btn:hover {
    transform: scale(1.08);
    box-shadow:
      0 6px 16px rgba(244, 180, 0, 0.4),
      inset 0 1px 4px rgba(255, 255, 255, 0.5);
  }

  .qb-mobile-wallet-btn::before {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.6) 0%, transparent 60%);
    pointer-events: none;
  }

  .qb-mobile-wallet-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    animation: qb-wallet-pulse 2s ease-in-out infinite;
  }

  @keyframes qb-wallet-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(244, 180, 0, 0.4);
    }
    50% {
      box-shadow: 0 0 0 3px rgba(244, 180, 0, 0.15);
    }
  }

  .qb-chat-badge {
    position: absolute !important;
    top: -8px !important;
    right: -8px !important;
    background: #e74c3c !important;
    color: #fff !important;
    border-radius: 50% !important;
    width: 20px !important;
    height: 20px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 11px !important;
    font-weight: 800 !important;
    animation: qb-badge-bounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) infinite !important;
    box-shadow: 0 4px 12px rgba(231, 76, 60, 0.4) !important;
  }

  @keyframes qb-badge-bounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }

  body.has-mobile-footer {
  }

  /* ── Global Bee Theme Effects ── */
  @keyframes bee-flight {
    0% { transform: translateX(0) translateY(0) rotate(0deg); }
    25% { transform: translateX(20px) translateY(-10px) rotate(-5deg); }
    50% { transform: translateX(0) translateY(-20px) rotate(0deg); }
    75% { transform: translateX(-20px) translateY(-10px) rotate(5deg); }
    100% { transform: translateX(0) translateY(0) rotate(0deg); }
  }

  @keyframes honey-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245, 197, 24, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(245, 197, 24, 0); }
  }

  @keyframes honeycomb-flicker {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 1; }
  }

  @keyframes sweet-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  /* Global hover glow effect for interactive elements */
  button, a, input[type="submit"], [role="button"] {
    position: relative;
  }

  button:hover::after,
  a:hover::after,
  input[type="submit"]:hover::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(245, 197, 24, 0.1) 0%, transparent 70%);
    border-radius: inherit;
    pointer-events: none;
    animation: honey-glow 1.5s infinite;
  }

  /* Honeycomb pattern background for special sections */
  .honeycomb-bg {
    background-image:
      repeating-linear-gradient(90deg, transparent, transparent 35px, rgba(245, 197, 24, 0.02) 35px, rgba(245, 197, 24, 0.02) 70px),
      repeating-linear-gradient(60deg, transparent, transparent 20px, rgba(245, 197, 24, 0.02) 20px, rgba(245, 197, 24, 0.02) 40px),
      repeating-linear-gradient(120deg, transparent, transparent 20px, rgba(245, 197, 24, 0.02) 20px, rgba(245, 197, 24, 0.02) 40px);
