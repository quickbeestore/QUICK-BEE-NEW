// Update timer
window.qbUpdateTimerDisplay = function() {
  const data = JSON.parse(localStorage.getItem(window.QB_WHEEL_CONFIG.storageKey) || '{}');
  const timerDisplay = document.getElementById('qbTimerDisplay');
  const timerReadyMsg = document.getElementById('qbTimerReadyMsg');
  const spinBtn = document.getElementById('qbSpinBtn');
  const cooldownMsg = document.getElementById('qbCooldownMsg');

  if (!data.lastSpinTime) {
    timerDisplay.textContent = '∞';
    timerDisplay.classList.remove('ready');
    timerReadyMsg.style.display = 'none';
    spinBtn.disabled = false;
    cooldownMsg.style.display = 'none';
    return;
  }

  const remaining = (data.lastSpinTime + window.QB_WHEEL_CONFIG.cooldownMs) - Date.now();

  if (remaining <= 0) {
    timerDisplay.textContent = '∞';
    timerDisplay.classList.add('ready');
    timerReadyMsg.style.display = 'block';
    spinBtn.disabled = false;
    cooldownMsg.style.display = 'none';
    return;
  }

  const h = Math.floor(remaining / 3600000);
  const m = Math.floor((remaining % 3600000) / 60000);
  const s = Math.floor((remaining % 60000) / 1000);

  timerDisplay.textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  timerDisplay.classList.remove('ready');
  timerReadyMsg.style.display = 'none';
  spinBtn.disabled = true;
  cooldownMsg.style.display = 'block';
  cooldownMsg.innerHTML = `⏳ <strong>Come back in ${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}</strong>`;
};

// Spin wheel
window.qbSpinTheWheel = function() {
  if (window.QB_WHEEL_STATE.isSpinning) return;

  const data = JSON.parse(localStorage.getItem(window.QB_WHEEL_CONFIG.storageKey) || '{}');
  if (data.lastSpinTime && Date.now() < data.lastSpinTime + window.QB_WHEEL_CONFIG.cooldownMs) {
    alert('Already spun today! Come back later.');
    return;
  }

  window.QB_WHEEL_STATE.isSpinning = true;
  const wheel = document.getElementById('qbWheelMain');
  const spinBtn = document.getElementById('qbSpinBtn');
  const overlay = document.getElementById('qbWheelOverlay');
  spinBtn.disabled = true;

  // Show the wheel overlay
  if (overlay) {
    overlay.classList.add('show');
  }

  // Play drum roll sound - continues until result arrives
  window.qbPlayDrumRoll();

  const spins = 15 + Math.random() * 5;
  const extraDegrees = Math.random() * 360;
  const totalRotation = spins * 360 + extraDegrees;

  wheel.classList.add('spinning');
  wheel.style.transform = `rotate(${totalRotation}deg)`;

  const prizeIndex = Math.floor((360 - (extraDegrees % 360)) % 360 / (360 / window.QB_WHEEL_CONFIG.prizes.length));
  const prize = window.QB_WHEEL_CONFIG.prizes[prizeIndex];

  setTimeout(() => {
    wheel.classList.remove('spinning');

    // Lock the pointer on the winning prize
    const pointer = document.querySelector('.qb-wheel-pointer');
    if (pointer) {
      pointer.classList.add('locked');
    }

    const newData = {
      lastSpinTime: Date.now(),
      lastPrize: prize,
      totalSpins: (data.totalSpins || 0) + 1
    };
    localStorage.setItem(window.QB_WHEEL_CONFIG.storageKey, JSON.stringify(newData));

    window.qbShowResult(prize);
    window.QB_WHEEL_STATE.isSpinning = false;
    window.qbUpdateTimerDisplay();
  }, 16000);
};

