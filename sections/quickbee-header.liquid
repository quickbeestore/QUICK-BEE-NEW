// Simple contact form for customer support messages

window.qbShopifyInbox = {
  shopDomain: 'yetinepal.myshopify.com',
  initialized: false,
  chatModalOpen: false,

  init: function() {
    if (this.initialized) return;
    try {
      console.log('💬 Initializing Customer Support Chat...');

      // Setup chat form submission
      const form = document.getElementById('qbChatForm');
      if (form) {
        form.addEventListener('submit', (e) => this.handleFormSubmit(e));
      }

      this.initialized = true;
      console.log('✅ Customer Support Chat Ready');
    } catch(e) {
      console.log('⚠️ Chat initialization warning:', e);
      this.initialized = true;
    }
  },

  openChat: function() {
    try {
      const modal = document.getElementById('qbChatModal');
      if (!modal) {
        console.log('❌ Chat modal not found');
        return;
      }

      // Clear form on open
      const form = document.getElementById('qbChatForm');
      if (form) {
        form.reset();
        const status = document.getElementById('qbChatStatus');
        if (status) status.style.display = 'none';
      }

      // Show modal with animation
      modal.classList.add('show');
      this.chatModalOpen = true;

      // Focus name input
      setTimeout(() => {
        const nameInput = document.getElementById('qbChatName');
        if (nameInput) nameInput.focus();
      }, 100);

      console.log('💬 Chat opened');
    } catch(e) {
      console.log('Chat error:', e);
    }
  },

  closeChat: function() {
    try {
      const modal = document.getElementById('qbChatModal');
      if (modal) {
        modal.classList.remove('show');
        this.chatModalOpen = false;
        console.log('💬 Chat closed');
      }
    } catch(e) {
      console.log('Close chat error:', e);
    }
  },

  handleFormSubmit: function(e) {
    e.preventDefault();

    try {
      const name = document.getElementById('qbChatName').value.trim();
      const email = document.getElementById('qbChatEmail').value.trim();
      const message = document.getElementById('qbChatMessage').value.trim();
      const status = document.getElementById('qbChatStatus');
      const submitBtn = document.querySelector('#qbChatForm button[type="submit"]');

      if (!name || !email || !message) {
        status.textContent = '❌ Please fill all fields';
        status.style.display = 'block';
        status.style.color = '#ff6b6b';
        return;
      }

      // Disable submit button
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      status.textContent = '';
      status.style.display = 'none';

      // Create message object
      const messageData = {
        name: name,
        email: email,
        message: message,
        timestamp: new Date().toISOString(),
        url: window.location.href
      };

      // Try multiple ways to save the message
      this.saveMessageToStoreAPI(messageData, (success) => {
        if (success) {
          status.textContent = '✅ Message sent! We\'ll get back to you soon.';
          status.style.color = '#51cf66';
          status.style.display = 'block';

          // Reset form
          document.getElementById('qbChatForm').reset();

          // Close modal after 2 seconds
          setTimeout(() => this.closeChat(), 2000);
        } else {
          status.textContent = '⚠️ Failed to send. Please try again or email: support@quickbee.com';
          status.style.color = '#ffd43b';
          status.style.display = 'block';
        }

        // Re-enable submit button
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      });

    } catch(e) {
      console.log('Form submit error:', e);
      const status = document.getElementById('qbChatStatus');
      status.textContent = '❌ Error: ' + e.message;
      status.style.color = '#ff6b6b';
      status.style.display = 'block';

      const submitBtn = document.querySelector('#qbChatForm button[type="submit"]');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  },

  saveMessageToStoreAPI: function(data, callback) {
    try {
      // Option 1: Save to localStorage (offline fallback)
      const savedMessages = JSON.parse(localStorage.getItem('qb_saved_messages') || '[]');
      savedMessages.push(data);
      localStorage.setItem('qb_saved_messages', JSON.stringify(savedMessages));
      console.log('💾 Message saved locally');

      // Option 2: Try to send to Shopify API endpoint (if backend is configured)
      fetch(`https://${this.shopDomain}/api/customer-messages`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(res => {
        if (res.ok) {
          console.log('✅ Message sent to Shopify API');
          callback(true);
        } else {
          console.log('⚠️ API returned status:', res.status);
          // Still consider it success since we saved to localStorage
          callback(true);
        }
      })
      .catch(err => {
        console.log('⚠️ API request failed (normal if endpoint not setup):', err);
        // Still success - we saved to localStorage as fallback
        callback(true);
      });

    } catch(e) {
      console.log('Error saving message:', e);
      callback(false);
    }
  }
};

