{% schema %}
{
  "name": "QuickBee Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text_1",
      "label": "Announcement Text 1",
      "default": "⚡ Free Delivery on orders above Rs 1000!"
    },
    {
      "type": "text",
      "id": "announcement_text_2",
      "label": "Announcement Text 2",
      "default": "🕒 Anything delivered in ~20 minutes"
    },
    {
      "type": "text",
      "id": "announcement_text_3",
      "label": "Announcement Text 3",
      "default": "🎁 Spin the wheel for exclusive deals!"
    }
  ]
}
{% endschema %}

<style>
  /* ── Header Base ── */
  :root {
    --qb-header-bg: var(--theme-bg-primary);
    --qb-header-border: var(--theme-border);
    --qb-text-main: var(--theme-text-main);
    --qb-text-muted: var(--theme-text-muted);
    --qb-header-surface: var(--theme-bg-secondary);
    --qb-yellow: #F4B400;
  }

  .qb-header {
    background: var(--qb-header-bg);
    border-bottom: 2px solid rgba(244,180,0,0.18);
    position: relative;
    z-index: 5000;
    width: 100%;
    max-width: 100%;
    margin: 0;
    overflow: visible !important;
  }

  /* Light mode header gets a subtle warm tint */
  html:not([data-theme="dark"]) .qb-header {
    background: #fafaf8;
    border-bottom-color: rgba(244,180,0,0.25);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .qb-header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    gap: 16px;
    max-width: 100%;
    width: 100%;
    margin: 0;
    overflow: visible !important;
  }

  @media (min-width: 1024px) {
    .qb-header-top {
      max-width: 1400px;
      margin: 0 auto;
    }
  }

  /* ── Search Bar UI Overhaul ── */
  .qb-search-container {
    flex: 1;
    max-width: 100%;
    position: relative;
    overflow: visible !important;
  }

  @media (min-width: 768px) {
    .qb-search-container {
      max-width: 680px;
    }
  }

  /* ── Search bar: clean pill, no heavy decorations ── */
  .qb-search-bar-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 48px;
    padding: 0 16px 0 10px;
    background: #efefef;
    border: 1.5px solid transparent;
    border-radius: 999px;
    transition: background 0.15s, border-color 0.15s;
  }

  /* light mode focused */
  .qb-search-bar-wrap:focus-within {
    background: #fff;
    border-color: rgba(244,180,0,0.55);
  }

  /* dark mode */
  [data-theme="dark"] .qb-search-bar-wrap {
    background: #1e1e1e;
    border-color: rgba(255,255,255,0.08);
  }
  [data-theme="dark"] .qb-search-bar-wrap:focus-within {
    background: #242424;
    border-color: rgba(244,180,0,0.5);
    box-shadow: 0 0 0 3px rgba(244,180,0,0.08);
  }

  /* Search icon — plain icon, zero box/bg */
  .qb-search-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent !important;
    background-color: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    color: #888;
    flex-shrink: 0;
    border-radius: 0 !important;
    -webkit-appearance: none !important;
    appearance: none !important;
  }
  [data-theme="dark"] .qb-search-icon {
    background: transparent !important;
    background-color: transparent !important;
    border: none !important;
    box-shadow: none !important;
    color: rgba(255,255,255,0.4) !important;
  }
  .qb-search-icon svg {
    width: 18px;
    height: 18px;
    display: block;
  }

  .qb-search-bar-wrap > input.qb-search-input {
    all: unset;
    display: block;
    width: 100%;
    min-width: 0;
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    color: #111;
    caret-color: #F4B400;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    appearance: none !important;
    -webkit-appearance: none !important;
    -webkit-box-shadow: none !important;
    -webkit-text-fill-color: currentColor !important;
  }

  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input {
    color: #FFF8EB;
    -webkit-text-fill-color: #FFF8EB !important;
  }

  .qb-search-bar-wrap > input.qb-search-input::placeholder {
    color: #94a3b8;
    opacity: 1;
    transition: color 0.25s ease;
    font-weight: 500;
  }

  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input::placeholder {
    color: rgba(255, 237, 213, 0.45);
  }

  .qb-search-bar-wrap > input.qb-search-input:focus::placeholder {
    color: rgba(148, 163, 184, 0.55);
  }

  .qb-search-bar-wrap > input.qb-search-input,
  .qb-search-bar-wrap > input.qb-search-input:hover,
  .qb-search-bar-wrap > input.qb-search-input:focus,
  .qb-search-bar-wrap > input.qb-search-input:focus-visible,
  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input,
  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input:hover,
  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input:focus,
  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input:focus-visible {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    -webkit-box-shadow: none !important;
  }

  .qb-search-bar-wrap > input.qb-search-input::-webkit-search-decoration,
  .qb-search-bar-wrap > input.qb-search-input::-webkit-search-cancel-button,
  .qb-search-bar-wrap > input.qb-search-input::-webkit-search-results-button,
  .qb-search-bar-wrap > input.qb-search-input::-webkit-search-results-decoration {
    -webkit-appearance: none;
    appearance: none;
    display: none;
  }

  /* ── Kill Chrome autofill dark background (light mode) ── */
  .qb-search-bar-wrap > input.qb-search-input:-webkit-autofill,
  .qb-search-bar-wrap > input.qb-search-input:-webkit-autofill:hover,
  .qb-search-bar-wrap > input.qb-search-input:-webkit-autofill:focus,
  .qb-search-bar-wrap > input.qb-search-input:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 1000px #efefef inset !important;
    box-shadow: 0 0 0 1000px #efefef inset !important;
    -webkit-text-fill-color: #111 !important;
    transition: background-color 9999s ease-in-out 0s;
    caret-color: #F4B400;
  }
  .qb-search-bar-wrap:focus-within > input.qb-search-input:-webkit-autofill,
  .qb-search-bar-wrap:focus-within > input.qb-search-input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px #ffffff inset !important;
    box-shadow: 0 0 0 1000px #ffffff inset !important;
    -webkit-text-fill-color: #111 !important;
  }

  /* ── Kill Chrome autofill dark background (dark mode) ── */
  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input:-webkit-autofill,
  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input:-webkit-autofill:hover,
  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input:-webkit-autofill:focus,
  [data-theme="dark"] .qb-search-bar-wrap > input.qb-search-input:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 1000px #1e1e1e inset !important;
    box-shadow: 0 0 0 1000px #1e1e1e inset !important;
    -webkit-text-fill-color: #FFF8EB !important;
    transition: background-color 9999s ease-in-out 0s;
  }
  [data-theme="dark"] .qb-search-bar-wrap:focus-within > input.qb-search-input:-webkit-autofill,
  [data-theme="dark"] .qb-search-bar-wrap:focus-within > input.qb-search-input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px #242424 inset !important;
    box-shadow: 0 0 0 1000px #242424 inset !important;
    -webkit-text-fill-color: #FFF8EB !important;
  }

  /* ── Search Backdrop ── */
  .qb-search-backdrop {
    display: none;
    position: fixed;
    top: 0; /* overridden by JS to sit below header */
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 99990;
    background: rgba(0,0,0,0.30);
    animation: qbBdIn .18s ease;
  }
  @keyframes qbBdIn { from{opacity:0} to{opacity:1} }
  .qb-search-backdrop.open { display: block; }

  /* ── Main Dropdown Panel ── */
  .qb-search-dropdown {
    position: fixed;
    top: 0; /* overridden by JS */
    left: 0;
    width: 100%;
    z-index: 99999;
    display: none;
    overflow: hidden;
    animation: qbDropIn .22s cubic-bezier(0.16,1,0.3,1);

    /* Light mode */
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.07);
    border-top: none;
    border-radius: 0 0 20px 20px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12), 0 4px 16px rgba(0,0,0,0.06);
  }
  @keyframes qbDropIn {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0);   }
  }

  /* Desktop: constrain to search container width */
  @media (min-width: 768px) {
    .qb-search-dropdown {
      width: min(600px, 96vw) !important;
      left: 50% !important;
      transform: translateX(-50%);
      border-radius: 0 0 20px 20px;
    }
  }

  /* Dark mode dropdown */
  [data-theme="dark"] .qb-search-dropdown {
    background: #111111;
    border-color: rgba(255,255,255,0.07);
    box-shadow: 0 24px 80px rgba(0,0,0,0.85), 0 4px 20px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  /* Inner scroll area */
  .qb-sdrop-inner {
    max-height: 50vh;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    padding: 4px 12px 16px;
    scrollbar-width: none;
  }
  .qb-sdrop-inner::-webkit-scrollbar { display: none; }

  /* ── Section label ── */
  .qb-sdrop-label {
    font-size: 10.5px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: #94a3b8;
    padding: 12px 2px 7px;
  }
  [data-theme="dark"] .qb-sdrop-label {
    color: rgba(255,220,140,0.55);
  }

  /* ── Quick Category Chips (horizontal scroll) ── */
  .qb-sdrop-chips {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding: 0 2px 2px;
    scrollbar-width: none;
    margin-bottom: 4px;
  }
  .qb-sdrop-chips::-webkit-scrollbar { display: none; }
  .qb-sdrop-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: 50px;
    border: 1.5px solid rgba(0,0,0,0.09);
    background: #f8f9fa;
    color: #1e293b;
    font-size: 12.5px;
    font-weight: 700;
    white-space: nowrap;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: all .15s;
    flex-shrink: 0;
    font-family: inherit;
  }
  .qb-sdrop-chip:active { transform: scale(.95); }
  [data-theme="dark"] .qb-sdrop-chip {
    border-color: rgba(255,255,255,0.09);
    background: #1e1e1e;
    color: #e8e8e8;
  }
  [data-theme="dark"] .qb-sdrop-chip:hover,
  [data-theme="dark"] .qb-sdrop-chip:active {
    border-color: rgba(244,180,0,0.45);
    background: rgba(244,180,0,0.1);
    color: #F4B400;
  }
  /* Frequent search chips in dark mode */
  [data-theme="dark"] .qb-sdrop-chip[style*="rgba(244,180,0"] {
    border-color: rgba(244,180,0,0.25) !important;
    background: rgba(244,180,0,0.08) !important;
    color: #F4B400 !important;
  }

  /* ── Result Items ── */
  .qb-sdrop-items {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .qb-sdrop-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 14px;
    border-radius: 15px;
    border: 1.5px solid transparent;
    background: transparent;
    color: inherit;
    font: inherit;
    text-align: left;
    width: 100%;
    cursor: pointer;
    text-decoration: none;
    transition: background .15s, border-color .15s;
    -webkit-tap-highlight-color: transparent;
    position: relative;
  }
  .qb-sdrop-item:active,
  .qb-sdrop-item:hover {
    background: rgba(244,180,0,0.07);
    border-color: rgba(244,180,0,0.22);
  }
  [data-theme="dark"] .qb-sdrop-item:active,
  [data-theme="dark"] .qb-sdrop-item:hover {
    background: rgba(244,180,0,0.09);
    border-color: rgba(244,180,0,0.3);
  }

  /* Trend item: icon pill */
  .qb-sdrop-ico {
    width: 40px;
    height: 40px;
    border-radius: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 19px;
    flex-shrink: 0;
    background: rgba(244,180,0,0.10);
  }
  [data-theme="dark"] .qb-sdrop-ico {
    background: rgba(244,180,0,0.12);
  }

  /* Product image pill */
  .qb-sdrop-img {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    object-fit: contain;
    background: #fff;
    flex-shrink: 0;
    border: 1px solid rgba(0,0,0,0.07);
  }
  [data-theme="dark"] .qb-sdrop-img {
    background: #222;
    border-color: rgba(255,255,255,0.08);
  }
  .qb-sdrop-img-placeholder {
    width: 40px; height: 40px;
    border-radius: 12px;
    background: rgba(244,180,0,0.10);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .qb-sdrop-body { flex: 1; min-width: 0; }
  .qb-sdrop-name {
    font-size: 13.5px;
    font-weight: 700;
    color: #0f172a;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-bottom: 2px;
  }
  [data-theme="dark"] .qb-sdrop-name { color: #f0f0f0; }
  .qb-sdrop-sub {
    font-size: 11.5px;
    color: #64748b;
  }
  [data-theme="dark"] .qb-sdrop-sub { color: #666; }

  .qb-sdrop-price {
    font-size: 13px;
    font-weight: 900;
    color: #F4B400;
    background: rgba(244,180,0,0.10);
    padding: 4px 9px;
    border-radius: 9px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  [data-theme="dark"] .qb-sdrop-price {
    background: rgba(244,180,0,0.13);
  }

  /* Recent searches */
  .qb-sdrop-recent-row {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    border-radius: 14px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: background .14s;
  }
  .qb-sdrop-recent-row:hover { background: rgba(0,0,0,0.03); }
  [data-theme="dark"] .qb-sdrop-recent-row:hover { background: rgba(255,255,255,0.04); }
  .qb-sdrop-recent-ico { font-size: 14px; color: #94a3b8; flex-shrink:0; }
  .qb-sdrop-recent-txt { flex:1; font-size:13px; font-weight:600; color:#334155; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  [data-theme="dark"] .qb-sdrop-recent-txt { color:#bbb; }
  .qb-sdrop-recent-del { font-size:16px; color:#94a3b8; padding: 2px 4px; }

  /* See all row */
  .qb-sdrop-seeall {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 15px;
    border: 1.5px dashed rgba(244,180,0,0.3);
    background: rgba(244,180,0,0.04);
    color: #F4B400;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    text-decoration: none;
    margin-top: 4px;
    width: 100%;
    font-family: inherit;
    -webkit-tap-highlight-color: transparent;
    transition: background .15s, border-color .15s;
  }
  .qb-sdrop-seeall:hover { background: rgba(244,180,0,0.10); border-color: rgba(244,180,0,0.5); }

  /* Loading skeletons */
  .qb-sdrop-skeleton {
    display: flex; align-items: center; gap: 12px;
    padding: 11px 14px;
  }
  .qb-sdrop-sk-ico { width:40px; height:40px; border-radius:13px; flex-shrink:0; }
  .qb-sdrop-sk-body { flex:1; display:flex; flex-direction:column; gap:7px; }
  .qb-sdrop-sk-line { height:11px; border-radius:6px; }
  .qb-sdrop-sk-line.w80 { width:80%; }
  .qb-sdrop-sk-line.w50 { width:50%; }
  @keyframes qbSkPulse {
    0%,100%{ opacity:.35 } 50%{ opacity:.65 }
  }
  .qb-sdrop-sk-ico,
  .qb-sdrop-sk-line {
    background: #e2e8f0;
    animation: qbSkPulse 1.4s ease infinite;
  }
  [data-theme="dark"] .qb-sdrop-sk-ico,
  [data-theme="dark"] .qb-sdrop-sk-line {
    background: #2a2a2a;
  }

  /* No results */
  .qb-sdrop-empty {
    text-align: center; padding: 28px 20px;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .qb-sdrop-empty-ico { font-size: 36px; }
  .qb-sdrop-empty-txt { font-size: 14px; font-weight: 700; color: #334155; }
  [data-theme="dark"] .qb-sdrop-empty-txt { color: #aaa; }
  .qb-sdrop-empty-sub { font-size: 12px; color: #64748b; }
  [data-theme="dark"] .qb-sdrop-empty-sub { color: #555; }

  /* Divider */
  .qb-sdrop-divider {
    height: 1px;
    background: rgba(0,0,0,0.06);
    margin: 4px 0;
  }
  [data-theme="dark"] .qb-sdrop-divider {
    background: rgba(255,255,255,0.06);
  }

  /* ── Location Button ── */
  .qb-loc-btn {
    display: inline-grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 12px;
    background: #f1f5f9;
    border: 2px solid #e2e8f0;
    border-radius: 999px;
    padding: 10px 18px;
    cursor: pointer;
    max-width: 280px;
    min-height: 52px;
    box-shadow: inset 0 1px 3px rgba(15, 23, 42, 0.05);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
  }

  .qb-loc-btn:hover {
    background: #e8edf4;
    border-color: rgba(244, 180, 0, 0.7);
    box-shadow: 0 0 0 3px rgba(244, 180, 0, 0.12);
    transform: translateY(-1px);
  }

  .qb-loc-btn:focus-visible {
    outline: none;
    border-color: rgba(244, 180, 0, 0.88);
    box-shadow: 0 0 0 4px rgba(244, 180, 0, 0.18), 0 12px 24px rgba(15, 23, 42, 0.1);
  }

  .qb-loc-content {
    min-width: 0;
    text-align: center;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .qb-loc-title {
    font-size: 15px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--qb-text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .qb-loc-address {
    font-size: 12px;
    line-height: 1.2;
    color: var(--qb-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .qb-loc-address:empty {
    display: none;
  }

  .qb-loc-btn[data-has-address="false"] {
    padding-block: 13px;
  }

  .qb-loc-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--qb-text-main);
    opacity: 0.82;
  }

  [data-theme="dark"] .qb-loc-btn {
    background: #1a1a1a;
    border-color: rgba(255,255,255,0.07);
    box-shadow: none;
  }

  [data-theme="dark"] .qb-loc-btn:hover {
    background: #222;
    border-color: rgba(244, 180, 0, 0.4);
    box-shadow: none;
  }

  [data-theme="dark"] .qb-loc-btn:focus-visible {
    border-color: rgba(244, 180, 0, 0.5);
    outline: none;
  }

  [data-theme="dark"] .qb-loc-title {
    color: #f8fafc;
  }

  [data-theme="dark"] .qb-loc-address {
    color: rgba(226, 232, 240, 0.78);
  }

  [data-theme="dark"] .qb-loc-btn svg {
    color: #f8fafc;
    opacity: 0.88;
  }

  /* ── Announcement Bar ── */
  .qb-announcement {
    height: 32px;
    background: #000;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .qb-announcement-track {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    min-width: max-content;
    white-space: nowrap;
    will-change: transform;
    animation: qb-ann-scroll 24s linear infinite;
  }

  .qb-announcement-group {
