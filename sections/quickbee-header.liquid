<script>
// Ensure DOM is ready before initializing
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initLocationPicker);
} else {
  initLocationPicker();
}

function initLocationPicker() {
  try {
    var wrap    = document.getElementById('qbLocationWrap');
    var btn     = document.getElementById('qbLocBtn');
    var modal   = document.getElementById('qbLocationModal');
    var modalOverlay = document.getElementById('qbModalOverlay');
    var modalClose = document.getElementById('qbModalClose');
    var modalCancel = document.getElementById('qbModalCancel');
    var modalConfirm = document.getElementById('qbLocationOkBtnModal');
    var breadcrumb = document.getElementById('qbBreadcrumb');
    var progressFill = document.getElementById('qbProgressFill');
    var titleEl = document.getElementById('qbLocTitle');
    var addressEl = document.getElementById('qbLocAddress');

    // Debug logging
    console.log('🐝 QB Location Picker Init START', {
      btn: !!btn,
      modal: !!modal,
      modalClose: !!modalClose,
      modalCancel: !!modalCancel
    });

  // Fallback: search for modal if not found by ID
  if (!modal) {
    modal = document.querySelector('.qb-location-modal');
    console.log('Modal found via class selector:', !!modal);
  }

  // Fallback: search for button if not found by ID
  if (!btn) {
    btn = document.querySelector('.qb-loc-btn');
    console.log('Button found via class selector:', !!btn);
  }

  if (!btn || !modal) {
    console.error('QB Location Picker: Missing required elements after fallback', {
      btn: !!btn,
      modal: !!modal
    });
    return;
  }

  // Hierarchical modal elements
  var districtSelect = document.getElementById('qbDistrictSelectModal');
  var municipalitySelect = document.getElementById('qbMunicipalitySelectModal');
  var areaSelect = document.getElementById('qbAreaSelectModal');
  var subAreaSelect = document.getElementById('qbSubAreaSelectModal');
  var currentLocationData = null;
  var deliveryTimeDisplay = document.getElementById('qbDeliveryTimeModal');
  var deliveryTimeValue = document.getElementById('qbDeliveryTimeValueModal');

  // Address management
  var currentSelectedPlace = null;
  var savedAddresses = [];
  var allowedCities = ['Kathmandu', 'Bhaktapur', 'Lalitpur'];
  var currentDeliveryTime = 22;
  var areasData = window.QB_AREAS_DATA;

  // Generate random delivery time between 18-32 minutes
  function getRandomDeliveryTime() {
    return Math.floor(Math.random() * (32 - 18 + 1)) + 18;
  }

  // Check if location is in service area
  function isLocationInServiceArea(address) {
    if (!address) return false;
    return allowedCities.some(function(city) {
      return address.toUpperCase().includes(city.toUpperCase());
    });
  }

  // Show service area error popup
  function showServiceAreaError() {
    var modal = document.createElement('div');
    modal.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:10000';
    modal.innerHTML = '<div style="background:#fff;border-radius:12px;padding:24px;max-width:320px;text-align:center;box-shadow:0 10px 40px rgba(0,0,0,0.2)">' +
      '<div style="font-size:16px;font-weight:700;color:#222;margin-bottom:12px">Service Area</div>' +
      '<p style="font-size:14px;color:#666;margin-bottom:16px;line-height:1.5">Currently we only operate in <strong>Kathmandu, Bhaktapur</strong> and <strong>Lalitpur</strong>. Please enter a location inside these areas.</p>' +
      '<button style="background:#f5c518;border:none;padding:10px 24px;border-radius:6px;font-weight:600;cursor:pointer;font-size:14px;color:#222;width:100%;transition:background 0.2s" onclick="this.closest(\'div\').parentElement.remove()">OK, Got it</button>' +
      '</div>';
    document.body.appendChild(modal);
  }

  // Load saved addresses
  function loadSavedAddresses() {
    try {
      var saved = localStorage.getItem('qb_saved_addresses');
      savedAddresses = saved ? JSON.parse(saved) : [];
      updateSavedAddressesCount();
      renderSavedAddresses();
    } catch (e) {
      savedAddresses = [];
    }
  }

  function updateSavedAddressesCount() {
    var tab = Array.from(document.querySelectorAll('.qb-loc-tab')).find(function (t) {
      return t.textContent.includes('Saved');
    });
    if (tab) tab.textContent = 'Saved (' + savedAddresses.length + ')';
  }

  function saveSavedAddresses() {
    try {
      localStorage.setItem('qb_saved_addresses', JSON.stringify(savedAddresses));
    } catch (e) {}
  }

  // Restore current location
  try {
    var savedLoc = localStorage.getItem('qb_location_detail');
    if (savedLoc) {
      var locData = JSON.parse(savedLoc);
      updateLocationDisplay(locData);
      window.QB_LOCATION = locData; // expose to window for checkout
    }
  } catch (e) {}

  // Update location display (title and address)
  function updateLocationDisplay(locData) {
    if (titleEl && addressEl) {
      currentDeliveryTime = locData.deliveryTime || getRandomDeliveryTime();
      titleEl.textContent = 'Delivery in ' + currentDeliveryTime + ' mins';
      // Show location name with delivery time
      addressEl.textContent = (locData.name || 'Select Location') + ' (' + currentDeliveryTime + ' mins)';
    }
  }

  // Tab switching for saved addresses
  var tabs = document.querySelectorAll('.qb-loc-tab');
  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      var tabName = tab.getAttribute('data-tab');
      var content = Array.from(document.querySelectorAll('.qb-loc-tab-content')).find(function (c) {
        return c.getAttribute('data-tab') === tabName;
      });
      if (content) {
        // Toggle or show
        var isVisible = !content.hidden;
        document.querySelectorAll('.qb-loc-tab-content').forEach(function (c) { c.hidden = true; });
        content.hidden = isVisible;
        tab.classList.toggle('active', !isVisible);
      }
    });
  });

  loadSavedAddresses();

  // Modal open/close functions
  function openModal() {
    modal.removeAttribute('hidden');
    modal.style.cssText = 'display: flex !important; visibility: visible !important; opacity: 1 !important; pointer-events: auto !important; z-index: 10000 !important; position: fixed !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; align-items: center !important; justify-content: center !important;';

    // Clear opacity and pointerEvents from all children
    var allChildren = modal.querySelectorAll('*');
    allChildren.forEach(function(child) {
      child.style.opacity = '1';
      child.style.pointerEvents = 'auto';
      child.style.visibility = 'visible';
    });

    btn.setAttribute('aria-expanded', 'true');
    // Reset selects when opening
    districtSelect.value = '';
    municipalitySelect.innerHTML = '<option value="">Select Municipality</option>';
    areaSelect.innerHTML = '<option value="">Select Area</option>';
    subAreaSelect.innerHTML = '<option value="">Select Sub-Area</option>';
    updateBreadcrumb(0);
    updateProgressBar(0);
    deliveryTimeDisplay.hidden = true;
    modalConfirm.hidden = true;
  }

  function closeModal() {
    modal.setAttribute('hidden', '');
    modal.style.cssText = 'display: none !important; visibility: hidden !important; opacity: 0 !important; pointer-events: none !important; z-index: -9999 !important;';

    // Hide all children
    var allChildren = modal.querySelectorAll('*');
    allChildren.forEach(function(child) {
      child.style.opacity = '0';
      child.style.pointerEvents = 'none';
      child.style.visibility = 'hidden';
    });

    btn.setAttribute('aria-expanded', 'false');
  }

  function updateBreadcrumb(level) {
    var items = breadcrumb.querySelectorAll('.qb-breadcrumb-item');
    items.forEach(function(item, index) {
      item.classList.toggle('active', index <= level);
    });
  }

  function updateProgressBar(level) {
    var percentage = (level + 1) * 25;
    progressFill.style.width = percentage + '%';
  }

  // Button click to open modal
  if (btn) {
    btn.addEventListener('click', function () {
      console.log('🐝 Location button clicked!');
      try {
        openModal();
        console.log('🐝 Modal opened successfully');
      } catch (e) {
        console.error('🐝 Error opening modal:', e);
      }
    });
    console.log('🐝 Click listener attached to location button');
  } else {
    console.error('🐝 Button not found - click listener not attached');
  }

  // Close button
  modalClose.addEventListener('click', function () {
    closeModal();
  });

  // Cancel button
  modalCancel.addEventListener('click', function () {
    closeModal();
  });

  // Overlay click to close modal
  modalOverlay.addEventListener('click', function () {
    closeModal();
  });

  // Populate districts on init
  if (areasData && areasData.districts) {
    areasData.districts.forEach(function(district) {
      var option = document.createElement('option');
      option.value = district.id;
      option.textContent = district.name;
      districtSelect.appendChild(option);
    });
  }

  // District change → populate municipalities
  districtSelect.addEventListener('change', function() {
    municipalitySelect.innerHTML = '<option value="">Select Municipality</option>';
    areaSelect.innerHTML = '<option value="">Select Area</option>';
    subAreaSelect.innerHTML = '<option value="">Select Sub-Area</option>';
    deliveryTimeDisplay.hidden = true;
    modalConfirm.hidden = true;
    updateBreadcrumb(0);
    updateProgressBar(0);

    if (!this.value) {
      municipalitySelect.disabled = true;
      areaSelect.disabled = true;
      subAreaSelect.disabled = true;
      return;
    }

    var district = areasData.districts.find(function(d) { return d.id === this.value; }.bind(this));
    if (district && district.municipalities) {
      district.municipalities.forEach(function(mun) {
        var option = document.createElement('option');
        option.value = mun.id;
        option.textContent = mun.name;
        municipalitySelect.appendChild(option);
      });
      municipalitySelect.disabled = false;
      updateBreadcrumb(0);
      updateProgressBar(0);
    }
  });

  // Municipality change → populate areas
  municipalitySelect.addEventListener('change', function() {
    areaSelect.innerHTML = '<option value="">Select Area</option>';
    subAreaSelect.innerHTML = '<option value="">Select Sub-Area</option>';
    deliveryTimeDisplay.hidden = true;
    modalConfirm.hidden = true;
    updateBreadcrumb(1);
    updateProgressBar(1);

    if (!this.value) {
      areaSelect.disabled = true;
      subAreaSelect.disabled = true;
      return;
    }

    var districtId = districtSelect.value;
    var district = areasData.districts.find(function(d) { return d.id === districtId; });
    var mun = district.municipalities.find(function(m) { return m.id === this.value; }.bind(this));

    if (mun && mun.areas) {
      mun.areas.forEach(function(area) {
        var option = document.createElement('option');
        option.value = area.id;
        option.textContent = area.name;
        areaSelect.appendChild(option);
      });
      areaSelect.disabled = false;
    }
  });

  // Area change → populate sub-areas
  areaSelect.addEventListener('change', function() {
    subAreaSelect.innerHTML = '<option value="">Select Sub-Area</option>';
    deliveryTimeDisplay.hidden = true;
    modalConfirm.hidden = true;
    updateBreadcrumb(2);
    updateProgressBar(2);

    if (!this.value) {
      subAreaSelect.disabled = true;
      return;
    }

    var districtId = districtSelect.value;
    var munId = municipalitySelect.value;
    var areaId = this.value;

    var district = areasData.districts.find(function(d) { return d.id === districtId; });
    var mun = district.municipalities.find(function(m) { return m.id === munId; });
    var area = mun.areas.find(function(a) { return a.id === areaId; });

    if (area && area.subAreas) {
      area.subAreas.forEach(function(subArea) {
        var option = document.createElement('option');
        option.value = subArea.id;
        option.textContent = subArea.name;
        subAreaSelect.appendChild(option);
      });
      subAreaSelect.disabled = false;
    }
  });

  // SubArea change → select location and show delivery time (final selection)
  subAreaSelect.addEventListener('change', function() {
    deliveryTimeDisplay.hidden = true;
    modalConfirm.hidden = true;
    updateBreadcrumb(3);
    updateProgressBar(3);

    if (!this.value) {
      return;
    }

    var districtId = districtSelect.value;
    var munId = municipalitySelect.value;
    var areaId = areaSelect.value;
    var subAreaId = this.value;

    var district = areasData.districts.find(function(d) { return d.id === districtId; });
    var mun = district.municipalities.find(function(m) { return m.id === munId; });
    var area = mun.areas.find(function(a) { return a.id === areaId; });
    var subArea = area.subAreas.find(function(s) { return s.id === subAreaId; });

    if (subArea) {
      var deliveryTime = subArea.deliveryTime || 20;
      currentDeliveryTime = deliveryTime;
      deliveryTimeValue.textContent = deliveryTime;
      deliveryTimeDisplay.hidden = false;
      modalConfirm.hidden = false;

      var fullPath = district.name + ' → ' + mun.name + ' → ' + area.name + ' → ' + subArea.name;
      currentLocationData = {
        district: district.name,
        municipality: mun.name,
        area: area.name,
        subArea: subArea.name,
        deliveryTime: deliveryTime
      };
    }
  });

  // Confirm button click handler
  modalConfirm.addEventListener('click', function() {
    if (!currentLocationData) return;
    closeModal();
    selectLocation({
      main: currentLocationData.subArea,
      full: currentLocationData.area + ' - ' + currentLocationData.subArea,
      locData: currentLocationData,
      deliveryTime: currentLocationData.deliveryTime
    });
  });

  function selectLocation(placeData) {
    // placeData can be a string (from GPS) or full object (from search)
    var name = typeof placeData === 'string' ? placeData : placeData.main;
    var fullAddress = typeof placeData === 'string' ? placeData : placeData.full;
    var lat = placeData.lat || null;
    var lon = placeData.lon || null;

    // Service area validation removed - accept all locations

    currentSelectedPlace = { name: name, address: fullAddress, lat: lat, lon: lon };

    // Update display
    updateLocationDisplay(currentSelectedPlace);

    // Save to current location
    try {
      var locObj = {
        name: name,
        address: fullAddress,
        lat: lat,
        lon: lon,
        deliveryTime: currentDeliveryTime,
        savedAt: new Date().toISOString()
      };

      // Add detailed location data (4 levels) if available
      if (placeData.locData) {
        locObj.locData = placeData.locData;
        // Create order note/message for Shopify
        locObj.orderNote = 'Delivery Location:\n' +
          'District: ' + placeData.locData.district + '\n' +
          'Municipality: ' + placeData.locData.municipality + '\n' +
          'Area: ' + placeData.locData.area + '\n' +
          'Estimated Delivery Time: ' + placeData.locData.deliveryTime + ' minutes';
      }

      localStorage.setItem('qb_location_detail', JSON.stringify(locObj));
      window.QB_LOCATION = locObj;

      // Update cart attributes with location data for Shopify orders
      if (placeData.locData) {
        try {
          fetch('/cart/update.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              attributes: {
                'delivery_district': placeData.locData.district,
                'delivery_municipality': placeData.locData.municipality,
                'delivery_area': placeData.locData.area,
                'delivery_subarea': placeData.locData.subArea,
                'delivery_time': placeData.locData.deliveryTime
              }
            })
          });
        } catch (e) { console.log('Cart attributes update failed'); }
      }

      // Dispatch location change event for weather widget
      window.dispatchEvent(new Event('qb_location_changed'));
    } catch (e) {}

    // Show save form
    var saveForm = document.getElementById('qbLocSaveForm');
    if (saveForm) saveForm.hidden = false;

    input.value = '';
    results.innerHTML = '';
    clearBtn.hidden = true;
    currentQuery = '';
  }

  // Save address button handlers
  var saveButtons = document.querySelectorAll('.qb-loc-save-btn');
  saveButtons.forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      if (!currentSelectedPlace) return;
      var lbl = btn.getAttribute('data-label');
      var addressObj = Object.assign({}, currentSelectedPlace, {
        label: lbl,
        id: Date.now(),
        savedAt: new Date().toISOString()
      });
      savedAddresses.push(addressObj);
      saveSavedAddresses();
      updateSavedAddressesCount();
      renderSavedAddresses();
      document.getElementById('qbLocSaveForm').hidden = true;
      currentSelectedPlace = null;
      btn.textContent = '✓ Saved!';
      setTimeout(function () { btn.textContent = lbl; }, 1500);
    });
  });

  console.log('🐝 QB Location Picker INITIALIZATION COMPLETE ✅');
  } catch (e) {
    console.error('🐝 QB Location Picker INITIALIZATION FAILED:', e);
    console.error('Error details:', e.message, e.stack);
  }

  // Render saved addresses
  function renderSavedAddresses() {
    var listContainer = document.getElementById('qbLocSavedList');
    if (!listContainer) return;
    if (savedAddresses.length === 0) {
      listContainer.innerHTML = '<div style="padding:16px 14px;text-align:center;color:#aaa;font-size:13px">No saved addresses yet</div>';
      return;
    }
    listContainer.innerHTML = '';
    savedAddresses.forEach(function (addr, idx) {
      var item = document.createElement('div');
      item.className = 'qb-loc-saved-item';
      item.innerHTML =
        '<div class="qb-loc-saved-info">' +
        '<div class="qb-loc-saved-label">' + esc(addr.label) + '</div>' +
        '<div class="qb-loc-saved-address">' + esc(addr.address.substring(0, 50)) + (addr.address.length > 50 ? '…' : '') + '</div>' +
        '</div>' +
        '<button type="button" class="qb-loc-saved-delete" title="Delete">✕</button>';

      item.querySelector('.qb-loc-saved-info').addEventListener('click', function () {
        // Service area validation removed - accept all locations

        // Update with new random delivery time
        updateLocationDisplay(addr);
        try {
          var updatedAddr = Object.assign({}, addr, { deliveryTime: currentDeliveryTime });
          localStorage.setItem('qb_location_detail', JSON.stringify(updatedAddr));
          window.QB_LOCATION = updatedAddr;

          // Dispatch location change event for weather widget
          window.dispatchEvent(new Event('qb_location_changed'));
        } catch (e) {}
        closeModal();
      });

      item.querySelector('.qb-loc-saved-delete').addEventListener('click', function (e) {
        e.stopPropagation();
        savedAddresses.splice(idx, 1);
        saveSavedAddresses();
        updateSavedAddressesCount();
        renderSavedAddresses();
      });

      listContainer.appendChild(item);
    });
  }

  function esc(s) {
    return String(s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
})();

