<script>
(function(){
  var p = window.location.pathname;
  var map = [
    { id: 'qb-fn-home',  match: function(p){ return p === '/'; } },
    { id: 'qb-fn-cats',  match: function(p){ return p.startsWith('/collections'); } },
    { id: 'qb-fn-svc',   match: function(p){ return p.startsWith('/pages/services'); } },
    { id: 'qb-fn-acct',  match: function(p){ return p.startsWith('/account'); } }
  ];
  map.forEach(function(item){
    var el = document.getElementById(item.id);
    if (el) el.classList.toggle('active', item.match(p));
  });
})();
</script>

<script>
  // Dropdown Logic
  (function() {
    const form = document.querySelector('.qb-search-bar-wrap');
    const input = document.getElementById('qbSearchInput');
    const dropdown = document.getElementById('qbSearchDropdown');
    const items = document.getElementById('qbDropdownItems');
    const trends = [
      { label: "Cold Drinks", icon: "🥤" },
      { label: "Instant Noodles", icon: "🍜" },
      { label: "Chips & Snacks", icon: "🛒" },
      { label: "Fresh Fruits", icon: "🍎" },
      { label: "Baby Care", icon: "🍼" },
      { label: "Domestic Beer", icon: "🍺" }
    ];

    if (!form || !input || !dropdown || !items) return;

    function renderSuggestions(query) {
      const normalized = query.trim().toLowerCase();
      const filtered = normalized
        ? trends.filter((item) => item.label.toLowerCase().includes(normalized))
        : trends;

      if (!filtered.length) {
        dropdown.style.display = 'none';
        return;
      }

      items.innerHTML = filtered
        .slice(0, 6)
        .map((item) => `
          <button type="button" class="qb-dropdown-item" data-query="${item.label}">
            <span class="qb-dropdown-item-icon" aria-hidden="true">${item.icon}</span>
            <span class="qb-dropdown-item-label">${item.label}</span>
          </button>
        `)
        .join('');
    }

    function show() {
      renderSuggestions(input.value);
      const rect = input.getBoundingClientRect();
      dropdown.style.display = 'block';
      dropdown.style.minWidth = rect.width + 'px';
    }

    function hide() {
      dropdown.style.display = 'none';
    }

    input.addEventListener('input', show);
    input.addEventListener('focus', show);
    input.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') hide();
    });

    items.addEventListener('click', (event) => {
      const item = event.target.closest('.qb-dropdown-item');
      if (!item) return;
      input.value = item.dataset.query || '';
      form.submit();
    });

    document.addEventListener('click', (e) => {
      if (!form.contains(e.target) && !dropdown.contains(e.target)) hide();
    });
  })();
</script>
