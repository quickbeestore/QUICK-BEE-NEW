<script>
  (function() {
    const input = document.getElementById('qbSearchInput');
    if (!input) return;

    const phrases = [
      'Search groceries in 20 mins',
      'Search cold drinks near you',
      'Search snacks for tonight',
      'Search fruits, noodles, beer'
    ];

    let phraseIndex = 0;
    let charIndex = 0;
    let typingTimer = null;
    let paused = false;

    function queueNext(delay) {
      window.clearTimeout(typingTimer);
      typingTimer = window.setTimeout(typeNextChar, delay);
    }

    function typeNextChar() {
      if (paused || document.activeElement === input || input.value) {
        queueNext(500);
        return;
      }

      const phrase = phrases[phraseIndex];
      charIndex += 1;
      input.placeholder = phrase.slice(0, charIndex);

      if (charIndex < phrase.length) {
        queueNext(42);
        return;
      }

      window.setTimeout(() => {
        if (paused || document.activeElement === input || input.value) {
          return;
        }
        phraseIndex = (phraseIndex + 1) % phrases.length;
        charIndex = 0;
        input.placeholder = '';
        queueNext(220);
      }, 1100);
    }

    input.addEventListener('focus', () => {
      paused = true;
      input.placeholder = '';
    });

    input.addEventListener('blur', () => {
      paused = false;
      if (!input.value) {
        charIndex = 0;
        input.placeholder = '';
        queueNext(120);
      }
    });

    input.addEventListener('input', () => {
      if (input.value) {
        window.clearTimeout(typingTimer);
        input.placeholder = '';
      } else if (document.activeElement !== input) {
        paused = false;
        charIndex = 0;
        queueNext(120);
      }
    });

    queueNext(180);
  })();

  (function() {
    const button = document.querySelector('.qb-loc-btn');
    const title = document.getElementById('qbLocTitle');
    const address = document.getElementById('qbLocAddress');

    if (!button || !title || !address) {
      return;
    }

    function readSavedLocation() {
      const keys = ['qb_location_detail', 'qb_selected_location'];
      for (const key of keys) {
        const raw = localStorage.getItem(key);
        if (!raw) {
          continue;
        }

        try {
          const parsed = JSON.parse(raw);
          if (parsed && typeof parsed === 'object') {
            return parsed;
          }
        } catch (error) {
          console.warn(`Unable to parse ${key}`, error);
        }
      }

      return null;
    }

    function pickTitle(location) {
      if (location?.mode === 'someone_else') {
        return location?.recipient_name || 'Order for someone else';
      }

      return (
        location?.label ||
        location?.name ||
        location?.street ||
        location?.address ||
        location?.city ||
        location?.area ||
        location?.district ||
        'Set location'
      );
    }

    function readDeliveryTime() {
      const raw = localStorage.getItem('qb_delivery_time');
      if (!raw) {
        return '';
      }

      try {
        const parsed = JSON.parse(raw);
        return parsed?.range || '';
      } catch (error) {
        console.warn('Unable to parse qb_delivery_time', error);
        return '';
      }
    }

    function pickSubtitle(location) {
      if (location?.mode === 'someone_else') {
        return location?.recipient_name || '';
      }

      const deliveryRange = readDeliveryTime();
      if (deliveryRange) {
        return `⚡ ${deliveryRange}`;
      }

      const parts = [
        location?.address,
        location?.formatted_address,
        location?.street,
        location?.ward,
        location?.locality,
        location?.city,
      ].filter(Boolean);

      return [...new Set(parts)].join(', ');
    }

    function updateLocationButton(detail) {
      const location = detail || readSavedLocation();
      const nextTitle = pickTitle(location);
      const nextAddress = location ? pickSubtitle(location) : readDeliveryTime();

      title.textContent = nextTitle;
      address.textContent = nextAddress;
      button.dataset.hasAddress = nextAddress ? 'true' : 'false';
      button.setAttribute('aria-label', nextAddress ? `${nextTitle}, ${nextAddress}` : nextTitle);
    }

    button.addEventListener('click', () => {
      if (typeof window.showLocationModal === 'function') {
        window.showLocationModal();
      }
    });

    window.addEventListener('locationSelected', (event) => {
      const location = event.detail;
      if (location) {
        try {
          // This is the fix: ensure the selection is saved to the key the cart page expects.
          localStorage.setItem('qb_selected_location', JSON.stringify(location));
        } catch (e) {
          console.error('Failed to save selected location to localStorage:', e);
        }
      }
      updateLocationButton(location);
    });

    window.addEventListener('qb_location_changed', () => {
      updateLocationButton();
    });

    document.addEventListener('DOMContentLoaded', () => {
      updateLocationButton();
    });

    updateLocationButton();

    // ── Silent location auto-refresh every 10–14 minutes ──────────────
    // Only fires when the browser has already granted geolocation permission.
    // No prompts, no UI changes unless the address actually changes.
    (function startLocationTimer(){
      var INTERVAL_MS = 12 * 60 * 1000; // 12 minutes
      var STALE_MS    =  9 * 60 * 1000; //  9 minutes — don't refresh if saved < 9 min ago

      function silentGeoRefresh(){
        // Check permission state first — never prompt the user
        if(!navigator || !navigator.geolocation){ return; }
        if(navigator.permissions && navigator.permissions.query){
          navigator.permissions.query({ name: 'geolocation' }).then(function(perm){
            if(perm.state === 'granted'){
              doRefresh();
            }
            // 'prompt' or 'denied' → do nothing
          }).catch(function(){
            doRefresh(); // Older browsers that don't support permission API
          });
        } else {
          doRefresh(); // Fallback for browsers without Permissions API
        }
      }

      function doRefresh(){
        // Don't hit GPS if location was saved very recently
        var saved = localStorage.getItem('qb_location_detail') || localStorage.getItem('qb_selected_location');
        if(saved){
          try{
            var obj = JSON.parse(saved);
            var ts = obj._timestamp || 0;
            if(ts && (Date.now() - ts) < STALE_MS){ return; }
          }catch(e){}
        }

        navigator.geolocation.getCurrentPosition(function(pos){
          var lat = pos.coords.latitude;
          var lng = pos.coords.longitude;
          // Reverse geocode via Nominatim (free, no API key)
          fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat=' + lat + '&lon=' + lng + '&zoom=16&addressdetails=1', {
            headers: { 'Accept-Language': 'en' }
          })
          .then(function(r){ return r.json(); })
          .then(function(data){
            var addr = data.address || {};
            var streetName = [addr.road, addr.quarter, addr.neighbourhood].filter(Boolean).join(', ');
            var locationObj = {
              type: 'self',
              mode: 'self',
              lat: lat,
              lng: lng,
              latitude: lat,
              longitude: lng,
              name: addr.suburb || addr.neighbourhood || addr.village || addr.town || addr.city || '',
              city: addr.city || addr.town || addr.village || '',
              district: addr.county || addr.state_district || '',
              ward: addr.suburb || addr.quarter || '',
              locality: addr.residential || addr.neighbourhood || '',
              formatted_address: data.display_name || '',
              street: streetName || addr.road || '',
              address: streetName || addr.road || addr.suburb || '',
              location: streetName || addr.suburb || addr.neighbourhood || addr.village || addr.city || '',
              _timestamp: Date.now(),
              _auto: true
            };
            try{
              localStorage.setItem('qb_location_detail', JSON.stringify(locationObj));
              localStorage.setItem('qb_selected_location', JSON.stringify(locationObj));
            }catch(e){}
            updateLocationButton(locationObj);
            window.dispatchEvent(new CustomEvent('locationSelected', { detail: locationObj }));
          })
          .catch(function(){}); // Silently fail — don't break anything
        },
        function(err){}, // Permission denied / unavailable — ignore
        { timeout: 8000, maximumAge: STALE_MS, enableHighAccuracy: false }
        );
      }

      // Start the recurring timer
      setInterval(silentGeoRefresh, INTERVAL_MS);
      // Also do one refresh 30 seconds after page load (warm start)
      setTimeout(silentGeoRefresh, 30000);
    })();
    // ── End auto-refresh ──────────────────────────────────────────────
  })();
</script>

