  .qb-loc-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 14px;
    color: #111 !important;
    font-family: 'Segoe UI', Arial, sans-serif;
    background: #fff !important;
    font-weight: 500;
    padding: 8px 12px !important;
    border-radius: 4px;
    min-height: 36px;
  }
  .qb-loc-input::placeholder {
    color: #333 !important;
    font-weight: 500;
    opacity: 1 !important;
  }
  .qb-loc-input:focus {
    color: #111 !important;
