  <div class="wls-trust-grid">
    <div class="wls-trust-item">
      <span class="wls-trust-icon">🔬</span>
      <div>
        <div class="wls-trust-name">Lab Certified</div>
        <div class="wls-trust-sub">Third-party tested for purity</div>
      </div>
    </div>
    <div class="wls-trust-item">
      <span class="wls-trust-icon">✅</span>
      <div>
        <div class="wls-trust-name">FSSAI Approved</div>
        <div class="wls-trust-sub">Meets India's safety standards</div>
      </div>
    </div>
    <div class="wls-trust-item">
      <span class="wls-trust-icon">🚫</span>
      <div>
        <div class="wls-trust-name">No Banned Substances</div>
        <div class="wls-trust-sub">Safe for competitive athletes</div>
      </div>
    </div>
    <div class="wls-trust-item">
      <span class="wls-trust-icon">🏷️</span>
      <div>
        <div class="wls-trust-name">Genuine Products</div>
        <div class="wls-trust-sub">100% authentic, sealed packaging</div>
      </div>
    </div>
  </div>

</div><!-- /.qb-wls-wrap -->

<script>
(function() {
  var wlsState = {};

  // Initialise per product
  wlsState['{{ product.id }}'] = {
    variantId: {{ first_variant.id }},
    variantTitle: {{ first_variant.title | json }},
    productType: {{ product.type | json }},
    quantity: 1
  };

  window.wlsSelectVariant = function(pid, el) {
    var pills = document.querySelectorAll('#wls-variants-' + pid + ' .wls-variant-pill');
    pills.forEach(function(p) { p.classList.remove('wls-variant-pill--active'); });
    el.classList.add('wls-variant-pill--active');

    var vid   = el.getAttribute('data-variant-id');
    var price = parseInt(el.getAttribute('data-variant-price'));
    var cmp   = parseInt(el.getAttribute('data-variant-compare'));
    var title = el.getAttribute('data-variant-title');
    var avail = el.getAttribute('data-variant-available') === 'true';

    wlsState[pid].variantId    = parseInt(vid);
    wlsState[pid].variantTitle = title;

    // Update price display
    var priceEl = document.getElementById('wls-price-' + pid);
    if (priceEl) priceEl.textContent = wlsFormatMoney(price);

    var compareEl = document.getElementById('wls-compare-' + pid);
    var saveEl    = document.getElementById('wls-save-' + pid);
    if (cmp && cmp > price) {
      if (compareEl) { compareEl.textContent = wlsFormatMoney(cmp); compareEl.style.display = ''; }
      if (saveEl) {
        var pct = Math.round((cmp - price) / cmp * 100);
        saveEl.textContent = pct + '% OFF';
        saveEl.style.display = '';
      }
    } else {
      if (compareEl) compareEl.style.display = 'none';
      if (saveEl)    saveEl.style.display = 'none';
    }

    // Update ATC button data
    var atcBtn = document.getElementById('wls-atc-' + pid);
    if (atcBtn) {
      atcBtn.setAttribute('data-variant-id', vid);
      atcBtn.setAttribute('data-variant-title', title);
      atcBtn.disabled = !avail;
      atcBtn.textContent = avail ? '🛒 ADD TO CART' : '❌ Out of Stock';
    }
  };

  window.wlsQtyChange = function(pid, delta) {
    var inp = document.getElementById('wls-qty-' + pid);
    if (!inp) return;
    var val = parseInt(inp.value) + delta;
    val = Math.max(1, Math.min(6, val));
    inp.value = val;
    wlsState[pid].quantity = val;
  };

  window.wlsAddToCart = function(pid) {
    var state  = wlsState[pid];
    var btn    = document.getElementById('wls-atc-' + pid);
    var fb     = document.getElementById('wls-feedback-' + pid);
    var qtyInp = document.getElementById('wls-qty-' + pid);
    var qty    = qtyInp ? parseInt(qtyInp.value) : 1;

    if (!state || !state.variantId) return;

    btn.disabled    = true;
    btn.textContent = '⏳ Adding…';
    if (fb) { fb.textContent = ''; fb.style.color = '#22c55e'; }

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        id: state.variantId,
        quantity: qty,
        properties: {
          'Type':    state.productType,
          'Flavour': state.variantTitle
        }
      })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      btn.disabled    = false;
      btn.textContent = '🛒 ADD TO CART';
      if (data.id) {
        if (fb) fb.textContent = '✓ Added to cart!';
        // Trigger cart drawer / bubble update if theme supports it
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
      } else {
        if (fb) { fb.textContent = data.description || 'Could not add item.'; fb.style.color = '#ef4444'; }
      }
    })
    .catch(function() {
      btn.disabled    = false;
      btn.textContent = '🛒 ADD TO CART';
      if (fb) { fb.textContent = 'Something went wrong. Try again.'; fb.style.color = '#ef4444'; }
    });
  };

  // Helper: format Shopify cents to money string
  function wlsFormatMoney(cents) {
    if (!cents) return '₹0.00';
    return '₹' + (cents / 100).toFixed(2);
  }
})();
</script>

