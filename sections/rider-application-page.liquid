          <p>Your application is in! Our team will reach out within <strong>24 hours</strong>. Get ready to ride with QuickBee!</p>
          <a href="/" class="ra-back-btn">Back to Home</a>
        </div>

      {%- else -%}

        <input type="hidden" name="contact[email]" id="RaHiddenEmail" value="rider-{{ "now" | date: "%H%M%S" }}@quickbee.store">

        <!-- ── Personal Info ── -->
        <div class="ra-card">
          <div class="ra-card-head">
            <div class="ra-card-icon">👤</div>
            <div>
              <div class="ra-card-title">Personal Info</div>
              <div class="ra-card-sub">Tell us a bit about yourself</div>
            </div>
          </div>
          <div class="ra-fields">
            <div class="ra-field">
              <label for="RaName">Full Name <span class="ra-req-star">*</span></label>
              <input type="text" id="RaName" name="contact[Full_Name]" placeholder="Your full name" required>
            </div>
            <div class="ra-field">
              <label for="RaPhone">Phone Number <span class="ra-req-star">*</span></label>
              <input type="tel" id="RaPhone" name="contact[phone]" placeholder="98XXXXXXXX" required>
            </div>
            <div class="ra-row">
              <div class="ra-field">
                <label for="RaAge">Age <span class="ra-req-star">*</span></label>
                <input type="text" id="RaAge" name="contact[Age]" placeholder="e.g. 24" required>
              </div>
              <div class="ra-field">
                <label for="RaLocation">Your Area</label>
                <input type="text" id="RaLocation" name="contact[Location]" placeholder="e.g. Thamel">
              </div>
            </div>
          </div>
        </div>

        <!-- ── Vehicle Info ── -->
        <div class="ra-card">
          <div class="ra-card-head">
            <div class="ra-card-icon">🛵</div>
            <div>
              <div class="ra-card-title">Vehicle Details</div>
              <div class="ra-card-sub">What are you riding?</div>
            </div>
          </div>
          <div class="ra-fields">
            <div class="ra-field">
              <label>Vehicle Type <span class="ra-req-star">*</span></label>
              <div class="ra-vehicle-grid">
                <label class="ra-vehicle-opt">
                  <input type="radio" name="contact[Vehicle_Type]" value="Bike" required>
                  <div class="ra-vehicle-label"><span class="ra-vehicle-emoji">🏍️</span> Bike</div>
                </label>
                <label class="ra-vehicle-opt">
                  <input type="radio" name="contact[Vehicle_Type]" value="Scooter">
                  <div class="ra-vehicle-label"><span class="ra-vehicle-emoji">🛵</span> Scooter</div>
                </label>
                <label class="ra-vehicle-opt">
                  <input type="radio" name="contact[Vehicle_Type]" value="Electric">
                  <div class="ra-vehicle-label"><span class="ra-vehicle-emoji">⚡</span> Electric</div>
                </label>
                <label class="ra-vehicle-opt">
                  <input type="radio" name="contact[Vehicle_Type]" value="Other">
                  <div class="ra-vehicle-label"><span class="ra-vehicle-emoji">🚗</span> Other</div>
                </label>
              </div>
            </div>
            <div class="ra-row">
              <div class="ra-field">
                <label for="RaPlate">Plate Number</label>
                <input type="text" id="RaPlate" name="contact[Vehicle_No]" placeholder="BA 1 PA 1234">
              </div>
              <div class="ra-field">
                <label for="RaLicense">License No.</label>
                <input type="text" id="RaLicense" name="contact[License_No]" placeholder="License number">
              </div>
            </div>
          </div>
        </div>

        <!-- ── Delivery IQ ── -->
        <div class="ra-card ra-iq-card">
          <div class="ra-card-head">
            <div class="ra-card-icon" style="background:linear-gradient(135deg,#4A6FFF,#7B5EA7);">🧠</div>
            <div>
              <div class="ra-card-title">Delivery IQ Check</div>
              <div class="ra-card-sub">3 quick questions — no wrong answers, just honest ones</div>
            </div>
          </div>
          <div class="ra-fields">

            <div class="ra-iq-q">
              <p class="ra-iq-question"><span class="ra-iq-num">1</span>A customer doesn't answer the door or phone for 10 minutes. What do you do?</p>
              <div class="ra-iq-options">
                <label class="ra-iq-opt">
                  <input type="radio" name="contact[IQ_Q1]" value="Leave at door and go">
                  <div class="ra-iq-opt-label"><span class="ra-iq-opt-dot"></span>Leave the order at the door and go</div>
                </label>
                <label class="ra-iq-opt">
                  <input type="radio" name="contact[IQ_Q1]" value="Call Support and wait for instructions">
                  <div class="ra-iq-opt-label"><span class="ra-iq-opt-dot"></span>Call support and wait for instructions</div>
                </label>
                <label class="ra-iq-opt">
                  <input type="radio" name="contact[IQ_Q1]" value="Take the food and finish shift">
                  <div class="ra-iq-opt-label"><span class="ra-iq-opt-dot"></span>Take the food home</div>
                </label>
              </div>
            </div>

            <div class="ra-iq-q">
              <p class="ra-iq-question"><span class="ra-iq-num">2</span>A drink spills slightly inside the bag. Best action?</p>
              <div class="ra-iq-options">
                <label class="ra-iq-opt">
                  <input type="radio" name="contact[IQ_Q2]" value="Wipe it and deliver silently">
                  <div class="ra-iq-opt-label"><span class="ra-iq-opt-dot"></span>Wipe it and deliver without saying anything</div>
                </label>
                <label class="ra-iq-opt">
                  <input type="radio" name="contact[IQ_Q2]" value="Inform customer, apologize, and contact support">
                  <div class="ra-iq-opt-label"><span class="ra-iq-opt-dot"></span>Tell the customer, apologize & contact support</div>
                </label>
                <label class="ra-iq-opt">
                  <input type="radio" name="contact[IQ_Q2]" value="Tell the customer it was the restaurant's fault">
                  <div class="ra-iq-opt-label"><span class="ra-iq-opt-dot"></span>Blame the restaurant</div>
                </label>
              </div>
            </div>

            <div class="ra-iq-q">
              <p class="ra-iq-question"><span class="ra-iq-num">3</span>The most important part of being a QuickBee rider is?</p>
              <div class="ra-iq-options">
                <label class="ra-iq-opt">
                  <input type="radio" name="contact[IQ_Q3]" value="Speed - Driving as fast as possible">
                  <div class="ra-iq-opt-label"><span class="ra-iq-opt-dot"></span>Driving as fast as possible</div>
                </label>
                <label class="ra-iq-opt">
                  <input type="radio" name="contact[IQ_Q3]" value="Safety - Delivering items in perfect condition">
                  <div class="ra-iq-opt-label"><span class="ra-iq-opt-dot"></span>Delivering safely and in perfect condition</div>
                </label>
                <label class="ra-iq-opt">
                  <input type="radio" name="contact[IQ_Q3]" value="Earnings - Completing most orders by any means">
                  <div class="ra-iq-opt-label"><span class="ra-iq-opt-dot"></span>Completing the most orders by any means</div>
                </label>
              </div>
            </div>

          </div>
        </div>

        <!-- ── Availability ── -->
        <div class="ra-card">
          <div class="ra-card-head">
            <div class="ra-card-icon" style="background:linear-gradient(135deg,#00A86B,#00C87A);">📍</div>
            <div>
              <div class="ra-card-title">Availability & Area</div>
              <div class="ra-card-sub">When and where can you ride?</div>
            </div>
          </div>
          <div class="ra-fields">
            <div class="ra-field">
              <label for="RaAreas">Areas You Know Best</label>
              <input type="text" id="RaAreas" name="contact[Areas_Covered]" placeholder="e.g. Thamel, Baneshwor, Lalitpur, Patan">
            </div>
            <div class="ra-row">
              <div class="ra-field">
                <label for="RaAvail">Availability</label>
                <input type="text" id="RaAvail" name="contact[Available_Time]" placeholder="Full Time / Morning…">
              </div>
              <div class="ra-field">
                <label for="RaSalary">Expected Monthly Salary</label>
                <input type="text" id="RaSalary" name="contact[Expected_Salary]" placeholder="e.g. Rs 25,000+">
              </div>
            </div>
            <div class="ra-field">
              <label for="RaNote">Anything else to add? (optional)</label>
              <textarea id="RaNote" name="contact[body]" rows="3" placeholder="Tell us anything extra — experience, why you want to ride with QuickBee, etc."></textarea>
            </div>
          </div>
        </div>

        <!-- ── Submit ── -->
        <div class="ra-submit-wrap">
          <button type="submit" class="ra-submit-btn" id="RaSubmitBtn">
            <span id="RaSubmitText">Send My Application 🚀</span>
          </button>
          <p class="ra-submit-note">By applying you agree to QuickBee's rider terms & conditions. We'll never share your data with third parties.</p>
        </div>

      {%- endif -%}
    {%- endform -%}

  </div>

</div>

<script>
(function () {
  var W3F_KEY = 'WEB3FORMS_KEY'; // ← paste your web3forms access key

  document.addEventListener('DOMContentLoaded', function () {
    var form    = document.getElementById('RiderAppForm');
    var btn     = document.getElementById('RaSubmitBtn');
    var btnText = document.getElementById('RaSubmitText');
    if (!form || !btn) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      btnText.textContent = 'Sending…';
      btn.classList.add('loading');
      btn.disabled = true;

      var fd = new FormData(form);
      var payload = { access_key: W3F_KEY, subject: '🛵 New QuickBee Rider Application' };
      fd.forEach(function (v, k) {
        var clean = k.replace(/^contact\[/, '').replace(/\]$/, '');
        if (clean !== 'email') payload[clean] = v;
      });
      payload['Submitted_At'] = new Date().toLocaleString();

      function send(attempt) {
        fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(payload)
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
          if (res.success) {
            form.innerHTML =
              '<div class="ra-success">' +
              '<div class="ra-success-emoji">🎉</div>' +
              '<h2>Application Received!</h2>' +
              '<p>Our team will reach out within <strong>24 hours</strong>. Get ready to ride with QuickBee!</p>' +
              '<a href="/" class="ra-back-btn">Back to Home</a>' +
              '</div>';
          } else { throw new Error(res.message); }
        })
        .catch(function (err) {
          if (attempt < 1) { setTimeout(function () { send(1); }, 1200); return; }
          btnText.textContent = 'Send My Application 🚀';
          btn.classList.remove('loading');
          btn.disabled = false;
          alert('Something went wrong. Please check your connection and try again.');
        });
      }
      send(0);
    });
  });
})();
</script>

