{% comment %} sections/rider-application-page.liquid {% endcomment %}

<style>
  .ra-root {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    min-height: 100vh;
    background: var(--ra-bg, #0A0F1E);
    color: var(--ra-text, #F0F4FF);
  }

  html:not([data-theme="dark"]) .ra-root {
    --ra-bg: #F4F6FB;
    --ra-text: #1A1E2E;
    --ra-card: #FFFFFF;
    --ra-border: rgba(0,0,0,0.08);
    --ra-muted: #6B7280;
    --ra-gold: #D4A843;
    --ra-navy: #0D1A3A;
    --ra-input-bg: #F9FAFB;
    --ra-input-border: #D1D5DB;
  }

  html[data-theme="dark"] .ra-root {
    --ra-bg: #0A0F1E;
    --ra-text: #F0F4FF;
    --ra-card: #141929;
    --ra-border: rgba(255,255,255,0.08);
    --ra-muted: #8B92A5;
    --ra-gold: #F0BE55;
    --ra-navy: #0D1A3A;
    --ra-input-bg: #1A2035;
    --ra-input-border: rgba(255,255,255,0.12);
  }

  .ra-hero {
    background: linear-gradient(135deg, #080E20 0%, #0D1A3A 60%, #122040 100%);
    padding: 60px 20px 50px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .ra-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(212,168,67,0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .ra-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(212,168,67,0.15);
    border: 1px solid rgba(212,168,67,0.35);
    border-radius: 100px;
    padding: 6px 16px;
    font-size: 12px;
    font-weight: 600;
    color: #F0BE55;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .ra-hero-badge::before {
    content: '';
    width: 7px;
    height: 7px;
    background: #4ADE80;
    border-radius: 50%;
    animation: ra-pulse 1.5s ease-in-out infinite;
  }

  @keyframes ra-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  .ra-hero h1 {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    color: #FFFFFF;
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .ra-hero h1 em {
    font-style: normal;
    background: linear-gradient(135deg, #F0BE55, #D4A843);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ra-hero-sub {
    font-size: 16px;
    color: rgba(240,244,255,0.7);
    max-width: 480px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }

  .ra-stats {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .ra-stat {
    text-align: center;
  }

  .ra-stat-num {
    font-size: 24px;
    font-weight: 800;
    color: #F0BE55;
  }

  .ra-stat-label {
    font-size: 12px;
    color: rgba(240,244,255,0.6);
    margin-top: 2px;
  }

  .ra-section {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .ra-section-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--ra-text);
    margin: 0 0 20px;
  }

  .ra-cards-grid {
    display: grid;
    gap: 16px;
  }

  .ra-card {
    background: var(--ra-card);
    border: 1px solid var(--ra-border);
    border-radius: 16px;
    padding: 24px;
  }

  .ra-card-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--ra-text);
    margin: 0 0 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ra-input-group {
    margin-bottom: 14px;
  }

  .ra-input-group:last-child {
    margin-bottom: 0;
  }

  .ra-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--ra-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
  }

  .ra-input,
  .ra-select,
  .ra-textarea {
    width: 100%;
    background: var(--ra-input-bg);
    border: 1px solid var(--ra-input-border);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 15px;
    color: var(--ra-text);
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
    font-family: inherit;
  }

  .ra-input:focus,
  .ra-select:focus,
  .ra-textarea:focus {
    border-color: #F0BE55;
  }

  .ra-textarea {
    resize: vertical;
    min-height: 80px;
  }

  .ra-vehicle-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .ra-vehicle-tile {
    display: none;
  }

  .ra-vehicle-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: var(--ra-input-bg);
    border: 2px solid var(--ra-input-border);
    border-radius: 12px;
    padding: 16px 12px;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
  }

  .ra-vehicle-tile:checked + .ra-vehicle-label {
    border-color: #F0BE55;
    background: rgba(240,190,85,0.1);
  }

  .ra-vehicle-icon {
    font-size: 28px;
  }

  .ra-vehicle-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--ra-text);
  }

  .ra-vehicle-note {
    font-size: 11px;
    color: var(--ra-muted);
  }

  .ra-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  @media (max-width: 480px) {
    .ra-row { grid-template-columns: 1fr; }
  }

  .ra-submit-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 20px 60px;
  }

  .ra-submit-btn {
    width: 100%;
    background: linear-gradient(135deg, #F0BE55, #D4A843);
    color: #0A0F1E;
    font-size: 17px;
    font-weight: 800;
    border: none;
    border-radius: 14px;
    padding: 18px;
    cursor: pointer;
    letter-spacing: 0.3px;
    transition: opacity 0.2s, transform 0.1s;
  }

  .ra-submit-btn:active {
    transform: scale(0.98);
  }

  .ra-submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .ra-note {
    text-align: center;
    font-size: 12px;
    color: var(--ra-muted);
    margin-top: 12px;
  }
</style>

<div class="ra-root">

  <!-- Hero -->
  <div class="ra-hero">
    <div class="ra-hero-badge">Now Hiring</div>
    <h1>Ride with <em>QuickBee</em></h1>
    <p class="ra-hero-sub">Join Nepal's fastest delivery network. Earn on your schedule, get paid weekly.</p>
    <div class="ra-stats">
      <div class="ra-stat">
        <div class="ra-stat-num">Rs 800+</div>
        <div class="ra-stat-label">Daily Avg Earnings</div>
      </div>
      <div class="ra-stat">
        <div class="ra-stat-num">15 min</div>
        <div class="ra-stat-label">Onboarding</div>
      </div>
      <div class="ra-stat">
        <div class="ra-stat-num">Weekly</div>
        <div class="ra-stat-label">Payout</div>
      </div>
    </div>
  </div>

  <!-- Form -->
  <div class="ra-section">
    <div class="ra-section-title">Your Details</div>
    <div class="ra-cards-grid">

      <!-- Personal Info -->
      <div class="ra-card">
        <div class="ra-card-title">👤 Personal Information</div>
        <div class="ra-row">
          <div class="ra-input-group">
            <label class="ra-label">Full Name *</label>
            <input class="ra-input" id="ra-name" type="text" placeholder="Your full name" required>
          </div>
          <div class="ra-input-group">
            <label class="ra-label">Phone *</label>
            <input class="ra-input" id="ra-phone" type="tel" placeholder="98XXXXXXXX" required>
          </div>
        </div>
        <div class="ra-row">
          <div class="ra-input-group">
            <label class="ra-label">Age *</label>
            <input class="ra-input" id="ra-age" type="number" placeholder="18–45" min="18" max="60">
          </div>
          <div class="ra-input-group">
            <label class="ra-label">City *</label>
            <select class="ra-select" id="ra-city">
              <option value="">Select city</option>
              <option>Kathmandu</option>
              <option>Bhaktapur</option>
              <option>Lalitpur</option>
              <option>Pokhara</option>
            </select>
          </div>
        </div>
        <div class="ra-input-group">
          <label class="ra-label">Expected Monthly Salary</label>
          <input class="ra-input" id="ra-salary" type="text" placeholder="Write your expected salary">
        </div>
      </div>

      <!-- Vehicle -->
      <div class="ra-card">
        <div class="ra-card-title">🛵 Vehicle <span style="font-size:12px;font-weight:400;color:var(--ra-muted);margin-left:4px;">(recommended, not compulsory)</span></div>
        <div class="ra-vehicle-grid">
          <div>
            <input class="ra-vehicle-tile" type="radio" name="ra-vehicle" id="v-bike" value="Motorcycle">
            <label class="ra-vehicle-label" for="v-bike">
              <span class="ra-vehicle-icon">🏍️</span>
              <span class="ra-vehicle-name">Motorcycle</span>
            </label>
          </div>
          <div>
            <input class="ra-vehicle-tile" type="radio" name="ra-vehicle" id="v-scooter" value="Scooter">
            <label class="ra-vehicle-label" for="v-scooter">
              <span class="ra-vehicle-icon">🛵</span>
              <span class="ra-vehicle-name">Scooter</span>
            </label>
          </div>
          <div>
            <input class="ra-vehicle-tile" type="radio" name="ra-vehicle" id="v-bicycle" value="Bicycle">
            <label class="ra-vehicle-label" for="v-bicycle">
              <span class="ra-vehicle-icon">🚲</span>
              <span class="ra-vehicle-name">Bicycle</span>
            </label>
          </div>
          <div>
            <input class="ra-vehicle-tile" type="radio" name="ra-vehicle" id="v-none" value="No vehicle" checked>
            <label class="ra-vehicle-label" for="v-none">
              <span class="ra-vehicle-icon">🚶</span>
              <span class="ra-vehicle-name">No vehicle</span>
              <span class="ra-vehicle-note">Still welcome!</span>
            </label>
          </div>
        </div>
      </div>

      <!-- Availability -->
      <div class="ra-card">
        <div class="ra-card-title">🕒 Availability</div>
        <div class="ra-input-group">
          <label class="ra-label">Preferred Shift</label>
          <select class="ra-select" id="ra-shift">
            <option value="">Select shift</option>
            <option>Morning (6am–12pm)</option>
            <option>Afternoon (12pm–6pm)</option>
            <option>Evening (6pm–11pm)</option>
            <option>Full day</option>
            <option>Flexible</option>
          </select>
        </div>
        <div class="ra-input-group">
          <label class="ra-label">Anything else you want to tell us?</label>
          <textarea class="ra-textarea" id="ra-note" placeholder="Previous delivery experience, questions, etc."></textarea>
        </div>
      </div>

    </div>
  </div>

  <!-- Submit -->
  <div class="ra-submit-wrap">
    <input type="hidden" id="RaVariantId" value="{{ product.variants.first.id }}">
    <button class="ra-submit-btn" id="ra-submit-btn" onclick="raSubmit()">
      🛵 Submit Application
    </button>
    <p class="ra-note">We'll contact you within 24 hours via phone.</p>
  </div>

</div>

<script>
async function raSubmit() {
  const btn = document.getElementById('ra-submit-btn');
  const name = document.getElementById('ra-name').value.trim();
  const phone = document.getElementById('ra-phone').value.trim();

  if (!name || !phone) {
    alert('Please fill in your name and phone number.');
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Submitting...';

  const vehicle = document.querySelector('input[name="ra-vehicle"]:checked');
  const variantId = document.getElementById('RaVariantId').value;

  const props = {
    '👤 Full Name': name,
    '📞 Phone': phone,
    '🎂 Age': document.getElementById('ra-age').value || '—',
    '📍 City': document.getElementById('ra-city').value || '—',
    '💰 Expected Salary': document.getElementById('ra-salary').value || '—',
    '🛵 Vehicle': vehicle ? vehicle.value : '—',
    '🕒 Shift': document.getElementById('ra-shift').value || '—',
    '📝 Note': document.getElementById('ra-note').value || '—',
    '🕒 Submitted': new Date().toLocaleString('en-NP', { timeZone: 'Asia/Kathmandu' })
  };

  const note = `🛵 RIDER APPLICATION\n──────────────────\n` +
    Object.entries(props).map(([k,v]) => `${k}: ${v}`).join('\n');

  try {
    await fetch('/cart/clear.js', { method: 'POST' });
    await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1, properties: props })
    });
    await fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ note })
    });
    window.location.href = '/checkout';
  } catch(e) {
    btn.disabled = false;
    btn.textContent = '🛵 Submit Application';
    alert('Something went wrong. Please try again.');
  }
}
</script>

{% schema %}
{
  "name": "Rider Application",
  "settings": []
}
{% endschema %}
