{% if product.collections.first.title == "Yeti Kafe" or product.vendor == "YETI KAFE" %}
  <!-- Yeti Kafe Product -->
  <style>
    :root {
      --yeti-primary: #8B4513;
      --yeti-accent: #D2691E;
      --yeti-light: #FFF5E6;
      --yeti-dark: #3D2817;
    }

    .yetikafe-product-section {
      background: linear-gradient(135deg, var(--yeti-light) 0%, #FFFAF0 100%);
      padding: 20px 0;
    }

    .yetikafe-badge {
      display: inline-block;
      background: linear-gradient(135deg, var(--yeti-primary) 0%, var(--yeti-accent) 100%);
      color: white;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 16px;
      box-shadow: 0 4px 12px rgba(139, 69, 19, 0.3);
    }

    .yetikafe-header {
      padding: 0 20px;
      margin-bottom: 24px;
    }

    .yetikafe-cafe-message {
      font-size: 14px;
      color: var(--yeti-primary);
      font-weight: 600;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .yetikafe-title {
      font-size: 32px;
      font-weight: 900;
      color: var(--yeti-dark);
      line-height: 1.2;
      margin-bottom: 12px;
    }

    .yetikafe-price-section {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 20px;
    }

    .yetikafe-price {
      font-size: 36px;
      font-weight: 900;
      color: var(--yeti-primary);
    }

    .yetikafe-original-price {
      font-size: 18px;
      color: #999;
      text-decoration: line-through;
    }

    .yetikafe-fresh-badge {
      display: inline-block;
      background: #22C55E;
      color: white;
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      margin-left: 8px;
    }

    .yetikafe-delivery-info {
      background: white;
      border-left: 4px solid var(--yeti-accent);
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .yetikafe-delivery-icon {
      font-size: 24px;
    }

    .yetikafe-delivery-text {
      flex: 1;
    }

    .yetikafe-delivery-time {
      font-size: 14px;
      font-weight: 700;
      color: var(--yeti-dark);
    }

    .yetikafe-delivery-desc {
      font-size: 12px;
      color: #666;
      margin-top: 2px;
    }

    .yetikafe-description {
      background: white;
      padding: 16px;
      border-radius: 12px;
      margin-bottom: 20px;
      border: 1px solid #F0E6D2;
    }

    .yetikafe-description-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--yeti-dark);
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .yetikafe-description-text {
      font-size: 13px;
      color: #555;
      line-height: 1.6;
    }

    .yetikafe-highlights {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 12px;
      margin-bottom: 20px;
    }

    .yetikafe-highlight {
      background: white;
      padding: 12px;
      border-radius: 8px;
      text-align: center;
      border: 1px solid #F0E6D2;
      transition: all 0.3s ease;
    }

    .yetikafe-highlight:hover {
      border-color: var(--yeti-accent);
      box-shadow: 0 4px 12px rgba(139, 69, 19, 0.1);
    }

    .yetikafe-highlight-icon {
      font-size: 20px;
      margin-bottom: 6px;
    }

    .yetikafe-highlight-text {
      font-size: 11px;
      font-weight: 600;
      color: var(--yeti-primary);
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }

    .yetikafe-cta-section {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
    }

    .yetikafe-add-btn {
      flex: 1;
      background: linear-gradient(135deg, var(--yeti-primary) 0%, var(--yeti-accent) 100%);
      color: white;
      border: none;
      padding: 16px 24px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 12px rgba(139, 69, 19, 0.3);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .yetikafe-add-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(139, 69, 19, 0.4);
    }

    .yetikafe-product-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 20px;
    }

    .yetikafe-tag {
      background: white;
      border: 1px solid var(--yeti-accent);
      color: var(--yeti-primary);
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
    }

    .yetikafe-container {
      max-width: 600px;
      margin: 0 auto;
      padding: 0 16px;
    }

    .yetikafe-image-section {
      width: 100%;
      aspect-ratio: 1;
      background: #f5f5f5;
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .yetikafe-product-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (min-width: 768px) {
      .yetikafe-container {
        padding: 0 32px;
      }
      .yetikafe-title {
        font-size: 28px;
      }
      .yetikafe-image-section {
        margin-bottom: 32px;
      }
    }
  </style>

  <div class="yetikafe-product-section">
    <div class="yetikafe-container">
      <!-- Product Image -->
      <div class="yetikafe-image-section">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" class="yetikafe-product-image">
        {% else %}
          <div style="font-size: 80px; text-align: center; color: #ddd;">📦</div>
        {% endif %}
      </div>

      <div class="yetikafe-badge">☕ Fresh from Yeti Kafe</div>

      <div class="yetikafe-header">
        <div class="yetikafe-cafe-message">☕ Yeti Kafe Collection</div>
        <h1 class="yetikafe-title">{{ product.title }}</h1>

        <div class="yetikafe-price-section">
          <span class="yetikafe-price">Rs {{ product.price | money_without_currency }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="yetikafe-original-price">Rs {{ product.compare_at_price | money_without_currency }}</span>
          {% endif %}
          <span class="yetikafe-fresh-badge">Fresh</span>
        </div>
      </div>

      <div class="yetikafe-delivery-info">
        <div class="yetikafe-delivery-icon">🚚</div>
        <div class="yetikafe-delivery-text">
          <div class="yetikafe-delivery-time yeti-delivery-sync">⚡ 18-22 mins delivery</div>
          <div class="yetikafe-delivery-desc">Free delivery on orders above Rs 199</div>
        </div>
      </div>

      {% if product.description %}
        <div class="yetikafe-description">
          <div class="yetikafe-description-title">About this item</div>
          <div class="yetikafe-description-text">
            {{ product.description | strip_html | truncatewords: 30 }}
          </div>
        </div>
      {% endif %}

      <div class="yetikafe-highlights">
        <div class="yetikafe-highlight">
          <div class="yetikafe-highlight-icon">🌟</div>
          <div class="yetikafe-highlight-text">Premium Quality</div>
        </div>
        <div class="yetikafe-highlight">
          <div class="yetikafe-highlight-icon">❄️</div>
          <div class="yetikafe-highlight-text">Freshly Prepared</div>
        </div>
        <div class="yetikafe-highlight">
          <div class="yetikafe-highlight-icon">✓</div>
          <div class="yetikafe-highlight-text">100% Guarantee</div>
        </div>
      </div>

      <div class="yetikafe-product-tags">
        <span class="yetikafe-tag">☕ Beverages</span>
        <span class="yetikafe-tag">🍰 Café</span>
        <span class="yetikafe-tag">🌿 Fresh Ingredients</span>
      </div>

      <div class="yetikafe-cta-section">
        <button class="yetikafe-add-btn" onclick="alert('Add to cart: {{ product.title }}')">
          🛒 Add to Cart
        </button>
      </div>

      <div style="text-align: center; padding: 16px; background: white; border-radius: 8px; border: 1px solid #F0E6D2; margin-top: 20px;">
        <p style="font-size: 12px; color: #666; margin: 0;">
          ✨ Part of the Yeti Kafe Collection - Premium café beverages & food items
        </p>
      </div>
    </div>
  </div>

  <script>
    (function() {
      function updateDeliveryBadge() {
        const range = window.QB_DELIVERY_TIME?.range || '18-22 mins';
        const badge = document.querySelector('.yeti-delivery-sync');
        if (badge) {
          badge.textContent = '⚡ ' + range + ' delivery';
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', updateDeliveryBadge);
      } else {
        updateDeliveryBadge();
      }

      window.addEventListener('locationSelected', function() {
        setTimeout(updateDeliveryBadge, 50);
      });
    })();
  </script>

{% else %}
  <!-- Default Product Template -->
  {% section 'product-information-speed-first' %}
{% endif %}
