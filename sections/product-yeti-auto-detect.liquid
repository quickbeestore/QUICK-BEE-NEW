{% if product.collections.first.title == "Yeti Kafe" or product.vendor == "YETI KAFE" %}
  <!-- Yeti Kafe Product -->
  <style>
    :root {
      --yeti-primary: #8B4513;
      --yeti-accent: #D2691E;
      --yeti-light: #FFF5E6;
      --yeti-dark: #3D2817;
    }

    .yetikafe-product-section {
      background: linear-gradient(135deg, var(--yeti-light) 0%, #FFFAF0 100%);
      padding: 20px 0;
    }

    .yetikafe-badge {
      display: inline-block;
      background: linear-gradient(135deg, var(--yeti-primary) 0%, var(--yeti-accent) 100%);
      color: white;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 16px;
      box-shadow: 0 4px 12px rgba(139, 69, 19, 0.3);
    }

    .yetikafe-header {
      padding: 0 20px;
      margin-bottom: 24px;
    }

    .yetikafe-cafe-message {
      font-size: 14px;
      color: var(--yeti-primary);
      font-weight: 600;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .yetikafe-title {
      font-size: 32px;
      font-weight: 900;
      color: var(--yeti-dark);
      line-height: 1.2;
      margin-bottom: 12px;
    }

    .yetikafe-price-section {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 20px;
    }

    .yetikafe-price {
      font-size: 36px;
      font-weight: 900;
      color: var(--yeti-primary);
    }

    .yetikafe-original-price {
      font-size: 18px;
      color: #999;
      text-decoration: line-through;
    }

    .yetikafe-fresh-badge {
      display: inline-block;
      background: #22C55E;
      color: white;
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      margin-left: 8px;
    }

    .yetikafe-delivery-info {
      background: white;
      border-left: 4px solid var(--yeti-accent);
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .yetikafe-delivery-icon {
      font-size: 24px;
    }

    .yetikafe-delivery-text {
      flex: 1;
    }

    .yetikafe-delivery-time {
      font-size: 14px;
      font-weight: 700;
      color: var(--yeti-dark);
    }

    .yetikafe-delivery-desc {
      font-size: 12px;
      color: #666;
      margin-top: 2px;
    }

    .yetikafe-description {
      background: white;
      padding: 16px;
      border-radius: 12px;
      margin-bottom: 20px;
      border: 1px solid #F0E6D2;
    }

    .yetikafe-description-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--yeti-dark);
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .yetikafe-description-text {
      font-size: 13px;
      color: #555;
      line-height: 1.6;
    }

    .yetikafe-highlights {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 12px;
      margin-bottom: 20px;
    }

    .yetikafe-highlight {
      background: white;
      padding: 12px;
      border-radius: 8px;
      text-align: center;
      border: 1px solid #F0E6D2;
      transition: all 0.3s ease;
    }

    .yetikafe-highlight:hover {
      border-color: var(--yeti-accent);
      box-shadow: 0 4px 12px rgba(139, 69, 19, 0.1);
    }

    .yetikafe-highlight-icon {
      font-size: 20px;
      margin-bottom: 6px;
    }

    .yetikafe-highlight-text {
      font-size: 11px;
      font-weight: 600;
      color: var(--yeti-primary);
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }

    .yetikafe-cta-section {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
    }

    .yetikafe-add-btn {
      flex: 1;
      background: linear-gradient(135deg, var(--yeti-primary) 0%, var(--yeti-accent) 100%);
      color: white;
      border: none;
      padding: 16px 24px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 12px rgba(139, 69, 19, 0.3);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .yetikafe-add-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(139, 69, 19, 0.4);
    }

    .yetikafe-product-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 20px;
    }

    .yetikafe-tag {
      background: white;
      border: 1px solid var(--yeti-accent);
      color: var(--yeti-primary);
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
    }

    .yetikafe-container {
      max-width: 600px;
      margin: 0 auto;
      padding: 0 16px;
    }

    .yetikafe-image-section {
      width: 100%;
      aspect-ratio: 1;
      background: #f5f5f5;
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .yetikafe-product-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (min-width: 768px) {
      .yetikafe-container {
        padding: 0 32px;
      }
      .yetikafe-title {
        font-size: 28px;
      }
      .yetikafe-image-section {
        margin-bottom: 32px;
      }
    }
  </style>

  <div class="yetikafe-product-section">
    <div class="yetikafe-container">
      <!-- Product Image -->
      <div class="yetikafe-image-section">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" class="yetikafe-product-image">
        {% else %}
          <div style="font-size: 80px; text-align: center; color: #ddd;">📦</div>
        {% endif %}
      </div>

      <div class="yetikafe-badge">☕ Fresh from Yeti Kafe</div>

      <div class="yetikafe-header">
        <div class="yetikafe-cafe-message">☕ Yeti Kafe Collection</div>
        <h1 class="yetikafe-title">{{ product.title }}</h1>

        <div class="yetikafe-price-section">
          <span class="yetikafe-price">Rs {{ product.price | money_without_currency }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="yetikafe-original-price">Rs {{ product.compare_at_price | money_without_currency }}</span>
          {% endif %}
          <span class="yetikafe-fresh-badge">Fresh</span>
        </div>
      </div>

      <div class="yetikafe-delivery-info">
        <div class="yetikafe-delivery-icon">🚚</div>
        <div class="yetikafe-delivery-text">
          <div class="yetikafe-delivery-time yeti-delivery-sync">⚡ 18-22 mins delivery</div>
          <div class="yetikafe-delivery-desc">Free delivery on orders above Rs 199</div>
        </div>
      </div>

      {% if product.description %}
        <div class="yetikafe-description">
          <div class="yetikafe-description-title">About this item</div>
          <div class="yetikafe-description-text">
            {{ product.description | strip_html | truncatewords: 30 }}
          </div>
        </div>
      {% endif %}

      <div class="yetikafe-highlights">
        <div class="yetikafe-highlight">
          <div class="yetikafe-highlight-icon">🌟</div>
          <div class="yetikafe-highlight-text">Premium Quality</div>
        </div>
        <div class="yetikafe-highlight">
          <div class="yetikafe-highlight-icon">❄️</div>
          <div class="yetikafe-highlight-text">Freshly Prepared</div>
        </div>
        <div class="yetikafe-highlight">
          <div class="yetikafe-highlight-icon">✓</div>
          <div class="yetikafe-highlight-text">100% Guarantee</div>
        </div>
      </div>

      <div class="yetikafe-product-tags">
        <span class="yetikafe-tag">☕ Beverages</span>
        <span class="yetikafe-tag">🍰 Café</span>
        <span class="yetikafe-tag">🌿 Fresh Ingredients</span>
      </div>

      <!-- Variants -->
      {% if product.available and product.variants.size > 1 %}
        <div style="background: white; padding: 16px; border-radius: 12px; border: 1px solid #F0E6D2; margin-bottom: 20px;">
          <div style="font-size: 14px; font-weight: 700; color: var(--yeti-dark); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px;">Select Options</div>
          {% for option in product.options_with_values %}
            <div style="margin-bottom: 12px;">
              <label style="font-size: 12px; color: #666; font-weight: 600; display: block; margin-bottom: 6px;">{{ option.name }}</label>
              <select id="select-{{ option.name | slugify }}" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; cursor: pointer;">
                {% for value in option.values %}
                  <option value="{{ value }}">{{ value }}</option>
                {% endfor %}
              </select>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      <!-- Quantity Selector -->
      <div style="background: white; padding: 16px; border-radius: 12px; border: 1px solid #F0E6D2; margin-bottom: 20px;">
        <div style="font-size: 14px; font-weight: 700; color: var(--yeti-dark); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px;">Quantity</div>
        <div style="display: flex; gap: 10px; align-items: center;">
          <button id="qty-minus" style="width: 40px; height: 40px; border: 1px solid var(--yeti-accent); background: white; border-radius: 6px; cursor: pointer; font-size: 18px; font-weight: bold; color: var(--yeti-primary);">−</button>
          <input type="number" id="product-qty" value="1" min="1" style="width: 60px; text-align: center; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px;">
          <button id="qty-plus" style="width: 40px; height: 40px; border: 1px solid var(--yeti-accent); background: white; border-radius: 6px; cursor: pointer; font-size: 18px; font-weight: bold; color: var(--yeti-primary);">+</button>
        </div>
      </div>

      <div class="yetikafe-cta-section">
        <form id="yeti-add-form" method="post" action="/cart/add" style="width: 100%;">
          <input type="hidden" name="id" id="variant-id" value="{{ product.variants.first.id }}">
          <input type="hidden" name="quantity" id="final-qty" value="1">
          <button type="submit" class="yetikafe-add-btn" id="yeti-add-btn" {% unless product.available %}disabled{% endunless %}>
            🛒 {% if product.available %}Add to Cart{% else %}Out of Stock{% endif %}
          </button>
        </form>
      </div>

      <div style="text-align: center; padding: 16px; background: white; border-radius: 8px; border: 1px solid #F0E6D2; margin-top: 20px;">
        <p style="font-size: 12px; color: #666; margin: 0;">
          ✨ Part of the Yeti Kafe Collection - Premium café beverages & food items
        </p>
      </div>

      <!-- Recently Purchased Slider -->
      <div style="margin-top: 40px; padding-top: 40px; border-top: 2px solid #F0E6D2;">
        <h2 style="font-size: 24px; font-weight: 900; color: var(--yeti-dark); margin-bottom: 24px; text-align: center;">🔥 Top Rated from Yeti Kafe</h2>

        <div style="overflow-x: auto; -webkit-overflow-scrolling: touch; scroll-behavior: smooth;" id="yeti-slider">
          <div style="display: flex; gap: 16px; padding-bottom: 16px;">
            {% assign yeti_products = shop.collections.yeti-kafe.products | limit: 5 %}
            {% for item in yeti_products %}
              {% unless item.id == product.id %}
                <a href="{{ item.url }}" style="flex: 0 0 calc(50% - 8px); text-decoration: none; color: inherit; min-width: 160px;">
                  <div style="background: white; border-radius: 12px; overflow: hidden; border: 1px solid #F0E6D2; transition: all 0.3s ease; cursor: pointer;">
                    <div style="width: 100%; aspect-ratio: 1; background: #f5f5f5; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                      {% if item.featured_image %}
                        <img src="{{ item.featured_image | image_url: width: 300 }}" alt="{{ item.title }}" style="width: 100%; height: 100%; object-fit: contain; padding: 8px;">
                      {% else %}
                        <div style="font-size: 48px;">☕</div>
                      {% endif %}
                    </div>
                    <div style="padding: 12px;">
                      <div style="font-size: 12px; font-weight: 700; color: var(--yeti-primary); text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 6px;">{{ item.title | truncatewords: 2 }}</div>
                      <div style="font-size: 16px; font-weight: 900; color: var(--yeti-primary);">Rs {{ item.price | money_without_currency }}</div>
                    </div>
                  </div>
                </a>
              {% endunless %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      function updateDeliveryBadge() {
        const range = window.QB_DELIVERY_TIME?.range || '18-22 mins';
        const badge = document.querySelector('.yeti-delivery-sync');
        if (badge) {
          badge.textContent = '⚡ ' + range + ' delivery';
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', updateDeliveryBadge);
      } else {
        updateDeliveryBadge();
      }

      window.addEventListener('locationSelected', function() {
        setTimeout(updateDeliveryBadge, 50);
      });
    })();

    // Quantity and variant handling
    (function() {
      const qtyMinus = document.getElementById('qty-minus');
      const qtyPlus = document.getElementById('qty-plus');
      const qtyInput = document.getElementById('product-qty');
      const finalQty = document.getElementById('final-qty');
      const variantId = document.getElementById('variant-id');
      const addForm = document.getElementById('yeti-add-form');

      if (qtyMinus) {
        qtyMinus.addEventListener('click', function(e) {
          e.preventDefault();
          let val = parseInt(qtyInput.value) || 1;
          if (val > 1) {
            qtyInput.value = val - 1;
            finalQty.value = qtyInput.value;
          }
        });
      }

      if (qtyPlus) {
        qtyPlus.addEventListener('click', function(e) {
          e.preventDefault();
          let val = parseInt(qtyInput.value) || 1;
          qtyInput.value = val + 1;
          finalQty.value = qtyInput.value;
        });
      }

      if (qtyInput) {
        qtyInput.addEventListener('change', function() {
          finalQty.value = Math.max(1, parseInt(this.value) || 1);
        });
      }

      // Handle variant selection
      const variantSelects = document.querySelectorAll('[id^="select-"]');
      variantSelects.forEach(select => {
        select.addEventListener('change', function() {
          // Find matching variant
          const selectedOptions = {};
          variantSelects.forEach(s => {
            const optionName = s.id.replace('select-', '').replace(/-/g, ' ');
            selectedOptions[optionName] = s.value;
          });

          // Update variant ID based on selection
          const variant = findVariantByOptions(selectedOptions);
          if (variant) {
            variantId.value = variant.id;
          }
        });
      });

      function findVariantByOptions(options) {
        // This would need the product variants data
        // For now, just return the first available variant
        return {{ product.variants.first | json }};
      }
    })();
  </script>

{% endif %}
