{% comment %} Custom Magazine — Magazine Layout {% endcomment %}
{% assign mag_products = collection.products %}

<style>
.mag-page {
  background: #fafaf8;
  min-height: 100vh;
  font-family: Georgia, 'Times New Roman', serif;
  color: #1a1a1a;
  overflow-x: hidden;
}

/* MASTHEAD */
.mag-masthead {
  background: #1a1a1a; color: #fff;
  padding: 40px 20px;
  text-align: center;
  border-bottom: 3px solid #c9a02a;
}
.mag-masthead-top {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
  color: rgba(255,255,255,0.5); margin-bottom: 16px;
}
.mag-masthead-line { width: 60px; height: 1px; background: rgba(255,255,255,0.2); }
.mag-logo { font-size: clamp(36px, 8vw, 72px); font-weight: 900; letter-spacing: -2px; line-height: 1; }
.mag-logo span { color: #c9a02a; }
.mag-tagline { font-size: 14px; font-style: italic; color: rgba(255,255,255,0.5); margin-top: 10px; letter-spacing: 1px; }
.mag-date-bar {
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;
  margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1);
  font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.4);
}
.mag-cta-scroll {
  background: #c9a02a; color: #000; padding: 10px 28px; border-radius: 4px;
  font-size: 12px; font-weight: 700; letter-spacing: 1px; cursor: pointer; border: none;
  font-family: -apple-system, sans-serif; transition: background 0.2s; text-transform: uppercase;
}
.mag-cta-scroll:hover { background: #e8b830; }

/* SECTION HEADER */
.mag-section-wrap { max-width: 1200px; margin: 0 auto; padding: 40px 20px 80px; }
.mag-section-hdr {
  display: flex; align-items: center; gap: 16px; margin-bottom: 32px;
}
.mag-section-rule { flex: 1; height: 2px; background: #1a1a1a; }
.mag-section-rule-thin { flex: 1; height: 1px; background: #ddd; }
.mag-section-title-wrap { text-align: center; }
.mag-section-eyebrow { font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #c9a02a; font-family: -apple-system, sans-serif; }
.mag-section-h { font-size: 26px; font-weight: 900; letter-spacing: -0.5px; font-family: -apple-system, sans-serif; }

/* HERO FEATURE */
.mag-hero-feature {
  display: grid; grid-template-columns: 1fr; gap: 0;
  margin-bottom: 40px; border: 1px solid #e0e0e0;
}
@media(min-width: 768px){
  .mag-hero-feature { grid-template-columns: 3fr 2fr; }
}
.mag-hero-img { width: 100%; height: 360px; object-fit: cover; display: block; }
.mag-hero-img-ph {
  width: 100%; height: 360px; background: linear-gradient(135deg, #2a2820, #1a1a14);
  display: flex; align-items: center; justify-content: center; font-size: 80px;
}
.mag-hero-content {
  padding: 32px; background: #fff;
  display: flex; flex-direction: column; justify-content: center;
}
.mag-hero-label { font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #c9a02a; font-family: -apple-system, sans-serif; margin-bottom: 12px; }
.mag-hero-title { font-size: 28px; font-weight: 900; line-height: 1.2; margin-bottom: 12px; font-family: -apple-system, sans-serif; }
.mag-hero-desc { font-size: 14px; color: #555; line-height: 1.7; margin-bottom: 20px; }
.mag-hero-price { font-size: 22px; font-weight: 800; color: #c9a02a; font-family: -apple-system, sans-serif; }
.mag-hero-btn {
  display: inline-block; margin-top: 16px; padding: 12px 28px;
  background: #1a1a1a; color: #fff; border: none; border-radius: 4px;
  font-size: 13px; font-weight: 700; cursor: pointer; font-family: -apple-system, sans-serif;
  text-decoration: none; letter-spacing: 0.5px; transition: background 0.2s;
}
.mag-hero-btn:hover { background: #333; }

/* PRODUCTS GRID */
.mag-products-id { scroll-margin-top: 80px; }
.mag-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
  border: 1px solid #e0e0e0;
}
@media(min-width: 640px){ .mag-grid { grid-template-columns: repeat(3, 1fr); } }
@media(min-width: 1024px){ .mag-grid { grid-template-columns: repeat(4, 1fr); } }

.mag-card {
  border-right: 1px solid #e0e0e0;
  border-bottom: 1px solid #e0e0e0;
  overflow: hidden;
  transition: box-shadow 0.2s;
}
.mag-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.1); z-index: 1; position: relative; }
.mag-card-img-wrap { position: relative; overflow: hidden; }
.mag-card-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; transition: transform 0.3s; }
.mag-card:hover .mag-card-img { transform: scale(1.04); }
.mag-card-img-ph { width: 100%; aspect-ratio: 4/3; background: #f5f5f0; display: flex; align-items: center; justify-content: center; font-size: 40px; }
.mag-card-body { padding: 14px; background: #fff; }
.mag-card-type { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #c9a02a; font-family: -apple-system, sans-serif; margin-bottom: 6px; }
.mag-card-name { font-size: 14px; font-weight: 700; line-height: 1.4; margin-bottom: 6px; font-family: -apple-system, sans-serif; }
.mag-card-desc { font-size: 12px; color: #777; line-height: 1.5; margin-bottom: 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.mag-card-footer { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
.mag-card-price { font-size: 14px; font-weight: 800; color: #1a1a1a; font-family: -apple-system, sans-serif; }
.mag-card-compare { font-size: 12px; color: #aaa; text-decoration: line-through; }
.mag-add-btn {
  padding: 7px 14px; background: #1a1a1a; color: #fff; border: none; border-radius: 4px;
  font-size: 11px; font-weight: 700; cursor: pointer; font-family: -apple-system, sans-serif;
  transition: background 0.2s; white-space: nowrap;
}
.mag-add-btn:hover { background: #c9a02a; color: #000; }
.mag-add-btn:disabled { background: #ccc; color: #888; cursor: default; }
</style>

<div class="mag-page">

  <!-- MASTHEAD -->
  <div class="mag-masthead">
    <div class="mag-masthead-top">
      <div class="mag-masthead-line"></div>
      <span>QuickBee Presents</span>
      <div class="mag-masthead-line"></div>
    </div>
    <div class="mag-logo">{{ collection.title | default: 'THE MAGAZINE' | upcase }}</div>
    <div class="mag-tagline">{{ collection.description | strip_html | truncate: 80 | default: 'Curated selections, delivered to you.' }}</div>
    <div class="mag-date-bar">
      <span>{{ 'now' | date: '%B %Y' }} Edition</span>
      <button class="mag-cta-scroll" onclick="document.getElementById('mag-products').scrollIntoView({behavior:'smooth'})">Shop This Issue ↓</button>
      <span>{{ collection.products_count }} Items</span>
    </div>
  </div>

  <div class="mag-section-wrap">

    <!-- HERO FEATURE (first product) -->
    {% if mag_products.size > 0 %}
      {% assign hero = mag_products[0] %}
      <div class="mag-hero-feature">
        {% if hero.featured_image %}
          <img class="mag-hero-img" src="{{ hero.featured_image | img_url: '800x600', crop: 'center' }}" alt="{{ hero.title | escape }}">
        {% else %}
          <div class="mag-hero-img-ph">📰</div>
        {% endif %}
        <div class="mag-hero-content">
          <div class="mag-hero-label">✦ Cover Feature</div>
          <div class="mag-hero-title">{{ hero.title }}</div>
          {% if hero.description != blank %}<div class="mag-hero-desc">{{ hero.description | strip_html | truncate: 200 }}</div>{% endif %}
          <div class="mag-hero-price">NPR {{ hero.price | money_without_currency }}</div>
          {% if hero.available %}
            <button class="mag-hero-btn" onclick="magAdd(this, {{ hero.variants.first.id }})">+ Add to Cart</button>
          {% else %}
            <button class="mag-hero-btn" style="background:#ccc;color:#888" disabled>Sold Out</button>
          {% endif %}
        </div>
      </div>
    {% endif %}

    <!-- SECTION HEADER -->
    <div class="mag-section-hdr">
      <div class="mag-section-rule"></div>
      <div class="mag-section-title-wrap">
        <div class="mag-section-eyebrow">In This Issue</div>
        <div class="mag-section-h">All Products</div>
      </div>
      <div class="mag-section-rule"></div>
    </div>

    <!-- PRODUCTS GRID -->
    <div class="mag-grid" id="mag-products">
      {% for p in mag_products %}
        <div class="mag-card mag-products-id">
          <div class="mag-card-img-wrap">
            {% if p.featured_image %}
              <img class="mag-card-img" src="{{ p.featured_image | img_url: '400x300', crop: 'center' }}" alt="{{ p.title | escape }}" loading="lazy">
            {% else %}
              <div class="mag-card-img-ph">📄</div>
            {% endif %}
          </div>
          <div class="mag-card-body">
            {% if p.type != blank %}<div class="mag-card-type">{{ p.type }}</div>{% endif %}
            <div class="mag-card-name">{{ p.title }}</div>
            {% if p.description != blank %}<div class="mag-card-desc">{{ p.description | strip_html }}</div>{% endif %}
            <div class="mag-card-footer">
              <div>
                <span class="mag-card-price">NPR {{ p.price | money_without_currency }}</span>
                {% if p.compare_at_price > p.price %}<br><span class="mag-card-compare">NPR {{ p.compare_at_price | money_without_currency }}</span>{% endif %}
              </div>
              {% if p.available %}
                <button class="mag-add-btn" onclick="magAdd(this, {{ p.variants.first.id }})">Add +</button>
              {% else %}
                <button class="mag-add-btn" disabled>Sold Out</button>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</div>

<script>
window.magAdd = function(btn, vid){
  var orig = btn.textContent;
  btn.disabled = true; btn.textContent = '✓ Added';
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: vid, quantity: 1 })
  }).then(function(){
    setTimeout(function(){ btn.disabled = false; btn.textContent = orig; }, 1800);
  }).catch(function(){
    btn.disabled = false; btn.textContent = orig;
    alert('Could not add item. Please try again.');
  });
};
</script>
