    <a href="#mag-products" class="mag-hero-cta" onclick="event.preventDefault();document.getElementById('mag-products').scrollIntoView({behavior:'smooth',block:'start'});">
      ✦ Start Creating Now
      <span class="mag-hero-cta-arrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>

    <div class="mag-hero-proof">
      <span class="mag-hero-proof-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        4.9 Rating
      </span>
      <span class="mag-hero-proof-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Ready in ~20 mins
      </span>
      <span class="mag-hero-proof-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        Free Delivery
      </span>
    </div>

    <div class="mag-scroll-hint">
      <div class="mag-scroll-bar"></div>
      Scroll
    </div>
  </section>

  <!-- ── TRUST STRIP ── -->
  <div class="mag-trust mag-reveal">
    <div class="mag-trust-item"><span class="mag-trust-icon">⚡</span><div><span class="mag-trust-text">Fast Design</span><span class="mag-trust-sub">Ready in ~20 minutes</span></div></div>
    <div class="mag-trust-item"><span class="mag-trust-icon">🖨️</span><div><span class="mag-trust-text">Print Quality</span><span class="mag-trust-sub">Professional grade</span></div></div>
    <div class="mag-trust-item"><span class="mag-trust-icon">🚀</span><div><span class="mag-trust-text">Fast Delivery</span><span class="mag-trust-sub">Across KTM Valley</span></div></div>
    <div class="mag-trust-item"><span class="mag-trust-icon">🎁</span><div><span class="mag-trust-text">Gift Ready</span><span class="mag-trust-sub">Beautifully packaged</span></div></div>
  </div>

  <!-- ── HOW IT WORKS ── -->
  <section class="mag-steps-wrap">
    <div class="mag-steps-head mag-reveal">
      <div class="mag-steps-label">How It Works</div>
      <h2 class="mag-steps-title">Four Simple Steps</h2>
    </div>
    <div class="mag-steps-track">
      <div class="mag-step-item mag-reveal mag-reveal--delay-1">
        <div class="mag-step-num"><span>🎨</span></div>
        <div class="mag-step-t">Pick a Style</div>
        <div class="mag-step-d">Choose your cover theme & package</div>
      </div>
      <div class="mag-step-item mag-reveal mag-reveal--delay-2">
        <div class="mag-step-num"><span>📸</span></div>
        <div class="mag-step-t">Send Photos</div>
        <div class="mag-step-d">Share your favourite memories</div>
      </div>
      <div class="mag-step-item mag-reveal mag-reveal--delay-3">
        <div class="mag-step-num"><span>✏️</span></div>
        <div class="mag-step-t">We Design</div>
        <div class="mag-step-d">Your magazine is ready in ~20 mins</div>
      </div>
      <div class="mag-step-item mag-reveal mag-reveal--delay-4">
        <div class="mag-step-num"><span>📦</span></div>
        <div class="mag-step-t">Delivered</div>
        <div class="mag-step-d">Printed & delivered to your door</div>
      </div>
    </div>
  </section>

  <!-- ── PACKAGES ── -->
  {%- if collection.products_count > 0 -%}
  <section class="mag-products-wrap" id="mag-products">

    <div class="mag-products-head mag-reveal">
      <div>
        <div class="mag-products-label">Our Packages</div>
        <h2 class="mag-products-title">Choose Your Package</h2>
      </div>
      <span class="mag-products-count">{{ collection.products_count }} option{% if collection.products_count > 1 %}s{% endif %}</span>
    </div>

    <div class="mag-cards-list">
      {%- for product in collection.products -%}
        {%- assign is_featured = false -%}
        {%- if forloop.index == 1 -%}{%- assign is_featured = true -%}{%- endif -%}
        {%- assign has_discount = false -%}
        {%- if product.compare_at_price > product.price -%}{%- assign has_discount = true -%}{%- endif -%}
        {%- assign save_amt = product.compare_at_price | minus: product.price -%}

        <a href="{{ product.url }}" class="mag-card{% if is_featured %} mag-card--featured{% endif %} mag-reveal mag-reveal--delay-{{ forloop.index }}">

          <!-- Image -->
          <div class="mag-card-img-wrap">
            {%- if product.featured_image -%}
              <img
                class="mag-card-img"
                src="{{ product.featured_image | image_url: width: 800 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="800"
              >
            {%- else -%}
              <div class="mag-card-img-placeholder">
                <div class="mag-card-img-placeholder-icon">📰</div>
                <div class="mag-card-img-placeholder-text">Custom Magazine</div>
              </div>
            {%- endif -%}

            <!-- Floating badge -->
            <span class="mag-card-img-badge">
              {%- if is_featured -%}⭐ Most Popular{%- else -%}✦ Custom Design{%- endif -%}
            </span>

            <!-- Price overlay -->
            <div class="mag-card-img-price">
              <span class="mag-card-price-main">{{ product.price | money }}</span>
              {%- if has_discount -%}
                <span class="mag-card-price-was">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>

            <!-- Save badge -->
            {%- if has_discount -%}
              <span class="mag-card-save-badge">Save {{ save_amt | money }}</span>
            {%- endif -%}
          </div>

          <!-- Body -->
          <div class="mag-card-body">
            <h2 class="mag-card-title">{{ product.title }}</h2>

            {%- if product.description != blank -%}
              <p class="mag-card-desc">{{ product.description | strip_html | truncate: 110 }}</p>
            {%- endif -%}

            {%- if product.tags.size > 0 -%}
              <div class="mag-card-features">
                {%- for tag in product.tags limit: 4 -%}
                  <span class="mag-card-feature">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    {{ tag }}
                  </span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="mag-card-foot">
              <span class="mag-card-btn">
                Select Package
                <span class="mag-card-btn-arrow">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </span>
              <span class="mag-card-eta">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                ~20 min
              </span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </section>

  {%- else -%}
  <div class="mag-empty mag-reveal">
    <div style="font-size:52px;margin-bottom:16px;filter:drop-shadow(0 0 20px rgba(244,180,0,0.3))">📰</div>
    <div style="font-size:18px;font-weight:800;color:var(--ink);margin-bottom:8px;font-family:'Playfair Display',serif">Packages coming soon</div>
    <p style="font-size:14px;color:var(--muted)">Start your custom magazine directly in the meantime.</p>
    <a href="/pages/magazine-builder" style="display:inline-flex;align-items:center;gap:8px;margin-top:20px;background:var(--gold);color:#000;font-weight:800;font-size:13px;padding:13px 24px;border-radius:999px;">✦ Start Creating Now</a>
  </div>
  {%- endif -%}

  <!-- ── BOTTOM CTA ── -->
  <div class="mag-bottom mag-reveal">
    <div class="mag-bottom-inner">
      <div class="mag-bottom-badge">✦ Ready to Begin?</div>
      <h2 class="mag-bottom-h">Turn Memories into<br><em>Your Story</em></h2>
      <p class="mag-bottom-p">Birthdays, anniversaries, graduations — a custom magazine is the most personal gift you can give.</p>
      <a href="/pages/magazine-builder" class="mag-bottom-btn">
        ✦ Start Building Now
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

</div>

<!-- Sticky CTA (appears after scroll past hero) -->
<div class="mag-sticky" id="mag-sticky-bar">
  <a href="/pages/magazine-builder" class="mag-sticky-btn">
    ✦ Start Creating Your Magazine
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </a>
</div>

<script>
(function() {
  // Scroll reveal
  var revealEls = document.querySelectorAll('.mag-reveal');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('mag-reveal--visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(function(el) { io.observe(el); });
  } else {
    revealEls.forEach(function(el) { el.classList.add('mag-reveal--visible'); });
  }

  // Sticky CTA
  var stickyBar = document.getElementById('mag-sticky-bar');
  var hero = document.querySelector('.mag-hero');
  if (stickyBar && hero) {
    var lastY = 0;
    window.addEventListener('scroll', function() {
      var heroBottom = hero.getBoundingClientRect().bottom;
      var y = window.scrollY;
      var scrollingUp = y < lastY;
      lastY = y;
      if (heroBottom < 0) {
        stickyBar.classList.add('mag-sticky--show');
        // hide when near bottom of page
        var nearBottom = (window.innerHeight + y) >= document.body.scrollHeight - 120;
        if (nearBottom || scrollingUp && y < 200) {
          stickyBar.classList.remove('mag-sticky--show');
        }
      } else {
        stickyBar.classList.remove('mag-sticky--show');
      }
    }, { passive: true });
  }
})();
</script>

{% schema %}
{
  "name": "Magazine Collection",
  "settings": [],
  "presets": [{ "name": "Magazine Collection" }]
}
{% endschema %}
