<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">

<style>
html:not([data-theme="dark"]) {
  --mcm-bg:       #f5f4f0;
  --mcm-surface:  #ffffff;
  --mcm-border:   rgba(0,0,0,0.09);
  --mcm-title:    #0a0a0a;
  --mcm-text:     #444;
  --mcm-muted:    #999;
  --mcm-gold:     #F4B400;
  --mcm-gold-bg:  rgba(244,180,0,0.08);
  --mcm-shadow:   0 2px 18px rgba(0,0,0,0.07);
  --mcm-hover:    0 6px 30px rgba(0,0,0,0.12);
}
[data-theme="dark"] {
  --mcm-bg:       #0e0e0e;
  --mcm-surface:  #1a1a1a;
  --mcm-border:   rgba(255,255,255,0.08);
  --mcm-title:    #f0f0f0;
  --mcm-text:     #bbb;
  --mcm-muted:    #555;
  --mcm-gold:     #F4B400;
  --mcm-gold-bg:  rgba(244,180,0,0.09);
  --mcm-shadow:   0 2px 20px rgba(0,0,0,0.45);
  --mcm-hover:    0 8px 36px rgba(0,0,0,0.6);
}

.mcm-page {
  background: var(--mcm-bg);
  padding-bottom: 80px;
  min-height: 100vh;
}

/* ── Hero ── */
.mcm-hero {
  text-align: center;
  padding: 56px 20px 44px;
  position: relative;
}
.mcm-hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(244,180,0,0.09) 0%, transparent 70%);
  pointer-events: none;
}
.mcm-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--mcm-gold-bg);
  border: 1px solid rgba(244,180,0,0.22);
  color: var(--mcm-gold);
  border-radius: 999px;
  padding: 4px 14px;
  font-size: 10.5px;
  font-weight: 800;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  margin-bottom: 18px;
}
.mcm-hero-h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 6vw, 3.6rem);
  font-weight: 700;
  color: var(--mcm-title);
  line-height: 1.15;
  margin: 0 0 12px;
}
.mcm-hero-h1 em { color: var(--mcm-gold); font-style: italic; }
.mcm-hero-p {
  font-size: 14px;
  color: var(--mcm-text);
  max-width: 460px;
  margin: 0 auto 28px;
  line-height: 1.65;
}
.mcm-hero-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--mcm-gold);
  color: #000;
  font-weight: 800;
  font-size: 13.5px;
  padding: 13px 26px;
  border-radius: 999px;
  text-decoration: none;
  box-shadow: 0 4px 18px rgba(244,180,0,0.35);
  transition: transform .18s, box-shadow .18s;
}
.mcm-hero-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 26px rgba(244,180,0,0.45); }

/* ── Steps strip ── */
.mcm-steps {
  display: flex;
  gap: 10px;
  max-width: 860px;
  margin: 0 auto 48px;
  padding: 0 16px;
  overflow-x: auto;
  scrollbar-width: none;
}
.mcm-steps::-webkit-scrollbar { display: none; }
.mcm-step {
  flex: 1 0 160px;
  background: var(--mcm-surface);
  border: 1px solid var(--mcm-border);
  border-radius: 14px;
  padding: 16px 14px;
  text-align: center;
}
.mcm-step-n {
  width: 32px; height: 32px;
  background: var(--mcm-gold);
  color: #000;
  border-radius: 50%;
  font-weight: 900;
  font-size: 14px;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 8px;
}
.mcm-step-t { font-size: 12.5px; font-weight: 700; color: var(--mcm-title); margin-bottom: 2px; }
.mcm-step-d { font-size: 11px; color: var(--mcm-muted); line-height: 1.4; }

/* ── Section label ── */
.mcm-label-row {
  display: flex;
  align-items: center;
  gap: 12px;
  max-width: 900px;
  margin: 0 auto 20px;
  padding: 0 16px;
}
.mcm-label {
  font-size: 10.5px;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--mcm-gold);
  white-space: nowrap;
}
.mcm-label-line { flex: 1; height: 1px; background: var(--mcm-border); }

/* ── Package cards — TITLE FIRST ── */
.mcm-cards {
  display: flex;
  flex-direction: column;
  gap: 14px;
  max-width: 900px;
  margin: 0 auto;
  padding: 0 16px;
}

.mcm-card {
  display: flex;
  align-items: stretch;
  background: var(--mcm-surface);
  border: 1px solid var(--mcm-border);
  border-radius: 20px;
  box-shadow: var(--mcm-shadow);
  text-decoration: none;
  overflow: hidden;
  transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
  position: relative;
}
.mcm-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--mcm-hover);
  border-color: rgba(244,180,0,0.3);
}

/* Left accent strip */
.mcm-card-strip {
  width: 5px;
  flex-shrink: 0;
  background: var(--mcm-gold);
  opacity: 0.6;
  transition: opacity .2s;
}
.mcm-card:hover .mcm-card-strip { opacity: 1; }
.mcm-card--featured .mcm-card-strip { opacity: 1; }

/* Main body */
.mcm-card-body {
  flex: 1;
  padding: 22px 20px 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* Top row: badge + price */
.mcm-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  flex-wrap: wrap;
}
.mcm-card-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--mcm-gold-bg);
  border: 1px solid rgba(244,180,0,0.25);
  color: var(--mcm-gold);
  border-radius: 999px;
  padding: 3px 11px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.6px;
  text-transform: uppercase;
}
.mcm-card--featured .mcm-card-badge {
  background: var(--mcm-gold);
  color: #000;
  border-color: var(--mcm-gold);
}
.mcm-card-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 6px;
}
.mcm-card-price {
  font-size: 18px;
  font-weight: 900;
  color: var(--mcm-title);
}
.mcm-card-compare {
  font-size: 12.5px;
  color: var(--mcm-muted);
  text-decoration: line-through;
}
.mcm-card-save {
  font-size: 10.5px;
  font-weight: 700;
  color: #16a34a;
  background: rgba(22,163,74,0.1);
  border-radius: 999px;
  padding: 2px 8px;
}

/* Title */
.mcm-card-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.25rem, 3.5vw, 1.6rem);
  font-weight: 700;
  color: var(--mcm-title);
  line-height: 1.2;
  margin: 0;
}

/* Description */
.mcm-card-desc {
  font-size: 13px;
  color: var(--mcm-text);
  line-height: 1.6;
  margin: 0;
}

/* Tags row */
.mcm-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 2px;
}
.mcm-card-tag {
  font-size: 11px;
  font-weight: 600;
  color: var(--mcm-muted);
  background: var(--mcm-bg);
  border: 1px solid var(--mcm-border);
  border-radius: 999px;
  padding: 3px 10px;
}

/* CTA row */
.mcm-card-cta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6px;
  padding-top: 14px;
  border-top: 1px solid var(--mcm-border);
  gap: 10px;
}
.mcm-card-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #111;
  color: #F4B400;
  font-weight: 800;
  font-size: 12.5px;
  padding: 10px 20px;
  border-radius: 999px;
  transition: background .18s, transform .18s;
}
[data-theme="dark"] .mcm-card-cta-btn {
  background: #F4B400;
  color: #000;
}
.mcm-card:hover .mcm-card-cta-btn {
  transform: translateX(3px);
}
.mcm-card-cta-note {
  font-size: 11px;
  color: var(--mcm-muted);
  display: flex;
  align-items: center;
  gap: 4px;
}

/* Thumbnail — small, optional, right side */
.mcm-card-thumb {
  width: 90px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px 12px 16px 0;
}
@media(max-width:480px){ .mcm-card-thumb { display: none; } }
.mcm-card-thumb img {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: 12px;
  border: 1px solid var(--mcm-border);
}
.mcm-card-thumb-placeholder {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 12px;
  border: 1px solid rgba(244,180,0,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
}

/* ── Empty ── */
.mcm-empty { text-align: center; padding: 60px 20px; color: var(--mcm-muted); }

/* ── Bottom CTA ── */
.mcm-bottom-cta {
  max-width: 900px;
  margin: 48px auto 0;
  padding: 0 16px;
}
.mcm-bottom-inner {
  background: linear-gradient(135deg, #0d0d0d, #1a1a2e);
  border-radius: 22px;
  border: 1px solid rgba(244,180,0,0.18);
  padding: 40px 28px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.mcm-bottom-inner::before {
  content: '';
  position: absolute;
  top: -50px; left: 50%;
  transform: translateX(-50%);
  width: 260px; height: 260px;
  background: radial-gradient(circle, rgba(244,180,0,0.12) 0%, transparent 70%);
  pointer-events: none;
}
.mcm-bottom-tag {
  display: inline-block;
  background: rgba(244,180,0,0.12);
  color: #F4B400;
  border: 1px solid rgba(244,180,0,0.25);
  border-radius: 999px;
  padding: 3px 13px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 14px;
}
.mcm-bottom-h { font-family: 'Playfair Display', serif; font-size: clamp(1.4rem, 4vw, 2rem); color: #fff; margin: 0 0 8px; }
.mcm-bottom-h em { color: #F4B400; font-style: italic; }
.mcm-bottom-p { font-size: 13px; color: rgba(255,255,255,0.5); max-width: 380px; margin: 0 auto 24px; line-height: 1.6; }
.mcm-bottom-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #F4B400;
  color: #000;
  font-weight: 800;
  font-size: 13.5px;
  padding: 13px 26px;
  border-radius: 999px;
  text-decoration: none;
  box-shadow: 0 4px 20px rgba(244,180,0,0.38);
  transition: transform .18s, box-shadow .18s;
}
.mcm-bottom-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(244,180,0,0.5); }
</style>

<div class="mcm-page">

  <!-- Hero -->
  <div class="mcm-hero">
    <div class="mcm-eyebrow">✦ Personalised Gifts</div>
    <h1 class="mcm-hero-h1">Custom <em>Magazine</em><br>Made For You</h1>
    <p class="mcm-hero-p">Turn your photos & memories into a stunning printed magazine. Professional design, fast delivery.</p>
    <a href="/pages/magazine-builder" class="mcm-hero-btn">✦ Start Creating Now</a>
  </div>

  <!-- Steps -->
  <div class="mcm-steps">
    <div class="mcm-step"><div class="mcm-step-n">1</div><div class="mcm-step-t">Pick a Style</div><div class="mcm-step-d">Choose your cover theme</div></div>
    <div class="mcm-step"><div class="mcm-step-n">2</div><div class="mcm-step-t">Send Photos</div><div class="mcm-step-d">Share your memories</div></div>
    <div class="mcm-step"><div class="mcm-step-n">3</div><div class="mcm-step-t">We Design</div><div class="mcm-step-d">Ready in ~20 minutes</div></div>
    <div class="mcm-step"><div class="mcm-step-n">4</div><div class="mcm-step-t">Delivered</div><div class="mcm-step-d">Printed to your door</div></div>
  </div>

  {%- if collection.products_count > 0 -%}

    <div class="mcm-label-row">
      <span class="mcm-label">Choose Your Package</span>
      <div class="mcm-label-line"></div>
    </div>

    <div class="mcm-cards">
      {%- for product in collection.products -%}
        {%- assign is_featured = false -%}
        {%- if forloop.index == 1 -%}{%- assign is_featured = true -%}{%- endif -%}

        {%- assign save_amt = 0 -%}
        {%- if product.compare_at_price > product.price -%}
          {%- assign save_amt = product.compare_at_price | minus: product.price -%}
        {%- endif -%}

        <a href="{{ product.url }}" class="mcm-card{% if is_featured %} mcm-card--featured{% endif %}">
          <div class="mcm-card-strip"></div>
          <div class="mcm-card-body">

            <!-- Top: badge + price -->
            <div class="mcm-card-top">
              <div class="mcm-card-badge">
                {%- if is_featured -%}⭐ Most Popular{%- else -%}✦ Custom Design{%- endif -%}
              </div>
              <div class="mcm-card-price-wrap">
                <span class="mcm-card-price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="mcm-card-compare">{{ product.compare_at_price | money }}</span>
                  <span class="mcm-card-save">Save {{ save_amt | money }}</span>
                {%- endif -%}
              </div>
            </div>

            <!-- Title -->
            <h2 class="mcm-card-title">{{ product.title }}</h2>

            <!-- Description -->
            {%- if product.description != blank -%}
              <p class="mcm-card-desc">{{ product.description | strip_html | truncate: 120 }}</p>
            {%- endif -%}

            <!-- Tags -->
            {%- if product.tags.size > 0 -%}
              <div class="mcm-card-tags">
                {%- for tag in product.tags limit: 4 -%}
                  <span class="mcm-card-tag">{{ tag }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <!-- CTA -->
            <div class="mcm-card-cta-row">
              <span class="mcm-card-cta-btn">
                Select Package
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
              <span class="mcm-card-cta-note">⚡ ~20 min design</span>
            </div>
          </div>

          <!-- Thumbnail (small, right side) -->
          <div class="mcm-card-thumb">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 160 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">
            {%- else -%}
              <div class="mcm-card-thumb-placeholder">📰</div>
            {%- endif -%}
          </div>
        </a>

      {%- endfor -%}
    </div>

  {%- else -%}
    <div class="mcm-empty">
      <div style="font-size:44px;margin-bottom:12px">📰</div>
      <div style="font-size:16px;font-weight:700;color:var(--mcm-title);margin-bottom:6px">Packages coming soon</div>
      <p>Start your custom magazine directly in the meantime.</p>
    </div>
  {%- endif -%}

  <!-- Bottom CTA -->
  <div class="mcm-bottom-cta">
    <div class="mcm-bottom-inner">
      <div class="mcm-bottom-tag">✦ Ready to Begin?</div>
      <h2 class="mcm-bottom-h">Create Your <em>Story</em> Today</h2>
      <p class="mcm-bottom-p">A custom magazine is the most personal gift — birthdays, anniversaries, graduations, or just because.</p>
      <a href="/pages/magazine-builder" class="mcm-bottom-btn">Start Building Now ↗</a>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Magazine Collection",
  "settings": [],
  "presets": [{ "name": "Magazine Collection" }]
}
{% endschema %}
