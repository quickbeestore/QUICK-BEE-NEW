{% comment %}
  sections/qb-account-dashboard.liquid — QuickBee My Account
  All data lives in localStorage. No Shopify login required.
  Profile · Order History · Saved Location · Settings
{% endcomment %}

<style>
/* ══════════════════════════════════════════════════════
   TOKENS
══════════════════════════════════════════════════════ */
html[data-theme="dark"] {
  --ac-bg:         #0a0a0a; --ac-bg2: #141414; --ac-bg3: #222222;
  --ac-card:       #161616; --ac-card2: #1e1e1e;
  --ac-border:     rgba(255,255,255,0.09); --ac-border2: rgba(255,255,255,0.15);
  --ac-text:       #f2f2f2; --ac-text2: #999; --ac-text3: #555;
  --ac-gold:       #F4B400; --ac-gold2: #FFD700; --ac-gold-dim: rgba(244,180,0,0.13);
  --ac-green:      #22c55e; --ac-green-dim: rgba(34,197,94,0.10);
  --ac-red:        #FF4444; --ac-red-dim: rgba(255,68,68,0.10);
  --ac-blue:       #60a5fa; --ac-blue-dim: rgba(96,165,250,0.10);
  --ac-shadow:     0 2px 20px rgba(0,0,0,0.55);
  --ac-shadow-lg:  0 16px 60px rgba(0,0,0,0.85);
  --ac-inp-bg:     #252525;
  --ac-inp-border: rgba(255,255,255,0.13);
  --ac-hero-bg:    linear-gradient(155deg, #0c0c0c 0%, #1c1400 55%, #0c0c0c 100%);
  --ac-hero-text:  #fff;
  --ac-hero-sub:   rgba(255,255,255,0.4);
  --ac-hero-tag:   rgba(255,255,255,0.45);
  --ac-strip-bg:   rgba(255,255,255,0.06);
  --ac-strip-bdr:  rgba(255,255,255,0.08);
  --ac-strip-bar:  rgba(255,255,255,0.1);
  --ac-strip-line: rgba(255,255,255,0.06);
}
html:not([data-theme="dark"]) {
  --ac-bg:         #f4f5f8; --ac-bg2: #fff; --ac-bg3: #eef0f4;
  --ac-card:       #fff; --ac-card2: #f8f9fb;
  --ac-border:     rgba(15,23,42,0.08); --ac-border2: rgba(15,23,42,0.14);
  --ac-text:       #0f172a; --ac-text2: #64748b; --ac-text3: #94a3b8;
  --ac-gold:       #D4900A; --ac-gold2: #E8A820; --ac-gold-dim: rgba(212,144,10,0.10);
  --ac-green:      #16a34a; --ac-green-dim: rgba(22,163,74,0.08);
  --ac-red:        #EF4444; --ac-red-dim: rgba(239,68,68,0.08);
  --ac-blue:       #3b82f6; --ac-blue-dim: rgba(59,130,246,0.08);
  --ac-shadow:     0 2px 16px rgba(15,23,42,0.07);
  --ac-shadow-lg:  0 16px 60px rgba(15,23,42,0.12);
  --ac-inp-bg:     #f4f5f8;
  --ac-inp-border: rgba(15,23,42,0.10);
  --ac-hero-bg:    linear-gradient(155deg, #1a0f00 0%, #3d2000 55%, #1a0f00 100%);
  --ac-hero-text:  #fff;
  --ac-hero-sub:   rgba(255,255,255,0.5);
  --ac-hero-tag:   rgba(255,255,255,0.55);
  --ac-strip-bg:   rgba(255,255,255,0.12);
  --ac-strip-bdr:  rgba(255,255,255,0.15);
  --ac-strip-bar:  rgba(255,255,255,0.25);
  --ac-strip-line: rgba(255,255,255,0.1);
}

/* ══════════════════════════════════════════════════════
   ROOT
══════════════════════════════════════════════════════ */
.qb-ac {
  background: var(--ac-bg);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  padding-bottom: 60px;
}

/* ══════════════════════════════════════════════════════
   HERO BANNER
══════════════════════════════════════════════════════ */
.qb-ac-hero {
  background: var(--ac-hero-bg);
  padding: 28px 20px 24px;
  position: relative;
  overflow: hidden;
}
.qb-ac-hero::before {
  content:''; position:absolute; top:-80px; right:-60px;
  width:260px; height:260px;
  background:radial-gradient(circle,rgba(244,180,0,.18) 0%,transparent 70%);
  pointer-events:none;
}
.qb-ac-hero-top { display:flex; align-items:center; gap:16px; margin-bottom:20px; }

/* Avatar with completion ring */
.qb-ac-avatar-wrap { position:relative; flex-shrink:0; }
.qb-ac-avatar-ring {
  position:absolute; inset:-4px;
  border-radius:50%;
  background: conic-gradient(#F4B400 0deg, #F4B400 var(--ring-deg, 0deg), var(--ac-strip-bdr) var(--ring-deg, 0deg));
  z-index:0;
}
.qb-ac-avatar {
  position:relative; z-index:1;
  width:62px; height:62px; border-radius:50%;
  background:linear-gradient(135deg,#F4B400,#FFD700);
  display:flex; align-items:center; justify-content:center;
  font-size:22px; font-weight:900; color:#000;
  border:3px solid transparent;
}
.qb-ac-hero-info { flex:1; min-width:0; }
.qb-ac-greeting  { font-size:12px; color:var(--ac-hero-sub); margin-bottom:3px; }
.qb-ac-name      { font-size:19px; font-weight:900; color:var(--ac-hero-text); margin-bottom:2px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.qb-ac-phone-tag { font-size:12px; color:var(--ac-hero-tag); }

/* Completion bar */
.qb-ac-completion {
  background:var(--ac-strip-bg); border:1px solid var(--ac-strip-bdr);
  border-radius:14px; padding:12px 16px;
  display:flex; align-items:center; gap:12px;
}
.qb-ac-comp-bar-wrap { flex:1; height:6px; background:var(--ac-strip-bar); border-radius:3px; overflow:hidden; }
.qb-ac-comp-bar {
  height:100%; border-radius:3px;
  background:linear-gradient(90deg,#F4B400,#FFD700);
  transition:width .6s cubic-bezier(.175,.885,.32,1.275);
  width:0%;
}
.qb-ac-comp-pct { font-size:13px; font-weight:900; color:#F4B400; flex-shrink:0; }
.qb-ac-comp-lbl { font-size:11px; color:var(--ac-hero-sub); }

/* Stats strip */
.qb-ac-stats {
  display:flex; gap:0;
  background:var(--ac-strip-bg); border:1px solid var(--ac-strip-bdr);
  border-radius:14px; overflow:hidden; margin-top:14px;
}
.qb-ac-stat { flex:1; text-align:center; padding:11px 8px; border-right:1px solid var(--ac-strip-line); }
.qb-ac-stat:last-child { border-right:none; }
.qb-ac-stat-v { font-size:18px; font-weight:900; color:#F4B400; display:block; }
.qb-ac-stat-l { font-size:10px; color:var(--ac-hero-sub); text-transform:uppercase; letter-spacing:.4px; }

/* ══════════════════════════════════════════════════════
   BODY / CARDS
══════════════════════════════════════════════════════ */
.qb-ac-body { padding:14px 14px 0; max-width:600px; margin:0 auto; display:flex; flex-direction:column; gap:12px; }

.qb-ac-card {
  background:var(--ac-card); border:1px solid var(--ac-border);
  border-radius:20px; overflow:hidden; box-shadow:var(--ac-shadow);
}

/* Card header */
.qb-ac-card-hdr {
  display:flex; align-items:center; justify-content:space-between;
  padding:15px 18px 13px; border-bottom:1px solid var(--ac-border);
}
.qb-ac-card-title { display:flex; align-items:center; gap:8px; font-size:14px; font-weight:800; color:var(--ac-text); }
.qb-ac-card-action { font-size:12px; font-weight:700; color:var(--ac-gold); cursor:pointer; -webkit-tap-highlight-color:transparent; }

/* ══════════════════════════════════════════════════════
   PROFILE — SAVED VIEW
══════════════════════════════════════════════════════ */
.qb-ac-prow {
  display:flex; align-items:center; gap:12px;
  padding:11px 18px; border-bottom:1px solid var(--ac-border);
  animation: acRowIn .3s ease both;
}
.qb-ac-prow:last-child { border-bottom:none; }
@keyframes acRowIn { from{opacity:0;transform:translateX(-6px)} to{opacity:1;transform:none} }
.qb-ac-prow-icon { font-size:16px; flex-shrink:0; width:22px; text-align:center; }
.qb-ac-prow-lbl  { font-size:11px; color:var(--ac-text3); min-width:74px; flex-shrink:0; text-transform:uppercase; letter-spacing:.5px; }
.qb-ac-prow-val  { font-size:13.5px; font-weight:700; color:var(--ac-text); flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.qb-ac-prow-val.missing { color:var(--ac-text3); font-weight:400; font-style:italic; }

/* ══════════════════════════════════════════════════════
   PROFILE — FORM VIEW
══════════════════════════════════════════════════════ */
.qb-ac-form { padding:16px 18px 20px; display:flex; flex-direction:column; gap:15px; }

.qb-ac-field {}
.qb-ac-flabel {
  font-size:10.5px; font-weight:800; text-transform:uppercase;
  letter-spacing:.7px; color:var(--ac-text2); margin-bottom:7px;
  display:flex; align-items:center; gap:5px;
}
.qb-ac-req { color:var(--ac-gold); }
.qb-ac-opt { font-weight:400; text-transform:none; letter-spacing:0; color:var(--ac-text3); font-size:10px; }

.qb-ac-inp-wrap {
  display:flex; align-items:center; gap:10px;
  background: var(--ac-inp-bg) !important;
  border: 1.5px solid var(--ac-inp-border) !important;
  border-radius:14px; padding:13px 15px;
  transition:border-color .2s, background .2s;
  position: relative;
}
html[data-theme="dark"] .qb-ac-inp-wrap {
  background: #252525 !important;
  border-color: rgba(255,255,255,0.10) !important;
}
html[data-theme="dark"] .qb-ac-inp-wrap:focus-within {
  border-color: rgba(244,180,0,0.55) !important;
  background: #252525 !important;
}
.qb-ac-inp-wrap:focus-within { border-color: rgba(244,180,0,.6) !important; background: var(--ac-bg2) !important; }
.qb-ac-inp-wrap.error { border-color: var(--ac-red) !important; background: var(--ac-red-dim) !important; }
.qb-ac-inp-icon { font-size:16px; flex-shrink:0; }
.qb-ac-inp {
  flex: 1;
  border: none !important;
  outline: none !important;
  box-shadow: none !important;
  -webkit-box-shadow: none !important;
  -webkit-appearance: none !important;
  appearance: none !important;
  font-size: 15px; font-weight: 600;
  color: var(--ac-text) !important;
  -webkit-text-fill-color: var(--ac-text) !important;
  font-family: inherit; min-width: 0;
  caret-color: var(--ac-gold);
  background: #252525 !important;
}
html:not([data-theme="dark"]) .qb-ac-inp {
  background: #f4f5f8 !important;
}
.qb-ac-inp:focus,
.qb-ac-inp:active,
.qb-ac-inp:hover {
  border: none !important;
  outline: none !important;
  box-shadow: none !important;
  -webkit-box-shadow: none !important;
}
.qb-ac-inp::placeholder {
  color: var(--ac-text3) !important;
  -webkit-text-fill-color: var(--ac-text3) !important;
  opacity: 1 !important;
  font-weight: 400;
}
.qb-ac-inp:-webkit-autofill,
.qb-ac-inp:-webkit-autofill:hover,
.qb-ac-inp:-webkit-autofill:focus {
  -webkit-text-fill-color: var(--ac-text) !important;
  -webkit-box-shadow: 0 0 0 1000px #252525 inset !important;
  transition: background-color 99999s ease-in-out 0s;
}
html:not([data-theme="dark"]) .qb-ac-inp:-webkit-autofill,
html:not([data-theme="dark"]) .qb-ac-inp:-webkit-autofill:hover,
html:not([data-theme="dark"]) .qb-ac-inp:-webkit-autofill:focus {
  -webkit-box-shadow: 0 0 0 1000px #f4f5f8 inset !important;
}
html[data-theme="dark"] .qb-ac-inp[type="date"]::-webkit-calendar-picker-indicator {
  filter: invert(0.6);
  opacity: 0.5;
  cursor: pointer;
}
/* Date picker text color */
html[data-theme="dark"] .qb-ac-inp[type="date"]::-webkit-datetime-edit,
html[data-theme="dark"] .qb-ac-inp[type="date"]::-webkit-datetime-edit-fields-wrapper,
html[data-theme="dark"] .qb-ac-inp[type="date"]::-webkit-datetime-edit-text,
html[data-theme="dark"] .qb-ac-inp[type="date"]::-webkit-datetime-edit-day-field,
html[data-theme="dark"] .qb-ac-inp[type="date"]::-webkit-datetime-edit-month-field,
html[data-theme="dark"] .qb-ac-inp[type="date"]::-webkit-datetime-edit-year-field {
  color: var(--ac-text) !important;
  -webkit-text-fill-color: var(--ac-text) !important;
}

/* Pill groups */
.qb-ac-pills { display:flex; gap:8px; flex-wrap:wrap; }
.qb-ac-pill {
  padding:9px 14px; border-radius:12px;
  border: 1.5px solid var(--ac-border) !important;
  background: var(--ac-bg3) !important;
  color: var(--ac-text2) !important;
  -webkit-text-fill-color: var(--ac-text2) !important;
  font-size:13px; font-weight:700;
  cursor:pointer; transition:all .18s; -webkit-tap-highlight-color:transparent;
  font-family:inherit; white-space:nowrap;
}
.qb-ac-pill.sel {
  border-color: var(--ac-gold) !important;
  background: var(--ac-gold-dim) !important;
  color: var(--ac-gold) !important;
  -webkit-text-fill-color: var(--ac-gold) !important;
}

/* Two-col row */
.qb-ac-form-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }

/* Save btn */
.qb-ac-save-btn {
  display:flex; align-items:center; justify-content:center; gap:8px;
  width:100%; padding:15px; border-radius:14px; border:none;
  background:var(--ac-gold); color:#000;
  font-size:15px; font-weight:900; cursor:pointer;
  font-family:inherit; -webkit-tap-highlight-color:transparent;
  transition:all .2s; box-shadow:0 4px 18px rgba(244,180,0,.3);
  margin-top:4px;
}
.qb-ac-save-btn:active { transform:scale(.97); box-shadow:none; }
@keyframes acSavedFlash {
  0%{background:#22c55e;box-shadow:0 0 0 4px rgba(34,197,94,.3)}
  100%{background:var(--ac-gold);box-shadow:0 4px 18px rgba(244,180,0,.3)}
}
.qb-ac-save-btn.saved { animation:acSavedFlash .45s ease-out forwards; }

/* Cancel link */
.qb-ac-cancel-link {
  background:none; border:none; color:var(--ac-text2); font-size:13px;
  font-weight:600; cursor:pointer; padding:4px 0; font-family:inherit;
  text-align:center; display:block; width:100%; -webkit-tap-highlight-color:transparent;
}

/* ══════════════════════════════════════════════════════
   LOCATION
══════════════════════════════════════════════════════ */
.qb-ac-loc-item { display:flex; align-items:flex-start; gap:12px; padding:14px 18px; border-bottom:1px solid var(--ac-border); }
.qb-ac-loc-item:last-child { border-bottom:none; }
.qb-ac-loc-ico { width:38px; height:38px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; background:var(--ac-gold-dim); }
.qb-ac-loc-body { flex:1; min-width:0; }
.qb-ac-loc-name-row { display:flex; align-items:center; gap:6px; margin-bottom:3px; }
.qb-ac-loc-name { font-size:13.5px; font-weight:800; color:var(--ac-text); }
.qb-ac-loc-badge { font-size:9px; font-weight:800; background:var(--ac-gold); color:#000; padding:2px 7px; border-radius:8px; text-transform:uppercase; }
.qb-ac-loc-addr { font-size:12px; color:var(--ac-text2); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.qb-ac-loc-sub  { font-size:11px; color:var(--ac-text3); margin-top:2px; }
.qb-ac-loc-btns { display:flex; gap:8px; margin-top:9px; }
.qb-ac-loc-btn  { font-size:11.5px; font-weight:700; padding:5px 12px; border-radius:10px; border:1.5px solid var(--ac-border); background:var(--ac-bg3); color:var(--ac-text2); cursor:pointer; -webkit-tap-highlight-color:transparent; text-decoration:none; transition:all .18s; }
.qb-ac-loc-btn.pri { background:var(--ac-gold-dim); border-color:rgba(244,180,0,.3); color:var(--ac-gold); }

/* ══════════════════════════════════════════════════════
   ORDER HISTORY
══════════════════════════════════════════════════════ */
.qb-ac-order {
  display:flex; align-items:center; gap:12px;
  padding:13px 18px; border-bottom:1px solid var(--ac-border);
  cursor:pointer; -webkit-tap-highlight-color:transparent;
  transition:background .15s; animation:acRowIn .3s ease both;
}
.qb-ac-order:last-child { border-bottom:none; }
.qb-ac-order:active { background:var(--ac-bg3); }
.qb-ac-order-ico { width:42px; height:42px; border-radius:13px; background:var(--ac-bg3); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
.qb-ac-order-body { flex:1; min-width:0; }
.qb-ac-order-name { font-size:13px; font-weight:700; color:var(--ac-text); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; margin-bottom:2px; }
.qb-ac-order-meta { font-size:11.5px; color:var(--ac-text2); }
.qb-ac-order-r { text-align:right; flex-shrink:0; }
.qb-ac-order-price { font-size:14px; font-weight:900; color:var(--ac-text); }
.qb-ac-order-status { font-size:9.5px; font-weight:800; padding:3px 8px; border-radius:8px; margin-top:3px; display:inline-block; text-transform:uppercase; letter-spacing:.3px; }
.st-delivered { background:var(--ac-green-dim); color:var(--ac-green); }
.st-processing { background:var(--ac-gold-dim); color:var(--ac-gold); }
.st-placed    { background:var(--ac-blue-dim); color:var(--ac-blue); }

/* Reorder button */
.qb-ac-reorder {
  display:inline-flex; align-items:center; gap:5px;
  background:var(--ac-gold-dim); border:1px solid rgba(244,180,0,.25);
  color:var(--ac-gold); font-size:11px; font-weight:800;
  padding:4px 10px; border-radius:9px; cursor:pointer;
  -webkit-tap-highlight-color:transparent; transition:all .18s;
  margin-top:4px; font-family:inherit;
}
.qb-ac-reorder:active { transform:scale(.95); }

/* ══════════════════════════════════════════════════════
   DELIVERY PREFS
══════════════════════════════════════════════════════ */
.qb-ac-pref-row { display:flex; align-items:center; justify-content:space-between; padding:13px 18px; border-bottom:1px solid var(--ac-border); }
.qb-ac-pref-row:last-child { border-bottom:none; }
.qb-ac-pref-l { display:flex; align-items:center; gap:10px; }
.qb-ac-pref-ico { font-size:18px; }
.qb-ac-pref-lbl { font-size:13.5px; font-weight:700; color:var(--ac-text); }
.qb-ac-pref-sub { font-size:11.5px; color:var(--ac-text2); margin-top:1px; }
.qb-ac-pref-val { font-size:13px; font-weight:700; color:var(--ac-gold); background:var(--ac-gold-dim); padding:5px 12px; border-radius:10px; }

/* ══════════════════════════════════════════════════════
   QUICK LINKS
══════════════════════════════════════════════════════ */
.qb-ac-links { display:grid; grid-template-columns:1fr 1fr; gap:10px; padding:14px; }
.qb-ac-link { display:flex; align-items:center; gap:10px; padding:13px 14px; background:var(--ac-card2); border:1px solid var(--ac-border); border-radius:14px; text-decoration:none; cursor:pointer; -webkit-tap-highlight-color:transparent; transition:all .18s; }
.qb-ac-link:active { transform:scale(.97); }
.qb-ac-link-ico { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
.qb-ac-link-txt { font-size:12.5px; font-weight:700; color:var(--ac-text); line-height:1.3; }
.qb-ac-link-sub { font-size:10.5px; color:var(--ac-text2); margin-top:1px; }

/* ══════════════════════════════════════════════════════
   SETTINGS
══════════════════════════════════════════════════════ */
.qb-ac-setting { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid var(--ac-border); cursor:pointer; -webkit-tap-highlight-color:transparent; transition:background .15s; }
.qb-ac-setting:last-child { border-bottom:none; }
.qb-ac-setting:active { background:var(--ac-bg3); }
.qb-ac-setting-l { display:flex; align-items:center; gap:12px; }
.qb-ac-setting-ico { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:18px; }
.qb-ac-setting-lbl { font-size:14px; font-weight:700; color:var(--ac-text); }
.qb-ac-setting-sub { font-size:11.5px; color:var(--ac-text2); margin-top:1px; }
.qb-ac-chevron { color:var(--ac-text3); }

/* Toggle */
.qb-ac-toggle { width:44px; height:26px; background:var(--ac-bg3); border-radius:13px; position:relative; cursor:pointer; transition:background .2s; flex-shrink:0; border:none; -webkit-tap-highlight-color:transparent; }
.qb-ac-toggle.on { background:var(--ac-gold); }
.qb-ac-toggle::after { content:''; position:absolute; top:3px; left:3px; width:20px; height:20px; border-radius:50%; background:#fff; transition:transform .25s cubic-bezier(.175,.885,.32,1.275); box-shadow:0 2px 6px rgba(0,0,0,.2); }
.qb-ac-toggle.on::after { transform:translateX(18px); }

/* App buttons */
.qb-ac-app-row { display:flex; gap:10px; padding:14px 18px; }
.qb-ac-app-btn { flex:1; display:flex; align-items:center; justify-content:center; gap:7px; padding:11px 14px; background:var(--ac-bg3); border:1px solid var(--ac-border); border-radius:12px; text-decoration:none; font-size:12px; font-weight:800; color:var(--ac-text); -webkit-tap-highlight-color:transparent; transition:all .18s; }
.qb-ac-app-btn:active { transform:scale(.97); }

/* Empty / no-data */
.qb-ac-empty { display:flex; flex-direction:column; align-items:center; padding:32px 20px; gap:9px; text-align:center; }
.qb-ac-empty-ico { font-size:40px; }
.qb-ac-empty-txt { font-size:14px; font-weight:700; color:var(--ac-text); }
.qb-ac-empty-sub { font-size:12.5px; color:var(--ac-text2); }

/* Search history items */
.qb-ac-search-row {
  display:flex; align-items:center; gap:12px;
  padding:11px 18px; border-bottom:1px solid var(--ac-border);
  cursor:pointer; -webkit-tap-highlight-color:transparent;
  transition:background .15s;
}
.qb-ac-search-row:last-child { border-bottom:none; }
.qb-ac-search-row:active { background:var(--ac-bg3); }
.qb-ac-search-ico { font-size:16px; width:36px; height:36px; border-radius:11px; background:var(--ac-bg3); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.qb-ac-search-body { flex:1; min-width:0; }
.qb-ac-search-term { font-size:13.5px; font-weight:700; color:var(--ac-text); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.qb-ac-search-meta { font-size:11.5px; color:var(--ac-text2); margin-top:1px; }
.qb-ac-search-freq { font-size:11px; font-weight:800; background:var(--ac-gold-dim); color:var(--ac-gold); padding:3px 8px; border-radius:8px; flex-shrink:0; }

/* Version */
.qb-ac-ver { text-align:center; font-size:11px; color:var(--ac-text3); padding:14px 0 4px; }
</style>

