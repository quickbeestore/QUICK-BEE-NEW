<script>
(function () {
  'use strict';

  /* ── helpers ── */
  var ls = {
    get:  function(k)    { try { return localStorage.getItem(k); }           catch(e) { return null; } },
    set:  function(k,v)  { try { localStorage.setItem(k, v); }               catch(e) {} },
    rm:   function(k)    { try { localStorage.removeItem(k); }               catch(e) {} },
    json: function(k)    { try { var s=localStorage.getItem(k); return s?JSON.parse(s):null; } catch(e){return null;} }
  };

  function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  function fmtDate(iso) {
    if(!iso) return '—';
    try { return new Date(iso).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}); }
    catch(e){ return iso; }
  }

  function fmtMoney(n) {
    return 'Rs ' + Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g,',');
  }

  /* ═══════════════════════════════════════════
     PROFILE
  ═══════════════════════════════════════════ */
  var PROF_FIELDS = [
    { key:'name',        icon:'🙍', label:'Name',         weight:20 },
    { key:'phone',       icon:'📞', label:'Phone',        weight:20 },
    { key:'email',       icon:'✉️', label:'Email',        weight:10 },
    { key:'dob',         icon:'🎂', label:'Birthday',     weight:10 },
    { key:'gender',      icon:'🙋', label:'Gender',       weight:10 },
    { key:'nationality', icon:'🌍', label:'Nationality',  weight:10 },
    { key:'citizen',     icon:'🪪', label:'Citizenship',  weight:10 },
    { key:'deliveryPref',icon:'🚪', label:'Delivery Pref',weight:10 },
  ];

  var selectedGender  = '';
  var selectedDelPref = '';

  /* UI elements */
  var savedDiv   = document.getElementById('qbAcProfSaved');
  var formDiv    = document.getElementById('qbAcProfForm');
  var editBtn    = document.getElementById('qbAcEditBtn');
  var cancelBtn  = document.getElementById('qbCancelBtn');
  var saveBtn    = document.getElementById('qbSaveBtn');

  function completion(prof) {
    if(!prof) return 0;
    var score = 0, total = 0;
    PROF_FIELDS.forEach(function(f){
      total += f.weight;
      if(prof[f.key]) score += f.weight;
    });
    return Math.round(score/total*100);
  }

  function renderHero(prof) {
    var pct    = completion(prof);
    var bar    = document.getElementById('qbAcCompBar');
    var pctEl  = document.getElementById('qbAcCompPct');
    var lblEl  = document.getElementById('qbAcCompLbl');
    var nameEl = document.getElementById('qbAcName');
    var subtEl = document.getElementById('qbAcSubtitle');
    var avEl   = document.getElementById('qbAcAvatar');
    var ring   = document.getElementById('qbAcRing');

    if(bar)   bar.style.width = pct+'%';
    if(pctEl) pctEl.textContent = pct+'%';
    if(lblEl) lblEl.textContent = pct===100 ? '✓ Profile complete!' : 'Profile '+pct+'% complete';
    if(ring)  ring.style.setProperty('--ring-deg', Math.round(pct*3.6)+'deg');

    if(prof && prof.name) {
      if(nameEl) nameEl.textContent = prof.name;
      if(avEl)   avEl.textContent   = prof.name.split(' ').map(function(w){return w[0];}).join('').toUpperCase().slice(0,2);
    }
    if(prof && prof.phone && subtEl) subtEl.textContent = prof.phone + (prof.nationality ? ' · '+prof.nationality : '');
  }

  function renderSaved(prof) {
    var rows = PROF_FIELDS.map(function(f, i){
      var val = prof[f.key];
      var display = val
        ? (f.key==='dob' ? fmtDate(val) : esc(val))
        : '<span class="qb-ac-prow-val missing">Not set</span>';
      return '<div class="qb-ac-prow" style="animation-delay:'+(i*.04)+'s">'
        +'<span class="qb-ac-prow-icon">'+f.icon+'</span>'
        +'<span class="qb-ac-prow-lbl">'+f.label+'</span>'
        +(val ? '<span class="qb-ac-prow-val">'+display+'</span>' : display)
        +'</div>';
    }).join('');
    savedDiv.innerHTML = rows;
    savedDiv.style.display = '';
    formDiv.style.display  = 'none';
    editBtn.style.display  = '';
    cancelBtn.style.display= 'none';
  }

  function showForm(prefill) {
    savedDiv.style.display = 'none';
    formDiv.style.display  = '';
    editBtn.style.display  = 'none';
    cancelBtn.style.display= prefill ? '' : 'none';

    if(prefill) {
      var fld = function(id){ return document.getElementById(id); };
      if(prefill.name)        { var n=fld('qbFName');        if(n) n.value=prefill.name; }
      if(prefill.phone)       { var p=fld('qbPhone');        if(p) p.value=prefill.phone; }
      if(prefill.email)       { var e=fld('qbEmail');        if(e) e.value=prefill.email; }
      if(prefill.dob)         { var d=fld('qbDob');          if(d) d.value=prefill.dob; }
      if(prefill.nationality) { var na=fld('qbNationality'); if(na) na.value=prefill.nationality; }
      if(prefill.citizen)     { var ci=fld('qbCitizen');     if(ci) ci.value=prefill.citizen; }
      if(prefill.gender) {
        selectedGender = prefill.gender;
        document.querySelectorAll('#qbGenderGroup .qb-ac-pill').forEach(function(p){
          p.classList.toggle('sel', p.getAttribute('data-val')===prefill.gender);
        });
      }
      if(prefill.deliveryPref) {
        selectedDelPref = prefill.deliveryPref;
        document.querySelectorAll('#qbDeliveryPrefGroup .qb-ac-pill').forEach(function(p){
          p.classList.toggle('sel', p.getAttribute('data-val')===prefill.deliveryPref);
        });
      }
    }
  }

  function loadProfile() {
    var prof = ls.json('qb_user_profile');
    renderHero(prof || {});
    if(prof && (prof.name || prof.phone)) { renderSaved(prof); }
    else                                 { showForm(null); }
  }

  /* Pill clicks */
  document.querySelectorAll('#qbGenderGroup .qb-ac-pill').forEach(function(p){
    p.addEventListener('click',function(){
      selectedGender = p.getAttribute('data-val');
      document.querySelectorAll('#qbGenderGroup .qb-ac-pill').forEach(function(x){ x.classList.toggle('sel',x===p); });
    });
  });
  document.querySelectorAll('#qbDeliveryPrefGroup .qb-ac-pill').forEach(function(p){
    p.addEventListener('click',function(){
      selectedDelPref = p.getAttribute('data-val');
      document.querySelectorAll('#qbDeliveryPrefGroup .qb-ac-pill').forEach(function(x){ x.classList.toggle('sel',x===p); });
    });
  });

  /* Save */
  if(saveBtn) {
    saveBtn.addEventListener('click', function(){
      var phone    = (document.getElementById('qbPhone')||{}).value||'';
      var name     = (document.getElementById('qbFName')||{}).value||'';
      var nameInp  = document.getElementById('qbFName');
      var nameWrap = nameInp ? nameInp.closest('.qb-ac-inp-wrap') : null;

      if(!name.trim()) {
        if(nameWrap){ nameWrap.classList.add('error'); setTimeout(function(){ nameWrap.classList.remove('error'); },2200); }
        if(nameInp) nameInp.focus();
        return;
      }
      if(!phone.trim()) {
        var w = document.getElementById('qbPhoneWrap');
        if(w) { w.classList.add('error'); setTimeout(function(){ w.classList.remove('error'); },2200); }
        var ph = document.getElementById('qbPhone');
        if(ph) ph.focus();
        return;
      }

      var prof = {
        name:        (document.getElementById('qbFName')||{}).value||'',
        phone:       phone.trim(),
        email:       (document.getElementById('qbEmail')||{}).value||'',
        dob:         (document.getElementById('qbDob')||{}).value||'',
        gender:      selectedGender,
        nationality: (document.getElementById('qbNationality')||{}).value||'Nepali',
        citizen:     (document.getElementById('qbCitizen')||{}).value||'',
        deliveryPref:selectedDelPref,
        savedAt:     new Date().toISOString()
      };

      ls.set('qb_user_profile', JSON.stringify(prof));

      saveBtn.classList.add('saved');
      saveBtn.textContent = '✓ Profile Saved!';
      setTimeout(function(){
        saveBtn.classList.remove('saved');
        saveBtn.textContent = 'Save Profile ✓';
        renderSaved(prof);
        renderHero(prof);
        syncCartNote(prof);
      }, 900);
    });
  }

  if(editBtn)   editBtn.addEventListener('click',   function(){ var p=ls.json('qb_user_profile'); showForm(p||{}); });
  if(cancelBtn) cancelBtn.addEventListener('click', function(){ loadProfile(); });

  /* ═══════════════════════════════════════════
     LOCATION
  ═══════════════════════════════════════════ */
  function loadLocation() {
    var loc     = ls.json('qb_selected_location');
    var dt      = ls.json('qb_delivery_time');
    var area    = document.getElementById('qbAcLocArea');
    var timeEl  = document.getElementById('qbDeliveryTime');
    var tsEl    = document.getElementById('qbLocTimestamp');
    var statEl  = document.getElementById('qbAcStatLoc');

    if(dt && dt.range && timeEl) timeEl.textContent = dt.range;
    if(loc && loc.timestamp && tsEl) tsEl.textContent = fmtDate(loc.timestamp);

    if(!loc || (!loc.location && !loc.address && !loc.street)) {
      if(area) area.innerHTML = '<div class="qb-ac-empty"><div class="qb-ac-empty-ico">📍</div>'
        +'<div class="qb-ac-empty-txt">No location set</div>'
        +'<div class="qb-ac-empty-sub"><a href="/" style="color:var(--ac-gold);font-weight:700;">Set location →</a></div></div>';
      return;
    }

    var addr  = loc.location || loc.address || loc.street || '';
    var type  = loc.type === 'other' ? '👤 For someone else' : '📡 Live GPS';
    var maps  = loc.landmark_link || (loc.latitude&&loc.longitude ? 'https://www.google.com/maps?q='+loc.latitude+','+loc.longitude : '');

    if(statEl) statEl.textContent = addr.split(',')[0] || '—';

    if(area) area.innerHTML =
      '<div class="qb-ac-loc-item">'
      +'<div class="qb-ac-loc-ico">📍</div>'
      +'<div class="qb-ac-loc-body">'
        +'<div class="qb-ac-loc-name-row"><span class="qb-ac-loc-name">'+esc(addr.split(',')[0])+'</span>'
          +'<span class="qb-ac-loc-badge">Active</span></div>'
        +'<div class="qb-ac-loc-addr">'+esc(addr)+'</div>'
        +'<div class="qb-ac-loc-sub">'+type+'</div>'
        +(loc.name  ? '<div class="qb-ac-loc-sub">👤 '+esc(loc.name)+'</div>' : '')
        +(loc.phone ? '<div class="qb-ac-loc-sub">📞 '+esc(loc.phone)+'</div>' : '')
        +'<div class="qb-ac-loc-btns">'
          +'<span class="qb-ac-loc-btn pri" id="qbLocChangeInner">📍 Change</span>'
          +(maps ? '<a href="'+esc(maps)+'" target="_blank" rel="noopener" class="qb-ac-loc-btn">🗺️ View Map</a>' : '')
        +'</div>'
      +'</div></div>';

    var changeInner = document.getElementById('qbLocChangeInner');
    if(changeInner) changeInner.addEventListener('click', triggerLocModal);
  }

  function triggerLocModal() {
    if(window.QB_MODAL && typeof window.QB_MODAL.show === 'function') window.QB_MODAL.show(false);
    else window.location.href = '/';
  }

  var changeLocBtn = document.getElementById('qbChangeLocBtn');
  if(changeLocBtn) changeLocBtn.addEventListener('click', triggerLocModal);

  /* ═══════════════════════════════════════════
     ORDER HISTORY (localStorage)
  ═══════════════════════════════════════════ */
  function loadLocalOrders() {
    var localEl = document.getElementById('qbOrdersLocal');
    if(!localEl) return; /* Shopify orders already rendered */

    var history = ls.json('qb_order_history') || [];
    var clearBtn = document.getElementById('qbClearOrdersBtn');

    if(history.length === 0) {
      localEl.innerHTML = '<div class="qb-ac-empty">'
        +'<div class="qb-ac-empty-ico">📦</div>'
        +'<div class="qb-ac-empty-txt">No orders yet</div>'
        +'<div class="qb-ac-empty-sub"><a href="/collections" style="color:var(--ac-gold);font-weight:700;">Start shopping →</a></div>'
        +'</div>';
      return;
    }

    if(clearBtn) clearBtn.style.display = '';

    localEl.innerHTML = history.slice(0,8).map(function(o, i){
      var statusCls = o.status==='delivered' ? 'st-delivered' : o.status==='processing' ? 'st-processing' : 'st-placed';
      var statusLbl = o.status==='delivered' ? 'Delivered'    : o.status==='processing' ? 'Processing'    : 'Order Placed';
      return '<div class="qb-ac-order" style="animation-delay:'+(i*.05)+'s">'
        +'<div class="qb-ac-order-ico">🛍️</div>'
        +'<div class="qb-ac-order-body">'
          +'<div class="qb-ac-order-name">'+esc(o.summary||'Order #'+o.id)+'</div>'
          +'<div class="qb-ac-order-meta">'+fmtDate(o.date)+' · '+esc(o.location||'')+'</div>'
          +'<button class="qb-ac-reorder" data-items="'+esc(JSON.stringify(o.items||[]))+'">🔄 Reorder</button>'
        +'</div>'
        +'<div class="qb-ac-order-r">'
          +'<div class="qb-ac-order-price">'+fmtMoney(o.total||0)+'</div>'
          +'<div class="qb-ac-order-status '+statusCls+'">'+statusLbl+'</div>'
        +'</div>'
        +'</div>';
    }).join('');

    /* Update stats */
    var totalSpent = history.reduce(function(sum,o){ return sum+(o.total||0); }, 0);
    var statO = document.getElementById('qbAcStatOrders');
    var statT = document.getElementById('qbAcStatTotal');
    if(statO) statO.textContent = history.length;
    if(statT) statT.textContent = totalSpent > 0 ? fmtMoney(totalSpent) : 'Rs 0';

    /* Reorder buttons */
    localEl.querySelectorAll('.qb-ac-reorder').forEach(function(btn){
      btn.addEventListener('click', function(e){
        e.stopPropagation();
        var items;
        try { items = JSON.parse(btn.getAttribute('data-items')||'[]'); } catch(x){ items=[]; }
        if(!items.length) { window.location.href='/collections'; return; }
        /* Add all items back to cart */
        var adds = items.map(function(it){
          return fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},
            body:JSON.stringify({id:it.variant_id, quantity:it.quantity||1})})
            .catch(function(){});
        });
        Promise.all(adds).then(function(){ window.location.href='/cart'; });
      });
    });
  }

  var clearOrdersBtn = document.getElementById('qbClearOrdersBtn');
  if(clearOrdersBtn) {
    clearOrdersBtn.addEventListener('click', function(){
      if(!confirm('Clear order history? This only removes locally saved history.')) return;
      ls.rm('qb_order_history');
      loadLocalOrders();
    });
  }

  /* ═══════════════════════════════════════════
     SEARCH HISTORY
  ═══════════════════════════════════════════ */
  function loadSearchHistory() {
    var card   = document.getElementById('qbSearchHistoryCard');
    var area   = document.getElementById('qbSearchHistoryArea');
    var clrBtn = document.getElementById('qbClearSearchBtn');
    if(!card || !area) return;

    var recent = [];
    var freq   = {};
    try { recent = JSON.parse(localStorage.getItem('qb_recent_searches') || '[]'); } catch(e){}
    try { freq   = JSON.parse(localStorage.getItem('qb_frequent_searches') || '{}'); } catch(e){}

    if(!recent.length && !Object.keys(freq).length) {
      card.style.display = 'none';
      return;
    }

    card.style.display = '';

    /* Build combined list: recent searches + frequency count */
    var seen = {};
    var rows = [];
    recent.forEach(function(q){
      if(seen[q]) return; seen[q]=true;
      rows.push({ term: q, count: freq[q] || 1 });
    });
    /* Also add any freq entries not in recent */
    Object.keys(freq).forEach(function(q){
      if(seen[q]) return; seen[q]=true;
      rows.push({ term: q, count: freq[q] || 1 });
    });
    rows.sort(function(a,b){ return b.count - a.count; });

    area.innerHTML = rows.slice(0,10).map(function(r, i){
      var badge = r.count > 1
        ? '<span class="qb-ac-search-freq">×'+r.count+'</span>'
        : '';
      return '<div class="qb-ac-search-row" data-search="'+esc(r.term)+'">'
        +'<div class="qb-ac-search-ico">🔍</div>'
        +'<div class="qb-ac-search-body">'
          +'<div class="qb-ac-search-term">'+esc(r.term)+'</div>'
          +'<div class="qb-ac-search-meta">'+(r.count > 1 ? 'Searched '+r.count+' times' : 'Searched recently')+'</div>'
        +'</div>'
        + badge
        +'</div>';
    }).join('');

    /* Click to re-search */
    area.querySelectorAll('[data-search]').forEach(function(row){
      row.addEventListener('click', function(){
        var q = row.getAttribute('data-search');
        if(q) window.location.href = '/search?q=' + encodeURIComponent(q);
      });
    });

    /* Clear button */
    if(clrBtn) {
      clrBtn.addEventListener('click', function(){
        if(!confirm('Clear your search history?')) return;
        ls.rm('qb_recent_searches');
        ls.rm('qb_frequent_searches');
        card.style.display = 'none';
        syncCartNote(ls.json('qb_user_profile') || {});
      });
    }
  }

  /* ═══════════════════════════════════════════
     CART COUNT
  ═══════════════════════════════════════════ */
  var cartEl = document.getElementById('qbCartCount');
  if(cartEl) {
    fetch('/cart.js',{headers:{'X-Requested-With':'XMLHttpRequest'}})
      .then(function(r){return r.json();})
      .then(function(c){ cartEl.textContent=(c.item_count||0)+' items'; })
      .catch(function(){});
  }

  /* ═══════════════════════════════════════════
     SETTINGS TOGGLES
  ═══════════════════════════════════════════ */
  function syncDateColorScheme() {
    var isDark = (document.documentElement.getAttribute('data-theme')||'dark')==='dark';
    document.querySelectorAll('input[type="date"]').forEach(function(el){
      el.style.colorScheme = isDark ? 'dark' : 'light';
    });
  }
  syncDateColorScheme();

  var themeToggle = document.getElementById('qbThemeToggle');
  if(themeToggle) {
    themeToggle.classList.toggle('on', (document.documentElement.getAttribute('data-theme')||'dark')==='dark');
    themeToggle.addEventListener('click', function(){
      var cur  = document.documentElement.getAttribute('data-theme')||'dark';
      var next = cur==='dark'?'light':'dark';
      document.documentElement.setAttribute('data-theme',next);
      ls.set('quickbee-theme',next);
      themeToggle.classList.toggle('on',next==='dark');
      syncDateColorScheme();
    });
  }

  var notifToggle = document.getElementById('qbNotifToggle');
  if(notifToggle) {
    var notifOn = ls.get('qb_notifications')!=='off';
    notifToggle.classList.toggle('on',notifOn);
    notifToggle.addEventListener('click',function(){
      notifOn=!notifOn; notifToggle.classList.toggle('on',notifOn);
      ls.set('qb_notifications',notifOn?'on':'off');
    });
  }

  /* ═══════════════════════════════════════════
     CLEAR ALL DATA
  ═══════════════════════════════════════════ */
  var clearDataRow = document.getElementById('qbClearDataRow');
  if(clearDataRow) {
    clearDataRow.addEventListener('click', function(){
      if(!confirm('Clear ALL QuickBee saved data (profile, location, orders, preferences)? Cannot be undone.')) return;
      ['qb_user_profile','qb_selected_location','qb_delivery_time','qb_notifications',
       'qb_active_nickname','qb_order_history','quickbee-theme',
       'qb_recent_searches','qb_frequent_searches'].forEach(function(k){ ls.rm(k); });
      loadProfile(); loadLocation(); loadLocalOrders(); loadSearchHistory();
      alert('✅ All data cleared.');
    });
  }

  /* ═══════════════════════════════════════════
     SYNC CART NOTE (called on profile save & checkout)
  ═══════════════════════════════════════════ */
  function syncCartNote(prof) {
    var loc     = ls.json('qb_selected_location') || {};
    var recent  = [];
    var freq    = {};
    try { recent = JSON.parse(localStorage.getItem('qb_recent_searches') || '[]'); } catch(e){}
    try { freq   = JSON.parse(localStorage.getItem('qb_frequent_searches') || '{}'); } catch(e){}
    var topFreq = Object.keys(freq).sort(function(a,b){ return freq[b]-freq[a]; }).slice(0,3).join(', ') || 'None';

    var note = [
      '📍 Delivery: '   + (loc.location||loc.address||loc.street||'Not set'),
      '👤 Name: '       + (prof.name     || loc.name  || 'N/A'),
      '📞 Phone: '      + (prof.phone    || loc.phone || 'N/A'),
      '✉️ Email: '      + (prof.email    || 'N/A'),
      '🎂 DOB: '        + (prof.dob      || 'N/A'),
      '🙋 Gender: '     + (prof.gender   || 'N/A'),
      '🌍 Nationality: '+ (prof.nationality || 'N/A'),
      '🪪 Citizenship: '+ (prof.citizen  || 'N/A'),
      '🚪 Delivery Pref: '+(prof.deliveryPref||'N/A'),
      '🔍 Recent Searches: '+(recent.slice(0,5).join(', ')||'None'),
      '📊 Top Searches: '+topFreq,
    ].join('\n');

    fetch('/cart/update.js',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({note:note})}).catch(function(){});
  }

  /* ═══════════════════════════════════════════
     INIT
  ═══════════════════════════════════════════ */
  loadProfile();
  loadLocation();
  loadLocalOrders();
  loadSearchHistory();
})();
</script>
