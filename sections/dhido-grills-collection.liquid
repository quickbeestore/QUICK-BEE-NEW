{%- comment -%}
  The Dhido & The Grills — Premium Food Collection v2
  Swiggy-style horizontal menu cards · Dark green × Gold
{%- endcomment -%}

{%- liquid
  assign all_products = collection.products

  assign cat_lassi     = '' | split: ''
  assign cat_noodles   = '' | split: ''
  assign cat_grills    = '' | split: ''
  assign cat_burger    = '' | split: ''
  assign cat_momo      = '' | split: ''
  assign cat_snacks    = '' | split: ''
  assign cat_beverages = '' | split: ''
  assign cat_icecream  = '' | split: ''

  for p in all_products
    assign pt  = p.type  | downcase | strip
    assign ptl = p.title | downcase | strip
    if pt contains 'lassi' or ptl contains 'lassi'
      assign cat_lassi = cat_lassi | concat: p
    elsif pt contains 'noodle' or ptl contains 'noodle' or ptl contains 'chow' or ptl contains 'thukpa'
      assign cat_noodles = cat_noodles | concat: p
    elsif pt contains 'grill' or ptl contains 'grill' or ptl contains 'sekuwa' or ptl contains 'bbq' or ptl contains 'chop'
      assign cat_grills = cat_grills | concat: p
    elsif pt contains 'burger' or pt contains 'sandwich' or ptl contains 'burger' or ptl contains 'sandwich' or ptl contains 'wrap'
      assign cat_burger = cat_burger | concat: p
    elsif pt contains 'momo' or ptl contains 'momo' or ptl contains 'dumpling'
      assign cat_momo = cat_momo | concat: p
    elsif pt contains 'snack' or ptl contains 'snack' or ptl contains 'fries' or ptl contains 'chips' or ptl contains 'samosa' or ptl contains 'roll'
      assign cat_snacks = cat_snacks | concat: p
    elsif pt contains 'beverage' or pt contains 'drink' or ptl contains 'juice' or ptl contains 'tea' or ptl contains 'coffee' or ptl contains 'shake' or ptl contains 'lemonade'
      assign cat_beverages = cat_beverages | concat: p
    elsif pt contains 'ice' or ptl contains 'ice cream' or ptl contains 'gelato' or ptl contains 'kulfi'
      assign cat_icecream = cat_icecream | concat: p
    endif
  endfor
-%}

<style>
/* ═══════════════════════════════════════════════════
   DHIDO & GRILLS v2 — Premium Swiggy-style UI
   ═══════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap');

.dg-wrap {
  --g: #0d1f13;
  --g2: #1a3324;
  --g3: #122a1a;
  --card: #152b1d;
  --card2: #1c3526;
  --gold: #e5c25a;
  --gold2: #f5d876;
  --gold-dim: rgba(229,194,90,0.12);
  --gold-glow: rgba(229,194,90,0.22);
  --cream: #f5ecd4;
  --cream2: #e8dfc6;
  --border: rgba(229,194,90,0.1);
  --border2: rgba(229,194,90,0.22);
  --text: #e8dfc6;
  --text2: #9aaa97;
  --text3: #5a6b58;
  --red: #e84040;
  --ease: cubic-bezier(.4,0,.2,1);
  background: var(--g);
  font-family: 'Sora', -apple-system, BlinkMacSystemFont, sans-serif;
  color: var(--text);
  min-height: 100vh;
  padding-bottom: 120px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ═══ HERO ═══════════════════════════════════════════ */
.dg-hero {
  position: relative;
  background: linear-gradient(160deg, #0a1a0d 0%, #1a3324 55%, #0f2216 100%);
  padding: 56px 20px 72px;
  text-align: center;
  overflow: hidden;
}
.dg-hero::after {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 50% 30%, rgba(229,194,90,0.09) 0%, transparent 65%),
    radial-gradient(circle 200px at 10% 80%, rgba(229,194,90,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.dg-hero-tag {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(229,194,90,0.1); border: 1px solid var(--border2);
  border-radius: 100px; padding: 5px 14px;
  font-size: 10px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--gold); margin-bottom: 18px;
}
.dg-hero-title {
  font-size: clamp(32px, 8vw, 64px); font-weight: 800; line-height: 1.08;
  color: var(--cream); margin-bottom: 10px;
  letter-spacing: -0.5px;
}
.dg-hero-title em {
  font-style: normal;
  background: linear-gradient(120deg, var(--gold) 0%, var(--gold2) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.dg-hero-sub {
  font-size: 15px; color: var(--text2); letter-spacing: 1px;
  font-style: italic; margin-bottom: 28px;
}
.dg-hero-pills {
  display: flex; justify-content: center; gap: 10px; flex-wrap: wrap;
}
.dg-hero-pill {
  display: inline-flex; align-items: center; gap: 5px;
  background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
  border-radius: 100px; padding: 7px 14px;
  font-size: 12px; font-weight: 500; color: var(--text2);
}
.dg-hero-pill b { color: var(--cream); }
/* Particles */
.dg-fp { position: absolute; font-size: 22px; opacity: 0.1; animation: fp var(--d,8s) ease-in-out infinite var(--dl,0s); pointer-events: none; }
@keyframes fp { 0%,100%{transform:translateY(0) rotate(0deg);opacity:.09} 50%{transform:translateY(-18px) rotate(10deg);opacity:.17} }
.dg-hero-wave {
  position: absolute; bottom: -1px; left: 0; right: 0; line-height: 0;
}

/* ═══ SEARCH BAR ═════════════════════════════════════ */
.dg-search-wrap {
  padding: 16px 16px 0;
}
.dg-search {
  display: flex; align-items: center; gap: 10px;
  background: var(--card); border: 1px solid var(--border);
  border-radius: 14px; padding: 12px 16px;
  transition: border-color 0.2s;
}
.dg-search:focus-within { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-dim); }
.dg-search-icon { font-size: 16px; opacity: 0.5; flex-shrink: 0; }
.dg-search input {
  flex: 1; background: none; border: none; outline: none;
  font-family: inherit; font-size: 14px; color: var(--text);
}
.dg-search input::placeholder { color: var(--text3); }

/* ═══ CATEGORY NAV ═══════════════════════════════════ */
.dg-cat-outer {
  position: sticky; top: 0; z-index: 90;
  background: rgba(13,31,19,0.96);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  margin-top: 16px;
}
.dg-cat-scroll {
  display: flex; overflow-x: auto; scrollbar-width: none;
  padding: 0 12px; gap: 2px;
}
.dg-cat-scroll::-webkit-scrollbar { display: none; }
.dg-cat-btn {
  flex-shrink: 0; display: inline-flex; align-items: center; gap: 5px;
  padding: 13px 14px; font-size: 13px; font-weight: 500;
  color: var(--text3); background: none; border: none;
  cursor: pointer; white-space: nowrap;
  border-bottom: 2px solid transparent;
  transition: all .2s var(--ease);
  font-family: inherit;
}
.dg-cat-btn:hover { color: var(--cream); }
.dg-cat-btn.act { color: var(--gold); border-bottom-color: var(--gold); font-weight: 700; }
.dg-cat-count {
  font-size: 10px; padding: 1px 6px; border-radius: 100px;
  background: rgba(255,255,255,0.07); color: inherit;
}
.dg-cat-btn.act .dg-cat-count { background: var(--gold); color: #000; }

/* ═══ COMBO BANNER ═══════════════════════════════════ */
.dg-combo {
  margin: 16px 16px 0;
  background: linear-gradient(120deg, rgba(229,194,90,0.08) 0%, rgba(229,194,90,0.04) 100%);
  border: 1px solid var(--border2);
  border-radius: 16px; padding: 14px 16px;
  display: flex; align-items: center; gap: 14px;
  position: relative; overflow: hidden;
}
.dg-combo::before {
  content: '';
  position: absolute; right: -20px; top: -20px;
  width: 100px; height: 100px;
  background: radial-gradient(circle, rgba(229,194,90,0.15) 0%, transparent 70%);
}
.dg-combo-ico { font-size: 32px; flex-shrink: 0; }
.dg-combo-txt { flex: 1; }
.dg-combo-label { font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 3px; }
.dg-combo-title { font-size: 14px; font-weight: 700; color: var(--cream); }
.dg-combo-sub { font-size: 12px; color: var(--text2); margin-top: 2px; }
.dg-combo-sub b { color: #4ade80; }
.dg-combo-btn {
  flex-shrink: 0; background: var(--gold); color: #000;
  font-size: 11px; font-weight: 800; border: none; border-radius: 10px;
  padding: 9px 14px; cursor: pointer; font-family: inherit;
  transition: all .18s;
}
.dg-combo-btn:hover { background: var(--gold2); transform: scale(1.04); }

/* ═══ SECTION HEADER ═════════════════════════════════ */
.dg-sh {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24px 16px 12px;
}
.dg-sh-title { font-size: 18px; font-weight: 800; color: var(--cream); letter-spacing: -0.3px; }
.dg-sh-title span { color: var(--gold); }
.dg-sh-count { font-size: 12px; color: var(--text3); background: var(--card2); padding: 4px 10px; border-radius: 100px; }

/* ═══ MENU LIST (main view) ══════════════════════════ */
.dg-list { padding: 0 16px; display: flex; flex-direction: column; gap: 10px; }

.dg-item {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  display: flex; align-items: stretch; gap: 0;
  overflow: hidden;
  transition: border-color .22s, box-shadow .22s, transform .22s;
  position: relative;
}
.dg-item:hover {
  border-color: var(--border2);
  box-shadow: 0 8px 32px rgba(0,0,0,0.35), 0 0 0 1px var(--border2);
  transform: translateY(-2px);
}
.dg-item-sold { opacity: 0.55; }

/* Left accent bar */
.dg-item::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
  background: linear-gradient(180deg, var(--gold) 0%, transparent 100%);
  opacity: 0;
  transition: opacity .22s;
}
.dg-item:hover::before { opacity: 1; }

/* Emoji icon box */
.dg-item-ico {
  width: 72px; min-height: 80px;
  display: flex; align-items: center; justify-content: center;
  font-size: 30px; flex-shrink: 0;
  background: var(--card2);
  border-right: 1px solid var(--border);
  position: relative;
}
/* If product HAS image */
.dg-item-ico img {
  width: 100%; height: 100%; object-fit: cover;
  position: absolute; inset: 0;
}

/* Body */
.dg-item-body {
  flex: 1; min-width: 0;
  padding: 13px 12px 13px 14px;
  display: flex; flex-direction: column; justify-content: center; gap: 4px;
}
.dg-item-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 2px; }
.dg-tag {
  font-size: 9px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase;
  padding: 2px 7px; border-radius: 100px;
}
.dg-tag-pop  { background: rgba(232,64,64,0.15); color: #ff6b6b; }
.dg-tag-fresh{ background: rgba(74,222,128,0.12); color: #4ade80; }
.dg-tag-fast { background: rgba(251,146,60,0.15); color: #fb923c; }
.dg-tag-new  { background: var(--gold-dim); color: var(--gold); }

.dg-item-name {
  font-size: 14px; font-weight: 700; color: var(--cream); line-height: 1.3;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.dg-item-desc {
  font-size: 11px; color: var(--text3); line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;
}
.dg-item-footer {
  display: flex; align-items: center; justify-content: space-between; margin-top: 6px;
}
.dg-item-price { font-size: 16px; font-weight: 800; color: var(--gold); }
.dg-item-compare { font-size: 11px; color: var(--text3); text-decoration: line-through; margin-left: 4px; }

/* Add / Stepper */
.dg-add {
  width: 36px; height: 36px; border-radius: 10px;
  background: var(--gold); color: #000;
  font-size: 22px; font-weight: 700; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  transition: all .18s; font-family: inherit; line-height: 1;
  position: relative; overflow: hidden;
}
.dg-add:hover { background: var(--gold2); transform: scale(1.1); box-shadow: 0 4px 16px rgba(229,194,90,0.4); }
.dg-add:disabled { background: var(--card2); color: var(--text3); cursor: not-allowed; transform: none; box-shadow: none; }
.dg-add .ripple {
  position: absolute; border-radius: 50%;
  background: rgba(255,255,255,0.45);
  transform: scale(0); animation: rpl .5s linear; pointer-events: none;
}
@keyframes rpl { to { transform: scale(4); opacity: 0; } }

.dg-stepper {
  display: none; align-items: center;
  background: var(--card2); border: 1px solid var(--border2);
  border-radius: 10px; overflow: hidden; height: 36px;
}
.dg-stepper.vis { display: flex; }
.dg-s-btn {
  width: 34px; height: 36px; background: none; border: none; cursor: pointer;
  color: var(--gold); font-size: 18px; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  transition: background .15s; font-family: inherit;
}
.dg-s-btn:hover { background: var(--gold-dim); }
.dg-s-val { min-width: 26px; text-align: center; font-size: 14px; font-weight: 800; color: var(--cream); }

/* ═══ 2-COL GRID (alternate layout for wider screens) ═ */
@media (min-width: 700px) {
  .dg-list { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .dg-item-ico { width: 84px; }
}
@media (min-width: 1100px) {
  .dg-list { grid-template-columns: 1fr 1fr 1fr; }
}

/* ═══ UPSELL RAIL ════════════════════════════════════ */
.dg-upsell {
  margin: 8px 0 0;
  padding: 0 0 20px;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: rgba(21,43,29,0.5);
}
.dg-u-rail {
  display: flex; gap: 10px; overflow-x: auto; scrollbar-width: none;
  padding: 4px 16px 4px;
}
.dg-u-rail::-webkit-scrollbar { display: none; }
.dg-u-card {
  flex-shrink: 0; width: 130px;
  background: var(--card); border: 1px solid var(--border);
  border-radius: 14px; overflow: hidden;
  transition: transform .2s, border-color .2s;
}
.dg-u-card:hover { transform: translateY(-3px); border-color: var(--border2); }
.dg-u-img {
  width: 100%; aspect-ratio: 1;
  object-fit: cover; background: var(--card2);
  display: flex; align-items: center; justify-content: center; font-size: 28px;
}
.dg-u-img img { width: 100%; height: 100%; object-fit: cover; }
.dg-u-body { padding: 8px 10px 10px; }
.dg-u-name { font-size: 11px; font-weight: 700; color: var(--cream); margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.dg-u-price { font-size: 12px; font-weight: 800; color: var(--gold); }
.dg-u-add {
  margin-top: 7px; width: 100%; background: var(--gold); color: #000;
  font-size: 11px; font-weight: 800; border: none; border-radius: 8px;
  padding: 6px; cursor: pointer; font-family: inherit; transition: all .18s;
}
.dg-u-add:hover { background: var(--gold2); }

/* ═══ TRUST ══════════════════════════════════════════ */
.dg-trust {
  display: flex; justify-content: center; gap: 0; flex-wrap: wrap;
  padding: 24px 16px 20px;
}
.dg-trust-item {
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  text-align: center; flex: 1; min-width: 80px;
}
.dg-trust-ico {
  width: 46px; height: 46px; border-radius: 50%;
  background: var(--card); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center; font-size: 20px;
}
.dg-trust-lbl { font-size: 10px; font-weight: 700; color: var(--text2); text-transform: uppercase; letter-spacing: 0.7px; }

/* ═══ CART FAB ════════════════════════════════════════ */
.dg-fab {
  position: fixed; top: 68px; right: 16px; z-index: 800;
  width: 50px; height: 50px; border-radius: 50%;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
  color: #000; font-size: 20px; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6px 24px rgba(229,194,90,0.4); transition: all .22s;
}
.dg-fab:hover { transform: scale(1.1); }
.dg-fab-badge {
  position: absolute; top: -4px; right: -4px;
  width: 20px; height: 20px; border-radius: 50%;
  background: var(--red); color: #fff;
  font-size: 10px; font-weight: 800;
  display: none; align-items: center; justify-content: center;
  border: 2px solid var(--g);
}
.dg-fab-badge.vis { display: flex; }

/* ═══ DRAWER ═════════════════════════════════════════ */
.dg-overlay {
  position: fixed; inset: 0; z-index: 900;
  background: rgba(0,0,0,0.72); backdrop-filter: blur(5px);
  opacity: 0; pointer-events: none; transition: opacity .3s;
}
.dg-overlay.open { opacity: 1; pointer-events: all; }
.dg-drawer {
  position: fixed; right: 0; top: 0; bottom: 0;
  width: min(380px, 100vw); z-index: 901;
  background: var(--g2); border-left: 1px solid var(--border);
  display: flex; flex-direction: column;
  transform: translateX(100%); transition: transform .32s cubic-bezier(.32,0,.67,0);
  box-shadow: -16px 0 48px rgba(0,0,0,0.5);
}
.dg-drawer.open { transform: none; transition-timing-function: cubic-bezier(.22,1,.36,1); }
.dg-dr-hdr {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 20px; border-bottom: 1px solid var(--border);
}
.dg-dr-title { font-size: 17px; font-weight: 800; color: var(--cream); }
.dg-dr-close {
  width: 34px; height: 34px; border-radius: 50%; background: var(--card2);
  border: 1px solid var(--border); color: var(--text); font-size: 16px;
  cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .18s;
}
.dg-dr-close:hover { background: var(--gold-dim); color: var(--gold); }
.dg-dr-body { flex: 1; overflow-y: auto; padding: 14px 16px; }
.dg-dr-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 0; border-bottom: 1px solid var(--border);
}
.dg-dr-img {
  width: 52px; height: 52px; border-radius: 10px; object-fit: cover;
  background: var(--card2); flex-shrink: 0; font-size: 22px;
  display: flex; align-items: center; justify-content: center;
}
.dg-dr-img img { width: 100%; height: 100%; object-fit: cover; border-radius: 10px; }
.dg-dr-info { flex: 1; min-width: 0; }
.dg-dr-name { font-size: 13px; font-weight: 700; color: var(--cream); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.dg-dr-price { font-size: 13px; font-weight: 800; color: var(--gold); margin-top: 2px; }
.dg-dr-qty {
  display: flex; align-items: center; gap: 6px;
  background: var(--card); border: 1px solid var(--border2);
  border-radius: 9px; padding: 4px 6px; flex-shrink: 0;
}
.dg-dr-qbtn { background: none; border: none; color: var(--gold); font-size: 16px; font-weight: 800; cursor: pointer; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; }
.dg-dr-qval { font-size: 13px; font-weight: 800; color: var(--cream); min-width: 18px; text-align: center; }
.dg-dr-empty { text-align: center; padding: 60px 20px; color: var(--text2); }
.dg-dr-empty-ico { font-size: 52px; margin-bottom: 12px; }
.dg-dr-foot { border-top: 1px solid var(--border); padding: 14px 20px 20px; }
.dg-dr-row { display: flex; justify-content: space-between; font-size: 13px; color: var(--text2); margin-bottom: 8px; }
.dg-dr-total { display: flex; justify-content: space-between; font-size: 18px; font-weight: 800; color: var(--cream); margin-bottom: 16px; }
.dg-dr-total span:last-child { color: var(--gold); }
.dg-dr-cta {
  width: 100%; background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
  color: #000; font-size: 15px; font-weight: 800;
  padding: 15px; border-radius: 13px; border: none; cursor: pointer;
  font-family: inherit; letter-spacing: 0.3px; transition: all .22s;
}
.dg-dr-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(229,194,90,0.45); }

/* ═══ STICKY BAR ═════════════════════════════════════ */
.dg-bar {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 799;
  background: var(--g2); border-top: 1px solid var(--border2);
  padding: 10px 16px 18px;
  display: none; align-items: center; justify-content: space-between; gap: 12px;
  box-shadow: 0 -10px 32px rgba(0,0,0,0.45);
}
.dg-bar.vis { display: flex; }
.dg-bar-info {}
.dg-bar-c { font-size: 11px; color: var(--text2); margin-bottom: 1px; }
.dg-bar-t { font-size: 20px; font-weight: 800; color: var(--gold); }
.dg-bar-btn {
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
  color: #000; font-size: 14px; font-weight: 800;
  padding: 13px 28px; border-radius: 13px; border: none; cursor: pointer;
  font-family: inherit; white-space: nowrap; transition: all .22s;
}
.dg-bar-btn:hover { transform: scale(1.04); box-shadow: 0 6px 22px rgba(229,194,90,0.4); }

/* ═══ TOAST ══════════════════════════════════════════ */
.dg-toast {
  position: fixed; bottom: 88px; left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: var(--card2); border: 1px solid var(--border2);
  border-radius: 12px; padding: 11px 20px;
  font-size: 13px; font-weight: 700; color: var(--cream);
  z-index: 950; opacity: 0; pointer-events: none; white-space: nowrap;
  transition: all .28s var(--ease);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}
.dg-toast.on { opacity: 1; transform: translateX(-50%) translateY(0); }

/* ═══ EMPTY / LOADING ════════════════════════════════ */
.dg-empty { text-align: center; padding: 80px 20px; color: var(--text2); }
.dg-empty-ico { font-size: 56px; margin-bottom: 16px; }
.dg-empty h3 { font-size: 20px; font-weight: 800; color: var(--cream); margin-bottom: 8px; }

/* Scroll reveal */
.dg-r { opacity: 0; transform: translateY(20px); transition: opacity .45s, transform .45s; }
.dg-r.in { opacity: 1; transform: none; }
</style>

<div class="dg-wrap" id="dgWrap">

  <!-- ═══ HERO ═══ -->
  <div class="dg-hero">
    <span class="dg-fp" style="left:7%;top:25%;--d:7s;--dl:0s">🥘</span>
    <span class="dg-fp" style="left:15%;top:65%;--d:9s;--dl:1.3s">🍖</span>
    <span class="dg-fp" style="left:80%;top:18%;--d:8s;--dl:0.4s">🥟</span>
    <span class="dg-fp" style="left:88%;top:62%;--d:10s;--dl:2.1s">🍜</span>
    <span class="dg-fp" style="left:50%;top:78%;--d:6.5s;--dl:0.9s">🌶️</span>
    <div class="dg-hero-tag">🌿 Authentic Nepali Cuisine</div>
    <h1 class="dg-hero-title">The Dhido &<br><em>The Grills</em></h1>
    <p class="dg-hero-sub">The Essence of Nepal</p>
    <div class="dg-hero-pills">
      <span class="dg-hero-pill">⚡ <b>20 min</b> delivery</span>
      <span class="dg-hero-pill">⭐ <b>4.8</b> rated</span>
      <span class="dg-hero-pill">🔥 <b>Fresh</b> daily</span>
    </div>
    <svg class="dg-hero-wave" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 50" preserveAspectRatio="none">
      <path fill="#0d1f13" d="M0,30 C400,55 1040,5 1440,32 L1440,50 L0,50Z"/>
    </svg>
  </div>

  <!-- ═══ SEARCH ═══ -->
  <div class="dg-search-wrap">
    <div class="dg-search">
      <span class="dg-search-icon">🔍</span>
      <input type="text" id="dgSearch" placeholder="Search dishes, drinks..." autocomplete="off">
    </div>
  </div>

  <!-- ═══ CATEGORY NAV ═══ -->
  <nav class="dg-cat-outer">
    <div class="dg-cat-scroll" id="dgCats">
      <button class="dg-cat-btn act" data-cat="all">🍽️ All <span class="dg-cat-count">{{ collection.products_count }}</span></button>
      {%- if cat_lassi.size > 0 -%}<button class="dg-cat-btn" data-cat="lassi">🥛 Lassi <span class="dg-cat-count">{{ cat_lassi.size }}</span></button>{%- endif -%}
      {%- if cat_noodles.size > 0 -%}<button class="dg-cat-btn" data-cat="noodles">🍜 Noodles <span class="dg-cat-count">{{ cat_noodles.size }}</span></button>{%- endif -%}
      {%- if cat_grills.size > 0 -%}<button class="dg-cat-btn" data-cat="grills">🥩 Grills <span class="dg-cat-count">{{ cat_grills.size }}</span></button>{%- endif -%}
      {%- if cat_burger.size > 0 -%}<button class="dg-cat-btn" data-cat="burger">🍔 Burgers <span class="dg-cat-count">{{ cat_burger.size }}</span></button>{%- endif -%}
      {%- if cat_momo.size > 0 -%}<button class="dg-cat-btn" data-cat="momo">🥟 Momo <span class="dg-cat-count">{{ cat_momo.size }}</span></button>{%- endif -%}
      {%- if cat_snacks.size > 0 -%}<button class="dg-cat-btn" data-cat="snacks">🍟 Snacks <span class="dg-cat-count">{{ cat_snacks.size }}</span></button>{%- endif -%}
      {%- if cat_beverages.size > 0 -%}<button class="dg-cat-btn" data-cat="beverages">🥤 Drinks <span class="dg-cat-count">{{ cat_beverages.size }}</span></button>{%- endif -%}
      {%- if cat_icecream.size > 0 -%}<button class="dg-cat-btn" data-cat="icecream">🍦 Ice Cream <span class="dg-cat-count">{{ cat_icecream.size }}</span></button>{%- endif -%}
    </div>
  </nav>

  <!-- ═══ COMBO DEAL ═══ -->
  <div class="dg-combo dg-r" id="dgCombo">
    <div class="dg-combo-ico">🍔</div>
    <div class="dg-combo-txt">
      <div class="dg-combo-label">⚡ Today's Deal</div>
      <div class="dg-combo-title">Burger + Coke Combo</div>
      <div class="dg-combo-sub">Save <b>Rs 50</b> on combo order</div>
    </div>
    <button class="dg-combo-btn" onclick="document.querySelector('[data-cat=burger]')?.click()">Order Now</button>
  </div>

  <!-- ═══ PRODUCT LISTS ═══ -->
  <main id="dgMain">
    {%- if collection.products_count == 0 -%}
      <div class="dg-empty">
        <div class="dg-empty-ico">🍽️</div>
        <h3>Menu Coming Soon</h3>
        <p>Something delicious is on the way!</p>
      </div>
    {%- else -%}

      <!-- ALL -->
      <div id="dgAll">
        <div class="dg-sh">
          <div class="dg-sh-title">Our <span>Menu</span></div>
          <div class="dg-sh-count">{{ collection.products_count }} items</div>
        </div>
        <div class="dg-list" id="dgListAll">
          {%- for product in collection.products -%}
            {%- render 'dg-menu-item', product: product -%}
          {%- endfor -%}
