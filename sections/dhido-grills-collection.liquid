<!-- STICKY BAR -->
<div class="dg-bar" id="dgBar">
  <div>
    <div class="dg-bar-c" id="dgBarC">0 items</div>
    <div class="dg-bar-t" id="dgBarT">Rs 0</div>
  </div>
  <button class="dg-bar-btn" onclick="window.location.href='/pages/payment'">Checkout →</button>
</div>

<div class="dg-toast" id="dgToast"></div>

<script>
(function(){
  var cart = { items:[], item_count:0, total_price:0 };
  var SECTION_IDS = ['dg-sec-specials','dg-sec-dhido','dg-sec-grills','dg-sec-momo','dg-sec-noodles','dg-sec-burger','dg-sec-snacks','dg-sec-bev','dg-sec-lassi','dg-sec-ice','dg-sec-other'];

  document.addEventListener('DOMContentLoaded', function(){
    dgFetch();
    dgCatInit();
    dgSearchInit();
  });

  /* ── CART ── */
  function dgFetch(){
    fetch('/cart.js').then(function(r){return r.json();}).then(function(c){
      cart=c; dgUI(); dgSteppers();
    }).catch(function(){});
  }

  window.dgAdd = function(btn){
    var vid  = btn.dataset.variant;
    var name = btn.dataset.name||'Item';
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:parseInt(vid),quantity:1})})
    .then(function(r){return r.json();}).then(function(){
      dgFetch(); dgToast('Added: '+name);
      var sp=document.createElement('span'); sp.className='ripple';
      sp.style.cssText='width:36px;height:36px;left:50%;top:50%;margin:-18px 0 0 -18px;';
      btn.appendChild(sp); setTimeout(function(){sp.remove();},550);
    });
  };

  window.dgChg = function(key,qty){
    fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:key,quantity:qty})})
    .then(function(r){return r.json();}).then(function(){dgFetch();});
  };

  /* ── UI SYNC ── */
  function dgUI(){
    var cnt=cart.item_count||0, tot=cart.total_price||0;
    var str='Rs '+(tot/100).toLocaleString('en-NP');
    var badge=document.getElementById('dgFabBadge');
    if(badge){badge.textContent=cnt; badge.classList.toggle('vis',cnt>0);}
    var bar=document.getElementById('dgBar');
    if(bar) bar.classList.toggle('vis',cnt>0);
    var bc=document.getElementById('dgBarC'),bt=document.getElementById('dgBarT');
    if(bc) bc.textContent=cnt+(cnt===1?' item':' items');
    if(bt) bt.textContent=str;
    var body=document.getElementById('dgDrBody'),foot=document.getElementById('dgDrFoot');
    var sub=document.getElementById('dgDrSub'),tot2=document.getElementById('dgDrTot');
    if(!body) return;
    if(cnt===0){
      body.innerHTML='<div class="dg-dr-empty"><div class="dg-dr-empty-ico">🍽️</div><p>Nothing added yet</p></div>';
      if(foot) foot.style.display='none'; return;
    }
    if(foot) foot.style.display='';
    if(sub) sub.textContent=str;
    if(tot2) tot2.innerHTML='<span>Total</span><span>'+str+'</span>';
    var html='';
    (cart.items||[]).forEach(function(item){
      var imgSrc=item.image?item.image.replace(/(\.\w+)$/,'_100x100$1'):'';
      html+='<div class="dg-dr-item">'+
        (imgSrc?'<div class="dg-dr-img"><img src="'+imgSrc+'" alt="" loading="lazy"></div>':'<div class="dg-dr-img" style="font-size:20px">🍽️</div>')+
        '<div class="dg-dr-info"><div class="dg-dr-name">'+item.product_title+'</div>'+
        '<div class="dg-dr-price">Rs '+(item.final_line_price/100).toLocaleString('en-NP')+'</div></div>'+
        '<div class="dg-dr-qty">'+
          '<button class="dg-dr-qbtn" onclick="dgChg(\''+item.key+'\','+(item.quantity-1)+')">−</button>'+
          '<span class="dg-dr-qval">'+item.quantity+'</span>'+
          '<button class="dg-dr-qbtn" onclick="dgChg(\''+item.key+'\','+(item.quantity+1)+')">+</button>'+
        '</div></div>';
    });
    body.innerHTML=html;
  }

  function dgSteppers(){
    document.querySelectorAll('.dg-card[data-v]').forEach(function(el){
      var vid=el.dataset.v;
      var item=(cart.items||[]).find(function(i){return String(i.variant_id)===String(vid);});
      var add=el.querySelector('.dg-add'), step=el.querySelector('.dg-stepper'), val=el.querySelector('.dg-s-val');
      if(item&&item.quantity>0){
        if(add) add.style.display='none';
        if(step) step.classList.add('vis');
        if(val) val.textContent=item.quantity;
      } else {
        if(add) add.style.display='';
        if(step) step.classList.remove('vis');
      }
    });
  }

  /* ── BUTTON DELEGATION ── */
  document.addEventListener('click',function(e){
    var ab=e.target.closest('.dg-add:not([disabled])');
    if(ab&&!ab.closest('.dg-stepper')){
      var card=ab.closest('.dg-card[data-v]');
      if(card) dgAdd(Object.assign(ab,{dataset:{variant:card.dataset.v,name:card.dataset.n||''}}));
      return;
    }
    var mb=e.target.closest('.dg-s-btn[data-a="minus"]');
    if(mb){
      var card=mb.closest('.dg-card[data-v]');
      if(card){var it=(cart.items||[]).find(function(i){return String(i.variant_id)===String(card.dataset.v);});if(it)dgChg(it.key,it.quantity-1);}
      return;
    }
    var pb=e.target.closest('.dg-s-btn[data-a="plus"]');
    if(pb){
      var card=pb.closest('.dg-card[data-v]');
      if(card){
        var it=(cart.items||[]).find(function(i){return String(i.variant_id)===String(card.dataset.v);});
        if(it)dgChg(it.key,it.quantity+1);
        else dgAdd(Object.assign(pb,{dataset:{variant:card.dataset.v,name:card.dataset.n||''}}));
      } return;
    }
  });

  /* ── CATEGORY NAV — scroll anchors + IntersectionObserver highlight ── */
  function dgCatInit(){
    var pills = document.querySelectorAll('.dg-cat-pill[data-target]');

    // Activate first visible pill on load
    if(pills.length > 0) pills[0].classList.add('act');

    // Click → smooth scroll to section
    pills.forEach(function(pill){
      pill.addEventListener('click',function(){
        var target = document.getElementById(this.dataset.target);
        if(!target) return;
        var catTop = document.getElementById('dgCatOuter');
        var offset = catTop ? catTop.offsetHeight : 56;
        var y = target.getBoundingClientRect().top + window.scrollY - offset - 8;
        window.scrollTo({top:y, behavior:'smooth'});
        setActive(this);
        this.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
      });
    });

    // IntersectionObserver → auto-highlight pill when section is in view
    if(!('IntersectionObserver' in window)) return;
    var obs = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if(entry.isIntersecting){
          var id = entry.target.id;
          var pill = document.querySelector('.dg-cat-pill[data-target="'+id+'"]');
          if(pill){ setActive(pill); pill.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'}); }
        }
      });
    },{rootMargin:'-30% 0px -60% 0px', threshold:0});

    SECTION_IDS.forEach(function(id){
      var el=document.getElementById(id);
      if(el) obs.observe(el);
    });
  }

  function setActive(activePill){
    document.querySelectorAll('.dg-cat-pill').forEach(function(p){p.classList.remove('act');});
    activePill.classList.add('act');
  }

  /* ── SEARCH ── */
  function dgSearchInit(){
    var inp=document.getElementById('dgSearch');
    var clr=document.getElementById('dgSearchClear');
    if(!inp) return;
    inp.addEventListener('input',function(){
      var q=this.value.trim().toLowerCase();
      clr&&clr.classList.toggle('vis', q.length>0);
      dgSearchRun(q);
    });
  }

  function dgSearchRun(q){
    var panel=document.getElementById('dgSearchPanel');
    var main=document.getElementById('dgMain');
    var catOuter=document.getElementById('dgCatOuter');
    var grid=document.getElementById('dgSrGrid');
    var label=document.getElementById('dgSrLabel');
    if(!panel||!main||!grid) return;

    if(!q){
      panel.style.display='none'; main.style.display=''; return;
    }

    // Search across all products
    var allCards=document.querySelectorAll('#dgMain .dg-card[data-v]');
    var matches=[];
    allCards.forEach(function(c){
      if((c.dataset.n||'').toLowerCase().includes(q)) matches.push(c.cloneNode(true));
    });

    panel.style.display='';
    main.style.display='none';
    label.textContent=matches.length+' result'+(matches.length!==1?'s':'')+ ' for "'+q+'"';
    grid.innerHTML='';
    if(matches.length===0){
      grid.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:40px 0;color:var(--t2)"><div style="font-size:40px;margin-bottom:12px">🤷</div><p>No dishes found</p></div>';
    } else {
      matches.forEach(function(c){ grid.appendChild(c); });
    }
    // Re-bind steppers on cloned cards
    dgSteppers();
  }

  window.dgClearSearch = function(){
    var inp=document.getElementById('dgSearch');
    var clr=document.getElementById('dgSearchClear');
    if(inp) inp.value='';
    if(clr) clr.classList.remove('vis');
    dgSearchRun('');
  };

  /* ── DRAWER ── */
  window.dgDrawerToggle=function(){
    var ov=document.getElementById('dgOverlay'),dr=document.getElementById('dgDrawer');
    var op=dr.classList.contains('open');
    ov.classList.toggle('open',!op); dr.classList.toggle('open',!op);
    document.body.style.overflow=op?'':'hidden';
  };

  /* ── TOAST ── */
  var tt;
  window.dgToast=function(msg){
    var t=document.getElementById('dgToast');
    if(!t) return;
    t.textContent='✅ '+msg; t.classList.add('on');
    clearTimeout(tt); tt=setTimeout(function(){t.classList.remove('on');},2000);
  };

})();
</script>

