{%- comment -%}
  The Dhido & The Grills — v3
  Swiggy-style always-visible sections · Category pills = scroll anchors
{%- endcomment -%}

{%- liquid
  assign all_products   = collection.products

  assign cat_specials   = '' | split: ''
  assign cat_dhido      = '' | split: ''
  assign cat_grills     = '' | split: ''
  assign cat_momo       = '' | split: ''
  assign cat_noodles    = '' | split: ''
  assign cat_burger     = '' | split: ''
  assign cat_snacks     = '' | split: ''
  assign cat_beverages  = '' | split: ''
  assign cat_lassi      = '' | split: ''
  assign cat_icecream   = '' | split: ''
  assign cat_other      = '' | split: ''

  for p in all_products
    assign pt  = p.type  | downcase | strip
    assign ptl = p.title | downcase | strip
    if pt contains 'special' or ptl contains 'special' or ptl contains 'combo' or ptl contains 'thali' or ptl contains 'set'
      assign cat_specials = cat_specials | concat: p
    elsif pt contains 'dhido' or ptl contains 'dhido' or ptl contains 'dal bhat' or ptl contains 'dal-bhat' or ptl contains 'bhat' or ptl contains 'gundruk' or ptl contains 'tarkari'
      assign cat_dhido = cat_dhido | concat: p
    elsif pt contains 'grill' or ptl contains 'grill' or ptl contains 'sekuwa' or ptl contains 'bbq' or ptl contains 'chop' or ptl contains 'buff' or ptl contains 'mutton' or ptl contains 'chicken sekuwa'
      assign cat_grills = cat_grills | concat: p
    elsif pt contains 'momo' or ptl contains 'momo' or ptl contains 'dumpling' or ptl contains 'kothey'
      assign cat_momo = cat_momo | concat: p
    elsif pt contains 'noodle' or ptl contains 'noodle' or ptl contains 'chow' or ptl contains 'thukpa' or ptl contains 'chowmein'
      assign cat_noodles = cat_noodles | concat: p
    elsif pt contains 'burger' or pt contains 'sandwich' or ptl contains 'burger' or ptl contains 'sandwich' or ptl contains 'wrap' or ptl contains 'roll'
      assign cat_burger = cat_burger | concat: p
    elsif pt contains 'snack' or ptl contains 'snack' or ptl contains 'fries' or ptl contains 'chips' or ptl contains 'samosa' or ptl contains 'pakoda' or ptl contains 'spring roll'
      assign cat_snacks = cat_snacks | concat: p
    elsif pt contains 'beverage' or pt contains 'drink' or ptl contains 'juice' or ptl contains 'tea' or ptl contains 'coffee' or ptl contains 'shake' or ptl contains 'lemonade' or ptl contains 'soda'
      assign cat_beverages = cat_beverages | concat: p
    elsif pt contains 'lassi' or ptl contains 'lassi'
      assign cat_lassi = cat_lassi | concat: p
    elsif pt contains 'ice' or ptl contains 'ice cream' or ptl contains 'gelato' or ptl contains 'kulfi'
      assign cat_icecream = cat_icecream | concat: p
    else
      assign cat_other = cat_other | concat: p
    endif
  endfor
-%}

<style>
/* ═══════════════════════════════════════════════════
   DHIDO & GRILLS v3 — Swiggy-style Sections
   ═══════════════════════════════════════════════════ */

.dg-wrap {
  --bg:    #0a1a0d;
  --bg2:   #0e2012;
  --card:  #122616;
  --card2: #1a3020;
  --gold:  #e5c25a;
  --gold2: #f5d876;
  --gdim:  rgba(229,194,90,0.10);
  --glow:  rgba(229,194,90,0.20);
  --cream: #f0e6cc;
  --t1:    #d4c9a8;
  --t2:    #7a8e78;
  --t3:    #3d5040;
  --red:   #e84040;
  --bdr:   rgba(229,194,90,0.09);
  --bdr2:  rgba(229,194,90,0.20);
  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: var(--t1);
  min-height: 100vh;
  padding-bottom: 100px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ═══ HERO ═══════════════════════════════════════════ */
.dg-hero {
  position: relative;
  background: linear-gradient(160deg, #071209 0%, #122a15 50%, #0a1e0d 100%);
  padding: 48px 20px 56px;
  text-align: center; overflow: hidden;
}
.dg-hero::before {
  content:''; position:absolute; top:-80px; left:50%; transform:translateX(-50%);
  width:400px; height:300px;
  background:radial-gradient(ellipse,rgba(229,194,90,0.1) 0%,transparent 65%);
  pointer-events:none;
}
.dg-hero-badge {
  display:inline-flex; align-items:center; gap:6px;
  background:rgba(229,194,90,0.1); border:1px solid var(--bdr2);
  border-radius:100px; padding:5px 14px;
  font-size:10px; font-weight:700; letter-spacing:2.5px; text-transform:uppercase;
  color:var(--gold); margin-bottom:16px;
}
.dg-hero-title {
  font-size: clamp(30px, 8vw, 58px); font-weight:900; line-height:1.05;
  color:var(--cream); letter-spacing:-1px; margin-bottom:8px;
}
.dg-hero-title em {
  font-style:normal;
  background:linear-gradient(120deg,var(--gold) 0%,var(--gold2) 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.dg-hero-sub { font-size:14px; color:var(--t2); font-style:italic; margin-bottom:24px; letter-spacing:0.5px; }
.dg-hero-pills { display:flex; justify-content:center; gap:8px; flex-wrap:wrap; }
.dg-hero-pill {
  display:inline-flex; align-items:center; gap:5px;
  background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08);
  border-radius:100px; padding:7px 14px; font-size:12px; color:var(--t2);
}
.dg-hero-pill b { color:var(--cream); font-weight:700; }
/* floating particles */
.dg-fp { position:absolute; font-size:20px; opacity:0.08; pointer-events:none;
  animation:dgfp var(--d,8s) ease-in-out infinite var(--dl,0s); }
@keyframes dgfp { 0%,100%{transform:translateY(0) rotate(0)} 50%{transform:translateY(-16px) rotate(8deg)} }
.dg-hero-wave { position:absolute; bottom:-1px; left:0; right:0; line-height:0; }

/* ═══ INFO BAR ════════════════════════════════════════ */
.dg-infobar {
  display:flex; align-items:center; gap:0;
  background:var(--bg2);
  border-bottom:1px solid var(--bdr);
  padding:0;
  overflow-x:auto; scrollbar-width:none;
}
.dg-infobar::-webkit-scrollbar { display:none; }
.dg-ib-item {
  flex-shrink:0; display:flex; flex-direction:column; align-items:center;
  padding:12px 18px; gap:2px; border-right:1px solid var(--bdr);
  min-width:80px;
}
.dg-ib-val { font-size:14px; font-weight:800; color:var(--cream); line-height:1; }
.dg-ib-lbl { font-size:9px; font-weight:600; color:var(--t3); text-transform:uppercase; letter-spacing:1px; }

/* ═══ SEARCH ════════════════════════════════════════ */
.dg-search-wrap { padding:14px 14px 0; }
.dg-search {
  display:flex; align-items:center; gap:10px;
  background:var(--card); border:1.5px solid var(--bdr);
  border-radius:14px; padding:11px 16px;
  transition:border-color .2s, box-shadow .2s;
}
.dg-search:focus-within { border-color:var(--gold); box-shadow:0 0 0 3px var(--gdim); }
.dg-search-ico { font-size:15px; opacity:0.4; flex-shrink:0; }
.dg-search input {
  flex:1; background:transparent; border:none; outline:none;
  font-size:14px; color:var(--cream); font-family:inherit;
  -webkit-appearance:none; appearance:none;
  -webkit-box-shadow:none; box-shadow:none;
  color-scheme:dark;
}
.dg-search input::placeholder { color:var(--t3); }
.dg-search input:focus { outline:none; box-shadow:none; -webkit-box-shadow:none; }
.dg-search-clear { background:none; border:none; color:var(--t2); font-size:16px; cursor:pointer; padding:2px 4px; display:none; -webkit-appearance:none; }
.dg-search-clear.vis { display:block; }

/* ═══ CATEGORY NAV (scroll anchors) ═════════════════ */
.dg-cat-outer {
  position:sticky; top:0; z-index:90;
  background:rgba(10,26,13,0.96); backdrop-filter:blur(20px);
  border-bottom:1px solid var(--bdr);
  margin-top:14px;
}
.dg-cat-scroll { display:flex; overflow-x:auto; scrollbar-width:none; padding:0 10px; gap:0; }
.dg-cat-scroll::-webkit-scrollbar { display:none; }
.dg-cat-pill {
  flex-shrink:0; display:inline-flex; align-items:center; gap:5px;
  padding:13px 13px; font-size:13px; font-weight:500; color:var(--t2);
  background:none; border:none; border-bottom:2px solid transparent;
  cursor:pointer; white-space:nowrap; transition:all .2s; font-family:inherit;
}
.dg-cat-pill:hover { color:var(--cream); }
.dg-cat-pill.act { color:var(--gold); border-bottom-color:var(--gold); font-weight:700; }
.dg-cat-count {
  font-size:9px; padding:1px 5px; border-radius:100px;
  background:rgba(255,255,255,0.06); color:inherit; line-height:1.6;
}
.dg-cat-pill.act .dg-cat-count { background:var(--gold); color:#000; }

/* ═══ SECTION ════════════════════════════════════════ */
.dg-section { margin-top:8px; scroll-margin-top:56px; }

.dg-sec-hdr {
  display:flex; align-items:center; justify-content:space-between;
  padding:20px 14px 10px;
}
.dg-sec-left { display:flex; align-items:center; gap:10px; }
.dg-sec-ico {
  width:38px; height:38px; border-radius:11px;
  background:var(--gdim); border:1px solid var(--bdr2);
  display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0;
}
.dg-sec-name { font-size:17px; font-weight:800; color:var(--cream); letter-spacing:-0.3px; }
.dg-sec-count { font-size:11px; color:var(--t3); background:var(--card2); padding:3px 9px; border-radius:100px; }
.dg-sec-divider { height:1px; background:linear-gradient(90deg,var(--bdr2),transparent); margin:0 14px; }

/* ═══ PRODUCT GRID ════════════════════════════════════ */
.dg-grid {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  padding:10px 14px 4px;
}
@media(min-width:640px){ .dg-grid { grid-template-columns:repeat(3,1fr); } }
@media(min-width:960px){ .dg-grid { grid-template-columns:repeat(4,1fr); } }

/* ═══ PRODUCT CARD ════════════════════════════════════ */
.dg-card {
  background:var(--card);
  border:1.5px solid var(--bdr);
  border-radius:16px; overflow:hidden;
  display:flex; flex-direction:column;
  transition:transform .2s, border-color .2s, box-shadow .2s;
  position:relative; cursor:pointer; text-decoration:none;
}
.dg-card:hover {
  transform:translateY(-3px);
  border-color:var(--bdr2);
  box-shadow:0 10px 32px rgba(0,0,0,0.4);
}
/* Image */
.dg-card-img {
  width:100%; aspect-ratio:1;
  background:var(--card2);
  position:relative; overflow:hidden;
  display:flex; align-items:center; justify-content:center;
  font-size:36px;
}
.dg-card-img img { width:100%; height:100%; object-fit:cover; position:absolute; inset:0; }
.dg-card-off {
  position:absolute; top:8px; left:8px;
  background:var(--red); color:#fff;
  font-size:9px; font-weight:900; padding:3px 7px;
  border-radius:100px; letter-spacing:0.5px;
}
.dg-card-badge {
  position:absolute; bottom:8px; left:8px;
  background:rgba(0,0,0,0.7); backdrop-filter:blur(6px);
  border:1px solid rgba(255,255,255,0.1);
  color:rgba(255,255,255,0.85); font-size:9px; font-weight:700;
  padding:3px 8px; border-radius:100px;
}
/* Info */
.dg-card-body { padding:10px 10px 12px; flex:1; display:flex; flex-direction:column; gap:4px; }
.dg-card-tags { display:flex; gap:4px; flex-wrap:wrap; margin-bottom:1px; }
.dg-ctag {
  font-size:8px; font-weight:800; letter-spacing:0.6px; text-transform:uppercase;
  padding:2px 6px; border-radius:100px;
}
.dg-ctag-pop  { background:rgba(232,64,64,0.14); color:#ff6b6b; }
.dg-ctag-new  { background:var(--gdim); color:var(--gold); }
.dg-ctag-fresh{ background:rgba(74,222,128,0.1); color:#4ade80; }
.dg-card-name { font-size:13px; font-weight:700; color:var(--cream); line-height:1.3; }
.dg-card-desc { font-size:10px; color:var(--t3); line-height:1.4;
  display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.dg-card-footer { display:flex; align-items:center; justify-content:space-between; margin-top:auto; padding-top:8px; }
.dg-card-price { font-size:15px; font-weight:900; color:var(--gold); }
.dg-card-old { font-size:10px; color:var(--t3); text-decoration:line-through; margin-left:3px; }

/* Add button */
.dg-add {
  width:32px; height:32px; border-radius:9px;
  background:var(--gold); color:#000; font-size:20px; font-weight:700;
  border:none; cursor:pointer; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  transition:all .18s; font-family:inherit; line-height:1;
  position:relative; overflow:hidden;
}
.dg-add:hover { background:var(--gold2); transform:scale(1.1); box-shadow:0 4px 14px var(--glow); }
.dg-add:disabled { background:var(--card2); color:var(--t3); cursor:not-allowed; transform:none; box-shadow:none; }
.dg-add .ripple { position:absolute; border-radius:50%; background:rgba(255,255,255,0.45); transform:scale(0); animation:rpl .5s linear; pointer-events:none; }
@keyframes rpl { to{transform:scale(4);opacity:0} }

/* Stepper */
.dg-stepper {
  display:none; align-items:center; gap:0;
  background:var(--card2); border:1.5px solid var(--bdr2);
  border-radius:9px; overflow:hidden; height:32px;
}
.dg-stepper.vis { display:flex; }
.dg-s-btn {
  width:30px; height:32px; background:none; border:none; cursor:pointer;
  color:var(--gold); font-size:16px; font-weight:800; font-family:inherit;
  display:flex; align-items:center; justify-content:center; transition:background .15s;
}
.dg-s-btn:hover { background:var(--gdim); }
.dg-s-val { min-width:22px; text-align:center; font-size:13px; font-weight:800; color:var(--cream); }

/* ═══ SHOW MORE ══════════════════════════════════════ */
.dg-showmore-wrap { text-align:center; padding:12px 14px 4px; }
.dg-showmore {
  background:transparent; border:1.5px solid var(--bdr2);
  color:var(--gold); font-size:13px; font-weight:700;
  padding:10px 24px; border-radius:12px; cursor:pointer;
  font-family:inherit; transition:all .2s; width:100%;
}
.dg-showmore:hover { background:var(--gdim); }

/* ═══ SECTION SEPARATOR ══════════════════════════════ */
.dg-sep { height:8px; background:rgba(0,0,0,0.25); margin:12px 0 0; }

/* ═══ TRUST ════════════════════════════════════════ */
.dg-trust {
  display:flex; justify-content:center; flex-wrap:wrap;
  padding:24px 16px 20px; gap:0;
  border-top:1px solid var(--bdr);
}
.dg-trust-item { flex:1; min-width:72px; display:flex; flex-direction:column; align-items:center; gap:6px; }
.dg-trust-ico {
  width:44px; height:44px; border-radius:50%;
  background:var(--card); border:1px solid var(--bdr);
  display:flex; align-items:center; justify-content:center; font-size:18px;
}
.dg-trust-lbl { font-size:9px; font-weight:700; color:var(--t2); text-transform:uppercase; letter-spacing:0.7px; text-align:center; }

/* ═══ CART FAB ═══════════════════════════════════════ */
.dg-fab {
  position:fixed; top:68px; right:14px; z-index:800;
  width:48px; height:48px; border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:#000; font-size:19px; border:none; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 6px 20px rgba(229,194,90,0.4); transition:all .22s;
}
.dg-fab:hover { transform:scale(1.1); }
.dg-fab-badge {
  position:absolute; top:-4px; right:-4px;
  width:18px; height:18px; border-radius:50%;
  background:var(--red); color:#fff; font-size:9px; font-weight:800;
  display:none; align-items:center; justify-content:center;
  border:2px solid var(--bg);
}
.dg-fab-badge.vis { display:flex; }

/* ═══ DRAWER ═════════════════════════════════════════ */
.dg-overlay { position:fixed; inset:0; z-index:900; background:rgba(0,0,0,0.72); backdrop-filter:blur(5px); opacity:0; pointer-events:none; transition:opacity .3s; }
.dg-overlay.open { opacity:1; pointer-events:all; }
.dg-drawer {
  position:fixed; right:0; top:0; bottom:0;
  width:min(380px,100vw); z-index:901;
  background:var(--bg2); border-left:1px solid var(--bdr);
  display:flex; flex-direction:column;
  transform:translateX(100%); transition:transform .32s cubic-bezier(.32,0,.67,0);
  box-shadow:-16px 0 48px rgba(0,0,0,0.5);
}
.dg-drawer.open { transform:none; transition-timing-function:cubic-bezier(.22,1,.36,1); }
.dg-dr-hdr { display:flex; align-items:center; justify-content:space-between; padding:18px 20px; border-bottom:1px solid var(--bdr); }
.dg-dr-title { font-size:17px; font-weight:800; color:var(--cream); }
.dg-dr-close { width:32px; height:32px; border-radius:50%; background:var(--card2); border:1px solid var(--bdr); color:var(--t1); font-size:15px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .18s; }
.dg-dr-close:hover { background:var(--gdim); color:var(--gold); }
.dg-dr-body { flex:1; overflow-y:auto; padding:12px 16px; }
.dg-dr-item { display:flex; align-items:center; gap:12px; padding:12px 0; border-bottom:1px solid var(--bdr); }
.dg-dr-img { width:50px; height:50px; border-radius:10px; object-fit:cover; background:var(--card2); flex-shrink:0; font-size:20px; display:flex; align-items:center; justify-content:center; }
.dg-dr-img img { width:100%; height:100%; object-fit:cover; border-radius:10px; }
.dg-dr-info { flex:1; min-width:0; }
.dg-dr-name { font-size:13px; font-weight:700; color:var(--cream); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.dg-dr-price { font-size:12px; font-weight:800; color:var(--gold); margin-top:2px; }
.dg-dr-qty { display:flex; align-items:center; gap:5px; background:var(--card); border:1px solid var(--bdr2); border-radius:8px; padding:3px 5px; flex-shrink:0; }
.dg-dr-qbtn { background:none; border:none; color:var(--gold); font-size:15px; font-weight:800; cursor:pointer; width:18px; height:18px; display:flex; align-items:center; justify-content:center; }
.dg-dr-qval { font-size:13px; font-weight:800; color:var(--cream); min-width:16px; text-align:center; }
.dg-dr-empty { text-align:center; padding:60px 20px; color:var(--t2); }
.dg-dr-empty-ico { font-size:48px; margin-bottom:12px; }
.dg-dr-foot { border-top:1px solid var(--bdr); padding:14px 20px 20px; }
.dg-dr-row { display:flex; justify-content:space-between; font-size:13px; color:var(--t2); margin-bottom:8px; }
.dg-dr-total { display:flex; justify-content:space-between; font-size:18px; font-weight:800; color:var(--cream); margin-bottom:16px; }
.dg-dr-total span:last-child { color:var(--gold); }
.dg-dr-cta { width:100%; background:linear-gradient(135deg,var(--gold),var(--gold2)); color:#000; font-size:15px; font-weight:800; padding:14px; border-radius:13px; border:none; cursor:pointer; font-family:inherit; transition:all .22s; }
.dg-dr-cta:hover { transform:translateY(-2px); box-shadow:0 8px 24px var(--glow); }

/* ═══ STICKY BAR ═════════════════════════════════════ */
.dg-bar {
  position:fixed; bottom:0; left:0; right:0; z-index:799;
  background:var(--bg2); border-top:1.5px solid var(--bdr2);
  padding:10px 16px 18px;
  display:none; align-items:center; justify-content:space-between; gap:12px;
  box-shadow:0 -10px 32px rgba(0,0,0,0.5);
}
.dg-bar.vis { display:flex; }
.dg-bar-c { font-size:11px; color:var(--t2); margin-bottom:1px; }
.dg-bar-t { font-size:20px; font-weight:800; color:var(--gold); }
.dg-bar-btn { background:linear-gradient(135deg,var(--gold),var(--gold2)); color:#000; font-size:14px; font-weight:800; padding:13px 28px; border-radius:13px; border:none; cursor:pointer; font-family:inherit; white-space:nowrap; transition:all .22s; }
.dg-bar-btn:hover { transform:scale(1.04); box-shadow:0 6px 22px var(--glow); }

/* ═══ TOAST ══════════════════════════════════════════ */
.dg-toast { position:fixed; bottom:86px; left:50%; transform:translateX(-50%) translateY(10px); background:var(--card2); border:1px solid var(--bdr2); border-radius:12px; padding:11px 20px; font-size:13px; font-weight:700; color:var(--cream); z-index:950; opacity:0; pointer-events:none; white-space:nowrap; transition:all .28s; box-shadow:0 8px 32px rgba(0,0,0,0.4); }
.dg-toast.on { opacity:1; transform:translateX(-50%) translateY(0); }

/* ═══ EMPTY ══════════════════════════════════════════ */
.dg-empty { text-align:center; padding:80px 20px; color:var(--t2); }
.dg-empty-ico { font-size:52px; margin-bottom:14px; }
.dg-empty h3 { font-size:20px; font-weight:800; color:var(--cream); margin-bottom:8px; }

/* ═══ SEARCH STATE ═══════════════════════════════════ */
.dg-search-results { padding:6px 14px 0; }
.dg-sr-label { font-size:11px; color:var(--t3); font-weight:600; text-transform:uppercase; letter-spacing:1px; margin-bottom:10px; }
</style>

<div class="dg-wrap" id="dgWrap">

