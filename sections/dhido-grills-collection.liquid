</style>

<div class="dg-wrap" id="dgWrap">

  <!-- HERO -->
  <div class="dg-hero">
    <span class="dg-fp" style="left:6%;top:22%;--d:7s;--dl:0s">🥘</span>
    <span class="dg-fp" style="left:14%;top:68%;--d:9s;--dl:1.2s">🍖</span>
    <span class="dg-fp" style="left:79%;top:16%;--d:8s;--dl:0.4s">🥟</span>
    <span class="dg-fp" style="left:87%;top:64%;--d:10s;--dl:2s">🍜</span>
    <span class="dg-fp" style="left:48%;top:80%;--d:6.5s;--dl:0.8s">🌶️</span>
    <div class="dg-hero-badge">🌿 Authentic Nepali Cuisine</div>
    <h1 class="dg-hero-title">The Dhido &<br><em>The Grills</em></h1>
    <p class="dg-hero-sub">The Essence of Nepal</p>
    <div class="dg-hero-pills">
      <span class="dg-hero-pill">⚡ <b>20 min</b> delivery</span>
      <span class="dg-hero-pill">⭐ <b>4.8</b> rated</span>
      <span class="dg-hero-pill">🔥 <b>Fresh</b> daily</span>
    </div>
    <svg class="dg-hero-wave" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 40" preserveAspectRatio="none">
      <path fill="#0a1a0d" d="M0,24 C360,44 1080,4 1440,28 L1440,40 L0,40Z"/>
    </svg>
  </div>

  <!-- INFO BAR -->
  <div class="dg-infobar">
    <div class="dg-ib-item"><div class="dg-ib-val">4.8 ⭐</div><div class="dg-ib-lbl">Rating</div></div>
    <div class="dg-ib-item"><div class="dg-ib-val">20 min</div><div class="dg-ib-lbl">Delivery</div></div>
    <div class="dg-ib-item"><div class="dg-ib-val">{{ collection.products_count }}</div><div class="dg-ib-lbl">Items</div></div>
    <div class="dg-ib-item"><div class="dg-ib-val">Rs 0</div><div class="dg-ib-lbl">Min Order</div></div>
    <div class="dg-ib-item"><div class="dg-ib-val">🟢 Open</div><div class="dg-ib-lbl">Now</div></div>
  </div>

  <!-- SEARCH -->
  <div class="dg-search-wrap">
    <div class="dg-search">
      <span class="dg-search-ico">🔍</span>
      <input type="text" id="dgSearch" placeholder="Search dishes, grills, momos..." autocomplete="off">
      <button class="dg-search-clear" id="dgSearchClear" onclick="dgClearSearch()">✕</button>
    </div>
  </div>

  <!-- SEARCH RESULTS PANEL (hidden by default) -->
  <div id="dgSearchPanel" style="display:none">
    <div class="dg-search-results">
      <div class="dg-sr-label" id="dgSrLabel">Results</div>
      <div class="dg-grid" id="dgSrGrid"></div>
    </div>
  </div>

  <!-- CATEGORY PILLS -->
  <nav class="dg-cat-outer" id="dgCatOuter">
    <div class="dg-cat-scroll" id="dgCats">
      {%- if cnt_specials > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-specials">🌟 Specials <span class="dg-cat-count">{{ cnt_specials }}</span></button>{%- endif -%}
      {%- if cnt_dhido > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-dhido">🫙 Dhido <span class="dg-cat-count">{{ cnt_dhido }}</span></button>{%- endif -%}
      {%- if cnt_grills > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-grills">🥩 Grills <span class="dg-cat-count">{{ cnt_grills }}</span></button>{%- endif -%}
      {%- if cnt_momo > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-momo">🥟 Momo <span class="dg-cat-count">{{ cnt_momo }}</span></button>{%- endif -%}
      {%- if cnt_noodles > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-noodles">🍜 Noodles <span class="dg-cat-count">{{ cnt_noodles }}</span></button>{%- endif -%}
      {%- if cnt_burger > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-burger">🍔 Burgers <span class="dg-cat-count">{{ cnt_burger }}</span></button>{%- endif -%}
      {%- if cnt_snacks > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-snacks">🍟 Snacks <span class="dg-cat-count">{{ cnt_snacks }}</span></button>{%- endif -%}
      {%- if cnt_beverages > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-bev">🥤 Drinks <span class="dg-cat-count">{{ cnt_beverages }}</span></button>{%- endif -%}
      {%- if cnt_lassi > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-lassi">🥛 Lassi <span class="dg-cat-count">{{ cnt_lassi }}</span></button>{%- endif -%}
      {%- if cnt_icecream > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-ice">🍦 Desserts <span class="dg-cat-count">{{ cnt_icecream }}</span></button>{%- endif -%}
      {%- if cnt_other > 0 -%}<button class="dg-cat-pill" data-target="dg-sec-other">🍽️ More <span class="dg-cat-count">{{ cnt_other }}</span></button>{%- endif -%}
    </div>
  </nav>

  <!-- SECTIONS -->
  <main id="dgMain">

    {%- if collection.products_count == 0 -%}
      <div class="dg-empty">
        <div class="dg-empty-ico">🍽️</div>
        <h3>Menu Coming Soon</h3>
        <p>Something delicious is on the way!</p>
      </div>
    {%- else -%}

    {%- comment -%}── SPECIALS ──{%- endcomment -%}
    {%- if cnt_specials > 0 -%}
    <section class="dg-section" id="dg-sec-specials">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🌟</div>
          <div class="dg-sec-name">Today's Specials</div>
        </div>
        <div class="dg-sec-count">{{ cnt_specials }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid" id="dg-grid-specials">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'special' or _ptl contains 'special' or _ptl contains 'combo' or _ptl contains 'thali' or _ptl contains 'set' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── DHIDO / DAL BHAT ──{%- endcomment -%}
    {%- if cnt_dhido > 0 -%}
    <section class="dg-section" id="dg-sec-dhido">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🫙</div>
          <div class="dg-sec-name">Dhido & Dal Bhat</div>
        </div>
        <div class="dg-sec-count">{{ cnt_dhido }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'dhido' or _ptl contains 'dhido' or _ptl contains 'dal bhat' or _ptl contains 'dal-bhat' or _ptl contains 'bhat' or _ptl contains 'gundruk' or _ptl contains 'tarkari' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── GRILLS ──{%- endcomment -%}
    {%- if cnt_grills > 0 -%}
    <section class="dg-section" id="dg-sec-grills">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🥩</div>
          <div class="dg-sec-name">Grills & Sekuwa</div>
        </div>
        <div class="dg-sec-count">{{ cnt_grills }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'grill' or _ptl contains 'grill' or _ptl contains 'sekuwa' or _ptl contains 'bbq' or _ptl contains 'chop' or _ptl contains 'buff' or _ptl contains 'mutton' or _ptl contains 'chicken sekuwa' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── MOMO ──{%- endcomment -%}
    {%- if cnt_momo > 0 -%}
    <section class="dg-section" id="dg-sec-momo">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🥟</div>
          <div class="dg-sec-name">Momo</div>
        </div>
        <div class="dg-sec-count">{{ cnt_momo }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'momo' or _ptl contains 'momo' or _ptl contains 'dumpling' or _ptl contains 'kothey' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── NOODLES ──{%- endcomment -%}
    {%- if cnt_noodles > 0 -%}
    <section class="dg-section" id="dg-sec-noodles">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🍜</div>
          <div class="dg-sec-name">Noodles & Thukpa</div>
        </div>
        <div class="dg-sec-count">{{ cnt_noodles }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'noodle' or _ptl contains 'noodle' or _ptl contains 'chow' or _ptl contains 'thukpa' or _ptl contains 'chowmein' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── BURGERS ──{%- endcomment -%}
    {%- if cnt_burger > 0 -%}
    <section class="dg-section" id="dg-sec-burger">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🍔</div>
          <div class="dg-sec-name">Burgers & Wraps</div>
        </div>
        <div class="dg-sec-count">{{ cnt_burger }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'burger' or _pt contains 'sandwich' or _ptl contains 'burger' or _ptl contains 'sandwich' or _ptl contains 'wrap' or _ptl contains 'roll' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── SNACKS ──{%- endcomment -%}
    {%- if cnt_snacks > 0 -%}
    <section class="dg-section" id="dg-sec-snacks">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🍟</div>
          <div class="dg-sec-name">Snacks & Sides</div>
        </div>
        <div class="dg-sec-count">{{ cnt_snacks }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'snack' or _ptl contains 'snack' or _ptl contains 'fries' or _ptl contains 'chips' or _ptl contains 'samosa' or _ptl contains 'pakoda' or _ptl contains 'spring roll' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── BEVERAGES ──{%- endcomment -%}
    {%- if cnt_beverages > 0 -%}
    <section class="dg-section" id="dg-sec-bev">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🥤</div>
          <div class="dg-sec-name">Drinks & Juices</div>
        </div>
        <div class="dg-sec-count">{{ cnt_beverages }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'beverage' or _pt contains 'drink' or _ptl contains 'juice' or _ptl contains 'tea' or _ptl contains 'coffee' or _ptl contains 'shake' or _ptl contains 'lemonade' or _ptl contains 'soda' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── LASSI ──{%- endcomment -%}
    {%- if cnt_lassi > 0 -%}
    <section class="dg-section" id="dg-sec-lassi">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🥛</div>
          <div class="dg-sec-name">Lassi</div>
        </div>
        <div class="dg-sec-count">{{ cnt_lassi }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'lassi' or _ptl contains 'lassi' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── ICE CREAM ──{%- endcomment -%}
    {%- if cnt_icecream > 0 -%}
    <section class="dg-section" id="dg-sec-ice">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🍦</div>
          <div class="dg-sec-name">Desserts</div>
        </div>
        <div class="dg-sec-count">{{ cnt_icecream }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- if _pt contains 'ice' or _ptl contains 'ice cream' or _ptl contains 'gelato' or _ptl contains 'kulfi' -%}{%- render 'dg-product-card', product: p -%}{%- endif -%}{%- endfor -%}
      </div>
    </section>
    <div class="dg-sep"></div>
    {%- endif -%}

    {%- comment -%}── OTHER ──{%- endcomment -%}
    {%- if cnt_other > 0 -%}
    <section class="dg-section" id="dg-sec-other">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🍽️</div>
          <div class="dg-sec-name">More from the Kitchen</div>
        </div>
        <div class="dg-sec-count">{{ cnt_other }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}{%- assign _pt=p.type|downcase|strip -%}{%- assign _ptl=p.title|downcase|strip -%}{%- unless _pt contains 'special' or _ptl contains 'special' or _ptl contains 'combo' or _ptl contains 'thali' or _ptl contains 'set' or _pt contains 'dhido' or _ptl contains 'dhido' or _ptl contains 'dal bhat' or _ptl contains 'bhat' or _ptl contains 'gundruk' or _ptl contains 'tarkari' or _pt contains 'grill' or _ptl contains 'grill' or _ptl contains 'sekuwa' or _ptl contains 'bbq' or _ptl contains 'chop' or _ptl contains 'buff' or _ptl contains 'mutton' or _pt contains 'momo' or _ptl contains 'momo' or _ptl contains 'dumpling' or _ptl contains 'kothey' or _pt contains 'noodle' or _ptl contains 'noodle' or _ptl contains 'chow' or _ptl contains 'thukpa' or _ptl contains 'chowmein' or _pt contains 'burger' or _ptl contains 'burger' or _ptl contains 'sandwich' or _ptl contains 'wrap' or _ptl contains 'roll' or _pt contains 'snack' or _ptl contains 'snack' or _ptl contains 'fries' or _ptl contains 'chips' or _pt contains 'beverage' or _pt contains 'drink' or _ptl contains 'juice' or _ptl contains 'tea' or _ptl contains 'coffee' or _ptl contains 'shake' or _pt contains 'lassi' or _ptl contains 'lassi' or _pt contains 'ice' or _ptl contains 'ice cream' or _ptl contains 'gelato' or _ptl contains 'kulfi' -%}{%- render 'dg-product-card', product: p -%}{%- endunless -%}{%- endfor -%}
      </div>
    </section>
    {%- endif -%}

    {%- comment -%}── FALLBACK: if all category counts are 0 but products exist, show everything ──{%- endcomment -%}
    {%- assign _any = cnt_specials | plus: cnt_dhido | plus: cnt_grills | plus: cnt_momo | plus: cnt_noodles | plus: cnt_burger | plus: cnt_snacks | plus: cnt_beverages | plus: cnt_lassi | plus: cnt_icecream | plus: cnt_other -%}
    {%- if _any == 0 and collection.products_count > 0 -%}
    <section class="dg-section" id="dg-sec-all">
      <div class="dg-sec-hdr">
        <div class="dg-sec-left">
          <div class="dg-sec-ico">🍽️</div>
          <div class="dg-sec-name">Our Menu</div>
        </div>
        <div class="dg-sec-count">{{ collection.products_count }} items</div>
      </div>
      <div class="dg-sec-divider"></div>
      <div class="dg-grid">
        {%- for p in collection.products limit:250 -%}
          {%- render 'dg-product-card', product: p -%}
        {%- endfor -%}
      </div>
    </section>
    {%- endif -%}

    {%- endif -%}
  </main>
  <!-- debug: specials={{ cnt_specials }} dhido={{ cnt_dhido }} grills={{ cnt_grills }} momo={{ cnt_momo }} noodles={{ cnt_noodles }} burger={{ cnt_burger }} snacks={{ cnt_snacks }} bev={{ cnt_beverages }} lassi={{ cnt_lassi }} ice={{ cnt_icecream }} other={{ cnt_other }} total={{ _any }} prods={{ collection.products_count }} -->

  <!-- TRUST -->
  <div class="dg-trust">
    <div class="dg-trust-item"><div class="dg-trust-ico">🔥</div><div class="dg-trust-lbl">Fresh Cooked</div></div>
    <div class="dg-trust-item"><div class="dg-trust-ico">⚡</div><div class="dg-trust-lbl">20 Min Delivery</div></div>
    <div class="dg-trust-item"><div class="dg-trust-ico">🌿</div><div class="dg-trust-lbl">Authentic Nepali</div></div>
    <div class="dg-trust-item"><div class="dg-trust-ico">⭐</div><div class="dg-trust-lbl">4.8 Rated</div></div>
  </div>

</div>

<!-- Sticky bar removed — universal qb-sticky-cart handles this -->

<div class="dg-toast" id="dgToast"></div>

<script>
(function(){
  var cart = { items:[], item_count:0, total_price:0 };
  var SECTION_IDS = ['dg-sec-specials','dg-sec-dhido','dg-sec-grills','dg-sec-momo','dg-sec-noodles','dg-sec-burger','dg-sec-snacks','dg-sec-bev','dg-sec-lassi','dg-sec-ice','dg-sec-other'];

  document.addEventListener('DOMContentLoaded', function(){
    dgFetch();
    dgCatInit();
    dgSearchInit();
  });

  /* ── Open global cart drawer ── */
  window.dgOpenGlobalCart = function(){
    var drawer = document.querySelector('cart-drawer-component');
    if(drawer && typeof drawer.open === 'function') { drawer.open(); }
    else { window.location.href = '/cart'; }
  };

  /* ── Notify global cart system ── */
  function dgNotifyGlobal(){
    document.dispatchEvent(new Event('cart:update', {bubbles:true}));
  }

  /* ── CART FETCH (for steppers + sticky bar only) ── */
  function dgFetch(){
    fetch('/cart.js').then(function(r){return r.json();}).then(function(c){
      cart=c; dgUpdateBar(); dgSteppers();
    }).catch(function(){});
  }

  window.dgAdd = function(btn){
    var vid  = btn.dataset.variant;
    var name = btn.dataset.name||'Item';
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:parseInt(vid),quantity:1})})
    .then(function(r){return r.json();}).then(function(){
      dgFetch(); dgNotifyGlobal(); dgToast('Added: '+name);
      var sp=document.createElement('span'); sp.className='ripple';
      sp.style.cssText='width:36px;height:36px;left:50%;top:50%;margin:-18px 0 0 -18px;';
      btn.appendChild(sp); setTimeout(function(){sp.remove();},550);
    });
  };

  window.dgChg = function(key,qty){
    fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:key,quantity:qty})})
    .then(function(r){return r.json();}).then(function(){ dgFetch(); dgNotifyGlobal(); });
  };

  /* ── STICKY BAR SYNC (no local drawer) ── */
  function dgUpdateBar(){
    var cnt=cart.item_count||0, tot=cart.total_price||0;
    var str='Rs '+(tot/100).toLocaleString('en-NP');
    var bar=document.getElementById('dgBar');
    if(bar) bar.classList.toggle('vis',cnt>0);
    var bc=document.getElementById('dgBarC'),bt=document.getElementById('dgBarT');
    if(bc) bc.textContent=cnt+(cnt===1?' item':' items');
    if(bt) bt.textContent=str;
  }

  function dgSteppers(){
    document.querySelectorAll('.dg-card[data-v]').forEach(function(el){
      var vid=el.dataset.v;
      var item=(cart.items||[]).find(function(i){return String(i.variant_id)===String(vid);});
      var add=el.querySelector('.dg-add'), step=el.querySelector('.dg-stepper'), val=el.querySelector('.dg-s-val');
      if(item&&item.quantity>0){
        if(add) add.style.display='none';
        if(step) step.classList.add('vis');
        if(val) val.textContent=item.quantity;
      } else {
        if(add) add.style.display='';
        if(step) step.classList.remove('vis');
      }
    });
  }

  /* ── BUTTON DELEGATION ── */
  document.addEventListener('click',function(e){
    var ab=e.target.closest('.dg-add:not([disabled])');
    if(ab&&!ab.closest('.dg-stepper')){
      var card=ab.closest('.dg-card[data-v]');
      if(card) dgAdd(Object.assign(ab,{dataset:{variant:card.dataset.v,name:card.dataset.n||''}}));
      return;
    }
    var mb=e.target.closest('.dg-s-btn[data-a="minus"]');
    if(mb){
      var card=mb.closest('.dg-card[data-v]');
      if(card){var it=(cart.items||[]).find(function(i){return String(i.variant_id)===String(card.dataset.v);});if(it)dgChg(it.key,it.quantity-1);}
      return;
    }
    var pb=e.target.closest('.dg-s-btn[data-a="plus"]');
    if(pb){
      var card=pb.closest('.dg-card[data-v]');
      if(card){
        var it=(cart.items||[]).find(function(i){return String(i.variant_id)===String(card.dataset.v);});
        if(it)dgChg(it.key,it.quantity+1);
        else dgAdd(Object.assign(pb,{dataset:{variant:card.dataset.v,name:card.dataset.n||''}}));
      } return;
    }
  });

  /* ── CATEGORY NAV — scroll anchors + IntersectionObserver highlight ── */
  function dgCatInit(){
    var pills = document.querySelectorAll('.dg-cat-pill[data-target]');

    // Activate first visible pill on load
    if(pills.length > 0) pills[0].classList.add('act');

    // Click → smooth scroll to section
    pills.forEach(function(pill){
      pill.addEventListener('click',function(){
        var target = document.getElementById(this.dataset.target);
        if(!target) return;
        var catTop = document.getElementById('dgCatOuter');
        var offset = catTop ? catTop.offsetHeight : 56;
        var y = target.getBoundingClientRect().top + window.scrollY - offset - 8;
        window.scrollTo({top:y, behavior:'smooth'});
        setActive(this);
        this.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
      });
    });

    // IntersectionObserver → auto-highlight pill when section is in view
    if(!('IntersectionObserver' in window)) return;
    var obs = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if(entry.isIntersecting){
          var id = entry.target.id;
          var pill = document.querySelector('.dg-cat-pill[data-target="'+id+'"]');
          if(pill){ setActive(pill); pill.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'}); }
        }
      });
    },{rootMargin:'-30% 0px -60% 0px', threshold:0});

    SECTION_IDS.forEach(function(id){
      var el=document.getElementById(id);
      if(el) obs.observe(el);
    });
  }

  function setActive(activePill){
    document.querySelectorAll('.dg-cat-pill').forEach(function(p){p.classList.remove('act');});
    activePill.classList.add('act');
  }

  /* ── SEARCH ── */
  function dgSearchInit(){
    var inp=document.getElementById('dgSearch');
    var clr=document.getElementById('dgSearchClear');
    if(!inp) return;
    inp.addEventListener('input',function(){
      var q=this.value.trim().toLowerCase();
      clr&&clr.classList.toggle('vis', q.length>0);
      dgSearchRun(q);
    });
  }

  function dgSearchRun(q){
    var panel=document.getElementById('dgSearchPanel');
    var main=document.getElementById('dgMain');
    var catOuter=document.getElementById('dgCatOuter');
    var grid=document.getElementById('dgSrGrid');
    var label=document.getElementById('dgSrLabel');
    if(!panel||!main||!grid) return;

    if(!q){
      panel.style.display='none'; main.style.display=''; return;
    }

    // Search across all products
    var allCards=document.querySelectorAll('#dgMain .dg-card[data-v]');
    var matches=[];
    allCards.forEach(function(c){
      if((c.dataset.n||'').toLowerCase().includes(q)) matches.push(c.cloneNode(true));
    });

    panel.style.display='';
    main.style.display='none';
    label.textContent=matches.length+' result'+(matches.length!==1?'s':'')+ ' for "'+q+'"';
    grid.innerHTML='';
    if(matches.length===0){
      grid.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:40px 0;color:var(--t2)"><div style="font-size:40px;margin-bottom:12px">🤷</div><p>No dishes found</p></div>';
    } else {
      matches.forEach(function(c){ grid.appendChild(c); });
    }
    // Re-bind steppers on cloned cards
    dgSteppers();
  }

  window.dgClearSearch = function(){
    var inp=document.getElementById('dgSearch');
    var clr=document.getElementById('dgSearchClear');
    if(inp) inp.value='';
    if(clr) clr.classList.remove('vis');
    dgSearchRun('');
  };

  /* ── DRAWER ── */
  window.dgDrawerToggle=function(){
    var ov=document.getElementById('dgOverlay'),dr=document.getElementById('dgDrawer');
    var op=dr.classList.contains('open');
    ov.classList.toggle('open',!op); dr.classList.toggle('open',!op);
    document.body.style.overflow=op?'':'hidden';
  };

  /* ── TOAST ── */
  var tt;
  window.dgToast=function(msg){
    var t=document.getElementById('dgToast');
    if(!t) return;
    t.textContent='✅ '+msg; t.classList.add('on');
    clearTimeout(tt); tt=setTimeout(function(){t.classList.remove('on');},2000);
  };

})();
</script>

