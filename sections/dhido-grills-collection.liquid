    <div class="dg-trust-item"><div class="dg-trust-ico">⚡</div><div class="dg-trust-lbl">Fast Delivery</div></div>
    <div class="dg-trust-item"><div class="dg-trust-ico">🌿</div><div class="dg-trust-lbl">Authentic</div></div>
    <div class="dg-trust-item"><div class="dg-trust-ico">⭐</div><div class="dg-trust-lbl">Top Rated</div></div>
  </div>

</div><!-- /dg-wrap -->

<!-- FAB -->
<button class="dg-fab" id="dgFab" onclick="dgDrawerToggle()" aria-label="Cart">
  🛒<span class="dg-fab-badge" id="dgFabBadge">0</span>
</button>

<!-- DRAWER -->
<div class="dg-overlay" id="dgOverlay" onclick="dgDrawerToggle()"></div>
<div class="dg-drawer" id="dgDrawer">
  <div class="dg-dr-hdr">
    <div class="dg-dr-title">🛒 Your Order</div>
    <button class="dg-dr-close" onclick="dgDrawerToggle()">✕</button>
  </div>
  <div class="dg-dr-body" id="dgDrBody">
    <div class="dg-dr-empty"><div class="dg-dr-empty-ico">🍽️</div><p>Nothing added yet</p></div>
  </div>
  <div class="dg-dr-foot" id="dgDrFoot" style="display:none">
    <div class="dg-dr-row"><span>Subtotal</span><span id="dgDrSub">Rs 0</span></div>
    <div class="dg-dr-total"><span>Total</span><span id="dgDrTot">Rs 0</span></div>
    <button class="dg-dr-cta" onclick="window.location.href='/pages/payment'">Proceed to Checkout →</button>
  </div>
</div>

<!-- STICKY BAR -->
<div class="dg-bar" id="dgBar">
  <div class="dg-bar-info">
    <div class="dg-bar-c" id="dgBarC">0 items</div>
    <div class="dg-bar-t" id="dgBarT">Rs 0</div>
  </div>
  <button class="dg-bar-btn" onclick="window.location.href='/pages/payment'">Checkout →</button>
</div>

<!-- TOAST -->
<div class="dg-toast" id="dgToast"></div>

<script>
(function(){
  var cart = { items:[], item_count:0, total_price:0 };

  /* ─ INIT ─ */
  document.addEventListener('DOMContentLoaded', function(){
    dgFetch();
    dgCatInit();
    dgReveal();
    dgSearchInit();
  });

  /* ─ CART ─ */
  function dgFetch(){
    fetch('/cart.js').then(function(r){return r.json();}).then(function(c){
      cart = c; dgUI(); dgSteppers();
    }).catch(function(){});
  }

  window.dgAdd = function(btn){
    var vid  = btn.dataset.variant;
    var name = btn.dataset.name || 'Item';
    fetch('/cart/add.js',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({id:parseInt(vid), quantity:1})
    }).then(function(r){return r.json();}).then(function(){
      dgFetch(); dgToast('Added: '+name);
      var sp = document.createElement('span');
      sp.className = 'ripple';
      sp.style.cssText = 'width:40px;height:40px;left:50%;top:50%;margin:-20px 0 0 -20px;';
      btn.appendChild(sp); setTimeout(function(){sp.remove();},550);
    });
  };

  window.dgChg = function(key, qty){
    fetch('/cart/change.js',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({id:key, quantity:qty})
    }).then(function(r){return r.json();}).then(function(){ dgFetch(); });
  };

  /* ─ UI SYNC ─ */
  function dgUI(){
    var cnt = cart.item_count || 0;
    var tot = cart.total_price || 0;
    var str = 'Rs '+(tot/100).toLocaleString('en-NP');

    /* FAB */
    var badge = document.getElementById('dgFabBadge');
    if(badge){ badge.textContent = cnt; badge.classList.toggle('vis', cnt>0); }

    /* Bar */
    var bar = document.getElementById('dgBar');
    if(bar) bar.classList.toggle('vis', cnt>0);
    var bc = document.getElementById('dgBarC');
    var bt = document.getElementById('dgBarT');
    if(bc) bc.textContent = cnt+(cnt===1?' item':' items');
    if(bt) bt.textContent = str;

    /* Drawer */
    var body = document.getElementById('dgDrBody');
    var foot = document.getElementById('dgDrFoot');
    var sub  = document.getElementById('dgDrSub');
    var tot2 = document.getElementById('dgDrTot');
    if(!body) return;
    if(cnt===0){
      body.innerHTML='<div class="dg-dr-empty"><div class="dg-dr-empty-ico">🍽️</div><p>Nothing added yet</p></div>';
      if(foot) foot.style.display='none'; return;
    }
    if(foot) foot.style.display='';
    if(sub) sub.textContent=str;
    if(tot2) tot2.innerHTML='<span>Total</span><span>'+str+'</span>';

    var html='';
    (cart.items||[]).forEach(function(item){
      var imgSrc = item.image ? item.image.replace(/(\.\w+)$/, '_100x100$1') : '';
      html+='<div class="dg-dr-item">'+
        (imgSrc
          ?'<div class="dg-dr-img"><img src="'+imgSrc+'" alt="" loading="lazy"></div>'
          :'<div class="dg-dr-img" style="font-size:22px">🍽️</div>')+
        '<div class="dg-dr-info"><div class="dg-dr-name">'+item.product_title+'</div>'+
        '<div class="dg-dr-price">Rs '+(item.final_line_price/100).toLocaleString('en-NP')+'</div></div>'+
        '<div class="dg-dr-qty">'+
          '<button class="dg-dr-qbtn" onclick="dgChg(\''+item.key+'\','+(item.quantity-1)+')">−</button>'+
          '<span class="dg-dr-qval">'+item.quantity+'</span>'+
          '<button class="dg-dr-qbtn" onclick="dgChg(\''+item.key+'\','+(item.quantity+1)+')">+</button>'+
        '</div></div>';
    });
    body.innerHTML=html;
  }

  function dgSteppers(){
    document.querySelectorAll('.dg-item[data-v]').forEach(function(el){
      var vid  = el.dataset.v;
      var item = (cart.items||[]).find(function(i){ return String(i.variant_id)===String(vid); });
      var add  = el.querySelector('.dg-add');
      var step = el.querySelector('.dg-stepper');
      var val  = el.querySelector('.dg-s-val');
      if(item && item.quantity>0){
        if(add) add.style.display='none';
        if(step) step.classList.add('vis');
        if(val) val.textContent = item.quantity;
      } else {
        if(add) add.style.display='';
        if(step) step.classList.remove('vis');
      }
    });
  }

  /* ─ BUTTON DELEGATION ─ */
  document.addEventListener('click', function(e){
    /* Add btn */
    var ab = e.target.closest('.dg-add:not([disabled])');
    if(ab && !ab.closest('.dg-stepper')){
      var card = ab.closest('.dg-item[data-v]');
      if(card) dgAdd(Object.assign(ab, {dataset:{variant:card.dataset.v, name:card.dataset.n||''}}));
      return;
    }
    /* Minus */
    var mb = e.target.closest('.dg-s-btn[data-a="minus"]');
    if(mb){
      var card = mb.closest('.dg-item[data-v]');
      if(card){
        var it = (cart.items||[]).find(function(i){return String(i.variant_id)===String(card.dataset.v);});
        if(it) dgChg(it.key, it.quantity-1);
      } return;
    }
    /* Plus */
    var pb = e.target.closest('.dg-s-btn[data-a="plus"]');
    if(pb){
      var card = pb.closest('.dg-item[data-v]');
      if(card){
        var it = (cart.items||[]).find(function(i){return String(i.variant_id)===String(card.dataset.v);});
        if(it) dgChg(it.key, it.quantity+1);
        else dgAdd(Object.assign(pb, {dataset:{variant:card.dataset.v, name:card.dataset.n||''}}));
      } return;
    }
  });

  /* ─ CATEGORY NAV ─ */
  function dgCatInit(){
    document.querySelectorAll('.dg-cat-btn').forEach(function(btn){
      btn.addEventListener('click',function(){
        document.querySelectorAll('.dg-cat-btn').forEach(function(b){b.classList.remove('act');});
        this.classList.add('act');
        var cat = this.dataset.cat;
        document.getElementById('dgAll').style.display = cat==='all' ? '' : 'none';
        ['lassi','noodles','grills','burger','momo','snacks','beverages','icecream'].forEach(function(k){
          var el = document.getElementById('dgCat_'+k);
          if(el) el.style.display = (cat===k) ? '' : 'none';
        });
        this.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
        /* reset search */
        var si = document.getElementById('dgSearch');
        if(si){ si.value=''; dgSearchRun(''); }
      });
    });
  }

  /* ─ SEARCH ─ */
  function dgSearchInit(){
    var inp = document.getElementById('dgSearch');
    if(!inp) return;
    inp.addEventListener('input', function(){ dgSearchRun(this.value.trim().toLowerCase()); });
  }
  function dgSearchRun(q){
    document.querySelectorAll('.dg-item').forEach(function(el){
      if(!q){ el.style.display=''; return; }
      var name = (el.dataset.n||'').toLowerCase();
      el.style.display = name.includes(q) ? '' : 'none';
    });
  }

  /* ─ DRAWER ─ */
  window.dgDrawerToggle = function(){
    var ov = document.getElementById('dgOverlay');
    var dr = document.getElementById('dgDrawer');
    var op = dr.classList.contains('open');
    ov.classList.toggle('open',!op);
    dr.classList.toggle('open',!op);
    document.body.style.overflow = op ? '' : 'hidden';
  };

  /* ─ TOAST ─ */
  var tt;
  window.dgToast = function(msg){
    var t = document.getElementById('dgToast');
    if(!t) return;
    t.textContent = '✅ '+msg;
    t.classList.add('on');
    clearTimeout(tt);
    tt = setTimeout(function(){ t.classList.remove('on'); }, 2000);
  };

  /* ─ SCROLL REVEAL ─ */
  function dgReveal(){
    if(!('IntersectionObserver' in window)){
      document.querySelectorAll('.dg-r').forEach(function(el){el.classList.add('in');});
      return;
    }
    var obs = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); obs.unobserve(e.target); } });
    },{threshold:.1});
    document.querySelectorAll('.dg-r').forEach(function(el){ obs.observe(el); });
  }

})();
</script>

{% schema %}
{ "name": "Dhido & Grills Collection", "settings": [], "presets": [{"name":"Dhido & Grills Collection"}] }
{% endschema %}
