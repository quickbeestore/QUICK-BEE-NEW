      </div>
      {%- endif -%}

      <!-- NOODLES -->
      {%- if cat_noodles.size > 0 -%}
      <div id="dgCat_noodles" style="display:none">
        <div class="dg-sh"><div class="dg-sh-title">🍜 <span>Noodles</span></div><div class="dg-sh-count">{{ cat_noodles.size }} items</div></div>
        <div class="dg-list">{%- for p in cat_noodles -%}{%- render 'dg-menu-item', product: p -%}{%- endfor -%}</div>
      </div>
      {%- endif -%}

      <!-- GRILLS -->
      {%- if cat_grills.size > 0 -%}
      <div id="dgCat_grills" style="display:none">
        <div class="dg-sh"><div class="dg-sh-title">🥩 <span>Grills</span></div><div class="dg-sh-count">{{ cat_grills.size }} items</div></div>
        <div class="dg-list">{%- for p in cat_grills -%}{%- render 'dg-menu-item', product: p -%}{%- endfor -%}</div>
      </div>
      {%- endif -%}

      <!-- BURGER -->
      {%- if cat_burger.size > 0 -%}
      <div id="dgCat_burger" style="display:none">
        <div class="dg-sh"><div class="dg-sh-title">🍔 <span>Burgers &amp; Sandwiches</span></div><div class="dg-sh-count">{{ cat_burger.size }} items</div></div>
        <div class="dg-list">{%- for p in cat_burger -%}{%- render 'dg-menu-item', product: p -%}{%- endfor -%}</div>
      </div>
      {%- endif -%}

      <!-- MOMO -->
      {%- if cat_momo.size > 0 -%}
      <div id="dgCat_momo" style="display:none">
        <div class="dg-sh"><div class="dg-sh-title">🥟 <span>Momo</span></div><div class="dg-sh-count">{{ cat_momo.size }} items</div></div>
        <div class="dg-list">{%- for p in cat_momo -%}{%- render 'dg-menu-item', product: p -%}{%- endfor -%}</div>
      </div>
      {%- endif -%}

      <!-- SNACKS -->
      {%- if cat_snacks.size > 0 -%}
      <div id="dgCat_snacks" style="display:none">
        <div class="dg-sh"><div class="dg-sh-title">🍟 <span>Snacks</span></div><div class="dg-sh-count">{{ cat_snacks.size }} items</div></div>
        <div class="dg-list">{%- for p in cat_snacks -%}{%- render 'dg-menu-item', product: p -%}{%- endfor -%}</div>
      </div>
      {%- endif -%}

      <!-- BEVERAGES -->
      {%- if cat_beverages.size > 0 -%}
      <div id="dgCat_beverages" style="display:none">
        <div class="dg-sh"><div class="dg-sh-title">🥤 <span>Beverages</span></div><div class="dg-sh-count">{{ cat_beverages.size }} items</div></div>
        <div class="dg-list">{%- for p in cat_beverages -%}{%- render 'dg-menu-item', product: p -%}{%- endfor -%}</div>
      </div>
      {%- endif -%}

      <!-- ICE CREAM -->
      {%- if cat_icecream.size > 0 -%}
      <div id="dgCat_icecream" style="display:none">
        <div class="dg-sh"><div class="dg-sh-title">🍦 <span>Ice Cream</span></div><div class="dg-sh-count">{{ cat_icecream.size }} items</div></div>
        <div class="dg-list">{%- for p in cat_icecream -%}{%- render 'dg-menu-item', product: p -%}{%- endfor -%}</div>
      </div>
      {%- endif -%}

    {%- endif -%}
  </main>

  <!-- ═══ PEOPLE ALSO ORDERED ═══ -->
  {%- if collection.products_count > 4 -%}
  <section class="dg-upsell dg-r">
    <div class="dg-sh"><div class="dg-sh-title">People Also <span>Ordered</span></div></div>
    <div class="dg-u-rail">
      {%- assign uc = 0 -%}
      {%- for p in collection.products limit: 10 -%}
        {%- if uc < 8 and p.available -%}
          {%- assign uc = uc | plus: 1 -%}
          <div class="dg-u-card">
            <div class="dg-u-img">
              {%- if p.featured_image -%}
                <img src="{{ p.featured_image | image_url: width: 260 }}" alt="{{ p.title | escape }}" loading="lazy">
              {%- else -%}
                {%- assign ptl2 = p.title | downcase -%}
                {%- if ptl2 contains 'momo' -%}🥟
                {%- elsif ptl2 contains 'grill' or ptl2 contains 'sekuwa' -%}🥩
                {%- elsif ptl2 contains 'burger' -%}🍔
                {%- elsif ptl2 contains 'noodle' or ptl2 contains 'thukpa' -%}🍜
                {%- elsif ptl2 contains 'lassi' -%}🥛
                {%- elsif ptl2 contains 'juice' or ptl2 contains 'drink' -%}🥤
                {%- else -%}🍽️{%- endif -%}
              {%- endif -%}
            </div>
            <div class="dg-u-body">
              <div class="dg-u-name">{{ p.title | truncate: 22 }}</div>
              <div class="dg-u-price">Rs {{ p.price | money_without_currency }}</div>
              <button class="dg-u-add"
                data-variant="{{ p.variants.first.id }}"
                data-name="{{ p.title | escape }}"
                onclick="dgAdd(this)">+ Add</button>
