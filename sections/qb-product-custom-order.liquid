<script>
(function () {
  'use strict';

  var leadDays = {{ lead_days | default: 3 }};

  /* ─── Set minimum delivery date ─── */
  (function setMinDate() {
    var dateInput = document.getElementById('cus-delivery-date');
    if (!dateInput) return;
    var minDate = new Date();
    minDate.setDate(minDate.getDate() + leadDays);
    var yyyy = minDate.getFullYear();
    var mm   = String(minDate.getMonth() + 1).padStart(2, '0');
    var dd   = String(minDate.getDate()).padStart(2, '0');
    dateInput.min = yyyy + '-' + mm + '-' + dd;
  })();

  /* ─── Variant selection ─── */
  window.cusSelectVariant = function (btn) {
    document.querySelectorAll('.cus-variant-pill').forEach(function (p) {
      p.classList.remove('active');
    });
    btn.classList.add('active');
    document.getElementById('cus-variant-id').value = btn.dataset.variantId;
    var priceEl = document.getElementById('cus-price-display');
    if (priceEl) priceEl.textContent = btn.dataset.price;
  };

  /* ─── Single variant fallback ─── */
  var singleVariant = document.getElementById('cus-single-variant');
  if (singleVariant) {
    document.getElementById('cus-variant-id').value = singleVariant.value;
  }

  /* ─── Form submit ─── */
  var form    = document.getElementById('cus-order-form');
  var submitBtn = document.getElementById('cus-submit-btn');
  var errorEl = document.getElementById('cus-error');
  var successEl = document.getElementById('cus-success');

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.classList.add('visible');
  }

  function hideError() {
    errorEl.classList.remove('visible');
  }

  function setLoading(loading) {
    submitBtn.disabled = loading;
    submitBtn.classList.toggle('loading', loading);
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    hideError();

    var variantId   = document.getElementById('cus-variant-id').value;
    var occasion    = document.getElementById('cus-occasion').value;
    var designNotes = document.getElementById('cus-design-notes').value.trim();
    var nameOnItem  = document.getElementById('cus-name-on-item').value.trim();
    var delivDate   = document.getElementById('cus-delivery-date').value;
    var timeSlot    = document.getElementById('cus-time-slot').value;
    var allergies   = document.getElementById('cus-allergies').value.trim();

    if (!occasion)    { showError('Please select an occasion.'); return; }
    if (!designNotes) { showError('Please describe your design requirements.'); return; }
    if (!delivDate)   { showError('Please select a preferred delivery date.'); return; }
    if (!timeSlot)    { showError('Please select a preferred time slot.'); return; }

    setLoading(true);

    var payload = {
      id: parseInt(variantId, 10),
      quantity: 1,
      properties: {
        'Occasion':         occasion,
        'Design Notes':     designNotes,
        'Name on Item':     nameOnItem || 'N/A',
        'Delivery Date':    delivDate,
        'Time Slot':        timeSlot,
        'Allergies/Dietary': allergies || 'None'
      }
    };

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(function (res) {
      if (!res.ok) return res.json().then(function (d) { throw new Error(d.description || 'Could not add to cart.'); });
      return res.json();
    })
    .then(function () {
      form.style.display = 'none';
      successEl.classList.add('visible');
      window.scrollTo({ top: successEl.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
    })
    .catch(function (err) {
      showError(err.message || 'Something went wrong. Please try again.');
    })
    .finally(function () {
      setLoading(false);
    });
  });

})();
</script>

