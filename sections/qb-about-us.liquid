<!-- QuickBee About Us Page -->
<!-- Brand Story + Mission + Values + Impact + Team -->

<div class="qb-about-wrapper">

  <!-- Hero: Brand Story -->
  <div class="qb-about-hero">
    <div class="qb-about-hero-pattern"></div>
    <div class="qb-about-hero-inner">
      <div class="qb-about-badge">🐝 Our Story</div>
      <h1 class="qb-about-hero-title">We're QuickBee</h1>
      <p class="qb-about-hero-sub">
        Delivering everyday essentials to your doorstep in 18–22 minutes,
        <span class="qb-about-highlight">24/7 across Kathmandu, Lalitpur & Bhaktapur</span>
      </p>
      <p class="qb-about-hero-desc">
        Founded in 2024, QuickBee is reimagining quick commerce in South Asia.
        We believe fast, affordable, and reliable delivery shouldn't be a luxury—it should be the standard.
      </p>
    </div>
    <div class="qb-about-hero-wave"></div>
  </div>

  <!-- Mission & Vision -->
  <div class="qb-about-section qb-about-section-alt">
    <div class="qb-about-mission-grid">
      <div class="qb-about-card">
        <div class="qb-about-card-icon">🎯</div>
        <h3 class="qb-about-card-title">Our Mission</h3>
        <p class="qb-about-card-text">
          To make quality everyday products instantly accessible to everyone,
          reducing delivery time from hours to minutes while creating dignified livelihood opportunities.
        </p>
      </div>
      <div class="qb-about-card">
        <div class="qb-about-card-icon">⭐</div>
        <h3 class="qb-about-card-title">Our Vision</h3>
        <p class="qb-about-card-text">
          A world where no one waits for essentials. QuickBee in every neighborhood,
          every day, for every need—powered by local expertise and cutting-edge technology.
        </p>
      </div>
    </div>
  </div>

  <!-- Core Values -->
  <div class="qb-about-section">
    <h2 class="qb-about-section-title">Our Core Values</h2>
    <p class="qb-about-section-sub">What we stand for, every single day</p>
    <div class="qb-about-values-grid">
      <div class="qb-about-value">
        <div class="qb-about-value-icon">⚡</div>
        <h4 class="qb-about-value-title">Speed</h4>
        <p class="qb-about-value-desc">18–22 minutes. Not "by tomorrow," not "in 2 hours." Today. Now.</p>
      </div>
      <div class="qb-about-value">
        <div class="qb-about-value-icon">💰</div>
        <h4 class="qb-about-value-title">Affordability</h4>
        <p class="qb-about-value-desc">Best prices on 20,000+ products. Quality shouldn't break the bank.</p>
      </div>
      <div class="qb-about-value">
        <div class="qb-about-value-icon">🤝</div>
        <h4 class="qb-about-value-title">Trust</h4>
        <p class="qb-about-value-desc">Verified sellers, safe payments, no hidden charges. Ever.</p>
      </div>
      <div class="qb-about-value">
        <div class="qb-about-value-icon">🌱</div>
        <h4 class="qb-about-value-title">Sustainability</h4>
        <p class="qb-about-value-desc">Eco-friendly packaging and responsible sourcing. We care for tomorrow.</p>
      </div>
    </div>
  </div>

  <!-- Impact Stats -->
  <div class="qb-about-impact">
    <div class="qb-about-impact-content">
      <h2 class="qb-about-impact-title">Our Impact So Far</h2>
      <div class="qb-about-stats-grid">
        <div class="qb-about-stat">
          <div class="qb-about-stat-number">{{ section.settings.customers | default: '50,000+' }}</div>
          <div class="qb-about-stat-label">Happy Customers</div>
        </div>
        <div class="qb-about-stat">
          <div class="qb-about-stat-number">{{ section.settings.deliveries | default: '500,000+' }}</div>
          <div class="qb-about-stat-label">Orders Delivered</div>
        </div>
        <div class="qb-about-stat">
          <div class="qb-about-stat-number">{{ section.settings.products | default: '20,000+' }}</div>
          <div class="qb-about-stat-label">Products Available</div>
        </div>
        <div class="qb-about-stat">
          <div class="qb-about-stat-number">{{ section.settings.response_time | default: '18-22' }} min</div>
          <div class="qb-about-stat-label">Average Delivery</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Why QuickBee? -->
  <div class="qb-about-section qb-about-section-alt">
    <h2 class="qb-about-section-title">Why Choose QuickBee?</h2>
    <div class="qb-about-why-grid">
      <div class="qb-about-why-item">
        <div class="qb-about-why-num">1</div>
        <h4 class="qb-about-why-title">Lightning-Fast Delivery</h4>
        <p class="qb-about-why-text">18–22 minute guaranteed delivery. Order at noon, have groceries by 12:20 PM. That's the QuickBee promise.</p>
      </div>
      <div class="qb-about-why-item">
        <div class="qb-about-why-num">2</div>
        <h4 class="qb-about-why-title">Unbeatable Prices</h4>
        <p class="qb-about-why-text">We've negotiated directly with top suppliers. You get wholesale prices on everyday essentials.</p>
      </div>
      <div class="qb-about-why-item">
        <div class="qb-about-why-num">3</div>
        <h4 class="qb-about-why-title">Verified Quality</h4>
        <p class="qb-about-why-text">Every product, every batch. We personally inspect inventory to ensure freshness and authenticity.</p>
      </div>
      <div class="qb-about-why-item">
        <div class="qb-about-why-num">4</div>
        <h4 class="qb-about-why-title">24/7 Availability</h4>
        <p class="qb-about-why-text">No closing times. Forgot milk at 2 AM? QuickBee is there. Need party supplies at midnight? We deliver.</p>
      </div>
      <div class="qb-about-why-item">
        <div class="qb-about-why-num">5</div>
        <h4 class="qb-about-why-title">Local Expertise</h4>
        <p class="qb-about-why-text">We know every neighborhood in Kathmandu, Lalitpur, and Bhaktapur. Fast delivery at scale.</p>
      </div>
      <div class="qb-about-why-item">
        <div class="qb-about-why-num">6</div>
        <h4 class="qb-about-why-title">Customer First</h4>
        <p class="qb-about-why-text">Problems? We fix them. Easy returns, instant refunds, and a support team that actually responds.</p>
      </div>
    </div>
  </div>

  <!-- Team Section -->
  <div class="qb-about-section">
    <h2 class="qb-about-section-title">Meet the Team Behind the Buzz</h2>
    <p class="qb-about-section-sub">Built by passionate problem-solvers obsessed with speed and quality</p>
    <div class="qb-about-team-grid">
      <div class="qb-about-team-member">
        <div class="qb-about-team-avatar">👨‍💼</div>
        <h4 class="qb-about-team-name">Founder & CEO</h4>
        <p class="qb-about-team-role">Visionary who's obsessed with solving the "last 30 minutes" problem</p>
      </div>
      <div class="qb-about-team-member">
        <div class="qb-about-team-avatar">👩‍💻</div>
        <h4 class="qb-about-team-name">Chief Technology Officer</h4>
        <p class="qb-about-team-role">Building the algorithms and infrastructure that power our 18-minute guarantee</p>
      </div>
      <div class="qb-about-team-member">
        <div class="qb-about-team-avatar">👨‍🔧</div>
        <h4 class="qb-about-team-name">Operations Head</h4>
        <p class="qb-about-team-role">Ensuring every order leaves the warehouse faster than before</p>
      </div>
      <div class="qb-about-team-member">
        <div class="qb-about-team-avatar">👩‍🤝‍👨</div>
        <h4 class="qb-about-team-name">Customer Success Lead</h4>
        <p class="qb-about-team-role">Making sure every customer interaction is delightful</p>
      </div>
    </div>
    <p class="qb-about-team-closing">
      <strong>Plus 100+ delivery partners, quality checkers, and neighborhood specialists</strong>
      who make the magic happen every single day.
    </p>
  </div>

  <!-- Sustainability Commitment -->
  <div class="qb-about-section qb-about-section-alt qb-about-green">
    <h2 class="qb-about-section-title">Our Commitment to the Planet 🌍</h2>
    <div class="qb-about-sustainability">
      <div class="qb-about-sustain-item">
        <span class="qb-about-sustain-icon">♻️</span>
        <h4>100% Recyclable Packaging</h4>
        <p>No plastic bags. Reusable boxes, paper inserts, and biodegradable packaging only.</p>
      </div>
      <div class="qb-about-sustain-item">
        <span class="qb-about-sustain-icon">🚲</span>
        <h4>Green Delivery Fleet</h4>
        <p>Electric bicycles for short-range deliveries. EV vans for longer routes. Zero fossil fuel by 2026.</p>
      </div>
      <div class="qb-about-sustain-item">
        <span class="qb-about-sustain-icon">🌱</span>
        <h4>Local Sourcing</h4>
        <p>Partner with local farmers and suppliers. Reduce transport emissions, support local economy.</p>
      </div>
      <div class="qb-about-sustain-item">
        <span class="qb-about-sustain-icon">📊</span>
        <h4>Carbon Neutral</h4>
        <p>Every delivery tracks its carbon footprint. We offset 150% of our emissions through verified projects.</p>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="qb-about-cta">
    <h2 class="qb-about-cta-title">Ready to Experience the Buzz? 🐝</h2>
    <p class="qb-about-cta-desc">Join thousands of customers enjoying fast, affordable, reliable delivery.</p>
    <div class="qb-about-cta-btns">
      <a href="/collections/all" class="qb-about-cta-btn qb-about-cta-primary">Shop Now</a>
      <a href="https://wa.me/9779800000000?text=Hi+QuickBee!+Tell+me+more" class="qb-about-cta-btn qb-about-cta-secondary" target="_blank" rel="noopener">
