{% comment %}
  sections/qb-biryani-challenge.liquid
  7 Days Chicken Biryani Challenge — Price-first promo hero
  Dark premium, Rs 1111 as the biggest element, countdown urgency
{% endcomment %}

<div class="qbc-root" id="qbc-root">

  <!-- BG glow blobs -->
  <div class="qbc-blob qbc-blob--gold"></div>
  <div class="qbc-blob qbc-blob--red"></div>

  <!-- BADGE -->
  <div class="qbc-badge-row">
    <span class="qbc-badge qbc-badge--fire">🔥 LIMITED OFFER</span>
    <span class="qbc-badge qbc-badge--loc">📍 Kathmandu Only</span>
  </div>

  <!-- HEADLINE -->
  <h1 class="qbc-headline">🍗 7 Days Chicken<br>Biryani Challenge</h1>

  <!-- PRICE — THE STAR -->
  <div class="qbc-price-block">
    <div class="qbc-price-only">ONLY</div>
    <div class="qbc-price-main">Rs <span>1111</span></div>
    <div class="qbc-price-compare">
      <span class="qbc-compare-line">Worth Rs 2000+</span>
      <span class="qbc-arrow">→</span>
      <span class="qbc-now">Now Rs 1111</span>
    </div>
  </div>

  <!-- SUBTEXT -->
  <p class="qbc-sub">Eat Chicken Biryani <strong>EVERY DAY</strong> for 7 Days 😋<br>Fresh, hot &amp; delivered to your door.</p>

  <!-- FEATURES -->
  <div class="qbc-features">
    <div class="qbc-feat"><span>🍗</span><span>Daily Chicken Biryani</span></div>
    <div class="qbc-feat"><span>⚡</span><span>Fast Delivery</span></div>
    <div class="qbc-feat"><span>📍</span><span>Kathmandu Only</span></div>
    <div class="qbc-feat"><span>💰</span><span>Best Deal Ever</span></div>
  </div>

  <!-- COUNTDOWN -->
  <div class="qbc-urgency">
    <div class="qbc-urgency-top">
      <span class="qbc-urgency-dot"></span>
      <span class="qbc-urgency-label">Offer ending soon &nbsp;·&nbsp; Limited slots</span>
    </div>
    <div class="qbc-countdown" id="qbc-countdown">
      <div class="qbc-unit"><span id="qbc-h">00</span><small>Hours</small></div>
      <div class="qbc-sep">:</div>
      <div class="qbc-unit"><span id="qbc-m">00</span><small>Mins</small></div>
      <div class="qbc-sep">:</div>
      <div class="qbc-unit"><span id="qbc-s">00</span><small>Secs</small></div>
    </div>
  </div>

  <!-- CTA -->
  <a href="{{ section.settings.cta_url | default: '/products/7-days-chicken-biryani-challenge' }}" class="qbc-cta">
    Start Challenge 🚀
  </a>
  <p class="qbc-cta-note">No commitment · Cancel anytime · Pay on delivery</p>

</div>

<style>
/* ── Root ── */
.qbc-root {
  position: relative;
  background: #0f0f0f;
  overflow: hidden;
  padding: 52px 20px 48px;
  text-align: center;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* ── Glow blobs ── */
.qbc-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(80px);
  opacity: 0.18;
}
.qbc-blob--gold {
  width: 360px; height: 360px;
  background: #F4B400;
  top: -80px; left: 50%;
  transform: translateX(-50%);
}
.qbc-blob--red {
  width: 240px; height: 240px;
  background: #e03030;
  bottom: -60px; right: -40px;
}

/* ── Badges ── */
.qbc-badge-row {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-bottom: 18px;
  flex-wrap: wrap;
}
.qbc-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.6px;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 20px;
}
.qbc-badge--fire {
  background: rgba(224,48,48,0.18);
  border: 1px solid rgba(224,48,48,0.4);
  color: #ff6b6b;
}
.qbc-badge--loc {
  background: rgba(244,180,0,0.12);
  border: 1px solid rgba(244,180,0,0.3);
  color: #F4B400;
}

/* ── Headline ── */
.qbc-headline {
  font-size: clamp(26px, 7vw, 40px);
  font-weight: 900;
  color: #ffffff;
  line-height: 1.2;
  margin: 0 0 28px;
  letter-spacing: -0.5px;
}

/* ── Price block ── */
.qbc-price-block {
  margin: 0 auto 24px;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: rgba(244,180,0,0.07);
  border: 2px solid rgba(244,180,0,0.25);
  border-radius: 24px;
  padding: 20px 40px 18px;
}
.qbc-price-only {
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 2px;
  color: rgba(244,180,0,0.7);
  text-transform: uppercase;
  margin-bottom: 4px;
}
.qbc-price-main {
  font-size: clamp(56px, 16vw, 96px);
  font-weight: 900;
  color: #F4B400;
  line-height: 1;
  letter-spacing: -3px;
  text-shadow: 0 0 60px rgba(244,180,0,0.5);
}
.qbc-price-main span {
  font-size: inherit;
  font-weight: inherit;
  color: inherit;
}
.qbc-price-compare {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
  font-size: 13px;
  flex-wrap: wrap;
  justify-content: center;
}
.qbc-compare-line {
  text-decoration: line-through;
  color: rgba(255,255,255,0.35);
}
.qbc-arrow { color: rgba(255,255,255,0.3); }
.qbc-now {
  color: #22c55e;
  font-weight: 800;
}

/* ── Subtext ── */
.qbc-sub {
  font-size: 16px;
  color: rgba(255,255,255,0.6);
  line-height: 1.6;
  margin: 0 auto 24px;
  max-width: 340px;
}
.qbc-sub strong { color: rgba(255,255,255,0.9); }

/* ── Features ── */
.qbc-features {
  display: flex;
  justify-content: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 28px;
}
.qbc-feat {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  padding: 7px 14px;
  font-size: 13px;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
}
.qbc-feat span:first-child { font-size: 15px; }

/* ── Urgency / Countdown ── */
.qbc-urgency {
  margin: 0 auto 28px;
  max-width: 340px;
}
.qbc-urgency-top {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 12px;
}
.qbc-urgency-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #ef4444;
  animation: qbcPulse 1.2s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes qbcPulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.5); }
  50% { box-shadow: 0 0 0 6px rgba(239,68,68,0); }
}
.qbc-urgency-label {
  font-size: 12px;
  font-weight: 700;
  color: #ef4444;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.qbc-countdown {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 4px;
}
.qbc-unit {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(239,68,68,0.12);
  border: 1px solid rgba(239,68,68,0.25);
  border-radius: 12px;
  padding: 10px 18px 8px;
  min-width: 70px;
}
.qbc-unit span {
  font-size: 32px;
  font-weight: 900;
  color: #ff6b6b;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: -1px;
}
.qbc-unit small {
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: rgba(255,255,255,0.35);
  font-weight: 600;
  margin-top: 4px;
}
.qbc-sep {
  font-size: 24px;
  font-weight: 900;
  color: rgba(239,68,68,0.4);
  padding-bottom: 16px;
  line-height: 1;
}

/* ── CTA ── */
.qbc-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: linear-gradient(135deg, #F4B400 0%, #e6a800 100%);
  color: #000;
  font-size: 17px;
  font-weight: 900;
  padding: 16px 48px;
  border-radius: 18px;
  text-decoration: none;
  letter-spacing: 0.2px;
  box-shadow: 0 8px 32px rgba(244,180,0,0.4);
  transition: transform 0.18s, box-shadow 0.18s;
  -webkit-tap-highlight-color: transparent;
}
.qbc-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(244,180,0,0.5); }
.qbc-cta:active { transform: scale(0.97); }
.qbc-cta-note {
  font-size: 12px;
  color: rgba(255,255,255,0.3);
  margin-top: 12px;
  margin-bottom: 0;
}

/* ── Mobile ── */
@media (max-width: 400px) {
  .qbc-price-block { padding: 16px 24px 14px; }
  .qbc-unit { min-width: 58px; padding: 8px 12px 6px; }
  .qbc-unit span { font-size: 26px; }
  .qbc-cta { padding: 15px 36px; font-size: 16px; }
}
</style>

<script>
(function(){
  // Countdown resets every 24h — creates rolling urgency
  var stored = localStorage.getItem('qbc_end');
  var end;
  if (stored) {
    end = parseInt(stored, 10);
  } else {
    end = Date.now() + 23 * 3600000 + 47 * 60000 + Math.floor(Math.random() * 59) * 1000;
    localStorage.setItem('qbc_end', end);
  }

  function tick() {
    var diff = end - Date.now();
    if (diff <= 0) {
      // Reset for next cycle
      end = Date.now() + 23 * 3600000 + 47 * 60000;
      localStorage.setItem('qbc_end', end);
      diff = end - Date.now();
    }
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    var hEl = document.getElementById('qbc-h');
    var mEl = document.getElementById('qbc-m');
    var sEl = document.getElementById('qbc-s');
    if (hEl) hEl.textContent = String(h).padStart(2,'0');
    if (mEl) mEl.textContent = String(m).padStart(2,'0');
    if (sEl) sEl.textContent = String(s).padStart(2,'0');
  }
  tick();
  setInterval(tick, 1000);
})();
</script>

{% schema %}
{
  "name": "Biryani Challenge Hero",
  "tag": "section",
  "class": "qbc-section",
  "settings": [
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL",
      "info": "Link to the Biryani Challenge product page"
    }
  ],
  "presets": [
    {
      "name": "Biryani Challenge Hero"
    }
  ]
}
{% endschema %}
