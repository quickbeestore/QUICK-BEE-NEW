<script>
// Countdown timer functionality
(function initCountdownTimer() {
  function updateCountdown() {
    // Set the target time to 6 hours from now
    const now = new Date();
    const targetTime = new Date(now.getTime() + 6 * 60 * 60 * 1000);

    function tick() {
      const currentTime = new Date();
      const timeRemaining = targetTime - currentTime;

      if (timeRemaining <= 0) {
        // Timer ended
        document.getElementById('countdown-hours').textContent = '00';
        document.getElementById('countdown-mins').textContent = '00';
        document.getElementById('countdown-secs').textContent = '00';
        return;
      }

      // Calculate hours, minutes, seconds
      const hours = Math.floor((timeRemaining / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((timeRemaining / (1000 * 60)) % 60);
      const seconds = Math.floor((timeRemaining / 1000) % 60);

      // Format with leading zeros
      document.getElementById('countdown-hours').textContent = String(hours).padStart(2, '0');
      document.getElementById('countdown-mins').textContent = String(minutes).padStart(2, '0');
      document.getElementById('countdown-secs').textContent = String(seconds).padStart(2, '0');
    }

    // Initial tick
    tick();

    // Update every second
    setInterval(tick, 1000);
  }

  // Initialize on page load or if already loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateCountdown);
  } else {
    updateCountdown();
  }
})();

// CTA button click handler
document.addEventListener('DOMContentLoaded', function() {
  const ctaButton = document.querySelector('.qb-urgency-cta');
  if (ctaButton) {
    ctaButton.addEventListener('click', function() {
      // Navigate to flash deals section or collection
      window.location.href = '/collections/all?sort_by=best-selling';
    });
  }
});
</script>
