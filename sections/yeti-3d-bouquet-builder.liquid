<!-- YETI KAFE - Interactive 3D Bouquet Builder -->
<div class="yeti-3d-builder">
  <!-- Header Section -->
  <div class="builder-header">
    <div class="header-content">
      <h1 class="builder-title">🌹 Create Your Perfect Bouquet 🌹</h1>
      <p class="builder-subtitle">Flowers • Love • Fresh Moments</p>
      <p class="builder-description">Click flowers below to add them to your bouquet</p>
    </div>
  </div>

  <!-- Main Builder Container -->
  <div class="builder-main">
    <!-- 3D Canvas (Center) -->
    <div class="canvas-section">
      <div id="3d-canvas" class="three-canvas"></div>
      <div class="canvas-controls">
        <button id="reset-btn" class="control-btn">🔄 Reset</button>
        <button id="rotate-btn" class="control-btn">🔁 Auto Rotate</button>
      </div>
      <p class="canvas-hint">🖱️ Drag to rotate • Scroll to zoom</p>
    </div>

    <!-- Flowers Grid (Right Side) -->
    <div class="flowers-section">
      <h2 class="section-title">🌸 Select Flowers</h2>
      <div class="flowers-grid" id="flowers-grid">
        <!-- Flowers will be added here -->
      </div>
    </div>
  </div>

  <!-- Summary & Checkout -->
  <div class="summary-section">
    <div class="summary-card">
      <h3>📋 Your Bouquet Summary</h3>
      <div id="bouquet-items" class="bouquet-items">
        <p class="empty-message">👈 Click flowers to add them</p>
      </div>

      <div class="price-breakdown">
        <div class="price-row">
          <span>Flowers:</span>
          <span id="flowers-price">Rs 0</span>
        </div>
        <div class="price-row">
          <span>Packaging:</span>
          <span id="packaging-price">Rs 250</span>
        </div>
        <div class="price-row total">
          <span>Total:</span>
          <span id="total-price">Rs 250</span>
        </div>
      </div>

      <div class="packaging-options">
        <label class="radio-option">
          <input type="radio" name="packaging" value="standard" checked>
          <span>Standard Packaging (+Rs 250)</span>
        </label>
        <label class="radio-option">
          <input type="radio" name="packaging" value="premium">
          <span>Premium Packaging (+Rs 350)</span>
        </label>
      </div>

      <div class="action-buttons">
        <button id="save-design-btn" class="btn btn-primary">💾 Save Design</button>
        <button id="add-to-cart-btn" class="btn btn-success">🛒 Add to Cart</button>
      </div>

      <div class="info-box">
        <p>✓ Fresh, handpicked flowers</p>
        <p>✓ Expert arrangement</p>
        <p>⏱️ Delivery in 30-90 mins</p>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
  // Flower Data
  const FLOWERS_DATA = [
    { type: 'rose', name: 'Red Rose', price: 99, emoji: '🌹', color: 0xFF1744, size: 0.3 },
    { type: 'colored-rose', name: 'Colored Rose', price: 120, emoji: '🌷', color: 0xFF6090, size: 0.3 },
    { type: 'carnation', name: 'Carnation', price: 80, emoji: '🌸', color: 0xFF80AB, size: 0.25 },
    { type: 'gerbera', name: 'Gerbera', price: 60, emoji: '🌼', color: 0xFFD700, size: 0.28 },
    { type: 'sunflower', name: 'Sunflower', price: 450, emoji: '🌻', color: 0xFFC300, size: 0.4 },
    { type: 'lily', name: 'Lily', price: 650, emoji: '🌺', color: 0xFF69B4, size: 0.35 },
  ];

  const PACKAGING_PRICES = {
    standard: 250,
    premium: 350,
  };

  // State
  let state = {
    bouquet: {},
    packaging: 'standard',
    autoRotate: false,
  };

  // Three.js Setup
  let scene, camera, renderer, flowersGroup, vase;
  let isDragging = false;
  let previousMousePosition = { x: 0, y: 0 };

  function initThreeJS() {
    const canvas = document.getElementById('3d-canvas');

    // Scene
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0xfce4ec);

    // Camera
    camera = new THREE.PerspectiveCamera(
      75,
      canvas.clientWidth / canvas.clientHeight,
      0.1,
      1000
    );
    camera.position.z = 4;

    // Renderer
    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(canvas.clientWidth, canvas.clientHeight);
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFShadowShadowMap;
    canvas.appendChild(renderer.domElement);

    // Lighting
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.8);
    scene.add(ambientLight);

    const directionalLight = new THREE.DirectionalLight(0xffffff, 1);
    directionalLight.position.set(8, 12, 8);
    directionalLight.castShadow = true;
    directionalLight.shadow.mapSize.width = 2048;
    directionalLight.shadow.mapSize.height = 2048;
    scene.add(directionalLight);

    // Flowers group
    flowersGroup = new THREE.Group();
    scene.add(flowersGroup);

    // Create vase
    createVase();

    // Mouse controls
    renderer.domElement.addEventListener('mousedown', onMouseDown);
    renderer.domElement.addEventListener('mousemove', onMouseMove);
    renderer.domElement.addEventListener('mouseup', onMouseUp);
    renderer.domElement.addEventListener('wheel', onMouseWheel);

    // Handle resize
    window.addEventListener('resize', () => {
      const width = canvas.clientWidth;
      const height = canvas.clientHeight;
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height);
    });

    // Animation loop
    animate();
  }

  function createVase() {
    const vaseGeometry = new THREE.ConeGeometry(0.7, 1.8, 32);
    const vaseMaterial = new THREE.MeshStandardMaterial({
      color: 0xe8d5e8,
      metalness: 0.2,
      roughness: 0.5,
    });
    vase = new THREE.Mesh(vaseGeometry, vaseMaterial);
    vase.position.y = -1.5;
    vase.castShadow = true;
    vase.receiveShadow = true;

    // Vase base
    const baseGeometry = new THREE.CylinderGeometry(0.75, 0.5, 0.3, 32);
    const baseMaterial = new THREE.MeshStandardMaterial({
      color: 0xd0a8d0,
      metalness: 0.3,
      roughness: 0.4,
    });
    const base = new THREE.Mesh(baseGeometry, baseMaterial);
    base.position.y = -2.1;
    base.castShadow = true;
    base.receiveShadow = true;

    scene.add(vase);
    scene.add(base);
  }

  function createFlower(type, color, size) {
    // Main sphere (flower head)
    const headGeometry = new THREE.IcosahedronGeometry(size, 4);
    const headMaterial = new THREE.MeshStandardMaterial({
      color: color,
      metalness: 0.1,
      roughness: 0.7,
      emissive: new THREE.Color(color).multiplyScalar(0.2),
    });
    const head = new THREE.Mesh(headGeometry, headMaterial);
    head.castShadow = true;
    head.receiveShadow = true;

    // Petals (small spheres around the head)
    const petalCount = 5;
    for (let i = 0; i < petalCount; i++) {
      const petalGeometry = new THREE.SphereGeometry(size * 0.6, 16, 16);
      const petalMaterial = new THREE.MeshStandardMaterial({
        color: color,
        metalness: 0.05,
        roughness: 0.8,
      });
      const petal = new THREE.Mesh(petalGeometry, petalMaterial);

      const angle = (i / petalCount) * Math.PI * 2;
      petal.position.x = Math.cos(angle) * size * 0.8;
      petal.position.z = Math.sin(angle) * size * 0.8;
      petal.position.y = Math.sin(i * 0.7) * size * 0.3;
      petal.castShadow = true;
      petal.receiveShadow = true;

      head.add(petal);
    }

    // Stem
    const stemGeometry = new THREE.CylinderGeometry(0.08, 0.06, 2, 8);
    const stemMaterial = new THREE.MeshStandardMaterial({
      color: 0x2d5016,
      metalness: 0,
      roughness: 0.8,
    });
    const stem = new THREE.Mesh(stemGeometry, stemMaterial);
    stem.position.y = -1;
    stem.castShadow = true;
    stem.receiveShadow = true;

    head.add(stem);

    return head;
  }

  function addFlowerToScene() {
    // Clear existing flowers
    while (flowersGroup.children.length > 0) {
      flowersGroup.removeChild(flowersGroup.children[0]);
    }

    let flowerIndex = 0;
    const totalFlowers = Object.values(state.bouquet).reduce((a, b) => a + b, 0);

    // Add flowers based on bouquet state
    FLOWERS_DATA.forEach((flowerData) => {
      const quantity = state.bouquet[flowerData.type] || 0;
      for (let i = 0; i < quantity; i++) {
        const flower = createFlower(flowerData.type, flowerData.color, flowerData.size);

        // Arrange in circular pattern
        const angle = totalFlowers > 0 ? (flowerIndex / totalFlowers) * Math.PI * 2 : 0;
        const radius = 1.2 + Math.random() * 0.6;
        const height = 0.5 + Math.random() * 1.2;

        flower.position.x = Math.cos(angle) * radius;
        flower.position.z = Math.sin(angle) * radius;
        flower.position.y = height;

        // Random rotation
        flower.rotation.x = Math.random() * 0.5;
        flower.rotation.z = Math.random() * 0.5;

        flowersGroup.add(flower);
        flowerIndex++;
      }
    });
  }

  function animate() {
    requestAnimationFrame(animate);

    if (state.autoRotate && flowersGroup) {
      flowersGroup.rotation.y += 0.003;
    }

    renderer.render(scene, camera);
  }

  // Mouse controls
  function onMouseDown(e) {
    isDragging = true;
    previousMousePosition = { x: e.clientX, y: e.clientY };
  }

  function onMouseMove(e) {
    if (!isDragging || !flowersGroup) return;

    const deltaX = e.clientX - previousMousePosition.x;
    const deltaY = e.clientY - previousMousePosition.y;

    flowersGroup.rotation.y += deltaX * 0.01;
    flowersGroup.rotation.x += deltaY * 0.01;

    previousMousePosition = { x: e.clientX, y: e.clientY };
  }

  function onMouseUp() {
    isDragging = false;
  }

  function onMouseWheel(e) {
    e.preventDefault();
    camera.position.z += e.deltaY * 0.005;
    camera.position.z = Math.max(2, Math.min(8, camera.position.z));
  }

  // UI Functions
  function initFlowersGrid() {
    const grid = document.getElementById('flowers-grid');

    FLOWERS_DATA.forEach((flower) => {
      const card = document.createElement('div');
      card.className = 'flower-card';
      card.innerHTML = `
        <div class="flower-emoji">${flower.emoji}</div>
        <div class="flower-name">${flower.name}</div>
        <div class="flower-price">Rs ${flower.price}</div>
        <div class="flower-counter">
          <button class="minus-btn" data-type="${flower.type}">−</button>
          <span class="count" data-type="${flower.type}">0</span>
          <button class="plus-btn" data-type="${flower.type}">+</button>
        </div>
      `;

      card.addEventListener('click', (e) => {
        if (e.target.classList.contains('plus-btn')) {
          addFlower(flower.type);
        }
      });

      card.querySelector('.minus-btn').addEventListener('click', (e) => {
        e.stopPropagation();
        removeFlower(flower.type);
      });

      grid.appendChild(card);
    });
  }

  function addFlower(type) {
    state.bouquet[type] = (state.bouquet[type] || 0) + 1;
    updateUI();
  }

  function removeFlower(type) {
    if (state.bouquet[type] > 0) {
      state.bouquet[type]--;
      updateUI();
    }
  }

  function updateUI() {
    // Update counters
    FLOWERS_DATA.forEach((flower) => {
      const count = state.bouquet[flower.type] || 0;
      const countSpan = document.querySelector(`span[data-type="${flower.type}"]`);
      if (countSpan) countSpan.textContent = count;
    });

    // Update bouquet summary
    updateBouquetSummary();
    updatePrices();
    addFlowerToScene();
  }

  function updateBouquetSummary() {
    const container = document.getElementById('bouquet-items');
    const items = [];

    FLOWERS_DATA.forEach((flower) => {
      const qty = state.bouquet[flower.type] || 0;
      if (qty > 0) {
        items.push(`<div class="item">${flower.emoji} ${flower.name} × ${qty}</div>`);
      }
    });

    if (items.length === 0) {
      container.innerHTML = '<p class="empty-message">👈 Click flowers to add them</p>';
    } else {
      container.innerHTML = items.join('');
    }
  }

  function updatePrices() {
    const flowersPrice = FLOWERS_DATA.reduce((total, flower) => {
      const qty = state.bouquet[flower.type] || 0;
      return total + (flower.price * qty);
    }, 0);

    const packagingPrice = PACKAGING_PRICES[state.packaging];
    const total = flowersPrice + packagingPrice;

    document.getElementById('flowers-price').textContent = `Rs ${flowersPrice}`;
    document.getElementById('packaging-price').textContent = `Rs ${packagingPrice}`;
    document.getElementById('total-price').textContent = `Rs ${total}`;
  }

  // Event Listeners
  document.getElementById('reset-btn').addEventListener('click', () => {
    state.bouquet = {};
    updateUI();
  });

  document.getElementById('rotate-btn').addEventListener('click', (e) => {
    state.autoRotate = !state.autoRotate;
    e.target.style.opacity = state.autoRotate ? '1' : '0.5';
  });

  // Packaging options
  document.querySelectorAll('input[name="packaging"]').forEach((radio) => {
    radio.addEventListener('change', (e) => {
      state.packaging = e.target.value;
      updatePrices();
    });
  });

  // Action buttons
  document.getElementById('save-design-btn').addEventListener('click', () => {
    const totalFlowers = Object.values(state.bouquet).reduce((a, b) => a + b, 0);
    if (totalFlowers === 0) {
      alert('Please add flowers to your bouquet first! 🌹');
      return;
    }
    alert('✅ Bouquet design saved! You can create another or add this one to cart.');
  });

  document.getElementById('add-to-cart-btn').addEventListener('click', () => {
    const totalFlowers = Object.values(state.bouquet).reduce((a, b) => a + b, 0);
    if (totalFlowers === 0) {
      alert('Please add flowers to your bouquet first! 🌹');
      return;
    }

    const flowersPrice = FLOWERS_DATA.reduce((total, flower) => {
      const qty = state.bouquet[flower.type] || 0;
      return total + (flower.price * qty);
    }, 0);

    const packagingPrice = PACKAGING_PRICES[state.packaging];
    const total = flowersPrice + packagingPrice;

    // Create product variant string
    const flowerItems = FLOWERS_DATA
      .filter(f => (state.bouquet[f.type] || 0) > 0)
      .map(f => `${f.name}×${state.bouquet[f.type]}`)
      .join(', ');

    const cartData = {
      items: [{
        id: 12345,
        quantity: 1,
        properties: {
          'Flowers': flowerItems,
          'Packaging': state.packaging,
          'Total Price': `Rs ${total}`
        }
      }]
    };

    console.log('Adding to cart:', cartData);
    alert(`✅ Bouquet added to cart!\n\nTotal: Rs ${total}\n\nFlowers: ${flowerItems}`);
  });

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    initThreeJS();
    initFlowersGrid();
    updateUI();
  });
</script>

