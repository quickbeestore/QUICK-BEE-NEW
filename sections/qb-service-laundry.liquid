<div class="kw-toast" id="kw-toast"></div>

<script>
(function() {
  const serviceData = {
    'wash-fold': { name: 'Wash & Fold', price: 100, unit: 'kg', minQty: 3, surcharge: 50 },
    'wash-iron': { name: 'Wash & Iron', price: 140, unit: 'kg', minQty: 3, surcharge: 50 },
    'dry-clean': { name: 'Dry Cleaning', price: 150, unit: 'piece', minQty: 1, surcharge: 0 },
    'iron-only': { name: 'Iron Only', price: 40, unit: 'piece', minQty: 5, surcharge: 50 },
    'bedsheets': { name: 'Bedsheets & Linen', price: 200, unit: 'set', minQty: 2, surcharge: 50 },
    'express': { name: 'Express (6h)', price: 180, unit: 'kg', minQty: 3, surcharge: 50 }
  };

  let selectedServices = {};
  let pickupType = 'paid'; // Default to paid for initial 1kg state
  const freePickupPill = document.querySelector('[data-pickup="free"]');
  const paidPickupPill = document.querySelector('[data-pickup="paid"]');
  let pickupNote = document.getElementById('kw-pickup-note'); // This will be created dynamically if not present
  let upsellNote; // Declaring upsellNote here

  function selectFreePickup() {
    pickupType = 'free';
    freePickupPill.classList.add('active');
    paidPickupPill.classList.remove('active');
  }

  function selectPaidPickup() {
    pickupType = 'paid';
    paidPickupPill.classList.add('active');
    freePickupPill.classList.remove('active');
  }

  function disableFreePickup() {
    freePickupPill.classList.add('disabled');
  }

  function enableFreePickup() {
    freePickupPill.classList.remove('disabled');
  }

  function disablePaidPickup() {
    paidPickupPill.classList.add('disabled');
  }

  function enablePaidPickup() {
    paidPickupPill.classList.remove('disabled');
  }

  function renderQuantitySelectors() {
    const container = document.getElementById('kw-quantity-section');
    container.innerHTML = '';
    let currentTotalKg = 0;

    Object.keys(selectedServices).forEach(key => {
      const service = serviceData[key];
      const qty = selectedServices[key];
      
      if (service.unit === 'kg') {
        currentTotalKg += qty;
      }

      const el = document.createElement('div');
      el.className = 'kw-form-group';
      el.innerHTML = `
        <label class="kw-label">${service.name}</label>
        <div class="kw-qty-row">
          <button class="kw-qty-btn" data-service="${key}" data-action="minus" type="button">−</button>
          <input class="kw-input kw-qty-input" type="number" value="${qty}" readonly>
          <button class="kw-qty-btn" data-service="${key}" data-action="plus" type="button">+</button>
        </div>
      `;
      container.appendChild(el);
    });

    // Create and append upsell note if it doesn't exist
    const quantityCard = document.querySelector('.kw-form-section .kw-form-card');
    upsellNote = document.getElementById('kw-upsell-note');
    if (!upsellNote) {
      upsellNote = document.createElement('div');
      upsellNote.id = 'kw-upsell-note';
      upsellNote.className = 'kw-upsell-note';
      if (quantityCard) {
        quantityCard.appendChild(upsellNote);
      }
    }
    upsellNote.style.display = 'none'; // Always hide initially, updateSummary will show if needed


    // Add event listeners to new buttons
    container.querySelectorAll('.kw-qty-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const service = btn.dataset.service;
        const action = btn.dataset.action;
        if (action === 'plus') {
          selectedServices[service]++;
        } else {
          selectedServices[service]--;
          if (selectedServices[service] <= 0) { // Changed to <= 0 to allow deletion
            delete selectedServices[service];
            const serviceCard = document.querySelector(`.kw-service-card[data-service="${service}"]`);
            if (serviceCard) serviceCard.classList.remove('selected');
          }
        }
        renderQuantitySelectors(); // Re-render to update quantities and potentially upsell note
        updateSummary();
      });
    });
    updateSummary(); // Call updateSummary here to ensure upsell is calculated after re-render
  }

  function animatePriceUpdate(element, newValue) {
    if (!element) return;
    element.classList.add('kw-price-animate');
    setTimeout(() => {
      element.textContent = newValue;
      element.classList.remove('kw-price-animate');
    }, 250); // Match CSS transition duration
  }

  function showToast(message) {
    const toast = document.getElementById('kw-toast');
    if (toast) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => { toast.classList.remove('show'); }, 3500);
    }
  }

  // --- Location Logic ---
  let userLocation = null;
  let usingManualAddress = false;

  function updateLocationDisplay(locationName) {
    const labelEl = document.getElementById('kw-saved-loc-label');
    const manualAddressForm = document.getElementById('kw-change-form');
    const noLocBanner = document.getElementById('kw-no-loc-banner');
    const savedLocCard = document.getElementById('kw-saved-loc-card');

    if (locationName) {
      if (labelEl) labelEl.textContent = locationName;
      if (savedLocCard) savedLocCard.style.display = 'flex';
      if (noLocBanner) noLocBanner.style.display = 'none';
      if (manualAddressForm) manualAddressForm.style.display = 'none';
      usingManualAddress = false;
      showToast(`Location set to: ${locationName}`);
    } else {
      if (labelEl) labelEl.textContent = 'Enter Address';
      if (savedLocCard) savedLocCard.style.display = 'none';
      if (noLocBanner) noLocBanner.style.display = 'flex';
      if (manualAddressForm) manualAddressForm.style.display = 'block';
      usingManualAddress = true;
      showToast('Location detection failed. Please enter manually.');
    }
  }

  function reverseGeocode(latitude, longitude, callback) {
    const mockAddress = `Approx. Location (Lat: ${latitude.toFixed(4)}, Lng: ${longitude.toFixed(4)})`;
    callback(mockAddress);
  }

  function detectAndSetLocation() {
    const labelEl = document.getElementById('kw-saved-loc-label');
    const savedLocCard = document.getElementById('kw-saved-loc-card');
    const noLocBanner = document.getElementById('kw-no-loc-banner');
    const manualAddressForm = document.getElementById('kw-change-form');

    if (savedLocCard) savedLocCard.style.display = 'flex';
    if (noLocBanner) noLocBanner.style.display = 'none';
    if (manualAddressForm) manualAddressForm.style.display = 'none';
    if (labelEl) labelEl.textContent = 'Detecting location...';
    userLocation = null;

    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (position) => {
          const latitude = position.coords.latitude;
          const longitude = position.coords.longitude;
          reverseGeocode(latitude, longitude, (address) => {
            userLocation = address;
            localStorage.setItem("user_location", userLocation);
            updateLocationDisplay(userLocation);
          });
        },
        (error) => {
          console.error('Geolocation error:', error);
          userLocation = null;
          showToast('Location detection denied or failed. Please enter manually.');
          updateLocationDisplay(null);
        },
        { enableHighAccuracy: false, timeout: 5000, maximumAge: 0 }
      );
    } else {
      showToast('Geolocation not supported by your browser. Please enter manually.');
      updateLocationDisplay(null);
    }
  }

  function initAddressSection() {
    let storedLocation = localStorage.getItem("user_location");
    if (storedLocation) {
      userLocation = storedLocation;
      updateLocationDisplay(userLocation);
    } else {
      detectAndSetLocation();
    }
  }
  // --- End Location Logic ---


  function updateSummary() {
    const billItemsContainer = document.getElementById('kw-bill-items');
    const subtotalEl = document.getElementById('kw-bill-subtotal-val');
    const pickupEl = document.getElementById('kw-bill-pickup-val');
    const totalEl = document.getElementById('kw-bill-total-val');
    const footerPriceEl = document.getElementById('kw-footer-price');
    const stickyFooter = document.getElementById('kw-sticky-footer');

    let subtotal = 0;
    let totalKg = 0; // Track total kg for pickup logic
    billItemsContainer.innerHTML = '';

    Object.keys(selectedServices).forEach(key => {
      const service = serviceData[key];
      const qty = selectedServices[key];
      const itemPrice = service.price * qty;
      subtotal += itemPrice;

      if (service.unit === 'kg') {
        totalKg += qty;
      }

      const itemEl = document.createElement('div');
      itemEl.className = 'kw-bill-item';
      itemEl.innerHTML = `
        <span class="kw-bill-item-name">${service.name} (${qty}${service.unit})</span>
        <span class="kw-bill-item-price">Rs ${itemPrice}</span>
      `;
      billItemsContainer.appendChild(itemEl);
    });

    // --- Pickup Type & Upsell Logic ---
    if (totalKg >= 3) {
      selectFreePickup();
      disablePaidPickup(); // Free pickup active, paid disabled
      enableFreePickup(); // Ensure free pickup is clickable (if ever implemented)
      if (pickupNote) pickupNote.style.display = 'none';
      if (upsellNote) upsellNote.style.display = 'none'; // Hide upsell if free pickup is active
    } else {
      selectPaidPickup();
      disableFreePickup(); // Paid pickup active, free disabled
      enablePaidPickup(); // Ensure paid pickup is clickable (if ever implemented)
      if (pickupNote) pickupNote.style.display = 'block'; // Show note if paid is forced

      // Upsell message logic
      if (upsellNote && totalKg < 3) {
        const remainingKg = 3 - totalKg;
        upsellNote.textContent = `Add ${remainingKg}kg more to avoid Rs 50 fee`;
        upsellNote.style.display = 'block';
      } else if (upsellNote) {
        upsellNote.style.display = 'none';
      }
    }
    // --- End Pickup Type & Upsell Logic ---


    const pickupFee = pickupType === 'paid' ? 50 : 0;
    const finalTotal = subtotal + pickupFee;

    animatePriceUpdate(subtotalEl, `Rs ${subtotal}`);
    animatePriceUpdate(pickupEl, pickupFee === 0 ? 'Free' : `Rs ${pickupFee}`);
    animatePriceUpdate(totalEl, `Rs ${finalTotal}`);
    animatePriceUpdate(footerPriceEl, `Rs ${finalTotal}`);

    // Update booking bar
    const bookingBar = document.getElementById('booking-bar');
    const confirmBtn = document.getElementById('confirm-btn');
    const hasServices = Object.keys(selectedServices).length > 0;

    if (hasServices) {
      bookingBar.style.display = 'block';
      confirmBtn.textContent = `🐝 Confirm Booking • Rs ${finalTotal}`;
    } else {
      bookingBar.style.display = 'none';
    }

    stickyFooter.style.display = hasServices ? 'flex' : 'none';
  }

  // Service Card selection
  document.querySelectorAll('.kw-service-card').forEach(card => {
    card.addEventListener('click', function() {
      const service = this.dataset.service;
      if (selectedServices[service]) {
        delete selectedServices[service];
        this.classList.remove('selected');
      } else {
        selectedServices[service] = 1; // Default to 1
        this.classList.add('selected');
      }
      renderQuantitySelectors(); // This will call updateSummary
    });
  });
  
  // Remove manual click handlers for pickup pills by disabling pointer events
  document.querySelectorAll('[data-pickup]').forEach(function(pill) {
    pill.style.pointerEvents = 'none'; // Disable manual clicks
  });


  // Delivery type
  document.querySelectorAll('[data-delivery]').forEach(function(pill) {
    pill.addEventListener('click', function() {
      document.querySelectorAll('[data-delivery]').forEach(function(p) { p.classList.remove('active'); });
      this.classList.add('active');
      deliveryType = this.dataset.delivery;
      updateSummary();
    });
  });

  // Init address section and Initial call to update summary (after everything else is set up)
  document.addEventListener('DOMContentLoaded', () => {
    initAddressSection();
    renderQuantitySelectors(); // Initial render of quantity selectors
  });

})();
</script>

