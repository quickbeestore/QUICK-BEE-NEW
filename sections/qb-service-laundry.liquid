      <div class="kw-service-card" data-service="express" data-price="180" data-unit="kg">
        <span class="kw-service-icon">⚡</span>
        <div class="kw-service-name">Express (6h)</div>
        <div class="kw-service-price">Rs 180/kg</div>
        <div class="kw-service-desc">Priority 6-hour delivery</div>
      </div>
    </div>
  </div>

  <!-- ═══ BOOKING FORM ═══ -->
  <div class="kw-form-section">

    <!-- Step 1: Quantity -->
    <div class="kw-form-card">
      <div class="kw-form-card-title"><span>1</span> Quantity</div>
      <div class="kw-form-group">
        <label class="kw-label" id="kw-qty-label">Weight in kg</label>
        <div class="kw-qty-row">
          <button class="kw-qty-btn" id="kw-minus" type="button">−</button>
          <input class="kw-input kw-qty-input" type="number" id="kw-qty" value="1" min="1" max="100" readonly>
          <button class="kw-qty-btn" id="kw-plus" type="button">+</button>
        </div>
      </div>
    </div>

    <!-- Step 2: Pickup & Delivery -->
    <div class="kw-form-card">
      <div class="kw-form-card-title"><span>2</span> Pickup & Delivery</div>
      <div class="kw-form-group">
        <label class="kw-label">Pickup Type</label>
        <div class="kw-toggle-group">
          <div class="kw-toggle-pill active" data-pickup="free">
            <span class="kw-toggle-label">🆓 Free Pickup</span>
            <span class="kw-toggle-sub">Min. 3kg order</span>
          </div>
          <div class="kw-toggle-pill" data-pickup="paid">
            <span class="kw-toggle-label">🏍️ Paid Pickup</span>
            <span class="kw-toggle-sub">Rs 50 fee</span>
          </div>
        </div>
      </div>
      <div class="kw-form-group">
        <label class="kw-label">Preferred Pickup Date</label>
        <input type="date" class="kw-input" id="kw-date">
      </div>
      <div class="kw-form-group">
        <label class="kw-label">Pickup Time Slot</label>
        <select class="kw-select" id="kw-time">
          <option value="">— Choose time slot —</option>
          <option value="morning">🌅 Morning (6 AM – 12 PM)</option>
          <option value="afternoon">☀️ Afternoon (12 PM – 5 PM)</option>
          <option value="evening">🌆 Evening (5 PM – 9 PM)</option>
        </select>
      </div>
      <div class="kw-form-group">
        <label class="kw-label">Delivery Speed</label>
        <div class="kw-toggle-group">
          <div class="kw-toggle-pill active" data-delivery="standard">
            <span class="kw-toggle-label">📦 Standard</span>
            <span class="kw-toggle-sub">Free · 3–5 days</span>
          </div>
          <div class="kw-toggle-pill" data-delivery="express">
            <span class="kw-toggle-label">⚡ Express</span>
            <span class="kw-toggle-sub">Rs 100 · Next day</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 3: Your Details -->
    <div class="kw-form-card">
      <div class="kw-form-card-title"><span>3</span> Your Details</div>

      <div class="kw-form-group">
        <label class="kw-label">Full Name</label>
        <input type="text" class="kw-input" id="kw-name" placeholder="e.g. Ramesh Shrestha">
      </div>
      <div class="kw-form-group">
        <label class="kw-label">Phone Number</label>
        <input type="tel" class="kw-input" id="kw-phone" placeholder="98XXXXXXXX" maxlength="15">
      </div>

      <!-- Delivery Address -->
      <div class="kw-form-group">
        <label class="kw-label">Delivery Address</label>

        <!-- Saved location card (visible when location is set) -->
        <div id="kw-saved-loc-card" class="kw-saved-loc-card" style="display:none;">
          <div class="kw-saved-loc-pin">📍</div>
          <div class="kw-saved-loc-info">
            <div class="kw-saved-loc-label" id="kw-saved-loc-label">—</div>
            <div class="kw-saved-loc-sub">✓ Saved delivery location</div>
            <a id="kw-saved-maps-link" class="kw-saved-maps-link" href="#" target="_blank" style="display:none;">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              View on Maps
            </a>
          </div>
          <button type="button" class="kw-change-btn" id="kw-change-btn">Change</button>
        </div>

        <!-- No location saved notice -->
        <div id="kw-no-loc-banner" class="kw-no-loc-banner" style="display:none;">
          <span>⚠️</span>
          <span>No location saved — please enter your address below.</span>
        </div>

        <!-- Manual address form (shown when no location OR user clicks Change) -->
        <div id="kw-change-form" class="kw-change-form" style="display:none;">
          <div class="kw-form-group" style="margin-bottom:12px;">
            <label class="kw-label" style="margin-bottom:6px;">Street Address *</label>
            <textarea class="kw-textarea" id="kw-address" rows="2"
              placeholder="e.g. Kuleshwar, Kathmandu-14, near Hotel XYZ"
              style="min-height:70px;"></textarea>
          </div>
          <div class="kw-form-group" style="margin-bottom:0;">
            <div class="kw-maps-row">
              <label class="kw-label" style="margin-bottom:0;">Google Maps Link *</label>
              <button type="button" class="kw-maps-help-btn" id="kw-maps-help-btn">Help</button>
            </div>
            <input type="url" class="kw-input" id="kw-maps-link" style="margin-top:6px;"
              placeholder="Paste Google Maps share link">
            <a href="https://www.google.com/maps" target="_blank" class="kw-open-maps-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              Open Google Maps
            </a>
          </div>
        </div>
      </div>

      <div class="kw-form-group">
        <label class="kw-label">Special Instructions (Optional)</label>
        <textarea class="kw-textarea" id="kw-notes"
          placeholder="e.g. Handle delicates separately, no bleach"
          style="min-height: 60px;"></textarea>
      </div>
    </div>

    <!-- Google Maps Guide Overlay -->
    <div class="kw-maps-guide" id="kw-maps-guide">
      <div class="kw-maps-guide-inner">
        <div class="kw-maps-guide-title">How to copy the Google Maps link</div>
        <div class="kw-maps-guide-sub">Open Google Maps → find your exact landmark → tap Share → copy the link → paste it here.</div>
        <img class="kw-maps-guide-img"
          src="{{ 'assets-share-google-maps-location.png' | asset_url }}"
          alt="How to copy Google Maps link" loading="lazy">
        <a href="https://www.google.com/maps" target="_blank" class="kw-open-maps-btn" style="margin-bottom:10px;">
          Open Google Maps
        </a>
        <button class="kw-maps-guide-close" id="kw-maps-guide-close">Got it</button>
      </div>
    </div>

    <!-- Order Summary -->
    <div class="kw-summary-card">
      <div class="kw-summary-title">🧾 Order Summary</div>
      <div class="kw-summary-row">
        <span class="kw-summary-row-label">Service</span>
        <span class="kw-summary-row-val" id="kw-s-service">Wash & Fold</span>
      </div>
      <div class="kw-summary-row">
        <span class="kw-summary-row-label">Quantity</span>
        <span class="kw-summary-row-val" id="kw-s-qty">1 kg</span>
      </div>
      <div class="kw-summary-row">
        <span class="kw-summary-row-label">Service Cost</span>
        <span class="kw-summary-row-val" id="kw-s-cost">Rs 100</span>
      </div>
      <div class="kw-summary-row">
        <span class="kw-summary-row-label">Pickup Fee</span>
        <span class="kw-summary-row-val" id="kw-s-pickup">Free</span>
      </div>
      <div class="kw-summary-row">
        <span class="kw-summary-row-label">Delivery Fee</span>
        <span class="kw-summary-row-val" id="kw-s-delivery">Free</span>
      </div>
      <div class="kw-summary-divider"></div>
      <div class="kw-summary-total">
        <span>Total</span>
        <span class="kw-summary-total-val" id="kw-s-total">Rs 100</span>
      </div>
    </div>


    <!-- CTA Buttons -->
    <button class="kw-book-btn" id="kw-book-btn" type="button">
      🐝 Confirm Booking
    </button>
    <div class="trust-urgency-badge">
      <div class="trust-urgency-line1">
        ⚡ Express 6h Delivery Available
      </div>
      <div class="trust-urgency-line2">
        <span>✔ Safe Handling</span>
        <span>✔ On-Time Delivery</span>
        <span>✔ Quality Assured</span>
      </div>
    </div>
    <div class="kw-spacer"></div>
  </div>

</div>

<script>
(function() {
  var selectedService = 'wash-fold';
  var selectedPrice = 100;
  var selectedUnit = 'kg';
  var qty = 1;
  var pickupType = 'free';
  var deliveryType = 'standard';

  var serviceNames = {
    'wash-fold': 'Wash & Fold',
    'wash-iron': 'Wash & Iron',
    'dry-clean': 'Dry Cleaning',
    'iron-only': 'Iron Only',
    'bedsheets': 'Bedsheets & Linen',
    'express': 'Express (6h)'
  };

  // ── Read saved location from localStorage ──
  var savedLocation = null;
  var usingManualAddress = false;

  function readSavedLocation() {
    var keys = ['qb_location_detail', 'qb_selected_location'];
    for (var i = 0; i < keys.length; i++) {
      try {
        var raw = localStorage.getItem(keys[i]);
        if (raw) {
          var parsed = JSON.parse(raw);
          if (parsed && typeof parsed === 'object') return parsed;
        }
      } catch(e) {}
    }
    return null;
  }

  function getLocationDisplay(loc) {
    if (!loc) return '';
    if (loc.mode === 'someone_else') {
      return loc.recipient_name || loc.label || 'Saved location';
    }
    return loc.label || loc.name || loc.street || loc.address ||
           loc.city || loc.area || loc.district || 'Saved location';
  }

  function initAddressSection() {
    savedLocation = readSavedLocation();
    var savedCard = document.getElementById('kw-saved-loc-card');
    var noLocBanner = document.getElementById('kw-no-loc-banner');
    var changeForm = document.getElementById('kw-change-form');

    if (savedLocation) {
      // Has saved location — show card
      var display = getLocationDisplay(savedLocation);
      var labelEl = document.getElementById('kw-saved-loc-label');
      if (labelEl) labelEl.textContent = display;

      // Auto-generate Google Maps link from lat/lng
      var lat = savedLocation.latitude || savedLocation.lat;
      var lng = savedLocation.longitude || savedLocation.lng || savedLocation.lon;
      var mapsLinkEl = document.getElementById('kw-saved-maps-link');
      if (mapsLinkEl && lat && lng) {
        var autoMapsUrl = 'https://www.google.com/maps?q=' + lat + ',' + lng;
        mapsLinkEl.href = autoMapsUrl;
        mapsLinkEl.style.display = 'inline-flex';
        savedLocation._autoMapsUrl = autoMapsUrl;
      }

      if (savedCard) savedCard.style.display = 'flex';
      if (noLocBanner) noLocBanner.style.display = 'none';
      if (changeForm) changeForm.style.display = 'none';
      usingManualAddress = false;
    } else {
      // No saved location — show manual form directly
      if (savedCard) savedCard.style.display = 'none';
      if (noLocBanner) noLocBanner.style.display = 'flex';
      if (changeForm) changeForm.style.display = 'block';
      usingManualAddress = true;
    }
  }

  // Change button toggle
  var changeBtn = document.getElementById('kw-change-btn');
  if (changeBtn) {
    changeBtn.addEventListener('click', function() {
      var savedCard = document.getElementById('kw-saved-loc-card');
      var changeForm = document.getElementById('kw-change-form');
      var noLocBanner = document.getElementById('kw-no-loc-banner');

      usingManualAddress = true;
      if (savedCard) savedCard.style.display = 'none';
      if (noLocBanner) noLocBanner.style.display = 'none';
      if (changeForm) {
        changeForm.style.display = 'block';
        // Scroll into view smoothly
        changeForm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  }

  // Google Maps help overlay
  var mapsHelpBtn = document.getElementById('kw-maps-help-btn');
  var mapsGuide = document.getElementById('kw-maps-guide');
  var mapsGuideClose = document.getElementById('kw-maps-guide-close');

  if (mapsHelpBtn && mapsGuide) {
    mapsHelpBtn.addEventListener('click', function() {
      mapsGuide.classList.add('active');
    });
  }
  if (mapsGuideClose && mapsGuide) {
    mapsGuideClose.addEventListener('click', function() {
      mapsGuide.classList.remove('active');
    });
  }
  if (mapsGuide) {
    mapsGuide.addEventListener('click', function(e) {
      if (e.target === mapsGuide) mapsGuide.classList.remove('active');
    });
  }

  // Init address section
  initAddressSection();

  // Set today as minimum date
  var today = new Date();
  var todayStr = today.getFullYear() + '-' +
    String(today.getMonth() + 1).padStart(2, '0') + '-' +
    String(today.getDate()).padStart(2, '0');
  var dateEl = document.getElementById('kw-date');
  if (dateEl) { dateEl.min = todayStr; dateEl.value = todayStr; }

  // Service Card selection
  document.querySelectorAll('.kw-service-card').forEach(function(card) {
    card.addEventListener('click', function() {
      document.querySelectorAll('.kw-service-card').forEach(function(c) { c.classList.remove('selected'); });
      this.classList.add('selected');
      selectedService = this.dataset.service;
      selectedPrice = parseInt(this.dataset.price);
      selectedUnit = this.dataset.unit;
      var unitMap = { 'kg': 'Weight in kg', 'piece': 'Number of pieces', 'set': 'Number of sets' };
      var label = document.getElementById('kw-qty-label');
      if (label) label.textContent = unitMap[selectedUnit] || 'Quantity';
      updateSummary();
    });
  });

  // Quantity
  document.getElementById('kw-plus').addEventListener('click', function() {
    if (qty < 50) { qty++; document.getElementById('kw-qty').value = qty; updateSummary(); }
  });
  document.getElementById('kw-minus').addEventListener('click', function() {
    if (qty > 1) { qty--; document.getElementById('kw-qty').value = qty; updateSummary(); }
  });

  // Pickup type
  document.querySelectorAll('[data-pickup]').forEach(function(pill) {
    pill.addEventListener('click', function() {
      document.querySelectorAll('[data-pickup]').forEach(function(p) { p.classList.remove('active'); });
      this.classList.add('active');
      pickupType = this.dataset.pickup;
      updateSummary();
    });
  });

  // Delivery type
  document.querySelectorAll('[data-delivery]').forEach(function(pill) {
    pill.addEventListener('click', function() {
      document.querySelectorAll('[data-delivery]').forEach(function(p) { p.classList.remove('active'); });
      this.classList.add('active');
      deliveryType = this.dataset.delivery;
      updateSummary();
    });
  });

  // Live update WhatsApp link on inputs
  ['kw-name','kw-phone','kw-address','kw-maps-link','kw-date','kw-time','kw-notes'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', updateSummary);
  });
  var dateElWatch = document.getElementById('kw-date');
  if (dateElWatch) dateElWatch.addEventListener('change', updateSummary);
  var timeElWatch = document.getElementById('kw-time');
  if (timeElWatch) timeElWatch.addEventListener('change', updateSummary);

  // Helper: get the resolved delivery address for the booking
  function getDeliveryAddress() {
    if (!usingManualAddress && savedLocation) {
      var loc = savedLocation;
      // Build auto maps URL from lat/lng
      var autoLat = loc.latitude || loc.lat;
      var autoLng = loc.longitude || loc.lng || loc.lon;
      var autoMapsUrl = loc._autoMapsUrl ||
        (autoLat && autoLng ? 'https://www.google.com/maps?q=' + lat + ',' + autoLng : null);

      if (loc.mode === 'someone_else') {
        var parts = [];
        if (loc.recipient_name) parts.push('For: ' + loc.recipient_name);
        if (loc.recipient_phone) parts.push('Ph: ' + loc.recipient_phone);
        if (loc.landmark) parts.push('Maps: ' + loc.landmark);
        else if (autoMapsUrl) parts.push('Maps: ' + autoMapsUrl);
        return parts.join(' | ') || getLocationDisplay(loc);
      }
      var addrStr = loc.street || loc.address || loc.label || loc.name ||
                    loc.city || loc.area || loc.district || 'Saved location';
      return addrStr + (autoMapsUrl ? '
Maps: ' + autoMapsUrl : '');
    }
    // Manual form
    var addrEl = document.getElementById('kw-address');
    var mapsEl = document.getElementById('kw-maps-link');
    var addr = (addrEl && addrEl.value.trim()) || '';
    var maps = (mapsEl && mapsEl.value.trim()) || '';
    return addr + (maps ? '
Maps: ' + maps : '');
  }

  function updateSummary() {
    var cost = selectedPrice * qty;
    var pickupFee = pickupType === 'paid' ? 50 : 0;
    var delivFee = deliveryType === 'express' ? 100 : 0;
    var surcharge = 0;

    // Surcharge logic
    if ( (selectedService === 'wash-fold' || selectedService === 'wash-iron' || selectedService === 'express') && qty < 3) {
      surcharge = 50;
    }
    if (selectedService === 'socks' && qty < 10) {
      surcharge = 50;
    }
    if (selectedService === 'bedsheets' && qty < 2) {
      surcharge = 50;
    }

    // Dry Cleaning special rules
    if (selectedService === 'dry-clean') {
      pickupFee = 0;
      delivFee = 0;
      document.querySelector('[data-pickup="free"]').classList.add('active');
      document.querySelector('[data-pickup="paid"]').classList.remove('active');
      document.querySelector('[data-delivery="standard"]').classList.add('active');
      document.querySelector('[data-delivery="express"]').classList.remove('active');
      document.querySelector('[data-pickup="paid"]').style.pointerEvents = 'none';
      document.querySelector('[data-delivery="express"]').style.pointerEvents = 'none';
      document.querySelector('[data-pickup="paid"]').style.opacity = '0.5';
      document.querySelector('[data-delivery="express"]').style.opacity = '0.5';
    } else {
      document.querySelector('[data-pickup="paid"]').style.pointerEvents = 'auto';
      document.querySelector('[data-delivery="express"]').style.pointerEvents = 'auto';
      document.querySelector('[data-pickup="paid"]').style.opacity = '1';
      document.querySelector('[data-delivery="express"]').style.opacity = '1';
    }

    var total = cost + pickupFee + delivFee + surcharge;

    document.getElementById('kw-s-service').textContent = serviceNames[selectedService];
    document.getElementById('kw-s-qty').textContent = qty + ' ' + selectedUnit;
    document.getElementById('kw-s-cost').textContent = 'Rs ' + cost;
    document.getElementById('kw-s-pickup').textContent = pickupFee === 0 ? 'Free' : 'Rs ' + pickupFee;
    document.getElementById('kw-s-delivery').textContent = delivFee === 0 ? 'Free' : 'Rs ' + delivFee;

    var surchargeRow = document.getElementById('kw-surcharge-row');
    if (surcharge > 0) {
      surchargeRow.style.display = 'flex';
      document.getElementById('kw-s-surcharge').textContent = 'Rs ' + surcharge;
    } else {
      surchargeRow.style.display = 'none';
    }

    document.getElementById('kw-s-total').textContent = 'Rs ' + total;
  }
  // Book Button
  document.getElementById('kw-book-btn').addEventListener('click', function() {
    var name = document.getElementById('kw-name').value.trim();
    var phone = document.getElementById('kw-phone').value.trim();
    var date = document.getElementById('kw-date').value;
    var time = document.getElementById('kw-time').value;

    if (!name) { alert('Please enter your full name.'); return; }
    if (!phone || phone.length < 10) { alert('Please enter a valid phone number (10 digits).'); return; }

    // Validate address
    if (usingManualAddress || !savedLocation) {
      var addrVal = (document.getElementById('kw-address') || {}).value || '';
      if (!addrVal.trim()) { alert('Please enter your delivery address.'); return; }
    }

    if (!date) { alert('Please select a pickup date.'); return; }
    if (!time) { alert('Please choose a time slot.'); return; }

  });

  updateSummary();
})();
</script>

{% schema %}
{
  "name": "QB Laundry Service",
  "settings": []
}
{% endschema %}
