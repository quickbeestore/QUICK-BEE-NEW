    line-height: 1.5;
  }

  .kw-maps-guide-img {
    width: 100%;
    border-radius: 12px;
    margin-bottom: 16px;
    border: 1px solid var(--theme-border, #eee);
  }

  .kw-maps-guide-close {
    width: 100%;
