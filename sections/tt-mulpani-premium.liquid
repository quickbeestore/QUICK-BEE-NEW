    {%- assign cat_labels = '🍛 Biryani,🎁 Combo Deals,🍗 Chicken,🍖 Lollipop & BBQ,🍟 Snacks,🥤 Drinks,🍽️ More Items' | split: ',' -%}

    {%- for ci in (0..6) -%}
      {%- assign cat_key   = cat_keys[ci] -%}
      {%- assign cat_label = cat_labels[ci] -%}

      {%- comment -%} Collect products for this category {%- endcomment -%}
      {%- assign cat_products = '' -%}
      {%- assign cat_count = 0 -%}

      {%- for product in collection.products -%}
        {%- assign matched = false -%}

        {%- if cat_key == 'biryani' -%}
          {%- if product.tags contains 'biryani' or product.title contains 'Biryani' or product.title contains 'biryani' or product.type contains 'Biryani' -%}
            {%- assign matched = true -%}
          {%- endif -%}
        {%- elsif cat_key == 'combo' -%}
          {%- if product.tags contains 'combo' or product.title contains 'Combo' or product.title contains 'combo' or product.type contains 'Combo' -%}
            {%- assign matched = true -%}
          {%- endif -%}
        {%- elsif cat_key == 'chicken' -%}
          {%- if product.tags contains 'chicken' or product.title contains 'Chicken' or product.title contains 'chicken' or product.type contains 'Chicken' -%}
            {%- if product.tags contains 'lollipop' or product.title contains 'Lollipop' or product.title contains 'lollipop' -%}
              {%- assign matched = false -%}
            {%- else -%}
              {%- assign matched = true -%}
            {%- endif -%}
          {%- endif -%}
        {%- elsif cat_key == 'lollipop' -%}
          {%- if product.tags contains 'lollipop' or product.title contains 'Lollipop' or product.title contains 'lollipop' or product.tags contains 'bbq' or product.title contains 'BBQ' -%}
            {%- assign matched = true -%}
          {%- endif -%}
        {%- elsif cat_key == 'snacks' -%}
          {%- if product.tags contains 'snacks' or product.tags contains 'snack' or product.tags contains 'starter' or product.type contains 'Snack' -%}
            {%- assign matched = true -%}
          {%- endif -%}
        {%- elsif cat_key == 'drinks' -%}
          {%- if product.tags contains 'drink' or product.tags contains 'drinks' or product.tags contains 'beverage' or product.type contains 'Drink' -%}
            {%- assign matched = true -%}
          {%- endif -%}
        {%- elsif cat_key == 'other' -%}
          {%- assign already = false -%}
          {%- for ck in cat_keys -%}
            {%- if ck == 'other' -%}{%- continue -%}{%- endif -%}
            {%- if product.tags contains ck or product.title contains ck -%}
              {%- assign already = true -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if product.tags contains 'biryani' or product.title contains 'Biryani' or product.title contains 'biryani' -%}{%- assign already = true -%}{%- endif -%}
          {%- if product.tags contains 'combo' or product.title contains 'Combo' -%}{%- assign already = true -%}{%- endif -%}
          {%- if product.tags contains 'chicken' or product.title contains 'Chicken' -%}{%- assign already = true -%}{%- endif -%}
          {%- if product.tags contains 'lollipop' or product.title contains 'Lollipop' or product.tags contains 'bbq' -%}{%- assign already = true -%}{%- endif -%}
          {%- if product.tags contains 'snack' or product.tags contains 'snacks' or product.tags contains 'starter' -%}{%- assign already = true -%}{%- endif -%}
          {%- if product.tags contains 'drink' or product.tags contains 'drinks' or product.tags contains 'beverage' -%}{%- assign already = true -%}{%- endif -%}
          {%- unless already -%}
            {%- assign matched = true -%}
          {%- endunless -%}
        {%- endif -%}

        {%- if matched -%}
          {%- assign cat_count = cat_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if cat_count > 0 -%}

        <div class="tt-cat-section">
          <div class="tt-section-label" style="padding-top:36px;padding-bottom:20px;">
