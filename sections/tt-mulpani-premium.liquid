            <span class="tt-section-label-pill">{{ cat_label }}</span>
            <div class="tt-section-label-line tt-section-label-line--rtl"></div>
          </div>

          <div class="tt-grid-outer">
            <div class="tt-grid">

              {%- for product in collection.products -%}
                {%- assign matched = false -%}

                {%- if cat_key == 'biryani' -%}
                  {%- if product.tags contains 'biryani' or product.title contains 'Biryani' or product.title contains 'biryani' or product.type contains 'Biryani' -%}
                    {%- assign matched = true -%}
                  {%- endif -%}
                {%- elsif cat_key == 'combo' -%}
                  {%- if product.tags contains 'combo' or product.title contains 'Combo' or product.title contains 'combo' or product.type contains 'Combo' -%}
                    {%- assign matched = true -%}
                  {%- endif -%}
                {%- elsif cat_key == 'chicken' -%}
                  {%- if product.tags contains 'chicken' or product.title contains 'Chicken' or product.title contains 'chicken' or product.type contains 'Chicken' -%}
                    {%- if product.tags contains 'lollipop' or product.title contains 'Lollipop' or product.title contains 'lollipop' -%}
                      {%- assign matched = false -%}
                    {%- else -%}
                      {%- assign matched = true -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- elsif cat_key == 'lollipop' -%}
                  {%- if product.tags contains 'lollipop' or product.title contains 'Lollipop' or product.title contains 'lollipop' or product.tags contains 'bbq' or product.title contains 'BBQ' -%}
                    {%- assign matched = true -%}
                  {%- endif -%}
                {%- elsif cat_key == 'snacks' -%}
                  {%- if product.tags contains 'snacks' or product.tags contains 'snack' or product.tags contains 'starter' or product.type contains 'Snack' -%}
                    {%- assign matched = true -%}
                  {%- endif -%}
                {%- elsif cat_key == 'drinks' -%}
                  {%- if product.tags contains 'drink' or product.tags contains 'drinks' or product.tags contains 'beverage' or product.type contains 'Drink' -%}
                    {%- assign matched = true -%}
                  {%- endif -%}
                {%- elsif cat_key == 'other' -%}
                  {%- assign already = false -%}
                  {%- if product.tags contains 'biryani' or product.title contains 'Biryani' or product.title contains 'biryani' -%}{%- assign already = true -%}{%- endif -%}
                  {%- if product.tags contains 'combo' or product.title contains 'Combo' -%}{%- assign already = true -%}{%- endif -%}
                  {%- if product.tags contains 'chicken' or product.title contains 'Chicken' -%}{%- assign already = true -%}{%- endif -%}
                  {%- if product.tags contains 'lollipop' or product.title contains 'Lollipop' or product.tags contains 'bbq' -%}{%- assign already = true -%}{%- endif -%}
                  {%- if product.tags contains 'snack' or product.tags contains 'snacks' or product.tags contains 'starter' -%}{%- assign already = true -%}{%- endif -%}
                  {%- if product.tags contains 'drink' or product.tags contains 'drinks' or product.tags contains 'beverage' -%}{%- assign already = true -%}{%- endif -%}
                  {%- unless already -%}
                    {%- assign matched = true -%}
                  {%- endunless -%}
                {%- endif -%}

                {%- if matched -%}
                  {%- assign is_sold_out = false -%}
                  {%- unless product.available -%}{%- assign is_sold_out = true -%}{%- endunless -%}

                  {%- assign has_discount = false -%}
                  {%- assign save_pct = 0 -%}
                  {%- if product.compare_at_price > product.price -%}
                    {%- assign has_discount = true -%}
                    {%- assign save_amt = product.compare_at_price | minus: product.price -%}
                    {%- assign save_pct = save_amt | times: 100 | divided_by: product.compare_at_price -%}
                  {%- endif -%}

                  {%- assign badge = '' -%}
                  {%- if product.tags contains 'best-seller' -%}{%- assign badge = 'best' -%}
                  {%- elsif product.tags contains 'hot' -%}{%- assign badge = 'hot' -%}
                  {%- elsif product.tags contains 'new' -%}{%- assign badge = 'new' -%}
                  {%- endif -%}

                  <div class="tt-card{% if is_sold_out %} tt-sold-out{% endif %}"
                       data-product-id="{{ product.id }}"
                       onclick="ttGoTo('{{ product.url }}')"
                       role="article">

                    <div class="tt-card-img-wrap">
                      {%- if badge == 'best' -%}
                        <div class="tt-badge tt-badge--best">⭐ Best Seller</div>
                      {%- elsif badge == 'hot' -%}
                        <div class="tt-badge tt-badge--hot">🔥 Hot Pick</div>
                      {%- elsif badge == 'new' -%}
                        <div class="tt-badge tt-badge--new">✨ New</div>
                      {%- endif -%}
                      <div class="tt-sold-overlay">Sold Out</div>
                      <div class="tt-card-fire" aria-hidden="true"></div>
                      <div class="tt-card-steam" aria-hidden="true"></div>
                      {%- if product.featured_image -%}
                        <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title | escape }}" loading="lazy" decoding="async">
                      {%- else -%}
                        <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:64px;color:rgba(212,160,23,0.2);">🍛</div>
                      {%- endif -%}
                      <div class="tt-delivery-badge">⚡ 18-22 mins</div>
                    </div>

                    <div class="tt-card-body">
                      <div class="tt-card-name">{{ product.title }}</div>
                      <div class="tt-card-price-row">
                        <span class="tt-card-price">Rs {{ product.price | divided_by: 100 }}</span>
                        {%- if has_discount -%}
                          <span class="tt-card-compare">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                          <span class="tt-card-save">{{ save_pct }}% OFF</span>
                        {%- endif -%}
                      </div>
                      {%- if is_sold_out == false -%}
                        <div class="tt-card-urgency">🔥 Selling Fast</div>
                        <button class="tt-add-btn" onclick="ttAddCart(event, '{{ product.first_available_variant.id }}')" aria-label="Add {{ product.title | escape }} to cart">
                          🛒 Add to Cart
                        </button>
                      {%- else -%}
                        <button class="tt-add-btn" disabled>Sold Out</button>
                      {%- endif -%}
                    </div>

                  </div>
                {%- endif -%}
              {%- endfor -%}

            </div>
          </div>
        </div>

      {%- endif -%}
    {%- endfor -%}

  {%- else -%}
    <div class="tt-grid-outer">
      <div class="tt-empty">
        <div class="tt-empty-icon">🍛</div>
        <div class="tt-empty-text">Menu Coming Soon</div>
        <div class="tt-empty-sub">Check back shortly — new dishes are being added.</div>
      </div>
    </div>
  {%- endif -%}

  </div>

  <!-- ══════════════════════════════════════════
       STICKY ORDER BAR
  ══════════════════════════════════════════ -->
  <div class="tt-sticky-bar" id="ttStickyBar">
    <img
      src="{{ 'Typical taste mulpani logo.png' | asset_url }}"
      alt="Typical Taste"
      class="tt-sticky-logo"
      loading="lazy"
    >
    <div class="tt-sticky-text">
      <div class="tt-sticky-title">Typical Taste Mulpani</div>
      <div class="tt-sticky-sub">⚡ 18-22 min delivery</div>
    </div>
    <a href="#tt-products" class="tt-sticky-cta">🛒 Order Now</a>
  </div>

  <!-- Toast -->
  <div class="tt-toast" id="ttToast" aria-live="polite" role="status">
    <span class="tt-toast-icon" id="ttToastIcon">✅</span>
    <span class="tt-toast-text" id="ttToastText">Added to cart!</span>
  </div>

</div>

<script>
(function () {
  'use strict';

  /* ── Particle System ── */
  var canvas = document.getElementById('ttParticles');
  if (canvas) {
    var ctx = canvas.getContext('2d');
    var W, H, particles = [];

    function resize() {
      W = canvas.width  = canvas.offsetWidth;
      H = canvas.height = canvas.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    function rand(a, b) { return a + Math.random() * (b - a); }

    // Mix of ember sparks + gold dust
    function makeParticle() {
      var type = Math.random() < 0.6 ? 'ember' : 'dust';
      return {
        type: type,
        x: rand(0, W),
        y: rand(H * 0.3, H),
        vx: rand(-0.4, 0.4),
        vy: rand(-0.8, -0.2),
        size: type === 'ember' ? rand(1.5, 3.5) : rand(0.8, 2),
        alpha: rand(0.4, 0.9),
        life: rand(0.4, 1),
        decay: rand(0.003, 0.007),
        hue: type === 'ember' ? rand(10, 35) : rand(42, 52)
      };
    }

    for (var i = 0; i < 80; i++) {
      var p = makeParticle();
      p.y = rand(0, H); // spread initial
      particles.push(p);
    }

    function drawParticles() {
      ctx.clearRect(0, 0, W, H);
      for (var i = particles.length - 1; i >= 0; i--) {
        var p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.life -= p.decay;
        p.alpha = Math.max(0, p.life);

        if (p.life <= 0 || p.y < -10) {
          particles[i] = makeParticle();
          particles[i].y = H + 5;
          continue;
        }

        ctx.save();
        ctx.globalAlpha = p.alpha * 0.75;
        if (p.type === 'ember') {
          // orange-red ember
          var grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size * 2);
          grad.addColorStop(0, 'hsl(' + p.hue + ',100%,80%)');
          grad.addColorStop(0.5, 'hsl(' + p.hue + ',90%,55%)');
          grad.addColorStop(1, 'transparent');
          ctx.fillStyle = grad;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size * 2, 0, Math.PI * 2);
          ctx.fill();
        } else {
          // gold dust
          ctx.fillStyle = 'hsl(' + p.hue + ',80%,70%)';
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.restore();
      }
      requestAnimationFrame(drawParticles);
    }
    requestAnimationFrame(drawParticles);
  }

  /* ── Sticky bar on scroll ── */
  var stickyBar = document.getElementById('ttStickyBar');
  var hero = document.getElementById('ttHero');
  if (stickyBar && hero) {
    var obs = new IntersectionObserver(function(entries) {
      stickyBar.classList.toggle('visible', !entries[0].isIntersecting);
    }, { threshold: 0.15 });
    obs.observe(hero);
  }

  /* ── Smooth hero → products scroll ── */
  window.ttGoTo = function(url) {
    window.location.href = url;
  };

  document.querySelectorAll('a[href="#tt-products"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      e.preventDefault();
      var el = document.getElementById('tt-products');
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  /* ── Toast helper ── */
  var toast     = document.getElementById('ttToast');
  var toastIcon = document.getElementById('ttToastIcon');
  var toastText = document.getElementById('ttToastText');
  var toastTimer;

  function showToast(icon, msg) {
    toastIcon.textContent = icon;
    toastText.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function() { toast.classList.remove('show'); }, 2800);
  }

  /* ── Add to cart ── */
  window.ttAddCart = function(e, variantId) {
    e.stopPropagation();
    var btn = e.currentTarget;
    if (btn.hasAttribute('data-loading')) return;
    btn.setAttribute('data-loading', '1');
    var originalHTML = btn.innerHTML;
    btn.innerHTML = '⏳ Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.status) {
        showToast('⚠️', data.description || 'Could not add item.');
      } else {
        showToast('✅', data.product_title + ' added!');
        // Fire cart:update so the theme's cart drawer picks it up
        document.dispatchEvent(new Event('cart:update', { bubbles: true }));
        // Directly open the cart drawer
        var drawer = document.querySelector('cart-drawer-component');
        if (drawer && typeof drawer.open === 'function') {
          drawer.open();
        }
      }
    })
    .catch(function() {
      showToast('❌', 'Error — please try again.');
    })
    .finally(function() {
      btn.removeAttribute('data-loading');
      btn.innerHTML = originalHTML;
    });
  };

  /* ── Card entrance animation via IntersectionObserver ── */
  if ('IntersectionObserver' in window) {
    var cards = document.querySelectorAll('.tt-card');
    cards.forEach(function(card) {
      card.style.opacity = '0';
      card.style.transform = 'translateY(28px)';
      card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    });
    var cardObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          cardObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
    cards.forEach(function(card, i) {
      setTimeout(function() { cardObs.observe(card); }, i * 40);
    });
  }

})();
</script>

