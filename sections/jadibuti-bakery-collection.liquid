      {%- endif -%}
      {%- if has_choco -%}
      <button class="jb-pill" data-target="choco">🍫 Chocolate <small>({{ choco_count }})</small></button>
      {%- endif -%}
      {%- if has_bento -%}
      <button class="jb-pill" data-target="bento">🎁 Bento <small>({{ bento_count }})</small></button>
      {%- endif -%}
      {%- if has_mini -%}
      <button class="jb-pill" data-target="mini">🍰 Mini Cakes <small>({{ mini_count }})</small></button>
