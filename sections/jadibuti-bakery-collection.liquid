{%- comment -%}
  Cake Chocolate Bakery — Jadibuti
  sections/jadibuti-bakery-collection.liquid
  Theme: Dark Chocolate × Caramel × Gold
{%- endcomment -%}

{%- liquid
  assign all_products = collection.products

  assign has_pound   = false
  assign pound_count  = 0
  assign has_bento   = false
  assign bento_count  = 0
  assign has_choco   = false
  assign choco_count  = 0
  assign has_mini    = false
  assign mini_count   = 0
  assign has_others  = false
  assign other_count  = 0

  for p in all_products
    assign pt = p.type | downcase | strip
    if pt contains 'pound'
      assign has_pound = true
      assign pound_count = pound_count | plus: 1
    elsif pt contains 'bento'
      assign has_bento = true
      assign bento_count = bento_count | plus: 1
    elsif pt contains 'choco' or pt contains 'chocolate' or pt contains 'brownie' or pt contains 'truffle'
      assign has_choco = true
      assign choco_count = choco_count | plus: 1
    elsif pt contains 'mini'
      assign has_mini = true
      assign mini_count = mini_count | plus: 1
    else
      assign has_others = true
      assign other_count = other_count | plus: 1
    endif
  endfor
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
/* ============================================================
   JADIBUTI BAKERY — Dark Chocolate × Caramel × Gold
   ============================================================ */

/* ── Tokens ─────────────────────────────────────────── */
html:not([data-theme="dark"]) .jb-wrap {
  --jb-bg:        #FFF8F0;
  --jb-bg2:       #FFF3E6;
  --jb-surface:   #FFECD4;
  --jb-card:      #FFFFFF;
  --jb-border:    rgba(160,80,20,0.14);
  --jb-border2:   rgba(160,80,20,0.08);
  --jb-text:      #1E0E02;
  --jb-text2:     #6B3A10;
  --jb-text3:     #A06030;
  --jb-gold:      #B8860B;
  --jb-gold2:     #C8960F;
  --jb-caramel:   #C07830;
  --jb-choco:     #6B3A1F;
  --jb-cream:     #FFF5E0;
  --jb-green:     #2E7D32;
  --jb-red:       #C62828;
  --jb-shadow:    0 2px 12px rgba(100,40,0,0.10);
  --jb-shadow-lg: 0 8px 32px rgba(100,40,0,0.18);
  --jb-heading:   'Playfair Display', Georgia, serif;
  --jb-body:      'Inter', system-ui, sans-serif;
}
html[data-theme="dark"] .jb-wrap {
  --jb-bg:        #0e0905;
  --jb-bg2:       #140c04;
  --jb-surface:   #1c1108;
  --jb-card:      #221508;
  --jb-border:    rgba(255,200,100,0.10);
  --jb-border2:   rgba(255,200,100,0.06);
  --jb-text:      #f0dfc0;
  --jb-text2:     #b89060;
  --jb-text3:     #6a4828;
  --jb-gold:      #D4A017;
  --jb-gold2:     #F0C040;
  --jb-caramel:   #C07830;
  --jb-choco:     #5A3018;
  --jb-cream:     #FFF5E0;
  --jb-green:     #4CAF6A;
  --jb-red:       #E05030;
  --jb-shadow:    0 4px 24px rgba(0,0,0,0.7);
  --jb-shadow-lg: 0 16px 56px rgba(0,0,0,0.8);
  --jb-heading:   'Playfair Display', Georgia, serif;
  --jb-body:      'Inter', system-ui, sans-serif;
}

/* ── Reset / Base ───────────────────────────────────── */
.jb-wrap *, .jb-wrap *::before, .jb-wrap *::after { box-sizing: border-box; }
.jb-wrap {
  background: var(--jb-bg);
  font-family: var(--jb-body);
  color: var(--jb-text);
}

/* ── Keyframes ──────────────────────────────────────── */
@keyframes jb-fadein  { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }
@keyframes jb-pop     { 0%{transform:scale(0.7);opacity:0} 65%{transform:scale(1.06)} 100%{transform:scale(1);opacity:1} }
@keyframes jb-spin    { to{transform:rotate(360deg)} }
@keyframes jb-float   { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
@keyframes jb-shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
@keyframes jb-glow    { 0%,100%{box-shadow:0 0 20px rgba(212,160,23,0.3)} 50%{box-shadow:0 0 40px rgba(212,160,23,0.6)} }
@keyframes jb-drip    { 0%{height:0;opacity:0} 60%{opacity:1} 100%{height:24px;opacity:0.7} }

/* ══════════════════════════════════════════════════════
   1. HERO
   ══════════════════════════════════════════════════════ */
.jb-hero {
  position: relative;
  min-height: 360px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 60px 20px 80px;
  background: linear-gradient(160deg, #0d0602 0%, #1c0d04 30%, #2a1408 60%, #1a0d06 100%);
}
html:not([data-theme="dark"]) .jb-hero {
  background: linear-gradient(160deg, #3D1800 0%, #6B3A1F 30%, #9B5A2F 60%, #7A3A15 100%);
}

/* Chocolate texture overlay */
.jb-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 1;
}

/* Gold glow orbs */
.jb-hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
  z-index: 1;
}
.jb-hero-orb--1 { width: 350px; height: 350px; background: rgba(192,120,48,0.18); top: -80px; right: -60px; animation: jb-float 8s ease-in-out infinite; }
.jb-hero-orb--2 { width: 250px; height: 250px; background: rgba(212,160,23,0.12); bottom: -60px; left: 5%; animation: jb-float 10s ease-in-out infinite 2s; }
.jb-hero-orb--3 { width: 180px; height: 180px; background: rgba(107,58,31,0.25); top: 40%; left: -40px; animation: jb-float 7s ease-in-out infinite 1s; }

/* Chocolate drip top decoration */
.jb-drip-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8px;
  background: linear-gradient(90deg, #6B3A1F, #C07830, #D4A017, #C07830, #6B3A1F);
  z-index: 4;
}
.jb-drip-bar::after {
  content: '';
  position: absolute;
  bottom: -6px;
  left: 0;
  right: 0;
  height: 6px;
  background: linear-gradient(90deg, #C07830, #D4A017 50%, #C07830);
  clip-path: polygon(0% 0%, 3% 100%, 6% 0%, 9% 100%, 12% 0%, 15% 100%, 18% 0%, 21% 100%, 24% 0%, 27% 100%, 30% 0%, 33% 100%, 36% 0%, 39% 100%, 42% 0%, 45% 100%, 48% 0%, 51% 100%, 54% 0%, 57% 100%, 60% 0%, 63% 100%, 66% 0%, 69% 100%, 72% 0%, 75% 100%, 78% 0%, 81% 100%, 84% 0%, 87% 100%, 90% 0%, 93% 100%, 96% 0%, 100% 100%, 100% 0%);
}

/* Floating particles */
.jb-particle {
  position: absolute;
  font-size: 18px;
  opacity: 0.06;
  pointer-events: none;
  z-index: 1;
  animation: jb-float var(--fd, 9s) ease-in-out infinite var(--fdl, 0s);
}

.jb-hero-content {
  position: relative;
  z-index: 3;
  text-align: center;
  max-width: 640px;
  animation: jb-fadein 0.7s ease both;
}

/* Location pill */
.jb-hero-location {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(212,160,23,0.12);
  border: 1px solid rgba(212,160,23,0.25);
  border-radius: 999px;
  padding: 5px 14px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--jb-gold2);
  margin-bottom: 18px;
}

/* Big logo / icon */
.jb-hero-icon {
  font-size: 64px;
  line-height: 1;
  margin-bottom: 16px;
  display: block;
  filter: drop-shadow(0 6px 24px rgba(212,160,23,0.5));
  animation: jb-float 4s ease-in-out infinite;
}

.jb-hero-title {
  font-family: var(--jb-heading);
  font-size: clamp(32px, 7vw, 60px);
  font-weight: 900;
  line-height: 1.1;
  color: var(--jb-text);
  margin: 0 0 6px;
  letter-spacing: -0.5px;
}
.jb-hero-title em {
  font-style: italic;
  background: linear-gradient(120deg, var(--jb-caramel) 0%, var(--jb-gold) 45%, var(--jb-gold2) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.jb-hero-tagline {
  font-size: 13.5px;
  color: var(--jb-text2);
  font-style: italic;
  margin: 0 0 24px;
  letter-spacing: 0.04em;
}

/* Info pills */
.jb-hero-pills {
  display: flex;
  justify-content: center;
  gap: 8px;
  flex-wrap: wrap;
}
.jb-hero-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,200,100,0.15);
  border-radius: 999px;
  padding: 7px 16px;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--jb-text2);
}
.jb-hero-pill b { color: var(--jb-gold2); }

/* Wave */
.jb-hero-wave {
  position: absolute;
  bottom: -1px;
  left: 0; right: 0;
  z-index: 4;
  line-height: 0;
}
.jb-hero-wave svg { width: 100%; height: 52px; }

/* ══════════════════════════════════════════════════════
   2. BAKERY STRIP
   ══════════════════════════════════════════════════════ */
.jb-strip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  background: linear-gradient(90deg, var(--jb-choco), var(--jb-caramel), var(--jb-gold), var(--jb-caramel), var(--jb-choco));
  padding: 10px 16px;
  overflow: hidden;
}
.jb-strip-text {
  font-size: 11.5px;
  font-weight: 800;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: #fff;
  white-space: nowrap;
}
.jb-strip-dot {
  width: 4px; height: 4px;
  background: rgba(255,255,255,0.5);
  border-radius: 50%;
  margin: 0 14px;
  flex-shrink: 0;
}

/* ══════════════════════════════════════════════════════
   3. CATEGORY PILLS
   ══════════════════════════════════════════════════════ */
.jb-pills-outer {
  position: sticky;
  top: 0;
  z-index: 400;
  background: var(--jb-bg2);
  border-bottom: 1px solid var(--jb-border);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.jb-pills {
  display: flex;
  gap: 8px;
  padding: 11px 16px 12px;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}
.jb-pills::-webkit-scrollbar { display: none; }
.jb-pill {
  flex-shrink: 0;
  padding: 8px 18px;
  background: rgba(255,255,255,0.05);
  border: 1.5px solid var(--jb-border);
  color: var(--jb-text2);
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.18s ease;
  white-space: nowrap;
  font-family: var(--jb-body);
}
.jb-pill:hover { border-color: var(--jb-gold); color: var(--jb-gold2); background: rgba(212,160,23,0.08); }
.jb-pill.active {
  background: var(--jb-gold);
  border-color: var(--jb-gold);
  color: #000;
  box-shadow: 0 3px 14px rgba(212,160,23,0.35);
  font-weight: 800;
}

/* ══════════════════════════════════════════════════════
   4. PRODUCT GRID
   ══════════════════════════════════════════════════════ */
.jb-content {
  max-width: 1100px;
  margin: 0 auto;
  padding: 28px 14px 60px;
}
.jb-sec { margin-bottom: 44px; }
.jb-sec-head {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 18px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--jb-border);
}
.jb-sec-title {
  font-family: var(--jb-heading);
  font-size: 24px;
  font-weight: 700;
  color: var(--jb-text);
  margin: 0;
  letter-spacing: -0.2px;
}
.jb-sec-sub {
  font-size: 12.5px;
  color: var(--jb-text3);
  font-style: italic;
}
.jb-sec-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, var(--jb-border), transparent);
}
.jb-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
@media(min-width:600px)  { .jb-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; } }
@media(min-width:1024px) { .jb-grid { grid-template-columns: repeat(4, 1fr); gap: 18px; } }

/* ══════════════════════════════════════════════════════
   5. PRODUCT CARD
   ══════════════════════════════════════════════════════ */
.jb-card {
  background: var(--jb-card);
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid var(--jb-border2);
  box-shadow: var(--jb-shadow);
  transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.28s ease, border-color 0.2s;
  animation: jb-fadein 0.5s ease both;
  display: flex;
  flex-direction: column;
  cursor: pointer;
}
.jb-card:hover {
  transform: translateY(-7px);
  box-shadow: var(--jb-shadow-lg), 0 0 0 1px rgba(212,160,23,0.2);
  border-color: rgba(212,160,23,0.2);
}

/* Image */
.jb-card-img-wrap {
  position: relative;
  aspect-ratio: 1/1;
  overflow: hidden;
  background: linear-gradient(135deg, #2a1408 0%, #3d1e10 100%);
}
.jb-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.45s ease;
}
.jb-card:hover .jb-card-img { transform: scale(1.08); }
.jb-card-no-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52px;
  background: linear-gradient(135deg, #2a1408, #4a2210);
}

/* Gold drip on card top */
.jb-card-img-wrap::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--jb-gold), var(--jb-gold2), var(--jb-gold), transparent);
  z-index: 2;
  opacity: 0;
  transition: opacity 0.2s;
}
.jb-card:hover .jb-card-img-wrap::before { opacity: 1; }

/* Wishlist */
.jb-wishlist {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 34px;
  height: 34px;
  background: rgba(0,0,0,0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  cursor: pointer;
  border: none;
  backdrop-filter: blur(6px);
  transition: all 0.2s;
  z-index: 3;
}
.jb-wishlist:hover { background: rgba(212,160,23,0.3); transform: scale(1.1); }

/* Badges */
.jb-card-badges {
  position: absolute;
  top: 10px;
  left: 10px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  z-index: 3;
}
.jb-badge {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 3px 9px;
  border-radius: 6px;
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.4px;
  backdrop-filter: blur(6px);
  text-transform: uppercase;
}
.jb-badge--hot      { background: rgba(192,120,48,0.9); color: #fff; }
.jb-badge--new      { background: rgba(76,175,106,0.9); color: #fff; }
.jb-badge--deal     { background: rgba(212,160,23,0.9); color: #000; }
.jb-badge--choco    { background: rgba(107,58,31,0.9); color: #F0C040; border: 1px solid rgba(212,160,23,0.3); }

/* Delivery badge */
.jb-card-delivery {
  position: absolute;
  bottom: 8px;
  left: 8px;
  background: rgba(0,0,0,0.72);
  color: #fff;
  font-size: 9.5px;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 8px;
  backdrop-filter: blur(4px);
  z-index: 3;
}

/* Body */
.jb-card-body {
  padding: 14px 14px 16px;
  display: flex;
  flex-direction: column;
  flex: 1;
  background: var(--jb-card);
}
.jb-card-type {
  font-size: 9.5px;
  font-weight: 700;
  color: var(--jb-gold);
  text-transform: uppercase;
  letter-spacing: 1.2px;
  margin-bottom: 5px;
}
.jb-card-name {
  font-family: var(--jb-heading);
  font-size: 16px;
  font-weight: 700;
  color: var(--jb-text);
  margin: 0 0 5px;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.jb-card-desc {
  font-size: 11.5px;
  color: var(--jb-text2);
  margin: 0 0 12px;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.jb-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-top: auto;
}
.jb-price-wrap { display: flex; flex-direction: column; gap: 1px; }
.jb-price {
  font-size: 16px;
  font-weight: 800;
  color: var(--jb-text);
}
.jb-price-compare {
  font-size: 11px;
  color: var(--jb-text3);
  text-decoration: line-through;
}
.jb-price-save {
  font-size: 9.5px;
  font-weight: 700;
  color: var(--jb-green);
  background: rgba(76,175,106,0.12);
  padding: 1px 6px;
  border-radius: 5px;
}

/* ══════════════════════════════════════════════════════
   6. ADD BUTTON + STEPPER
   ══════════════════════════════════════════════════════ */
.jb-add-btn {
  flex-shrink: 0;
  padding: 9px 16px;
  background: var(--jb-gold);
  color: #000;
  border: none;
  border-radius: 11px;
  font-size: 12px;
  font-weight: 800;
  font-family: var(--jb-body);
  cursor: pointer;
  transition: all 0.22s cubic-bezier(0.34,1.56,0.64,1);
  position: relative;
  overflow: hidden;
  white-space: nowrap;
  letter-spacing: 0.2px;
}
.jb-add-btn::before {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 100%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
  transition: left 0.4s ease;
}
.jb-add-btn:hover { background: var(--jb-gold2); transform: scale(1.05); }
.jb-add-btn:hover::before { left: 100%; }
.jb-add-btn:active { transform: scale(0.95); }
.jb-add-btn.loading { color: transparent !important; pointer-events: none; }
.jb-add-btn.loading::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 14px; height: 14px;
  margin: -7px 0 0 -7px;
  border: 2.5px solid rgba(0,0,0,0.2);
  border-top-color: #000;
  border-radius: 50%;
  animation: jb-spin 0.5s linear infinite;
}
.jb-add-btn.success { background: var(--jb-green) !important; color: #fff !important; pointer-events: none; animation: jb-pop 0.3s ease; }

.jb-stepper {
  display: none;
  align-items: center;
  border-radius: 11px;
  background: var(--jb-gold);
  overflow: hidden;
  flex-shrink: 0;
}
.jb-stepper.visible { display: flex; animation: jb-pop 0.28s cubic-bezier(0.34,1.56,0.64,1); }
.jb-stepper-btn {
  width: 32px; height: 32px;
  background: none; border: none;
  color: #000; font-size: 17px; font-weight: 700;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: background 0.15s;
  font-family: var(--jb-body);
}
.jb-stepper-btn:hover { background: rgba(0,0,0,0.12); }
.jb-stepper-btn:active { background: rgba(0,0,0,0.22); }
.jb-stepper-btn.busy { opacity: 0.4; pointer-events: none; }
.jb-stepper-qty {
  min-width: 24px; text-align: center;
  font-size: 13px; font-weight: 900; color: #000;
  font-family: var(--jb-body);
}

/* ══════════════════════════════════════════════════════
   7. TRUST SECTION
   ══════════════════════════════════════════════════════ */
/* ── Trust strip ──────────────────────────────────── */
.jb-trust {
  padding: 32px 14px 36px;
}
.jb-trust-label {
  text-align: center;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 1.6px;
  text-transform: uppercase;
  color: var(--jb-gold);
  margin-bottom: 18px;
  opacity: 0.75;
}
.jb-trust-inner {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
  max-width: 900px;
  margin: 0 auto;
}
.jb-trust-inner::-webkit-scrollbar { display: none; }
@media(min-width: 680px) {
  .jb-trust-inner { overflow-x: visible; display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
}
.jb-trust-item {
  flex-shrink: 0;
  width: 220px;
  scroll-snap-align: start;
  background: var(--jb-card);
  border: 1px solid var(--jb-border);
  border-radius: 20px;
  padding: 20px 18px 22px;
  position: relative;
  overflow: hidden;
  transition: transform 0.22s ease, box-shadow 0.22s ease;
}
@media(min-width: 680px) { .jb-trust-item { width: auto; } }
.jb-trust-item:hover { transform: translateY(-3px); box-shadow: var(--jb-shadow-lg); }
/* gold top bar */
.jb-trust-item::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  border-radius: 20px 20px 0 0;
}
.jb-trust-item:nth-child(1)::before { background: linear-gradient(90deg, var(--jb-choco), var(--jb-caramel)); }
.jb-trust-item:nth-child(2)::before { background: linear-gradient(90deg, var(--jb-gold), var(--jb-gold2)); }
.jb-trust-item:nth-child(3)::before { background: linear-gradient(90deg, var(--jb-caramel), var(--jb-gold)); }
/* subtle bg glow */
.jb-trust-item::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(212,160,23,0.05) 0%, transparent 65%);
  pointer-events: none;
}
.jb-trust-icon {
  font-size: 32px;
  margin-bottom: 12px;
  display: block;
  line-height: 1;
}
.jb-trust-stat {
  font-family: var(--jb-heading);
  font-size: 28px;
  font-weight: 900;
  background: linear-gradient(120deg, var(--jb-caramel), var(--jb-gold));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 2px;
  line-height: 1;
}
.jb-trust-title {
  font-family: var(--jb-heading);
  font-size: 15px;
  font-weight: 700;
  color: var(--jb-text);
  margin: 0 0 6px;
  -webkit-text-fill-color: var(--jb-text);
}
.jb-trust-desc {
  font-size: 12px;
  color: var(--jb-text2);
  margin: 0;
  line-height: 1.55;
}

/* ══════════════════════════════════════════════════════
   8. CAKE MESSAGE
   ══════════════════════════════════════════════════════ */
.jb-msg-section {
  max-width: 580px;
  margin: 36px auto;
  padding: 28px 24px;
  background: var(--jb-surface);
  border-radius: 22px;
  border: 1px solid var(--jb-border);
  box-shadow: var(--jb-shadow);
  text-align: center;
}
.jb-msg-icon { font-size: 38px; margin-bottom: 10px; animation: jb-float 4s ease-in-out infinite; display: block; }
.jb-msg-title { font-family: var(--jb-heading); font-size: 22px; font-weight: 700; color: var(--jb-text); margin: 0 0 6px; }
.jb-msg-sub   { font-size: 13px; color: var(--jb-text2); margin: 0 0 18px; }
.jb-msg-input {
  width: 100%;
  padding: 13px 18px;
  background: var(--jb-card);
  border: 1.5px solid var(--jb-border);
  border-radius: 13px;
  font-size: 15px;
  font-family: var(--jb-body);
  color: var(--jb-text);
  transition: border-color 0.2s, box-shadow 0.2s;
  text-align: center;
  margin-bottom: 10px;
  -webkit-text-fill-color: var(--jb-text);
}
.jb-msg-input::placeholder { color: var(--jb-text3); font-style: italic; opacity: 1; -webkit-text-fill-color: var(--jb-text3); }
.jb-msg-input:focus { outline: none; border-color: var(--jb-gold); box-shadow: 0 0 0 3px rgba(212,160,23,0.18); }
html[data-theme="dark"] .jb-msg-input { background: #2a1a0a; color: #f5e6cc; -webkit-text-fill-color: #f5e6cc; border-color: rgba(212,160,23,0.22); }
html[data-theme="dark"] .jb-msg-input::placeholder { color: #7a5535; -webkit-text-fill-color: #7a5535; }

/* Live message preview */
.jb-msg-preview {
  display: none;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin: 0 0 16px;
  padding: 10px 18px;
  background: rgba(212,160,23,0.08);
  border: 1px dashed rgba(212,160,23,0.35);
  border-radius: 12px;
  animation: jb-fadein 0.25s ease;
}
.jb-msg-preview.show { display: flex; }
.jb-msg-preview-label { font-size: 11px; font-weight: 700; color: var(--jb-text3); text-transform: uppercase; letter-spacing: 0.8px; flex-shrink: 0; }
.jb-msg-preview-text {
  font-family: var(--jb-heading);
  font-size: 17px;
  font-weight: 700;
  font-style: italic;
  background: linear-gradient(120deg, var(--jb-caramel), var(--jb-gold), var(--jb-gold2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 0.3px;
}
.jb-msg-char  { font-size: 11px; color: var(--jb-text3); margin-bottom: 14px; }
.jb-msg-btn {
  padding: 12px 32px;
  background: linear-gradient(135deg, var(--jb-caramel), var(--jb-gold));
  color: #000;
  border: none;
  border-radius: 13px;
  font-size: 14px;
  font-weight: 800;
  font-family: var(--jb-body);
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 4px 16px rgba(212,160,23,0.3);
}
.jb-msg-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(212,160,23,0.45); }
.jb-msg-saved {
  display: none;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 600;
  color: var(--jb-green);
  margin-top: 10px;
}
.jb-msg-saved.show { display: flex; animation: jb-pop 0.3s ease; }

/* ══════════════════════════════════════════════════════
   9. UPSELL SLIDER
   ══════════════════════════════════════════════════════ */
.jb-upsell {
  padding: 36px 14px 56px;
  max-width: 1100px;
  margin: 0 auto;
}
.jb-upsell-title { font-family: var(--jb-heading); font-size: 26px; font-weight: 700; color: var(--jb-text); margin: 0 0 18px; }
.jb-upsell-title em { font-style: italic; color: var(--jb-gold2); }
.jb-upsell-outer { overflow-x: auto; padding-bottom: 8px; scrollbar-width: none; cursor: grab; }
.jb-upsell-outer::-webkit-scrollbar { display: none; }
.jb-upsell-outer:active { cursor: grabbing; }
.jb-upsell-track { display: flex; gap: 14px; padding: 4px 0; }
.jb-upsell-card {
  flex-shrink: 0;
  width: 160px;
  background: var(--jb-card);
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid var(--jb-border2);
  box-shadow: var(--jb-shadow);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  cursor: pointer;
}
.jb-upsell-card:hover { transform: translateY(-5px); box-shadow: var(--jb-shadow-lg); }
.jb-upsell-img { aspect-ratio: 1; overflow: hidden; background: var(--jb-surface); display: flex; align-items: center; justify-content: center; }
.jb-upsell-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s ease; }
.jb-upsell-card:hover .jb-upsell-img img { transform: scale(1.08); }
.jb-upsell-no-img { font-size: 34px; }
.jb-upsell-body { padding: 9px 11px 11px; }
.jb-upsell-name { font-family: var(--jb-heading); font-size: 13px; font-weight: 700; color: var(--jb-text); margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.jb-upsell-price { font-size: 12.5px; font-weight: 800; color: var(--jb-gold); }
.jb-upsell-add {
  width: 100%;
  padding: 8px;
  background: rgba(212,160,23,0.12);
  border: none;
  color: var(--jb-gold2);
  font-size: 12px;
  font-weight: 700;
  font-family: var(--jb-body);
  cursor: pointer;
  transition: all 0.2s;
}
.jb-upsell-add:hover { background: var(--jb-gold); color: #000; }

/* ── Toast ─────────────────────────────────────────── */
.jb-toast {
  position: fixed;
  bottom: calc(145px + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  background: var(--jb-green);
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  font-family: var(--jb-body);
  padding: 10px 22px;
  border-radius: 24px;
  z-index: 9999;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.22s;
  white-space: nowrap;
  box-shadow: 0 4px 16px rgba(76,175,106,0.4);
}
.jb-toast.show { opacity: 1; }

/* ══════════════════════════════════════════════════════
   10. FOUNDER SECTION
   ══════════════════════════════════════════════════════ */
.jb-founder {
  padding: 12px 14px 48px;
}
.jb-founder-inner {
  max-width: 700px;
  margin: 0 auto;
}
.jb-founder-eyebrow {
  text-align: center;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1.4px;
  text-transform: uppercase;
  color: var(--jb-gold);
  margin-bottom: 20px;
  opacity: 0.85;
}
.jb-founder-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28px;
  background: var(--jb-card);
  border: 1px solid var(--jb-border);
  border-radius: 24px;
  padding: 32px 24px 28px;
  box-shadow: var(--jb-shadow-lg);
  position: relative;
  overflow: hidden;
  text-align: center;
}
.jb-founder-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--jb-choco), var(--jb-caramel), var(--jb-gold), var(--jb-caramel), var(--jb-choco));
}
.jb-founder-card::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(212,160,23,0.07) 0%, transparent 65%);
  pointer-events: none;
}
@media(min-width: 560px) {
  .jb-founder-card {
    flex-direction: row;
    text-align: left;
    align-items: flex-start;
    gap: 32px;
    padding: 36px 32px 32px;
  }
}

/* Avatar */
.jb-founder-avatar-wrap {
  position: relative;
  flex-shrink: 0;
  width: 100px;
  height: 100px;
}
@media(min-width:560px){ .jb-founder-avatar-wrap { width: 120px; height: 120px; } }
.jb-founder-avatar {
  width: 100%; height: 100%;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--jb-choco), var(--jb-caramel));
  display: flex; align-items: center; justify-content: center;
  font-size: 46px;
  position: relative; z-index: 2;
  box-shadow: 0 6px 24px rgba(0,0,0,0.35);
}
@media(min-width:560px){ .jb-founder-avatar { font-size: 54px; } }
.jb-founder-avatar-ring {
  position: absolute; inset: -4px;
  border-radius: 50%;
  border: 2px solid transparent;
  background: linear-gradient(var(--jb-card), var(--jb-card)) padding-box,
              linear-gradient(135deg, var(--jb-gold), var(--jb-caramel), var(--jb-gold)) border-box;
  z-index: 1;
}
.jb-founder-avatar-glow {
  position: absolute; inset: -12px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212,160,23,0.20) 0%, transparent 70%);
  animation: jb-glow 3s ease-in-out infinite;
  z-index: 0;
}

/* Body */
.jb-founder-body { flex: 1; min-width: 0; }
.jb-founder-role {
  font-size: 10.5px;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--jb-gold);
  margin-bottom: 6px;
}
.jb-founder-name {
  font-family: var(--jb-heading);
  font-size: clamp(22px, 5vw, 32px);
  font-weight: 900;
  color: var(--jb-text);
  margin: 0 0 12px;
  line-height: 1.15;
  letter-spacing: -0.3px;
}
.jb-founder-name em {
  font-style: italic;
  background: linear-gradient(120deg, var(--jb-caramel), var(--jb-gold), var(--jb-gold2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.jb-founder-divider {
  width: 40px; height: 2px;
  background: linear-gradient(to right, var(--jb-gold), var(--jb-caramel));
  border-radius: 2px;
  margin: 0 auto 14px;
}
@media(min-width:560px){ .jb-founder-divider { margin: 0 0 14px; } }
.jb-founder-quote {
  font-size: 13px;
  color: var(--jb-text2);
  line-height: 1.7;
  font-style: italic;
  margin: 0 0 18px;
  padding: 12px 16px;
  background: rgba(212,160,23,0.05);
  border-left: 3px solid var(--jb-gold);
  border-radius: 0 10px 10px 0;
}
@media(min-width:560px){ .jb-founder-quote { text-align: left; } }

/* Stats */
.jb-founder-stats {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 16px;
  justify-content: center;
}
@media(min-width:560px){ .jb-founder-stats { justify-content: flex-start; } }
.jb-founder-stat {
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  padding: 0 16px;
}
.jb-founder-stat:first-child { padding-left: 0; }
.jb-founder-stat-num {
  font-family: var(--jb-heading);
  font-size: 17px; font-weight: 800;
  color: var(--jb-gold2);
}
.jb-founder-stat-label {
  font-size: 9.5px; font-weight: 600;
  color: var(--jb-text3);
  text-transform: uppercase; letter-spacing: 0.6px;
}
.jb-founder-stat-sep {
  width: 1px; height: 28px;
  background: var(--jb-border);
  flex-shrink: 0;
}

/* Tags */
.jb-founder-tags {
  display: flex; flex-wrap: wrap; gap: 6px;
  justify-content: center;
}
@media(min-width:560px){ .jb-founder-tags { justify-content: flex-start; } }
.jb-founder-tags span {
  font-size: 10.5px; font-weight: 700;
  padding: 4px 11px;
  background: rgba(212,160,23,0.08);
  border: 1px solid rgba(212,160,23,0.2);
  border-radius: 999px;
  color: var(--jb-text2);
}

/* Signature bottom */
.jb-founder-sig {
  display: flex; align-items: center; gap: 14px;
  margin-top: 24px;
}
.jb-founder-sig-line {
  flex: 1; height: 1px;
  background: linear-gradient(to right, transparent, var(--jb-border), transparent);
}
.jb-founder-sig-text {
  font-size: 11px; font-weight: 600;
  color: var(--jb-text3);
  white-space: nowrap;
}

/* Light mode overrides for founder */
html:not([data-theme="dark"]) .jb-founder-card {
  background: #fff;
  border-color: rgba(160,80,20,0.12);
  box-shadow: 0 4px 24px rgba(100,40,0,0.10);
}
html:not([data-theme="dark"]) .jb-founder-quote {
  background: rgba(184,134,11,0.06);
  border-left-color: var(--jb-gold);
}
html:not([data-theme="dark"]) .jb-founder-avatar-ring {
  background: linear-gradient(#fff, #fff) padding-box,
              linear-gradient(135deg, var(--jb-gold), var(--jb-caramel), var(--jb-gold)) border-box;
}

/* ══════════════════════════════════════════════════════
   LIGHT THEME OVERRIDES
   ══════════════════════════════════════════════════════ */
html:not([data-theme="dark"]) .jb-pills-outer {
  background: var(--jb-bg2);
  border-bottom: 1px solid var(--jb-border);
}
html:not([data-theme="dark"]) .jb-pill {
  background: #fff;
  border-color: var(--jb-border);
  color: var(--jb-text2);
}
html:not([data-theme="dark"]) .jb-pill.active {
