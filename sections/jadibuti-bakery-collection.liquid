<script>
(function () {
  'use strict';
  var jbCart = {}, jbPrices = {}, toastTimer = null;

  try {
    JSON.parse(document.getElementById('jbProductData').textContent)
      .forEach(function(p){ jbPrices[p.id] = p.price; });
  } catch(e){}

  fetch('/cart.js',{headers:{'X-Requested-With':'XMLHttpRequest'}})
    .then(function(r){return r.json();})
    .then(function(cart){
      cart.items.forEach(function(item){
        jbCart[item.variant_id] = item.quantity;
        if(!jbPrices[item.variant_id]) jbPrices[item.variant_id] = item.price;
      });
      Object.keys(jbCart).forEach(function(v){ renderVid(parseInt(v,10)); });
    }).catch(function(){});

  function renderVid(vid){
    var qty = jbCart[vid] || 0;
    document.querySelectorAll('.jb-add-btn[data-vid="'+vid+'"]').forEach(function(btn){
      if(qty>0){btn.style.display='none';}
      else{btn.style.display='';btn.classList.remove('loading','success');btn.removeAttribute('disabled');btn.textContent='Add +';}
    });
    document.querySelectorAll('.jb-stepper[data-vid="'+vid+'"]').forEach(function(s){
      if(qty>0){s.classList.add('visible');}else{s.classList.remove('visible');}
    });
    document.querySelectorAll('.jb-stepper-qty[data-vid="'+vid+'"]').forEach(function(c){c.textContent=qty;});
  }

  function jbAdd(vid, qty, btn){
    if(btn){btn.classList.add('loading');btn.setAttribute('disabled',true);}
    fetch('/cart/add.js',{
      method:'POST',
      headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
      body:JSON.stringify({id:parseInt(vid,10),quantity:qty})
    }).then(function(r){return r.json();})
    .then(function(){
      jbCart[vid]=(jbCart[vid]||0)+qty;
      if(btn){btn.classList.remove('loading');btn.classList.add('success');btn.textContent='✓';
        setTimeout(function(){renderVid(vid);showToast('Added to cart 🍫');},300);
      } else {renderVid(vid);showToast('Added ✓');}
    }).catch(function(){
      if(btn){btn.classList.remove('loading');btn.removeAttribute('disabled');btn.textContent='Add +';}
    });
  }

  function jbChange(vid, newQty, btn){
    if(btn) btn.classList.add('busy');
    fetch('/cart/change.js',{
      method:'POST',
      headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
      body:JSON.stringify({id:parseInt(vid,10),quantity:newQty})
    }).then(function(r){return r.json();})
    .then(function(){
      if(newQty<=0){delete jbCart[vid];}else{jbCart[vid]=newQty;}
      if(btn) btn.classList.remove('busy');
      renderVid(vid);
    }).catch(function(){if(btn) btn.classList.remove('busy');});
  }

  function showToast(msg){
    var t=document.getElementById('jbToast');
    if(!t) return;
    t.textContent=msg;t.classList.add('show');
    if(toastTimer) clearTimeout(toastTimer);
    toastTimer=setTimeout(function(){t.classList.remove('show');},2000);
  }

  /* Event delegation — cards */
  var content=document.getElementById('jbContent');
  if(content){
    content.addEventListener('click',function(e){
      var t=e.target;
      if(t.classList.contains('jb-add-btn')&&!t.classList.contains('loading')&&!t.classList.contains('success')){
        jbAdd(parseInt(t.getAttribute('data-vid'),10),1,t);
      }
      if(t.classList.contains('jb-stepper-minus')&&!t.classList.contains('busy')){
        var v=parseInt(t.getAttribute('data-vid'),10);
        jbChange(v,Math.max(0,(jbCart[v]||0)-1),t);
      }
      if(t.classList.contains('jb-stepper-plus')&&!t.classList.contains('busy')){
        var v2=parseInt(t.getAttribute('data-vid'),10);
        jbChange(v2,(jbCart[v2]||0)+1,t);
      }
      if(t.classList.contains('jb-wishlist')){
        t.textContent=t.textContent==='🤍'?'❤️':'🤍';
      }
    });
  }

  /* Upsell */
  var upsell=document.getElementById('jbUpsell');
  if(upsell){
    upsell.addEventListener('click',function(e){
      var btn=e.target.closest('.jb-upsell-add');
      if(btn){
        var vid=parseInt(btn.getAttribute('data-vid'),10);
        jbAdd(vid,1,null);
        btn.textContent='✓ Added';
        btn.style.background='var(--jb-green)';
        btn.style.color='#fff';
      }
    });
    var outer=document.getElementById('jbUpsellOuter');
    if(outer){
      var isDown=false,startX,scrollLeft;
      outer.addEventListener('mousedown',function(e){isDown=true;startX=e.pageX-outer.offsetLeft;scrollLeft=outer.scrollLeft;});
      outer.addEventListener('mouseleave',function(){isDown=false;});
      outer.addEventListener('mouseup',function(){isDown=false;});
      outer.addEventListener('mousemove',function(e){if(!isDown)return;e.preventDefault();outer.scrollLeft=scrollLeft-(e.pageX-outer.offsetLeft-startX);});
    }
  }

  /* Pills */
  var pillsWrap=document.getElementById('jbPills');
  if(pillsWrap){
    pillsWrap.addEventListener('click',function(e){
      var pill=e.target.closest('.jb-pill');
      if(!pill) return;
      document.querySelectorAll('.jb-pill').forEach(function(p){p.classList.remove('active');});
      pill.classList.add('active');
      var target=pill.getAttribute('data-target');
      if(target==='all'){
        document.querySelectorAll('.jb-sec').forEach(function(s){s.classList.remove('jb-hidden-sec');});
      } else {
        document.querySelectorAll('.jb-sec').forEach(function(s){s.classList.add('jb-hidden-sec');});
        var sec=document.getElementById('jb-sec-'+target);
        if(sec){sec.classList.remove('jb-hidden-sec');setTimeout(function(){sec.scrollIntoView({behavior:'smooth',block:'start'});},60);}
      }
    });
  }

  /* Cake message */
  var msgInput=document.getElementById('jbCakeMsg');
  var msgChar=document.getElementById('jbMsgChar');
  var msgBtn=document.getElementById('jbSaveMsgBtn');
  var msgSaved=document.getElementById('jbMsgSaved');
  var msgPreview=document.getElementById('jbMsgPreview');
  var msgPreviewText=document.getElementById('jbMsgPreviewText');
  if(msgInput){
    msgInput.addEventListener('input',function(){
      var val=msgInput.value;
      var len=val.length;
      if(msgChar) msgChar.textContent=len+' / 40 characters';
      if(msgSaved) msgSaved.classList.remove('show');
      if(msgPreviewText) msgPreviewText.textContent=val;
      if(msgPreview){
        if(val.length>0){ msgPreview.classList.add('show'); }
        else { msgPreview.classList.remove('show'); }
      }
    });
  }
  if(msgBtn){
    msgBtn.addEventListener('click',function(){
      var msg=msgInput?msgInput.value.trim():'';
      if(!msg){if(msgInput) msgInput.focus();return;}
      fetch('/cart/update.js',{
        method:'POST',
        headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
        body:JSON.stringify({note:'🍫 Cake Message: '+msg})
      }).then(function(){
        if(msgSaved) msgSaved.classList.add('show');
        showToast('Cake message saved! 🎀');
      }).catch(function(){if(msgSaved) msgSaved.classList.add('show');});
    });
  }
})();
</script>

