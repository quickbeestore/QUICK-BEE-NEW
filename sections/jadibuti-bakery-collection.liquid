  background: #fff;
}
html:not([data-theme="dark"]) .jb-sec-head {
  border-bottom-color: var(--jb-border);
}
html:not([data-theme="dark"]) .jb-trust-item {
  background: #fff;
  border-color: rgba(160,80,20,0.10);
  box-shadow: 0 2px 14px rgba(100,40,0,0.07);
}
html:not([data-theme="dark"]) .jb-trust-title {
  -webkit-text-fill-color: var(--jb-text);
}
html:not([data-theme="dark"]) .jb-msg-section {
  background: #fff;
  border-color: var(--jb-border);
}
html:not([data-theme="dark"]) .jb-msg-input {
  background: var(--jb-surface);
  border-color: var(--jb-border);
  color: var(--jb-text);
  -webkit-text-fill-color: var(--jb-text);
}
html:not([data-theme="dark"]) .jb-upsell-card {
  background: #fff;
  border-color: rgba(160,80,20,0.10);
  box-shadow: 0 2px 8px rgba(100,40,0,0.08);
}
html:not([data-theme="dark"]) .jb-hero-pill {
  background: rgba(255,255,255,0.15);
  border-color: rgba(255,220,150,0.35);
  color: #FFE0A0;
}
html:not([data-theme="dark"]) .jb-add-btn {
  background: var(--jb-gold);
  color: #fff;
}
html:not([data-theme="dark"]) .jb-add-btn:hover {
  background: var(--jb-caramel);
}

/* ── Empty / hidden ────────────────────────────────── */
.jb-empty { padding: 64px 24px; text-align: center; }
.jb-empty-icon { font-size: 64px; margin-bottom: 14px; animation: jb-float 3s ease-in-out infinite; }
.jb-empty-title { font-family: var(--jb-heading); font-size: 24px; font-weight: 700; color: var(--jb-text); margin: 0 0 8px; }
.jb-empty-sub { font-size: 14px; color: var(--jb-text2); margin: 0; }
.jb-card.jb-hidden { display: none !important; }
.jb-sec.jb-hidden-sec { display: none !important; }
</style>

<!-- ════════════════════════════════════════════════════
     JADIBUTI BAKERY COLLECTION PAGE
     ════════════════════════════════════════════════════ -->
<div class="jb-wrap" id="jbWrap">

  <!-- Hero -->
  <div class="jb-hero">
    <div class="jb-drip-bar"></div>
    <div class="jb-hero-orb jb-hero-orb--1"></div>
    <div class="jb-hero-orb jb-hero-orb--2"></div>
    <div class="jb-hero-orb jb-hero-orb--3"></div>
    <span class="jb-particle" style="left:4%;top:20%;--fd:10s;--fdl:0s">🍫</span>
    <span class="jb-particle" style="right:6%;top:18%;--fd:8s;--fdl:1.5s">🎂</span>
    <span class="jb-particle" style="left:14%;bottom:28%;--fd:12s;--fdl:3s">🌹</span>
    <span class="jb-particle" style="right:12%;bottom:32%;--fd:9s;--fdl:0.8s">🍰</span>
    <span class="jb-particle" style="left:3%;bottom:45%;--fd:11s;--fdl:2s">✨</span>
    <span class="jb-particle" style="right:3%;top:45%;--fd:13s;--fdl:4s">🎀</span>

