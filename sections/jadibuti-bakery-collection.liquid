      <p class="jb-hero-tagline">Handcrafted chocolate cakes & artisan pastries, baked fresh daily</p>
      <div class="jb-hero-pills">
        <span class="jb-hero-pill">⚡ <b>Same-Day</b> delivery</span>
        <span class="jb-hero-pill">🍫 <b>Premium</b> chocolate</span>
        <span class="jb-hero-pill">🎨 <b>Custom</b> orders</span>
      </div>
    </div>

    <div class="jb-hero-wave">
      <svg viewBox="0 0 1440 52" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,52 C240,20 480,4 720,20 C960,36 1200,52 1440,28 L1440,52 Z" fill="var(--jb-bg)"/>
      </svg>
    </div>
  </div>

  <!-- Marquee strip -->
  <div class="jb-strip">
    <span class="jb-strip-text">🍫 Handcrafted Cakes</span>
    <span class="jb-strip-dot"></span>
    <span class="jb-strip-text">Premium Belgian Chocolate</span>
    <span class="jb-strip-dot"></span>
    <span class="jb-strip-text">🎂 Custom Orders Welcome</span>
    <span class="jb-strip-dot"></span>
    <span class="jb-strip-text">⚡ Same-Day Delivery</span>
    <span class="jb-strip-dot"></span>
    <span class="jb-strip-text">🌹 Fresh Baked Daily</span>
  </div>

  <!-- Category Pills -->
  <div class="jb-pills-outer">
    <div class="jb-pills" id="jbPills">
      <button class="jb-pill active" data-target="all">🍫 All <small>({{ all_products.size }})</small></button>
