  border-color: var(--jb-gold);
  color: #fff;
  box-shadow: 0 3px 12px rgba(184,134,11,0.3);
}
html:not([data-theme="dark"]) .jb-card {
  background: #fff;
  border-color: rgba(160,80,20,0.10);
  box-shadow: 0 2px 10px rgba(100,40,0,0.08);
}
html:not([data-theme="dark"]) .jb-card:hover {
  border-color: var(--jb-gold);
  box-shadow: 0 6px 24px rgba(184,134,11,0.18);
}
