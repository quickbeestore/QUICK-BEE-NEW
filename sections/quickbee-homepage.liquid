.qb-brands-track-wrap::before { left:0; background:linear-gradient(90deg,var(--theme-bg-primary),transparent); }
.qb-brands-track-wrap::after  { right:0; background:linear-gradient(270deg,var(--theme-bg-primary),transparent); }
.qb-brands-track {
  display: flex; align-items: center; gap: 8px;
  width: max-content;
  animation: brandScroll 28s linear infinite;
}
.qb-brands-track:hover { animation-play-state: paused; }
@keyframes brandScroll { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.qb-brand-item {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 16px; border-radius: 40px; white-space: nowrap;
  background: var(--theme-bg-secondary);
  border: 1px solid rgba(244,180,0,0.1);
  font-size: 12px; font-weight: 700; color: var(--theme-text-muted);
  transition: border-color .2s;
  flex-shrink: 0;
}
.qb-brand-item:hover { border-color: rgba(244,180,0,0.35); }
.qb-brand-ico {
  width: 28px; height: 28px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; flex-shrink: 0;
}

/* ══════════════════════════════════════════════════════
   ⏳ FLASH DEAL COUNTDOWN
══════════════════════════════════════════════════════ */
.qb-flash-wrap { padding: 12px 12px 0; }
.qb-flash-card {
  border-radius: 22px; overflow: hidden; position: relative;
  padding: 28px 22px;
  background: linear-gradient(135deg, #1a0500 0%, #2d0800 40%, #1a0305 100%);
  border: 1.5px solid rgba(229,57,53,0.3);
  box-shadow: 0 12px 48px rgba(229,57,53,0.2), inset 0 0 60px rgba(229,57,53,0.04);
  display: flex; align-items: center; justify-content: space-between;
  gap: 20px; flex-wrap: wrap;
}
.qb-flash-fire {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 60px; pointer-events: none; overflow: hidden;
}
.qb-flash-fire span {
  position: absolute; bottom: -8px; left: var(--x);
  font-size: 20px; opacity: 0.35;
  animation: fireRise var(--d) ease-in-out infinite var(--dl);
}
@keyframes fireRise {
  0%,100%{transform:translateY(0) scale(1);opacity:0.35}
  50%{transform:translateY(-20px) scale(1.2);opacity:0.6}
}
.qb-flash-badge {
  display: inline-flex; align-items: center; gap: 5px;
  background: rgba(229,57,53,0.2); border: 1px solid rgba(229,57,53,0.5);
  color: #ff6b6b; font-size: 10px; font-weight: 900;
  padding: 4px 10px; border-radius: 20px; letter-spacing: 1px;
  text-transform: uppercase; margin-bottom: 10px;
  animation: flashBadgePulse 1.8s ease-in-out infinite;
}
@keyframes flashBadgePulse { 0%,100%{opacity:1} 50%{opacity:0.6} }
.qb-flash-title {
  font-size: 28px; font-weight: 900; color: #fff;
  letter-spacing: -0.5px; line-height: 1.1; margin-bottom: 6px;
}
.qb-flash-sub { font-size: 13px; color: rgba(255,255,255,0.55); margin-bottom: 18px; }
.qb-flash-btn {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 12px 22px; border-radius: 12px; text-decoration: none;
  background: linear-gradient(135deg,#E53935,#b71c1c);
  color: #fff; font-size: 14px; font-weight: 900;
  box-shadow: 0 4px 20px rgba(229,57,53,0.5);
  transition: transform .15s, box-shadow .15s;
}
.qb-flash-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(229,57,53,0.65); }
.qb-flash-right { text-align: center; }
.qb-flash-label { font-size: 11px; color: rgba(255,255,255,0.4); font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
.qb-flash-clock {
  display: flex; align-items: center; gap: 6px;
}
.qb-clock-unit {
  display: flex; flex-direction: column; align-items: center;
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px; padding: 10px 14px; min-width: 58px;
}
.qb-clock-unit span {
  font-size: 28px; font-weight: 900; color: #fff;
  line-height: 1; font-variant-numeric: tabular-nums;
  font-family: 'SF Mono', 'Monaco', monospace;
}
.qb-clock-unit small { font-size: 9px; color: rgba(255,255,255,0.35); font-weight: 700; text-transform: uppercase; margin-top: 3px; letter-spacing: 0.8px; }
.qb-clock-colon { font-size: 24px; font-weight: 900; color: rgba(229,57,53,0.7); animation: colonBlink 1s step-end infinite; }
@keyframes colonBlink { 0%,100%{opacity:1} 50%{opacity:0.1} }
.qb-flash-emoji-stack { font-size: 22px; margin-top: 14px; letter-spacing: 3px; }

/* ══════════════════════════════════════════════════════
   📰 BLOG STRIP
══════════════════════════════════════════════════════ */
.qb-blogstrip-section { padding: 24px 16px 8px; max-width: 1200px; margin: 0 auto; }
.qb-blogstrip-header {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 12px; margin-bottom: 16px; flex-wrap: wrap;
}
.qb-blogstrip-title { font-size: 20px; font-weight: 900; color: var(--theme-text-main); margin-bottom: 3px; }
.qb-blogstrip-sub { font-size: 12px; color: var(--theme-text-muted); }
.qb-blogstrip-grid {
  display: grid; grid-template-columns: 1fr;
  gap: 14px;
}
@media(min-width:600px){ .qb-blogstrip-grid { grid-template-columns: repeat(3,1fr); } }
.qb-bpost-card {
  display: flex; flex-direction: column;
  text-decoration: none; border-radius: 16px; overflow: hidden;
  background: var(--theme-bg-secondary);
  border: 1px solid rgba(244,180,0,0.1);
  transition: transform .2s, box-shadow .2s, border-color .2s;
}
.qb-bpost-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.15); border-color: rgba(244,180,0,0.3); }
.qb-bpost-img { height: 160px; overflow: hidden; position: relative; background: #1a1a1a; }
html:not([data-theme="dark"]) .qb-bpost-img { background: #f0f0f0; }
.qb-bpost-img img { width:100%;height:100%;object-fit:cover;display:block;transition:transform .35s; }
.qb-bpost-card:hover .qb-bpost-img img { transform: scale(1.06); }
.qb-bpost-no-img { width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:48px; }
.qb-bpost-tag {
  position:absolute;top:8px;left:8px;
  background:var(--qb-gold,#F4B400);color:#000;
  font-size:9px;font-weight:900;padding:3px 8px;border-radius:6px;
  text-transform:uppercase;letter-spacing:0.5px;
}
.qb-bpost-body { padding: 14px; flex: 1; }
.qb-bpost-title {
  font-size: 14px; font-weight: 800; color: var(--theme-text-main);
  line-height: 1.4; margin-bottom: 8px;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;
}
.qb-bpost-meta { font-size: 11px; color: var(--theme-text-muted); display:flex;gap:5px; }

/* ══════════════════════════════════════════════════════
   📱 APP TEASER + DELIVERY ZONE DUAL CARD
══════════════════════════════════════════════════════ */
.qb-bottom-duo {
  display: grid; grid-template-columns: 1fr;
  gap: 12px; padding: 12px 12px 16px;
  max-width: 1200px; margin: 0 auto;
}
@media(min-width:768px){ .qb-bottom-duo { grid-template-columns: 1fr 1fr; } }

/* App card */
.qb-app-card {
  border-radius: 22px; overflow: hidden; position: relative;
  padding: 28px 22px;
  background: linear-gradient(135deg, #080415 0%, #130a2e 50%, #0d0820 100%);
  border: 1.5px solid rgba(130,80,255,0.25);
  box-shadow: 0 12px 40px rgba(130,80,255,0.15);
  display: flex; gap: 16px; align-items: center;
  min-height: 240px;
}
.qb-app-orb {
  position: absolute; top: -40px; right: -40px;
  width: 200px; height: 200px; border-radius: 50%;
  background: radial-gradient(circle, rgba(130,80,255,0.18) 0%, transparent 70%);
  pointer-events: none;
}
.qb-app-content { flex: 1; min-width: 0; position: relative; z-index: 1; }
.qb-app-badge {
  display: inline-block; background: rgba(130,80,255,0.2); border: 1px solid rgba(130,80,255,0.4);
  color: #a878ff; font-size: 10px; font-weight: 900; padding: 3px 10px; border-radius: 20px;
  text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 10px;
}
.qb-app-title { font-size: 22px; font-weight: 900; color: #fff; margin-bottom: 6px; letter-spacing: -0.3px; }
.qb-app-sub { font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 16px; }
.qb-app-btns { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
.qb-app-store-btn {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 14px; border-radius: 10px;
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.7); font-size: 12px; font-weight: 700;
  cursor: not-allowed; opacity: 0.6;
}
/* Notify form */
.qb-notify-form { width: 100%; }
.qb-notify-row {
  display: flex; gap: 0; border-radius: 12px; overflow: hidden;
  border: 1.5px solid rgba(130,80,255,0.4);
  background: rgba(255,255,255,0.06);
  margin-bottom: 8px;
  transition: border-color .2s;
}
.qb-notify-row:focus-within { border-color: rgba(130,80,255,0.9); box-shadow: 0 0 0 3px rgba(130,80,255,0.2); }
.qb-notify-input {
  flex: 1; padding: 11px 14px;
  background: transparent; border: none; outline: none;
  font-size: 13px; font-weight: 500; color: #fff;
  min-width: 0;
}
.qb-notify-input::placeholder { color: rgba(255,255,255,0.3); }
.qb-notify-btn {
  flex-shrink: 0; padding: 11px 16px;
  background: linear-gradient(135deg, #8250ff, #6030d0);
  color: #fff; font-size: 13px; font-weight: 800;
  border: none; cursor: pointer; white-space: nowrap;
  display: flex; align-items: center; justify-content: center; gap: 6px;
  transition: opacity .18s;
}
.qb-notify-btn:hover { opacity: 0.9; }
.qb-notify-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.qb-notify-btn-loading svg { animation: notifySpin .8s linear infinite; }
@keyframes notifySpin { to { transform: rotate(360deg); } }
.qb-notify-hint { font-size: 10px; color: rgba(255,255,255,0.3); font-weight: 500; }
.qb-notify-success {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px; border-radius: 12px;
  background: rgba(34,197,94,0.12); border: 1.5px solid rgba(34,197,94,0.3);
  animation: notifySuccessIn .4s ease;
}
@keyframes notifySuccessIn { from{opacity:0;transform:scale(0.95)} to{opacity:1;transform:scale(1)} }
.qb-notify-success-icon { font-size: 22px; flex-shrink: 0; }
.qb-notify-success-title { font-size: 13px; font-weight: 800; color: #22c55e; }
.qb-notify-success-sub { font-size: 11px; color: rgba(255,255,255,0.45); margin-top: 2px; }

/* CSS Phone mockup */
.qb-phone-mock {
  flex-shrink: 0; position: relative; z-index: 1;
  width: 80px;
}
.qb-phone-screen {
  width: 80px; height: 144px; border-radius: 18px;
  background: linear-gradient(180deg, #1a1a2e, #0d0d1a);
  border: 2px solid rgba(130,80,255,0.4);
  box-shadow: 0 8px 32px rgba(130,80,255,0.3), 0 0 0 1px rgba(255,255,255,0.05);
  overflow: hidden; position: relative;
  display: flex; flex-direction: column; align-items: center;
  padding: 10px 6px 8px;
  animation: phonefloat 4s ease-in-out infinite;
}
@keyframes phonefloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
.qb-phone-notch {
  width: 28px; height: 5px; border-radius: 3px;
  background: rgba(255,255,255,0.2); margin-bottom: 8px; flex-shrink: 0;
}
.qb-phone-content { display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;width:100%; }
.qb-phone-logo { font-size: 20px; }
.qb-phone-text { font-size: 8px; font-weight: 900; color: #F4B400; letter-spacing: 0.5px; }
.qb-phone-bar { height: 5px; border-radius: 3px; background: rgba(130,80,255,0.4); width: 85%; }
.qb-phone-bar-sm { width: 55%; background: rgba(130,80,255,0.2); }
.qb-phone-items { display:flex; gap:4px; justify-content:center; margin-top:4px; }
.qb-phone-item { width: 20px;height:20px;border-radius:6px;background:rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;font-size:10px; }

/* Delivery zone card */
.qb-zone-card {
  border-radius: 22px; overflow: hidden;
  padding: 22px 20px;
  background: var(--theme-bg-secondary);
  border: 1.5px solid rgba(244,180,0,0.15);
  box-shadow: 0 8px 32px rgba(0,0,0,0.15);
}
.qb-zone-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:16px; }
.qb-zone-title { font-size: 16px; font-weight: 900; color: var(--theme-text-main); }
.qb-zone-live {
  font-size: 10px; font-weight: 800; color: #22c55e; letter-spacing: 0.5px;
  animation: openPulse 2.5s ease-in-out infinite;
}
.qb-zone-map {
  position: relative; height: 160px; border-radius: 14px;
  background: radial-gradient(ellipse at center, rgba(244,180,0,0.06) 0%, transparent 70%);
  border: 1px solid rgba(244,180,0,0.1); overflow: hidden;
  margin-bottom: 14px;
}
.qb-zone-ring {
  position: absolute; border-radius: 50%;
  border: 1.5px solid rgba(244,180,0,0.12);
  top: 50%; left: 50%; transform: translate(-50%,-50%);
}
.qb-zone-ring-1 { width: 60px;  height: 60px; }
.qb-zone-ring-2 { width: 110px; height: 110px; border-color: rgba(244,180,0,0.08); }
.qb-zone-ring-3 { width: 160px; height: 160px; border-color: rgba(244,180,0,0.05); }
.qb-zone-center {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  display: flex; flex-direction: column; align-items: center;
  background: rgba(244,180,0,0.15); border-radius: 50%;
  width: 44px; height: 44px; justify-content: center;
  border: 2px solid rgba(244,180,0,0.4);
  font-size: 16px; z-index: 2;
  animation: zonePulse 3s ease-in-out infinite;
}
@keyframes zonePulse {
  0%,100%{box-shadow:0 0 0 0 rgba(244,180,0,0.3)}
  50%{box-shadow:0 0 0 12px rgba(244,180,0,0)}
}
.qb-zone-center small { font-size: 7px; font-weight: 900; color: #F4B400; line-height: 1; }
.qb-zone-dot {
  position: absolute; left: var(--zx); top: var(--zy);
  transform: translate(-50%,-50%);
  font-size: 9px; font-weight: 700; color: rgba(255,255,255,0.55);
  background: rgba(244,180,0,0.1); border: 1px solid rgba(244,180,0,0.2);
  padding: 2px 6px; border-radius: 8px; white-space: nowrap;
}
html:not([data-theme="dark"]) .qb-zone-dot { color: rgba(0,0,0,0.5); }
.qb-zone-areas {
  display: flex; flex-wrap: wrap; gap: 6px;
}
.qb-zone-areas span {
  font-size: 11px; font-weight: 600; color: var(--theme-text-muted);
  background: rgba(244,180,0,0.07); border: 1px solid rgba(244,180,0,0.12);
  padding: 3px 9px; border-radius: 20px;
}

/* ══════════════════════════════════════════════════════
   🎁 DEAL / COUPON STRIP
══════════════════════════════════════════════════════ */
.qb-coupon-strip {
  display: flex; align-items: center; justify-content: center;
  gap: 10px; padding: 11px 16px;
  background: linear-gradient(90deg,rgba(229,57,53,0.07),rgba(244,180,0,0.09),rgba(229,57,53,0.07));
  background-size: 200% 100%;
  animation: couponShimmer 4s ease-in-out infinite;
  border-bottom: 1px solid rgba(244,180,0,0.12);
  flex-wrap: wrap; gap: 8px;
}
@keyframes couponShimmer {
  0%,100%{background-position:0% 50%} 50%{background-position:100% 50%}
}
.qb-coupon-text { font-size: 13px; font-weight: 600; color: var(--theme-text-main); }
.qb-coupon-code {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(244,180,0,0.18); border: 2px dashed rgba(244,180,0,0.85);
  border-radius: 8px; padding: 6px 15px;
  font-size: 15px; font-weight: 900; letter-spacing: 2px;
  color: #c48a00; cursor: pointer; position: relative;
  transition: background .18s, transform .15s;
  user-select: all;
  animation: qbCodePulse 2s ease-in-out infinite;
  box-shadow: 0 0 0 0 rgba(244,180,0,0.5);
}
[data-theme="dark"] .qb-coupon-code { color: #F4B400; }
@keyframes qbCodePulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(244,180,0,0.5); }
  50%      { box-shadow: 0 0 0 7px rgba(244,180,0,0); }
}
.qb-coupon-code:hover { background: rgba(244,180,0,0.28); transform: scale(1.04); animation: none; box-shadow: 0 4px 18px rgba(244,180,0,0.4); }
.qb-coupon-code:active { transform: scale(0.97); }
.qb-coupon-copy-toast {
  display: none; position: absolute; inset: 0;
  background: rgba(34,197,94,0.95); border-radius: 6px;
  align-items: center; justify-content: center;
  color: #fff; font-size: 12px; font-weight: 700;
}
.qb-coupon-code.qb-copied .qb-coupon-copy-toast { display: flex; }
.qb-coupon-copy-hint {
  font-size: 10px; color: var(--theme-text-muted);
  display: flex; align-items: center; gap: 3px;
}

/* ══════════════════════════════════════════════════════
   🍖 RESTAURANT SPOTLIGHT
══════════════════════════════════════════════════════ */
.qb-rs-wrap {
  padding: 12px 12px 4px;
}
.qb-rs-card {
  border-radius: 20px; overflow: hidden; position: relative;
  background: linear-gradient(135deg, #0b1e10 0%, #162b18 45%, #0d1f13 100%);
  border: 1.5px solid rgba(229,194,90,0.22);
  box-shadow: 0 12px 48px rgba(0,0,0,0.5), inset 0 0 40px rgba(229,194,90,0.03);
  padding: 22px 18px; display: flex; align-items: center;
  gap: 16px; cursor: pointer; text-decoration: none;
  transition: transform .2s, box-shadow .2s;
}
.qb-rs-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 18px 56px rgba(0,0,0,0.5), 0 0 0 2px rgba(229,194,90,0.35);
}
/* Decorative orb */
.qb-rs-card::before {
  content:''; position:absolute; top:-30px; right:-20px;
  width:160px; height:160px; border-radius:50%;
  background: radial-gradient(circle, rgba(229,194,90,0.1) 0%, transparent 70%);
  pointer-events:none;
}
.qb-rs-open-badge {
  position: absolute; top: 14px; right: 14px;
  background: rgba(34,197,94,0.18); border: 1px solid rgba(34,197,94,0.45);
  color: #22c55e; font-size: 10px; font-weight: 900;
  padding: 4px 10px; border-radius: 20px; letter-spacing: 0.6px;
  text-transform: uppercase;
  animation: openPulse 2.5s ease-in-out infinite;
}
@keyframes openPulse {
  0%,100%{opacity:1;box-shadow:0 0 6px rgba(34,197,94,0.3)}
  50%{opacity:0.65;box-shadow:none}
}
.qb-rs-logo-box {
  width: 70px; height: 70px; border-radius: 18px;
  background: linear-gradient(135deg,#091a09,#163016);
  border: 2px solid rgba(229,194,90,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 34px; flex-shrink: 0;
  box-shadow: 0 4px 20px rgba(0,0,0,0.5), 0 0 12px rgba(229,194,90,0.1);
}
.qb-rs-body { flex: 1; min-width: 0; }
.qb-rs-name {
  font-size: 17px; font-weight: 900; color: #e5c25a;
  letter-spacing: -0.4px; line-height: 1.2;
  font-family: Georgia, 'Times New Roman', serif;
}
.qb-rs-tagline { font-size: 11px; color: rgba(229,194,90,0.55); margin: 2px 0 9px; }
.qb-rs-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.qb-rs-pill {
  display: flex; align-items: center; gap: 3px;
  padding: 3px 8px; border-radius: 20px;
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
  font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.65);
}
.qb-rs-order-btn {
  flex-shrink: 0; display: flex; align-items: center; gap: 4px;
  padding: 11px 18px; border-radius: 12px;
  background: linear-gradient(135deg,#e5c25a,#c8a840);
  color: #0b1e10; font-size: 13px; font-weight: 900;
  border: none; cursor: pointer;
  box-shadow: 0 4px 16px rgba(229,194,90,0.3);
  transition: all .2s; text-decoration: none;
  white-space: nowrap;
}
.qb-rs-order-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(229,194,90,0.45); }

/* Light mode adjustments */
html:not([data-theme="dark"]) .qb-rs-card {
  background: linear-gradient(135deg,#0d2010,#1a3520,#0f2213);
}

/* ══════════════════════════════════════════════════════
   🥘 TYPICAL TASTE — 100% HALAL SECTION
══════════════════════════════════════════════════════ */
.qb-tt-sect {
  margin: 16px 12px 0;
  border-radius: 20px;
  overflow: hidden;
