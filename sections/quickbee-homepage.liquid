            {%- assign c_sav = product.compare_at_price | minus: product.price -%}
            {%- assign c_pct = c_sav | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}
          <a href="{{ product.url }}" class="qb-combo-card{% if product.price == 0 %} qb-cs{% endif %}">
            <div class="qb-combo-img-wrap">
              {% if c_disc %}<div class="qb-combo-off-badge">{{ c_pct }}% OFF</div>{% endif %}
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}" loading="lazy">
              {% else %}
                <div class="qb-combo-no-img">🌍</div>
              {% endif %}
              <div class="qb-combo-delivery-badge">⚡ 18-22 MINS</div>
            </div>
            <div class="qb-combo-info">
              <div class="qb-combo-product-name">{{ product.title }}</div>
              <div class="qb-combo-price-row">
                <div class="qb-combo-price-col">
                  <span class="qb-combo-price">Rs {{ product.price | divided_by: 100 }}</span>
                  {% if c_disc %}<span class="qb-combo-old-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>{% endif %}
                </div>
                <button class="qb-combo-add-btn" onclick="event.preventDefault();event.stopPropagation();qbAddToCart({{ product.variants.first.id }},this)">+</button>
              </div>
            </div>
          </a>
        {% endfor %}
      </div>
      <button class="qb-combo-arrow qb-combo-arrow-right" id="qbImportedNext" aria-label="Next">&#8250;</button>
    </div>
    <div class="qb-combo-dots" id="qbImportedDots"></div>
  </section>
  {% endif %}

