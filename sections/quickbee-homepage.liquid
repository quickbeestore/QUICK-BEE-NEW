<script>
  // Initialize delivery time system
  function initDeliveryTimeSystem() {
    try {
      const stored = localStorage.getItem('qb_delivery_time');
      if (stored) {
        const parsed = JSON.parse(stored);
        if (parsed && parsed.range) window.QB_DELIVERY_TIME = parsed;
      }
    } catch(e) {}

    if (!window.QB_DELIVERY_TIME) {
      window.QB_DELIVERY_TIME = { minTime: 18, maxTime: 22, range: '18-22 mins' };
    }

    function updateAllDeliveryBadges() {
      const range = window.QB_DELIVERY_TIME?.range || '18-22 mins';
      const text = '⚡ ' + range.replace(' mins', ' MINS');
      document.querySelectorAll('.qb-delivery-badge, .qb-carousel-badge, .qb-delivery-time-text').forEach(el => {
        if (el.classList.contains('qb-delivery-time-text')) {
          el.textContent = range;
        } else {
          el.textContent = text;
        }
      });
    }

    window.addEventListener('locationSelected', () => {
      try {
        const stored = localStorage.getItem('qb_delivery_time');
        if (stored) window.QB_DELIVERY_TIME = JSON.parse(stored);
      } catch(e) {}
      setTimeout(updateAllDeliveryBadges, 100);
    });

    window.addEventListener('qb_location_changed', () => {
      try {
        const stored = localStorage.getItem('qb_delivery_time');
        if (stored) window.QB_DELIVERY_TIME = JSON.parse(stored);
      } catch(e) {}
      setTimeout(updateAllDeliveryBadges, 100);
    });

    updateAllDeliveryBadges();
  }

  // Product image clicks
  document.querySelectorAll('.qb-product-image-wrap').forEach(wrap => {
    wrap.addEventListener('click', function() {
      const url = this.dataset.productUrl;
      if (url) window.location.href = url;
    });
  });

  // Carousel image clicks
  document.querySelectorAll('.qb-carousel-image-wrap').forEach(wrap => {
    wrap.addEventListener('click', function() {
      const url = this.dataset.productUrl;
      if (url) window.location.href = url;
    });
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDeliveryTimeSystem);
  } else {
    initDeliveryTimeSystem();
  }
</script>

<!-- Recruitment Popup -->
<div id="qb-homepage-popup" class="qb-popup-overlay" style="display: none;">
  <div class="qb-popup-content animate-fade-in">
    <button id="qb-close-popup" class="qb-popup-close" type="button">✕</button>
