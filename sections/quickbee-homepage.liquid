<script>
  // Initialize delivery time system
  function initDeliveryTimeSystem() {
    // Set default delivery time if not set
    if (!window.QB_DELIVERY_TIME) {
      window.QB_DELIVERY_TIME = {
        minTime: 18,
        maxTime: 22,
        range: '18-22 mins',
        updatedAt: new Date().toISOString()
      };
    }

    // Update all product badges with current delivery time
    function updateAllDeliveryBadges() {
      const badges = document.querySelectorAll('.qb-delivery-badge');
      const range = window.QB_DELIVERY_TIME?.range || '18-22 mins';
      badges.forEach(badge => {
        badge.textContent = `⚡ ${range}`;
      });
    }

    // Listen for location changes
    window.addEventListener('locationSelected', (event) => {
      // Delivery time will be updated by the location modal
      // Just refresh the badges here
      setTimeout(updateAllDeliveryBadges, 100);
    });

    // Initial update
    updateAllDeliveryBadges();
  }

  // Handle product image clicks to navigate to product page
  document.querySelectorAll('.qb-product-image-wrap').forEach(wrap => {
    wrap.addEventListener('click', function() {
      const url = this.dataset.productUrl;
      if (url) window.location.href = url;
    });
  });

  // Handle carousel image clicks to navigate to product page
  document.querySelectorAll('.qb-carousel-image-wrap').forEach(wrap => {
    wrap.addEventListener('click', function() {
      const url = this.dataset.productUrl;
      if (url) window.location.href = url;
    });
  });

  // Handle quantity selector
  document.querySelectorAll('.qb-qty-btn').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const input = this.closest('.qb-qty-selector').querySelector('.qb-qty-input');
      const currentVal = parseInt(input.value) || 1;

      if (this.textContent.includes('−')) {
        if (currentVal > 1) input.value = currentVal - 1;
      } else {
        input.value = currentVal + 1;
      }
    });
  });

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDeliveryTimeSystem);
  } else {
    initDeliveryTimeSystem();
  }
</script>
