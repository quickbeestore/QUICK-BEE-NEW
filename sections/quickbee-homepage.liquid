<style>
/* ═══════════════════════════════════
   PROMO BANNER CAROUSEL
═══════════════════════════════════ */
.qb-banners-section {
  padding: 12px 0 4px;
  position: relative;
  overflow: hidden;
}

/* Mobile: full-width single-slide snap scroll */
.qb-banners-track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  gap: 10px;
  padding: 0 16px 12px;
}
.qb-banners-track::-webkit-scrollbar { display: none; }

.qb-banner-slide {
  flex: 0 0 calc(75vw);
  max-width: 320px;
  scroll-snap-align: center;
  border-radius: 16px;
  overflow: hidden;
  display: block;
  box-shadow: 0 6px 24px rgba(0,0,0,0.35);
  transition: transform 0.2s ease;
}
.qb-banner-slide:active { transform: scale(0.97); }
.qb-banner-slide img {
  width: 100%;
  height: auto;
  display: block;
  aspect-ratio: 4/5;
  object-fit: cover;
}

