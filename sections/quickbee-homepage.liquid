  ];
  var ACTIONS = [
    'just ordered','placed an order for','ordered','just got'
  ];
  var TIMES = ['just now','1 min ago','2 mins ago','moments ago','just now'];

  var used = [];
  function getRandom(arr) {
    return arr[Math.floor(Math.random() * arr.length)];
  }
  function getUnusedItem() {
    if (used.length >= ITEMS.length) used = [];
    var avail = ITEMS.filter(function(i){ return used.indexOf(i[0]) < 0; });
    var pick = avail[Math.floor(Math.random() * avail.length)];
    used.push(pick[0]);
    return pick;
  }

  function buildMsg() {
    var name = getRandom(NAMES);
    var area = getRandom(AREAS);
    var item = getUnusedItem();
    var action = getRandom(ACTIONS);
    var time = getRandom(TIMES);
    return {
      avatar: name[1], avatarBg: name[2],
      name: name[0], area: area,
      emoji: item[1], item: item[0],
      action: action, time: time
    };
  }

  function renderMsg(d) {
    return '<div class="qb-tick-avatar" style="background:' + d.avatarBg + '">' + d.avatar + '</div>'
      + '<span class="qb-tick-emoji">' + d.emoji + '</span>'
      + '<span class="qb-tick-text"><b>' + d.name + ' from ' + d.area + '</b> ' + d.action + ' <em>' + d.item + '</em></span>'
      + '<span class="qb-tick-sep">●</span>'
      + '<span class="qb-tick-time">' + d.time + '</span>';
  }

  function initTicker() {
    var el = document.getElementById('qbTickMsg');
    if (!el) return;

    var HOLD = 4200;   // how long each message stays visible
    var FADE = 700;    // fade duration (matches CSS transition)

    function showNext() {
      // Exit current
      el.classList.remove('active');
      el.classList.add('exit');

      setTimeout(function() {
        // Swap content
        el.classList.remove('exit');
        el.innerHTML = renderMsg(buildMsg());

        // Small delay so browser paints reset state
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            el.classList.add('active');
          });
        });

        // Schedule next
        setTimeout(showNext, HOLD);
      }, FADE + 80);
    }

    // First message instantly
    el.innerHTML = renderMsg(buildMsg());
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        el.classList.add('active');
      });
    });
    setTimeout(showNext, HOLD);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTicker);
  } else {
    initTicker();
  }
})();

