<script>
// ──────────────────────────────────────
// DELIVERY TIME SYSTEM
// ──────────────────────────────────────
function initDeliveryTimeSystem() {
  try {
    var stored = localStorage.getItem('qb_delivery_time');
    if (stored) {
      var parsed = JSON.parse(stored);
      if (parsed && parsed.range) window.QB_DELIVERY_TIME = parsed;
    }
  } catch(e) {}

  if (!window.QB_DELIVERY_TIME) {
    window.QB_DELIVERY_TIME = { minTime: 18, maxTime: 22, range: '18-22 mins' };
  }

  function updateAllDeliveryBadges() {
    var range = (window.QB_DELIVERY_TIME && window.QB_DELIVERY_TIME.range) ? window.QB_DELIVERY_TIME.range : '18-22 mins';
    var text = '⚡ ' + range.replace(' mins', ' MINS');
    document.querySelectorAll('.qb-delivery-badge, .qb-combo-delivery-badge, .qb-delivery-time-text').forEach(function(el) {
      if (el.classList.contains('qb-delivery-time-text')) {
        el.textContent = range;
      } else {
        el.textContent = text;
      }
    });
  }

  window.addEventListener('locationSelected', function() {
    try {
      var stored = localStorage.getItem('qb_delivery_time');
      if (stored) window.QB_DELIVERY_TIME = JSON.parse(stored);
    } catch(e) {}
    setTimeout(updateAllDeliveryBadges, 100);
  });

  window.addEventListener('qb_location_changed', function() {
    try {
      var stored = localStorage.getItem('qb_delivery_time');
      if (stored) window.QB_DELIVERY_TIME = JSON.parse(stored);
    } catch(e) {}
    setTimeout(updateAllDeliveryBadges, 100);
  });

  updateAllDeliveryBadges();
}

// ──────────────────────────────────────
// GLOBAL ADD TO CART HELPER
// ──────────────────────────────────────
function qbAddToCart(variantId, btn) {
  if (!variantId || !btn) return;
  var orig = btn.textContent;
  btn.textContent = '…';
  btn.disabled = true;
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
  })
  .then(function(res) { return res.json(); })
  .then(function() {
    btn.textContent = '✓';
    btn.style.background = '#22c55e';
    btn.style.boxShadow = '0 4px 12px rgba(34,197,94,0.4)';
    setTimeout(function() {
      btn.textContent = orig;
      btn.style.background = '';
      btn.style.boxShadow = '';
      btn.disabled = false;
    }, 1600);
    // Trigger cart count update if theme supports it
    document.dispatchEvent(new CustomEvent('cart:updated'));
  })
  .catch(function() {
    btn.textContent = orig;
    btn.disabled = false;
  });
}

// ──────────────────────────────────────
// GENERIC SLIDER INITIALIZER
// ──────────────────────────────────────
function initSlider(trackId, prevId, nextId, dotsId) {
  var track = document.getElementById(trackId);
  var prev  = document.getElementById(prevId);
  var next  = document.getElementById(nextId);
  var dots  = document.getElementById(dotsId);
  if (!track) return;

  var cards = track.querySelectorAll('.qb-combo-card');
  var total = cards.length;
  if (total === 0) return;

  // Build dots
  if (dots) {
    cards.forEach(function(_, i) {
      var d = document.createElement('div');
      d.className = 'qb-combo-dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', function() { scrollToCard(i); });
      dots.appendChild(d);
    });
  }

  function getCardWidth() {
    return cards[0] ? (cards[0].offsetWidth + 12) : 200;
  }

  function scrollToCard(i) {
    track.scrollTo({ left: i * getCardWidth(), behavior: 'smooth' });
  }

  function updateDots() {
    if (!dots) return;
    var idx = Math.round(track.scrollLeft / getCardWidth());
    dots.querySelectorAll('.qb-combo-dot').forEach(function(d, i) {
      d.classList.toggle('active', i === idx);
    });
  }

  if (prev) {
    prev.addEventListener('click', function() {
      var idx = Math.round(track.scrollLeft / getCardWidth());
      scrollToCard(Math.max(0, idx - 1));
    });
  }
  if (next) {
    next.addEventListener('click', function() {
      var idx = Math.round(track.scrollLeft / getCardWidth());
      scrollToCard(Math.min(total - 1, idx + 1));
    });
  }

  track.addEventListener('scroll', updateDots, { passive: true });
}

// ──────────────────────────────────────
// BOOT
// ──────────────────────────────────────
function qbHomepageBoot() {
  initDeliveryTimeSystem();

  // Init all sliders
  initSlider('qbBeerComboTrack',  'qbBeerComboPrev',  'qbBeerComboNext',  'qbBeerComboDots');
  initSlider('qbBeerTrack',       'qbBeerPrev',       'qbBeerNext',       'qbBeerDots');
  initSlider('qbSmokesTrack',     'qbSmokesPrev',     'qbSmokesNext',     'qbSmokesDots');
  initSlider('qbWhiskeyTrack',    'qbWhiskeyPrev',    'qbWhiskeyNext',    'qbWhiskeyDots');
  initSlider('qbVodkaTrack',      'qbVodkaPrev',      'qbVodkaNext',      'qbVodkaDots');
  initSlider('qbImportedTrack',   'qbImportedPrev',   'qbImportedNext',   'qbImportedDots');
  initSlider('qbBabyTrack',       'qbBabyPrev',       'qbBabyNext',       'qbBabyDots');
  initSlider('qbPetTrack',        'qbPetPrev',        'qbPetNext',        'qbPetDots');
  initSlider('qbYetiTrack',       'qbYetiPrev',       'qbYetiNext',       'qbYetiDots');
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', qbHomepageBoot);
} else {
  qbHomepageBoot();
}
</script>
