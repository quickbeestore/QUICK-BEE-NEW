<!-- QuickBee Homepage - Dark Theme -->
<!-- ENFORCED: All product sections limited to 4 items maximum -->
<style>
:root {
  --qb-dark: var(--theme-bg-primary);
  --qb-dark2: color-mix(in srgb, var(--theme-bg-primary) 92%, #ffffff 8%);
  --qb-dark3: var(--theme-bg-secondary);
  --qb-dark4: color-mix(in srgb, var(--theme-bg-secondary) 82%, #000000 18%);
  --qb-gold: #F4B400;
  --qb-gold2: #FFD700;
  --qb-gold3: #E8A500;
  --qb-text: var(--theme-text-main);
  --qb-text2: var(--theme-text-muted);
  --qb-text3: color-mix(in srgb, var(--theme-text-muted) 70%, transparent);
  --qb-border: color-mix(in srgb, var(--theme-border) 70%, transparent);
  --qb-border-gold: rgba(244,180,0,0.22);
  --qb-ease: cubic-bezier(0.4, 0, 0.2, 1);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: var(--theme-bg-primary) !important;
  color: var(--theme-text-main) !important;
}

.qb-hp {
  background: var(--theme-bg-primary);
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* Product Sections */
.qb-section {
  padding: 36px 16px;
  border-bottom: 1px solid var(--qb-border);
  max-width: 100%;
  width: 100%;
  margin: 0;
  background: transparent;
}

@media(min-width: 1024px) {
  .qb-section {
    max-width: 1400px;
    margin: 0 auto;
  }
}

.qb-section:last-of-type {
  border-bottom: none;
}

@media(min-width: 640px) {
  .qb-section { padding: 40px 24px; }
}

@media(min-width: 1024px) {
  .qb-section { padding: 52px 48px; }
}

.qb-section h2 {
  font-size: 22px;
  font-weight: 900;
  margin-bottom: 24px;
  color: var(--qb-text);
  letter-spacing: -0.3px;
  position: relative;
  display: flex;
  align-items: center;
  gap: 10px;
}

.qb-section h2::after {
  content: '';
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, var(--qb-gold) 0%, transparent 100%);
  margin-left: 8px;
  max-width: 60px;
}

/* ─── CAROUSEL ─── */
.qb-carousel-container {
  overflow: hidden;
  position: relative;
  width: 100%;
  margin: 0 -20px;
  padding: 0 20px;
}

.qb-carousel-scroll {
  display: flex;
  gap: 16px;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-behavior: smooth;
  padding-bottom: 8px;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior-x: contain;
}

.qb-carousel-scroll::-webkit-scrollbar { height: 4px; }
.qb-carousel-scroll::-webkit-scrollbar-track { background: var(--qb-dark3); border-radius: 10px; }
.qb-carousel-scroll::-webkit-scrollbar-thumb { background: var(--qb-gold); border-radius: 10px; }
.qb-carousel-scroll::-webkit-scrollbar-thumb:hover { background: var(--qb-gold2); }

.qb-carousel-card {
  flex: 0 0 calc(50% - 8px);
  scroll-snap-align: start;
}

@media (min-width: 768px) {
  .qb-carousel-card { flex: 0 0 calc(33.333% - 11px); }
}

@media (min-width: 1024px) {
  .qb-carousel-card { flex: 0 0 280px; }
}

.qb-no-image { font-size: 48px; color: var(--qb-text3); }

.qb-discount-badge {
  position: absolute;
  top: 12px;
  right: 12px;
  background: #FF6B6B;
  color: white;
  padding: 5px 10px;
  border-radius: 8px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.3px;
  box-shadow: 0 4px 12px rgba(255,107,107,0.3);
}

.qb-carousel-content {
  padding: 10px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.qb-carousel-price {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.qb-price {
  font-size: 17px;
  font-weight: 900;
  color: var(--qb-gold);
}

.qb-original-price {
  font-size: 13px;
  color: var(--qb-text3);
  text-decoration: line-through;
}

/* ─── PRODUCT GRID ─── */
.qb-product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin: 0 auto;
  padding: 0;
  max-width: 100%;
  width: fit-content;
}

@media(max-width: 767px) {
  .qb-product-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; padding: 0; }
}

@media(min-width: 768px) and (max-width: 1023px) {
  .qb-product-grid { grid-template-columns: repeat(3, 1fr); gap: 14px; padding: 0; }
}

@media(min-width: 1024px) {
  .qb-product-grid { grid-template-columns: repeat(4, 1fr); gap: 16px; padding: 0; }
}

/* ENFORCE: Hide any product beyond the 4th */
.qb-product-card:nth-child(n+5) { display: none !important; }

.qb-product-card {
  display: flex;
  flex-direction: column;
  background: var(--qb-dark3) !important;
  border-radius: 12px;
  overflow: hidden;
  border: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  cursor: pointer;
  height: 100%;
  position: relative;
}

.qb-product-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(244,180,0,0.1);
}

@media(max-width: 767px) {
  .qb-product-card { border-radius: 10px; }
}

.qb-product-image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--qb-dark4) !important;
  overflow: hidden;
  display: block;
}

.qb-carousel-image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--qb-dark4) !important;
  overflow: hidden;
  display: block;
}

.qb-product-image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform 0.3s ease;
  display: block;
  padding: 0;
}

.qb-carousel-image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform 0.3s ease;
  display: block;
  padding: 0;
}

.qb-product-card:hover .qb-product-image-wrap img { transform: scale(1.05); }
.qb-product-card:hover .qb-carousel-image-wrap img { transform: scale(1.05); }

.qb-delivery-badge {
  position: absolute;
  bottom: 8px;
  right: 8px;
  background: rgba(196,30,58,0.95);
  color: white;
  padding: 5px 8px;
  border-radius: 14px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  z-index: 10;
  backdrop-filter: blur(4px);
  box-shadow: 0 2px 8px rgba(0,0,0,0.4);
  animation: badgePulse 3s ease-in-out infinite;
}

@keyframes badgePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@media (prefers-reduced-motion: reduce) {
  .qb-delivery-badge, .qb-carousel-badge { animation: none; }
}

.qb-product-name {
  font-size: 13px;
  font-weight: 600;
  padding: 8px 10px 4px;
  margin: 0;
  line-height: 1.4;
  color: var(--qb-text);
  min-height: 40px;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-word;
}

.qb-product-price {
  font-size: 15px;
  font-weight: 800;
  color: var(--qb-gold);
  padding: 0 10px 6px;
}

/* Empty State */
.qb-empty {
  grid-column: 1 / -1;
  padding: 40px;
  text-align: center;
  color: var(--qb-text3);
  font-size: 15px;
  font-weight: 500;
  background: var(--qb-dark3);
  border-radius: 8px;
  border: 1px dashed var(--qb-border);
  margin: 16px 0;
}
</style>

<style>
