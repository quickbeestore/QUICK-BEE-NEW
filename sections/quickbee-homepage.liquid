  <!-- BANNER GRID -->
  <div class="qb-banners-perfect">

    <!-- ROW 1: QuickBee Bee-on-Bike Banner (full width) -->
    <a href="/collections/all" class="qb-banner-item qb-banner-large1">
      <img src="{{ 'assets-20000-products-and-services.png' | asset_url }}" alt="QuickBee - 20,000+ Products & Services">
    </a>

    <!-- ROW 2: 3 SMALL BANNERS (Beer, Briyani, Yeti Kafe) -->
    <a href="/collections/domestic-beer" class="qb-banner-item qb-banner-row1">
      <img src="{{ 'assets-cold-domestic-beer.png' | asset_url }}" alt="Cold Beer">
    </a>
    <a href="/collections/biryani" class="qb-banner-item qb-banner-row1">
      <img src="{{ 'assets-briyani-starting-149.png' | asset_url }}" alt="Delicious Biryani">
    </a>
    <a href="/collections/yeti-kafe" class="qb-banner-item qb-banner-row1">
      <img src="{{ 'assets-delivery-within-20mins.png' | asset_url }}" alt="Yeti Kafe - Delivery within 20 mins">
    </a>

    <!-- ROW 3: Fresh Vegetables & Fruits (full width) -->
    <a href="/collections/farm-fresh" class="qb-banner-item qb-banner-large2">
      <img src="{{ 'assets-fresh-vegetables-and-fruits.png' | asset_url }}" alt="Fresh Vegetables & Fruits">
    </a>

  </div>

  <!-- Yeti Kafe - Carousel -->
  {% assign yeti_products = collections.yeti-kafe.products %}
  {% if yeti_products.size > 0 %}
  <section class="qb-section">
    <h2>☕ Yeti Kafe</h2>
    <div class="qb-carousel-container">
      <div class="qb-carousel-scroll">
          {% for product in yeti_products %}
            <div class="qb-product-card">
              <div class="qb-carousel-image-wrap" data-product-url="{{ product.url }}" style="cursor: pointer;">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '1080x1080', crop: 'center' }}" alt="{{ product.title }}" loading="lazy">
                {% else %}
                  <div class="qb-no-image" style="background:var(--qb-dark4);width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:40px;">🐝</div>
                {% endif %}
                <div class="qb-delivery-badge">⚡ 18-22 mins</div>
              </div>
              <div class="qb-carousel-content">
                <h3 class="qb-product-name">{{ product.title }}</h3>
                <div class="qb-product-price">
                  <span class="qb-price">Rs {{ product.price | divided_by: 100 }}</span>
                  {% if product.compare_at_price and product.compare_at_price > product.price %}
                    <span class="qb-original-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                  {% endif %}
                </div>
                <form action="/cart/add" method="post" class="qb-carousel-form">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="qb-add-btn">Add to Cart</button>
                </form>
              </div>
            </div>
          {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

