/* ══════════════════════════════════════════════════════
   🥩 DHIDO & THE GRILLS — DARK SECTION
══════════════════════════════════════════════════════ */
.qb-dg-sect {
  margin: 14px 0 0;
  background: linear-gradient(160deg, #061409 0%, #0d2011 45%, #091709 100%);
  padding: 0 0 10px;
  overflow: hidden;
  position: relative;
}
.qb-dg-sect::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse 70% 60% at 85% 20%, rgba(229,194,90,0.07) 0%, transparent 65%),
    radial-gradient(circle 250px at 5% 90%, rgba(34,197,94,0.05) 0%, transparent 55%);
