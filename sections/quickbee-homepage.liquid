  <script>
  (function(){
    var stored = localStorage.getItem('qbBirEnd');
    var end = stored ? parseInt(stored,10) : 0;
    if (!end || end < Date.now()) {
      end = Date.now() + 23*3600000 + 47*60000 + Math.floor(Math.random()*59)*1000;
      localStorage.setItem('qbBirEnd', end);
    }
    function tick(){
      var diff = end - Date.now();
      if(diff<=0){ end=Date.now()+23*3600000+47*60000; localStorage.setItem('qbBirEnd',end); diff=end-Date.now(); }
      var h=Math.floor(diff/3600000), m=Math.floor((diff%3600000)/60000), s=Math.floor((diff%60000)/1000);
      var hEl=document.getElementById('qbBirH'), mEl=document.getElementById('qbBirM'), sEl=document.getElementById('qbBirS');
      if(hEl) hEl.textContent=String(h).padStart(2,'0');
      if(mEl) mEl.textContent=String(m).padStart(2,'0');
      if(sEl) sEl.textContent=String(s).padStart(2,'0');
    }
    tick(); setInterval(tick,1000);
  })();
  </script>


