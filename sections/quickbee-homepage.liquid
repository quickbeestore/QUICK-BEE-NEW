  .qb-banners-perfect {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    padding: 16px;
    max-width: 1000px;
    margin: 0 auto;
    background: var(--theme-bg-primary);
  }

  .qb-banners-perfect > .qb-banner-large1,
  .qb-banners-perfect > .qb-banner-large2 {
    grid-column: 1 / -1;
    width: 100%;
  }

  @media(max-width: 767px) {
    .qb-banners-perfect {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      padding: 12px;
    }
  }

  @media(min-width: 768px) {
    .qb-banners-perfect {
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      padding: 20px 16px;
    }
  }

  .qb-banner-large1 { grid-column: 1 / -1; }
  .qb-banner-row1 { grid-column: span 1; }
  .qb-banner-large2 { grid-column: 1 / -1; }

  .qb-banner-item {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 10px;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 12px rgba(0,0,0,0.4);
    height: 100%;
  }

  .qb-banner-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  }

  .qb-banner-item img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
</style>

