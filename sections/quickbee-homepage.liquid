  <!-- Yeti Kafe - Modern Horizontal Carousel -->
  <section class="qb-section">
    <h2>☕ Yeti Kafe</h2>
    <div class="qb-carousel-container">
      <div class="qb-carousel-scroll">
        {% assign products = collections.yeti-kafe.products %}
        {% if products.size > 0 %}
          {% for product in products %}
            <div class="qb-carousel-card">
              <div class="qb-carousel-image-wrap" data-product-url="{{ product.url }}" style="cursor: pointer;">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '400x400' }}" alt="{{ product.title }}" loading="lazy">
                {% else %}
                  <div class="qb-no-image">📷</div>
                {% endif %}
                <div class="qb-carousel-badge">⚡ 18-22 mins</div>
                {% if product.compare_at_price and product.compare_at_price > product.price %}
                  <div class="qb-discount-badge">{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round }}% OFF</div>
                {% endif %}
              </div>
              <div class="qb-carousel-content">
                <h3 class="qb-carousel-title">{{ product.title }}</h3>
                <div class="qb-carousel-price">
                  <span class="qb-price">Rs {{ product.price | divided_by: 100 }}</span>
                  {% if product.compare_at_price and product.compare_at_price > product.price %}
                    <span class="qb-original-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                  {% endif %}
                </div>
                <form action="/cart/add" method="post" class="qb-carousel-form">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="qb-carousel-add-btn">Add to Cart</button>
                </form>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="qb-empty">No products available</div>
        {% endif %}
      </div>
    </div>
