      text:'I\'ve ordered 11 times in the last month. The app is fast, riders are always polite, and food is consistently great. My friends are all hooked now.' }
  ];

  var STAR_SVG = '<svg viewBox="0 0 24 24" fill="#F4B400" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>';
  var STAR_EMPTY_SVG = '<svg viewBox="0 0 24 24" fill="rgba(244,180,0,0.25)" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>';

  function buildCard(r) {
    var stars = '';
    for (var i = 0; i < 5; i++) {
      stars += '<span class="qb-rv-star">' + (i < r.stars ? STAR_SVG : STAR_EMPTY_SVG) + '</span>';
    }
    return '<div class="qb-rv-card">'
      + '<div class="qb-rv-stars-row">'
      + '<div class="qb-rv-stars">' + stars + '</div>'
      + '<span class="qb-rv-verified">Verified</span>'
      + '</div>'
      + '<p class="qb-rv-text">' + r.text + '</p>'
      + '<div class="qb-rv-author">'
      + '<div class="qb-rv-avatar" style="background:' + r.bg + '">' + r.avatar + '</div>'
      + '<div><div class="qb-rv-name">' + r.name + '</div>'
      + '<div class="qb-rv-meta">📍 ' + r.area + '</div></div>'
      + '</div></div>';
  }

  // Split reviews into two rows and duplicate 3x for infinite scroll
  var half1 = REVIEWS.slice(0, 8);
  var half2 = REVIEWS.slice(8);
  var html1 = '', html2 = '';
  for (var i = 0; i < 3; i++) {
    half1.forEach(function(r){ html1 += buildCard(r); });
    half2.forEach(function(r){ html2 += buildCard(r); });
  }

  var t1 = document.getElementById('qbRevTrack1');
  var t2 = document.getElementById('qbRevTrack2');
  if (t1) t1.innerHTML = html1;
  if (t2) t2.innerHTML = html2;
})();

// ══════════════════════════════════════════════════════════
// 🔔 APP NOTIFY FORM — AJAX submit via Shopify /contact
// ══════════════════════════════════════════════════════════
function qbNotifySubmit(event) {
  event.preventDefault();
  var email   = document.getElementById('qbNotifyEmail').value.trim();
  var btn     = document.getElementById('qbNotifyBtn');
  var form    = document.getElementById('qbNotifyForm');
  var success = document.getElementById('qbNotifySuccess');
  if (!email) return;

  // Check if already signed up
  if (localStorage.getItem('qb_notify_' + email)) {
    form.style.display = 'none';
    if (success) success.style.display = 'flex';
    return;
  }

  // Loading state
  var txt  = btn.querySelector('.qb-notify-btn-text');
  var spin = btn.querySelector('.qb-notify-btn-loading');
  if (txt)  txt.style.display  = 'none';
  if (spin) spin.style.display = 'flex';
  btn.disabled = true;

  // POST to Shopify contact endpoint
  var body = 'form_type=contact&utf8=%E2%9C%93'
    + '&contact%5Bemail%5D=' + encodeURIComponent(email)
    + '&contact%5Bfirst_name%5D=App+Launch+Notify'
    + '&contact%5Bbody%5D=QuickBee+App+Launch+Notification+Request+from+' + encodeURIComponent(email);

  fetch('/contact', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded',
      'Accept': 'application/json'
    },
    body: body
  })
  .then(function() {
    localStorage.setItem('qb_notify_' + email, '1');
    if (form)    form.style.display    = 'none';
    if (success) success.style.display = 'flex';
  })
  .catch(function() {
    // Still show success — save locally so it doesn't re-ask
    localStorage.setItem('qb_notify_' + email, '1');
    if (form)    form.style.display    = 'none';
    if (success) success.style.display = 'flex';
  });
}

// Show success immediately if user already signed up
(function(){
  var emailInput = document.getElementById('qbNotifyEmail');
  var form       = document.getElementById('qbNotifyForm');
  var success    = document.getElementById('qbNotifySuccess');
  if (!form || !success) return;

  // Pre-check on focus: if email recognised show success
  if (emailInput) {
    emailInput.addEventListener('blur', function(){
      var e = emailInput.value.trim();
      if (e && localStorage.getItem('qb_notify_' + e)) {
        form.style.display    = 'none';
        success.style.display = 'flex';
      }
    });
  }
})();

// ══════════════════════════════════════════════════════════
// 🧠 HOMEPAGE PERSONALISATION — Phase 1
// Time-based section ordering + localStorage behaviour tracking
// ══════════════════════════════════════════════════════════
(function(){
  var LS_KEY     = 'qb_pref';
  var LS_VISITS  = 'qb_visits';
  var LS_LAST    = 'qb_last_section';

  // ── 1. Count visits ──────────────────────────────────
  var visits = parseInt(localStorage.getItem(LS_VISITS) || '0', 10) + 1;
  localStorage.setItem(LS_VISITS, visits);

  // ── 2. Track category pill clicks ─────────────────────
  document.querySelectorAll('.qb-cat-pill[data-target]').forEach(function(pill) {
    pill.addEventListener('click', function() {
      var target = pill.getAttribute('data-target') || '';
      localStorage.setItem(LS_LAST, target);
      var prefs = JSON.parse(localStorage.getItem(LS_KEY) || '{}');
      prefs[target] = (prefs[target] || 0) + 1;
      localStorage.setItem(LS_KEY, JSON.stringify(prefs));
    });
  });

  // ── 3. Time-of-day section ordering ──────────────────
  var hour = new Date().getHours();
  // Morning (6-11): push food/dhido sections up
  // Afternoon (12-16): push food/combos up
  // Evening (17-22): push beer/sekuwa up
  // Night (23-5): push beer/whiskey up
  var ORDER_MAP = {
    morning:   ['qb-food','qb-cakes','qb-beer','qb-smokes','qb-whiskey'],
    afternoon: ['qb-food','qb-beer-combos','qb-cakes','qb-beer','qb-smokes'],
    evening:   ['qb-beer','qb-beer-combos','qb-food','qb-smokes','qb-whiskey'],
    night:     ['qb-whiskey','qb-vodka','qb-beer','qb-smokes','qb-imported']
  };
  var timeSlot = hour >= 6 && hour < 12 ? 'morning'
               : hour >= 12 && hour < 17 ? 'afternoon'
               : hour >= 17 && hour < 23 ? 'evening' : 'night';

  // ── 4. Preference-based ordering (overrides time) ─────
  var prefs = JSON.parse(localStorage.getItem(LS_KEY) || '{}');
  var topPref = null;
  var topCount = 0;
  Object.keys(prefs).forEach(function(k) {
    if (prefs[k] > topCount) { topCount = prefs[k]; topPref = k; }
  });

  // Reorder homepage sections based on preference
  if (topPref && topCount >= 2) {
    var main = document.querySelector('.qb-main') || document.querySelector('[id="qb-beer"]') && document.querySelector('[id="qb-beer"]').parentElement;
    if (main) {
      var prefEl = document.getElementById(topPref);
      if (prefEl && prefEl.parentElement === main) {
        // Move preferred section to be 2nd (after hero/catgrid)
        var anchor = document.getElementById('qb-food') || main.children[2];
        if (anchor && anchor !== prefEl) {
          main.insertBefore(prefEl, anchor);
        }
      }
    }
  }

  // ── 5. Returning visitor personalisation ──────────────
  if (visits >= 3) {
    var lastSection = localStorage.getItem(LS_LAST);
    var greetingMap = {
      'qb-beer':         'Your favourites are ready 🍺',
      'qb-beer-combos':  'The best combos are waiting 🍺🥟',
      'qb-whiskey':      'Your premium picks are here 🥃',
      'qb-vodka':        'Stocked up for the night? 🍸',
      'qb-smokes':       'Back for your usual? 🚬',
      'qb-food':         'Ready for something delicious? 🍽️',
      'qb-cakes':        'Something sweet today? 🎂',
      'qb-imported':     'Your premium picks are here 🥃'
    };
    var msg = greetingMap[lastSection] || 'Welcome back! 🐝';

    // Inject returning visitor greeting under hero
    var heroEl = document.querySelector('.qb-hero');
    if (heroEl && heroEl.nextSibling) {
      var banner = document.createElement('div');
      banner.className = 'qb-return-banner';
      banner.innerHTML = '<span class="qb-return-icon">👋</span>'
        + '<span>' + msg + '</span>'
        + '<span class="qb-return-count">Visit #' + visits + '</span>';
      heroEl.parentNode.insertBefore(banner, heroEl.nextSibling);
    }
  }
})();
// ── End Personalisation ──────────────────────────────────

// ══ WE ARE LIVE BANNER — dismiss + restore ══════════════
(function() {
  var banner = document.getElementById('qbLiveBanner');
  var closeBtn = document.getElementById('qbLiveBannerClose');
  var LS_KEY = 'qb_live_banner_dismissed';

  if (!banner) return;

  // If user dismissed it before, hide immediately (no flash)
  if (localStorage.getItem(LS_KEY) === '1') {
    banner.classList.add('qb-live-hidden');
    return;
  }

  // Close button
  if (closeBtn) {
    closeBtn.addEventListener('click', function() {
      banner.style.transition = 'max-height 0.35s ease, opacity 0.3s ease, padding 0.35s ease';
      banner.style.maxHeight = banner.offsetHeight + 'px';
      banner.style.overflow = 'hidden';
      requestAnimationFrame(function() {
        banner.style.maxHeight = '0';
        banner.style.opacity = '0';
        banner.style.paddingTop = '0';
        banner.style.paddingBottom = '0';
      });
      setTimeout(function() {
        banner.classList.add('qb-live-hidden');
        try { localStorage.setItem(LS_KEY, '1'); } catch(e) {}
      }, 350);
    });
  }
})();
</script>

<script>
/* ── Banner Carousel ── */
(function() {
  function initBannerCarousel() {
    const track = document.getElementById('qbBannersTrack');
    const dotsWrap = document.getElementById('qbBannersDots');
    if (!track || !dotsWrap) return;

    const slides = track.querySelectorAll('.qb-banner-slide');
    const total = slides.length;
    if (total === 0) return;

    // Build dots
    slides.forEach(function(_, i) {
      const d = document.createElement('span');
      d.className = 'qb-dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', function() { goTo(i); });
      dotsWrap.appendChild(d);
    });

    function getDots() { return dotsWrap.querySelectorAll('.qb-dot'); }

    function goTo(idx) {
      slides[idx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      getDots().forEach(function(d, i) { d.classList.toggle('active', i === idx); });
    }

    // Update dots on scroll
    let scrollTimer;
    track.addEventListener('scroll', function() {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function() {
        let closest = 0, minDist = Infinity;
        slides.forEach(function(s, i) {
          const rect = s.getBoundingClientRect();
          const trackRect = track.getBoundingClientRect();
          const dist = Math.abs(rect.left + rect.width/2 - (trackRect.left + trackRect.width/2));
          if (dist < minDist) { minDist = dist; closest = i; }
        });
        getDots().forEach(function(d, i) { d.classList.toggle('active', i === closest); });
      }, 80);
    }, { passive: true });

    // Auto-advance (mobile only)
    let current = 0;
    const interval = setInterval(function() {
      if (window.innerWidth >= 960) return;
      current = (current + 1) % total;
      goTo(current);
    }, 3500);

    // Pause on touch
    track.addEventListener('touchstart', function() { clearInterval(interval); }, { passive: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBannerCarousel);
  } else {
    initBannerCarousel();
  }
})();
</script>
