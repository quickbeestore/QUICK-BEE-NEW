}
.qb-dg-sect .qb-combo-card:hover,
html:not([data-theme="dark"]) .qb-dg-sect .qb-combo-card:hover {
  border-color: rgba(229,194,90,0.32) !important;
  box-shadow: 0 8px 32px rgba(0,0,0,0.55), 0 0 0 1px rgba(229,194,90,0.12) !important;
}
.qb-dg-sect .qb-combo-img-wrap,
html:not([data-theme="dark"]) .qb-dg-sect .qb-combo-img-wrap {
  background: rgba(0,0,0,0.35) !important;
}
.qb-dg-sect .qb-combo-product-name,
html:not([data-theme="dark"]) .qb-dg-sect .qb-combo-product-name { color: #e0d0b4 !important; }
.qb-dg-sect .qb-combo-price,
html:not([data-theme="dark"]) .qb-dg-sect .qb-combo-price { color: #e5c25a !important; }
.qb-dg-sect .qb-combo-subtitle { color: rgba(229,194,90,0.4); }
.qb-dg-sect .qb-combo-info { background: transparent !important; }
.qb-dg-sect .qb-combo-dots { background: transparent; padding-bottom: 6px; }
.qb-dg-sect .qb-combo-add-btn,
html:not([data-theme="dark"]) .qb-dg-sect .qb-combo-add-btn {
  background: linear-gradient(135deg, #c8a840, #e5c25a) !important;
  color: #0d1a0d !important;
  border-color: transparent !important;
}
.qb-dg-sect .qb-combo-arrow {
  background: rgba(229,194,90,0.1);
  border: 1.5px solid rgba(229,194,90,0.2);
  color: #e5c25a;
