    top: 10px;
    right: 10px;
    background: rgba(0,0,0,0.6) !important;
    border: 1px solid rgba(255,255,255,0.2) !important;
    width: 32px !important;
    max-width: 32px !important;
    min-width: 32px !important;
    height: 32px !important;
    min-height: unset !important;
    border-radius: 50%;
    font-size: 14px;
    color: #fff !important;
    cursor: pointer;
    z-index: 10;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 !important;
    transition: all 0.2s ease;
  }

  .qb-popup-close:hover {
    background: rgba(244,180,0,0.3) !important;
    border-color: var(--qb-gold) !important;
  }

  .qb-popup-link { display: block; width: 100%; }
  .qb-popup-link img { width: 100%; height: auto; display: block; }

  .animate-fade-in {
    animation: qbFadeIn 0.4s ease-out forwards;
  }

  @keyframes qbFadeIn {
    from { opacity: 0; transform: scale(0.92) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @media (max-width: 767px) {
    .qb-popup-content { max-width: 92%; }
  }
</style>

<script>
  (function() {
    function initRecruitmentPopup() {
      const popup = document.getElementById('qb-homepage-popup');
      const closeBtn = document.getElementById('qb-close-popup');
      const popupImg = document.getElementById('qb-popup-img');

      if (!popup) return;
      if (sessionStorage.getItem('qb_recruitment_popup_shown')) return;

      const showPopup = () => {
        if (sessionStorage.getItem('qb_recruitment_popup_shown')) return;
        popup.style.display = 'flex';
      };

      setTimeout(() => {
        if (popupImg && popupImg.complete) {
          showPopup();
        } else if (popupImg) {
          popupImg.addEventListener('load', showPopup);
          setTimeout(showPopup, 3000);
        } else {
          showPopup();
        }
      }, 2000);

      const closePopup = () => {
        popup.style.display = 'none';
        sessionStorage.setItem('qb_recruitment_popup_shown', 'true');
      };

      if (closeBtn) {
        closeBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          closePopup();
        });
      }

      popup.addEventListener('click', (e) => {
        if (e.target === popup) closePopup();
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initRecruitmentPopup);
    } else {
      initRecruitmentPopup();
    }
  })();
</script>
