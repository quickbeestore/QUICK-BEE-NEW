<!-- QuickBee Homepage - Zepto-Inspired Minimal Design -->
<style>
:root {
  --qb-purple: #7a14ac;
  --qb-black: #111111;
  --qb-white: #ffffff;
  --qb-light: #f5f5f5;
  --qb-border: #e5e5e5;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }

.qb-hp {
  background: var(--qb-white);
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* Hero */
.qb-hero {
  background: linear-gradient(135deg, #f8f9fa 0%, #f0f0f0 100%);
  padding: 40px 20px;
  text-align: center;
  border-bottom: 1px solid var(--qb-border);
}

@media(min-width: 1024px) { .qb-hero { padding: 60px 48px; } }

.qb-hero h1 {
  font-size: 32px;
  font-weight: 800;
  color: var(--qb-black);
  margin-bottom: 12px;
}

@media(min-width: 1024px) { .qb-hero h1 { font-size: 48px; } }

.qb-hero p {
  font-size: 16px;
  color: #666;
  margin-bottom: 24px;
}

.qb-search {
  max-width: 500px;
  margin: 0 auto;
  display: flex;
  gap: 8px;
}

.qb-search input {
  flex: 1;
  padding: 14px 16px;
  border: 1px solid var(--qb-border);
  border-radius: 8px;
  font-size: 14px;
}

.qb-search button {
  background: var(--qb-purple);
  color: white;
  border: none;
  padding: 14px 24px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
}

/* Categories */
.qb-categories {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  padding: 24px;
  max-width: 1200px;
  margin: 0 auto;
}

@media(min-width: 768px) { .qb-categories { grid-template-columns: repeat(4, 1fr); gap: 16px; padding: 32px 24px; } }

@media(min-width: 1024px) { .qb-categories { grid-template-columns: repeat(6, 1fr); gap: 20px; padding: 40px 48px; } }

.qb-cat-btn {
  padding: 16px;
  border: 1px solid var(--qb-border);
  border-radius: 12px;
  background: white;
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
  color: var(--qb-black);
  font-weight: 600;
  font-size: 14px;
  text-align: center;
}

.qb-cat-btn:hover {
  border-color: var(--qb-purple);
  background: rgba(122, 20, 172, 0.05);
}

.qb-cat-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

/* Product Sections */
.qb-section {
  padding: 36px 16px;
  border-bottom: 1px solid #f5f5f5;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
}

.qb-section:last-of-type {
  border-bottom: none;
}

@media(min-width: 640px) {
  .qb-section {
    padding: 40px 24px;
  }
}

@media(min-width: 1024px) {
  .qb-section {
    padding: 52px 48px;
  }
}

.qb-section h2 {
  font-size: 26px;
  font-weight: 900;
  margin-bottom: 28px;
  color: var(--qb-black);
  letter-spacing: -0.3px;
  position: relative;
  display: flex;
  align-items: center;
  gap: 10px;
}

.qb-section h2::after {
  content: '';
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, var(--qb-purple) 0%, transparent 100%);
  margin-left: 8px;
  max-width: 60px;
}

/* Professional Masonry Grid */
.qb-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin-bottom: 16px;
}

/* Mobile: Single column */
@media(max-width: 767px) {
  .qb-grid {
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .qb-product {
    min-height: 280px;
  }
}

/* Tablet: 2-column masonry */
@media(min-width: 768px) {
  .qb-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    grid-auto-rows: 260px;
  }

  /* Random sizes - every 5th, 7th, 11th product is tall */
  .qb-product:nth-child(5n) {
    grid-row: span 2;
    min-height: auto;
  }

  .qb-product:nth-child(7n) {
    grid-column: span 1;
  }

  /* Wide product - every 11th */
  .qb-product:nth-child(11n) {
    grid-row: span 2;
  }
}

/* Desktop: 4-column advanced masonry */
@media(min-width: 1024px) {
  .qb-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    grid-auto-rows: 240px;
  }

  /* Create visual variety with random spans */
  .qb-product:nth-child(3n) {
    grid-row: span 2;
    grid-column: span 1;
  }

  .qb-product:nth-child(5n) {
    grid-column: span 2;
    grid-row: span 1;
  }

  .qb-product:nth-child(7n) {
    grid-row: span 2;
    grid-column: span 2;
  }

  .qb-product:nth-child(11n) {
    grid-column: span 1;
    grid-row: span 2;
  }
}

/* Product Grid - 2x3 mobile, 4x2 desktop */
.qb-product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 16px;
}

@media(max-width: 767px) {
  .qb-product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .qb-product-grid .qb-product {
    min-height: 240px;
  }
}

@media(min-width: 768px) and (max-width: 1023px) {
  .qb-product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .qb-product-grid .qb-product {
    min-height: 260px;
  }
}

@media(min-width: 1024px) {
  .qb-product-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .qb-product-grid .qb-product {
    min-height: 240px;
  }
}

.qb-product {
  border: none;
  border-radius: 16px;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  background: white;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  position: relative;
  height: 100%;
}

.qb-product::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(122, 20, 172, 0.1) 0%, rgba(122, 20, 172, 0) 100%);
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

.qb-product:hover {
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
  transform: translateY(-8px);
  border-color: transparent;
}

.qb-product:hover::before {
  opacity: 1;
}

.qb-product-img {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 48px;
  position: relative;
  flex-shrink: 0;
}

.qb-product-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}

.qb-product:hover .qb-product-img img {
  transform: scale(1.05);
}

.qb-product-info {
  padding: 14px;
  flex: 1;
  display: flex;
  flex-direction: column;
  background: white;
  position: relative;
  z-index: 2;
  min-height: 120px;
  justify-content: space-between;
}

.qb-product-name {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 6px;
  line-height: 1.4;
  color: var(--qb-black);
  text-transform: capitalize;
  letter-spacing: 0.2px;
}

.qb-product-price {
  font-size: 17px;
  font-weight: 900;
  color: var(--qb-purple);
  margin-bottom: 8px;
  letter-spacing: -0.5px;
}

.qb-product-delivery {
  font-size: 11px;
  color: #999;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  margin-bottom: 10px;
}

.qb-product-btn {
  background: linear-gradient(135deg, var(--qb-purple) 0%, #6a0d9c 100%);
  color: white;
  border: none;
  padding: 11px 16px;
  border-radius: 8px;
  font-weight: 700;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  margin-top: auto;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  box-shadow: 0 4px 12px rgba(122, 20, 172, 0.2);
  position: relative;
  overflow: hidden;
}

.qb-product-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.2);
  transition: left 0.3s;
}

.qb-product-btn:hover {
  background: linear-gradient(135deg, #6a0d9c 0%, #5a0a8c 100%);
  box-shadow: 0 8px 20px rgba(122, 20, 172, 0.3);
  transform: translateY(-2px);
}

.qb-product-btn:hover::before {
  left: 100%;
}

.qb-product-btn:active {
  transform: translateY(0px);
}

/* Empty State */
.qb-empty {
  grid-column: 1 / -1;
  padding: 40px;
  text-align: center;
  color: #999;
}

/* Promotional Banners */
.qb-banners {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  padding: 12px;
  max-width: 1200px;
  margin: 0 auto;
}

@media(min-width: 768px) {
  .qb-banners {
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding: 32px 24px;
  }
}

@media(min-width: 1024px) {
  .qb-banners {
    padding: 40px 48px;
    gap: 24px;
  }
}

.qb-banner-item {
  position: relative;
  display: block;
  overflow: hidden;
  border-radius: 8px;
  text-decoration: none;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.qb-banner-item:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
}

.qb-banner-item img {
  width: 100%;
  height: auto;
  display: block;
}

/* Promotional Banners */
.qb-banners {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  padding: 12px;
  max-width: 1200px;
  margin: 0 auto;
}

@media(min-width: 768px) {
  .qb-banners {
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    padding: 32px 24px;
  }
}

@media(min-width: 1024px) {
  .qb-banners {
    gap: 24px;
    padding: 40px 48px;
  }
}
</style>

<div class="qb-hp">
  <!-- All Promotional Banners -->
  <div class="qb-banners">
    <!-- Original 4 Banners -->
    <a href="/collections/yeti-kafe" class="qb-banner-item">
      <img src="{{ 'hero-banner.png' | asset_url }}" alt="Yeti Kafe Collection">
    </a>
    <a href="/collections/farm-fresh" class="qb-banner-item">
      <img src="{{ 'banner-farm-fresh.png' | asset_url }}" alt="Farm Fresh - Get your daily essentials delivered">
    </a>
    <a href="/collections/pet-care" class="qb-banner-item">
      <img src="{{ 'banner-pet-care.png' | asset_url }}" alt="Pet Care - Everything Your Pet Loves Delivered">
    </a>
    <a href="/collections/baby-care" class="qb-banner-item">
      <img src="{{ 'banner-baby-care.png' | asset_url }}" alt="Baby Care - Made Easy">
    </a>

    <!-- New Collection Banners -->
    <a href="/collections/groceries" class="qb-banner-item">
      <img src="{{ 'banner-groceries.png' | asset_url }}" alt="Groceries - Buy 1 Get 1 Free">
    </a>
    <a href="/collections/clothes-washing" class="qb-banner-item">
      <img src="{{ 'banner-clothes-washing.png' | asset_url }}" alt="Clothes Washing - 24/7 Service">
    </a>
    <a href="/collections/vegetables" class="qb-banner-item">
      <img src="{{ 'banner-vegetables.png' | asset_url }}" alt="Vegetables - Fresh Farm Vegetables">
    </a>
    <a href="/collections/dairy" class="qb-banner-item">
      <img src="{{ 'banner-dairy.png' | asset_url }}" alt="Dairy Products - Milk, Yogurt, Butter">
    </a>
    <a href="/collections/snacks" class="qb-banner-item">
      <img src="{{ 'banner-snacks.png' | asset_url }}" alt="Snacks - Biscuits, Chips, Nuts, Chocolate">
    </a>
    <a href="/collections/oral-care" class="qb-banner-item">
      <img src="{{ 'banner-oral-care.png' | asset_url }}" alt="Oral Care - Toothpaste, Toothbrush, Mouthwash">
    </a>
    <a href="/collections/groceries" class="qb-banner-item">
      <img src="{{ 'banner-groceries-more.png' | asset_url }}" alt="Groceries & More - Order 24/7">
    </a>
    <a href="/collections/beer" class="qb-banner-item">
      <img src="{{ 'banner-beer.png' | asset_url }}" alt="Beer Month - Free Delivery">
    </a>
  </div>

  <!-- Flash Deals -->
  <section class="qb-section">
    <h2>⚡ Flash Deals</h2>
    <div class="qb-grid">
      {% assign collection = collections.all %}
      {% assign products = collection.products | sort: "created_at" | reverse | limit: 4 %}
      {% if products.size > 0 %}
        {% for product in products %}
          <a href="{{ product.url }}" class="qb-product">
            <div class="qb-product-img">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}">
              {% else %}
                💎
              {% endif %}
            </div>
            <div class="qb-product-info">
              <div class="qb-product-name">{{ product.title | truncatewords: 3 }}</div>
              <div class="qb-product-price">Rs {{ product.price | money_without_currency | remove: "Rs" | remove: "," }}</div>
              <div class="qb-product-delivery">⚡ 18-22 mins</div>
              <button type="button" class="qb-product-btn" onclick="fetch('{{ routes.cart_add_url }}', { method: 'POST', body: new FormData(Object.assign(document.createElement('form'), { innerHTML: '<input name=id value={{ product.variants.first.id }}><input name=quantity value=1>' })) }).then(() => window.location.href = '{{ routes.cart_url }}')">Add</button>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div class="qb-empty">No products available</div>
      {% endif %}
    </div>
  </section>

  <!-- Trending Now -->
  <section class="qb-section">
    <h2>🔥 Trending Now</h2>
    <div class="qb-product-grid">
      {% assign collection = collections.all %}
      {% assign trending = collection.products | sort: "created_at" | reverse | limit: 8 %}
      {% if trending.size > 0 %}
        {% for product in trending %}
          <a href="{{ product.url }}" class="qb-product">
            <div class="qb-product-img">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}">
              {% else %}
                🔥
              {% endif %}
            </div>
            <div class="qb-product-info">
              <div class="qb-product-name">{{ product.title | truncatewords: 3 }}</div>
              <div class="qb-product-price">Rs {{ product.price | money_without_currency | remove: "Rs" | remove: "," }}</div>
              <div class="qb-product-delivery">⚡ 17-21 mins</div>
              <button type="button" class="qb-product-btn" onclick="fetch('{{ routes.cart_add_url }}', { method: 'POST', body: new FormData(Object.assign(document.createElement('form'), { innerHTML: '<input name=id value={{ product.variants.first.id }}><input name=quantity value=1>' })) }).then(() => window.location.href = '{{ routes.cart_url }}')">Add</button>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div class="qb-empty">No products available</div>
      {% endif %}
    </div>
  </section>

  <!-- New Arrivals -->
  <section class="qb-section">
    <h2>✨ New Arrivals</h2>
    <div class="qb-product-grid">
      {% assign collection = collections.all %}
      {% assign new_arrivals = collection.products | sort: "created_at" | limit: 8 | offset: 8 %}
      {% if new_arrivals.size > 0 %}
        {% for product in new_arrivals %}
          <a href="{{ product.url }}" class="qb-product">
            <div class="qb-product-img">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}">
              {% else %}
                ✨
              {% endif %}
            </div>
            <div class="qb-product-info">
              <div class="qb-product-name">{{ product.title | truncatewords: 3 }}</div>
              <div class="qb-product-price">Rs {{ product.price | money_without_currency | remove: "Rs" | remove: "," }}</div>
              <div class="qb-product-delivery">⚡ 18-22 mins</div>
              <button type="button" class="qb-product-btn" onclick="fetch('{{ routes.cart_add_url }}', { method: 'POST', body: new FormData(Object.assign(document.createElement('form'), { innerHTML: '<input name=id value={{ product.variants.first.id }}><input name=quantity value=1>' })) }).then(() => window.location.href = '{{ routes.cart_url }}')">Add</button>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div class="qb-empty">No products available</div>
      {% endif %}
    </div>
  </section>

  <!-- Featured -->
  <section class="qb-section">
    <h2>⭐ Featured</h2>
    <div class="qb-grid">
      {% assign collection = collections.all %}
      {% assign featured = collection.products | sort: "created_at" | limit: 4 %}
      {% if featured.size > 0 %}
        {% for product in featured %}
          <a href="{{ product.url }}" class="qb-product">
            <div class="qb-product-img">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}">
              {% else %}
                ⭐
              {% endif %}
            </div>
            <div class="qb-product-info">
              <div class="qb-product-name">{{ product.title | truncatewords: 3 }}</div>
              <div class="qb-product-price">Rs {{ product.price | money_without_currency | remove: "Rs" | remove: "," }}</div>
              <div class="qb-product-delivery">⚡ 18-22 mins</div>
              <button type="button" class="qb-product-btn" onclick="fetch('{{ routes.cart_add_url }}', { method: 'POST', body: new FormData(Object.assign(document.createElement('form'), { innerHTML: '<input name=id value={{ product.variants.first.id }}><input name=quantity value=1>' })) }).then(() => window.location.href = '{{ routes.cart_url }}')">Add</button>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div class="qb-empty">No products available</div>
      {% endif %}
    </div>
  </section>
</div>
