// ── Category Pill Navigation ──────────────────────────
(function(){
  // Map: data-target → section ID (same value)
  var PILL_TARGETS = [
    'qb-beer-combos','qb-beer','qb-smokes',
    'qb-whiskey','qb-vodka','qb-imported'
  ];

  var pills = document.querySelectorAll('.qb-cat-pill[data-target]');
  if (!pills.length) return;

  // Click: smooth-scroll with header offset + set active
  pills.forEach(function(pill){
    pill.addEventListener('click', function(e){
      var targetId = pill.getAttribute('data-target');
      var section  = document.getElementById(targetId);
      if (!section) return; // let anchor fall through for non-section pills

      e.preventDefault();
      // Update active state immediately
      document.querySelectorAll('.qb-cat-pill').forEach(function(p){
        p.classList.remove('active');
      });
      pill.classList.add('active');
      // Scroll pills row so active pill is visible
      pill.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });

      // Scroll page to section (scroll-margin-top handles the offset via CSS)
      section.scrollIntoView({ behavior: 'smooth', block: 'start' });

      // Update URL hash without jumping
      if (history.replaceState) {
        history.replaceState(null, '', '#' + targetId);
      }
    });
  });

  // Intersection Observer: auto-highlight pill as user scrolls
  if (!window.IntersectionObserver) return;
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if (entry.isIntersecting){
        var id  = entry.target.id;
        var pill = document.querySelector('.qb-cat-pill[data-target="' + id + '"]');
        if (pill){
          document.querySelectorAll('.qb-cat-pill').forEach(function(p){ p.classList.remove('active'); });
          pill.classList.add('active');
          pill.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
        }
      }
    });
  }, { rootMargin: '-25% 0px -60% 0px', threshold: 0 });

  PILL_TARGETS.forEach(function(id){
    var el = document.getElementById(id);
    if (el) obs.observe(el);
  });

  // If page loaded with a hash, scroll to it after a tick
  (function(){
    var hash = window.location.hash && window.location.hash.slice(1);
    if (!hash) return;
    var section = document.getElementById(hash);
    if (!section) return;
    setTimeout(function(){
      section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 300);
  })();
})();
