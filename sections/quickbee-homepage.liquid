  /* Mobile: Stack to 2 columns */
  @media(max-width: 767px) {
    .qb-banners-perfect {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      padding: 12px;
    }
  }

  /* Tablet: 4 columns */
  @media(min-width: 768px) and (max-width: 1023px) {
    .qb-banners-perfect {
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      padding: 16px;
    }
  }

  /* Desktop: 4 columns */
  @media(min-width: 1024px) {
    .qb-banners-perfect {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      padding: 20px 16px;
    }
  }

  /* ROW 1: LARGE1 spans full width */
  .qb-banner-large1 {
    grid-column: 1 / -1;
  }

  /* ROW 2: 4 banner items (1 column each) */
  .qb-banner-row1 {
    grid-column: span 1;
  }

  .qb-banner-row2-small {
    grid-column: span 1;
  }

  /* ROW 3: hero-banner spans full width */
  .qb-banner-hero {
    grid-column: 1 / -1;
  }

  .qb-banner-row3-small {
    grid-column: span 1;
  }

  /* ROW 4: Large2 spans full width */
  .qb-banner-large2 {
    grid-column: 1 / -1;
  }

  /* Responsive adjustments */
  @media(max-width: 767px) {
    .qb-banner-large1,
    .qb-banner-hero,
    .qb-banner-large2 {
      grid-column: 1 / -1;
