}
.qb-dg-header {
  padding: 22px 16px 16px;
  display: flex;
  align-items: center;
  gap: 14px;
  position: relative;
  z-index: 2;
  border-bottom: 1px solid rgba(229,194,90,0.08);
}
.qb-dg-header::after {
  content: '🥩';
  position: absolute;
  right: 80px; top: 50%;
  transform: translateY(-50%) rotate(10deg);
  font-size: 72px;
  opacity: 0.05;
  pointer-events: none;
}
.qb-dg-logo {
  width: 66px; height: 66px;
  border-radius: 18px;
  background: linear-gradient(135deg, #0a1f0a, #162d16);
  border: 1.5px solid rgba(229,194,90,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 30px; flex-shrink: 0;
  box-shadow: 0 4px 20px rgba(0,0,0,0.6), 0 0 16px rgba(229,194,90,0.06);
}
.qb-dg-hinfo { flex: 1; min-width: 0; }
.qb-dg-open-dot {
  font-size: 10px; font-weight: 900; letter-spacing: 0.8px;
  text-transform: uppercase; color: #22c55e; margin-bottom: 4px;
  display: flex; align-items: center; gap: 5px;
}
.qb-dg-open-dot::before {
  content: '';
  width: 6px; height: 6px; border-radius: 50%;
  background: #22c55e; flex-shrink: 0;
  animation: dgOpenPulse 2s ease-in-out infinite;
}
@keyframes dgOpenPulse {
  0%,100% { box-shadow: 0 0 5px rgba(34,197,94,0.8); opacity: 1; }
  50%      { box-shadow: none; opacity: 0.5; }
}
.qb-dg-htitle {
  font-size: 20px; font-weight: 900; line-height: 1.1;
  background: linear-gradient(135deg, #e5c25a 0%, #f5dd88 55%, #c8a840 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 0 0 3px;
  letter-spacing: -0.4px;
  font-family: Georgia, 'Times New Roman', serif;
}
.qb-dg-hsub {
  font-size: 11px; color: rgba(229,194,90,0.5); margin: 0 0 9px;
}
.qb-dg-hpills { display: flex; flex-wrap: wrap; gap: 5px; }
.qb-dg-hpill {
  font-size: 10px; font-weight: 700;
  padding: 3px 8px; border-radius: 20px;
  background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.55);
}
.qb-dg-cta {
  flex-shrink: 0;
  padding: 10px 14px; border-radius: 12px;
  background: linear-gradient(135deg, #e5c25a, #c8a840);
  color: #0b1e10; font-size: 12px; font-weight: 900;
  text-decoration: none; white-space: nowrap;
  box-shadow: 0 3px 12px rgba(229,194,90,0.28);
  transition: transform .15s, box-shadow .15s;
}
.qb-dg-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(229,194,90,0.45); }
/* Slider override — dark bg */
.qb-dg-slider-wrap {
  position: relative;
  z-index: 2;
}
.qb-dg-sect .qb-combo-slider-outer {
  background: transparent;
}
.qb-dg-sect .qb-combo-track {
  padding-top: 14px;
  padding-bottom: 4px;
}
/* Dhido cards: always dark green regardless of theme */
.qb-dg-sect .qb-combo-card,
html:not([data-theme="dark"]) .qb-dg-sect .qb-combo-card {
  background: rgba(229,194,90,0.04) !important;
