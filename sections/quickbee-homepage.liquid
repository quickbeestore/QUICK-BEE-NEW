  {% assign food_products = collections['typical-taste'].products %}
  {% if food_products.size > 0 %}
  <section class="qb-combo-slider-section" id="qb-food">
    <div class="qb-combo-slider-header">
      <div class="qb-combo-slider-title-wrap">
        <span class="qb-combo-fire-icon">🍖</span>
        <div>
          <h2 class="qb-combo-title">Typical Taste</h2>
          <p class="qb-combo-subtitle">The Dhido & The Grills · Authentic Nepali</p>
        </div>
      </div>
      <a href="/collections/typical-taste" class="qb-combo-view-all">View All <span>→</span></a>
    </div>
    <div class="qb-combo-slider-outer">
      <button class="qb-combo-arrow qb-combo-arrow-left" id="qbFoodPrev" aria-label="Previous">&#8249;</button>
      <div class="qb-combo-track" id="qbFoodTrack">
        {% for product in food_products %}
          {%- assign c_disc = false -%}{%- assign c_pct = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign c_disc = true -%}
            {%- assign c_sav = product.compare_at_price | minus: product.price -%}
            {%- assign c_pct = c_sav | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}
          {%- assign ptl = product.title | downcase -%}
          {%- assign food_ico = '🍽️' -%}
          {%- if ptl contains 'momo' -%}{%- assign food_ico = '🥟' -%}
          {%- elsif ptl contains 'grill' or ptl contains 'sekuwa' -%}{%- assign food_ico = '🥩' -%}
          {%- elsif ptl contains 'burger' -%}{%- assign food_ico = '🍔' -%}
          {%- elsif ptl contains 'noodle' or ptl contains 'thukpa' -%}{%- assign food_ico = '🍜' -%}
          {%- elsif ptl contains 'chicken' -%}{%- assign food_ico = '🍗' -%}
          {%- elsif ptl contains 'biryani' or ptl contains 'rice' -%}{%- assign food_ico = '🍛' -%}
          {%- endif -%}
          <a href="{{ product.url }}" class="qb-combo-card">
            <div class="qb-combo-img-wrap">
              {% if c_disc %}<div class="qb-combo-off-badge">{{ c_pct }}% OFF</div>{% endif %}
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}" loading="lazy">
              {% else %}
                <div class="qb-combo-no-img">{{ food_ico }}</div>
              {% endif %}
              <div class="qb-combo-delivery-badge">⚡ 18-22 MINS</div>
            </div>
            <div class="qb-combo-info">
              <div class="qb-combo-product-name">{{ product.title }}</div>
              <div class="qb-combo-price-row">
                <div class="qb-combo-price-col">
                  <span class="qb-combo-price">Rs {{ product.price | divided_by: 100 }}</span>
                  {% if c_disc %}<span class="qb-combo-old-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>{% endif %}
                </div>
                <button class="qb-combo-add-btn" onclick="event.preventDefault();event.stopPropagation();qbAddToCart({{ product.variants.first.id }},this)">+</button>
              </div>
            </div>
          </a>
        {% endfor %}
      </div>
      <button class="qb-combo-arrow qb-combo-arrow-right" id="qbFoodNext" aria-label="Next">&#8250;</button>
    </div>
    <div class="qb-combo-dots" id="qbFoodDots"></div>
  </section>
  {% endif %}

