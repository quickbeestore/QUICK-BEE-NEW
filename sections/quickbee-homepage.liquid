</div>

<style>
  .qb-popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    z-index: 1000000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    backdrop-filter: blur(10px);
  }

  .qb-popup-content {
    position: relative;
    max-width: 420px;
    width: 100%;
    background: var(--qb-dark3);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(244,180,0,0.15), 0 25px 50px rgba(0,0,0,0.7);
