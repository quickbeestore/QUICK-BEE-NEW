.qb-dg-sect .qb-combo-arrow:hover {
  background: rgba(229,194,90,0.2);
  border-color: rgba(229,194,90,0.4);
}

/* ══════════════════════════════════════════════════════
   ⚡ HOW IT WORKS
══════════════════════════════════════════════════════ */
.qb-hiw-section {
  padding: 32px 16px 28px; text-align: center;
  background: linear-gradient(180deg,
    var(--theme-bg-primary) 0%,
    color-mix(in srgb, var(--theme-bg-primary) 92%, #F4B400 8%) 50%,
    var(--theme-bg-primary) 100%);
}
.qb-hiw-eyebrow {
  font-size: 11px; font-weight: 800; letter-spacing: 2px;
  text-transform: uppercase; color: #F4B400; margin-bottom: 8px;
}
.qb-hiw-title {
  font-size: 24px; font-weight: 900; color: var(--theme-text-main);
  margin-bottom: 4px; line-height: 1.2; letter-spacing: -0.5px;
}
.qb-hiw-sub {
  font-size: 13px; color: var(--theme-text-muted); margin-bottom: 28px;
}
.qb-hiw-steps {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 12px; max-width: 600px; margin: 0 auto;
}
.qb-hiw-step {
  position: relative; display: flex; flex-direction: column;
  align-items: center; gap: 10px;
}
.qb-hiw-step:not(:last-child)::after {
  content: '···'; position: absolute; top: 24px; left: calc(50% + 32px);
  width: calc(100% - 64px); color: rgba(244,180,0,0.25);
  font-size: 18px; letter-spacing: 2px; pointer-events: none;
  display: none;
}
@media(min-width:400px){ .qb-hiw-step:not(:last-child)::after { display: block; } }
.qb-hiw-ico {
  width: 62px; height: 62px; border-radius: 20px;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; position: relative;
  background: rgba(244,180,0,0.07);
  border: 1.5px solid rgba(244,180,0,0.18);
  box-shadow: 0 4px 16px rgba(0,0,0,0.2);
}
.qb-hiw-step:nth-child(1) .qb-hiw-ico { animation: hiwBounce 3.5s ease-in-out infinite; }
.qb-hiw-step:nth-child(2) .qb-hiw-ico { animation: hiwBounce 3.5s ease-in-out 1.1s infinite; }
.qb-hiw-step:nth-child(3) .qb-hiw-ico { animation: hiwBounce 3.5s ease-in-out 2.2s infinite; }
@keyframes hiwBounce {
  0%,100%{transform:translateY(0)} 40%{transform:translateY(-6px)} 60%{transform:translateY(-4px)}
}
.qb-hiw-num {
  position: absolute; top: -6px; right: -6px; width: 20px; height: 20px;
  background: #F4B400; color: #000; border-radius: 50%;
  font-size: 10px; font-weight: 900; display: flex; align-items: center; justify-content: center;
}
.qb-hiw-label { font-size: 12px; font-weight: 800; color: var(--theme-text-main); }
.qb-hiw-desc { font-size: 10px; color: var(--theme-text-muted); line-height: 1.5; }

/* ══════════════════════════════════════════════════════
   ⭐ CUSTOMER REVIEWS STRIP
══════════════════════════════════════════════════════ */
/* ══════════════════════════════════════════════════════
   ⭐ REVIEWS — full redesign
══════════════════════════════════════════════════════ */
.qb-reviews-section { padding: 24px 0 28px; overflow: hidden; }

/* Header */
.qb-reviews-header { padding: 0 16px 20px; }
.qb-reviews-header-top {
  display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 14px;
}
.qb-reviews-title {
  font-size: 20px; font-weight: 900; color: var(--theme-text-main); line-height: 1.2;
  letter-spacing: -0.3px;
}
.qb-reviews-sub { font-size: 12px; color: var(--theme-text-muted); margin-top: 3px; }

/* Rating pill — right side */
.qb-reviews-avg {
  flex-shrink: 0;
  display: flex; flex-direction: column; align-items: center;
  padding: 10px 14px; border-radius: 16px;
  background: linear-gradient(135deg,rgba(244,180,0,0.12),rgba(244,180,0,0.06));
  border: 1px solid rgba(244,180,0,0.25);
}
.qb-reviews-avg-num {
  font-size: 24px; font-weight: 900; color: #F4B400; line-height: 1;
}
.qb-reviews-avg-stars { font-size: 10px; color: #F4B400; letter-spacing: 2px; margin: 3px 0 2px; }
.qb-reviews-avg-lbl { font-size: 9px; font-weight: 600; color: rgba(244,180,0,0.6); white-space: nowrap; }

/* Social proof bar */
.qb-reviews-proof {
  display: flex; align-items: center; gap: 16px;
  padding: 10px 14px; border-radius: 12px;
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
}
.qb-reviews-proof-item {
  display: flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 700; color: var(--theme-text-muted);
}
.qb-reviews-proof-dot { width: 4px; height: 4px; border-radius: 50%; background: rgba(255,255,255,0.2); }

/* Tracks */
.qb-reviews-track-wrap { overflow: hidden; }
.qb-reviews-track {
  display: flex; gap: 12px; padding: 6px 16px 6px;
  width: max-content;
  animation: reviewsScroll 38s linear infinite;
}
.qb-reviews-track:hover { animation-play-state: paused; }
@keyframes reviewsScroll {
  0%{transform:translateX(0)} 100%{transform:translateX(-50%)}
}
.qb-reviews-track-rtl { animation-name: reviewsScrollRTL; }
@keyframes reviewsScrollRTL {
  0%{transform:translateX(-50%)} 100%{transform:translateX(0)}
}

/* Cards */
.qb-rv-card {
  width: 240px; flex-shrink: 0; padding: 16px;
  background: var(--theme-bg-secondary);
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.07);
  display: flex; flex-direction: column; gap: 10px;
  position: relative; overflow: hidden;
}
.qb-rv-card::before {
  content: '"'; position: absolute; top: 6px; right: 14px;
  font-size: 52px; font-family: Georgia, serif; color: rgba(244,180,0,0.08);
  line-height: 1; pointer-events: none;
}

/* Stars row */
.qb-rv-stars-row { display: flex; align-items: center; justify-content: space-between; }
.qb-rv-stars {
  display: flex; gap: 2px;
}
.qb-rv-star {
  width: 13px; height: 13px;
}
.qb-rv-star svg { width: 13px; height: 13px; display: block; }
.qb-rv-verified {
  font-size: 9px; font-weight: 700; color: #4ade80;
  background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.2);
  padding: 2px 6px; border-radius: 99px;
  display: flex; align-items: center; gap: 3px;
}
.qb-rv-verified::before { content: '✓'; }

/* Text */
.qb-rv-text {
  font-size: 12.5px; color: var(--theme-text-muted); line-height: 1.65;
  flex: 1; display: -webkit-box; -webkit-line-clamp: 4;
  -webkit-box-orient: vertical; overflow: hidden;
}

/* Author */
.qb-rv-author { display: flex; align-items: center; gap: 9px; margin-top: 2px; }
.qb-rv-avatar {
  width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 900; color: #fff;
  box-shadow: 0 0 0 2px rgba(255,255,255,0.1);
}
.qb-rv-name { font-size: 12px; font-weight: 800; color: var(--theme-text-main); line-height: 1.2; }
.qb-rv-meta { font-size: 10px; color: var(--theme-text-muted); margin-top: 1px; }

/* ── Custom Magazine Announcement ── */
.qb-mag-announce {
  padding: 6px 12px;
  margin-bottom: 4px;
}
@media(min-width:640px){ .qb-mag-announce { padding: 8px 24px; } }
.qb-mag-announce-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  background: linear-gradient(135deg, #0d0d0d 0%, #1a1a2e 60%, #16213e 100%);
  border-radius: 20px;
  padding: 28px 24px 28px 28px;
  text-decoration: none;
  overflow: hidden;
  position: relative;
  border: 1px solid rgba(244,180,0,0.2);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  box-shadow: 0 4px 24px rgba(0,0,0,0.25);
}
.qb-mag-announce-inner::before {
  content: '';
  position: absolute;
  top: -60px; left: -40px;
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(244,180,0,0.12) 0%, transparent 70%);
  pointer-events: none;
}
.qb-mag-announce-inner:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.35);
}
.qb-mag-announce-left {
  flex: 1;
}
.qb-mag-announce-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(244,180,0,0.15);
  border: 1px solid rgba(244,180,0,0.3);
  color: #F4B400;
  border-radius: 999px;
  padding: 3px 11px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.qb-mag-announce-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(1.4rem, 4vw, 2rem);
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 8px;
}
.qb-mag-announce-title em {
  color: #F4B400;
  font-style: italic;
}
.qb-mag-announce-sub {
  font-size: 13px;
  color: rgba(255,255,255,0.55);
  line-height: 1.5;
  margin-bottom: 18px;
  max-width: 340px;
}
.qb-mag-announce-cta {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: #F4B400;
  color: #000;
  font-weight: 800;
  font-size: 13px;
  padding: 10px 20px;
  border-radius: 999px;
  box-shadow: 0 3px 14px rgba(244,180,0,0.4);
  transition: transform 0.15s ease;
}
.qb-mag-announce-inner:hover .qb-mag-announce-cta {
  transform: translateX(3px);
}
.qb-mag-announce-right {
  flex-shrink: 0;
}
.qb-mag-announce-mockup {
  width: 80px;
}
@media(min-width:480px){ .qb-mag-announce-mockup { width: 110px; } }
.qb-mag-mock-cover {
  width: 100%;
  aspect-ratio: 3/4;
  background: linear-gradient(160deg, #1e2a3a, #0f1e30);
  border-radius: 8px;
  border: 2px solid rgba(244,180,0,0.35);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow: 4px 6px 20px rgba(0,0,0,0.5), -2px -2px 0 rgba(244,180,0,0.1);
  position: relative;
  overflow: hidden;
}
.qb-mag-mock-cover::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: #F4B400;
}
.qb-mag-mock-lines {
  display: flex;
  flex-direction: column;
  gap: 5px;
  width: 60%;
}
.qb-mag-mock-lines div {
  height: 3px;
  border-radius: 2px;
  background: rgba(255,255,255,0.15);
