  padding: 12px;
  transition: transform 0.3s ease;
}

.qb-carousel-card:hover .qb-carousel-image-wrap img {
  transform: scale(1.08);
}

.qb-no-image {
  font-size: 48px;
  color: #ddd;
}

.qb-carousel-badge {
  position: absolute;
  bottom: 12px;
  right: 12px;
  background: linear-gradient(135deg, #F4B400 0%, #FFB300 100%);
  color: #1a1a1a;
