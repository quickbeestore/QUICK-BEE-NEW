<!-- QuickBee Homepage - Zepto-Inspired Minimal Design -->
<style>
:root {
  --qb-purple: #7a14ac;
  --qb-black: #111111;
  --qb-white: #ffffff;
  --qb-light: #f5f5f5;
  --qb-border: #e5e5e5;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }

.qb-hp {
  background: var(--qb-white);
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* Hero */
.qb-hero {
  background: linear-gradient(135deg, #f8f9fa 0%, #f0f0f0 100%);
  padding: 40px 20px;
  text-align: center;
  border-bottom: 1px solid var(--qb-border);
}

@media(min-width: 1024px) { .qb-hero { padding: 60px 48px; } }

.qb-hero h1 {
  font-size: 32px;
  font-weight: 800;
  color: var(--qb-black);
  margin-bottom: 12px;
}

@media(min-width: 1024px) { .qb-hero h1 { font-size: 48px; } }

.qb-hero p {
  font-size: 16px;
  color: #666;
  margin-bottom: 24px;
}

.qb-search {
  max-width: 500px;
  margin: 0 auto;
  display: flex;
  gap: 8px;
}

.qb-search input {
  flex: 1;
  padding: 14px 16px;
  border: 1px solid var(--qb-border);
  border-radius: 8px;
  font-size: 14px;
}

.qb-search button {
  background: var(--qb-purple);
  color: white;
  border: none;
  padding: 14px 24px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
}

/* Categories */
.qb-categories {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  padding: 24px;
  max-width: 1200px;
  margin: 0 auto;
}

@media(min-width: 768px) { .qb-categories { grid-template-columns: repeat(4, 1fr); gap: 16px; padding: 32px 24px; } }

@media(min-width: 1024px) { .qb-categories { grid-template-columns: repeat(6, 1fr); gap: 20px; padding: 40px 48px; } }

.qb-cat-btn {
  padding: 16px;
  border: 1px solid var(--qb-border);
  border-radius: 12px;
  background: white;
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
  color: var(--qb-black);
  font-weight: 600;
  font-size: 14px;
  text-align: center;
}

.qb-cat-btn:hover {
  border-color: var(--qb-purple);
  background: rgba(122, 20, 172, 0.05);
}

.qb-cat-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

/* Product Sections */
.qb-section {
  padding: 36px 16px;
  border-bottom: 1px solid #f5f5f5;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
}

.qb-section:last-of-type {
  border-bottom: none;
}

@media(min-width: 640px) {
  .qb-section {
    padding: 40px 24px;
  }
}

@media(min-width: 1024px) {
  .qb-section {
    padding: 52px 48px;
  }
}

.qb-section h2 {
  font-size: 26px;
  font-weight: 900;
  margin-bottom: 28px;
  color: var(--qb-black);
  letter-spacing: -0.3px;
  position: relative;
  display: flex;
  align-items: center;
  gap: 10px;
}

.qb-section h2::after {
  content: '';
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, var(--qb-purple) 0%, transparent 100%);
  margin-left: 8px;
  max-width: 60px;
}

/* Professional Masonry Grid */
.qb-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin-bottom: 16px;
}

/* Mobile: Single column */
@media(max-width: 767px) {
  .qb-grid {
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .qb-product {
    min-height: 280px;
  }
}

/* Tablet: 2-column masonry */
@media(min-width: 768px) {
  .qb-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    grid-auto-rows: 260px;
  }

  /* Random sizes - every 5th, 7th, 11th product is tall */
  .qb-product:nth-child(5n) {
    grid-row: span 2;
    min-height: auto;
  }

  .qb-product:nth-child(7n) {
    grid-column: span 1;
  }

  /* Wide product - every 11th */
  .qb-product:nth-child(11n) {
    grid-row: span 2;
  }
}

/* Desktop: 4-column advanced masonry */
@media(min-width: 1024px) {
  .qb-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    grid-auto-rows: 240px;
  }

  /* Create visual variety with random spans */
  .qb-product:nth-child(3n) {
    grid-row: span 2;
    grid-column: span 1;
  }

  .qb-product:nth-child(5n) {
    grid-column: span 2;
    grid-row: span 1;
  }

  .qb-product:nth-child(7n) {
    grid-row: span 2;
    grid-column: span 2;
  }

  .qb-product:nth-child(11n) {
    grid-column: span 1;
    grid-row: span 2;
  }
}

/* Product Grid - 2x3 mobile, 4x2 desktop */
.qb-product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 16px;
  padding: 16px;
}

/* Product Card Styling - Matches Search Results Design */
.qb-product-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.2s ease;
  cursor: pointer;
  height: 100%;
  position: relative;
}

.qb-product-card:hover {
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  transform: translateY(-2px);
}

.qb-product-image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  background: #f5f5f5;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qb-product-image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform 0.3s ease;
}

.qb-product-card:hover .qb-product-image-wrap img {
  transform: scale(1.05);
}

.qb-delivery-badge {
  position: absolute;
  bottom: 8px;
  right: 8px;
  background: rgba(196, 30, 58, 0.95);
  color: white;
  padding: 6px 10px;
  border-radius: 16px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  z-index: 10;
  backdrop-filter: blur(4px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  animation: badgePulse 2s ease-in-out infinite;
}

@keyframes badgePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.qb-product-name {
  font-size: 14px;
  font-weight: 600;
  padding: 8px 12px 4px;
  margin: 0;
  line-height: 1.3;
  color: #111;
  height: 40px;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.qb-product-price {
  font-size: 16px;
  font-weight: 700;
  color: #7a14ac;
  padding: 0 12px 8px;
}

.qb-qty-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 0 12px 8px;
}

.qb-qty-btn {
  width: 28px;
  height: 28px;
  border: 1px solid #ddd;
  background: white;
  border-radius: 4px;
  cursor: pointer;
  font-weight: bold;
  transition: all 0.2s;
}

.qb-qty-btn:hover {
  border-color: #7a14ac;
  color: #7a14ac;
}

.qb-qty-input {
  width: 50px;
  text-align: center;
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 6px;
  font-size: 14px;
}

.qb-add-btn {
  width: calc(100% - 24px);
  margin: 0 12px 12px;
  padding: 10px;
  background: #7a14ac;
  color: white;
  border: none;
  border-radius: 6px;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
}

.qb-add-btn:hover {
  background: #5a0d8c;
  transform: translateY(-1px);
}

@media(max-width: 767px) {
  .qb-product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    padding: 12px;
  }

  .qb-product-card {
    border-radius: 6px;
  }

  .qb-product-name {
    font-size: 13px;
    padding: 6px 10px 3px;
  }

  .qb-product-price {
    font-size: 14px;
    padding: 0 10px 6px;
  }

  .qb-qty-selector {
    padding: 0 10px 6px;
    gap: 6px;
  }

  .qb-qty-btn {
    width: 24px;
    height: 24px;
    font-size: 12px;
  }

  .qb-qty-input {
    width: 40px;
    font-size: 12px;
    padding: 4px;
  }

  .qb-add-btn {
    width: calc(100% - 20px);
    margin: 0 10px 10px;
    padding: 8px;
    font-size: 12px;
  }
}

@media(min-width: 768px) and (max-width: 1023px) {
  .qb-product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    padding: 14px;
  }
}

@media(min-width: 1024px) {
  .qb-product-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    padding: 20px;
  }
}

.qb-product {
  border: none;
  border-radius: 16px;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  background: white;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  position: relative;
  height: 100%;
}

.qb-product::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(122, 20, 172, 0.1) 0%, rgba(122, 20, 172, 0) 100%);
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

.qb-product:hover {
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
  transform: translateY(-8px);
  border-color: transparent;
}

.qb-product:hover::before {
  opacity: 1;
}

.qb-product-img {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 48px;
  position: relative;
  flex-shrink: 0;
}

.qb-product-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}

.qb-product:hover .qb-product-img img {
  transform: scale(1.05);
}

.qb-product-info {
  padding: 14px;
  flex: 1;
  display: flex;
  flex-direction: column;
  background: white;
  position: relative;
  z-index: 2;
  min-height: 120px;
  justify-content: space-between;
}

.qb-product-name {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 6px;
  line-height: 1.4;
  color: var(--qb-black);
  text-transform: capitalize;
  letter-spacing: 0.2px;
}

.qb-product-price {
  font-size: 17px;
  font-weight: 900;
  color: var(--qb-purple);
  margin-bottom: 8px;
  letter-spacing: -0.5px;
}

.qb-product-delivery {
  font-size: 11px;
  color: #999;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  margin-bottom: 10px;
}

.qb-product-btn {
  background: linear-gradient(135deg, var(--qb-purple) 0%, #6a0d9c 100%);
  color: white;
  border: none;
  padding: 11px 16px;
  border-radius: 8px;
  font-weight: 700;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  margin-top: auto;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  box-shadow: 0 4px 12px rgba(122, 20, 172, 0.2);
  position: relative;
  overflow: hidden;
}

.qb-product-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.2);
  transition: left 0.3s;
}

.qb-product-btn:hover {
  background: linear-gradient(135deg, #6a0d9c 0%, #5a0a8c 100%);
  box-shadow: 0 8px 20px rgba(122, 20, 172, 0.3);
  transform: translateY(-2px);
}

.qb-product-btn:hover::before {
  left: 100%;
}

.qb-product-btn:active {
  transform: translateY(0px);
}

/* Empty State */
.qb-empty {
  grid-column: 1 / -1;
  padding: 40px;
  text-align: center;
  color: #999;
}

/* Promotional Banners */
.qb-banners {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  padding: 12px;
  max-width: 1200px;
  margin: 0 auto;
}

@media(min-width: 768px) {
  .qb-banners {
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding: 32px 24px;
  }
}

@media(min-width: 1024px) {
  .qb-banners {
    padding: 40px 48px;
    gap: 24px;
  }
}

.qb-banner-item {
  position: relative;
  display: block;
  overflow: hidden;
  border-radius: 8px;
  text-decoration: none;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.qb-banner-item:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
}

.qb-banner-item img {
  width: 100%;
  height: auto;
  display: block;
}

/* Promotional Banners */
.qb-banners {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  padding: 12px;
  max-width: 1200px;
  margin: 0 auto;
}

@media(min-width: 768px) {
  .qb-banners {
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    padding: 32px 24px;
  }
}

@media(min-width: 1024px) {
  .qb-banners {
    gap: 24px;
    padding: 40px 48px;
  }
}
</style>

<style>
  /* Perfect 5-Column Banner Grid (Mobile-First) */
  .qb-banners-perfect {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    padding: 12px;
    max-width: 1200px;
    margin: 0 auto;
    auto-rows: auto;
  }

  /* Mobile: Stack to 2 columns */
  @media(max-width: 767px) {
    .qb-banners-perfect {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      padding: 8px;
    }
  }

  /* Tablet: 3 columns */
  @media(min-width: 768px) and (max-width: 1023px) {
    .qb-banners-perfect {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      padding: 16px;
    }
  }

  /* Desktop: 5 columns (full grid) */
  @media(min-width: 1024px) {
    .qb-banners-perfect {
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      padding: 20px;
    }
  }

  /* ROW 1: Square images (1 column each) */
  .qb-banner-row1 {
    grid-column: span 1;
  }

  /* ROW 2: LARGE1 spans 3 cols, then 2 squares */
  .qb-banner-large1 {
    grid-column: span 3;
  }

  .qb-banner-row2-small {
    grid-column: span 1;
  }

  /* ROW 3: hero-banner spans 3 cols, then 2 squares */
  .qb-banner-hero {
    grid-column: span 3;
  }

  .qb-banner-row3-small {
    grid-column: span 1;
  }

  /* ROW 4: Largee spans full width (5 cols) */
  .qb-banner-large2 {
    grid-column: span 5;
  }

  /* Responsive adjustments */
  @media(max-width: 767px) {
    .qb-banner-large1,
    .qb-banner-hero,
    .qb-banner-large2 {
      grid-column: span 2;
    }
  }

  @media(min-width: 768px) and (max-width: 1023px) {
    .qb-banner-large1,
    .qb-banner-hero {
      grid-column: span 2;
    }
    .qb-banner-large2 {
      grid-column: span 3;
    }
  }

  .qb-banner-item {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .qb-banner-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .qb-banner-item img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
</style>

<div class="qb-hp">
  <!-- PERFECT 5-COLUMN GRID LAYOUT -->
  <div class="qb-banners-perfect">

    <!-- ROW 1: LARGE1 (spans full width - on top) -->
    <a href="/collections/all" class="qb-banner-item qb-banner-large1" style="grid-column: 1 / -1;">
      <img src="{{ 'LARGE1.png' | asset_url }}" alt="Exclusive Offer">
    </a>

    <!-- ROW 2: 4 BANNERS (1x4 grid) -->
    <a href="/collections/all" class="qb-banner-item qb-banner-row1">
      <img src="{{ 'smallsss.png' | asset_url }}" alt="Featured Collection">
    </a>
    <a href="/collections/baby-care" class="qb-banner-item qb-banner-row1">
      <img src="{{ 'banner-baby-care.png' | asset_url }}" alt="Baby Care">
    </a>
    <a href="/collections/pet-care" class="qb-banner-item qb-banner-row1">
      <img src="{{ 'banner-pet-care.png' | asset_url }}" alt="Pet Care">
    </a>
    <a href="/collections/all" class="qb-banner-item qb-banner-row1">
      <img src="{{ 'hero-banner.png' | asset_url }}" alt="Hero Banner">
    </a>

    <!-- ROW 3: Largee (spans full width) -->
    <a href="/collections/all" class="qb-banner-item qb-banner-large2" style="grid-column: 1 / -1;">
      <img src="{{ 'Largee.png' | asset_url }}" alt="Special Collection">
    </a>

  </div>

  <!-- Yeti Kafe -->
  <section class="qb-section">
    <h2>☕ Yeti Kafe</h2>
    <div class="qb-product-grid">
      {% assign products = collections.yeti-kafe.products | limit: 4 %}
      {% if products.size > 0 %}
        {% for product in products %}
          <div class="qb-product-card">
            <div class="qb-product-image-wrap" style="cursor: pointer;" data-product-url="{{ product.url }}">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '300x300' }}" alt="{{ product.title }}" class="qb-product-image" style="cursor: pointer;">
              {% else %}
                <div style="width:100%; height:100%; background:#f5f5f5; display:flex; align-items:center; justify-content:center; color:#999;">No Image</div>
              {% endif %}
              <div class="qb-delivery-badge">⚡ 16-21 mins</div>
            </div>
            <h3 class="qb-product-name">{{ product.title }}</h3>
            <div class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</div>
            <div class="qb-qty-selector">
              <button class="qb-qty-btn">−</button>
              <input type="number" class="qb-qty-input" value="1" min="1">
              <button class="qb-qty-btn">+</button>
            </div>
            <form action="/cart/add" method="post" class="product-form">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button type="submit" class="qb-add-btn">ADD TO CART</button>
            </form>
          </div>
        {% endfor %}
      {% else %}
        <div class="qb-empty">No products available</div>
      {% endif %}
    </div>
  </section>

  <!-- Farm Fresh -->
  <section class="qb-section">
    <h2>🥕 Farm Fresh</h2>
    <div class="qb-product-grid">
      {% assign new_arrivals = collections.farm-fresh.products | limit: 4 %}
      {% if new_arrivals.size > 0 %}
        {% for product in new_arrivals %}
          <div class="qb-product-card">
            <div class="qb-product-image-wrap" style="cursor: pointer;" data-product-url="{{ product.url }}">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '300x300' }}" alt="{{ product.title }}" class="qb-product-image" style="cursor: pointer;">
              {% else %}
                <div style="width:100%; height:100%; background:#f5f5f5; display:flex; align-items:center; justify-content:center; color:#999;">No Image</div>
              {% endif %}
              <div class="qb-delivery-badge">⚡ 16-21 mins</div>
            </div>
            <h3 class="qb-product-name">{{ product.title }}</h3>
            <div class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</div>
            <div class="qb-qty-selector">
              <button class="qb-qty-btn">−</button>
              <input type="number" class="qb-qty-input" value="1" min="1">
              <button class="qb-qty-btn">+</button>
            </div>
            <form action="/cart/add" method="post" class="product-form">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button type="submit" class="qb-add-btn">ADD TO CART</button>
            </form>
          </div>
        {% endfor %}
      {% else %}
        <div class="qb-empty">No products available</div>
      {% endif %}
    </div>
  </section>

  <!-- Pet Care -->
  <section class="qb-section">
    <h2>🐕 Pet Care</h2>
    <div class="qb-product-grid">
      {% assign featured = collections.pet-care.products | limit: 4 %}
      {% if featured.size > 0 %}
        {% for product in featured %}
          <div class="qb-product-card">
            <div class="qb-product-image-wrap" style="cursor: pointer;" data-product-url="{{ product.url }}">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '300x300' }}" alt="{{ product.title }}" class="qb-product-image" style="cursor: pointer;">
              {% else %}
                <div style="width:100%; height:100%; background:#f5f5f5; display:flex; align-items:center; justify-content:center; color:#999;">No Image</div>
              {% endif %}
              <div class="qb-delivery-badge">⚡ 16-21 mins</div>
            </div>
            <h3 class="qb-product-name">{{ product.title }}</h3>
            <div class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</div>
            <div class="qb-qty-selector">
              <button class="qb-qty-btn">−</button>
              <input type="number" class="qb-qty-input" value="1" min="1">
              <button class="qb-qty-btn">+</button>
            </div>
            <form action="/cart/add" method="post" class="product-form">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button type="submit" class="qb-add-btn">ADD TO CART</button>
            </form>
          </div>
        {% endfor %}
      {% else %}
        <div class="qb-empty">No products available</div>
      {% endif %}
    </div>
  </section>

