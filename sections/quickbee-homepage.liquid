    <!-- Slider Track -->
    <div class="qb-combo-slider-outer">
      <button class="qb-combo-arrow qb-combo-arrow-left" id="qbBeerPrev" aria-label="Previous">&#8249;</button>
      <div class="qb-combo-track" id="qbBeerTrack">
        {% for product in beer_combos %}
          {%- assign combo_discount = false -%}
          {%- assign combo_pct = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign combo_discount = true -%}
            {%- assign combo_savings = product.compare_at_price | minus: product.price -%}
            {%- assign combo_pct = combo_savings | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}
          <a href="{{ product.url }}" class="qb-combo-card">
            <div class="qb-combo-img-wrap">
              {% if combo_discount %}
                <div class="qb-combo-off-badge">{{ combo_pct }}% OFF</div>
              {% endif %}
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}" loading="lazy">
              {% else %}
                <div class="qb-combo-no-img">🍺</div>
              {% endif %}
              <div class="qb-combo-delivery-badge">⚡ 18-22 MINS</div>
            </div>
            <div class="qb-combo-info">
              <div class="qb-combo-product-name">{{ product.title }}</div>
              <div class="qb-combo-price-row">
                <div class="qb-combo-price-col">
                  <span class="qb-combo-price">Rs {{ product.price | divided_by: 100 }}</span>
                  {% if combo_discount %}
                    <span class="qb-combo-old-price">Rs {{ product.compare_at_price | divided_by: 100 }}</span>
                  {% endif %}
                </div>
                <button class="qb-combo-add-btn" onclick="event.preventDefault();event.stopPropagation();
                  var btn=this;
                  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},
                  body:JSON.stringify({items:[{id:{{ product.variants.first.id }},quantity:1}]})})
                  .then(function(){btn.textContent='✓';btn.style.background='#22c55e';
                  setTimeout(function(){btn.textContent='+';btn.style.background='';},1500)})">+</button>
              </div>
            </div>
          </a>
        {% endfor %}
      </div>
      <button class="qb-combo-arrow qb-combo-arrow-right" id="qbBeerNext" aria-label="Next">&#8250;</button>
    </div>

    <!-- Dots -->
    <div class="qb-combo-dots" id="qbBeerDots"></div>

  </section>
