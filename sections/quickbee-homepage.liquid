function qbAddToCart(variantId, btn) {
  if (!variantId || !btn) return;
  var orig = btn.innerHTML;
  btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';
  btn.disabled = true;
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    btn.innerHTML = '✓';
    btn.style.background = '#22c55e';
    btn.style.boxShadow = '0 4px 12px rgba(34,197,94,0.4)';
    // ── Update cart count live ──
    fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var el = document.getElementById('cart-count');
        if (el) el.textContent = cart.item_count;
      });
    // ── Update cart count ──
    document.dispatchEvent(new CustomEvent('cart:updated'));
    setTimeout(function() {
      btn.innerHTML = '+';
      btn.style.background = '';
      btn.style.boxShadow = '';
      btn.disabled = false;
    }, 1800);
    document.dispatchEvent(new CustomEvent('cart:updated'));
  })
  .catch(function() {
    btn.innerHTML = orig;
    btn.disabled = false;
  });
}

