              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '1080x1080', crop: 'center' }}" alt="{{ product.title }}" class="qb-product-image" style="cursor: pointer;">
              {% else %}
                <div style="width:100%;height:100%;background:var(--qb-dark4);display:flex;align-items:center;justify-content:center;font-size:36px;">🐝</div>
              {% endif %}
              <div class="qb-delivery-badge">⚡ 18-22 mins</div>
            </div>
            <div class="qb-carousel-content">
              <h3 class="qb-product-name">{{ product.title }}</h3>
              <div class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</div>
              <form action="/cart/add" method="post" class="product-form">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" class="qb-add-btn">ADD TO CART</button>
              </form>
            </div>
          </div>
        {% endfor %}
    </div>
  </section>
  {% endif %}

  <!-- Baby Care -->
  {% assign babies = collections.baby-care.products %}
  {% if babies.size > 0 %}
  <section class="qb-section">
    <h2>👶 Baby Care</h2>
    <div class="qb-product-grid">
        {% for product in babies limit: 4 %}
          <div class="qb-product-card">
            <div class="qb-product-image-wrap" style="cursor: pointer;" data-product-url="{{ product.url }}">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '1080x1080', crop: 'center' }}" alt="{{ product.title }}" class="qb-product-image" style="cursor: pointer;">
              {% else %}
                <div style="width:100%;height:100%;background:var(--qb-dark4);display:flex;align-items:center;justify-content:center;font-size:36px;">🐝</div>
              {% endif %}
              <div class="qb-delivery-badge">⚡ 18-22 mins</div>
            </div>
            <div class="qb-carousel-content">
              <h3 class="qb-product-name">{{ product.title }}</h3>
              <div class="qb-product-price">Rs {{ product.price | divided_by: 100 }}</div>
              <form action="/cart/add" method="post" class="product-form">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" class="qb-add-btn">ADD TO CART</button>
              </form>
            </div>
