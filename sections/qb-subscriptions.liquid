</div>

<script>
(function () {
  /* ── Category filter ── */
  var filters  = document.querySelectorAll('.qb-sub-filter');
  var cards    = document.querySelectorAll('.qb-sub-card');

  filters.forEach(function (btn) {
    btn.addEventListener('click', function () {
      filters.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var cat = btn.getAttribute('data-filter');
      cards.forEach(function (card) {
        var match = cat === 'all' || card.getAttribute('data-category') === cat;
        card.style.display = match ? '' : 'none';
      });
    });
  });

  /* ── Option pill selection ── */
  document.querySelectorAll('.qb-sub-options').forEach(function (group) {
    group.addEventListener('click', function (e) {
      var opt = e.target.closest('.qb-sub-option');
      if (!opt) return;
      group.querySelectorAll('.qb-sub-option').forEach(function (o) { o.classList.remove('selected'); });
      opt.classList.add('selected');
    });
  });

  /* ── FAQ accordion ── */
  document.querySelectorAll('.qb-sub-faq-q').forEach(function (q) {
    q.addEventListener('click', function () {
      var item = q.closest('.qb-sub-faq-item');
      var wasOpen = item.classList.contains('open');
      document.querySelectorAll('.qb-sub-faq-item').forEach(function (i) { i.classList.remove('open'); });
      if (!wasOpen) item.classList.add('open');
    });
  });

  /* ── Launch Countdown ── */
  // April 17, 2026 7:10 PM Nepal Standard Time (UTC+5:45) = April 17, 2026 13:25:00 UTC
  // Locked for 66 hours from April 14, 2026 ~19:25 NPT = April 14, 2026 13:40:00 UTC
  var qbLaunchTarget = new Date('2026-04-17T13:25:00Z').getTime();
  var qbLockStart    = qbLaunchTarget - (66 * 3600 * 1000); // 66 hrs before launch

  function qbTickLock() {
    var lock = document.getElementById('qbSubLock');
    if (!lock) return;
    var now  = Date.now();
    var diff = qbLaunchTarget - now;
    if (diff <= 0) {
      lock.style.display = 'none';
      return;
    }
    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    var dEl = document.getElementById('qbLockD');
    var hEl = document.getElementById('qbLockH');
    var mEl = document.getElementById('qbLockM');
    var sEl = document.getElementById('qbLockS');
    if (dEl) dEl.textContent = String(d).padStart(2, '0');
    if (hEl) hEl.textContent = String(h).padStart(2, '0');
    if (mEl) mEl.textContent = String(m).padStart(2, '0');
    if (sEl) sEl.textContent = String(s).padStart(2, '0');

    /* Progress bar — % of 66hr window elapsed */
    var totalMs  = qbLaunchTarget - qbLockStart;
    var elapsedMs = Math.max(0, now - qbLockStart);
    var pct = Math.min(100, Math.round((elapsedMs / totalMs) * 100));
    var fill = document.getElementById('qbLockFill');
    var pctEl = document.getElementById('qbLockPct');
    if (fill)  fill.style.width = pct + '%';
    if (pctEl) pctEl.textContent = pct + '%';
  }
  qbTickLock();
  setInterval(qbTickLock, 1000);
})();

function qbLockNotify() {
  var email = document.getElementById('qbLockEmail');
  var ok = document.getElementById('qbLockOk');
  if (!email || !email.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
    email && email.focus();
    return;
  }
  // Fires existing notify form if present, otherwise just shows OK
  var existingInput = document.getElementById('qbSubNotifyEmail');
  var existingForm = document.getElementById('qbSubNotifyForm');
  if (existingInput) existingInput.value = email.value;
  if (existingForm) existingForm.dispatchEvent(new Event('submit'));
  else if (ok) { ok.style.display = 'block'; email.value = ''; }
}
</script>
