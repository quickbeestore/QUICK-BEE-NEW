<style>
/* ═══════════════════════════════════════════
   RAFTAAR — DESIGN SYSTEM
═══════════════════════════════════════════ */
:root {
  --rf-black:   #000000;
  --rf-dark:    #0a0a0a;
  --rf-card:    #111111;
  --rf-card2:   #161616;
  --rf-border:  rgba(255,215,0,0.12);
  --rf-gold:    #FFD700;
  --rf-orange:  #FF6A00;
  --rf-fire:    linear-gradient(135deg, #FFD700, #FF6A00);
  --rf-text:    #ffffff;
  --rf-muted:   rgba(255,255,255,0.5);
  --rf-dim:     rgba(255,255,255,0.25);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.rf-page {
  background: var(--rf-black);
  color: var(--rf-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  overflow-x: hidden;
}

/* ── ANIMATIONS ── */
@keyframes rf-pulse-glow {
  0%,100% { box-shadow: 0 0 20px rgba(255,215,0,0.3), 0 0 60px rgba(255,106,0,0.15); }
  50%      { box-shadow: 0 0 40px rgba(255,215,0,0.6), 0 0 100px rgba(255,106,0,0.3); }
}
@keyframes rf-streak {
  0%   { transform: translateX(-100%) skewX(-15deg); opacity: 0; }
  20%  { opacity: 1; }
  100% { transform: translateX(400%) skewX(-15deg); opacity: 0; }
}
@keyframes rf-float {
  0%,100% { transform: translateY(0px); }
  50%      { transform: translateY(-10px); }
}
@keyframes rf-spin-slow {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
@keyframes rf-counter {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes rf-fade-up {
  from { opacity: 0; transform: translateY(40px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes rf-line-draw {
  from { width: 0; }
  to   { width: 100%; }
}
@keyframes rf-breathe {
  0%,100% { opacity: 0.6; }
  50%      { opacity: 1; }
}
@keyframes rf-speed-slide {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
@keyframes rf-bg-shift {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
@keyframes rf-particle {
  0%   { transform: translateY(100vh) translateX(0) scale(0); opacity: 0; }
  10%  { opacity: 1; }
  90%  { opacity: 1; }
  100% { transform: translateY(-10vh) translateX(var(--dx, 20px)) scale(1); opacity: 0; }
}

/* ═══════════════════════════════════════════
   HERO SECTION
═══════════════════════════════════════════ */
.rf-hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 80px 24px 100px;
  overflow: hidden;
}

/* animated gradient mesh background */
.rf-hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 0%, rgba(255,215,0,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(255,106,0,0.06) 0%, transparent 55%),
    radial-gradient(ellipse 50% 40% at 20% 70%, rgba(255,215,0,0.04) 0%, transparent 50%),
    var(--rf-black);
  background-size: 200% 200%;
  animation: rf-bg-shift 8s ease infinite;
}

/* speed lines */
.rf-hero-lines {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}
.rf-hero-lines span {
  position: absolute;
  height: 1.5px;
  width: 160px;
  background: linear-gradient(90deg, transparent, rgba(255,215,0,0.7), transparent);
  border-radius: 99px;
  animation: rf-streak linear infinite;
}
.rf-hero-lines span:nth-child(1)  { top: 12%; animation-duration: 2.2s; animation-delay: 0s;    width: 100px; }
.rf-hero-lines span:nth-child(2)  { top: 28%; animation-duration: 1.8s; animation-delay: 0.4s;  width: 180px; }
.rf-hero-lines span:nth-child(3)  { top: 44%; animation-duration: 2.5s; animation-delay: 0.9s;  width: 120px; }
.rf-hero-lines span:nth-child(4)  { top: 60%; animation-duration: 1.6s; animation-delay: 1.3s;  width: 200px; }
.rf-hero-lines span:nth-child(5)  { top: 75%; animation-duration: 2.1s; animation-delay: 0.2s;  width: 90px;  }
.rf-hero-lines span:nth-child(6)  { top: 88%; animation-duration: 1.9s; animation-delay: 0.7s;  width: 150px; }
.rf-hero-lines span:nth-child(7)  { top: 20%; animation-duration: 2.8s; animation-delay: 1.6s;  width: 130px; background: linear-gradient(90deg, transparent, rgba(255,106,0,0.5), transparent); }
.rf-hero-lines span:nth-child(8)  { top: 55%; animation-duration: 2.0s; animation-delay: 1.1s;  width: 170px; background: linear-gradient(90deg, transparent, rgba(255,106,0,0.5), transparent); }

/* floating particles */
.rf-particles {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.rf-particle {
  position: absolute;
  bottom: 0;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--rf-gold);
  animation: rf-particle linear infinite;
}
.rf-particle:nth-child(1)  { left: 10%; animation-duration: 6s;   animation-delay: 0s;   --dx: 15px;  }
.rf-particle:nth-child(2)  { left: 25%; animation-duration: 8s;   animation-delay: 1s;   --dx: -20px; background: var(--rf-orange); width: 3px; height: 3px; }
.rf-particle:nth-child(3)  { left: 40%; animation-duration: 5.5s; animation-delay: 2s;   --dx: 10px;  }
.rf-particle:nth-child(4)  { left: 55%; animation-duration: 7s;   animation-delay: 0.5s; --dx: -15px; background: var(--rf-orange); }
.rf-particle:nth-child(5)  { left: 70%; animation-duration: 6.5s; animation-delay: 1.5s; --dx: 25px;  width: 3px; height: 3px; }
.rf-particle:nth-child(6)  { left: 85%; animation-duration: 9s;   animation-delay: 3s;   --dx: -10px; background: var(--rf-orange); }

.rf-hero-content {
  position: relative;
  z-index: 2;
  max-width: 720px;
}

.rf-hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--rf-gold);
  background: rgba(255,215,0,0.08);
  border: 1px solid rgba(255,215,0,0.2);
  padding: 6px 16px;
  border-radius: 99px;
  margin-bottom: 28px;
  animation: rf-fade-up 0.6s ease both;
}

.rf-hero-title {
  font-size: clamp(64px, 18vw, 140px);
  font-weight: 900;
  letter-spacing: -3px;
  line-height: 0.9;
  text-transform: uppercase;
  background: var(--rf-fire);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 40px rgba(255,215,0,0.4));
  animation: rf-fade-up 0.6s 0.1s ease both, rf-pulse-glow 3s ease-in-out infinite;
  margin-bottom: 12px;
}

.rf-hero-sub {
  font-size: clamp(16px, 4vw, 22px);
  font-weight: 700;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  animation: rf-fade-up 0.6s 0.2s ease both;
  margin-bottom: 24px;
}

.rf-hero-tagline {
  font-size: clamp(18px, 4vw, 26px);
  font-weight: 800;
  color: #fff;
  animation: rf-fade-up 0.6s 0.3s ease both;
  margin-bottom: 48px;
  line-height: 1.3;
}
.rf-hero-tagline em {
  font-style: normal;
  background: var(--rf-fire);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.rf-hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--rf-fire);
  color: #000;
  font-size: 16px;
  font-weight: 900;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 18px 48px;
  border-radius: 99px;
  animation: rf-fade-up 0.6s 0.4s ease both, rf-pulse-glow 3s 1s ease-in-out infinite;
  transition: transform 0.2s ease, filter 0.2s ease;
  position: relative;
  overflow: hidden;
}
.rf-hero-cta::after {
  content: '';
  position: absolute;
  top: 0; left: -80%;
  width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
  animation: rf-streak 2.5s ease-in-out infinite;
}
.rf-hero-cta:hover {
  transform: scale(1.05) translateY(-2px);
  filter: brightness(1.1);
}

.rf-hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32px;
  margin-top: 64px;
  animation: rf-fade-up 0.6s 0.6s ease both;
  flex-wrap: wrap;
}
.rf-hero-stat {
  text-align: center;
}
.rf-hero-stat-num {
  font-size: 36px;
  font-weight: 900;
  background: var(--rf-fire);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}
.rf-hero-stat-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--rf-muted);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-top: 4px;
}
.rf-hero-stat-divider {
  width: 1px;
  height: 40px;
  background: rgba(255,255,255,0.1);
}

/* scroll indicator */
.rf-scroll-hint {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: var(--rf-muted);
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  animation: rf-breathe 2s ease-in-out infinite;
}
.rf-scroll-hint-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--rf-gold), transparent);
}

/* ═══════════════════════════════════════════
   SPEED PROOF SECTION
═══════════════════════════════════════════ */
.rf-speed {
  padding: 100px 24px;
  background: var(--rf-dark);
  position: relative;
  overflow: hidden;
}
.rf-speed::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--rf-gold), transparent);
}

.rf-section-label {
  text-align: center;
  margin-bottom: 60px;
}
.rf-section-chip {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--rf-gold);
  margin-bottom: 12px;
}
.rf-section-title {
  font-size: clamp(28px, 6vw, 48px);
  font-weight: 900;
  letter-spacing: -1px;
  color: #fff;
}
.rf-section-title span {
  background: var(--rf-fire);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.rf-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 20px;
  max-width: 1000px;
  margin: 0 auto;
}

.rf-card {
  background: var(--rf-card);
  border: 1px solid var(--rf-border);
  border-radius: 24px;
  padding: 36px 28px;
  position: relative;
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease, border-color 0.3s ease;
  cursor: default;
}
.rf-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% -20%, rgba(255,215,0,0.06), transparent);
  opacity: 0;
  transition: opacity 0.3s ease;
}
.rf-card:hover {
  transform: translateY(-8px);
  border-color: rgba(255,215,0,0.35);
  box-shadow: 0 20px 60px rgba(255,215,0,0.12), 0 4px 20px rgba(0,0,0,0.4);
}
.rf-card:hover::before { opacity: 1; }

.rf-card-icon {
  font-size: 40px;
  margin-bottom: 20px;
  display: block;
  animation: rf-float 3s ease-in-out infinite;
}
.rf-card:nth-child(2) .rf-card-icon { animation-delay: 0.4s; }
.rf-card:nth-child(3) .rf-card-icon { animation-delay: 0.8s; }
.rf-card:nth-child(4) .rf-card-icon { animation-delay: 1.2s; }

.rf-card-num {
  font-size: 42px;
  font-weight: 900;
  background: var(--rf-fire);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: 6px;
}
.rf-card-title {
  font-size: 18px;
  font-weight: 800;
  color: #fff;
  margin-bottom: 10px;
}
.rf-card-desc {
  font-size: 13px;
  color: var(--rf-muted);
  line-height: 1.6;
}

/* ═══════════════════════════════════════════
   HOW IT WORKS — TIMELINE
═══════════════════════════════════════════ */
.rf-how {
  padding: 100px 24px;
  background: var(--rf-black);
  position: relative;
  overflow: hidden;
}
.rf-how::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,106,0,0.5), transparent);
}

.rf-timeline {
  max-width: 820px;
  margin: 0 auto;
  position: relative;
}

/* vertical connecting line */
.rf-timeline::before {
  content: '';
  position: absolute;
  left: 32px;
  top: 24px;
  bottom: 24px;
  width: 2px;
  background: linear-gradient(to bottom, var(--rf-gold), var(--rf-orange), rgba(255,106,0,0.1));
}

.rf-step {
  display: flex;
  align-items: flex-start;
  gap: 28px;
  padding: 0 0 48px;
  position: relative;
}
.rf-step:last-child { padding-bottom: 0; }

.rf-step-num {
  width: 64px;
  height: 64px;
  flex-shrink: 0;
  border-radius: 50%;
  background: var(--rf-card);
  border: 2px solid var(--rf-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  position: relative;
  z-index: 1;
  box-shadow: 0 0 0 6px var(--rf-black), 0 0 20px rgba(255,215,0,0.3);
  transition: box-shadow 0.3s ease;
}
.rf-step:hover .rf-step-num {
  box-shadow: 0 0 0 6px var(--rf-black), 0 0 40px rgba(255,215,0,0.6);
}

.rf-step-body {
  padding-top: 12px;
}
.rf-step-tag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--rf-gold);
  margin-bottom: 6px;
}
.rf-step-title {
  font-size: 22px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 8px;
}
.rf-step-desc {
  font-size: 14px;
  color: var(--rf-muted);
  line-height: 1.7;
  max-width: 400px;
}

/* ═══════════════════════════════════════════
   EXPERIENCE SECTION
═══════════════════════════════════════════ */
.rf-experience {
  padding: 100px 24px;
  background: var(--rf-dark);
  position: relative;
  overflow: hidden;
}
.rf-experience::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--rf-gold), transparent);
}

.rf-exp-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 20px;
  max-width: 1000px;
  margin: 0 auto;
}

.rf-exp-card {
  background: var(--rf-card2);
  border-radius: 28px;
  padding: 40px 32px;
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.04);
  transition: transform 0.3s ease, border-color 0.3s ease;
}
.rf-exp-card::after {
  content: attr(data-emoji);
  position: absolute;
  bottom: -10px;
  right: 16px;
  font-size: 80px;
  opacity: 0.08;
  line-height: 1;
  pointer-events: none;
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.rf-exp-card:hover {
  transform: translateY(-6px);
  border-color: rgba(255,215,0,0.2);
}
.rf-exp-card:hover::after {
  opacity: 0.15;
  transform: scale(1.1);
}

.rf-exp-icon {
  font-size: 36px;
  margin-bottom: 16px;
  display: block;
}
.rf-exp-time {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--rf-orange);
  margin-bottom: 10px;
}
.rf-exp-title {
  font-size: 22px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 10px;
  line-height: 1.2;
}
.rf-exp-desc {
  font-size: 14px;
  color: var(--rf-muted);
  line-height: 1.7;
}
.rf-exp-badge {
  display: inline-block;
  margin-top: 20px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--rf-gold);
  background: rgba(255,215,0,0.1);
  border: 1px solid rgba(255,215,0,0.2);
  padding: 5px 14px;
  border-radius: 99px;
}

/* ═══════════════════════════════════════════
   COMPARISON SECTION
═══════════════════════════════════════════ */
.rf-compare {
  padding: 100px 24px;
  background: var(--rf-black);
  position: relative;
  overflow: hidden;
}
.rf-compare::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,106,0,0.5), transparent);
}

.rf-compare-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  max-width: 800px;
  margin: 0 auto;
}

.rf-compare-col {
  border-radius: 24px;
  padding: 40px 32px;
  border: 1px solid transparent;
}
.rf-compare-col.them {
  background: #0d0d0d;
  border-color: rgba(255,255,255,0.06);
  opacity: 0.7;
}
.rf-compare-col.us {
  background: linear-gradient(145deg, #1a1200, #0f0800);
  border-color: rgba(255,215,0,0.25);
  box-shadow: 0 8px 40px rgba(255,215,0,0.1);
  position: relative;
  overflow: hidden;
}
.rf-compare-col.us::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(255,215,0,0.07), transparent);
  pointer-events: none;
}

.rf-compare-head {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 28px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.rf-compare-col.them .rf-compare-head { color: var(--rf-muted); }
.rf-compare-col.us .rf-compare-head {
  color: var(--rf-gold);
  border-bottom-color: rgba(255,215,0,0.15);
}

.rf-compare-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  font-size: 15px;
  font-weight: 600;
}
.rf-compare-item:last-child { border-bottom: none; }
.rf-compare-col.them .rf-compare-item { color: rgba(255,255,255,0.35); }
.rf-compare-col.us .rf-compare-item { color: #fff; }

.rf-compare-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.rf-compare-col.them .rf-compare-dot { background: rgba(255,255,255,0.2); }
.rf-compare-col.us .rf-compare-dot {
  background: var(--rf-fire);
  background: linear-gradient(135deg, #FFD700, #FF6A00);
  box-shadow: 0 0 6px rgba(255,215,0,0.6);
}

/* ═══════════════════════════════════════════
   TICKER — SPEED STRIP
═══════════════════════════════════════════ */
.rf-ticker {
  background: linear-gradient(135deg, #1a1000, #0a0800);
  border-top: 1px solid rgba(255,215,0,0.15);
  border-bottom: 1px solid rgba(255,215,0,0.15);
  overflow: hidden;
  padding: 16px 0;
  position: relative;
}
.rf-ticker-track {
  display: flex;
  gap: 0;
  white-space: nowrap;
  animation: rf-speed-slide 18s linear infinite;
  width: max-content;
}
.rf-ticker-item {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 0 40px;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--rf-gold);
}
.rf-ticker-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--rf-orange);
  flex-shrink: 0;
}

/* ═══════════════════════════════════════════
   FINAL CTA
═══════════════════════════════════════════ */
.rf-final {
  padding: 120px 24px 100px;
  background: var(--rf-dark);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.rf-final::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--rf-gold), transparent);
}
.rf-final-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 70% at 50% 100%, rgba(255,215,0,0.07), transparent);
  pointer-events: none;
}
.rf-final-title {
  font-size: clamp(28px, 7vw, 60px);
  font-weight: 900;
  letter-spacing: -1.5px;
  line-height: 1.1;
  color: #fff;
  margin-bottom: 24px;
  position: relative;
}
.rf-final-title span {
  background: var(--rf-fire);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.rf-final-sub {
  font-size: 16px;
  color: var(--rf-muted);
  margin-bottom: 48px;
  position: relative;
}
.rf-final-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--rf-fire);
  color: #000;
  font-size: 17px;
  font-weight: 900;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 20px 56px;
  border-radius: 99px;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, filter 0.2s ease;
  animation: rf-pulse-glow 3s ease-in-out infinite;
}
.rf-final-cta::after {
  content: '';
  position: absolute;
  top: 0; left: -80%;
  width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
  animation: rf-streak 2.5s ease-in-out infinite;
}
.rf-final-cta:hover {
  transform: scale(1.05) translateY(-3px);
  filter: brightness(1.1);
}

/* ═══════════════════════════════════════════
   FOOTER STRIP
═══════════════════════════════════════════ */
.rf-footer {
  background: var(--rf-black);
  border-top: 1px solid rgba(255,255,255,0.04);
  padding: 28px 24px;
  text-align: center;
  font-size: 12px;
  color: rgba(255,255,255,0.2);
  letter-spacing: 1px;
}
.rf-footer a {
  color: rgba(255,215,0,0.5);
  text-decoration: none;
  transition: color 0.2s;
}
.rf-footer a:hover { color: var(--rf-gold); }

/* ═══════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════ */
@media (max-width: 640px) {
  .rf-compare-grid { grid-template-columns: 1fr; }
  .rf-compare-col.them { order: 2; }
  .rf-compare-col.us   { order: 1; }
  .rf-timeline::before { left: 28px; }
  .rf-step-num { width: 56px; height: 56px; font-size: 22px; }
  .rf-hero-stats { gap: 20px; }
  .rf-hero-stat-divider { display: none; }
}
</style>

