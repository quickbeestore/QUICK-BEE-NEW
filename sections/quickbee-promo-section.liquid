{% schema %}
{
  "name": "QuickBee Promo Section",
  "settings": [
    {
      "type": "text",
      "id": "emoji",
      "label": "Emoji/Icon",
      "default": "🎡"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Spin the QuickBee Wheel"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Unlock discounts, free delivery, and surprise rewards with every spin</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Spin Now"
    },
    {
      "type": "color",
      "id": "bg_color_start",
      "label": "Background Gradient Start",
      "default": "#F4B400"
    },
    {
      "type": "color",
      "id": "bg_color_end",
      "label": "Background Gradient End",
      "default": "#E8B800"
    }
  ],
  "presets": [
    {
      "name": "Promo Section"
    }
  ]
}
{% endschema %}

<style>
.qb-promo-section {
  padding: 40px 16px;
}
@media(min-width:1024px) {
  .qb-promo-section {
    padding: 60px 48px;
  }
}
.qb-spin {
  border-radius: 20px;
  padding: 32px 24px;
  text-align: center;
  color: #111111;
  margin: 20px 0;
}
@media(min-width:1024px) {
  .qb-spin {
    padding: 48px;
  }
}
.qb-spin-emoji {
  font-size: 48px;
  margin-bottom: 16px;
}
.qb-spin h3 {
  font-size: 24px;
  font-weight: 900;
  margin: 0 0 8px 0;
}
@media(min-width:1024px) {
  .qb-spin h3 {
    font-size: 32px;
  }
}
.qb-spin p {
  font-size: 14px;
  margin: 0 0 20px 0;
  opacity: 0.9;
}
.qb-spin-btn {
  background: #111111;
  color: #fff;
  border: none;
  padding: 14px 28px;
  border-radius: 24px;
  font-weight: 700;
  font-size: 16px;
  cursor: pointer;
  transition: all 0.3s ease;
}
.qb-spin-btn:hover {
  background: #fff;
  color: #111111;
  transform: translateY(-2px);
}
</style>

<!-- Promotional Section -->
<section class="qb-promo-section">
  <div class="qb-spin" style="background: linear-gradient(135deg, {{ section.settings.bg_color_start }} 0%, {{ section.settings.bg_color_end }} 100%);">
    <div class="qb-spin-emoji">{{ section.settings.emoji }}</div>
    <h3>{{ section.settings.title }}</h3>
    {{ section.settings.description }}
    <button class="qb-spin-btn" onclick="if (typeof window.qbSpinTheWheel === 'function') { window.qbSpinTheWheel(); } else { alert('Spin wheel not ready yet'); }">
      {{ section.settings.button_text }}
    </button>
  </div>
</section>
