{%- paginate collection.products by 250 -%}
<style>
.qbw *,.qbw *::before,.qbw *::after{box-sizing:border-box;margin:0;padding:0}
.qbw{
  --bg:#0a0a0c;--bg2:#111114;--bg3:#17171b;--bg4:#1e1e23;
  --bd:rgba(255,255,255,.06);--bd2:rgba(255,255,255,.11);
  --gold:#d4a843;--gold2:#f0c55a;--gold3:#ffd97d;
  --grn:#22c55e;--red:#ef4444;
  --txt:#f0ece4;--sub:#8c8880;--dim:#4e4c49;
  --ease:cubic-bezier(.4,0,.2,1);
  background:var(--bg);color:var(--txt);
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  -webkit-font-smoothing:antialiased;
}

/* ── TICKER ── */
.qbw-tick{background:var(--gold);color:#06040a;font-size:10px;font-weight:900;letter-spacing:.6px;text-transform:uppercase;padding:7px 0;overflow:hidden;white-space:nowrap}
.qbw-tick-inner{display:inline-flex;animation:qtick 38s linear infinite}
@keyframes qtick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.qbw-tick-item{padding:0 24px;border-right:1px solid rgba(0,0,0,.2);flex-shrink:0}

/* ── STICKY NAV ── */
.qbw-nav{position:sticky;top:0;z-index:200;background:rgba(10,10,12,.97);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border-bottom:1px solid var(--bd2)}
.qbw-nav-track{display:flex;overflow-x:auto;scrollbar-width:none;padding:0 8px;gap:2px;align-items:stretch}
.qbw-nav-track::-webkit-scrollbar{display:none}

/* flat nav btn (no children) */
.qbw-nav-btn{flex-shrink:0;padding:10px 11px;font-size:11px;font-weight:700;color:var(--dim);background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:color .12s,border-color .12s;-webkit-tap-highlight-color:transparent;position:relative}
.qbw-nav-btn:hover{color:var(--txt)}
.qbw-nav-btn.on{color:var(--gold2);border-bottom-color:var(--gold)}

/* dropdown group */
.qbw-nav-grp{position:relative;flex-shrink:0;display:flex;align-items:stretch}
.qbw-nav-grp-btn{display:flex;align-items:center;gap:4px;padding:10px 11px;font-size:11px;font-weight:700;color:var(--dim);background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:color .12s,border-color .12s;-webkit-tap-highlight-color:transparent}
.qbw-nav-grp-btn:hover,.qbw-nav-grp.open .qbw-nav-grp-btn{color:var(--gold2)}
.qbw-nav-grp.on .qbw-nav-grp-btn{border-bottom:2px solid var(--gold);color:var(--gold2)}
.qbw-nav-grp-btn .arrow{font-size:7px;opacity:.55;transition:transform .18s}
.qbw-nav-grp.open .qbw-nav-grp-btn .arrow{transform:rotate(180deg);opacity:1}

/* dropdown panel */
.qbw-nav-drop{display:none;position:absolute;top:100%;left:0;min-width:190px;background:rgba(14,14,17,.98);border:1px solid var(--bd2);border-top:2px solid var(--gold);border-radius:0 0 10px 10px;box-shadow:0 14px 40px rgba(0,0,0,.7);z-index:300;overflow:hidden}
.qbw-nav-grp.open .qbw-nav-drop{display:block}
.qbw-nav-drop-item{display:block;padding:9px 16px;font-size:11.5px;font-weight:600;color:var(--sub);background:none;border:none;width:100%;text-align:left;cursor:pointer;white-space:nowrap;transition:background .12s,color .12s;border-bottom:1px solid rgba(255,255,255,.04)}
.qbw-nav-drop-item:last-child{border-bottom:none}
.qbw-nav-drop-item:hover{background:rgba(212,168,67,.07);color:var(--gold2)}
.qbw-nav-drop-item.on{color:var(--gold2);background:rgba(212,168,67,.05)}

/* ── TOP BAR ── */
.qbw-topbar{padding:12px 16px;max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;border-bottom:1px solid var(--bd)}
.qbw-topbar-title{font-size:15px;font-weight:900;color:var(--txt);letter-spacing:-.3px}
.qbw-topbar-sub{font-size:11px;color:var(--sub);margin-top:1px}
.qbw-topbar-btns{display:flex;gap:8px;flex-shrink:0}
.qbw-btn-gold{display:inline-flex;align-items:center;gap:5px;background:linear-gradient(135deg,var(--gold),var(--gold2) 55%,var(--gold3));color:#06040a;font-size:11.5px;font-weight:900;padding:9px 16px;border-radius:8px;text-decoration:none;border:none;cursor:pointer;box-shadow:0 3px 14px rgba(212,168,67,.26);transition:transform .13s;white-space:nowrap}
.qbw-btn-gold:hover{transform:translateY(-1px)}
.qbw-btn-out{display:inline-flex;align-items:center;gap:5px;background:transparent;border:1.5px solid rgba(212,168,67,.22);color:var(--gold2);font-size:11.5px;font-weight:800;padding:8px 14px;border-radius:8px;text-decoration:none;cursor:pointer;transition:border-color .12s,background .12s;white-space:nowrap}
.qbw-btn-out:hover{border-color:var(--gold);background:rgba(212,168,67,.05)}

/* ── GROUP HEADER ── */
.qbw-grp{padding:32px 16px 0;max-width:1100px;margin:0 auto}
.qbw-grp-inner{display:flex;align-items:center;gap:10px;padding:12px 16px;background:var(--bg2);border:1px solid var(--bd);border-left:3px solid var(--gold);border-radius:10px}
.qbw-grp-emo{font-size:22px;flex-shrink:0}
.qbw-grp-name{font-size:14px;font-weight:900;color:var(--gold2);letter-spacing:-.15px}
.qbw-grp-sub{font-size:10px;color:var(--sub);margin-top:1px}

/* ── SECTION HEADER ── */
.qbw-sec{padding:20px 0 0}
.qbw-sec-head{max-width:1100px;margin:0 auto;padding:0 16px 8px;display:flex;align-items:baseline;justify-content:space-between}
.qbw-sec-eye{font-size:8px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);opacity:.65;margin-bottom:2px}
.qbw-sec-name{font-size:16px;font-weight:900;letter-spacing:-.25px;color:var(--txt);line-height:1.1}
.qbw-sec-cnt{font-size:9.5px;color:var(--dim);margin-top:2px}
.qbw-rule{height:1px;padding:0 16px;max-width:1100px;margin:0 auto}
.qbw-rule-inner{height:1px;background:linear-gradient(90deg,rgba(212,168,67,.18),transparent)}

/* ══════════════════════
   LAYOUT 1 — SLIDER (5+ products)
   ══════════════════════ */
.qbw-slider{overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;padding:8px 16px 20px;scroll-snap-type:x mandatory}
.qbw-slider::-webkit-scrollbar{display:none}
.qbw-slider-row{display:flex;gap:9px;width:max-content}

/* standard card */
.qbw-card{flex:0 0 calc(44vw - 16px);max-width:188px;min-width:130px;background:var(--bg2);border:1px solid var(--bd);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;text-decoration:none;color:inherit;scroll-snap-align:start;transition:border-color .18s,transform .16s;position:relative;-webkit-tap-highlight-color:transparent}
@media(min-width:480px){.qbw-card{flex:0 0 164px;max-width:164px}}
@media(min-width:700px){.qbw-card{flex:0 0 180px;max-width:180px}}
@media(min-width:960px){.qbw-card{flex:0 0 194px;max-width:194px}}
.qbw-card:active{transform:scale(.96)}
.qbw-card:hover{border-color:rgba(212,168,67,.38)}
.qbw-card-img{position:relative;aspect-ratio:1/1;background:linear-gradient(160deg,var(--bg3),#0b0b0d);overflow:hidden}
.qbw-card-img img{width:100%;height:100%;object-fit:contain;padding:10px;display:block;transition:transform .32s var(--ease)}
.qbw-card:hover .qbw-card-img img{transform:scale(1.05)}
.qbw-card-fade{position:absolute;bottom:0;left:0;right:0;height:28px;background:linear-gradient(to top,var(--bg2),transparent);pointer-events:none}
.qbw-card-empty{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:28px;opacity:.07}
.qbw-b-save{position:absolute;top:7px;left:7px;background:linear-gradient(135deg,#14532d,#16a34a);color:#fff;font-size:7.5px;font-weight:900;padding:2px 6px;border-radius:14px;box-shadow:0 2px 7px rgba(22,163,74,.35)}
.qbw-b-tag{position:absolute;bottom:7px;left:7px;font-size:7px;font-weight:900;letter-spacing:.4px;text-transform:uppercase;padding:2px 6px;border-radius:4px}
.qbw-b-best{background:rgba(212,168,67,.9);color:#0a0700}
.qbw-b-hot{background:rgba(239,68,68,.14);border:1px solid rgba(239,68,68,.28);color:#f87171;backdrop-filter:blur(4px)}
.qbw-b-new{background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.28);color:#4ade80;backdrop-filter:blur(4px)}
.qbw-sold{position:absolute;inset:0;background:rgba(6,6,8,.68);display:flex;align-items:center;justify-content:center}
.qbw-sold span{font-size:8.5px;font-weight:900;letter-spacing:1.2px;text-transform:uppercase;color:var(--sub);border:1px solid var(--bd2);padding:4px 10px;border-radius:4px;background:var(--bg)}
.qbw-card-body{padding:9px 10px 11px;flex:1;display:flex;flex-direction:column}
.qbw-card-type{font-size:7px;font-weight:900;letter-spacing:1.6px;text-transform:uppercase;color:var(--gold);opacity:.5;margin-bottom:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.qbw-card-name{font-size:11px;font-weight:700;line-height:1.35;color:var(--txt);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;flex:1;margin-bottom:7px}
.qbw-price{margin-top:auto}
.qbw-price-row{display:flex;align-items:baseline;gap:5px;flex-wrap:wrap;margin-bottom:1px}
.qbw-price-now{font-size:14px;font-weight:900;color:var(--gold2);letter-spacing:-.3px;line-height:1}
.qbw-price-was{font-size:9px;color:var(--dim);text-decoration:line-through}
.qbw-price-save{font-size:8px;font-weight:800;color:var(--grn)}
.qbw-price-locked{font-size:8.5px;font-weight:700;color:var(--sub);display:flex;align-items:center;gap:4px;padding:5px 8px;background:rgba(255,255,255,.025);border:1px solid var(--bd);border-radius:6px}
.qbw-price-locked::before{content:'🔒';font-size:9px}
.qbw-price-retail{font-size:8px;color:var(--dim);margin-bottom:1px}
.qbw-price-hint{font-size:7.5px;color:var(--dim);margin-top:1px}

/* ══════════════════════
   LAYOUT 2 — MINI GRID (2–4 products)
   ══════════════════════ */
.qbw-grid{display:grid;gap:9px;padding:8px 16px 20px;max-width:1100px;margin:0 auto}
.qbw-grid--2{grid-template-columns:repeat(2,1fr)}
.qbw-grid--3{grid-template-columns:repeat(3,1fr)}
.qbw-grid--4{grid-template-columns:repeat(2,1fr)}
@media(min-width:600px){.qbw-grid--3{grid-template-columns:repeat(3,1fr)}.qbw-grid--4{grid-template-columns:repeat(4,1fr)}}
/* grid card — same as slider card but flex:none */
.qbw-gcard{background:var(--bg2);border:1px solid var(--bd);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;text-decoration:none;color:inherit;transition:border-color .18s,transform .16s;position:relative;-webkit-tap-highlight-color:transparent}
.qbw-gcard:active{transform:scale(.96)}
.qbw-gcard:hover{border-color:rgba(212,168,67,.38)}
.qbw-gcard-img{position:relative;aspect-ratio:1/1;background:linear-gradient(160deg,var(--bg3),#0b0b0d);overflow:hidden}
.qbw-gcard-img img{width:100%;height:100%;object-fit:contain;padding:10px;display:block;transition:transform .32s var(--ease)}
.qbw-gcard:hover .qbw-gcard-img img{transform:scale(1.05)}
.qbw-gcard-fade{position:absolute;bottom:0;left:0;right:0;height:28px;background:linear-gradient(to top,var(--bg2),transparent);pointer-events:none}
.qbw-gcard-empty{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:28px;opacity:.07}
.qbw-gcard-body{padding:9px 10px 11px;flex:1;display:flex;flex-direction:column}
.qbw-gcard-type{font-size:7px;font-weight:900;letter-spacing:1.6px;text-transform:uppercase;color:var(--gold);opacity:.5;margin-bottom:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.qbw-gcard-name{font-size:11px;font-weight:700;line-height:1.35;color:var(--txt);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;flex:1;margin-bottom:7px}

/* ══════════════════════
   LAYOUT 3 — HERO FEATURE (1 product)
   ══════════════════════ */
.qbw-hero-card{max-width:1100px;margin:8px 16px 20px;border-radius:14px;overflow:hidden;background:var(--bg2);border:1px solid var(--bd);display:flex;align-items:stretch;text-decoration:none;color:inherit;position:relative;transition:border-color .18s;-webkit-tap-highlight-color:transparent}
@media(max-width:1116px){.qbw-hero-card{margin:8px 16px 20px}}
.qbw-hero-card:hover{border-color:rgba(212,168,67,.4)}
.qbw-hero-img{flex:0 0 42%;max-width:200px;aspect-ratio:1/1;background:linear-gradient(160deg,var(--bg3),#0b0b0d);overflow:hidden;position:relative}
.qbw-hero-img img{width:100%;height:100%;object-fit:contain;padding:16px;display:block}
.qbw-hero-img-empty{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:42px;opacity:.07}
.qbw-hero-body{flex:1;padding:18px 16px;display:flex;flex-direction:column;justify-content:center}
.qbw-hero-eye{font-size:8px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(--gold);opacity:.65;margin-bottom:5px}
.qbw-hero-name{font-size:16px;font-weight:900;color:var(--txt);line-height:1.3;margin-bottom:8px;letter-spacing:-.2px}
.qbw-hero-vendor{font-size:10px;color:var(--sub);margin-bottom:10px}
.qbw-hero-badge{display:inline-flex;align-items:center;gap:5px;background:linear-gradient(135deg,#14532d,#16a34a);color:#fff;font-size:9px;font-weight:900;padding:3px 9px;border-radius:14px;margin-bottom:10px;width:fit-content}
.qbw-hero-price-now{font-size:20px;font-weight:900;color:var(--gold2);letter-spacing:-.4px;line-height:1}
.qbw-hero-price-was{font-size:11px;color:var(--dim);text-decoration:line-through;margin-left:6px}
.qbw-hero-price-locked{font-size:10px;color:var(--sub);display:flex;align-items:center;gap:5px}
.qbw-hero-price-locked::before{content:'🔒'}
.qbw-hero-glow{position:absolute;right:-20px;top:-20px;width:160px;height:160px;background:radial-gradient(circle,rgba(212,168,67,.08),transparent 65%);pointer-events:none}

/* ══════════════════════
   LAYOUT 4 — DUO HERO (2 featured products side by side, big)
   ══════════════════════ */
.qbw-duo{display:grid;grid-template-columns:1fr 1fr;gap:9px;padding:8px 16px 20px;max-width:1100px;margin:0 auto}
.qbw-duo-card{background:var(--bg2);border:1px solid var(--bd);border-radius:12px;overflow:hidden;text-decoration:none;color:inherit;display:flex;flex-direction:column;position:relative;transition:border-color .18s,transform .16s;-webkit-tap-highlight-color:transparent}
.qbw-duo-card:active{transform:scale(.97)}
.qbw-duo-card:hover{border-color:rgba(212,168,67,.4)}
.qbw-duo-img{position:relative;aspect-ratio:4/3;background:linear-gradient(160deg,var(--bg3),#0b0b0d);overflow:hidden}
.qbw-duo-img img{width:100%;height:100%;object-fit:contain;padding:14px;display:block;transition:transform .32s var(--ease)}
.qbw-duo-card:hover .qbw-duo-img img{transform:scale(1.06)}
.qbw-duo-fade{position:absolute;bottom:0;left:0;right:0;height:32px;background:linear-gradient(to top,var(--bg2),transparent);pointer-events:none}
.qbw-duo-empty{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:36px;opacity:.07}
.qbw-duo-body{padding:11px 12px 13px}
.qbw-duo-type{font-size:7px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:var(--gold);opacity:.5;margin-bottom:3px}
.qbw-duo-name{font-size:12px;font-weight:700;line-height:1.35;color:var(--txt);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:7px}
.qbw-duo-price-now{font-size:15px;font-weight:900;color:var(--gold2);letter-spacing:-.3px}
.qbw-duo-price-locked{font-size:9px;color:var(--sub);display:flex;align-items:center;gap:4px}
.qbw-duo-price-locked::before{content:'🔒';font-size:9px}
.qbw-duo-b-save{position:absolute;top:7px;left:7px;background:linear-gradient(135deg,#14532d,#16a34a);color:#fff;font-size:7.5px;font-weight:900;padding:2px 6px;border-radius:14px}

/* ══════════════════════
   MID CTA STRIP
   ══════════════════════ */
.qbw-cta{margin:28px 16px 0;max-width:1100px;background:linear-gradient(135deg,rgba(212,168,67,.07),rgba(212,168,67,.02));border:1px solid rgba(212,168,67,.14);border-radius:12px;padding:18px 18px;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;position:relative;overflow:hidden}
.qbw-cta::after{content:'🔒';position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:56px;opacity:.04;pointer-events:none}
.qbw-cta-tag{font-size:8px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:3px}
.qbw-cta-title{font-size:15px;font-weight:900;color:var(--txt);margin-bottom:3px;letter-spacing:-.2px}
.qbw-cta-sub{font-size:11px;color:var(--sub);line-height:1.5}
@media(max-width:540px){.qbw-cta{flex-direction:column;align-items:flex-start}}

/* ══════════════════════
   BOTTOM
   ══════════════════════ */
.qbw-faq{padding:36px 16px;background:var(--bg2);border-top:1px solid var(--bd)}
.qbw-faq-inner{max-width:700px;margin:0 auto}
.qbw-faq-eye{font-size:8.5px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);opacity:.7;text-align:center;margin-bottom:4px}
.qbw-faq-ttl{font-size:clamp(17px,3.5vw,23px);font-weight:900;letter-spacing:-.3px;color:var(--txt);text-align:center;margin-bottom:18px}
.qbw-faq-list{display:flex;flex-direction:column;gap:6px}
.qbw-faq-item{background:var(--bg);border:1px solid var(--bd);border-radius:10px;overflow:hidden;transition:border-color .16s}
.qbw-faq-item.open{border-color:rgba(212,168,67,.28)}
.qbw-faq-q{display:flex;align-items:center;justify-content:space-between;padding:12px 15px;cursor:pointer;gap:10px;user-select:none;-webkit-tap-highlight-color:transparent}
.qbw-faq-qtxt{font-size:12.5px;font-weight:700;color:var(--txt);line-height:1.4;flex:1}
.qbw-faq-icon{width:22px;height:22px;border-radius:50%;background:var(--bg3);border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .2s,background .16s;font-size:13px;color:var(--sub)}
.qbw-faq-item.open .qbw-faq-icon{transform:rotate(45deg);background:rgba(212,168,67,.08);color:var(--gold2)}
.qbw-faq-body{max-height:0;overflow:hidden;transition:max-height .28s var(--ease)}
.qbw-faq-body-inner{padding:0 15px 12px;font-size:11.5px;color:var(--sub);line-height:1.7}
.qbw-faq-item.open .qbw-faq-body{max-height:160px}

.qbw-foot{padding:32px 16px;background:var(--bg);border-top:1px solid var(--bd);text-align:center}
.qbw-foot-inner{max-width:480px;margin:0 auto}
.qbw-foot-ttl{font-size:19px;font-weight:900;color:var(--txt);margin-bottom:7px;letter-spacing:-.3px}
.qbw-foot-sub{font-size:12px;color:var(--sub);margin-bottom:18px;line-height:1.6}
.qbw-foot-btns{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:12px}
.qbw-foot-note{font-size:9px;color:var(--dim)}
.qbw-foot-note::before{content:'🔒 '}

/* ══ 2-ROW HORIZONTAL GRID SLIDER (5-12 products) ══ */
.qbw-s2wrap{overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;padding:8px 16px 20px}
.qbw-s2wrap::-webkit-scrollbar{display:none}
.qbw-s2{display:grid;grid-auto-flow:column;grid-template-rows:1fr 1fr;gap:9px;width:max-content}
.qbw-s2 .qbw-card{width:148px;min-width:130px;max-width:148px;flex:none}
@media(min-width:480px){.qbw-s2 .qbw-card{width:160px;max-width:160px}}
</style>

<!-- DATA LAYER -->
<div id="qbwData" style="display:none" aria-hidden="true">
  {%- for p in collection.products -%}
    <div class="qbwp"
      data-url="{{ p.url }}"
      data-title="{{ p.title | escape }}"
      data-type="{{ p.type | escape | downcase }}"
      data-tags="{{ p.tags | join: ',' | escape | downcase }}"
      data-img="{%- if p.featured_image -%}{{ p.featured_image | img_url: '400x400', crop: 'center' }}{%- endif -%}"
      data-price="{{ p.price }}"
      data-compare="{{ p.compare_at_price | default: 0 }}"
      data-avail="{{ p.available }}"
      data-vendor="{{ p.vendor | escape }}"
    ></div>
  {%- endfor -%}
</div>

<div class="qbw">

<!-- TICKER -->
<div class="qbw-tick" aria-hidden="true">
  <div class="qbw-tick-inner">
    <span class="qbw-tick-item">🐝 Nepal's #1 Wholesale Platform</span>
