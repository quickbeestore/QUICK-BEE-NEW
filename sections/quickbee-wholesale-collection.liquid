<script>
(function(){
'use strict';
/* ═══════════════════════════════════════════════════════════
   QUICKBEE WHOLESALE — clean single-render, no duplicates
   ═══════════════════════════════════════════════════════════ */

/* ─── INGEST ─── */
var ALL = [];
document.querySelectorAll('#qbwData .qbwp').forEach(function(n){
  var cmp=parseInt(n.dataset.compare)||0, prc=parseInt(n.dataset.price)||0;
  var sv=cmp>prc&&cmp>0;
  ALL.push({
    url:n.dataset.url, title:n.dataset.title,
    type:(n.dataset.type||'').toLowerCase(),
    tags:(n.dataset.tags||'').toLowerCase(),
    img:n.dataset.img||'',
    price:prc, cmp:cmp, avail:n.dataset.avail==='true',
    vendor:(n.dataset.vendor||''),
    sv:sv, svPct:sv?Math.round((cmp-prc)*100/cmp):0, svAmt:sv?Math.round((cmp-prc)/100):0
  });
});

/* ─── UTILS ─── */
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function hay(p){return p.type+' '+p.tags+' '+p.title.toLowerCase()+' '+p.vendor.toLowerCase();}
function hits(p,kws){return kws.some(function(k){return hay(p).indexOf(k)>-1;});}
function isType(p,types){return types.some(function(t){return p.type.indexOf(t)>-1;});}
function bySave(a){return a.slice().sort(function(x,y){return y.svPct-x.svPct;});}

/* ─── PER-CATEGORY DEDUPER ─── */
/* Returns a claim(fn) function. Each call removes matched items from the pool.
   Call with no fn to claim all remaining. */
function deduper(pool){
  var rem=pool.slice();
  return function(fn){
    var out=rem.filter(fn||function(){return true;});
    out.forEach(function(p){var i=rem.indexOf(p);if(i>-1)rem.splice(i,1);});
    return out;
  };
}

/* ─── PRICE ─── */
function priceHtml(p,big){
  if(!p.price) return '';
  var sz=big?'font-size:17px':'';
  if(p.sv) return '<div class="qbw-price"><div class="qbw-price-row"><span class="qbw-price-now" style="'+sz+'">Rs '+Math.round(p.price/100)+'</span><span class="qbw-price-was">Rs '+Math.round(p.cmp/100)+'</span></div><div class="qbw-price-save">Save Rs '+p.svAmt+' ('+p.svPct+'%)</div></div>';
  return '<div class="qbw-price"><div class="qbw-price-row"><span class="qbw-price-now" style="'+sz+'">Rs '+Math.round(p.price/100)+'</span></div></div>';
}

/* ─── BADGE / IMAGE ─── */
function badge(p){
  var b1=p.sv?'<div class="qbw-b-save">−'+p.svPct+'%</div>':'';
  var t=p.tags;
  var b2=(t.indexOf('best-seller')>-1||t.indexOf('bestseller')>-1)?'<span class="qbw-b-tag qbw-b-best">⭐ Best</span>'
        :(t.indexOf('high-demand')>-1||t.indexOf('demand')>-1)?'<span class="qbw-b-tag qbw-b-hot">🔥 Hot</span>'
        :(/(?:^|,)\s*new\s*(?:,|$)/.test(t))?'<span class="qbw-b-tag qbw-b-new">✦ New</span>':'';
  return b1+b2;
}
function soldMask(p){return p.avail?'':'<div class="qbw-sold"><span>Out of Stock</span></div>';}
function imgTag(p,cls){return p.img?'<img src="'+p.img+'" alt="'+esc(p.title)+'" loading="lazy" width="400" height="400">':'<div class="'+cls+'">📦</div>';}

/* ─── LAYOUT HELPERS ─── */
function secWrap(id,eye,name,cnt,inner){
  return '<div class="qbw-sec" id="s-'+id+'">'
    +'<div class="qbw-sec-head"><div>'
    +'<div class="qbw-sec-eye">'+eye+'</div>'
    +'<div class="qbw-sec-name">'+name+'</div>'
    +'<div class="qbw-sec-cnt">'+cnt+' product'+(cnt!==1?'s':'')+'</div>'
    +'</div></div>'
    +'<div class="qbw-rule"><div class="qbw-rule-inner"></div></div>'
    +inner+'</div>';
}
function grp(emo,name,sub){
  return '<div class="qbw-grp"><div class="qbw-grp-inner"><span class="qbw-grp-emo">'+emo+'</span>'
    +'<div><div class="qbw-grp-name">'+name+'</div><div class="qbw-grp-sub">'+sub+'</div></div></div></div>';
}
function cta(tag,title,sub){
  return '<div class="qbw-cta" style="margin-left:auto;margin-right:auto;max-width:1100px">'
    +'<div><div class="qbw-cta-tag">'+tag+'</div><div class="qbw-cta-title">'+title+'</div><div class="qbw-cta-sub">'+sub+'</div></div>'
    +'<a href="/products/vendor-registration" class="qbw-btn-gold" style="font-size:12px;flex-shrink:0">Register Now →</a></div>';
}

/* Card HTML (used by slider + 2-row) */
function cardHtml(p){
  return '<a href="'+p.url+'" class="qbw-card">'
    +'<div class="qbw-card-img">'+imgTag(p,'qbw-card-empty')+'<div class="qbw-card-fade"></div>'+badge(p)+soldMask(p)+'</div>'
    +'<div class="qbw-card-body">'+(p.type?'<div class="qbw-card-type">'+esc(p.type)+'</div>':'')
    +'<div class="qbw-card-name">'+esc(p.title)+'</div>'+priceHtml(p,false)+'</div></a>';
}

/* LAYOUT: single-row horizontal slider (13+ products) */
function layoutSlider(id,eye,name,prods){
  return secWrap(id,eye,name,prods.length,
    '<div class="qbw-slider"><div class="qbw-slider-row">'+prods.map(cardHtml).join('')+'</div></div>');
}

/* LAYOUT: 2-row horizontal grid (5-12 products) */
function layout2Row(id,eye,name,prods){
  return secWrap(id,eye,name,prods.length,
    '<div class="qbw-s2wrap"><div class="qbw-s2">'+prods.map(cardHtml).join('')+'</div></div>');
}

/* LAYOUT: standard grid (2-4 products) */
function layoutGrid(id,eye,name,prods){
  var n=prods.length;
  var cls=n===2?'qbw-grid--2':n===3?'qbw-grid--3':'qbw-grid--4';
  var cards=prods.map(function(p){
    return '<a href="'+p.url+'" class="qbw-gcard">'
      +'<div class="qbw-gcard-img">'+imgTag(p,'qbw-gcard-empty')+'<div class="qbw-gcard-fade"></div>'+badge(p)+soldMask(p)+'</div>'
      +'<div class="qbw-gcard-body">'+(p.type?'<div class="qbw-gcard-type">'+esc(p.type)+'</div>':'')
      +'<div class="qbw-gcard-name">'+esc(p.title)+'</div>'+priceHtml(p,false)+'</div></a>';
  }).join('');
  return secWrap(id,eye,name,n,'<div class="qbw-grid '+cls+'">'+cards+'</div>');
}

/* LAYOUT: hero single */
function layoutHero(id,eye,name,p){
  var imgEl=p.img?'<img src="'+p.img+'" alt="'+esc(p.title)+'" loading="lazy" width="400" height="400">':'<div class="qbw-hero-img-empty">📦</div>';
  var bdg=p.sv?'<div class="qbw-hero-badge">−'+p.svPct+'% · Rs '+p.svAmt+' off</div>':'';
  var vendor=p.vendor?'<div class="qbw-hero-vendor">'+esc(p.vendor)+'</div>':'';
  return secWrap(id,eye,name,1,
    '<a href="'+p.url+'" class="qbw-hero-card">'
    +'<div class="qbw-hero-img">'+imgEl+'</div>'
    +'<div class="qbw-hero-body"><div class="qbw-hero-glow"></div>'
    +'<div class="qbw-hero-eye">'+esc(eye)+'</div>'
    +'<div class="qbw-hero-name">'+esc(p.title)+'</div>'
    +vendor+bdg+priceHtml(p,true)+'</div></a>');
}

/* LAYOUT: duo (2 big cards) */
function layoutDuo(id,eye,name,prods){
  var top=prods.slice(0,2);
  var cards=top.map(function(p){
    var bd=p.sv?'<div class="qbw-duo-b-save">−'+p.svPct+'%</div>':'';
    var imgEl=p.img?'<img src="'+p.img+'" alt="'+esc(p.title)+'" loading="lazy" width="400" height="400">':'<div class="qbw-duo-empty">📦</div>';
    var pr=p.sv?'<div class="qbw-duo-price-now">Rs '+Math.round(p.price/100)+'</div><div style="font-size:9px;color:var(--dim);text-decoration:line-through">Rs '+Math.round(p.cmp/100)+'</div>'
              :(p.price>0?'<div class="qbw-duo-price-now">Rs '+Math.round(p.price/100)+'</div>':'');
    return '<a href="'+p.url+'" class="qbw-duo-card">'
      +'<div class="qbw-duo-img">'+imgEl+'<div class="qbw-duo-fade"></div>'+bd+soldMask(p)+'</div>'
      +'<div class="qbw-duo-body">'+(p.type?'<div class="qbw-duo-type">'+esc(p.type)+'</div>':'')
      +'<div class="qbw-duo-name">'+esc(p.title)+'</div>'+pr+'</div></a>';
  }).join('');
  return secWrap(id,eye,name,prods.length,'<div class="qbw-duo">'+cards+'</div>');
}

/* Smart layout: picks layout based on count */
function sec(id,eye,name,prods){
  if(!prods||!prods.length) return '';
  var n=prods.length;
  if(n===1) return layoutHero(id,eye,name,prods[0]);
  if(n===2) return layoutDuo(id,eye,name,prods);
  if(n<=4)  return layoutGrid(id,eye,name,prods);
  if(n<=12) return layout2Row(id,eye,name,prods);
  return layoutSlider(id,eye,name,prods);
}

/* ══════════════════════════════
   CATEGORY BUILDING — STRICT DEDUP
   Each product appears in EXACTLY ONE subcategory.
   Global set tracks used URLs across ALL categories.
   ══════════════════════════════ */

var USED = {}; // global dedup across all categories
function globalClaim(arr){
  var out=arr.filter(function(p){return !USED[p.url];});
  out.forEach(function(p){USED[p.url]=true;});
  return out;
}

var H = '';

/* ── FLASH DEALS (independent — doesn't affect category sections) ── */
var FLASH = bySave(ALL.filter(function(p){return p.sv&&p.svPct>=10;})).slice(0,24);
H += sec('flash','🔥 FLASH DEALS','Flash Deals — Best Savings',FLASH);

/* ══ WHISKY ══
   Strict filter: must have whisky/whiskey keyword but exclude
   products whose type is clearly liqueur/beer/etc. */
(function(){
  var pool = ALL.filter(function(p){
    if(USED[p.url]) return false;
    var h=hay(p);
    if(h.indexOf('whisky')<0 && h.indexOf('whiskey')<0) return false;
    // exclude mismatches (e.g. "Whisky Liqueur Chocolates", Drambuie etc.)
    if(isType(p,['liqueur','beer','wine','vodka','gin','rum','brandy','cognac'])) return false;
    if(hits(p,['chocolate','praline','truffle','candy','dessert','cream liqueur','whisky liqueur'])) return false;
    return true;
  });
  if(!pool.length) return;
  var c=deduper(pool);
  var W_REG  = c(function(p){return hits(p,['regular whisky','black label','red label','old tavern','bagpiper','teachers','vat 69','blenders','antiquity','royal stag','imperial blue','signature','dsp black','officers','100 pipers','something special','black dog','old smuggler']);});
  var W_PREM = c(function(p){return hits(p,['premium','gold label','blue label','double black','platinum','chivas','ballantine','dewar','famous grouse','grants','william peel','johnnie walker','passport scotch','the glenlivet']);});
  var W_BOUR = c(function(p){return hits(p,['bourbon','american whiskey','jack daniel','jim beam','maker','wild turkey','knob creek','bulleit','woodford','buffalo trace']);});
  var W_MALT = c(function(p){return hits(p,['single malt','glenfiddich','macallan','laphroaig','glenmorangie','balvenie','talisker','ardbeg','bowmore','lagavulin','singleton','highland park','dalmore','oban','auchentoshan']);});
  var W_DOM  = c(function(p){return hits(p,['khukuri','old durbar','kumari','8848','coronation','himalayan whisky','nepal whisky','yeti whisky','ruslan']);});
  var W_OTH  = c(); // remaining whisky
  pool.forEach(function(p){USED[p.url]=true;});
  H += grp('🥃','Whisky','Regular · Premium · Bourbon · Single Malt · Domestic');
  H += sec('w-reg','WHISKY · REGULAR','Regular Whisky',globalClaim(W_REG));
  H += sec('w-prem','WHISKY · PREMIUM','Premium Whisky',globalClaim(W_PREM));
  H += sec('w-bour','WHISKY · BOURBON','American &amp; Bourbon Whiskey',globalClaim(W_BOUR));
  H += sec('w-malt','WHISKY · SINGLE MALT','Single Malt Scotch',globalClaim(W_MALT));
  H += sec('w-dom','WHISKY · DOMESTIC','Domestic Whisky',globalClaim(W_DOM));
  if(W_OTH.length) H += sec('w-oth','WHISKY · OTHER','More Whisky',globalClaim(W_OTH));
})();

/* ══ VODKA ══ */
(function(){
  var pool=ALL.filter(function(p){
    if(USED[p.url]) return false;
    return isType(p,['vodka'])||(hay(p).indexOf('vodka')>-1&&!isType(p,['whisky','whiskey','beer','wine','gin','rum','liqueur','brandy']));
  });
  if(!pool.length) return;
  var c=deduper(pool);
  var V_IMP=c(function(p){return hits(p,['absolut','grey goose','belvedere','smirnoff','ciroc','tito','ketel','stolichnaya','stoli','finlandia','russian standard','skyy','imported']);});
  var V_DOM=c(function(p){return hits(p,['domestic','nepal','ruslan','khukuri','himalayan','kumari']);});
  var V_OTH=c();
  pool.forEach(function(p){USED[p.url]=true;});
  H += grp('🧊','Vodka','Imported · Domestic');
  H += sec('v-imp','VODKA · IMPORTED','Imported Vodka',globalClaim(V_IMP));
  H += sec('v-dom','VODKA · DOMESTIC','Domestic Vodka',globalClaim(V_DOM));
  if(V_OTH.length) H += sec('v-oth','VODKA · OTHER','More Vodka',globalClaim(V_OTH));
})();

/* ══ BEER ══ */
(function(){
  var pool=ALL.filter(function(p){
    if(USED[p.url]) return false;
    return isType(p,['beer','lager','ale','stout','pilsner'])||
      (hits(p,['beer','lager','ale','stout','pilsner'])&&!isType(p,['whisky','vodka','wine','gin','rum','liqueur','brandy']));
  });
  if(!pool.length) return;
  var c=deduper(pool);
  var BE_DOM   =c(function(p){return hits(p,['everest','gorkha','nepal ice','star beer','tuborg nepal','carlsberg nepal','yak beer','nepal beer']);});
  var BE_IMP   =c(function(p){return hits(p,['heineken','corona','budweiser','stella','asahi','kirin','kingfisher','leffe','tiger','chang','san miguel','hoegaarden','erdinger','paulaner']);});
  var BE_CRAFT =c(function(p){return hits(p,['craft','ipa','pale ale','wheat beer','porter','stout']);});
  var BE_BULK  =c(function(p){return hits(p,['case','bulk','6 pack','12 pack','24 pack','carton','slab']);});
  var BE_NA    =c(function(p){return hits(p,['non alcoholic','non-alcoholic','alcohol free','0%','zero beer','0.0']);});
  var BE_OTH   =c();
  pool.forEach(function(p){USED[p.url]=true;});
  H += grp('🍺','Beer','Domestic · Imported · Craft · Bulk · Non-Alcoholic');
  H += sec('be-dom','BEER · DOMESTIC','Domestic Beer',globalClaim(BE_DOM));
  H += sec('be-imp','BEER · IMPORTED','Imported Beer',globalClaim(BE_IMP));
  H += sec('be-craft','BEER · CRAFT','Craft Beer',globalClaim(BE_CRAFT));
  H += sec('be-bulk','BEER · BULK','Bulk Cases',globalClaim(BE_BULK));
  H += sec('be-na','BEER · NA','Non-Alcoholic Beer',globalClaim(BE_NA));
  if(BE_OTH.length) H += sec('be-oth','BEER · OTHER','More Beer',globalClaim(BE_OTH));
})();

/* ══ BRANDY & COGNAC ══ */
(function(){
  var pool=ALL.filter(function(p){
    if(USED[p.url]) return false;
    return (isType(p,['brandy','cognac'])||hits(p,['brandy','cognac']))&&
      !isType(p,['whisky','beer','wine','vodka','gin','rum','liqueur']);
  });
  if(!pool.length) return;
  var c=deduper(pool);
  var B_VS   =c(function(p){return hits(p,[' vs ',' vs ','very special']);});
  var B_VSOP =c(function(p){return hits(p,['vsop']);});
  var B_NAP  =c(function(p){return hits(p,['napoleon']);});
  var B_XO   =c(function(p){return hits(p,[' xo ','extra old']);});
  var B_DOM  =c(function(p){return hits(p,['marpha','mustang','nepal brandy','himalayan brandy','domestic brandy']);});
  var B_OTH  =c();
  pool.forEach(function(p){USED[p.url]=true;});
  H += grp('🍇','Brandy &amp; Cognac','VS · VSOP · Napoleon · XO · Domestic');
  H += sec('b-vs','COGNAC · VS','VS Cognac',globalClaim(B_VS));
  H += sec('b-vsop','COGNAC · VSOP','VSOP Cognac',globalClaim(B_VSOP));
  H += sec('b-nap','COGNAC · NAPOLEON','Napoleon Cognac',globalClaim(B_NAP));
  H += sec('b-xo','COGNAC · XO','XO Cognac',globalClaim(B_XO));
  H += sec('b-dom','BRANDY · DOMESTIC','Domestic Brandy',globalClaim(B_DOM));
  if(B_OTH.length) H += sec('b-oth','BRANDY · OTHER','More Brandy',globalClaim(B_OTH));
})();

H += cta('Licensed Businesses Only','Unlock Full Wholesale Pricing','Register your business · up to 40% savings on every order.');

/* ══ GIN ══ */
(function(){
  var pool=ALL.filter(function(p){
    if(USED[p.url]) return false;
    return isType(p,['gin'])||(hay(p).indexOf(' gin')>-1&&!isType(p,['whisky','beer','wine','vodka','rum','liqueur','brandy']));
  });
  if(!pool.length) return;
  var c=deduper(pool);
  var G_IMP=c(function(p){return hits(p,['tanqueray','hendrick','bombay','beefeater','gordon','monkey 47','roku','malfy','sipsmith','whitley','imported']);});
  var G_DOM=c(function(p){return hits(p,['domestic','nepal','himalayan','khukuri']);});
  var G_OTH=c();
  pool.forEach(function(p){USED[p.url]=true;});
  H += grp('🌿','Gin','Imported · Domestic');
  H += sec('g-imp','GIN · IMPORTED','Imported Gin',globalClaim(G_IMP));
  H += sec('g-dom','GIN · DOMESTIC','Domestic Gin',globalClaim(G_DOM));
  if(G_OTH.length) H += sec('g-oth','GIN · OTHER','More Gin',globalClaim(G_OTH));
})();

/* ══ RUM ══ */
(function(){
  var pool=ALL.filter(function(p){
    if(USED[p.url]) return false;
    return isType(p,['rum'])||(hay(p).indexOf('rum')>-1&&!isType(p,['whisky','beer','wine','vodka','gin','liqueur','brandy']));
  });
