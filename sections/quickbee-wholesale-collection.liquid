.qbw-foot-qr{width:48px;height:48px;background:var(--bg2);border:1px solid var(--bd2);border-radius:8px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:7px;color:var(--dim);text-align:center;line-height:1.4}

/* ── LOAD MORE ── */
.qbw-loadmore-wrap{text-align:center;padding:24px 20px 0}
.qbw-loadmore-btn{display:inline-flex;align-items:center;gap:8px;background:var(--bg2);border:1.5px solid var(--bd2);color:var(--sub);font-size:13px;font-weight:800;padding:13px 28px;border-radius:9px;cursor:pointer;transition:border-color .15s,color .15s}
