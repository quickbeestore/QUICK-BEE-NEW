<script>
(function(){
'use strict';

/* ── Read all product data from DOM ── */
var nodes = document.querySelectorAll('#qbwData .qbw-pdata');
var allProducts = [];
nodes.forEach(function(n){
  var cmp = parseInt(n.dataset.compare)||0;
  var prc = parseInt(n.dataset.price)||0;
  var hasSave = cmp > prc && cmp > 0;
  var savePct = hasSave ? Math.round((cmp-prc)*100/cmp) : 0;
  var saveAmt = hasSave ? Math.round((cmp-prc)/100) : 0;
  allProducts.push({
    url: n.dataset.url,
    title: n.dataset.title,
    type: n.dataset.type||'',
    tags: n.dataset.tags||'',
    img: n.dataset.img||'',
    price: prc,
    compare: cmp,
    avail: n.dataset.avail==='true',
    vendor: n.dataset.vendor||'',
    best: n.dataset.bestseller==='1',
    demand: n.dataset.demand==='1',
    isNew: n.dataset.new==='1',
    hasSave: hasSave,
    savePct: savePct,
    saveAmt: saveAmt
  });
});

/* ── Build card HTML ── */
function card(p, big){
  var save='', demand='', sold='';
  if(p.hasSave) save='<div class="qbw-save-badge">−'+p.savePct+'%<small> Rs '+p.saveAmt+'</small></div>';
  if(p.best) demand='<span class="qbw-demand-tag qbw-demand-tag--best">⭐ Best</span>';
  else if(p.demand) demand='<span class="qbw-demand-tag qbw-demand-tag--hot">🔥 Hot</span>';
  else if(p.isNew) demand='<span class="qbw-demand-tag qbw-demand-tag--new">✦ New</span>';
  if(!p.avail) sold='<div class="qbw-sold-mask"><span class="qbw-sold-lbl">Out of Stock</span></div>';

  var imgHtml = p.img
    ? '<img src="'+p.img+'" alt="'+escHtml(p.title)+'" loading="lazy" width="400" height="400">'
    : '<div class="qbw-card-no-img">📦</div>';

  var priceHtml;
  {%- if customer and customer.tags contains 'wholesale-approved' -%}
  priceHtml='<div class="qbw-card-price"><span class="qbw-price-now">Rs '+Math.round(p.price/100)+'</span>'+(p.hasSave?'<span class="qbw-price-was">Rs '+Math.round(p.compare/100)+'</span>':'')+(p.hasSave?'<div class="qbw-price-save">Save Rs '+p.saveAmt+'</div>':'')+'</div>';
  {%- else -%}
  if(p.hasSave){
    priceHtml='<div class="qbw-card-price"><div class="qbw-price-retail">Retail Rs '+Math.round(p.compare/100)+'</div><div class="qbw-price-save">↓ Save '+p.savePct+'%</div><div class="qbw-price-unlock">🔒 Register to unlock</div></div>';
  } else {
    priceHtml='<div class="qbw-card-price"><div class="qbw-price-locked">Wholesale Price</div></div>';
  }
  {%- endif -%}

  var cls = big ? 'qbw-hero-card' : 'qbw-card';
  var typeLabel = p.type ? '<div class="qbw-card-type-lbl">'+escHtml(p.type)+'</div>' : '';

  return '<a href="'+p.url+'" class="'+cls+'">'
    +'<div class="qbw-card-img">'+imgHtml+'<div class="qbw-card-img-fade"></div>'+save+demand+sold+'</div>'
    +'<div class="qbw-card-body">'+typeLabel
    +'<div class="qbw-card-name">'+escHtml(p.title)+'</div>'
    +priceHtml
    +'</div></a>';
}

/* ── Image-only auto-scroll strip ── */
function makeImageStrip(id, products){
  if(!products.length) return '';
  var items = products.slice(0,20);
  while(items.length < 8) items = items.concat(items); // ensure enough for seamless loop
  var dur = Math.max(18, Math.round(items.length * 1.6)) + 's';
  var build = function(list){
    return list.map(function(p){
      var img = p.img
        ? '<img src="'+p.img+'" alt="'+escHtml(p.title)+'" loading="lazy">'
        : '<img src="" alt="" style="background:var(--bg3)">';
      return '<a href="'+p.url+'" class="qbw-istrip-item">'+img
        +'<div class="qbw-istrip-item-lbl">'+escHtml(p.title.substring(0,32))+'</div></a>';
    }).join('');
  };
  // duplicate for seamless infinite loop
  var inner = build(items) + build(items);
  return '<div class="qbw-istrip-outer"><div class="qbw-istrip-track" style="--qbw-strip-dur:'+dur+'">'+inner+'</div></div>';
}

function escHtml(s){
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ── Slider HTML ── */
function makeSlider(id, products, big){
  var cards = products.map(function(p){ return card(p, big); }).join('');
  return '<div class="qbw-slide-wrap" id="'+id+'-wrap">'
    +'<button class="qbw-arr qbw-arr-l" onclick="qbwScroll(this,-1)" aria-label="Prev">‹</button>'
    +'<div class="qbw-slide-outer"><div class="qbw-slide-track" id="'+id+'">'+cards+'</div></div>'
    +'<button class="qbw-arr qbw-arr-r" onclick="qbwScroll(this,1)" aria-label="Next">›</button>'
    +'</div>';
}

/* ── Grid HTML ── */
function makeGrid(products, cols){
  var cls = cols===5 ? 'qbw-grid-5' : 'qbw-grid-4';
  return '<div class="qbw-grid-wrap"><div class="'+cls+'">'+products.map(function(p){return card(p,false);}).join('')+'</div></div>';
}

/* ── Section HTML ── */
function makeSection(id, tag, title, subtitle, products, layout, big){
  if(!products.length) return '';
  var inner;
  if(layout==='imagestrip') inner = makeImageStrip(id, products);
  else if(layout==='slider') inner = makeSlider(id, products, big||false);
  else if(layout==='grid5') inner = makeGrid(products, 5);
  else inner = makeGrid(products, 4);

  return '<div class="qbw-sec" id="qbw-sec-'+id+'">'
    +'<div class="qbw-sec-head"><div>'
    +'<div class="qbw-sec-tag">'+tag+'</div>'
    +'<div class="qbw-sec-title">'+title+'</div>'
    +(subtitle?'<div class="qbw-sec-count">'+subtitle+'</div>':'')
    +'</div></div>'
    +inner+'</div>';
}

