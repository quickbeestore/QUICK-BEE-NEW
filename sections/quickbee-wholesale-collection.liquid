{%- paginate collection.products by 250 -%}
<style>
.qbw *,.qbw *::before,.qbw *::after{box-sizing:border-box;margin:0;padding:0}
.qbw{
  --c-bg:#0a0a0c;
  --c-bg2:#111114;
  --c-bg3:#17171b;
  --c-bg4:#1e1e23;
  --c-bd:rgba(255,255,255,.06);
  --c-bd2:rgba(255,255,255,.11);
  --c-gold:#d4a843;
  --c-gold2:#f0c55a;
  --c-gold3:#ffd97d;
  --c-grn:#22c55e;
  --c-red:#ef4444;
  --c-txt:#f0ece4;
  --c-sub:#8c8880;
  --c-dim:#4e4c49;
  --c-ease:cubic-bezier(.4,0,.2,1);
  background:var(--c-bg);
  color:var(--c-txt);
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  -webkit-font-smoothing:antialiased;
}

/* TICKER */
.qbw-ticker{background:var(--c-gold);color:#07050a;font-size:10px;font-weight:900;letter-spacing:.6px;text-transform:uppercase;padding:7px 0;overflow:hidden;white-space:nowrap}
.qbw-ticker-inner{display:inline-flex;animation:qtick 40s linear infinite}
@keyframes qtick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.qbw-ticker-item{padding:0 24px;border-right:1px solid rgba(0,0,0,.2);flex-shrink:0}

/* STICKY CATEGORY NAV */
.qbw-nav{position:sticky;top:0;z-index:200;background:rgba(10,10,12,.97);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border-bottom:1px solid var(--c-bd2)}
.qbw-nav-inner{display:flex;overflow-x:auto;scrollbar-width:none;padding:0 12px}
.qbw-nav-inner::-webkit-scrollbar{display:none}
.qbw-nav-btn{flex-shrink:0;display:flex;align-items:center;gap:5px;padding:10px 11px;font-size:11px;font-weight:700;color:var(--c-dim);background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:color .12s,border-color .12s;-webkit-tap-highlight-color:transparent}
.qbw-nav-btn:hover{color:var(--c-txt)}
.qbw-nav-btn.on{color:var(--c-gold2);border-bottom-color:var(--c-gold)}
.qbw-nav-btn .qbw-nav-count{font-size:9px;color:var(--c-dim);font-weight:600}
.qbw-nav-btn.on .qbw-nav-count{color:rgba(212,168,67,.6)}

/* INTRO STRIP — minimal, not giant */
.qbw-intro{padding:20px 16px 16px;max-width:1100px;margin:0 auto}
.qbw-intro-row{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.qbw-intro-left{}
.qbw-intro-title{font-size:18px;font-weight:900;letter-spacing:-.4px;color:var(--c-txt);line-height:1.2;margin-bottom:4px}
.qbw-intro-sub{font-size:12px;color:var(--c-sub);line-height:1.5}
.qbw-btn-gold{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,var(--c-gold),var(--c-gold2) 55%,var(--c-gold3));color:#07050a;font-size:12px;font-weight:900;padding:10px 18px;border-radius:9px;text-decoration:none;border:none;cursor:pointer;box-shadow:0 3px 16px rgba(212,168,67,.26);transition:transform .14s,box-shadow .14s;white-space:nowrap}
.qbw-btn-gold:hover{transform:translateY(-1px);box-shadow:0 6px 22px rgba(212,168,67,.38)}
.qbw-btn-outline{display:inline-flex;align-items:center;gap:6px;background:transparent;border:1.5px solid rgba(212,168,67,.24);color:var(--c-gold2);font-size:12px;font-weight:800;padding:9px 16px;border-radius:9px;text-decoration:none;cursor:pointer;transition:border-color .12s,background .12s;white-space:nowrap}
.qbw-btn-outline:hover{border-color:var(--c-gold);background:rgba(212,168,67,.05)}
.qbw-intro-btns{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}

/* STATS — compact inline */
.qbw-stats{display:flex;gap:0;border-top:1px solid var(--c-bd);border-bottom:1px solid var(--c-bd)}
.qbw-stats-inner{max-width:1100px;margin:0 auto;display:flex;width:100%}
.qbw-stat{flex:1;padding:14px 10px;text-align:center;border-right:1px solid var(--c-bd)}
.qbw-stat:last-child{border-right:none}
.qbw-stat-val{font-size:18px;font-weight:900;color:var(--c-gold2);letter-spacing:-.3px;line-height:1}
.qbw-stat-lbl{font-size:9px;color:var(--c-sub);margin-top:2px;line-height:1.4}

/* GROUP LABEL */
.qbw-grp{padding:28px 16px 0;max-width:1100px;margin:0 auto}
.qbw-grp-inner{display:flex;align-items:center;gap:10px;padding:11px 16px;background:var(--c-bg2);border:1px solid var(--c-bd);border-left:3px solid var(--c-gold);border-radius:10px}
.qbw-grp-emo{font-size:20px;flex-shrink:0}
.qbw-grp-txt{}
.qbw-grp-name{font-size:13.5px;font-weight:900;color:var(--c-gold2);letter-spacing:-.15px}
.qbw-grp-sub{font-size:10px;color:var(--c-sub);margin-top:1px}

/* SECTION */
.qbw-sec{padding:18px 0 0}
.qbw-sec-head{max-width:1100px;margin:0 auto;padding:0 16px 8px;display:flex;align-items:flex-end;justify-content:space-between}
.qbw-sec-eyebrow{font-size:8px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--c-gold);opacity:.65;margin-bottom:2px}
.qbw-sec-name{font-size:16px;font-weight:900;letter-spacing:-.25px;color:var(--c-txt);line-height:1.1}
.qbw-sec-count{font-size:9.5px;color:var(--c-dim);margin-top:2px}
.qbw-rule{height:1px;background:linear-gradient(90deg,rgba(212,168,67,.15),transparent);max-width:1100px;margin:0 auto;padding:0 16px}
.qbw-rule-inner{height:1px;background:linear-gradient(90deg,rgba(212,168,67,.2),transparent)}

/* SLIDER */
.qbw-slide-wrap{position:relative}
.qbw-slide{overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;padding:8px 16px 20px;scroll-snap-type:x mandatory}
.qbw-slide::-webkit-scrollbar{display:none}
.qbw-slide-row{display:flex;gap:9px;width:max-content}

/* CARD */
.qbw-card{flex:0 0 calc(44vw - 16px);max-width:188px;min-width:132px;background:var(--c-bg2);border:1px solid var(--c-bd);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;text-decoration:none;color:inherit;scroll-snap-align:start;transition:border-color .18s,transform .16s;position:relative;-webkit-tap-highlight-color:transparent}
@media(min-width:480px){.qbw-card{flex:0 0 165px;max-width:165px}}
@media(min-width:640px){.qbw-card{flex:0 0 180px;max-width:180px}}
@media(min-width:900px){.qbw-card{flex:0 0 196px;max-width:196px}}
.qbw-card:active{transform:scale(.96)}
.qbw-card:hover{border-color:rgba(212,168,67,.4)}

/* card img */
.qbw-card-img{position:relative;aspect-ratio:1/1;background:linear-gradient(160deg,var(--c-bg3),#0b0b0d);overflow:hidden}
.qbw-card-img img{width:100%;height:100%;object-fit:contain;object-position:center;padding:10px;display:block;transition:transform .32s var(--c-ease)}
.qbw-card:hover .qbw-card-img img{transform:scale(1.05)}
.qbw-card-img-fade{position:absolute;bottom:0;left:0;right:0;height:28px;background:linear-gradient(to top,var(--c-bg2),transparent);pointer-events:none}
.qbw-card-empty{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:28px;opacity:.07}
/* badges */
.qbw-badge{position:absolute;top:7px;left:7px;font-size:7.5px;font-weight:900;padding:2px 6px;border-radius:16px;letter-spacing:.3px;line-height:1.4;white-space:nowrap}
.qbw-badge--save{background:linear-gradient(135deg,#14532d,#16a34a);color:#fff;box-shadow:0 2px 8px rgba(22,163,74,.35)}
.qbw-badge-corner{position:absolute;bottom:7px;left:7px;font-size:7px;font-weight:900;letter-spacing:.4px;text-transform:uppercase;padding:2px 6px;border-radius:4px}
.qbw-badge-corner--best{background:rgba(212,168,67,.9);color:#0a0700}
.qbw-badge-corner--hot{background:rgba(239,68,68,.14);border:1px solid rgba(239,68,68,.28);color:#f87171;backdrop-filter:blur(4px)}
.qbw-badge-corner--new{background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.28);color:#4ade80;backdrop-filter:blur(4px)}
.qbw-sold-mask{position:absolute;inset:0;background:rgba(6,6,8,.68);display:flex;align-items:center;justify-content:center}
.qbw-sold-lbl{font-size:8.5px;font-weight:900;letter-spacing:1.2px;text-transform:uppercase;color:var(--c-sub);border:1px solid var(--c-bd2);padding:4px 10px;border-radius:4px;background:var(--c-bg)}
/* card body */
.qbw-card-body{padding:9px 10px 11px;flex:1;display:flex;flex-direction:column}
.qbw-card-type{font-size:7px;font-weight:900;letter-spacing:1.6px;text-transform:uppercase;color:var(--c-gold);opacity:.5;margin-bottom:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.qbw-card-name{font-size:11px;font-weight:700;line-height:1.35;color:var(--c-txt);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;flex:1;margin-bottom:7px}
/* price */
.qbw-price{margin-top:auto}
.qbw-price-row{display:flex;align-items:baseline;gap:5px;flex-wrap:wrap;margin-bottom:1px}
.qbw-price-now{font-size:14px;font-weight:900;color:var(--c-gold2);letter-spacing:-.3px;line-height:1}
.qbw-price-was{font-size:9px;color:var(--c-dim);text-decoration:line-through}
.qbw-price-save{font-size:8px;font-weight:800;color:var(--c-grn)}
.qbw-price-locked{font-size:8.5px;font-weight:700;color:var(--c-sub);display:flex;align-items:center;gap:4px;padding:5px 8px;background:rgba(255,255,255,.025);border:1px solid var(--c-bd);border-radius:6px}
.qbw-price-locked::before{content:'🔒';font-size:9px}
.qbw-price-retail{font-size:8px;color:var(--c-dim);margin-bottom:1px}
.qbw-price-hint{font-size:7.5px;color:var(--c-dim);margin-top:1px}

/* MID-PAGE CTA BANNER */
.qbw-cta-strip{margin:28px 16px 0;background:linear-gradient(135deg,rgba(212,168,67,.07),rgba(212,168,67,.02));border:1px solid rgba(212,168,67,.14);border-radius:12px;padding:20px 18px;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;position:relative;overflow:hidden;max-width:1100px;margin-left:auto;margin-right:auto}
.qbw-cta-strip::after{content:'🔒';position:absolute;right:16px;top:50%;transform:translateY(-50%);font-size:60px;opacity:.04;pointer-events:none}
.qbw-cta-tag{font-size:8px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(--c-gold);margin-bottom:3px}
.qbw-cta-title{font-size:15px;font-weight:900;color:var(--c-txt);margin-bottom:3px;letter-spacing:-.2px}
.qbw-cta-sub{font-size:11px;color:var(--c-sub);line-height:1.5}
@media(max-width:560px){.qbw-cta-strip{flex-direction:column;align-items:flex-start}}

/* BOTTOM SECTIONS */
.qbw-bottom{margin-top:40px}

.qbw-faq{padding:36px 16px;background:var(--c-bg)}
.qbw-faq-inner{max-width:700px;margin:0 auto}
.qbw-faq-list{margin-top:18px;display:flex;flex-direction:column;gap:6px}
.qbw-faq-item{background:var(--c-bg2);border:1px solid var(--c-bd);border-radius:10px;overflow:hidden;transition:border-color .16s}
.qbw-faq-item.open{border-color:rgba(212,168,67,.28)}
.qbw-faq-q{display:flex;align-items:center;justify-content:space-between;padding:12px 15px;cursor:pointer;gap:10px;user-select:none;-webkit-tap-highlight-color:transparent}
.qbw-faq-qtxt{font-size:12.5px;font-weight:700;color:var(--c-txt);line-height:1.4;flex:1}
.qbw-faq-icon{width:22px;height:22px;border-radius:50%;background:var(--c-bg3);border:1px solid var(--c-bd);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .2s,background .16s;font-size:13px;color:var(--c-sub)}
.qbw-faq-item.open .qbw-faq-icon{transform:rotate(45deg);background:rgba(212,168,67,.08);color:var(--c-gold2)}
.qbw-faq-body{max-height:0;overflow:hidden;transition:max-height .28s var(--c-ease)}
.qbw-faq-body-inner{padding:0 15px 12px;font-size:11.5px;color:var(--c-sub);line-height:1.7}
.qbw-faq-item.open .qbw-faq-body{max-height:160px}

.qbw-close{padding:52px 16px;background:var(--c-bg2);text-align:center;border-top:1px solid var(--c-bd);position:relative;overflow:hidden}
.qbw-close::before{content:'';position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:500px;height:340px;background:radial-gradient(ellipse,rgba(212,168,67,.07) 0%,transparent 65%);pointer-events:none}
.qbw-close-inner{max-width:500px;margin:0 auto;position:relative}
.qbw-close-tag{font-size:8.5px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--c-gold);margin-bottom:10px}
.qbw-close-h2{font-size:clamp(22px,5vw,38px);font-weight:900;letter-spacing:-.8px;color:var(--c-txt);line-height:1.08;margin-bottom:10px}
.qbw-close-h2 em{font-style:normal;background:linear-gradient(90deg,var(--c-gold),var(--c-gold3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.qbw-close-p{font-size:13px;color:var(--c-sub);line-height:1.65;margin-bottom:24px}
.qbw-close-btns{display:flex;gap:9px;justify-content:center;flex-wrap:wrap;margin-bottom:12px}
.qbw-close-note{font-size:9px;color:var(--c-dim);letter-spacing:.3px}
.qbw-close-note::before{content:'🔒 '}
</style>

<!-- DATA LAYER (hidden) -->
<div id="qbwData" style="display:none" aria-hidden="true">
  {%- for p in collection.products -%}
    <div class="qbwp"
      data-url="{{ p.url }}"
      data-title="{{ p.title | escape }}"
      data-type="{{ p.type | escape | downcase }}"
      data-tags="{{ p.tags | join: ',' | escape | downcase }}"
      data-img="{%- if p.featured_image -%}{{ p.featured_image | img_url: '400x400', crop: 'center' }}{%- endif -%}"
      data-price="{{ p.price }}"
      data-compare="{{ p.compare_at_price | default: 0 }}"
      data-avail="{{ p.available }}"
      data-vendor="{{ p.vendor | escape }}"
    ></div>
  {%- endfor -%}
</div>

<div class="qbw">

<!-- TICKER -->
<div class="qbw-ticker" aria-hidden="true">
  <div class="qbw-ticker-inner">
    <span class="qbw-ticker-item">🐝 Nepal's #1 B2B Wholesale Platform</span>
    <span class="qbw-ticker-item">⚡ 24hr Dispatch · Same-Day Valley Delivery</span>
    <span class="qbw-ticker-item">🏨 Restaurants · Bars · Hotels · Clubs · Cafés</span>
    <span class="qbw-ticker-item">💳 Credit Terms for Approved Businesses</span>
    <span class="qbw-ticker-item">📦 Bulk Case Orders — Best Per-Unit Pricing</span>
    <span class="qbw-ticker-item">🐝 Nepal's #1 B2B Wholesale Platform</span>
    <span class="qbw-ticker-item">⚡ 24hr Dispatch · Same-Day Valley Delivery</span>
    <span class="qbw-ticker-item">🏨 Restaurants · Bars · Hotels · Clubs · Cafés</span>
    <span class="qbw-ticker-item">💳 Credit Terms for Approved Businesses</span>
    <span class="qbw-ticker-item">📦 Bulk Case Orders — Best Per-Unit Pricing</span>
  </div>
</div>

<!-- STICKY CATEGORY NAV (built by JS) -->
<div class="qbw-nav"><div class="qbw-nav-inner" id="qbwNav"></div></div>

<!-- INTRO (minimal) -->
<div style="padding:14px 16px;max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;border-bottom:1px solid var(--c-bd)">
  <div>
    <div style="font-size:15px;font-weight:900;color:var(--c-txt);letter-spacing:-.3px">QuickBee Wholesale <span style="font-size:11px;color:var(--c-sub);font-weight:500">— {{ collection.products_count }}+ products · 42 categories</span></div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <a href="/products/vendor-registration" class="qbw-btn-gold" style="font-size:11.5px;padding:9px 16px">Register Business →</a>
    <a href="/pages/contact-support" class="qbw-btn-outline" style="font-size:11.5px;padding:8px 14px">Contact Sales</a>
  </div>
</div>

<!-- ALL DYNAMIC PRODUCT SECTIONS -->
<div id="qbwSections"></div>

<!-- BOTTOM INFO SECTIONS -->
<div class="qbw-bottom">

  <!-- FAQ -->
  <div class="qbw-faq">
    <div class="qbw-faq-inner">
      <div class="qbw-s-eyebrow">FAQ</div>
      <div class="qbw-s-title">Common Questions</div>
      <div class="qbw-faq-list">
        <div class="qbw-faq-item"><div class="qbw-faq-q" onclick="qbwFaq(this)"><span class="qbw-faq-qtxt">Who can order from QuickBee Wholesale?</span><span class="qbw-faq-icon">+</span></div><div class="qbw-faq-body"><div class="qbw-faq-body-inner">Licensed businesses only — restaurants, bars, clubs, hotels, cafés, hookah lounges, and licensed retailers across Nepal.</div></div></div>
        <div class="qbw-faq-item"><div class="qbw-faq-q" onclick="qbwFaq(this)"><span class="qbw-faq-qtxt">How do I see wholesale prices?</span><span class="qbw-faq-icon">+</span></div><div class="qbw-faq-body"><div class="qbw-faq-body-inner">Register your business. Once verified (24–48 hours), all wholesale pricing unlocks — up to 40% below retail.</div></div></div>
        <div class="qbw-faq-item"><div class="qbw-faq-q" onclick="qbwFaq(this)"><span class="qbw-faq-qtxt">What payment methods are accepted?</span><span class="qbw-faq-icon">+</span></div><div class="qbw-faq-body"><div class="qbw-faq-body-inner">eSewa, Khalti, bank transfers, and QuickPay credit terms. Orders above Rs 50,000 qualify for 30-day credit.</div></div></div>
        <div class="qbw-faq-item"><div class="qbw-faq-q" onclick="qbwFaq(this)"><span class="qbw-faq-qtxt">How fast is delivery?</span><span class="qbw-faq-icon">+</span></div><div class="qbw-faq-body"><div class="qbw-faq-body-inner">Next-day (24hr) within Kathmandu Valley. Same-day available for urgent orders placed before 12 PM.</div></div></div>
        <div class="qbw-faq-item"><div class="qbw-faq-q" onclick="qbwFaq(this)"><span class="qbw-faq-qtxt">Is there a minimum order?</span><span class="qbw-faq-icon">+</span></div><div class="qbw-faq-body"><div class="qbw-faq-body-inner">No strict minimum. Case orders (6/12/24 units) get the best per-unit pricing. Your account manager advises optimal quantities.</div></div></div>
      </div>
    </div>
  </div>

  <!-- Closing CTA -->
  <div style="padding:36px 16px;background:var(--c-bg2);border-top:1px solid var(--c-bd);text-align:center">
    <div style="max-width:480px;margin:0 auto">
      <div style="font-size:20px;font-weight:900;color:var(--c-txt);margin-bottom:8px;letter-spacing:-.3px">Unlock Wholesale Pricing</div>
      <div style="font-size:12px;color:var(--c-sub);margin-bottom:18px;line-height:1.6">Register your business to access up to 40% below retail. 24hr delivery across Kathmandu Valley.</div>
      <div style="display:flex;gap:9px;justify-content:center;flex-wrap:wrap">
        <a href="/products/vendor-registration" class="qbw-btn-gold" style="font-size:13px;padding:12px 22px">Register Your Business →</a>
        <a href="/pages/contact-support" class="qbw-btn-outline" style="font-size:13px;padding:11px 20px">Contact Sales</a>
      </div>
      <div style="font-size:9px;color:var(--c-dim);margin-top:12px">🔒 Licensed businesses only · Nepal</div>
    </div>
  </div>

</div><!-- /.qbw-bottom -->
</div><!-- /.qbw -->

<script>
(function(){
'use strict';

/* ─── INGEST PRODUCT DATA ─── */
var ALL = [];
document.querySelectorAll('#qbwData .qbwp').forEach(function(n){
  var cmp = parseInt(n.dataset.compare)||0;
  var prc = parseInt(n.dataset.price)||0;
  var sv  = cmp > prc && cmp > 0;
  ALL.push({
    url:   n.dataset.url,
    title: n.dataset.title,
    type:  (n.dataset.type||'').toLowerCase(),
    tags:  (n.dataset.tags||'').toLowerCase(),
    img:   n.dataset.img||'',
    price: prc, cmp: cmp,
    avail: n.dataset.avail === 'true',
    vendor:(n.dataset.vendor||''),
    sv: sv,
    svPct: sv ? Math.round((cmp-prc)*100/cmp) : 0,
    svAmt: sv ? Math.round((cmp-prc)/100) : 0
  });
});

/* ─── UTILITIES ─── */
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

/* match any keyword against type + tags + title + vendor — NO deduplication between categories */
function hit(p, kws){
  var h = p.type + ' ' + p.tags + ' ' + p.title.toLowerCase() + ' ' + p.vendor.toLowerCase();
  return kws.some(function(k){ return h.indexOf(k) > -1; });
}
function filter(fn){ return ALL.filter(fn); }
function kw(words){ return filter(function(p){ return hit(p, words); }); }

/* sort helpers */
function byPop(a){ return a.slice().sort(function(x,y){ return (y.sv-x.sv)||(y.svPct-x.svPct); }); }
function bySave(a){ return a.slice().sort(function(x,y){ return y.svPct-x.svPct; }); }

/* curated sections use tags only (deduplication only here, so same product doesn't repeat in flash+best etc.) */
var _usedCurated = {};
function takeCurated(fn){
  var out = ALL.filter(function(p){ return !_usedCurated[p.url] && fn(p); });
  out.forEach(function(p){ _usedCurated[p.url]=true; });
  return out;
}

/* ─── PRICE BLOCK ─── */
function priceHtml(p){
  {%- if customer and customer.tags contains 'wholesale-approved' -%}
    if(p.sv){
      return '<div class="qbw-price">'
        +'<div class="qbw-price-row"><span class="qbw-price-now">Rs '+Math.round(p.price/100)+'</span>'
        +'<span class="qbw-price-was">Rs '+Math.round(p.cmp/100)+'</span></div>'
        +'<div class="qbw-price-save">Save Rs '+p.svAmt+' ('+p.svPct+'% off)</div>'
        +'</div>';
    }
    return '<div class="qbw-price"><div class="qbw-price-row"><span class="qbw-price-now">Rs '+Math.round(p.price/100)+'</span></div></div>';
  {%- else -%}
    if(p.sv){
      return '<div class="qbw-price">'
        +'<div class="qbw-price-retail">Retail Rs '+Math.round(p.cmp/100)+'</div>'
        +'<div class="qbw-price-save">↓ Save '+p.svPct+'%</div>'
        +'<div class="qbw-price-hint">🔒 Register to unlock</div>'
        +'</div>';
    }
    return '<div class="qbw-price"><div class="qbw-price-locked">Wholesale Pricing</div></div>';
  {%- endif -%}
}

/* ─── CARD ─── */
function card(p){
  var b1 = p.sv ? '<div class="qbw-badge qbw-badge--save">−'+p.svPct+'%</div>' : '';
  var tagSet = p.tags + ' ';
  var b2 = '';
  if(tagSet.indexOf('best-seller')>-1||tagSet.indexOf('bestseller')>-1) b2 = '<span class="qbw-badge-corner qbw-badge-corner--best">⭐ Best</span>';
  else if(tagSet.indexOf('high-demand')>-1||tagSet.indexOf('demand')>-1) b2 = '<span class="qbw-badge-corner qbw-badge-corner--hot">🔥 Hot</span>';
  else if(tagSet.indexOf(',new,')>-1||tagSet.indexOf('new,')===0||tagSet.slice(-4)==='new,') b2 = '<span class="qbw-badge-corner qbw-badge-corner--new">✦ New</span>';
  var sold = p.avail ? '' : '<div class="qbw-sold-mask"><span class="qbw-sold-lbl">Out of Stock</span></div>';
  var imgEl = p.img
    ? '<img src="'+p.img+'" alt="'+esc(p.title)+'" loading="lazy" width="400" height="400">'
    : '<div class="qbw-card-empty">📦</div>';
  var typeLbl = p.type ? '<div class="qbw-card-type">'+esc(p.type)+'</div>' : '';
  return '<a href="'+p.url+'" class="qbw-card">'
    +'<div class="qbw-card-img">'+imgEl+'<div class="qbw-card-img-fade"></div>'+b1+b2+sold+'</div>'
    +'<div class="qbw-card-body">'+typeLbl+'<div class="qbw-card-name">'+esc(p.title)+'</div>'+priceHtml(p)+'</div>'
    +'</a>';
}

/* ─── SECTION BUILDER ─── */
function section(id, eyebrow, name, products){
  if(!products.length) return '';
  var cards = products.map(card).join('');
  return '<div class="qbw-sec" id="sec-'+id+'">'
    +'<div class="qbw-sec-head"><div>'
    +'<div class="qbw-sec-eyebrow">'+eyebrow+'</div>'
    +'<div class="qbw-sec-name">'+name+'</div>'
    +'<div class="qbw-sec-count">'+products.length+' products</div>'
    +'</div></div>'
    +'<div class="qbw-rule"><div class="qbw-rule-inner"></div></div>'
    +'<div class="qbw-slide-wrap"><div class="qbw-slide"><div class="qbw-slide-row">'+cards+'</div></div></div>'
    +'</div>';
}

/* ─── GROUP LABEL ─── */
function group(emo, name, sub){
  return '<div class="qbw-grp"><div class="qbw-grp-inner">'
    +'<span class="qbw-grp-emo">'+emo+'</span>'
    +'<div class="qbw-grp-txt"><div class="qbw-grp-name">'+name+'</div><div class="qbw-grp-sub">'+sub+'</div></div>'
    +'</div></div>';
}

/* ─── MID CTA BANNER ─── */
function ctaBanner(tag, title, sub){
  return '<div class="qbw-cta-strip" style="margin-top:28px">'
    +'<div><div class="qbw-cta-tag">'+tag+'</div><div class="qbw-cta-title">'+title+'</div><div class="qbw-cta-sub">'+sub+'</div></div>'
    +'<a href="/products/vendor-registration" class="qbw-btn-gold" style="font-size:12px;white-space:nowrap;flex-shrink:0">Register Now →</a>'
    +'</div>';
}

