}
.qb-faq-q:hover{color:var(--gold)}
.qb-faq-arrow{font-size:18px;color:var(--gold);transition:transform .25s;flex-shrink:0;margin-left:8px}
.qb-faq-item.open .qb-faq-arrow{transform:rotate(90deg)}
.qb-faq-a{
