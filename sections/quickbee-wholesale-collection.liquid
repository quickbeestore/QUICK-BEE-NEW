<style>
/* ══════════════════════════════════════════════
   QUICKBEE WHOLESALE — COMPLETE REDESIGN
   Target: Restaurants · Clubs · Cafés · Hotels
   ══════════════════════════════════════════════ */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.qbw {
  --black:   #080808;
  --bg:      #0d0d0f;
  --bg2:     #141416;
  --bg3:     #1a1a1d;
  --bg4:     #202024;
  --border:  rgba(255,255,255,0.06);
  --border2: rgba(255,255,255,0.1);
  --gold:    #d4a843;
  --gold2:   #f0c96a;
  --gold3:   #ffd97d;
  --green:   #22c55e;
  --red:     #ef4444;
  --text:    #f5f1eb;
  --sub:     #9c9894;
  --dim:     #5c5a58;
  --ease:    cubic-bezier(.4,0,.2,1);
  --r:       12px;
  --r-sm:    8px;

  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
  -webkit-font-smoothing: antialiased;
  min-height: 100vh;
}

/* ── ANNOUNCEMENT BAR ── */
.qbw-ann {
  background: var(--gold);
  color: #0d0a00;
  text-align: center;
  font-size: 11px; font-weight: 900; letter-spacing: 0.8px;
  text-transform: uppercase;
  padding: 9px 16px;
  position: relative;
}
.qbw-ann span { opacity: 0.7; margin: 0 8px; }

/* ── HERO ── */
.qbw-hero {
  position: relative;
  overflow: hidden;
  background: var(--black);
  padding: 52px 20px 48px;
}
.qbw-hero::before {
  content: '';
  position: absolute;
  top: -60px; right: -80px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(212,168,67,0.12) 0%, transparent 65%);
  pointer-events: none;
}
.qbw-hero::after {
  content: '';
  position: absolute;
  bottom: -40px; left: -60px;
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(212,168,67,0.05) 0%, transparent 65%);
  pointer-events: none;
}
.qbw-hero-inner {
  max-width: 1100px; margin: 0 auto;
  position: relative; z-index: 1;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px; align-items: center;
}
@media (max-width: 700px) {
  .qbw-hero-inner { grid-template-columns: 1fr; }
  .qbw-hero-right { display: none; }
}
.qbw-hero-pill {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(212,168,67,0.1);
  border: 1px solid rgba(212,168,67,0.25);
  border-radius: 100px;
  padding: 5px 14px 5px 8px;
  margin-bottom: 18px;
}
.qbw-hero-pill-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 6px var(--green);
  animation: qbwBlink 2s ease-in-out infinite;
}
@keyframes qbwBlink { 0%,100%{opacity:1} 50%{opacity:.3} }
.qbw-hero-pill-text {
  font-size: 10px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--gold2);
}
.qbw-hero-title {
  font-size: clamp(28px, 5vw, 52px);
  font-weight: 900; line-height: 1.05;
  letter-spacing: -1px;
  color: var(--text);
  margin-bottom: 16px;
}
.qbw-hero-title em {
  font-style: normal;
  background: linear-gradient(90deg, var(--gold) 0%, var(--gold3) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.qbw-hero-sub {
  font-size: 15px; color: var(--sub);
  line-height: 1.65;
  max-width: 480px;
  margin-bottom: 28px;
}
.qbw-hero-btns { display: flex; gap: 10px; flex-wrap: wrap; }
.qbw-btn-gold {
  display: inline-flex; align-items: center; gap: 7px;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 60%, var(--gold3) 100%);
  color: #0d0900; font-size: 13px; font-weight: 900; letter-spacing: 0.3px;
  padding: 13px 24px;
  border-radius: var(--r-sm);
  text-decoration: none; border: none; cursor: pointer;
  box-shadow: 0 2px 20px rgba(212,168,67,0.3), 0 1px 0 rgba(255,255,255,0.15) inset;
  transition: transform .18s var(--ease), box-shadow .18s var(--ease);
  white-space: nowrap;
}
.qbw-btn-gold:hover { transform: translateY(-2px); box-shadow: 0 6px 28px rgba(212,168,67,0.45); }
.qbw-btn-outline {
  display: inline-flex; align-items: center; gap: 7px;
  background: transparent;
  border: 1.5px solid rgba(212,168,67,0.3);
  color: var(--gold2); font-size: 13px; font-weight: 800;
  padding: 12px 22px;
  border-radius: var(--r-sm);
  text-decoration: none; cursor: pointer;
  transition: border-color .18s, background .18s;
  white-space: nowrap;
}
.qbw-btn-outline:hover { border-color: var(--gold); background: rgba(212,168,67,0.07); }
.qbw-hero-right {
  display: flex; flex-direction: column; gap: 10px;
}
.qbw-hero-stat {
  background: var(--bg2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  padding: 16px 22px;
  min-width: 140px;
  text-align: center;
}
.qbw-hero-stat-val {
  font-size: 28px; font-weight: 900;
  color: var(--gold2);
  line-height: 1;
  letter-spacing: -0.5px;
}
.qbw-hero-stat-label {
  font-size: 10px; font-weight: 700; letter-spacing: 1px;
  text-transform: uppercase; color: var(--dim);
  margin-top: 4px;
}
.qbw-hero-trust {
  display: flex; align-items: center; gap: 16px;
  margin-top: 24px; flex-wrap: wrap;
}
.qbw-hero-trust-item {
  display: flex; align-items: center; gap: 6px;
  font-size: 11px; color: var(--dim); font-weight: 600;
}
.qbw-hero-trust-item::before {
  content: '✓';
  color: var(--green); font-weight: 900; font-size: 10px;
}

/* ── SAVINGS MARQUEE ── */
.qbw-ticker {
  background: linear-gradient(90deg, var(--bg2) 0%, var(--bg3) 100%);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border2);
  overflow: hidden;
  padding: 10px 0;
  position: relative;
}
.qbw-ticker::before, .qbw-ticker::after {
  content: '';
  position: absolute; top: 0; bottom: 0;
  width: 60px; z-index: 2; pointer-events: none;
}
.qbw-ticker::before { left: 0; background: linear-gradient(90deg, var(--bg2), transparent); }
.qbw-ticker::after  { right: 0; background: linear-gradient(-90deg, var(--bg2), transparent); }
.qbw-ticker-track {
  display: flex; gap: 0;
  white-space: nowrap;
  animation: qbwTick 30s linear infinite;
}
@keyframes qbwTick { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.qbw-ticker-item {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 0 28px;
  font-size: 11px; font-weight: 800; letter-spacing: 0.5px;
  color: var(--sub);
  border-right: 1px solid var(--border);
  white-space: nowrap;
}
.qbw-ticker-item strong { color: var(--gold2); }
.qbw-ticker-item .dot { color: var(--gold); font-size: 14px; }

/* ── FILTER BAR ── */
.qbw-filters-wrap {
  position: sticky; top: 0; z-index: 200;
  background: rgba(13,13,15,0.96);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border2);
}
.qbw-filters-inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center;
  gap: 0;
  overflow-x: auto;
  scrollbar-width: none;
  padding: 0 16px;
}
.qbw-filters-inner::-webkit-scrollbar { display: none; }
.qbw-filter-btn {
  flex-shrink: 0;
  padding: 14px 18px;
  font-size: 12px; font-weight: 700; letter-spacing: 0.2px;
  color: var(--sub);
  background: none; border: none; cursor: pointer;
  border-bottom: 2.5px solid transparent;
  white-space: nowrap;
  transition: color .15s, border-color .15s;
}
.qbw-filter-btn:hover { color: var(--text); }
.qbw-filter-btn.active { color: var(--gold2); border-bottom-color: var(--gold); }
.qbw-filter-count {
  display: inline-flex; align-items: center; justify-content: center;
  background: rgba(212,168,67,0.15);
  color: var(--gold2);
  font-size: 9px; font-weight: 900;
  width: 18px; height: 18px; border-radius: 100px;
  margin-left: 5px;
  vertical-align: middle;
}

/* ── PRODUCTS AREA ── */
.qbw-main {
  max-width: 1200px; margin: 0 auto;
  padding: 28px 16px 0;
}
.qbw-bar {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20px; flex-wrap: wrap; gap: 10px;
}
.qbw-bar-left {
  font-size: 13px; color: var(--sub);
}
.qbw-bar-left strong { color: var(--text); font-weight: 800; }
.qbw-bar-savings {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 800;
  color: var(--green);
  background: rgba(34,197,94,0.08);
  border: 1px solid rgba(34,197,94,0.2);
  border-radius: 100px;
  padding: 4px 10px;
  margin-left: 10px;
}
.qbw-bar-savings::before { content: '↓'; font-size: 10px; }

/* ── PRODUCT GRID ── */
.qbw-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 14px;
}
@media (max-width: 600px) {
  .qbw-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
}
@media (max-width: 360px) {
  .qbw-grid { grid-template-columns: 1fr; }
}

/* ── PRODUCT CARD ── */
.qbw-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
  display: flex; flex-direction: column;
  text-decoration: none; color: inherit;
  transition: border-color .22s var(--ease), box-shadow .22s var(--ease), transform .22s var(--ease);
  position: relative;
}
.qbw-card:hover {
  border-color: rgba(212,168,67,0.35);
  box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(212,168,67,0.12);
  transform: translateY(-3px);
}
.qbw-card-img-wrap {
  position: relative;
  background: var(--bg3);
  aspect-ratio: 1 / 1;
  overflow: hidden;
}
.qbw-card-img-wrap img {
  width: 100%; height: 100%;
  object-fit: contain;
  object-position: center;
  padding: 16px;
  display: block;
  transition: transform .35s var(--ease);
}
.qbw-card:hover .qbw-card-img-wrap img { transform: scale(1.06); }
.qbw-card-no-img {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 40px; opacity: 0.15;
}

/* SAVE BADGE — top left, biggest visual draw */
.qbw-save-badge {
  position: absolute;
  top: 10px; left: 10px;
  background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
  color: #fff;
  font-size: 11px; font-weight: 900; letter-spacing: 0.3px;
  padding: 5px 10px;
  border-radius: 7px;
  box-shadow: 0 2px 10px rgba(22,163,74,0.4);
  line-height: 1.2;
  text-align: center;
}
.qbw-save-badge small {
  display: block;
  font-size: 8px; font-weight: 700; letter-spacing: 0.5px;
  opacity: 0.85; margin-top: 1px;
}

/* product type chip — top right */
.qbw-card-type-chip {
  position: absolute; top: 10px; right: 10px;
  background: rgba(13,13,15,0.85);
  border: 1px solid var(--border2);
  backdrop-filter: blur(4px);
  color: var(--sub);
  font-size: 8px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 5px;
}

/* demand badge — bottom left of image */
.qbw-demand {
  position: absolute; bottom: 10px; left: 10px;
  background: rgba(212,168,67,0.15);
  border: 1px solid rgba(212,168,67,0.3);
  color: var(--gold2);
  font-size: 8px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase;
  padding: 3px 9px; border-radius: 5px;
}

/* sold out */
.qbw-sold-overlay {
  position: absolute; inset: 0;
  background: rgba(8,8,8,0.7);
  display: flex; align-items: center; justify-content: center;
}
.qbw-sold-tag {
  font-size: 10px; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--sub);
  border: 1.5px solid var(--border2);
  background: var(--bg);
  padding: 6px 16px; border-radius: 6px;
}

/* ── CARD BODY ── */
.qbw-card-body {
  padding: 14px 14px 16px;
  flex: 1; display: flex; flex-direction: column; gap: 0;
}
.qbw-card-type-label {
  font-size: 9px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--dim);
  margin-bottom: 5px;
}
.qbw-card-name {
  font-size: 13px; font-weight: 700; line-height: 1.35;
  color: var(--text);
  margin-bottom: 12px;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}

/* PRICE BLOCK */
.qbw-price-block {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  padding: 10px 12px;
  margin-bottom: 12px;
}
.qbw-price-row {
  display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;
}
.qbw-price-current {
  font-size: 18px; font-weight: 900;
  color: var(--gold2);
  letter-spacing: -0.3px;
  line-height: 1;
}
.qbw-price-compare {
  font-size: 12px; color: var(--dim);
  text-decoration: line-through;
}
.qbw-price-locked {
  font-size: 11px; font-weight: 700;
  color: var(--sub);
  display: flex; align-items: center; gap: 5px;
}
.qbw-price-locked::before { content: '🔒'; font-size: 10px; }
.qbw-price-save-line {
  margin-top: 5px;
  font-size: 11px; font-weight: 800;
  color: var(--green);
  display: flex; align-items: center; gap: 4px;
}
.qbw-price-save-line::before { content: '↓'; font-weight: 900; }
.qbw-price-per {
  margin-top: 3px;
  font-size: 9px; color: var(--dim); font-weight: 600;
}

/* CTA BUTTONS */
.qbw-card-actions {
  display: flex; gap: 7px;
  margin-top: auto;
}
.qbw-card-btn-primary {
  flex: 1;
  padding: 10px 8px;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
  color: #0d0900;
  font-size: 11px; font-weight: 900; letter-spacing: 0.3px;
  border-radius: var(--r-sm);
  border: none; cursor: pointer;
  text-align: center; text-decoration: none;
  display: flex; align-items: center; justify-content: center;
  transition: box-shadow .15s, transform .15s;
  box-shadow: 0 2px 10px rgba(212,168,67,0.2);
}
.qbw-card-btn-primary:hover { box-shadow: 0 4px 16px rgba(212,168,67,0.35); transform: translateY(-1px); }
.qbw-card-btn-ghost {
  padding: 10px 10px;
  background: transparent;
  border: 1.5px solid var(--border2);
  color: var(--sub);
  font-size: 10px; font-weight: 800;
  border-radius: var(--r-sm);
  cursor: pointer;
  text-align: center; text-decoration: none;
  display: flex; align-items: center; justify-content: center;
  transition: border-color .15s, color .15s;
  white-space: nowrap;
}
.qbw-card-btn-ghost:hover { border-color: var(--gold); color: var(--gold2); }

/* ── INLINE B2B STRIP ── */
.qbw-b2b-strip {
  margin: 32px 0 0;
  background: linear-gradient(90deg, rgba(212,168,67,0.07) 0%, rgba(212,168,67,0.03) 100%);
  border: 1px solid rgba(212,168,67,0.15);
  border-radius: var(--r);
  padding: 18px 24px;
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
  flex-wrap: wrap;
}
.qbw-b2b-strip-text {
  font-size: 13px; color: var(--sub); line-height: 1.5;
  display: flex; align-items: center; gap: 10px;
}
.qbw-b2b-strip-icon {
  font-size: 20px; flex-shrink: 0;
}

/* ── PAGINATION ── */
.qbw-pagination {
  display: flex; justify-content: center; gap: 6px; flex-wrap: wrap;
  padding: 32px 16px 0;
  max-width: 1200px; margin: 0 auto;
}
.qbw-page-btn {
  min-width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--r-sm);
  font-size: 13px; font-weight: 700;
  text-decoration: none;
  border: 1px solid var(--border);
  color: var(--sub);
  background: var(--bg2);
  transition: all .15s;
}
.qbw-page-btn:hover, .qbw-page-btn--active {
  background: var(--gold); color: #0d0900; border-color: var(--gold);
}
.qbw-page-btn--disabled { opacity: 0.3; pointer-events: none; }

/* ── SOCIAL PROOF ── */
.qbw-proof {
  background: var(--black);
  border-top: 1px solid var(--border);
  padding: 40px 20px;
}
.qbw-proof-inner {
  max-width: 1100px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
}
.qbw-proof-item {
  background: var(--bg2);
  padding: 24px 20px;
  text-align: center;
}
.qbw-proof-num {
  font-size: 32px; font-weight: 900;
  color: var(--gold2); letter-spacing: -1px; line-height: 1;
}
.qbw-proof-label {
  font-size: 11px; color: var(--sub); margin-top: 5px; line-height: 1.4;
}

/* ── WHY QUICKBEE ── */
.qbw-why {
  padding: 64px 20px;
  background: var(--bg);
}
.qbw-why-inner { max-width: 1100px; margin: 0 auto; }
.qbw-section-tag {
  font-size: 10px; font-weight: 900; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--gold);
  display: flex; align-items: center; gap: 8px;
  margin-bottom: 8px;
}
.qbw-section-tag::before, .qbw-section-tag::after {
  content: ''; flex: 1; height: 1px; background: var(--border);
  max-width: 40px;
}
.qbw-section-title {
  font-size: clamp(22px, 4vw, 34px); font-weight: 900;
  letter-spacing: -0.5px; color: var(--text);
  margin-bottom: 36px; text-align: center;
}
.qbw-why-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
}
.qbw-why-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 24px 20px 22px;
  transition: border-color .2s;
}
.qbw-why-card:hover { border-color: rgba(212,168,67,0.25); }
.qbw-why-icon {
  width: 44px; height: 44px;
  background: rgba(212,168,67,0.1);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
  margin-bottom: 14px;
}
.qbw-why-title {
  font-size: 14px; font-weight: 800; color: var(--text);
  margin-bottom: 6px;
}
.qbw-why-desc {
  font-size: 12px; color: var(--sub); line-height: 1.6;
}

/* ── WHO WE SERVE ── */
.qbw-serve {
  background: var(--bg2);
  border-top: 1px solid var(--border);
  padding: 52px 20px;
}
.qbw-serve-inner { max-width: 1100px; margin: 0 auto; }
.qbw-serve-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 10px;
  margin-top: 0;
}
.qbw-serve-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 22px 16px;
  text-align: center;
  transition: border-color .2s, background .2s;
  cursor: default;
}
.qbw-serve-card:hover {
  border-color: rgba(212,168,67,0.3);
  background: var(--bg3);
}
.qbw-serve-emoji { font-size: 28px; margin-bottom: 10px; display: block; }
.qbw-serve-name {
  font-size: 12px; font-weight: 800; color: var(--text);
  margin-bottom: 4px;
}
.qbw-serve-sub { font-size: 10px; color: var(--dim); }

/* ── CLOSING CONVERSION ── */
.qbw-closing {
  background: var(--black);
  padding: 80px 20px;
  text-align: center;
  position: relative; overflow: hidden;
}
.qbw-closing::before {
  content: '';
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 600px; height: 400px;
  background: radial-gradient(ellipse, rgba(212,168,67,0.1) 0%, transparent 65%);
  pointer-events: none;
}
.qbw-closing-inner { max-width: 640px; margin: 0 auto; position: relative; }
.qbw-closing-eyebrow {
  font-size: 9px; font-weight: 900; letter-spacing: 3px; text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
}
.qbw-closing-title {
  font-size: clamp(28px, 5vw, 48px);
  font-weight: 900; line-height: 1.05;
  letter-spacing: -1px; color: var(--text);
  margin-bottom: 16px;
}
.qbw-closing-title em {
  font-style: normal;
  background: linear-gradient(90deg, var(--gold) 0%, var(--gold3) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.qbw-closing-primary {
  font-size: 15px; color: var(--sub); line-height: 1.65;
  margin-bottom: 10px;
}
.qbw-closing-secondary {
  font-size: 12px; color: var(--dim); line-height: 1.6;
  margin-bottom: 36px;
}
.qbw-closing-btns {
  display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
  margin-bottom: 20px;
}
.qbw-closing-footnote {
  font-size: 10px; color: var(--dim); letter-spacing: 0.5px;
}
.qbw-closing-footnote::before { content: '🔒 '; }

/* ── FOOTER ── */
.qbw-footer {
  background: var(--black);
  border-top: 1px solid var(--border);
  padding: 22px 20px;
}
.qbw-footer-inner {
  max-width: 1100px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 12px;
}
.qbw-footer-brand {
  font-size: 16px; font-weight: 900; letter-spacing: -0.3px;
  color: var(--gold);
}
.qbw-footer-brand span { color: var(--sub); font-weight: 400; font-size: 12px; margin-left: 6px; }
.qbw-footer-note {
  font-size: 10px; color: var(--dim); letter-spacing: 0.5px;
  display: flex; align-items: center; gap: 5px;
}
.qbw-footer-qr {
  width: 48px; height: 48px;
  background: var(--bg2);
  border: 1px solid var(--border2);
  border-radius: 8px;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  font-size: 7px; color: var(--dim); text-align: center; gap: 2px; line-height: 1.2;
}

/* ── EMPTY ── */
.qbw-empty {
  text-align: center; padding: 80px 20px;
}
.qbw-empty-icon { font-size: 52px; margin-bottom: 14px; opacity: 0.3; }
.qbw-empty-title { font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
.qbw-empty-sub { font-size: 13px; color: var(--sub); }

@media (max-width: 500px) {
  .qbw-why-grid { grid-template-columns: 1fr 1fr; }
  .qbw-serve-grid { grid-template-columns: 1fr 1fr; }
  .qbw-proof-inner { grid-template-columns: 1fr 1fr; }
  .qbw-b2b-strip { flex-direction: column; align-items: flex-start; }
}
</style>

