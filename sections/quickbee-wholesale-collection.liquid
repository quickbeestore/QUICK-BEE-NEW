{%- paginate collection.products by 250 -%}
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blk:#060608;--bg:#0d0d0f;--bg2:#111113;--bg3:#161618;--bg4:#1c1c1f;
  --bd:rgba(255,255,255,.055);--bd2:rgba(255,255,255,.10);--bd3:rgba(255,255,255,.16);
  --gold:#d4a843;--gold2:#f0c55a;--gold3:#ffd97d;
  --grn:#22c55e;--red:#ef4444;--blue:#3b82f6;
  --txt:#f2ede6;--sub:#9c9892;--dim:#5a5754;
  --ease:cubic-bezier(.4,0,.2,1);--r:14px;
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Inter',sans-serif;
  -webkit-font-smoothing:antialiased;
}
.qbw{background:var(--bg);color:var(--txt)}

/* ── TICKER ── */
.qbw-tick{background:var(--gold);color:#07050a;font-size:10.5px;font-weight:900;letter-spacing:.7px;text-transform:uppercase;padding:8px 0;overflow:hidden;white-space:nowrap}
.qbw-tick-inner{display:inline-flex;animation:tick 38s linear infinite}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.qbw-tick-item{padding:0 26px;border-right:1px solid rgba(0,0,0,.18);flex-shrink:0}

/* ── HERO ── */
.qbw-hero{position:relative;overflow:hidden;background:var(--blk);padding:44px 20px 40px;min-height:340px;display:flex;align-items:center}
.qbw-hero-glow{position:absolute;top:-60px;right:-80px;width:480px;height:480px;background:radial-gradient(circle,rgba(212,168,67,.12) 0%,transparent 60%);pointer-events:none}
.qbw-hero-glow2{position:absolute;bottom:-30px;left:-60px;width:300px;height:300px;background:radial-gradient(circle,rgba(212,168,67,.05) 0%,transparent 60%);pointer-events:none}
.qbw-hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(212,168,67,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(212,168,67,.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;mask-image:radial-gradient(ellipse 90% 90% at 50% 50%,black 10%,transparent 100%);-webkit-mask-image:radial-gradient(ellipse 90% 90% at 50% 50%,black 10%,transparent 100%)}
.qbw-hero-wrap{max-width:1120px;margin:0 auto;width:100%;position:relative;z-index:1}
.qbw-hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(212,168,67,.09);border:1px solid rgba(212,168,67,.2);border-radius:100px;padding:4px 13px 4px 7px;margin-bottom:14px}
.qbw-hero-dot{width:7px;height:7px;border-radius:50%;background:var(--grn);box-shadow:0 0 8px var(--grn);animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.25}}
.qbw-hero-badge-txt{font-size:9.5px;font-weight:900;letter-spacing:1.4px;text-transform:uppercase;color:var(--gold2)}
.qbw-hero-h1{font-size:clamp(24px,6vw,50px);font-weight:900;line-height:1.06;letter-spacing:-1.4px;color:var(--txt);margin-bottom:12px}
.qbw-hero-h1 em{font-style:normal;background:linear-gradient(95deg,var(--gold) 0%,var(--gold3) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.qbw-hero-desc{font-size:13.5px;color:var(--sub);line-height:1.68;margin-bottom:22px;max-width:440px}
.qbw-hero-cta{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px}
.qbw-btn-gold{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,var(--gold) 0%,var(--gold2) 55%,var(--gold3) 100%);color:#08060a;font-size:13px;font-weight:900;letter-spacing:.2px;padding:12px 22px;border-radius:10px;text-decoration:none;border:none;cursor:pointer;box-shadow:0 4px 20px rgba(212,168,67,.28);transition:transform .16s,box-shadow .16s;white-space:nowrap}
.qbw-btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(212,168,67,.4)}
.qbw-btn-outline{display:inline-flex;align-items:center;gap:6px;background:transparent;border:1.5px solid rgba(212,168,67,.26);color:var(--gold2);font-size:13px;font-weight:800;padding:11px 20px;border-radius:10px;text-decoration:none;cursor:pointer;transition:border-color .14s,background .14s;white-space:nowrap}
.qbw-btn-outline:hover{border-color:var(--gold);background:rgba(212,168,67,.06)}
.qbw-hero-checks{display:flex;gap:14px;flex-wrap:wrap}
.qbw-hero-check{font-size:11px;font-weight:700;color:var(--dim);display:flex;align-items:center;gap:5px}
.qbw-hero-check::before{content:'✓';color:var(--grn);font-size:10px;font-weight:900}

/* ── STATS BAR ── */
.qbw-stats{background:var(--blk);border-top:1px solid var(--bd);border-bottom:1px solid var(--bd);padding:0}
.qbw-stats-inner{max-width:1120px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr)}
@media(max-width:600px){.qbw-stats-inner{grid-template-columns:1fr 1fr}}
.qbw-stat{padding:20px 16px;text-align:center;border-right:1px solid var(--bd);position:relative}
.qbw-stat:last-child{border-right:none}
.qbw-stat::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(212,168,67,.4),transparent)}
.qbw-stat-icon{font-size:18px;margin-bottom:6px}
.qbw-stat-val{font-size:22px;font-weight:900;color:var(--gold2);letter-spacing:-.4px;line-height:1}
.qbw-stat-lbl{font-size:9.5px;color:var(--sub);margin-top:3px;line-height:1.4}

/* ── CAT JUMP NAV ── */
.qbw-catjump{padding:28px 16px 24px;max-width:1120px;margin:0 auto}
.qbw-catjump-title{font-size:10px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(--dim);margin-bottom:14px;text-align:center}
.qbw-catjump-groups{display:flex;flex-direction:column;gap:16px}
.qbw-catjump-group{}
.qbw-catjump-group-lbl{font-size:9px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:var(--gold);opacity:.65;margin-bottom:8px;padding-left:2px}
.qbw-catjump-pills{display:flex;flex-wrap:wrap;gap:7px}
.qbw-catjump-pill{display:inline-flex;align-items:center;gap:5px;padding:7px 12px;background:var(--bg2);border:1px solid var(--bd);border-radius:100px;font-size:11px;font-weight:700;color:var(--sub);cursor:pointer;transition:border-color .14s,color .14s,background .14s;text-decoration:none;-webkit-tap-highlight-color:transparent}
.qbw-catjump-pill:hover,.qbw-catjump-pill:active{border-color:rgba(212,168,67,.4);color:var(--gold2);background:rgba(212,168,67,.06)}
.qbw-catjump-pill-count{font-size:9px;color:var(--dim);font-weight:600}

/* ── STICKY NAV ── */
.qbw-sticky{position:sticky;top:0;z-index:200;background:rgba(9,9,11,.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--bd2)}
.qbw-sticky-track{max-width:1120px;margin:0 auto;display:flex;overflow-x:auto;scrollbar-width:none;padding:0 14px}
.qbw-sticky-track::-webkit-scrollbar{display:none}
.qbw-sticky-btn{flex-shrink:0;padding:11px 13px;font-size:11px;font-weight:700;color:var(--dim);background:none;border:none;cursor:pointer;border-bottom:2.5px solid transparent;white-space:nowrap;transition:color .14s,border-color .14s;-webkit-tap-highlight-color:transparent}
.qbw-sticky-btn:hover{color:var(--txt)}
.qbw-sticky-btn.qbw-active{color:var(--gold2);border-bottom-color:var(--gold)}

/* ── GROUP HEADER ── */
.qbw-grp{padding:36px 16px 0;max-width:1120px;margin:0 auto}
.qbw-grp-inner{display:flex;align-items:center;gap:12px;padding:14px 18px;background:linear-gradient(135deg,rgba(212,168,67,.07) 0%,rgba(212,168,67,.025) 100%);border:1px solid rgba(212,168,67,.15);border-left:3px solid var(--gold);border-radius:12px}
.qbw-grp-emo{font-size:22px}
.qbw-grp-name{font-size:15px;font-weight:900;color:var(--gold2);letter-spacing:-.2px}
.qbw-grp-sub{font-size:11px;color:var(--sub);margin-top:2px}

/* ── SECTION ── */
.qbw-sec{padding:20px 0 0}
.qbw-sec-head{max-width:1120px;margin:0 auto;padding:0 16px 10px;display:flex;align-items:flex-end;justify-content:space-between}
.qbw-sec-left{}
.qbw-sec-eyebrow{font-size:8.5px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);opacity:.7;margin-bottom:3px}
.qbw-sec-name{font-size:clamp(16px,3vw,22px);font-weight:900;letter-spacing:-.3px;color:var(--txt);line-height:1.1}
.qbw-sec-count{font-size:10px;color:var(--dim);margin-top:3px}
.qbw-sec-divider{height:1px;background:linear-gradient(90deg,rgba(212,168,67,.18),transparent);max-width:1120px;margin:0 auto;padding:0 16px}
.qbw-divider-line{height:1px;background:linear-gradient(90deg,rgba(212,168,67,.22),transparent)}

/* ── SLIDER ── */
.qbw-slider{position:relative}
.qbw-slider-scroll{overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;padding:8px 16px 22px;scroll-snap-type:x mandatory}
.qbw-slider-scroll::-webkit-scrollbar{display:none}
.qbw-slider-row{display:flex;gap:10px;width:max-content}

/* ── PRODUCT CARD ── */
.qbw-card{flex:0 0 calc(45vw - 18px);max-width:192px;min-width:134px;background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r);overflow:hidden;display:flex;flex-direction:column;text-decoration:none;color:inherit;scroll-snap-align:start;transition:border-color .2s,box-shadow .2s,transform .18s;position:relative;-webkit-tap-highlight-color:transparent}
@media(min-width:480px){.qbw-card{flex:0 0 170px;max-width:170px}}
@media(min-width:640px){.qbw-card{flex:0 0 186px;max-width:186px}}
@media(min-width:900px){.qbw-card{flex:0 0 200px;max-width:200px}}
.qbw-card:active{transform:scale(.97)}
.qbw-card:hover{border-color:rgba(212,168,67,.45);box-shadow:0 10px 32px rgba(0,0,0,.55),0 0 0 1px rgba(212,168,67,.1)}

/* big card (featured) */
.qbw-card--xl{flex:0 0 calc(58vw - 18px);max-width:250px;min-width:190px}
@media(min-width:480px){.qbw-card--xl{flex:0 0 220px;max-width:220px}}
@media(min-width:900px){.qbw-card--xl{flex:0 0 240px;max-width:240px}}

.qbw-card-img{position:relative;aspect-ratio:1/1;background:linear-gradient(160deg,var(--bg3) 0%,#0c0c0e 100%);overflow:hidden}
.qbw-card-img img{width:100%;height:100%;object-fit:contain;object-position:center;padding:10px;display:block;transition:transform .36s var(--ease)}
.qbw-card:hover .qbw-card-img img{transform:scale(1.06)}
.qbw-card-img-fade{position:absolute;bottom:0;left:0;right:0;height:32px;background:linear-gradient(to top,var(--bg2),transparent);pointer-events:none}
.qbw-card-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;opacity:.08}
/* badges */
.qbw-b-save{position:absolute;top:7px;left:7px;background:linear-gradient(135deg,#166534,#22c55e);color:#fff;font-size:8px;font-weight:900;padding:2px 7px;border-radius:20px;white-space:nowrap;box-shadow:0 2px 8px rgba(22,163,74,.4)}
.qbw-b-hot{position:absolute;bottom:7px;left:7px;background:rgba(212,168,67,.9);color:#0a0700;font-size:7px;font-weight:900;letter-spacing:.5px;text-transform:uppercase;padding:2px 6px;border-radius:4px}
.qbw-b-new{position:absolute;bottom:7px;left:7px;background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.3);color:#4ade80;font-size:7px;font-weight:900;letter-spacing:.5px;text-transform:uppercase;padding:2px 6px;border-radius:4px;backdrop-filter:blur(4px)}
.qbw-b-demand{position:absolute;bottom:7px;left:7px;background:rgba(239,68,68,.14);border:1px solid rgba(239,68,68,.28);color:#f87171;font-size:7px;font-weight:900;letter-spacing:.5px;text-transform:uppercase;padding:2px 6px;border-radius:4px;backdrop-filter:blur(4px)}
.qbw-sold-mask{position:absolute;inset:0;background:rgba(6,6,8,.72);display:flex;align-items:center;justify-content:center}
.qbw-sold-lbl{font-size:9px;font-weight:900;letter-spacing:1.4px;text-transform:uppercase;color:var(--sub);border:1px solid var(--bd2);background:var(--bg);padding:4px 11px;border-radius:4px}
/* card body */
.qbw-card-body{padding:9px 10px 11px;flex:1;display:flex;flex-direction:column}
.qbw-card-type{font-size:7px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:var(--gold);opacity:.55;margin-bottom:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.qbw-card-title{font-size:11.5px;font-weight:700;line-height:1.35;color:var(--txt);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;flex:1;margin-bottom:8px}
.qbw-card--xl .qbw-card-title{font-size:12.5px}
/* price */
.qbw-card-price{margin-top:auto}
.qbw-price-row{display:flex;align-items:baseline;gap:5px;flex-wrap:wrap;margin-bottom:2px}
.qbw-price-now{font-size:15px;font-weight:900;color:var(--gold2);letter-spacing:-.4px;line-height:1}
.qbw-card--xl .qbw-price-now{font-size:17px}
.qbw-price-was{font-size:9px;color:var(--dim);text-decoration:line-through}
.qbw-price-save{font-size:8.5px;font-weight:800;color:var(--grn)}
.qbw-price-locked{font-size:9px;font-weight:700;color:var(--sub);display:flex;align-items:center;gap:4px;padding:5px 8px;background:rgba(255,255,255,.025);border:1px solid var(--bd);border-radius:6px}
.qbw-price-locked::before{content:'🔒';font-size:9px}
.qbw-price-retail{font-size:8px;color:var(--dim);margin-bottom:1px}
.qbw-price-hint{font-size:7.5px;color:var(--dim);margin-top:1px}

/* ── INLINE PROMO CARD ── */
.qbw-promo-card{flex:0 0 calc(62vw - 18px);max-width:230px;min-width:170px;border-radius:var(--r);padding:20px 16px;position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;scroll-snap-align:start;text-decoration:none}
.qbw-promo-card--reg{background:linear-gradient(135deg,#0c0700 0%,#1c1200 60%,#0c0700 100%);border:1px solid rgba(212,168,67,.14)}
.qbw-promo-card--cool{background:linear-gradient(135deg,#060a12 0%,#0d1626 60%,#060a12 100%);border:1px solid rgba(59,130,246,.12)}
.qbw-promo-card-bg{position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:48px;opacity:.12;pointer-events:none}
.qbw-promo-card-tag{font-size:8px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:var(--gold);margin-bottom:5px;position:relative}
.qbw-promo-card-title{font-size:15px;font-weight:900;color:var(--txt);letter-spacing:-.3px;position:relative;line-height:1.2;margin-bottom:3px}
.qbw-promo-card-sub{font-size:9.5px;color:var(--sub);position:relative;line-height:1.5}

/* ── B2B BANNER ── */
.qbw-b2b{max-width:1120px;margin:28px auto 0;padding:0 16px}
.qbw-b2b-inner{background:linear-gradient(135deg,rgba(212,168,67,.075) 0%,rgba(212,168,67,.02) 100%);border:1px solid rgba(212,168,67,.15);border-radius:16px;padding:26px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;position:relative;overflow:hidden}
.qbw-b2b-inner::before{content:'🔒';position:absolute;right:22px;top:50%;transform:translateY(-50%);font-size:72px;opacity:.04;pointer-events:none}
.qbw-b2b-tag{font-size:8.5px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:4px}
.qbw-b2b-title{font-size:17px;font-weight:900;color:var(--txt);margin-bottom:4px;letter-spacing:-.25px}
.qbw-b2b-sub{font-size:12px;color:var(--sub);line-height:1.5}
@media(max-width:600px){.qbw-b2b-inner{padding:18px 16px;flex-direction:column;align-items:flex-start}}

/* ── BRANDS ── */
.qbw-brands{padding:30px 16px;background:var(--blk);border-top:1px solid var(--bd)}
.qbw-brands-inner{max-width:1120px;margin:0 auto}
.qbw-brands-lbl{font-size:9px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--dim);text-align:center;margin-bottom:14px}
.qbw-brands-row{display:flex;gap:7px;flex-wrap:wrap;justify-content:center}
.qbw-brand{background:var(--bg2);border:1px solid var(--bd);border-radius:100px;padding:5px 13px;font-size:11px;font-weight:800;color:var(--dim);transition:border-color .14s,color .14s}
.qbw-brand:hover{border-color:rgba(212,168,67,.3);color:var(--gold2)}

/* ── WHO WE SERVE ── */
.qbw-serve{padding:40px 16px;background:var(--bg2);border-top:1px solid var(--bd)}
.qbw-serve-inner{max-width:1120px;margin:0 auto}
.qbw-section-eyebrow{font-size:9px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);text-align:center;margin-bottom:5px}
.qbw-section-title{font-size:clamp(18px,3.5vw,28px);font-weight:900;letter-spacing:-.4px;color:var(--txt);text-align:center;margin-bottom:22px}
.qbw-serve-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px}
@media(max-width:480px){.qbw-serve-grid{grid-template-columns:repeat(2,1fr)}}
.qbw-serve-card{background:var(--bg);border:1px solid var(--bd);border-radius:12px;padding:16px 12px;text-align:center;transition:border-color .16s,background .16s}
.qbw-serve-card:hover{border-color:rgba(212,168,67,.25);background:var(--bg3)}
.qbw-serve-emo{font-size:24px;display:block;margin-bottom:7px}
.qbw-serve-name{font-size:12px;font-weight:800;color:var(--txt);margin-bottom:2px}
.qbw-serve-sub{font-size:9.5px;color:var(--dim)}

/* ── WHY ── */
.qbw-why{padding:40px 16px;background:var(--bg)}
.qbw-why-inner{max-width:1120px;margin:0 auto}
.qbw-why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px}
@media(max-width:600px){.qbw-why-grid{grid-template-columns:1fr}}
.qbw-why-card{background:var(--bg2);border:1px solid var(--bd);border-radius:12px;padding:18px 16px}
.qbw-why-icon{width:38px;height:38px;background:rgba(212,168,67,.08);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;margin-bottom:10px}
.qbw-why-name{font-size:13px;font-weight:800;color:var(--txt);margin-bottom:4px}
.qbw-why-desc{font-size:11px;color:var(--sub);line-height:1.6}

/* ── HOW TO ORDER ── */
.qbw-hto{padding:40px 16px;background:var(--blk);border-top:1px solid var(--bd)}
.qbw-hto-inner{max-width:840px;margin:0 auto}
.qbw-hto-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:26px}
@media(max-width:580px){.qbw-hto-steps{grid-template-columns:1fr;gap:0}}
.qbw-hto-step{text-align:center;padding:22px 16px;position:relative}
.qbw-hto-step:not(:last-child)::after{content:'→';position:absolute;right:-10px;top:42px;font-size:18px;color:var(--gold);opacity:.4}
@media(max-width:580px){.qbw-hto-step:not(:last-child)::after{content:'↓';right:auto;left:50%;top:auto;bottom:-4px;transform:translateX(-50%)}}
.qbw-hto-num{width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#08060a;font-size:17px;font-weight:900;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;box-shadow:0 4px 18px rgba(212,168,67,.3)}
.qbw-hto-lbl{font-size:13.5px;font-weight:900;color:var(--txt);margin-bottom:4px;letter-spacing:-.15px}
.qbw-hto-desc{font-size:10.5px;color:var(--sub);line-height:1.6;max-width:170px;margin:0 auto}

/* ── FAQ ── */
.qbw-faq{padding:40px 16px;background:var(--bg2);border-top:1px solid var(--bd)}
.qbw-faq-inner{max-width:720px;margin:0 auto}
.qbw-faq-list{margin-top:22px;display:flex;flex-direction:column;gap:7px}
.qbw-faq-item{background:var(--bg);border:1px solid var(--bd);border-radius:12px;overflow:hidden;transition:border-color .18s}
.qbw-faq-item.open{border-color:rgba(212,168,67,.3)}
.qbw-faq-q{display:flex;align-items:center;justify-content:space-between;padding:13px 16px;cursor:pointer;gap:10px;-webkit-tap-highlight-color:transparent;user-select:none}
.qbw-faq-q-txt{font-size:13px;font-weight:700;color:var(--txt);line-height:1.4;flex:1}
.qbw-faq-icon{width:22px;height:22px;border-radius:50%;background:var(--bg3);border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .22s,background .18s;font-size:13px;color:var(--sub)}
.qbw-faq-item.open .qbw-faq-icon{transform:rotate(45deg);background:rgba(212,168,67,.09);color:var(--gold2)}
.qbw-faq-body{max-height:0;overflow:hidden;transition:max-height .3s var(--ease)}
.qbw-faq-body-inner{padding:0 16px 13px;font-size:12px;color:var(--sub);line-height:1.7}
.qbw-faq-item.open .qbw-faq-body{max-height:180px}

/* ── CLOSING ── */
.qbw-close{padding:60px 16px;background:var(--blk);text-align:center;position:relative;overflow:hidden}
.qbw-close::before{content:'';position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:560px;height:380px;background:radial-gradient(ellipse,rgba(212,168,67,.08) 0%,transparent 65%);pointer-events:none}
.qbw-close-inner{max-width:540px;margin:0 auto;position:relative}
.qbw-close-tag{font-size:9px;font-weight:900;letter-spacing:2.8px;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
.qbw-close-h2{font-size:clamp(24px,5.5vw,42px);font-weight:900;letter-spacing:-.9px;color:var(--txt);line-height:1.07;margin-bottom:12px}
.qbw-close-h2 em{font-style:normal;background:linear-gradient(90deg,var(--gold),var(--gold3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.qbw-close-p{font-size:13.5px;color:var(--sub);line-height:1.65;margin-bottom:7px}
.qbw-close-note-text{font-size:11px;color:var(--dim);line-height:1.6;margin-bottom:28px}
.qbw-close-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:14px}
.qbw-close-legal{font-size:9px;color:var(--dim);letter-spacing:.4px}
.qbw-close-legal::before{content:'🔒 '}

/* ── FOOTER ── */
.qbw-foot{background:var(--blk);border-top:1px solid var(--bd);padding:18px 16px}
.qbw-foot-inner{max-width:1120px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.qbw-foot-brand{font-size:14px;font-weight:900;color:var(--gold)}
.qbw-foot-brand span{color:var(--sub);font-weight:400;font-size:10.5px;margin-left:5px}
.qbw-foot-note{font-size:9px;color:var(--dim);margin-top:3px}

/* ── EMPTY ── */
.qbw-sec-empty{padding:14px 16px 20px;font-size:11.5px;color:var(--dim);font-style:italic}

/* ── DELIVERY STRIP ── */
