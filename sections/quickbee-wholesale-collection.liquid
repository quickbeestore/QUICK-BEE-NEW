{%- paginate collection.products by 250 -%}
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
.qbw{
  --blk:#060608;--bg:#0d0d0f;--bg2:#121215;--bg3:#191920;--bg4:#1e1e28;
  --bd:rgba(255,255,255,0.06);--bd2:rgba(255,255,255,0.11);
  --gold:#d4a843;--gold2:#f0c55a;--gold3:#ffd97d;
  --grn:#22c55e;--red:#ef4444;
  --txt:#f2ede6;--sub:#9c9892;--dim:#5a5855;
  --ease:cubic-bezier(.4,0,.2,1);--r:12px;
  background:var(--bg);color:var(--txt);
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Inter',sans-serif;
  -webkit-font-smoothing:antialiased;
}

/* ── TICKER ── */
.qbw-ann{background:var(--gold);color:#08060a;font-size:11px;font-weight:900;letter-spacing:.8px;text-transform:uppercase;padding:9px 0;overflow:hidden;white-space:nowrap}
.qbw-ann-inner{display:inline-flex;animation:qbwTick 30s linear infinite}
@keyframes qbwTick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.qbw-ann-item{padding:0 28px;border-right:1px solid rgba(0,0,0,.15);flex-shrink:0}

/* ── HERO ── */
.qbw-hero{position:relative;overflow:hidden;background:var(--blk);padding:56px 24px 52px;min-height:440px;display:flex;align-items:center}
.qbw-hero-g1{position:absolute;top:-100px;right:-80px;width:560px;height:560px;background:radial-gradient(circle,rgba(212,168,67,.14) 0%,transparent 62%);pointer-events:none}
.qbw-hero-g2{position:absolute;bottom:-60px;left:-80px;width:380px;height:380px;background:radial-gradient(circle,rgba(212,168,67,.06) 0%,transparent 62%);pointer-events:none}
.qbw-hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(212,168,67,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(212,168,67,.04) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;-webkit-mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 20%,transparent 100%);mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 20%,transparent 100%)}
.qbw-hero-inner{max-width:1180px;margin:0 auto;width:100%;position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
@media(max-width:760px){.qbw-hero-inner{grid-template-columns:1fr}.qbw-hero-stats{display:none!important}}
.qbw-hero-pill{display:inline-flex;align-items:center;gap:7px;background:rgba(212,168,67,.1);border:1px solid rgba(212,168,67,.25);border-radius:100px;padding:5px 14px 5px 8px;margin-bottom:18px}
.qbw-hero-dot{width:7px;height:7px;border-radius:50%;background:var(--grn);box-shadow:0 0 8px var(--grn);animation:blink 2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.qbw-hero-pill-txt{font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold2)}
.qbw-hero-h1{font-size:clamp(28px,4.5vw,52px);font-weight:900;line-height:1.05;letter-spacing:-1.5px;color:var(--txt);margin-bottom:16px}
.qbw-hero-h1 em{font-style:normal;background:linear-gradient(90deg,var(--gold) 0%,var(--gold3) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.qbw-hero-sub{font-size:15px;color:var(--sub);line-height:1.7;margin-bottom:28px;max-width:440px}
.qbw-hero-btns{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:28px}
.qbw-btn-gold{display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,var(--gold) 0%,var(--gold2) 60%,var(--gold3) 100%);color:#08060a;font-size:13px;font-weight:900;letter-spacing:.3px;padding:13px 26px;border-radius:9px;text-decoration:none;border:none;cursor:pointer;box-shadow:0 4px 20px rgba(212,168,67,.3),0 1px 0 rgba(255,255,255,.15) inset;transition:transform .18s var(--ease),box-shadow .18s var(--ease);white-space:nowrap}
.qbw-btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(212,168,67,.45)}
.qbw-btn-ghost{display:inline-flex;align-items:center;gap:7px;background:transparent;border:1.5px solid rgba(212,168,67,.3);color:var(--gold2);font-size:13px;font-weight:800;padding:12px 24px;border-radius:9px;text-decoration:none;cursor:pointer;transition:border-color .15s,background .15s;white-space:nowrap}
.qbw-btn-ghost:hover{border-color:var(--gold);background:rgba(212,168,67,.07)}
.qbw-hero-chips{display:flex;gap:10px;flex-wrap:wrap}
.qbw-hero-chip{font-size:11px;font-weight:700;color:var(--dim);display:flex;align-items:center;gap:5px}
.qbw-hero-chip::before{content:'✓';color:var(--grn);font-size:10px;font-weight:900}
.qbw-hero-stats{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.qbw-hero-stat{background:var(--bg2);border:1px solid var(--bd2);border-radius:14px;padding:20px 16px;text-align:center;position:relative;overflow:hidden}
.qbw-hero-stat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.qbw-hero-stat-icon{font-size:22px;margin-bottom:8px}
.qbw-hero-stat-val{font-size:26px;font-weight:900;color:var(--gold2);letter-spacing:-.5px;line-height:1}
.qbw-hero-stat-lbl{font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--dim);margin-top:4px}

/* ── CAT NAV ── */
.qbw-catnav{background:var(--bg2);border-top:1px solid var(--bd);border-bottom:1px solid var(--bd);padding:20px}
.qbw-catnav-inner{max-width:1180px;margin:0 auto}
.qbw-catnav-lbl{font-size:9px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--dim);text-align:center;margin-bottom:14px}
.qbw-catnav-row{display:flex;gap:8px;flex-wrap:wrap;justify-content:center}
.qbw-catnav-btn{display:flex;flex-direction:column;align-items:center;gap:5px;background:var(--bg3);border:1px solid var(--bd);border-radius:12px;padding:12px 14px;cursor:pointer;font-size:10px;font-weight:800;color:var(--sub);min-width:82px;text-align:center;transition:border-color .15s,color .15s,background .15s}
.qbw-catnav-btn:hover,.qbw-catnav-btn.active{border-color:rgba(212,168,67,.4);background:rgba(212,168,67,.07);color:var(--gold2)}
.qbw-catnav-btn span:first-child{font-size:22px}

/* ── STICKY FILTER BAR ── */
.qbw-sticky{position:sticky;top:0;z-index:200;background:rgba(13,13,15,.97);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--bd2)}
.qbw-sticky-inner{max-width:1180px;margin:0 auto;display:flex;overflow-x:auto;scrollbar-width:none;padding:0 16px}
.qbw-sticky-inner::-webkit-scrollbar{display:none}
.qbw-sticky-btn{flex-shrink:0;padding:13px 16px;font-size:12px;font-weight:700;color:var(--sub);background:none;border:none;cursor:pointer;border-bottom:2.5px solid transparent;white-space:nowrap;transition:color .15s,border-color .15s}
.qbw-sticky-btn:hover{color:var(--txt)}
.qbw-sticky-btn.active{color:var(--gold2);border-bottom-color:var(--gold)}

/* ── SECTION WRAPPER ── */
.qbw-sec{padding:44px 0 0}
.qbw-sec-head{max-width:1180px;margin:0 auto;padding:0 20px 16px;display:flex;align-items:flex-end;justify-content:space-between;gap:12px;flex-wrap:wrap}
.qbw-sec-left{}
.qbw-sec-tag{font-size:9px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);margin-bottom:4px}
.qbw-sec-title{font-size:clamp(18px,3vw,26px);font-weight:900;letter-spacing:-.5px;color:var(--txt)}
.qbw-sec-count{font-size:11px;color:var(--dim);margin-top:3px}

/* ── SLIDER ── */
.qbw-slide-wrap{position:relative}
.qbw-slide-outer{overflow:hidden;padding:4px 20px 20px;max-width:calc(1180px + 40px);margin:0 auto}
.qbw-slide-track{display:flex;gap:12px;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;-webkit-overflow-scrolling:touch;padding-bottom:4px}
.qbw-slide-track::-webkit-scrollbar{display:none}
.qbw-arr{position:absolute;top:50%;transform:translateY(-50%);z-index:10;width:40px;height:40px;background:var(--bg2);border:1px solid var(--bd2);border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--txt);box-shadow:0 4px 20px rgba(0,0,0,.5);transition:background .15s,color .15s,border-color .15s}
.qbw-arr:hover{background:var(--gold);color:#08060a;border-color:var(--gold)}
.qbw-arr-l{left:4px}.qbw-arr-r{right:4px}
@media(max-width:600px){.qbw-arr{display:none}}

/* ── GRID LAYOUT (featured / 5-wide etc.) ── */
.qbw-grid-wrap{max-width:1180px;margin:0 auto;padding:0 20px 20px}
.qbw-grid-4{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px}
.qbw-grid-5{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}
@media(max-width:1100px){.qbw-grid-5{grid-template-columns:repeat(4,1fr)}}
@media(max-width:840px){.qbw-grid-5{grid-template-columns:repeat(3,1fr)}}
@media(max-width:600px){.qbw-grid-4,.qbw-grid-5{grid-template-columns:repeat(2,1fr);gap:10px}}

/* ── PRODUCT CARD ── */
.qbw-card{flex-shrink:0;width:172px;background:var(--bg2);border:1px solid var(--bd);border-radius:16px;overflow:hidden;display:flex;flex-direction:column;text-decoration:none;color:inherit;scroll-snap-align:start;transition:border-color .22s var(--ease),box-shadow .22s var(--ease),transform .22s var(--ease);position:relative}
.qbw-card:active{transform:scale(0.97)}
.qbw-card:hover{border-color:rgba(212,168,67,.5);box-shadow:0 14px 40px rgba(0,0,0,.55),0 0 0 1px rgba(212,168,67,.15);transform:translateY(-4px)}
.qbw-grid-4 .qbw-card,.qbw-grid-5 .qbw-card{width:auto;flex-shrink:1}
@media(max-width:600px){.qbw-card{width:156px}}

/* image area */
.qbw-card-img{position:relative;background:linear-gradient(160deg,var(--bg3) 0%,#0d0d10 100%);aspect-ratio:1/1;overflow:hidden}
.qbw-card-img img{width:100%;height:100%;object-fit:contain;object-position:center;padding:14px;display:block;transition:transform .4s var(--ease)}
.qbw-card:hover .qbw-card-img img{transform:scale(1.08)}
.qbw-card-img-fade{position:absolute;bottom:0;left:0;right:0;height:40px;background:linear-gradient(to top,var(--bg2),transparent);pointer-events:none}
.qbw-card-no-img{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:40px;opacity:.1}

/* save badge */
.qbw-save-badge{position:absolute;top:8px;left:8px;background:linear-gradient(135deg,#15803d,#22c55e);color:#fff;font-size:9px;font-weight:900;letter-spacing:.3px;padding:3px 8px;border-radius:20px;box-shadow:0 2px 8px rgba(22,163,74,.45);white-space:nowrap}
.qbw-save-badge small{font-size:8px;font-weight:700;opacity:.9;margin-left:2px}
.qbw-demand-tag{position:absolute;bottom:8px;left:8px;font-size:7px;font-weight:900;letter-spacing:.8px;text-transform:uppercase;padding:2px 7px;border-radius:4px;backdrop-filter:blur(6px)}
.qbw-demand-tag--hot{background:rgba(212,168,67,.18);border:1px solid rgba(212,168,67,.35);color:var(--gold2)}
.qbw-demand-tag--best{background:rgba(212,168,67,.88);color:#09070a}
.qbw-demand-tag--new{background:rgba(34,197,94,.14);border:1px solid rgba(34,197,94,.28);color:#4ade80}
.qbw-sold-mask{position:absolute;inset:0;background:rgba(6,6,8,.7);display:flex;align-items:center;justify-content:center}
.qbw-sold-lbl{font-size:9px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--sub);border:1px solid var(--bd2);background:var(--bg);padding:5px 14px;border-radius:5px}

/* card body — no button, cleaner */
.qbw-card-body{padding:10px 11px 11px;flex:1;display:flex;flex-direction:column}
.qbw-card-type-lbl{font-size:7px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:var(--gold);opacity:.65;margin-bottom:3px}
.qbw-card-name{font-size:12px;font-weight:700;line-height:1.35;color:var(--txt);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;flex:1;margin-bottom:7px}
.qbw-card-price{margin-top:auto}
.qbw-price-now{font-size:16px;font-weight:900;color:var(--gold2);letter-spacing:-.4px;line-height:1}
.qbw-price-was{font-size:9px;color:var(--dim);text-decoration:line-through;margin-left:3px}
.qbw-price-save{font-size:9px;font-weight:800;color:var(--grn);margin-top:2px}
.qbw-price-locked{font-size:9px;font-weight:700;color:var(--sub);display:flex;align-items:center;gap:4px;padding:5px 8px;background:rgba(255,255,255,.03);border:1px solid var(--bd);border-radius:5px}
.qbw-price-locked::before{content:'🔒';font-size:9px}
.qbw-price-retail{font-size:8px;color:var(--dim);margin-bottom:2px}
.qbw-price-unlock{font-size:8px;color:var(--dim);margin-top:1px}

/* ── IMAGE STRIP (auto-scroll, image-only) ── */
.qbw-istrip-outer{overflow:hidden;padding:4px 0 20px;cursor:grab}
.qbw-istrip-outer:active{cursor:grabbing}
.qbw-istrip-track{display:flex;gap:10px;width:max-content;animation:qbwIStrip var(--qbw-strip-dur,24s) linear infinite}
@keyframes qbwIStrip{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.qbw-istrip-item{flex:0 0 auto;display:block;text-decoration:none;position:relative}
.qbw-istrip-item img{width:var(--qbw-iw,150px);height:var(--qbw-iw,150px);object-fit:contain;object-position:center;background:var(--bg2);border:1px solid var(--bd);border-radius:14px;padding:10px;display:block;transition:border-color .25s,transform .28s var(--ease)}
.qbw-istrip-item:hover img,.qbw-istrip-item:active img{border-color:rgba(212,168,67,.5);transform:scale(1.05)}
.qbw-istrip-item-lbl{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(0,0,0,.85),transparent);border-radius:0 0 14px 14px;padding:18px 8px 6px;font-size:9px;font-weight:700;color:rgba(255,255,255,.85);text-align:center;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .2s}
.qbw-istrip-item:hover .qbw-istrip-item-lbl{opacity:1}
@media(max-width:600px){
  .qbw-istrip-item img{width:var(--qbw-iw-m,130px)!important;height:var(--qbw-iw-m,130px)!important}
}

/* ── LARGE HERO CARD (featured) ── */
.qbw-hero-card{flex-shrink:0;width:250px;background:var(--bg2);border:1px solid var(--bd);border-radius:16px;overflow:hidden;display:flex;flex-direction:column;text-decoration:none;color:inherit;scroll-snap-align:start;transition:border-color .22s,box-shadow .22s,transform .22s;position:relative}
.qbw-hero-card:hover{border-color:rgba(212,168,67,.5);box-shadow:0 20px 54px rgba(0,0,0,.6);transform:translateY(-6px)}
.qbw-hero-card .qbw-card-img{aspect-ratio:4/3}
.qbw-hero-card .qbw-card-name{font-size:13px;font-weight:800}
.qbw-hero-card .qbw-price-now{font-size:18px}
@media(max-width:600px){.qbw-hero-card{width:200px}}

/* ── INFO BANNERS ── */
.qbw-banner-stats{background:var(--blk);border-top:1px solid var(--bd);border-bottom:1px solid var(--bd);padding:36px 20px;margin-top:44px}
.qbw-banner-stats-inner{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--bd);border:1px solid var(--bd);border-radius:var(--r);overflow:hidden}
@media(max-width:700px){.qbw-banner-stats-inner{grid-template-columns:1fr 1fr}}
.qbw-bstat{background:var(--bg2);padding:26px 20px;text-align:center;position:relative}
.qbw-bstat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.qbw-bstat-icon{font-size:24px;margin-bottom:10px}
.qbw-bstat-val{font-size:28px;font-weight:900;color:var(--gold2);letter-spacing:-.5px;line-height:1}
.qbw-bstat-lbl{font-size:11px;color:var(--sub);margin-top:5px;line-height:1.4}

.qbw-banner-b2b{max-width:1180px;margin:44px auto 0;padding:0 20px}
.qbw-banner-b2b-inner{background:linear-gradient(135deg,rgba(212,168,67,.08) 0%,rgba(212,168,67,.03) 100%);border:1px solid rgba(212,168,67,.18);border-radius:16px;padding:32px 32px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;position:relative;overflow:hidden}
.qbw-banner-b2b-inner::before{content:'🔒';position:absolute;right:32px;top:50%;transform:translateY(-50%);font-size:90px;opacity:.05;pointer-events:none}
.qbw-banner-b2b-tag{font-size:9px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:6px}
.qbw-banner-b2b-title{font-size:20px;font-weight:900;color:var(--txt);margin-bottom:6px;letter-spacing:-.3px}
.qbw-banner-b2b-sub{font-size:13px;color:var(--sub);line-height:1.5}
@media(max-width:600px){.qbw-banner-b2b-inner{padding:24px 20px;flex-direction:column}}

.qbw-banner-delivery{background:var(--bg2);border-top:1px solid var(--bd);border-bottom:1px solid var(--bd);padding:28px 20px;margin-top:44px}
.qbw-banner-delivery-inner{max-width:1180px;margin:0 auto;display:flex;align-items:center;gap:0;flex-wrap:wrap;justify-content:center}
.qbw-del-item{display:flex;align-items:center;gap:12px;padding:8px 24px;border-right:1px solid var(--bd);flex:1;min-width:180px}
.qbw-del-item:last-child{border-right:none}
.qbw-del-icon{font-size:24px;flex-shrink:0}
.qbw-del-title{font-size:13px;font-weight:800;color:var(--txt)}
.qbw-del-sub{font-size:11px;color:var(--sub);margin-top:2px}
@media(max-width:700px){.qbw-del-item{border-right:none;border-bottom:1px solid var(--bd);width:100%;flex:unset}.qbw-del-item:last-child{border-bottom:none}}

/* ── DUAL PROMO ── */
.qbw-dual{max-width:1180px;margin:44px auto 0;padding:0 20px;display:grid;grid-template-columns:1fr 1fr;gap:14px}
@media(max-width:600px){.qbw-dual{grid-template-columns:1fr}}
.qbw-promo{border-radius:14px;padding:30px 26px;position:relative;overflow:hidden;border:1px solid var(--bd);min-height:130px;display:flex;flex-direction:column;justify-content:flex-end}
.qbw-promo--liq{background:linear-gradient(135deg,#0a0600 0%,#1c1200 60%,#0a0600 100%)}
.qbw-promo--hook{background:linear-gradient(135deg,#060a14 0%,#0c1222 60%,#060a14 100%)}
.qbw-promo-emoji{position:absolute;right:24px;top:50%;transform:translateY(-50%);font-size:60px;opacity:.2;pointer-events:none}
.qbw-promo-tag{font-size:8px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:5px;position:relative}
.qbw-promo-title{font-size:18px;font-weight:900;color:var(--txt);letter-spacing:-.3px;position:relative}
.qbw-promo-sub{font-size:11px;color:var(--sub);margin-top:3px;position:relative}

/* ── BRANDS ── */
.qbw-brands{padding:40px 20px;background:var(--blk);border-top:1px solid var(--bd)}
.qbw-brands-inner{max-width:1180px;margin:0 auto}
.qbw-brands-lbl{font-size:9px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--dim);text-align:center;margin-bottom:18px}
.qbw-brands-row{display:flex;gap:8px;flex-wrap:wrap;justify-content:center}
.qbw-brand{background:var(--bg2);border:1px solid var(--bd);border-radius:100px;padding:7px 16px;font-size:12px;font-weight:800;color:var(--dim);transition:border-color .15s,color .15s}
.qbw-brand:hover{border-color:rgba(212,168,67,.35);color:var(--gold2)}

/* ── SERVE ── */
.qbw-serve{padding:56px 20px;background:var(--bg2);border-top:1px solid var(--bd)}
.qbw-serve-inner{max-width:1180px;margin:0 auto}
.qbw-stag{font-size:9px;font-weight:900;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);text-align:center;margin-bottom:6px}
.qbw-stitle{font-size:clamp(22px,3.5vw,32px);font-weight:900;letter-spacing:-.5px;color:var(--txt);text-align:center;margin-bottom:28px}
.qbw-serve-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px}
.qbw-serve-card{background:var(--bg);border:1px solid var(--bd);border-radius:12px;padding:22px 16px;text-align:center;transition:border-color .18s,background .18s}
.qbw-serve-card:hover{border-color:rgba(212,168,67,.3);background:var(--bg3)}
.qbw-serve-emoji{font-size:28px;margin-bottom:10px;display:block}
.qbw-serve-name{font-size:13px;font-weight:800;color:var(--txt);margin-bottom:3px}
.qbw-serve-sub{font-size:10px;color:var(--dim)}

/* ── WHY ── */
