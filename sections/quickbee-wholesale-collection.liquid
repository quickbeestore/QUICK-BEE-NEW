/* ─── SCROLL OFFSET ─── */
function off(){
  var n = document.querySelector('.qbw-nav');
  var h = document.querySelector('sticky-header,#shopify-section-quickbee-header');
  return (n?n.offsetHeight:44)+(h?h.offsetHeight:56)+8;
}

/* ─── NAV CLICK ─── */
window.qbwNav = function(btn){
  document.querySelectorAll('.qbw-nav-btn').forEach(function(b){ b.classList.remove('on'); });
  btn.classList.add('on');
  var el = document.getElementById(btn.getAttribute('data-id'));
  if(el) window.scrollTo({ top: el.getBoundingClientRect().top+window.scrollY-off(), behavior:'smooth' });
  btn.scrollIntoView({ inline:'center', behavior:'smooth', block:'nearest' });
};

/* ─── AUTO-HIGHLIGHT ─── */
if(window.IntersectionObserver){
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting) return;
      var id = e.target.id;
      document.querySelectorAll('.qbw-nav-btn').forEach(function(b){ b.classList.toggle('on',b.getAttribute('data-id')===id); });
      var act = document.querySelector('.qbw-nav-btn.on');
      if(act) act.scrollIntoView({ inline:'nearest', behavior:'smooth', block:'nearest' });
    });
  },{ threshold:0.2, rootMargin:'-50px 0px -55% 0px' });
  document.querySelectorAll('[id^="s-"]').forEach(function(s){ io.observe(s); });
}

/* ─── FAQ ─── */
window.qbwFaq = function(el){
  var item = el.closest('.qbw-faq-item');
  if(!item) return;
  var was = item.classList.contains('open');
  document.querySelectorAll('.qbw-faq-item.open').forEach(function(i){ i.classList.remove('open'); });
  if(!was) item.classList.add('open');
};

