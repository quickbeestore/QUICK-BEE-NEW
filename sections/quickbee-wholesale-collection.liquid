{%- paginate collection.products by 250 -%}
<style>
/* ══════════════════════════════════
   QUICKBEE WHOLESALE — RICH LAYOUT
   ══════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.qbw {
  --blk:   #060608;
  --bg:    #0c0c0f;
  --bg2:   #121215;
  --bg3:   #181820;
  --bg4:   #1e1e28;
  --bd:    rgba(255,255,255,0.06);
  --bd2:   rgba(255,255,255,0.10);
  --gold:  #d4a843;
  --gold2: #f0c55a;
  --gold3: #ffd97d;
  --grn:   #22c55e;
  --red:   #ef4444;
  --txt:   #f2ede6;
  --sub:   #9c9892;
  --dim:   #5a5855;
  --ease:  cubic-bezier(.4,0,.2,1);
  --r:     12px;

  background: var(--bg);
  color: var(--txt);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ── TICKER ── */
.qbw-ann {
  background: var(--gold);
  color: #08060a;
  font-size: 11px; font-weight: 900; letter-spacing: 0.8px;
  text-transform: uppercase;
  padding: 9px 0;
  overflow: hidden; white-space: nowrap;
}
.qbw-ann-inner {
  display: inline-flex; gap: 0;
  animation: qbwAnn 28s linear infinite;
}
@keyframes qbwAnn { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.qbw-ann-item { padding: 0 32px; border-right: 1px solid rgba(0,0,0,0.15); }

/* ── HERO ── */
.qbw-hero {
  position: relative; overflow: hidden;
  background: var(--blk);
  min-height: 480px;
  display: flex; align-items: center;
  padding: 60px 24px;
}
.qbw-hero-glow1 {
  position: absolute; top: -100px; right: -100px;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(212,168,67,0.14) 0%, transparent 60%);
  pointer-events: none;
}
.qbw-hero-glow2 {
  position: absolute; bottom: -80px; left: -60px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(212,168,67,0.06) 0%, transparent 60%);
  pointer-events: none;
}
.qbw-hero-grid-bg {
  position: absolute; inset: 0;
  background-image: linear-gradient(rgba(212,168,67,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(212,168,67,0.04) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
}
.qbw-hero-inner {
  max-width: 1180px; margin: 0 auto; width: 100%;
  position: relative; z-index: 1;
  display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center;
}
@media(max-width:760px){.qbw-hero-inner{grid-template-columns:1fr}.qbw-hero-right-visual{display:none}}
.qbw-hero-pill {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(212,168,67,0.1); border: 1px solid rgba(212,168,67,0.25);
  border-radius: 100px; padding: 5px 14px 5px 8px; margin-bottom: 20px;
}
.qbw-hero-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--grn); box-shadow: 0 0 8px var(--grn); animation: blink 2s ease-in-out infinite; }
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.qbw-hero-pill-txt { font-size: 10px; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gold2); }
.qbw-hero-title {
  font-size: clamp(30px, 4.5vw, 54px); font-weight: 900;
  line-height: 1.05; letter-spacing: -1.5px; color: var(--txt);
  margin-bottom: 18px;
}
.qbw-hero-title em {
  font-style: normal;
  background: linear-gradient(90deg, var(--gold) 0%, var(--gold3) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.qbw-hero-sub { font-size: 15px; color: var(--sub); line-height: 1.7; margin-bottom: 30px; max-width: 440px; }
.qbw-hero-btns { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 32px; }
.qbw-btn-gold {
  display: inline-flex; align-items: center; gap: 7px;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 60%, var(--gold3) 100%);
  color: #08060a; font-size: 13px; font-weight: 900; letter-spacing: 0.3px;
  padding: 13px 26px; border-radius: 9px; text-decoration: none; border: none; cursor: pointer;
  box-shadow: 0 4px 20px rgba(212,168,67,0.3), 0 1px 0 rgba(255,255,255,0.15) inset;
  transition: transform .18s var(--ease), box-shadow .18s var(--ease);
  white-space: nowrap;
}
.qbw-btn-gold:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(212,168,67,0.45); }
.qbw-btn-ghost {
  display: inline-flex; align-items: center; gap: 7px;
  background: transparent; border: 1.5px solid rgba(212,168,67,0.3);
  color: var(--gold2); font-size: 13px; font-weight: 800;
  padding: 12px 24px; border-radius: 9px; text-decoration: none; cursor: pointer;
  transition: border-color .15s, background .15s;
  white-space: nowrap;
}
.qbw-btn-ghost:hover { border-color: var(--gold); background: rgba(212,168,67,0.07); }
.qbw-hero-chips { display: flex; gap: 8px; flex-wrap: wrap; }
.qbw-hero-chip {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 700; color: var(--dim);
  padding: 5px 0;
}
.qbw-hero-chip::before { content: '✓'; color: var(--grn); font-size: 10px; font-weight: 900; }

/* right visual */
.qbw-hero-right-visual {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}
.qbw-hero-stat-box {
  background: var(--bg2); border: 1px solid var(--bd2);
  border-radius: 14px; padding: 20px 18px; text-align: center;
  position: relative; overflow: hidden;
}
.qbw-hero-stat-box::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}
.qbw-hero-stat-box-icon { font-size: 22px; margin-bottom: 8px; }
.qbw-hero-stat-val { font-size: 26px; font-weight: 900; color: var(--gold2); letter-spacing: -0.5px; line-height: 1; }
.qbw-hero-stat-label { font-size: 10px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--dim); margin-top: 4px; }

/* ── CATEGORY NAV ── */
.qbw-catnav {
  background: var(--bg2); border-top: 1px solid var(--bd); border-bottom: 1px solid var(--bd);
  padding: 24px 20px;
}
.qbw-catnav-inner { max-width: 1180px; margin: 0 auto; }
.qbw-catnav-label { font-size: 10px; font-weight: 900; letter-spacing: 2px; text-transform: uppercase; color: var(--dim); margin-bottom: 16px; text-align: center; }
.qbw-catnav-grid {
  display: flex; gap: 8px; flex-wrap: wrap; justify-content: center;
}
.qbw-catnav-item {
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  background: var(--bg3); border: 1px solid var(--bd);
  border-radius: 12px; padding: 14px 16px; cursor: pointer;
  text-decoration: none; color: var(--sub);
  transition: border-color .18s, background .18s, color .18s;
  min-width: 90px; text-align: center;
}
.qbw-catnav-item:hover, .qbw-catnav-item.active {
  border-color: rgba(212,168,67,0.4); background: rgba(212,168,67,0.07); color: var(--gold2);
}
.qbw-catnav-emoji { font-size: 24px; }
.qbw-catnav-name { font-size: 10px; font-weight: 800; letter-spacing: 0.3px; }
.qbw-catnav-count { font-size: 9px; color: var(--dim); }

/* ── SHARED SECTION HEADER ── */
.qbw-section { padding: 48px 0 0; }
.qbw-section-head {
  max-width: 1180px; margin: 0 auto;
  padding: 0 20px 18px;
  display: flex; align-items: flex-end; justify-content: space-between; gap: 12px; flex-wrap: wrap;
}
.qbw-section-label {
  font-size: 9px; font-weight: 900; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--gold); margin-bottom: 4px;
}
.qbw-section-title { font-size: clamp(20px, 3vw, 28px); font-weight: 900; letter-spacing: -0.5px; color: var(--txt); }
.qbw-section-count { font-size: 12px; color: var(--dim); margin-top: 2px; }
.qbw-section-viewall {
  font-size: 12px; font-weight: 800; color: var(--gold);
  text-decoration: none; display: flex; align-items: center; gap: 4px;
  white-space: nowrap;
  transition: color .15s;
}
.qbw-section-viewall:hover { color: var(--gold3); }

/* ── SLIDER ── */
.qbw-slider-wrap { position: relative; }
.qbw-slider-track-outer {
  overflow: hidden;
  padding: 4px 20px 20px;
  max-width: calc(1180px + 40px); margin: 0 auto;
}
.qbw-slider-track {
  display: flex; gap: 12px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 4px;
}
.qbw-slider-track::-webkit-scrollbar { display: none; }

/* slider arrow buttons */
.qbw-slider-arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  z-index: 10;
  width: 40px; height: 40px;
  background: var(--bg2); border: 1px solid var(--bd2);
  border-radius: 50%; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; color: var(--txt);
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  transition: background .15s, border-color .15s, transform .15s var(--ease);
}
.qbw-slider-arrow:hover { background: var(--gold); color: #08060a; border-color: var(--gold); transform: translateY(-50%) scale(1.05); }
.qbw-slider-arrow--prev { left: 4px; }
.qbw-slider-arrow--next { right: 4px; }
@media(max-width:600px){ .qbw-slider-arrow { display: none; } }

/* ── PRODUCT CARD ── */
.qbw-card {
  flex-shrink: 0;
  width: 200px;
  background: var(--bg2); border: 1px solid var(--bd);
  border-radius: var(--r); overflow: hidden;
  display: flex; flex-direction: column;
  text-decoration: none; color: inherit;
  scroll-snap-align: start;
  transition: border-color .2s var(--ease), box-shadow .2s var(--ease), transform .2s var(--ease);
  position: relative;
}
.qbw-card:hover {
  border-color: rgba(212,168,67,0.4);
  box-shadow: 0 10px 36px rgba(0,0,0,0.5), 0 0 0 1px rgba(212,168,67,0.12);
  transform: translateY(-4px);
}
@media(max-width:600px){ .qbw-card { width: 162px; } }

.qbw-card-img {
  position: relative; background: var(--bg3);
  aspect-ratio: 1/1; overflow: hidden;
}
.qbw-card-img img {
  width: 100%; height: 100%;
  object-fit: contain; object-position: center;
  padding: 14px; display: block;
  transition: transform .35s var(--ease);
}
.qbw-card:hover .qbw-card-img img { transform: scale(1.07); }
.qbw-card-img-empty {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36px; opacity: 0.12;
}

/* save badge */
.qbw-save {
  position: absolute; top: 8px; left: 8px;
  background: linear-gradient(135deg, #16a34a, #22c55e);
  color: #fff; font-size: 10px; font-weight: 900; letter-spacing: 0.2px;
  padding: 4px 9px; border-radius: 6px;
  box-shadow: 0 2px 10px rgba(22,163,74,0.4);
  line-height: 1.3; text-align: center;
}
.qbw-save small { display: block; font-size: 8px; font-weight: 700; opacity: 0.85; }

/* type chip */
.qbw-chip {
  position: absolute; top: 8px; right: 8px;
  background: rgba(6,6,8,0.82); border: 1px solid var(--bd2);
  backdrop-filter: blur(4px);
  font-size: 7px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase;
  color: var(--sub); padding: 3px 7px; border-radius: 5px;
}
/* demand label */
.qbw-demand {
  position: absolute; bottom: 8px; left: 8px;
  font-size: 7px; font-weight: 900; letter-spacing: 0.8px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 5px;
}
.qbw-demand--hot { background: rgba(212,168,67,0.15); border: 1px solid rgba(212,168,67,0.3); color: var(--gold2); }
.qbw-demand--best { background: rgba(212,168,67,0.9); color: #0a0800; }
.qbw-demand--new { background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.25); color: #4ade80; }

/* sold */
.qbw-sold-mask {
  position: absolute; inset: 0; background: rgba(6,6,8,0.72);
  display: flex; align-items: center; justify-content: center;
}
.qbw-sold-tag {
  font-size: 9px; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--sub); border: 1px solid var(--bd2); background: var(--bg);
  padding: 5px 14px; border-radius: 5px;
}

/* card body */
.qbw-card-body { padding: 12px 12px 14px; flex: 1; display: flex; flex-direction: column; gap: 0; }
.qbw-card-type { font-size: 8px; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; color: var(--dim); margin-bottom: 5px; }
.qbw-card-name {
  font-size: 12px; font-weight: 700; line-height: 1.35; color: var(--txt);
  margin-bottom: 10px;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.qbw-price-box {
  background: var(--bg3); border: 1px solid var(--bd);
  border-radius: 7px; padding: 8px 10px; margin-bottom: 10px;
}
.qbw-price-row { display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; }
.qbw-price-now { font-size: 16px; font-weight: 900; color: var(--gold2); letter-spacing: -0.3px; line-height: 1; }
.qbw-price-was { font-size: 11px; color: var(--dim); text-decoration: line-through; }
.qbw-price-save { font-size: 10px; font-weight: 800; color: var(--grn); margin-top: 4px; }
.qbw-price-locked { font-size: 10px; font-weight: 700; color: var(--sub); display: flex; align-items: center; gap: 4px; }
.qbw-price-locked::before { content: '🔒'; font-size: 9px; }
.qbw-price-retail { font-size: 10px; color: var(--dim); margin-bottom: 3px; }
.qbw-price-unlock { font-size: 9px; color: var(--dim); margin-top: 3px; }

.qbw-card-btns { display: flex; gap: 6px; margin-top: auto; }
.qbw-cbtn-p {
  flex: 1; padding: 9px 6px;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
  color: #08060a; font-size: 10px; font-weight: 900;
  border-radius: 7px; border: none; cursor: pointer;
  text-align: center; text-decoration: none; display: block;
  transition: box-shadow .15s, transform .15s;
}
.qbw-cbtn-p:hover { box-shadow: 0 4px 16px rgba(212,168,67,0.35); transform: translateY(-1px); }
.qbw-cbtn-g {
  padding: 9px 8px;
  background: transparent; border: 1.5px solid var(--bd2);
  color: var(--sub); font-size: 10px; font-weight: 800;
  border-radius: 7px; cursor: pointer; text-decoration: none;
  display: flex; align-items: center; justify-content: center;
  transition: border-color .15s, color .15s;
  white-space: nowrap;
}
.qbw-cbtn-g:hover { border-color: var(--gold); color: var(--gold2); }

/* ── INFO BANNER — savingsstrip ── */
.qbw-banner-savings {
  margin: 48px 0 0;
  background: var(--blk);
  border-top: 1px solid var(--bd); border-bottom: 1px solid var(--bd);
  padding: 40px 20px;
  position: relative; overflow: hidden;
}
.qbw-banner-savings::before {
  content: '';
  position: absolute; top: -80px; right: -80px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(212,168,67,0.09) 0%, transparent 60%);
  pointer-events: none;
}
.qbw-banner-savings-inner {
  max-width: 1180px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 1px; background: var(--bd);
  border: 1px solid var(--bd); border-radius: var(--r); overflow: hidden;
}
@media(max-width:700px){ .qbw-banner-savings-inner { grid-template-columns: 1fr 1fr; } }
.qbw-banner-stat {
  background: var(--bg2); padding: 28px 20px; text-align: center;
  position: relative;
}
.qbw-banner-stat::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}
.qbw-banner-stat-icon { font-size: 24px; margin-bottom: 10px; display: block; }
.qbw-banner-stat-val { font-size: 28px; font-weight: 900; color: var(--gold2); letter-spacing: -0.5px; line-height: 1; }
.qbw-banner-stat-label { font-size: 11px; color: var(--sub); margin-top: 5px; line-height: 1.4; }

/* ── INFO BANNER — B2B trust ── */
.qbw-banner-b2b {
  margin: 48px 20px 0;
  max-width: 1180px; margin-left: auto; margin-right: auto;
  background: linear-gradient(135deg, rgba(212,168,67,0.07) 0%, rgba(212,168,67,0.03) 100%);
  border: 1px solid rgba(212,168,67,0.18);
  border-radius: 16px; padding: 32px 32px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 24px; flex-wrap: wrap;
  position: relative; overflow: hidden;
}
.qbw-banner-b2b::before {
  content: '🔒';
  position: absolute; right: 32px; top: 50%; transform: translateY(-50%);
  font-size: 80px; opacity: 0.06; pointer-events: none;
}
.qbw-banner-b2b-left { flex: 1; }
.qbw-banner-b2b-tag { font-size: 9px; font-weight: 900; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
.qbw-banner-b2b-title { font-size: 20px; font-weight: 900; color: var(--txt); margin-bottom: 6px; letter-spacing: -0.3px; }
.qbw-banner-b2b-sub { font-size: 13px; color: var(--sub); line-height: 1.5; }
@media(max-width:600px){ .qbw-banner-b2b { margin: 48px 16px 0; padding: 24px 20px; } }

/* ── INFO BANNER — delivery ── */
.qbw-banner-delivery {
  background: var(--bg2);
  border-top: 1px solid var(--bd); border-bottom: 1px solid var(--bd);
  padding: 32px 20px; margin-top: 48px;
}
.qbw-banner-delivery-inner {
  max-width: 1180px; margin: 0 auto;
  display: flex; align-items: center; gap: 20px; flex-wrap: wrap; justify-content: center;
}
.qbw-delivery-item {
  display: flex; align-items: center; gap: 12px;
  padding: 0 20px;
  border-right: 1px solid var(--bd);
}
.qbw-delivery-item:last-child { border-right: none; }
.qbw-delivery-icon { font-size: 24px; flex-shrink: 0; }
.qbw-delivery-text-title { font-size: 13px; font-weight: 800; color: var(--txt); }
.qbw-delivery-text-sub { font-size: 11px; color: var(--sub); margin-top: 2px; }
@media(max-width:600px){ .qbw-delivery-item { border-right: none; border-bottom: 1px solid var(--bd); padding: 12px 0; width: 100%; } .qbw-delivery-item:last-child { border-bottom: none; } }

/* ── INFO BANNER — categories promo ── */
.qbw-banner-cats {
  max-width: 1180px; margin: 48px auto 0;
  padding: 0 20px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
}
@media(max-width:600px){ .qbw-banner-cats { grid-template-columns: 1fr; } }
.qbw-cat-promo {
  border-radius: 14px; padding: 28px 24px;
  position: relative; overflow: hidden;
  border: 1px solid var(--bd);
  min-height: 120px; display: flex; flex-direction: column; justify-content: flex-end;
}
.qbw-cat-promo-bg { position: absolute; inset: 0; pointer-events: none; }
.qbw-cat-promo--liquor .qbw-cat-promo-bg { background: linear-gradient(135deg, #0a0600 0%, #1a1000 50%, #0d0a00 100%); }
.qbw-cat-promo--hookah .qbw-cat-promo-bg { background: linear-gradient(135deg, #060a12 0%, #0a1020 50%, #060a12 100%); }
.qbw-cat-promo-emoji {
  position: absolute; right: 24px; top: 50%; transform: translateY(-50%);
  font-size: 52px; opacity: 0.25;
}
.qbw-cat-promo-tag { font-size: 8px; font-weight: 900; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; position: relative; }
.qbw-cat-promo-title { font-size: 18px; font-weight: 900; color: var(--txt); letter-spacing: -0.3px; position: relative; }
.qbw-cat-promo-sub { font-size: 11px; color: var(--sub); margin-top: 3px; position: relative; }

/* ── BRANDS STRIP ── */
.qbw-brands {
  padding: 40px 20px; background: var(--blk);
  border-top: 1px solid var(--bd);
}
.qbw-brands-inner { max-width: 1180px; margin: 0 auto; }
.qbw-brands-label { font-size: 9px; font-weight: 900; letter-spacing: 2.5px; text-transform: uppercase; color: var(--dim); text-align: center; margin-bottom: 20px; }
.qbw-brands-row {
  display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;
}
.qbw-brand-pill {
  background: var(--bg2); border: 1px solid var(--bd);
  border-radius: 100px; padding: 8px 18px;
  font-size: 12px; font-weight: 800; color: var(--dim);
  transition: border-color .15s, color .15s;
}
.qbw-brand-pill:hover { border-color: rgba(212,168,67,0.35); color: var(--gold2); }

/* ── WHO WE SERVE ── */
.qbw-serve { padding: 56px 20px; background: var(--bg2); border-top: 1px solid var(--bd); }
.qbw-serve-inner { max-width: 1180px; margin: 0 auto; }
.qbw-stag { font-size: 9px; font-weight: 900; letter-spacing: 2.5px; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; text-align: center; }
.qbw-stitle { font-size: clamp(22px, 3.5vw, 32px); font-weight: 900; letter-spacing: -0.5px; color: var(--txt); text-align: center; margin-bottom: 32px; }
.qbw-serve-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 10px; }
.qbw-serve-card {
  background: var(--bg); border: 1px solid var(--bd); border-radius: 12px;
  padding: 22px 16px; text-align: center;
  transition: border-color .18s, background .18s;
}
.qbw-serve-card:hover { border-color: rgba(212,168,67,0.3); background: var(--bg3); }
.qbw-serve-emoji { font-size: 28px; margin-bottom: 10px; display: block; }
.qbw-serve-name { font-size: 13px; font-weight: 800; color: var(--txt); margin-bottom: 3px; }
.qbw-serve-sub { font-size: 10px; color: var(--dim); }

/* ── WHY ── */
.qbw-why { padding: 56px 20px; background: var(--bg); border-top: 1px solid var(--bd); }
.qbw-why-inner { max-width: 1180px; margin: 0 auto; }
.qbw-why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 12px; }
.qbw-why-card {
  background: var(--bg2); border: 1px solid var(--bd); border-radius: 12px;
  padding: 24px 20px; transition: border-color .18s;
}
.qbw-why-card:hover { border-color: rgba(212,168,67,0.25); }
.qbw-why-icon {
  width: 44px; height: 44px; background: rgba(212,168,67,0.1);
  border-radius: 10px; display: flex; align-items: center; justify-content: center;
  font-size: 20px; margin-bottom: 14px;
}
.qbw-why-title { font-size: 14px; font-weight: 800; color: var(--txt); margin-bottom: 6px; }
.qbw-why-desc { font-size: 12px; color: var(--sub); line-height: 1.6; }

/* ── CLOSING ── */
.qbw-close {
  padding: 80px 20px; background: var(--blk);
  text-align: center; position: relative; overflow: hidden;
}
.qbw-close::before {
  content: '';
  position: absolute; left: 50%; top: 60%; transform: translate(-50%, -50%);
  width: 700px; height: 500px;
  background: radial-gradient(ellipse, rgba(212,168,67,0.1) 0%, transparent 65%);
  pointer-events: none;
}
.qbw-close-inner { max-width: 640px; margin: 0 auto; position: relative; }
.qbw-close-eyebrow { font-size: 9px; font-weight: 900; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
.qbw-close-title { font-size: clamp(28px, 5vw, 48px); font-weight: 900; letter-spacing: -1px; color: var(--txt); line-height: 1.05; margin-bottom: 16px; }
.qbw-close-title em { font-style: normal; background: linear-gradient(90deg,var(--gold),var(--gold3)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.qbw-close-primary { font-size: 15px; color: var(--sub); line-height: 1.65; margin-bottom: 10px; }
.qbw-close-secondary { font-size: 12px; color: var(--dim); line-height: 1.6; margin-bottom: 36px; }
.qbw-close-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 20px; }
.qbw-close-note { font-size: 10px; color: var(--dim); letter-spacing: 0.5px; }
.qbw-close-note::before { content: '🔒 '; }

/* ── FOOTER ── */
.qbw-footer {
  background: var(--blk); border-top: 1px solid var(--bd);
  padding: 24px 20px;
}
.qbw-footer-inner {
  max-width: 1180px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
}
.qbw-footer-brand { font-size: 16px; font-weight: 900; color: var(--gold); }
.qbw-footer-brand span { color: var(--sub); font-weight: 400; font-size: 12px; margin-left: 6px; }
.qbw-footer-note { font-size: 10px; color: var(--dim); }
.qbw-footer-qr {
  width: 48px; height: 48px; background: var(--bg2); border: 1px solid var(--bd2);
  border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center;
  font-size: 7px; color: var(--dim); text-align: center; line-height: 1.4;
}

/* ── EMPTY ── */
.qbw-cat-empty { padding: 40px 20px; text-align: center; color: var(--dim); font-size: 12px; }

/* ── PAGINATION ── */
.qbw-pg { display: flex; justify-content: center; gap: 6px; flex-wrap: wrap; padding: 40px 20px 0; }
.qbw-pg-btn {
  min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
  border-radius: 8px; font-size: 13px; font-weight: 700;
  text-decoration: none; border: 1px solid var(--bd); color: var(--sub); background: var(--bg2);
  transition: all .15s;
}
.qbw-pg-btn:hover, .qbw-pg-btn--on { background: var(--gold); color: #08060a; border-color: var(--gold); }
.qbw-pg-btn--off { opacity: 0.3; pointer-events: none; }

@media(max-width:500px){
  .qbw-why-grid { grid-template-columns: 1fr; }
  .qbw-serve-grid { grid-template-columns: 1fr 1fr; }
  .qbw-banner-b2b-title { font-size: 16px; }
}
</style>

