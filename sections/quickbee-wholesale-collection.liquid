{%- paginate collection.products by 250 -%}

<div id="qb-data-root" style="display:none" aria-hidden="true">
  {%- for product in collection.products -%}
    <div class="qb-data"
      data-id="{{ product.id }}"
      data-title="{{ product.title | escape }}"
      data-url="{{ product.url }}"
      data-img="{{ product.featured_image | img_url: '500x' }}"
      data-price="{{ product.price }}"
      data-compare="{{ product.compare_at_price }}"
      data-tags="{{ product.tags | join: ',' | downcase | escape }}"
      data-vendor="{{ product.vendor | escape }}"
      data-variant="{{ product.variants.first.id }}"
      data-avail="{{ product.available }}">
    </div>
  {%- endfor -%}
</div>

{%- if paginate.pages > 1 -%}
  {%- for i in (2..paginate.pages) -%}
    <div class="qb-page-stub" data-page="{{ i }}" data-url="{{ collection.url }}?page={{ i }}"></div>
  {%- endfor -%}
{%- endif -%}

{%- endpaginate -%}

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d0d0f;
  --bg2:#121215;
  --bg3:#1a1a1f;
  --gold:#d4a843;
  --gold2:#f0c05a;
  --border:rgba(255,255,255,0.06);
  --border2:rgba(212,168,67,0.25);
  --text:#e8e8ec;
  --muted:#888896;
  --red:#e05555;
  --green:#3dd68c;
  --radius:12px;
  --radius-sm:8px;
  --shadow:0 4px 24px rgba(0,0,0,0.6);
  --glow:0 0 20px rgba(212,168,67,0.15);
}
#qb-wholesale-root{
  background:var(--bg);
  min-height:100vh;
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  color:var(--text);
  padding-bottom:80px;
}
/* HERO */
#qb-hero{
  background:linear-gradient(180deg,#0f0c03 0%,#0d0d0f 100%);
  padding:28px 16px 24px;
  text-align:center;
  position:relative;overflow:hidden;
}
#qb-hero::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(212,168,67,0.12) 0%,transparent 65%);
  pointer-events:none;
}
#qb-hero-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(212,168,67,0.12);border:1px solid rgba(212,168,67,0.3);
  border-radius:20px;padding:4px 12px;
  font-size:11px;font-weight:700;color:var(--gold);
  text-transform:uppercase;letter-spacing:.6px;
  margin-bottom:12px;
}
#qb-hero h1{
  font-size:clamp(26px,7vw,42px);font-weight:900;
  letter-spacing:-1px;color:#fff;margin-bottom:6px;
  line-height:1.1;
}
#qb-hero h1 span{color:var(--gold)}
#qb-hero p{
  color:var(--muted);font-size:13px;
  max-width:340px;margin:0 auto 20px;line-height:1.5;
}
.qb-hero-stats{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:8px;margin-bottom:20px;
}
.qb-hero-stat{
  background:rgba(255,255,255,0.04);
  border:1px solid var(--border);border-radius:10px;padding:10px 8px;
}
.qb-hero-stat strong{display:block;font-size:20px;font-weight:800;color:var(--gold);line-height:1.1}
.qb-hero-stat span{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
.qb-hero-ctas{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.qb-hero-cta-primary{
  flex:1;max-width:200px;
  padding:13px 20px;
  background:var(--gold);color:#000;
  border:none;border-radius:10px;
  font-size:14px;font-weight:800;
  cursor:pointer;transition:all .2s;
  letter-spacing:.2px;
}
.qb-hero-cta-primary:hover{background:var(--gold2);transform:scale(1.02)}
.qb-hero-cta-secondary{
  flex:1;max-width:180px;
  padding:13px 20px;
  background:rgba(255,255,255,0.06);color:var(--text);
  border:1px solid var(--border);border-radius:10px;
  font-size:14px;font-weight:700;
  cursor:pointer;transition:all .2s;
}
.qb-hero-cta-secondary:hover{border-color:var(--gold);color:var(--gold)}
/* BRANDS STRIP */
#qb-brands-strip{
  background:var(--bg2);
  border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  padding:10px 0;overflow:hidden;position:relative;
}
#qb-brands-strip::before,#qb-brands-strip::after{
  content:'';position:absolute;top:0;bottom:0;width:40px;z-index:2;
}
#qb-brands-strip::before{left:0;background:linear-gradient(90deg,var(--bg2),transparent)}
#qb-brands-strip::after{right:0;background:linear-gradient(-90deg,var(--bg2),transparent)}
#qb-brands-inner{
  display:flex;gap:0;width:max-content;
  animation:qbMarquee 30s linear infinite;
}
#qb-brands-inner:hover{animation-play-state:paused}
.qb-brand-chip{
  display:inline-flex;align-items:center;
  padding:4px 16px;
  font-size:12px;font-weight:600;color:var(--muted);
  border-right:1px solid var(--border);
  white-space:nowrap;letter-spacing:.3px;
}
@keyframes qbMarquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
/* CATEGORY TILES */
#qb-cat-tiles{
  padding:16px;
  background:var(--bg);
}
#qb-cat-tiles-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:8px;
}
@media(min-width:480px){#qb-cat-tiles-grid{grid-template-columns:repeat(4,1fr)}}
@media(min-width:768px){#qb-cat-tiles-grid{grid-template-columns:repeat(6,1fr)}}
@media(min-width:1024px){#qb-cat-tiles-grid{grid-template-columns:repeat(8,1fr)}}
.qb-tile{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:5px;padding:12px 6px 10px;
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:12px;
  cursor:pointer;transition:all .2s;
  position:relative;overflow:hidden;
  min-height:76px;
  text-align:center;
}
.qb-tile::before{
  content:'';position:absolute;inset:0;opacity:0;
  transition:opacity .2s;
}
.qb-tile:active{transform:scale(.96)}
.qb-tile.t-whisky::before{background:linear-gradient(135deg,rgba(180,100,20,.15),transparent)}
.qb-tile.t-vodka::before{background:linear-gradient(135deg,rgba(100,160,255,.12),transparent)}
.qb-tile.t-beer::before{background:linear-gradient(135deg,rgba(212,168,67,.15),transparent)}
.qb-tile.t-gin::before{background:linear-gradient(135deg,rgba(80,200,140,.12),transparent)}
.qb-tile.t-rum::before{background:linear-gradient(135deg,rgba(200,80,80,.12),transparent)}
.qb-tile.t-tequila::before{background:linear-gradient(135deg,rgba(220,180,60,.15),transparent)}
.qb-tile.t-liqueur::before{background:linear-gradient(135deg,rgba(160,80,220,.12),transparent)}
.qb-tile.t-wine::before{background:linear-gradient(135deg,rgba(180,60,100,.15),transparent)}
.qb-tile.t-brandy::before{background:linear-gradient(135deg,rgba(160,100,40,.15),transparent)}
.qb-tile.t-japanese::before{background:linear-gradient(135deg,rgba(220,100,100,.12),transparent)}
.qb-tile.t-mixers::before{background:linear-gradient(135deg,rgba(60,180,220,.12),transparent)}
.qb-tile.t-accessories::before{background:linear-gradient(135deg,rgba(150,150,150,.1),transparent)}
.qb-tile:hover{transform:translateY(-3px);border-color:var(--border2);box-shadow:0 6px 20px rgba(0,0,0,.5)}
.qb-tile:hover::before{opacity:1}
.qb-tile-icon{font-size:24px;line-height:1}
.qb-tile-name{font-size:10px;font-weight:700;color:var(--text);line-height:1.2;letter-spacing:.2px}
.qb-tile-count{
  font-size:9px;font-weight:600;
  background:rgba(212,168,67,0.15);color:var(--gold);
  border-radius:8px;padding:1px 6px;
}
/* STICKY NAV BAR (slim, desktop) */
#qb-cat-bar{
  position:sticky;top:0;z-index:100;
  background:rgba(13,13,15,0.97);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  padding:0 16px;overflow-x:auto;scrollbar-width:none;
  white-space:nowrap;display:flex;align-items:center;gap:4px;height:46px;
}
#qb-cat-bar::-webkit-scrollbar{display:none}
.qb-cat-pill{
  display:inline-flex;align-items:center;gap:5px;
  padding:5px 12px;border-radius:20px;
  border:1px solid var(--border);background:transparent;
  color:var(--muted);font-size:12px;font-weight:500;
  cursor:pointer;transition:all .2s;white-space:nowrap;flex-shrink:0;
}
.qb-cat-pill:hover{border-color:var(--gold);color:var(--gold)}
.qb-cat-pill.active{background:var(--gold);border-color:var(--gold);color:#000;font-weight:700}
.qb-cat-pill .qb-pill-count{font-size:9px;background:rgba(0,0,0,0.2);border-radius:8px;padding:1px 5px}
.qb-cat-pill.active .qb-pill-count{background:rgba(0,0,0,0.25)}
/* MAIN */
#qb-main{padding:0 16px;max-width:1600px;margin:0 auto}
/* SECTIONS */
.qb-section{margin-top:48px;animation:qbFadeIn .4s ease}
.qb-section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;gap:12px}
.qb-section-title{font-size:20px;font-weight:800;display:flex;align-items:center;gap:10px}
.qb-section-title .qb-sec-icon{font-size:22px}
.qb-section-title .qb-sec-label{color:#fff}
.qb-section-title .qb-sec-count{
  font-size:12px;font-weight:500;color:var(--muted);
  background:var(--bg3);border:1px solid var(--border);
  border-radius:20px;padding:2px 10px;
}
/* SLIDER */
.qb-slider-wrap{position:relative}
.qb-slider{
  display:flex;gap:14px;overflow-x:auto;
  scroll-snap-type:x mandatory;scrollbar-width:none;padding-bottom:8px;
}
.qb-slider::-webkit-scrollbar{display:none}
.qb-slider>.qb-card{flex:0 0 200px;scroll-snap-align:start}
@media(min-width:640px){.qb-slider>.qb-card{flex:0 0 210px}}
@media(min-width:1024px){.qb-slider>.qb-card{flex:0 0 220px}}
.qb-arr{
  position:absolute;top:50%;transform:translateY(-60%);
  width:36px;height:36px;border-radius:50%;
  background:var(--bg3);border:1px solid var(--border);
  color:#fff;font-size:18px;display:flex;align-items:center;justify-content:center;
  cursor:pointer;z-index:5;transition:all .2s;box-shadow:var(--shadow);
}
.qb-arr:hover{background:var(--gold);color:#000;border-color:var(--gold)}
.qb-arr-l{left:-18px}
.qb-arr-r{right:-18px}
@media(max-width:640px){.qb-arr{display:none}}
/* GRID */
.qb-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
@media(min-width:640px){.qb-grid{grid-template-columns:repeat(3,1fr)}}
@media(min-width:900px){.qb-grid{grid-template-columns:repeat(4,1fr)}}
@media(min-width:1200px){.qb-grid{grid-template-columns:repeat(5,1fr)}}
/* CARD */
.qb-card{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:var(--radius);overflow:hidden;
  transition:transform .25s,box-shadow .25s,border-color .25s;
  position:relative;display:flex;flex-direction:column;
}
.qb-card:hover{transform:translateY(-4px);box-shadow:var(--glow),0 8px 32px rgba(0,0,0,.7);border-color:var(--border2)}
.qb-card-img-wrap{aspect-ratio:1/1;overflow:hidden;background:#0a0a0c;position:relative}
.qb-card-img-wrap img{width:100%;height:100%;object-fit:contain;padding:8px;transition:transform .4s ease}
.qb-card:hover .qb-card-img-wrap img{transform:scale(1.08)}
.qb-card-badges{position:absolute;top:8px;left:8px;display:flex;flex-direction:column;gap:4px;z-index:2}
.qb-badge{font-size:9px;font-weight:700;padding:3px 7px;border-radius:4px;text-transform:uppercase;letter-spacing:.4px;line-height:1.2}
.qb-badge-save{background:var(--red);color:#fff}
.qb-badge-hot{background:#ff6b35;color:#fff}
.qb-badge-dom{background:var(--green);color:#000}
.qb-badge-best{background:var(--gold);color:#000}
.qb-badge-new{background:#7c5cfc;color:#fff}
.qb-card-body{padding:12px;flex:1;display:flex;flex-direction:column}
.qb-card-vendor{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px}
.qb-card-title{
  font-size:13px;font-weight:600;color:var(--text);line-height:1.35;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;
  margin-bottom:8px;flex:1;
}
.qb-card-price-row{display:flex;align-items:baseline;gap:8px;flex-wrap:wrap;margin-bottom:10px}
.qb-card-price{font-size:18px;font-weight:800;color:var(--gold)}
.qb-card-cmp{font-size:12px;color:var(--muted);text-decoration:line-through}
.qb-card-footer{display:flex;gap:8px;align-items:center}
.qb-qty-wrap{display:flex;align-items:center;border:1px solid var(--border);border-radius:6px;overflow:hidden;background:var(--bg3)}
.qb-qty-btn{width:28px;height:28px;background:none;border:none;color:var(--text);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s}
.qb-qty-btn:hover{background:var(--border)}
.qb-qty-val{width:30px;text-align:center;font-size:13px;font-weight:600;color:var(--text);background:none;border:none;outline:none}
.qb-atc{
  flex:1;height:28px;background:var(--gold);color:#000;
  border:none;border-radius:6px;font-size:12px;font-weight:700;
  cursor:pointer;transition:all .2s;white-space:nowrap;
}
.qb-atc:hover{background:var(--gold2);transform:scale(1.03)}
.qb-atc:active{transform:scale(.97)}
.qb-atc.loading{opacity:.6;pointer-events:none}
.qb-atc.done{background:var(--green);color:#000}
/* SKELETON */
.qb-skel{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.qb-skel-img{aspect-ratio:1/1;background:var(--bg3);position:relative;overflow:hidden}
.qb-skel-body{padding:12px}
.qb-skel-line{height:10px;border-radius:4px;background:var(--bg3);margin-bottom:8px;position:relative;overflow:hidden}
.qb-skel-line.w60{width:60%}
.qb-skel-line.w80{width:80%}
.qb-skel-line.h16{height:16px}
.qb-skel-img::after,.qb-skel-line::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,0.04) 50%,transparent 100%);
  animation:qbShimmer 1.5s infinite;
}
@keyframes qbShimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
@keyframes qbFadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
/* FEATURED */
#qb-sec-featured .qb-feat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
@media(min-width:640px){#qb-sec-featured .qb-feat-grid{grid-template-columns:repeat(3,1fr)}}
@media(min-width:900px){#qb-sec-featured .qb-feat-grid{grid-template-columns:repeat(4,1fr)}}
@media(min-width:1200px){#qb-sec-featured .qb-feat-grid{grid-template-columns:repeat(6,1fr)}}
.qb-feat-label{
  display:inline-flex;align-items:center;gap:6px;
  background:linear-gradient(135deg,rgba(212,168,67,0.15),rgba(212,168,67,0.05));
  border:1px solid var(--border2);border-radius:var(--radius-sm);
  padding:4px 12px;font-size:11px;font-weight:700;
  color:var(--gold);text-transform:uppercase;letter-spacing:.6px;margin-bottom:16px;
}
/* PARENT GROUP HEADER */
.qb-group{margin-top:56px}
.qb-group-head{
  display:flex;align-items:center;gap:12px;
  padding:16px 20px;
  background:linear-gradient(135deg,rgba(212,168,67,0.08),rgba(212,168,67,0.03));
  border:1px solid var(--border2);border-radius:var(--radius);
  margin-bottom:8px;
}
.qb-group-icon{font-size:28px}
.qb-group-name{font-size:22px;font-weight:900;color:#fff;letter-spacing:-0.3px}
.qb-group-count{
  margin-left:auto;font-size:12px;color:var(--muted);
  background:var(--bg3);border:1px solid var(--border);
  border-radius:20px;padding:3px 12px;
}
.qb-subcat-label{
  font-size:13px;font-weight:700;color:var(--gold);
  text-transform:uppercase;letter-spacing:.5px;
  margin:20px 0 10px;
  display:flex;align-items:center;gap:8px;
}
.qb-subcat-label::after{
  content:'';flex:1;height:1px;background:var(--border);
}
/* QUICK ORDER SHEET */
#qb-order-sheet{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:var(--radius);overflow:hidden;margin-top:40px;
  scroll-margin-top:60px;
}
.qb-sheet-head{
  background:linear-gradient(135deg,var(--bg3),rgba(212,168,67,0.06));
  border-bottom:1px solid var(--border2);
  padding:16px;
}
.qb-sheet-head-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.qb-sheet-head h2{
  font-size:15px;font-weight:800;color:#fff;
  display:flex;align-items:center;gap:8px;
}
.qb-sheet-head h2 small{
  font-size:10px;font-weight:600;color:var(--muted);
  background:var(--bg);border-radius:6px;padding:2px 7px;border:1px solid var(--border);
}
.qb-sheet-search-wrap{position:relative}
.qb-sheet-search-wrap svg{
  position:absolute;left:10px;top:50%;transform:translateY(-50%);
  width:14px;height:14px;opacity:.4;pointer-events:none;
}
.qb-sheet-search{
  width:100%;background:var(--bg);
  border:1px solid var(--border);border-radius:8px;
  padding:9px 12px 9px 32px;
  color:var(--text);font-size:13px;outline:none;
  transition:border-color .2s;
}
.qb-sheet-search:focus{border-color:var(--gold)}
.qb-sheet-search::placeholder{color:var(--muted)}
/* mobile card-style rows */
.qb-sheet-cards{padding:0;max-height:60vh;overflow-y:auto}
.qb-sheet-cards::-webkit-scrollbar{width:3px}
.qb-sheet-cards::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.qb-sheet-row{
  display:flex;align-items:center;gap:10px;
  padding:10px 14px;
  border-bottom:1px solid var(--border);
  transition:background .15s;
}
.qb-sheet-row:hover{background:rgba(255,255,255,0.02)}
.qb-sheet-img{
  width:44px;height:44px;border-radius:8px;
  object-fit:contain;background:#0a0a0c;
  flex-shrink:0;border:1px solid var(--border);
}
.qb-sheet-info{flex:1;min-width:0}
.qb-sheet-name{
  font-size:12px;font-weight:600;color:var(--text);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.qb-sheet-price-row{display:flex;align-items:center;gap:6px;margin-top:2px}
.qb-sheet-price{font-size:13px;font-weight:800;color:var(--gold)}
.qb-sheet-vendor{font-size:10px;color:var(--muted)}
.qb-sheet-controls{display:flex;align-items:center;gap:6px;flex-shrink:0}
.qb-sheet-stepper{
  display:flex;align-items:center;
  background:var(--bg3);border:1px solid var(--border);
  border-radius:8px;overflow:hidden;
}
.qb-sheet-step-btn{
  width:30px;height:32px;
  background:none;border:none;color:var(--text);
  font-size:16px;font-weight:700;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:background .15s;
}
.qb-sheet-step-btn:hover{background:rgba(255,255,255,0.08)}
.qb-sheet-qty{
  width:36px;height:32px;text-align:center;
  background:none;border:none;
  color:var(--text);font-size:13px;font-weight:700;
  outline:none;
}
/* hide number input arrows */
.qb-sheet-qty::-webkit-outer-spin-button,.qb-sheet-qty::-webkit-inner-spin-button{-webkit-appearance:none}
.qb-sheet-qty{-moz-appearance:textfield}
.qb-sheet-row-atc{flex:none!important;padding:0 14px!important;height:32px!important;font-size:12px!important}
.qb-sheet-footer{
  background:linear-gradient(135deg,var(--bg3),rgba(212,168,67,0.06));
  border-top:1px solid var(--border2);
  padding:14px 16px;
  display:flex;align-items:center;justify-content:space-between;gap:12px;
}
.qb-sheet-grand{
  font-size:13px;color:var(--muted);
  display:flex;flex-direction:column;
}
.qb-sheet-grand strong{font-size:20px;font-weight:900;color:var(--gold)}
.qb-sheet-add-all{
  padding:12px 20px;background:var(--gold);color:#000;
  border:none;border-radius:10px;font-size:14px;font-weight:800;
  cursor:pointer;transition:all .2s;white-space:nowrap;
}
.qb-sheet-add-all:hover{background:var(--gold2);transform:scale(1.03)}
.qb-sheet-add-all:active{transform:scale(.97)}
/* BOTTOM SECTIONS */
#qb-bottom-sections{margin-top:8px}
.qb-info-section{padding:40px 16px;border-top:1px solid var(--border)}
.qb-info-head{text-align:center;margin-bottom:28px}
.qb-info-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(212,168,67,0.1);border:1px solid var(--border2);
  border-radius:20px;padding:4px 14px;
  font-size:11px;font-weight:700;color:var(--gold);
  text-transform:uppercase;letter-spacing:.6px;margin-bottom:12px;
}
.qb-info-title{font-size:clamp(20px,5vw,30px);font-weight:900;color:#fff;line-height:1.2}
.qb-info-title span{color:var(--gold)}
/* WHY GRID */
.qb-why-grid{display:grid;grid-template-columns:repeat(1,1fr);gap:12px}
@media(min-width:540px){.qb-why-grid{grid-template-columns:repeat(2,1fr)}}
@media(min-width:900px){.qb-why-grid{grid-template-columns:repeat(3,1fr)}}
.qb-why-card{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:var(--radius);padding:20px;
  transition:border-color .2s,transform .2s;
}
.qb-why-card:hover{border-color:var(--border2);transform:translateY(-2px)}
.qb-why-icon{font-size:28px;margin-bottom:10px}
.qb-why-title{font-size:15px;font-weight:800;color:#fff;margin-bottom:6px}
.qb-why-desc{font-size:13px;color:var(--muted);line-height:1.55}
/* VENDOR REGISTER */
.qb-register-section{
  margin:0 16px;
  background:linear-gradient(135deg,#1a1408,#0d0d0f);
  border:1px solid var(--border2);border-radius:16px;
  padding:36px 20px;text-align:center;position:relative;overflow:hidden;
}
.qb-register-glow{
  position:absolute;top:-60px;left:50%;transform:translateX(-50%);
  width:300px;height:200px;
  background:radial-gradient(ellipse,rgba(212,168,67,0.15),transparent 70%);
  pointer-events:none;
}
.qb-register-title{font-size:clamp(22px,5vw,32px);font-weight:900;color:#fff;line-height:1.2;margin-bottom:12px}
.qb-register-desc{font-size:14px;color:var(--muted);line-height:1.6;max-width:520px;margin:0 auto 20px}
.qb-register-perks{
  display:grid;grid-template-columns:repeat(2,1fr);gap:8px;
  max-width:420px;margin:0 auto 24px;text-align:left;
}
.qb-perk{font-size:13px;color:var(--text);font-weight:500}
.qb-register-btn{
  display:inline-block;
  background:var(--gold);color:#000;
  padding:14px 28px;border-radius:10px;
  font-size:14px;font-weight:800;
  text-decoration:none;transition:all .2s;
  word-break:break-all;
}
.qb-register-btn:hover{background:var(--gold2);transform:scale(1.02)}
/* HOW IT WORKS */
.qb-steps{display:flex;flex-direction:column;gap:0;max-width:560px;margin:0 auto}
.qb-step{display:flex;align-items:flex-start;gap:14px;padding:0 8px}
.qb-step-num{
  width:36px;height:36px;border-radius:50%;flex-shrink:0;
  background:var(--gold);color:#000;
  font-size:16px;font-weight:900;
  display:flex;align-items:center;justify-content:center;
}
.qb-step-body{padding-bottom:4px}
.qb-step-title{font-size:15px;font-weight:800;color:#fff;margin-bottom:4px}
.qb-step-desc{font-size:13px;color:var(--muted);line-height:1.55}
.qb-step-line{width:2px;height:24px;background:var(--border);margin-left:17px}
/* FAQ */
.qb-faq-list{max-width:680px;margin:0 auto;display:flex;flex-direction:column;gap:8px}
.qb-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.qb-faq-q{
  width:100%;text-align:left;
