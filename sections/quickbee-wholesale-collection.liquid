<script>
(function(){
'use strict';

/* ── Read all product data from DOM ── */
var nodes = document.querySelectorAll('#qbwData .qbw-pdata');
var allProducts = [];
nodes.forEach(function(n){
  var cmp = parseInt(n.dataset.compare)||0;
  var prc = parseInt(n.dataset.price)||0;
  var hasSave = cmp > prc && cmp > 0;
  var savePct = hasSave ? Math.round((cmp-prc)*100/cmp) : 0;
  var saveAmt = hasSave ? Math.round((cmp-prc)/100) : 0;
  allProducts.push({
    url: n.dataset.url,
    title: n.dataset.title,
    type: n.dataset.type||'',
    tags: n.dataset.tags||'',
    img: n.dataset.img||'',
    price: prc,
    compare: cmp,
    avail: n.dataset.avail==='true',
    vendor: n.dataset.vendor||'',
    best: n.dataset.bestseller==='1',
    demand: n.dataset.demand==='1',
    isNew: n.dataset.new==='1',
    hasSave: hasSave,
    savePct: savePct,
    saveAmt: saveAmt
  });
});

/* ── Build card HTML ── */
function card(p, big){
  var save='', chip='', demand='', sold='';
  if(p.hasSave) save='<div class="qbw-save-badge">SAVE '+p.savePct+'%<small>Rs '+p.saveAmt+' OFF</small></div>';
  if(p.type) chip='<span class="qbw-type-chip">'+escHtml(p.type)+'</span>';
  if(p.best) demand='<span class="qbw-demand-tag qbw-demand-tag--best">⭐ Best Seller</span>';
  else if(p.demand) demand='<span class="qbw-demand-tag qbw-demand-tag--hot">⚡ High Demand</span>';
  else if(p.isNew) demand='<span class="qbw-demand-tag qbw-demand-tag--new">🆕 New</span>';
  if(!p.avail) sold='<div class="qbw-sold-mask"><span class="qbw-sold-lbl">Out of Stock</span></div>';

  var imgHtml = p.img
    ? '<img src="'+p.img+'" alt="'+escHtml(p.title)+'" loading="lazy" width="400" height="400">'
    : '<div class="qbw-card-no-img">📦</div>';

  var priceHtml;
  {%- if customer and customer.tags contains 'wholesale-approved' -%}
  var priceRows='<div class="qbw-price-row"><span class="qbw-price-now">Rs '+Math.round(p.price/100)+'</span>'+(p.hasSave?'<span class="qbw-price-was">Rs '+Math.round(p.compare/100)+'</span>':'')+'</div>'+(p.hasSave?'<div class="qbw-price-save">↓ Save Rs '+p.saveAmt+' ('+p.savePct+'%)</div>':'');
  priceHtml='<div class="qbw-price-box">'+priceRows+'</div>';
  {%- else -%}
  if(p.hasSave){
    priceHtml='<div class="qbw-price-box"><div class="qbw-price-retail">Retail: Rs '+Math.round(p.compare/100)+'</div><div class="qbw-price-save">↓ Save Rs '+p.saveAmt+' ('+p.savePct+'%)</div><div class="qbw-price-unlock">Register to unlock price</div></div>';
  } else {
    priceHtml='<div class="qbw-price-box"><div class="qbw-price-locked">Wholesale Pricing Available</div></div>';
  }
  {%- endif -%}

  var btns = p.avail
    ? '<a href="'+p.url+'" class="qbw-cbtn-p">View Product</a><a href="/products/vendor-registration" class="qbw-cbtn-g">Get Price</a>'
    : '<span class="qbw-cbtn-g" style="flex:1;text-align:center">Out of Stock</span>';

  var cls = big ? 'qbw-hero-card' : 'qbw-card';
  var typeLabel = p.type ? '<div class="qbw-card-type-lbl">'+escHtml(p.type)+'</div>' : '';

  return '<a href="'+p.url+'" class="'+cls+'">'
    +'<div class="qbw-card-img">'+imgHtml+save+chip+demand+sold+'</div>'
    +'<div class="qbw-card-body">'+typeLabel
    +'<div class="qbw-card-name">'+escHtml(p.title)+'</div>'
    +priceHtml
    +'<div class="qbw-card-btns">'+btns+'</div>'
    +'</div></a>';
}

function escHtml(s){
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ── Slider HTML ── */
function makeSlider(id, products, big){
  var cards = products.map(function(p){ return card(p, big); }).join('');
  return '<div class="qbw-slide-wrap" id="'+id+'-wrap">'
    +'<button class="qbw-arr qbw-arr-l" onclick="qbwScroll(this,-1)" aria-label="Prev">‹</button>'
    +'<div class="qbw-slide-outer"><div class="qbw-slide-track" id="'+id+'">'+cards+'</div></div>'
    +'<button class="qbw-arr qbw-arr-r" onclick="qbwScroll(this,1)" aria-label="Next">›</button>'
    +'</div>';
}

/* ── Grid HTML ── */
function makeGrid(products, cols){
  var cls = cols===5 ? 'qbw-grid-5' : 'qbw-grid-4';
  return '<div class="qbw-grid-wrap"><div class="'+cls+'">'+products.map(function(p){return card(p,false);}).join('')+'</div></div>';
}

/* ── Section HTML ── */
function makeSection(id, tag, title, subtitle, products, layout, big){
  if(!products.length) return '';
  var inner;
  if(layout==='slider') inner = makeSlider(id, products, big||false);
  else if(layout==='grid5') inner = makeGrid(products, 5);
  else inner = makeGrid(products, 4);

  return '<div class="qbw-sec" id="qbw-sec-'+id+'">'
    +'<div class="qbw-sec-head"><div>'
    +'<div class="qbw-sec-tag">'+tag+'</div>'
    +'<div class="qbw-sec-title">'+title+'</div>'
    +(subtitle?'<div class="qbw-sec-count">'+subtitle+'</div>':'')
    +'</div></div>'
    +inner+'</div>';
}

/* ── B2B Banner HTML ── */
function b2bBanner(){
  return '<div class="qbw-banner-b2b"><div class="qbw-banner-b2b-inner">'
    +'<div class="qbw-banner-b2b-left"><div class="qbw-banner-b2b-tag">Licensed Businesses Only</div>'
    +'<div class="qbw-banner-b2b-title">Unlock Real Wholesale Pricing</div>'
    +'<div class="qbw-banner-b2b-sub">Register your restaurant, bar, club or hotel to access full pricing and up to 40% savings vs retail.</div></div>'
    +'<a href="/products/vendor-registration" class="qbw-btn-gold" style="font-size:13px;white-space:nowrap">Register to Access Pricing →</a>'
    +'</div></div>';
}

/* ── Stats Banner ── */
function statsBanner(){
  return '<div class="qbw-banner-stats"><div class="qbw-banner-stats-inner">'
    +'<div class="qbw-bstat"><div class="qbw-bstat-icon">📊</div><div class="qbw-bstat-val">40%</div><div class="qbw-bstat-lbl">Average savings<br>vs retail price</div></div>'
    +'<div class="qbw-bstat"><div class="qbw-bstat-icon">📦</div><div class="qbw-bstat-val">'+allProducts.length+'+</div><div class="qbw-bstat-lbl">Wholesale SKUs<br>loaded now</div></div>'
    +'<div class="qbw-bstat"><div class="qbw-bstat-icon">⚡</div><div class="qbw-bstat-val">24hr</div><div class="qbw-bstat-lbl">Order dispatch<br>guaranteed</div></div>'
    +'<div class="qbw-bstat"><div class="qbw-bstat-icon">🏨</div><div class="qbw-bstat-val">200+</div><div class="qbw-bstat-lbl">Licensed businesses<br>trust QuickBee</div></div>'
    +'</div></div>';
}

/* ── Dual promo ── */
function dualPromo(){
  return '<div class="qbw-dual">'
    +'<div class="qbw-promo qbw-promo--liq"><div class="qbw-promo-emoji">🥃</div><div class="qbw-promo-tag">Wholesale Supply</div><div class="qbw-promo-title">Premium Spirits &amp; Liquor</div><div class="qbw-promo-sub">Whiskey, Rum, Vodka, Gin, Brandy &amp; more</div></div>'
    +'<div class="qbw-promo qbw-promo--hook"><div class="qbw-promo-emoji">💨</div><div class="qbw-promo-tag">Full Range</div><div class="qbw-promo-title">Hookah Flavors &amp; Equipment</div><div class="qbw-promo-sub">200+ flavors, premium setups for your lounge</div></div>'
    +'</div>';
}

/* ── Categorise ── */
function matchCat(p, keywords){
  var t = p.type+' '+p.tags;
  return keywords.some(function(k){ return t.indexOf(k)>-1; });
}

var cats = [
  { id:'featured',   icon:'⭐', name:'Featured',         tag:'Handpicked',      title:'⭐ Featured — Best of Everything',      sub:'Top picks across all categories',             kw:null,   layout:'slider', big:true  },
  { id:'liquor',     icon:'🥃', name:'Liquor',           tag:'Premium Wholesale',title:'🥃 Liquor &amp; Spirits',               sub:'Whiskey · Rum · Vodka · Gin · Brandy · Wine', kw:['liquor','spirits','whiskey','rum','vodka','gin','brandy','scotch','bourbon','tequila'], layout:'slider' },
  { id:'beer',       icon:'🍺', name:'Beer &amp; Wine',  tag:'Wholesale Supply', title:'🍺 Beer &amp; Wine',                    sub:'Domestic &amp; imported brands',              kw:['beer','wine','cider','lager','ale'],        layout:'slider' },
  { id:'cigarette',  icon:'🚬', name:'Cigarettes',       tag:'Bulk Supply',      title:'🚬 Cigarettes &amp; Tobacco',           sub:'All major brands in bulk',                    kw:['cigarette','tobacco','cigar','smoke'],      layout:'slider' },
  { id:'hookahflav', icon:'💨', name:'Hookah Flavors',   tag:'200+ Flavors',     title:'💨 Hookah Flavors',                     sub:'Al Fakher · Starbuzz · Fumari &amp; more',    kw:['hookah-flavor','hookah flavor','shisha','molasses','flavour'], layout:'slider' },
  { id:'hookahequip',icon:'🪄', name:'Hookah Equipment', tag:'Lounge Setup',     title:'🪄 Hookah Equipment',                   sub:'Setups · Bowls · Pipes · Parts',              kw:['hookah-equipment','hookah equipment','hookah','kalyan'], layout:'slider' },
  { id:'rolling',    icon:'📜', name:'Rolling Papers',   tag:'Bulk Wholesale',   title:'📜 Rolling Papers',                     sub:'RAW · OCB · Rizla &amp; more',                kw:['rolling','paper','roll'],                  layout:'slider' },
  { id:'acc',        icon:'🛍', name:'Accessories',      tag:'Smoking Supplies', title:'🛍 Accessories',                        sub:'Lighters · Grinders · Filters &amp; more',    kw:['accessory','accessories','lighter','grinder','filter','tip'], layout:'grid4' },
];

/* map products into cats */
var catProducts = {};
var usedIds = {};

// featured = best-sellers + high-demand first, then fill up to 24
var feat = allProducts.filter(function(p){ return p.best||p.demand; }).slice(0,24);
if(feat.length < 12) feat = allProducts.slice(0,24);
catProducts['featured'] = feat;

cats.slice(1).forEach(function(c){
  catProducts[c.id] = allProducts.filter(function(p){ return matchCat(p, c.kw); });
});

/* ── Detect unique brands from vendor field ── */
var brandSet = {};
allProducts.forEach(function(p){ if(p.vendor) brandSet[p.vendor]=1; });
var brandNames = Object.keys(brandSet).slice(0,20);

/* ── Render ── */
var sections = document.getElementById('qbwSections');
var html = '';

html += makeSection('featured', cats[0].tag, cats[0].title, cats[0].sub+' ('+feat.length+')', feat, 'slider', true);
html += statsBanner();

// liquor + beer
html += makeSection('liquor', cats[1].tag, cats[1].title, cats[1].sub+(catProducts['liquor'].length?' · '+catProducts['liquor'].length+' products':''), catProducts['liquor'], 'slider', false);
html += makeSection('beer', cats[2].tag, cats[2].title, cats[2].sub+(catProducts['beer'].length?' · '+catProducts['beer'].length+' products':''), catProducts['beer'], 'slider', false);

html += b2bBanner();

html += makeSection('cigarette', cats[3].tag, cats[3].title, cats[3].sub+(catProducts['cigarette'].length?' · '+catProducts['cigarette'].length+' products':''), catProducts['cigarette'], 'slider', false);
html += dualPromo();
html += makeSection('hookahflav', cats[4].tag, cats[4].title, cats[4].sub+(catProducts['hookahflav'].length?' · '+catProducts['hookahflav'].length+' products':''), catProducts['hookahflav'], 'slider', false);
html += makeSection('hookahequip', cats[5].tag, cats[5].title, cats[5].sub+(catProducts['hookahequip'].length?' · '+catProducts['hookahequip'].length+' products':''), catProducts['hookahequip'], 'slider', false);
html += makeSection('rolling', cats[6].tag, cats[6].title, cats[6].sub+(catProducts['rolling'].length?' · '+catProducts['rolling'].length+' products':''), catProducts['rolling'], 'slider', false);
html += makeSection('acc', cats[7].tag, cats[7].title, cats[7].sub+(catProducts['acc'].length?' · '+catProducts['acc'].length+' products':''), catProducts['acc'], 'grid4', false);

// Catch-all: products not matched by any category
var matchedUrls = {};
cats.slice(1).forEach(function(c){ catProducts[c.id].forEach(function(p){ matchedUrls[p.url]=1; }); });
var other = allProducts.filter(function(p){ return !matchedUrls[p.url]; });
if(other.length){
  html += makeSection('other','More Products','🛒 More Products','Everything else in our catalogue · '+other.length+' products', other, 'grid4', false);
}

sections.innerHTML = html;

/* ── Build category nav + sticky ── */
var navHtml = '<button class="qbw-catnav-btn active" data-target="qbw-sec-featured" onclick="qbwNavClick(this)"><span>⭐</span><span>Featured</span></button>';
var stickyHtml = '<button class="qbw-sticky-btn active" data-target="qbw-sec-featured" onclick="qbwNavClick(this)">All / Featured</button>';

cats.slice(1).forEach(function(c){
  if(catProducts[c.id].length){
    navHtml += '<button class="qbw-catnav-btn" data-target="qbw-sec-'+c.id+'" onclick="qbwNavClick(this)"><span>'+c.icon+'</span><span>'+c.name+'</span></button>';
    stickyHtml += '<button class="qbw-sticky-btn" data-target="qbw-sec-'+c.id+'" onclick="qbwNavClick(this)">'+c.icon+' '+c.name+'</button>';
  }
});
if(other.length){
  navHtml += '<button class="qbw-catnav-btn" data-target="qbw-sec-other" onclick="qbwNavClick(this)"><span>🛒</span><span>More</span></button>';
  stickyHtml += '<button class="qbw-sticky-btn" data-target="qbw-sec-other" onclick="qbwNavClick(this)">🛒 More</button>';
}

document.getElementById('qbwCatNav').innerHTML = navHtml;
document.getElementById('qbwSticky').innerHTML = stickyHtml;

/* ── Build brands ── */
var brandHtml = (brandNames.length ? brandNames : ['Absolut','Jack Daniel\'s','Johnnie Walker','Bacardi','Marlboro','Al Fakher','Starbuzz','RAW Papers','Heineken','Budweiser','Corona'])
  .map(function(b){ return '<span class="qbw-brand">'+escHtml(b)+'</span>'; }).join('');
brandHtml += '<span class="qbw-brand">+ Many More</span>';
document.getElementById('qbwBrands').innerHTML = brandHtml;

/* ── Nav click ── */
window.qbwNavClick = function(btn){
  document.querySelectorAll('.qbw-catnav-btn,.qbw-sticky-btn').forEach(function(b){
    if(b.getAttribute('data-target')===btn.getAttribute('data-target')) b.classList.add('active');
    else b.classList.remove('active');
  });
  var target = document.getElementById(btn.getAttribute('data-target'));
  if(target){ var y = target.getBoundingClientRect().top + window.scrollY - 56; window.scrollTo({ top: y, behavior: 'smooth' }); }
};

/* ── Slider scroll ── */
window.qbwScroll = function(btn, dir){
  var track = btn.closest('.qbw-slide-wrap').querySelector('.qbw-slide-track');
  if(!track) return;
  var first = track.querySelector('.qbw-card,.qbw-hero-card');
  var w = first ? first.offsetWidth + 12 : 212;
  track.scrollBy({ left: dir * w * 3, behavior: 'smooth' });
};

})();
</script>

{%- endpaginate -%}

