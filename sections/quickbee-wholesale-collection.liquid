(function(){
  var tilesGrid=document.getElementById('qb-cat-tiles-grid');
  var bar=document.getElementById('qb-cat-bar');
  CATEGORY_TREE.forEach(function(grp){
    var total=0;
    grp.subcats.forEach(function(sc){total+=(TAG_MAP[sc.tag]||[]).length;});
    if(!total)return;
    // Tile
    if(tilesGrid){
      var tile=document.createElement('div');
      tile.className='qb-tile t-'+grp.id;
      tile.dataset.cat=grp.id;
      tile.innerHTML='<span class="qb-tile-icon">'+grp.icon+'</span>'
        +'<span class="qb-tile-name">'+esc(grp.label)+'</span>'
        +'<span class="qb-tile-count">'+total+'</span>';
      tile.addEventListener('click',function(){
        var el=document.getElementById('grp-'+grp.id);
        if(el){var top=el.getBoundingClientRect().top+window.pageYOffset-56;window.scrollTo({top:top,behavior:'smooth'});}
      });
      tilesGrid.appendChild(tile);
    }
    // Pill
    var btn=document.createElement('button');
    btn.className='qb-cat-pill';
    btn.dataset.cat=grp.id;
    btn.innerHTML=grp.icon+' '+esc(grp.label)+' <span class="qb-pill-count">'+total+'</span>';
    bar.appendChild(btn);
  });
})();

/* --- 11. SECTIONS RENDER (with skeleton) --- */
(function(){
  var container=document.getElementById('qb-sections');
  // Skeleton
  var skelDiv=document.createElement('div');
  skelDiv.id='qb-skel-sec';
  var sh='';
  for(var s=0;s<3;s++){
    sh+='<div class="qb-group"><div class="qb-group-head" style="opacity:.3"><div style="width:160px;height:22px;background:var(--bg3);border-radius:6px"></div></div>'
      +'<div class="qb-grid">';
    for(var k=0;k<10;k++)sh+=skelCard();
    sh+='</div></div>';
  }
  skelDiv.innerHTML=sh;
  container.appendChild(skelDiv);

  requestAnimationFrame(function(){
    setTimeout(function(){
      var html='';
      CATEGORY_TREE.forEach(function(grp){html+=buildGroupSection(grp);});
      var realDiv=document.createElement('div');
      realDiv.id='qb-real-sec';
      realDiv.innerHTML=html;
      var old=document.getElementById('qb-skel-sec');
      if(old)container.replaceChild(realDiv,old);
      realDiv.querySelectorAll('.qb-group[id^="grp-"]').forEach(function(el){
        spyObs.observe(el);
      });
    },80);
  });
})();

/* --- 12. QUICK ORDER SHEET (mobile card layout, default qty 6) --- */
function buildSheetCards(products){
  return products.map(function(p){
    var pct=savePct(p);
    var cmpHtml=(p.cmp&&p.cmp>p.price)?'<span style="font-size:10px;color:var(--muted);text-decoration:line-through;margin-left:4px">'+fmt(p.cmp)+'</span>':'';
    var discHtml=pct>=5?'<span style="font-size:9px;font-weight:700;background:var(--red);color:#fff;border-radius:4px;padding:1px 5px;margin-left:4px">-'+pct+'%</span>':'';
    return '<div class="qb-sheet-row" data-id="'+esc(p.id)+'">'
      +'<img class="qb-sheet-img" src="'+esc(p.img)+'" alt="" loading="lazy">'
      +'<div class="qb-sheet-info">'
      +'<div class="qb-sheet-name">'+esc(p.title)+'</div>'
      +'<div class="qb-sheet-price-row">'
      +'<span class="qb-sheet-price">'+fmt(p.price)+'</span>'+cmpHtml+discHtml
      +'</div>'
      +'</div>'
      +'<div class="qb-sheet-controls">'
      +'<div class="qb-sheet-stepper">'
      +'<button class="qb-sheet-step-btn" data-dir="-1">−</button>'
      +'<input class="qb-sheet-qty" type="number" value="0" min="0" max="999" data-price="'+p.price+'" data-variant="'+esc(p.variant)+'" data-title="'+esc(p.title)+'">'
      +'<button class="qb-sheet-step-btn" data-dir="1">+</button>'
      +'</div>'
      +'<button class="qb-sheet-row-atc qb-atc" style="height:32px;padding:0 12px;font-size:11px;flex:none;border-radius:7px" data-variant="'+esc(p.variant)+'" data-title="'+esc(p.title)+'" data-row="1">Add</button>'
      +'</div>'
      +'</div>';
  }).join('');
}

var sheetBody=document.getElementById('qb-sheet-body');
var sheetCountEl=document.getElementById('qb-sheet-count');

function renderSheet(products){
  sheetBody.innerHTML=buildSheetCards(products);
  if(sheetCountEl)sheetCountEl.textContent=products.length+' items';
  calcSheetTotal();
}
renderSheet(ALL.slice(0,60));

function calcSheetTotal(){
  var total=0;
  sheetBody.querySelectorAll('.qb-sheet-qty').forEach(function(inp){
    var qty=parseInt(inp.value)||0;
    var price=parseInt(inp.dataset.price)||0;
    if(qty>0) total+=qty*price;
  });
  document.getElementById('qb-sheet-total').textContent=fmt(total);
}

// Stepper buttons + per-row Add button inside sheet
sheetBody.addEventListener('click',function(e){
  // Stepper
  var stepBtn=e.target.closest('.qb-sheet-step-btn');
  if(stepBtn){
    var inp=stepBtn.closest('.qb-sheet-stepper').querySelector('.qb-sheet-qty');
    if(inp){inp.value=Math.max(0,(parseInt(inp.value)||0)+parseInt(stepBtn.dataset.dir));calcSheetTotal();}
    return;
  }
  // Per-row Add to Cart
  var rowAtc=e.target.closest('.qb-sheet-row-atc');
  if(rowAtc){
    var row=rowAtc.closest('.qb-sheet-row');
    var qtyInp=row?row.querySelector('.qb-sheet-qty'):null;
    var qty=qtyInp?Math.max(1,parseInt(qtyInp.value)||1):1;
    addToCart(rowAtc.dataset.variant,qty,rowAtc,rowAtc.dataset.title||'Product');
    return;
  }
});
sheetBody.addEventListener('input',function(e){if(e.target.classList.contains('qb-sheet-qty'))calcSheetTotal();});

document.getElementById('qb-sheet-search').addEventListener('input',function(e){
  var q=e.target.value.toLowerCase().trim();
  var filtered=q
    ?ALL.filter(function(p){return p.title.toLowerCase().indexOf(q)>-1||p.vendor.toLowerCase().indexOf(q)>-1;}).slice(0,120)
    :ALL.slice(0,60);
  renderSheet(filtered);
});

document.getElementById('qb-sheet-add-all').addEventListener('click',function(){
  var items=[];
  sheetBody.querySelectorAll('.qb-sheet-qty').forEach(function(inp){
    var qty=parseInt(inp.value)||0;
    if(qty>0)items.push({id:parseInt(inp.dataset.variant),quantity:qty});
  });
  if(!items.length){showToast('Set quantities first','error');return;}
  addMultiple(items,'Order added to cart ✓');
});

/* --- 13. CATEGORY NAV — scroll to group section --- */
function showFilter(catId){
  if(catId==='all'){
    window.scrollTo({top:0,behavior:'smooth'});
    return;
  }
  // scroll to the group section
  var el=document.getElementById('grp-'+catId);
  if(el){
    var offset=60; // sticky bar height
    var top=el.getBoundingClientRect().top+window.pageYOffset-offset;
    window.scrollTo({top:top,behavior:'smooth'});
  }
}

document.getElementById('qb-cat-bar').addEventListener('click',function(e){
  var pill=e.target.closest('.qb-cat-pill');
  if(!pill)return;
  document.querySelectorAll('.qb-cat-pill').forEach(function(p){p.classList.remove('active');});
  pill.classList.add('active');
  showFilter(pill.dataset.cat);
});

/* --- 14. SLIDER ARROWS --- */
document.addEventListener('click',function(e){
  var arr=e.target.closest('.qb-arr');
  if(!arr)return;
  var slider=document.getElementById(arr.dataset.target);
  if(!slider)return;
  slider.scrollBy({left:(arr.classList.contains('qb-arr-l')?-1:1)*680,behavior:'smooth'});
});

/* --- 15. QTY STEPPER --- */
document.addEventListener('click',function(e){
  var btn=e.target.closest('.qb-qty-btn');
  if(!btn)return;
  var inp=btn.closest('.qb-qty-wrap').querySelector('.qb-qty-val');
  if(inp)inp.value=Math.max(1,(parseInt(inp.value)||1)+parseInt(btn.dataset.dir));
});

/* --- 16. CART SYSTEM --- */
function showToast(msg,type){
  var t=document.getElementById('qb-toast');
  t.textContent=msg;t.className='show '+(type||'');
  clearTimeout(t._timer);t._timer=setTimeout(function(){t.className='';},3000);
}

function addToCart(variantId,qty,btn,title){
  if(btn)btn.classList.add('loading');
  fetch('/cart/add.js',{
    method:'POST',
    headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
    body:JSON.stringify({id:parseInt(variantId),quantity:qty||1})
  }).then(function(r){return r.json();})
  .then(function(){return fetch('/cart.js');})
  .then(function(r){return r.json();})
  .then(function(cart){
    if(btn){btn.classList.remove('loading');btn.classList.add('done');setTimeout(function(){btn.classList.remove('done');},1800);}
    showToast('✓ '+title+' added!','success');
    document.dispatchEvent(new CustomEvent('cart:update',{detail:{itemCount:cart.item_count}}));
    if(window.Shopify&&window.Shopify.theme&&window.Shopify.theme.openCartDrawer)window.Shopify.theme.openCartDrawer();
  }).catch(function(){
    if(btn)btn.classList.remove('loading');
    showToast('Could not add to cart','error');
  });
}

function addMultiple(items,msg){
  fetch('/cart/add.js',{
    method:'POST',
    headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
    body:JSON.stringify({items:items})
  }).then(function(r){return r.json();})
  .then(function(){return fetch('/cart.js');})
  .then(function(r){return r.json();})
  .then(function(cart){
    showToast('✓ '+(msg||'Added to cart!'),'success');
    document.dispatchEvent(new CustomEvent('cart:update',{detail:{itemCount:cart.item_count}}));
  }).catch(function(){showToast('Could not add to cart','error');});
}

document.addEventListener('click',function(e){
  var btn=e.target.closest('.qb-atc');
  if(!btn)return;
  var variantId=btn.dataset.variant;
  var title=btn.dataset.title||'Product';
  var wrap=btn.closest('.qb-card-footer');
  var qty=1;
  if(wrap){var qi=wrap.querySelector('.qb-qty-val');if(qi)qty=Math.max(1,parseInt(qi.value)||1);}
  addToCart(variantId,qty,btn,title);
});

/* --- FAQ ACCORDION --- */
(function(){
  var list=document.getElementById('qb-faq-list');
  if(!list)return;
  list.addEventListener('click',function(e){
    var q=e.target.closest('.qb-faq-q');
    if(!q)return;
    var item=q.closest('.qb-faq-item');
    var wasOpen=item.classList.contains('open');
    list.querySelectorAll('.qb-faq-item.open').forEach(function(i){i.classList.remove('open');});
    if(!wasOpen)item.classList.add('open');
  });
})();

} /* end initApp */

