<script>
(function(){
'use strict';

/* ─── INGEST ─── */
var ALL = [];
document.querySelectorAll('#qbwData .qbwp').forEach(function(n){
  var cmp = parseInt(n.dataset.compare)||0;
  var prc = parseInt(n.dataset.price)||0;
  var sv  = cmp > prc && cmp > 0;
  ALL.push({
    url:    n.dataset.url,
    title:  n.dataset.title,
    type:   (n.dataset.type||'').toLowerCase(),
    tags:   (n.dataset.tags||'').toLowerCase(),
    img:    n.dataset.img||'',
    price:  prc, cmp: cmp,
    avail:  n.dataset.avail==='true',
    vendor: (n.dataset.vendor||''),
    sv: sv,
    svPct:  sv ? Math.round((cmp-prc)*100/cmp) : 0,
    svAmt:  sv ? Math.round((cmp-prc)/100) : 0
  });
});

/* ─── UTILS ─── */
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function hay(p){ return p.type+' '+p.tags+' '+p.title.toLowerCase()+' '+p.vendor.toLowerCase(); }
function hits(p,kws){ return kws.some(function(k){ return hay(p).indexOf(k)>-1; }); }
function f(fn){ return ALL.filter(fn); }
function kw(words){ return f(function(p){ return hits(p,words); }); }
function bySave(a){ return a.slice().sort(function(x,y){ return y.svPct-x.svPct; }); }
function byPop(a){ return a.slice().sort(function(x,y){
  var xs=(x.tags.indexOf('best-seller')>-1?2:0)+(x.tags.indexOf('demand')>-1?1:0);
  var ys=(y.tags.indexOf('best-seller')>-1?2:0)+(y.tags.indexOf('demand')>-1?1:0);
  return ys-xs;
}); }

/* ─── PRICE ─── */
function priceHtml(p, big){
  var sz = big ? 'font-size:17px' : '';
  {%- if customer and customer.tags contains 'wholesale-approved' -%}
  if(p.sv) return '<div class="qbw-price"><div class="qbw-price-row"><span class="qbw-price-now" style="'+sz+'">Rs '+Math.round(p.price/100)+'</span><span class="qbw-price-was">Rs '+Math.round(p.cmp/100)+'</span></div><div class="qbw-price-save">Save Rs '+p.svAmt+' ('+p.svPct+'%)</div></div>';
  return '<div class="qbw-price"><div class="qbw-price-row"><span class="qbw-price-now" style="'+sz+'">Rs '+Math.round(p.price/100)+'</span></div></div>';
  {%- else -%}
  if(p.sv) return '<div class="qbw-price"><div class="qbw-price-retail">Retail Rs '+Math.round(p.cmp/100)+'</div><div class="qbw-price-save">↓ Save '+p.svPct+'%</div><div class="qbw-price-hint">🔒 Register to unlock</div></div>';
  return '<div class="qbw-price"><div class="qbw-price-locked">Wholesale Price</div></div>';
  {%- endif -%}
}

/* ─── BADGE ─── */
function badge(p){
  var b1 = p.sv ? '<div class="qbw-b-save">−'+p.svPct+'%</div>' : '';
  var t = p.tags;
  var b2 = (t.indexOf('best-seller')>-1||t.indexOf('bestseller')>-1) ? '<span class="qbw-b-tag qbw-b-best">⭐ Best</span>'
         : (t.indexOf('high-demand')>-1||t.indexOf('demand')>-1) ? '<span class="qbw-b-tag qbw-b-hot">🔥 Hot</span>'
         : (/(?:^|,)\s*new\s*(?:,|$)/.test(t)) ? '<span class="qbw-b-tag qbw-b-new">✦ New</span>' : '';
  return b1+b2;
}
function soldMask(p){ return p.avail?'':'<div class="qbw-sold"><span>Out of Stock</span></div>'; }
function imgTag(p,cls){ return p.img?'<img src="'+p.img+'" alt="'+esc(p.title)+'" loading="lazy" width="400" height="400">':'<div class="'+cls+'">📦</div>'; }

/* ══════════════════════════════
   LAYOUT BUILDERS
   ══════════════════════════════ */

/* LAYOUT A — horizontal slider (5+ items) */
function slider(id, eye, name, prods){
  if(!prods.length) return '';
  var cards = prods.map(function(p){
    var typeLbl = p.type?'<div class="qbw-card-type">'+esc(p.type)+'</div>':'';
    return '<a href="'+p.url+'" class="qbw-card">'
      +'<div class="qbw-card-img">'+imgTag(p,'qbw-card-empty')+'<div class="qbw-card-fade"></div>'+badge(p)+soldMask(p)+'</div>'
      +'<div class="qbw-card-body">'+typeLbl+'<div class="qbw-card-name">'+esc(p.title)+'</div>'+priceHtml(p,false)+'</div>'
      +'</a>';
  }).join('');
  return _secWrap(id,eye,name,prods.length,
    '<div class="qbw-slider"><div class="qbw-slider-row">'+cards+'</div></div>');
}

/* LAYOUT B — grid (2-4 items) */
function grid(id, eye, name, prods){
  if(!prods.length) return '';
  var n = prods.length;
  var cls = n===2?'qbw-grid--2':n===3?'qbw-grid--3':'qbw-grid--4';
  var cards = prods.map(function(p){
    var typeLbl = p.type?'<div class="qbw-gcard-type">'+esc(p.type)+'</div>':'';
    return '<a href="'+p.url+'" class="qbw-gcard">'
      +'<div class="qbw-gcard-img">'+imgTag(p,'qbw-gcard-empty')+'<div class="qbw-gcard-fade"></div>'+badge(p)+soldMask(p)+'</div>'
      +'<div class="qbw-gcard-body">'+typeLbl+'<div class="qbw-gcard-name">'+esc(p.title)+'</div>'+priceHtml(p,false)+'</div>'
      +'</a>';
  }).join('');
  return _secWrap(id,eye,name,prods.length,
    '<div class="qbw-grid '+cls+'">'+cards+'</div>');
}

/* LAYOUT C — hero single */
function hero(id, eye, name, p){
  if(!p) return '';
  var imgEl = p.img?'<img src="'+p.img+'" alt="'+esc(p.title)+'" loading="lazy" width="400" height="400">':'<div class="qbw-hero-img-empty">📦</div>';
  var bdg = p.sv?'<div class="qbw-hero-badge">−'+p.svPct+'% · Rs '+p.svAmt+' off</div>':'';
  var vendor = p.vendor?'<div class="qbw-hero-vendor">'+esc(p.vendor)+'</div>':'';
  return _secWrap(id,eye,name,1,
    '<a href="'+p.url+'" class="qbw-hero-card">'
    +'<div class="qbw-hero-img">'+imgEl+'</div>'
    +'<div class="qbw-hero-body"><div class="qbw-hero-glow"></div>'
    +'<div class="qbw-hero-eye">'+esc(eye)+'</div>'
    +'<div class="qbw-hero-name">'+esc(p.title)+'</div>'
    +vendor+bdg+priceHtml(p,true)
    +'</div></a>');
}

/* LAYOUT D — duo (best 2 products, big cards) */
function duo(id, eye, name, prods){
  if(prods.length < 2) return prods.length===1 ? hero(id,eye,name,prods[0]) : '';
  var top = prods.slice(0,2);
  var cards = top.map(function(p){
    var bd = p.sv?'<div class="qbw-duo-b-save">−'+p.svPct+'%</div>':'';
    var imgEl = p.img?'<img src="'+p.img+'" alt="'+esc(p.title)+'" loading="lazy" width="400" height="400">':'<div class="qbw-duo-empty">📦</div>';
    var pr = p.sv
      ? '<div class="qbw-duo-price-now">Rs '+Math.round({%- if customer and customer.tags contains 'wholesale-approved' -%}p.price{%- else -%}p.cmp{%- endif -%}/100)+'</div>'
      : '<div class="qbw-duo-price-locked">Wholesale Price</div>';
    return '<a href="'+p.url+'" class="qbw-duo-card">'
      +'<div class="qbw-duo-img">'+imgEl+'<div class="qbw-duo-fade"></div>'+bd+soldMask(p)+'</div>'
      +'<div class="qbw-duo-body">'+(p.type?'<div class="qbw-duo-type">'+esc(p.type)+'</div>':'')
      +'<div class="qbw-duo-name">'+esc(p.title)+'</div>'+pr+'</div>'
      +'</a>';
  }).join('');
  return _secWrap(id,eye,name,prods.length,'<div class="qbw-duo">'+cards+'</div>');
}

/* smart layout selector */
function sec(id, eye, name, prods){
  if(!prods||!prods.length) return '';
  var n = prods.length;
  if(n===1) return hero(id,eye,name,prods[0]);
  if(n<=4)  return grid(id,eye,name,prods);
  return slider(id,eye,name,prods);
}

function _secWrap(id,eye,name,cnt,inner){
  return '<div class="qbw-sec" id="s-'+id+'">'
    +'<div class="qbw-sec-head"><div>'
    +'<div class="qbw-sec-eye">'+eye+'</div>'
    +'<div class="qbw-sec-name">'+name+'</div>'
    +'<div class="qbw-sec-cnt">'+cnt+' product'+(cnt!==1?'s':'')+'</div>'
    +'</div></div>'
    +'<div class="qbw-rule"><div class="qbw-rule-inner"></div></div>'
    +inner+'</div>';
}

function grp(emo,name,sub){
  return '<div class="qbw-grp"><div class="qbw-grp-inner"><span class="qbw-grp-emo">'+emo+'</span>'
    +'<div><div class="qbw-grp-name">'+name+'</div><div class="qbw-grp-sub">'+sub+'</div></div></div></div>';
}

function cta(tag,title,sub){
  return '<div class="qbw-cta" style="margin-left:auto;margin-right:auto;max-width:1100px">'
    +'<div><div class="qbw-cta-tag">'+tag+'</div><div class="qbw-cta-title">'+title+'</div><div class="qbw-cta-sub">'+sub+'</div></div>'
    +'<a href="/products/vendor-registration" class="qbw-btn-gold" style="font-size:12px;flex-shrink:0">Register Now →</a>'
    +'</div>';
}

/* ══════════════════════════════
   CATEGORY DEFINITIONS
   — no deduplication so every product appears in its relevant sections
   ══════════════════════════════ */

/* CURATED (use a small dedup pool just for curated so no same item in flash+best) */
var _cu = {};
function cu(fn){ var o=ALL.filter(function(p){ return !_cu[p.url]&&fn(p); }); o.forEach(function(p){ _cu[p.url]=true; }); return o; }

var FLASH   = bySave(cu(function(p){ return p.sv&&p.svPct>=10; })).slice(0,50);
var BEST    = cu(function(p){ return p.tags.indexOf('best-seller')>-1||p.tags.indexOf('bestseller')>-1; });
var NEW     = cu(function(p){ return /(?:^|,)\s*new\s*(?:,|$)/.test(p.tags); });
var DEMAND  = cu(function(p){ return p.tags.indexOf('high-demand')>-1||p.tags.indexOf('demand')>-1; });

/* WHISKY */
var W_ALL   = kw(['whisky','whiskey']);
var W_REG   = W_ALL.filter(function(p){ return hits(p,['regular','black label','red label','old tavern','bagpiper','teachers','vat 69','blenders','antiquity','royal stag','imperial blue','signature','dsp black']); });
var W_PREM  = W_ALL.filter(function(p){ return hits(p,['premium','gold label','blue label','double black','platinum','chivas','ballantine','dewar','famous grouse','grants','william peel','johnnie walker','passport scotch']); });
var W_BOUR  = W_ALL.filter(function(p){ return hits(p,['bourbon','american whiskey','jack daniel','jim beam','maker','wild turkey','knob creek','bulleit','woodford','buffalo trace']); });
var W_MALT  = W_ALL.filter(function(p){ return hits(p,['single malt','malt','glenfiddich','macallan','laphroaig','glenlivet','glenmorangie','balvenie','talisker','ardbeg','bowmore','lagavulin','singleton']); });
var W_DOM   = W_ALL.filter(function(p){ return hits(p,['khukuri','old durbar','kumari','ruslan','8848','coronation','himalayan whisky','nepal whisky','yeti whisky']); });
var W_OTH   = W_ALL.filter(function(p){ return !W_REG.includes(p)&&!W_PREM.includes(p)&&!W_BOUR.includes(p)&&!W_MALT.includes(p)&&!W_DOM.includes(p); });

/* VODKA */
var V_ALL   = kw(['vodka']);
var V_DOM   = V_ALL.filter(function(p){ return hits(p,['domestic','nepal','ruslan vodka','khukuri vodka','himalayan vodka','kumari vodka']); });
var V_IMP   = V_ALL.filter(function(p){ return hits(p,['absolut','grey goose','belvedere','smirnoff','ciroc','tito','ketel','stolichnaya','stoli','finlandia','russian standard','skyy']); });
var V_OTH   = V_ALL.filter(function(p){ return !V_DOM.includes(p)&&!V_IMP.includes(p); });

/* GIN */
var G_ALL   = kw(['gin']);
var G_DOM   = G_ALL.filter(function(p){ return hits(p,['domestic','nepal gin','himalayan gin','khukuri gin']); });
var G_IMP   = G_ALL.filter(function(p){ return hits(p,['tanqueray','hendricks','bombay','beefeater','gordon','monkey 47','roku','malfy','sipsmith','whitley']); });
var G_OTH   = G_ALL.filter(function(p){ return !G_DOM.includes(p)&&!G_IMP.includes(p); });

/* RUM */
var R_ALL   = kw(['rum']);
var R_DOM   = R_ALL.filter(function(p){ return hits(p,['khukuri rum','himalayan rum','kumari rum','old cask','nepal rum']); });
var R_IMP   = R_ALL.filter(function(p){ return hits(p,['bacardi','captain morgan','havana','kraken','malibu','mount gay','diplomatico','zacapa','angostura','appleton','flor de cana']); });
var R_OTH   = R_ALL.filter(function(p){ return !R_DOM.includes(p)&&!R_IMP.includes(p); });

/* TEQUILA */
var TEQ     = kw(['tequila','mezcal']);
var TEQ_BLN = TEQ.filter(function(p){ return hits(p,['blanco','silver','plata']); });
var TEQ_REP = TEQ.filter(function(p){ return hits(p,['reposado']); });
var TEQ_ANJ = TEQ.filter(function(p){ return hits(p,['anejo','añejo','extra anejo']); });
var TEQ_OTH = TEQ.filter(function(p){ return !TEQ_BLN.includes(p)&&!TEQ_REP.includes(p)&&!TEQ_ANJ.includes(p); });

/* BRANDY / COGNAC */
var B_ALL   = kw(['brandy','cognac']);
var B_VS    = B_ALL.filter(function(p){ return hits(p,[' vs ','vs cognac','very special']); });
var B_VSOP  = B_ALL.filter(function(p){ return hits(p,['vsop']); });
var B_NAP   = B_ALL.filter(function(p){ return hits(p,['napoleon']); });
var B_XO    = B_ALL.filter(function(p){ return hits(p,[' xo ','xo cognac','extra old','extra-old']); });
var B_DOM   = B_ALL.filter(function(p){ return hits(p,['marpha','mustang brandy','nepal brandy','himalayan brandy']); });
var B_OTH   = B_ALL.filter(function(p){ return !B_VS.includes(p)&&!B_VSOP.includes(p)&&!B_NAP.includes(p)&&!B_XO.includes(p)&&!B_DOM.includes(p); });

/* LIQUEUR */
var LIQ     = kw(['liqueur','kahlua','baileys','aperol','cointreau','triple sec','campari','amaretto','disaronno','frangelico','midori','sambuca','jagermeister','schnapps','drambuie','limoncello','grand marnier','curacao','st germain']);
var LIQ_CRE = LIQ.filter(function(p){ return hits(p,['cream','baileys','advocaat','irish cream']); });
var LIQ_BIT = LIQ.filter(function(p){ return hits(p,['bitter','aperol','campari','amaro','cynar','fernet']); });
var LIQ_OTH = LIQ.filter(function(p){ return !LIQ_CRE.includes(p)&&!LIQ_BIT.includes(p); });

/* RTD */
var RTD     = kw(['ready to drink','rtd','premixed','pre-mixed','smirnoff ice','bacardi breezer','hard seltzer','breezer']);

/* SOJU */
var SOJU    = kw(['soju','jinro','chum churum','chamisul']);

/* SAKE / JAPANESE */
var SAKE    = kw(['sake','nihonshu','junmai','daiginjo','ginjo']);
var SHOCHU  = kw(['shochu','iichiko']);
var UMESHU  = kw(['umeshu','plum wine','choya']);
var JPWINE  = kw(['japanese wine','koshu']);

/* WINE */
var WI_ALL  = kw(['wine']);
var WI_CHMP = WI_ALL.filter(function(p){ return hits(p,['champagne','moet','veuve','bollinger','perrier jouet','dom perignon','krug','mumm','taittinger']); });
var WI_PROS = WI_ALL.filter(function(p){ return hits(p,['prosecco','valdobbiadene','spumante']); });
var WI_SPK  = WI_ALL.filter(function(p){ return hits(p,['sparkling','cava','frizzante','lambrusco','cremant','asti']); });
var WI_RED  = WI_ALL.filter(function(p){ return hits(p,['red wine','cabernet','merlot','shiraz','syrah','pinot noir','malbec','sangiovese','tempranillo','chianti','barolo','rioja','bordeaux']); });
var WI_WHT  = WI_ALL.filter(function(p){ return hits(p,['white wine','sauvignon blanc','chardonnay','pinot grigio','riesling','viognier','chenin']); });
var WI_ROS  = WI_ALL.filter(function(p){ return hits(p,['rose wine','rosé','blush']); });
var WI_FLV  = WI_ALL.filter(function(p){ return hits(p,['flavoured','flavored','fruit wine','sangria','mulled']); });
var WI_DOM  = WI_ALL.filter(function(p){ return hits(p,['marpha','mustang wine','nepal wine','himalayan wine']); });
var WI_OTH  = WI_ALL.filter(function(p){ return !WI_CHMP.includes(p)&&!WI_PROS.includes(p)&&!WI_SPK.includes(p)&&!WI_RED.includes(p)&&!WI_WHT.includes(p)&&!WI_ROS.includes(p)&&!WI_FLV.includes(p)&&!WI_DOM.includes(p); });

/* BEER */
var BE_ALL  = kw(['beer','lager','ale','stout','pilsner']);
var BE_DOM  = BE_ALL.filter(function(p){ return hits(p,['everest','gorkha','nepal ice','star beer','tuborg nepal','carlsberg nepal','yak beer','nepal beer']); });
var BE_IMP  = BE_ALL.filter(function(p){ return hits(p,['heineken','corona','budweiser','stella','asahi','kirin','kingfisher','leffe','tiger','chang','san miguel','hoegaarden','erdinger','paulaner']); });
var BE_CS   = BE_ALL.filter(function(p){ return hits(p,['case','bulk','6 pack','12 pack','24 pack','carton','slab']); });
var BE_NA   = BE_ALL.filter(function(p){ return hits(p,['non alcoholic','non-alcoholic','alcohol free','0%','zero beer','0.0']); });
var BE_CRAFT= BE_ALL.filter(function(p){ return hits(p,['craft','ipa','pale ale','wheat beer','dark beer','porter','stout']); });
var BE_OTH  = BE_ALL.filter(function(p){ return !BE_DOM.includes(p)&&!BE_IMP.includes(p)&&!BE_CS.includes(p)&&!BE_NA.includes(p)&&!BE_CRAFT.includes(p); });

/* MIXERS */
var MX_SYR  = kw(['syrup','monin','torani','grenadine','falernum','orgeat','gomme']);
var MX_ICE  = kw(['ice cube','ice block','ice bag','cocktail ice','crushed ice','party ice']);
var MX_TOOL = kw(['shaker','jigger','muddler','strainer','bar spoon','bar tool','mixing glass','bar set']);
var MX_FLO  = kw(['floral mixer','elderflower','hibiscus','lavender syrup','rose water','butterfly pea']);
var MX_SUP  = kw(['supplement','energy mix','electrolyte','recovery mix']);
var MX_SODA = kw(['soda water','tonic water','ginger beer','mixer','club soda','sparkling water']);

/* HOOKAH */
var HK_ALL  = kw(['hookah','shisha','kalyan']);
var HK_FL   = HK_ALL.filter(function(p){ return hits(p,['flavor','flavour','tobacco','molasses','al fakher','starbuzz','fumari','adalya','mazaya','tangiers','afzal']); });
var HK_EQ   = HK_ALL.filter(function(p){ return hits(p,['pipe','bowl','hose','charcoal','coal','setup','base','equipment']); });
var HK_COAL = HK_ALL.filter(function(p){ return hits(p,['charcoal','coal','coconut coal','quick light']); });
var HK_OTH  = HK_ALL.filter(function(p){ return !HK_FL.includes(p)&&!HK_EQ.includes(p)&&!HK_COAL.includes(p); });

/* TOBACCO */
var CIG     = kw(['cigarette','cigar','tobacco','marlboro','winston','gold flake','surya','shikhar','camel','parliament','dunhill','benson','lucky strike','newport']);
var CIG_MEN = CIG.filter(function(p){ return hits(p,['menthol','mint cigarette']); });
var CIG_PRE = CIG.filter(function(p){ return hits(p,['premium','prestige']); });
var CIG_DOM = CIG.filter(function(p){ return hits(p,['surya','shikhar','yak','nepal cigarette']); });
var CIG_IMP = CIG.filter(function(p){ return hits(p,['marlboro','winston','camel','parliament','dunhill','benson','lucky strike']); });
var CIG_OTH = CIG.filter(function(p){ return !CIG_MEN.includes(p)&&!CIG_PRE.includes(p)&&!CIG_DOM.includes(p)&&!CIG_IMP.includes(p); });

/* ROLLING */
var ROLL    = kw(['rolling paper','raw paper','ocb','rizla','juicy jay','zig zag','blunt wrap','hemp paper','roach','hemp wrap']);

/* CATCH-ALL */
