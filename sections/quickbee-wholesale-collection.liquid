/* ── SCROLL OFFSET ── */
function offset(){
  var sticky = document.querySelector('.qbw-sticky');
  var site = document.querySelector('sticky-header,#shopify-section-quickbee-header,[id*="header"]');
  return ((sticky?sticky.offsetHeight:44) + (site?site.offsetHeight:60) + 10);
}

/* ── NAV CLICK ── */
window.qbwNav = function(btn){
  document.querySelectorAll('.qbw-sticky-btn').forEach(function(b){ b.classList.remove('qbw-active'); });
  btn.classList.add('qbw-active');
  var el = document.getElementById(btn.getAttribute('data-id'));
  if(el) window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - offset(), behavior:'smooth' });
  /* scroll sticky nav to show active btn */
  btn.scrollIntoView({ inline:'center', behavior:'smooth', block:'nearest' });
};

/* ── CATEGORY JUMP ── */
window.qbwJump = function(e, id){
  e.preventDefault();
  var el = document.getElementById(id);
  if(el) window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - offset(), behavior:'smooth' });
};

/* ── FAQ ── */
window.qbwFaq = function(qEl){
  var item = qEl.closest('.qbw-faq-item');
  if(!item) return;
  var was = item.classList.contains('open');
  document.querySelectorAll('.qbw-faq-item.open').forEach(function(i){ i.classList.remove('open'); });
  if(!was) item.classList.add('open');
};

/* ── INTERSECTION OBSERVER for active nav ── */
(function(){
  if(!window.IntersectionObserver) return;
  var secs = document.querySelectorAll('[id^="s-"]');
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){
        var id = e.target.id;
        document.querySelectorAll('.qbw-sticky-btn').forEach(function(b){
          b.classList.toggle('qbw-active', b.getAttribute('data-id')===id);
        });
      }
    });
  },{ threshold:0.25, rootMargin:'-60px 0px -60% 0px' });
  secs.forEach(function(s){ io.observe(s); });
})();

})();
</script>

