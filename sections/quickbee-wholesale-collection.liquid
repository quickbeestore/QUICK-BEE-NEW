/* --- 6. CARD BUILDER --- */
function buildCard(p){
  var pct=savePct(p);
  var isBest=hasAnyTag(p,['bestseller','high-demand']);
  var isDom=hasTag(p,'domestic');
  var isNew=hasTag(p,'new');
  var badges='';
  if(pct>=5)badges+='<span class="qb-badge qb-badge-save">-'+pct+'%</span>';
  if(isBest)badges+='<span class="qb-badge qb-badge-best">⭐ Top</span>';
  if(isDom)badges+='<span class="qb-badge qb-badge-dom">DOM</span>';
  if(isNew)badges+='<span class="qb-badge qb-badge-new">New</span>';
  var cmpHtml=(p.cmp&&p.cmp>p.price)?'<span class="qb-card-cmp">'+fmt(p.cmp)+'</span>':'';
  var soldOut=!p.avail?' style="opacity:.55"':'';
  return '<div class="qb-card" data-id="'+esc(p.id)+'"'+soldOut+'>'
    +'<div class="qb-card-img-wrap"><div class="qb-card-badges">'+badges+'</div>'
    +'<img src="'+esc(p.img)+'" alt="'+esc(p.title)+'" loading="lazy"></div>'
    +'<div class="qb-card-body">'
    +'<div class="qb-card-vendor">'+esc(p.vendor)+'</div>'
    +'<div class="qb-card-title">'+esc(p.title)+'</div>'
    +'<div class="qb-card-price-row"><span class="qb-card-price">'+fmt(p.price)+'</span>'+cmpHtml+'</div>'
    +'<div class="qb-card-footer">'
    +'<div class="qb-qty-wrap">'
    +'<button class="qb-qty-btn" data-dir="-1">−</button>'
    +'<input class="qb-qty-val" type="number" value="1" min="1" max="99">'
    +'<button class="qb-qty-btn" data-dir="1">+</button>'
    +'</div>'
    +'<button class="qb-atc" data-variant="'+esc(p.variant)+'" data-title="'+esc(p.title)+'">Add</button>'
    +'</div></div></div>';
}

function skelCard(){
  return '<div class="qb-skel"><div class="qb-skel-img"></div><div class="qb-skel-body">'
    +'<div class="qb-skel-line w60"></div><div class="qb-skel-line w80"></div>'
    +'<div class="qb-skel-line h16 w60"></div></div></div>';
}

/* --- 7. SECTION BUILDER --- */
function buildSubcatSlider(tag,label,products){
  if(!products||!products.length)return '';
  var sid='sl-'+tag.replace(/[^a-z0-9]/g,'-');
  var n=products.length;
  var inner='';
  if(n>=4){
    inner='<div class="qb-slider-wrap">'
      +'<button class="qb-arr qb-arr-l" data-target="'+sid+'">‹</button>'
      +'<div class="qb-slider" id="'+sid+'">'+products.map(buildCard).join('')+'</div>'
      +'<button class="qb-arr qb-arr-r" data-target="'+sid+'">›</button>'
      +'</div>';
  }else{
    inner='<div class="qb-grid">'+products.map(buildCard).join('')+'</div>';
  }
  return '<div class="qb-subcat-label">'+esc(label)+' <span style="font-size:11px;color:var(--muted);font-weight:500;text-transform:none;letter-spacing:0">('+n+')</span></div>'
    +inner;
}

function buildGroupSection(grp){
  var parts=[];
  var total=0;
  grp.subcats.forEach(function(sc){
    var prods=TAG_MAP[sc.tag]||[];
    if(prods.length){
      parts.push(buildSubcatSlider(sc.tag,sc.label,prods));
      total+=prods.length;
    }
  });
  if(!parts.length)return '';
  return '<div class="qb-group" id="grp-'+grp.id+'">'
    +'<div class="qb-group-head">'
    +'<span class="qb-group-icon">'+grp.icon+'</span>'
    +'<span class="qb-group-name">'+esc(grp.label)+'</span>'
    +'<span class="qb-group-count">'+total+' products</span>'
    +'</div>'
    +parts.join('')
    +'</div>';
}

