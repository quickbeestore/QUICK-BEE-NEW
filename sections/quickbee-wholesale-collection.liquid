<script>
function qbwScroll(btn, dir) {
  var wrap = btn.closest('.qbw-slider-wrap').querySelector('.qbw-slider-track');
  if (!wrap) return;
  var cardW = wrap.querySelector('.qbw-card');
  var scrollAmt = cardW ? (cardW.offsetWidth + 12) * 3 : 660;
  wrap.scrollBy({ left: dir * scrollAmt, behavior: 'smooth' });
}
/* smooth anchor scroll for category nav */
document.querySelectorAll('.qbw-catnav-item').forEach(function(a){
  a.addEventListener('click', function(e){
    var href = a.getAttribute('href');
    if(href && href.startsWith('#')){
      e.preventDefault();
      var target = document.querySelector(href);
      if(target){ target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      document.querySelectorAll('.qbw-catnav-item').forEach(function(i){ i.classList.remove('active'); });
      a.classList.add('active');
    }
  });
});
</script>

