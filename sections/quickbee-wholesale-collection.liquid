{% paginate collection.products by 24 %}

<style>
.qb-container {
  padding: 30px;
  background: radial-gradient(circle at top, #111, #000);
}

.qb-title {
  font-size: 40px;
  color: #fff;
  margin-bottom: 25px;
  font-weight: 700;
}

.qb-category {
  color: #f4c542;
  margin: 30px 0 10px;
  font-size: 20px;
  font-weight: 600;
}

/* GRID */
.qb-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

/* CARD */
.qb-card {
  background: #0b0b0b;
  border-radius: 14px;
  overflow: hidden;
  transition: 0.3s ease;
  position: relative;
}

.qb-card:hover {
  transform: translateY(-6px) scale(1.02);
}

/* IMAGE */
.qb-img {
  position: relative;
  height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qb-img img {
  max-height: 180px;
  width: auto;
  z-index: 2;
}

/* GLOW EFFECT */
.qb-glow {
  position: absolute;
  width: 160px;
  height: 160px;
  background: radial-gradient(circle, rgba(244,197,66,0.35), transparent);
  filter: blur(30px);
  opacity: 0;
  transition: 0.4s;
}

.qb-card:hover .qb-glow {
  opacity: 1;
}

/* INFO */
.qb-info {
  padding: 12px;
}

.qb-info h3 {
  font-size: 13px;
  color: #fff;
  margin-bottom: 6px;
}

.qb-price {
  color: #f4c542;
  font-weight: bold;
}

/* PAGINATION */
.qb-pagination {
  margin-top: 40px;
  color: white;
}

/* MOBILE */
@media(max-width:768px){
  .qb-grid {
    grid-template-columns: repeat(2,1fr);
  }
}
</style>

<div class="qb-container">

  <h1 class="qb-title">QuickBee Wholesale</h1>

  {% assign last_category = "" %}

  {% for product in collection.products %}

    {% assign category = "Other" %}

    {% for tag in product.tags %}
      {% if tag contains "category:" %}
        {% assign category = tag | remove: "category:" | capitalize %}
      {% endif %}
    {% endfor %}

    {% if category != last_category %}
      <h2 class="qb-category">{{ category }}</h2>
      <div class="qb-grid">
    {% endif %}

    <div class="qb-card">
      <a href="{{ product.url }}">

        <div class="qb-img">
          <img src="{{ product.featured_image | img_url: '500x' }}" alt="{{ product.title }}">
          <div class="qb-glow"></div>
        </div>

        <div class="qb-info">
          <h3>{{ product.title }}</h3>
          <p class="qb-price">{{ product.price | money }}</p>
        </div>

      </a>
    </div>

    {% assign next_index = forloop.index0 | plus: 1 %}
    {% assign next_product = collection.products[next_index] %}

    {% assign next_category = "" %}
    {% if next_product %}
      {% for tag in next_product.tags %}
        {% if tag contains "category:" %}
          {% assign next_category = tag | remove: "category:" | capitalize %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if category != next_category %}
      </div>
    {% endif %}

    {% assign last_category = category %}

  {% endfor %}

  <div class="qb-pagination">
    {{ paginate | default_pagination }}
  </div>

</div>

{% endpaginate %}