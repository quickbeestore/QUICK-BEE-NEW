<script>
(function(){
'use strict';

/* ─── LOAD ALL PRODUCTS ─── */
var nodes = document.querySelectorAll('#qbwData .qbwp');
var ALL = [];
nodes.forEach(function(n){
  var cmp = parseInt(n.dataset.compare)||0;
  var prc = parseInt(n.dataset.price)||0;
  var save = cmp > prc && cmp > 0;
  ALL.push({
    url:n.dataset.url, title:n.dataset.title,
    type:n.dataset.type||'', tags:n.dataset.tags||'',
    img:n.dataset.img||'', price:prc, compare:cmp,
    avail:n.dataset.avail==='true', vendor:n.dataset.vendor||'',
    best:n.dataset.best==='1', demand:n.dataset.demand==='1',
    isNew:n.dataset.new==='1', save:save,
    savePct:save?Math.round((cmp-prc)*100/cmp):0,
    saveAmt:save?Math.round((cmp-prc)/100):0
  });
});

/* ─── UTILS ─── */
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function hay(p){ return (p.type+' '+p.tags+' '+p.title+' '+p.vendor).toLowerCase(); }
function kw(p,words){ return words.some(function(w){ return hay(p).indexOf(w)>-1; }); }

var used = {};
function take(fn){
  var out = ALL.filter(function(p){ return !used[p.url] && fn(p); });
  out.forEach(function(p){ used[p.url]=true; });
  return out;
}
function takeKw(words){ return take(function(p){ return kw(p,words); }); }

/* ─── PRICE RENDER ─── */
function price(p){
  {%- if customer and customer.tags contains 'wholesale-approved' -%}
  if(p.save){
    return '<div class="qbw-card-price">'
      +'<div class="qbw-price-row"><span class="qbw-price-now">Rs '+Math.round(p.price/100)+'</span><span class="qbw-price-was">Rs '+Math.round(p.compare/100)+'</span></div>'
      +'<div class="qbw-price-save">Save Rs '+p.saveAmt+' ('+p.savePct+'% off)</div>'
      +'</div>';
  }
  return '<div class="qbw-card-price"><div class="qbw-price-row"><span class="qbw-price-now">Rs '+Math.round(p.price/100)+'</span></div></div>';
  {%- else -%}
  if(p.save){
    return '<div class="qbw-card-price">'
      +'<div class="qbw-price-retail">Retail Rs '+Math.round(p.compare/100)+'</div>'
      +'<div class="qbw-price-save">↓ Save '+p.savePct+'% · Rs '+p.saveAmt+'</div>'
      +'<div class="qbw-price-hint">🔒 Register to unlock wholesale</div>'
      +'</div>';
  }
  return '<div class="qbw-card-price"><div class="qbw-price-locked">Wholesale Pricing Available</div></div>';
  {%- endif -%}
}

/* ─── CARD HTML ─── */
function card(p, xl){
  var badges = '';
  if(p.save) badges += '<div class="qbw-b-save">−'+p.savePct+'% Rs '+p.saveAmt+'</div>';
  if(p.best) badges += '<span class="qbw-b-hot">⭐ Best</span>';
  else if(p.demand) badges += '<span class="qbw-b-demand">🔥 Hot</span>';
  else if(p.isNew) badges += '<span class="qbw-b-new">✦ New</span>';
  var soldMask = p.avail ? '' : '<div class="qbw-sold-mask"><span class="qbw-sold-lbl">Out of Stock</span></div>';
  var imgHtml = p.img
    ? '<img src="'+p.img+'" alt="'+esc(p.title)+'" loading="lazy" width="400" height="400">'
    : '<div class="qbw-card-placeholder">📦</div>';
  var cls = 'qbw-card'+(xl?' qbw-card--xl':'');
  var typeLbl = p.type?'<div class="qbw-card-type">'+esc(p.type)+'</div>':'';
  return '<a href="'+p.url+'" class="'+cls+'">'
    +'<div class="qbw-card-img">'+imgHtml+'<div class="qbw-card-img-fade"></div>'+badges+soldMask+'</div>'
    +'<div class="qbw-card-body">'+typeLbl+'<div class="qbw-card-title">'+esc(p.title)+'</div>'+price(p)+'</div>'
    +'</a>';
}

/* ─── SLIDER ─── */
function slider(id, prods, xl){
  if(!prods.length) return '';
  return '<div class="qbw-slider"><div class="qbw-slider-scroll"><div class="qbw-slider-row" id="trk-'+id+'">'
    +prods.map(function(p){ return card(p,xl||false); }).join('')
    +'</div></div></div>';
}

/* ─── SECTION ─── */
function sec(id, eyebrow, name, sub, prods, xl, noPad){
  if(!prods.length) return '';
  return '<div class="qbw-sec'+(noPad?' qbw-sec--np':'')+'" id="s-'+id+'">'
    +'<div class="qbw-sec-head"><div class="qbw-sec-left">'
    +'<div class="qbw-sec-eyebrow">'+eyebrow+'</div>'
    +'<div class="qbw-sec-name">'+name+'</div>'
    +(sub?'<div class="qbw-sec-count">'+sub+'</div>':'')
    +'</div></div>'
    +'<div class="qbw-sec-divider"><div class="qbw-divider-line"></div></div>'
    +slider(id,prods,xl)
    +'</div>';
}

/* ─── GROUP HEADER ─── */
function grp(emo, name, sub){
  return '<div class="qbw-grp"><div class="qbw-grp-inner">'
    +'<span class="qbw-grp-emo">'+emo+'</span>'
    +'<div><div class="qbw-grp-name">'+name+'</div><div class="qbw-grp-sub">'+sub+'</div></div>'
    +'</div></div>';
}

/* ─── B2B BANNER ─── */
function b2b(tag, title, sub){
  return '<div class="qbw-b2b"><div class="qbw-b2b-inner">'
