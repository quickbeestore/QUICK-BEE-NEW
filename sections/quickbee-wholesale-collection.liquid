    navHtml += '<button class="qbw-nav-btn" data-id="'+d[0]+'" onclick="qbwNav(this)">'+d[1]+'</button>';
  }
});
document.getElementById('qbwNav').innerHTML = navHtml;

/* ── BRANDS ROW (no longer in HTML, skipped for clean layout) ── */

/* ── SCROLL OFFSET ── */
function scrollOffset(){
  var nav = document.querySelector('.qbw-nav');
  var siteHdr = document.querySelector('sticky-header,#shopify-section-quickbee-header,[id*="quickbee-header"]');
  return (nav ? nav.offsetHeight : 44) + (siteHdr ? siteHdr.offsetHeight : 56) + 8;
}

/* ── NAV CLICK ── */
window.qbwNav = function(btn){
  document.querySelectorAll('.qbw-nav-btn').forEach(function(b){ b.classList.remove('on'); });
  btn.classList.add('on');
  var el = document.getElementById(btn.getAttribute('data-id'));
  if(el) window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - scrollOffset(), behavior: 'smooth' });
  btn.scrollIntoView({ inline: 'center', behavior: 'smooth', block: 'nearest' });
};

/* ── AUTO-HIGHLIGHT NAV ON SCROLL ── */
if(window.IntersectionObserver){
  var secs = document.querySelectorAll('[id^="sec-"]');
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting) return;
      var id = e.target.id;
      document.querySelectorAll('.qbw-nav-btn').forEach(function(b){
        b.classList.toggle('on', b.getAttribute('data-id') === id);
      });
      /* scroll nav pill into view */
      var activeBtn = document.querySelector('.qbw-nav-btn.on');
      if(activeBtn) activeBtn.scrollIntoView({ inline: 'nearest', behavior: 'smooth', block: 'nearest' });
    });
  }, { threshold: 0.2, rootMargin: '-50px 0px -55% 0px' });
  secs.forEach(function(s){ io.observe(s); });
}

/* ── FAQ ── */
window.qbwFaq = function(el){
  var item = el.closest('.qbw-faq-item');
  if(!item) return;
  var was = item.classList.contains('open');
  document.querySelectorAll('.qbw-faq-item.open').forEach(function(i){ i.classList.remove('open'); });
  if(!was) item.classList.add('open');
};

})();
</script>

