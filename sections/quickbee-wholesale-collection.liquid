var navHtml='';
navGroups.forEach(function(g){
  var mainEl=document.getElementById(g.id);
  var validCh=g.ch.filter(function(c){return !!document.getElementById(c[0]);});
  if(!mainEl&&!validCh.length) return;
  var targetId=mainEl?g.id:(validCh.length?validCh[0][0]:null);
  if(!targetId) return;
  if(!validCh.length){
    navHtml+='<button class="qbw-nav-btn" data-id="'+targetId+'" onclick="qbwNav(this)">'+g.label+'</button>';
  } else {
    var drops=validCh.map(function(c){return '<button class="qbw-nav-drop-item" data-id="'+c[0]+'" onclick="qbwNavDrop(this)">'+c[1]+'</button>';}).join('');
    navHtml+='<div class="qbw-nav-grp" data-main="'+targetId+'"><button class="qbw-nav-grp-btn" onclick="qbwNavGrp(this)">'+g.label+'<span class="arrow">▾</span></button><div class="qbw-nav-drop">'+drops+'</div></div>';
  }
});
document.getElementById('qbwNav').innerHTML=navHtml;

document.addEventListener('click',function(e){
  if(!e.target.closest('.qbw-nav-grp')) document.querySelectorAll('.qbw-nav-grp.open').forEach(function(g){g.classList.remove('open');});
});

/* ─── SCROLL / NAV ─── */
function off(){
  var n=document.querySelector('.qbw-nav');
  var h=document.querySelector('sticky-header,#shopify-section-quickbee-header');
  return (n?n.offsetHeight:44)+(h?h.offsetHeight:56)+8;
}
function scrollToSection(id){
  var el=document.getElementById(id);
  if(el) window.scrollTo({top:el.getBoundingClientRect().top+window.scrollY-off(),behavior:'smooth'});
}
window.qbwNav=function(btn){
  document.querySelectorAll('.qbw-nav-btn').forEach(function(b){b.classList.remove('on');});
  document.querySelectorAll('.qbw-nav-grp').forEach(function(g){g.classList.remove('on');});
  btn.classList.add('on');
  scrollToSection(btn.getAttribute('data-id'));
  btn.scrollIntoView({inline:'center',behavior:'smooth',block:'nearest'});
};
window.qbwNavGrp=function(btn){
  var grp=btn.closest('.qbw-nav-grp');
  var wasOpen=grp.classList.contains('open');
  document.querySelectorAll('.qbw-nav-grp.open').forEach(function(g){g.classList.remove('open');});
  if(!wasOpen) grp.classList.add('open');
  else { grp.classList.add('on'); scrollToSection(grp.getAttribute('data-main')); }
};
window.qbwNavDrop=function(btn){
  document.querySelectorAll('.qbw-nav-grp.open').forEach(function(g){g.classList.remove('open');});
  document.querySelectorAll('.qbw-nav-grp').forEach(function(g){g.classList.remove('on');});
  document.querySelectorAll('.qbw-nav-drop-item').forEach(function(b){b.classList.remove('on');});
  btn.classList.add('on');
  var grp=btn.closest('.qbw-nav-grp');
  if(grp) grp.classList.add('on');
  scrollToSection(btn.getAttribute('data-id'));
};

/* ─── AUTO-HIGHLIGHT ─── */
if(window.IntersectionObserver){
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting) return;
      var id=e.target.id;
      document.querySelectorAll('.qbw-nav-btn').forEach(function(b){b.classList.toggle('on',b.getAttribute('data-id')===id);});
      document.querySelectorAll('.qbw-nav-drop-item').forEach(function(b){b.classList.toggle('on',b.getAttribute('data-id')===id);});
      document.querySelectorAll('.qbw-nav-grp').forEach(function(g){
        g.classList.toggle('on',!!g.querySelector('.qbw-nav-drop-item.on')||g.getAttribute('data-main')===id);
      });
      var act=document.querySelector('.qbw-nav-btn.on,.qbw-nav-grp.on .qbw-nav-grp-btn');
      if(act) act.scrollIntoView({inline:'nearest',behavior:'smooth',block:'nearest'});
    });
  },{threshold:0.2,rootMargin:'-50px 0px -55% 0px'});
  document.querySelectorAll('[id^="s-"]').forEach(function(s){io.observe(s);});
}

/* ─── FAQ ─── */
window.qbwFaq=function(el){
  var item=el.closest('.qbw-faq-item');
  if(!item) return;
  var was=item.classList.contains('open');
  document.querySelectorAll('.qbw-faq-item.open').forEach(function(i){i.classList.remove('open');});
  if(!was) item.classList.add('open');
};

})();
