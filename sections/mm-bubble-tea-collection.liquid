<div class="mm-toast" id="mmToast"></div>

<script>
(function () {
  'use strict';
  var mmCart = {};

  /* ── Render ADD/stepper for a variant ──────────────── */
  function mmRenderVid(vid) {
    var qty  = mmCart[vid] || 0;
    document.querySelectorAll('.mm-add-btn[data-vid="' + vid + '"]').forEach(function (b) {
      b.style.display = qty > 0 ? 'none' : '';
    });
    document.querySelectorAll('.mm-stepper[data-vid="' + vid + '"]').forEach(function (s) {
      s.style.display = qty > 0 ? 'flex' : 'none';
      qty > 0 ? s.classList.add('visible') : s.classList.remove('visible');
    });
    document.querySelectorAll('.mm-stepper-count[data-vid="' + vid + '"]').forEach(function (c) {
      c.textContent = qty;
    });
  }

  /* ── Update QB universal cart bar ──────────────────── */
  function mmUpdateBar() {
    var total = Object.values(mmCart).reduce(function (a, b) { return a + b; }, 0);
    document.dispatchEvent(new CustomEvent('qb:cart:update', { detail: { count: total } }));
  }

  /* ── Toast ──────────────────────────────────────────── */
  function mmShowToast(msg) {
    var t = document.getElementById('mmToast');
    if (!t) return;
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(t._mm);
    t._mm = setTimeout(function () { t.classList.remove('show'); }, 2000);
  }

  /* ── Add to cart ────────────────────────────────────── */
  function mmAddToCart(vid, qty, btn) {
    if (!vid) return;
    if (btn) { btn.classList.add('loading'); btn.setAttribute('disabled', ''); }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: qty })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      mmCart[vid] = (mmCart[vid] || 0) + qty;
      if (btn) {
        btn.classList.remove('loading');
        btn.classList.add('success');
        btn.textContent = '✓';
        setTimeout(function () { mmRenderVid(vid); mmUpdateBar(); mmShowToast('Added! 🧋'); }, 320);
      } else { mmRenderVid(vid); mmUpdateBar(); mmShowToast('Added! 🧋'); }
    })
    .catch(function () {
      if (btn) { btn.classList.remove('loading'); btn.removeAttribute('disabled'); btn.textContent = 'ADD'; }
    });
  }

  /* ── Change quantity ────────────────────────────────── */
  function mmChangeQty(vid, newQty, btn) {
    if (btn) btn.classList.add('busy');
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: newQty })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      if (newQty <= 0) delete mmCart[vid]; else mmCart[vid] = newQty;
      mmRenderVid(vid); mmUpdateBar();
    })
    .catch(function () { if (btn) btn.classList.remove('busy'); });
  }

  /* ── Restore cart on load ───────────────────────────── */
  function mmRestoreCart() {
    fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      mmCart = {};
      if (data && data.items) {
        data.items.forEach(function (item) { mmCart[String(item.variant_id)] = item.quantity; });
      }
      Object.keys(mmCart).forEach(mmRenderVid);
      mmUpdateBar();
    });
  }

  /* ── Sticky tabs (JS fixed — works across all themes) ─ */
  var mmHeaderH = 0, mmTabsWrapEl = null, mmTabsSpacerEl = null, mmTabsFixed = false;

  function mmGetHeaderH() {
    var hdr = document.querySelector('.qb-header');
    var ann = document.querySelector('.qb-announcement');
    var h = 0;
    if (hdr) h += hdr.offsetHeight;
    if (ann) h += ann.offsetHeight;
    return h > 20 ? h : 102;
  }

  function mmUpdateFixed() {
    if (!mmTabsWrapEl) return;
    var top = mmTabsWrapEl.getBoundingClientRect().top;
    if (!mmTabsFixed) {
      if (top <= mmHeaderH) {
        mmTabsFixed = true;
        mmTabsWrapEl.classList.add('mm-tabs-fixed');
        mmTabsWrapEl.style.top = mmHeaderH + 'px';
        if (mmTabsSpacerEl) {
          mmTabsSpacerEl.style.height = mmTabsWrapEl.offsetHeight + 'px';
          mmTabsSpacerEl.classList.add('mm-tabs-spacer-active');
        }
      }
    } else {
      if (mmTabsSpacerEl && mmTabsSpacerEl.getBoundingClientRect().top > mmHeaderH) {
        mmTabsFixed = false;
        mmTabsWrapEl.classList.remove('mm-tabs-fixed');
        mmTabsWrapEl.style.top = '';
        mmTabsSpacerEl.classList.remove('mm-tabs-spacer-active');
      }
    }
  }

  function mmInitFixed() {
    mmTabsWrapEl   = document.getElementById('mmTabsWrap');
    mmTabsSpacerEl = document.getElementById('mmTabsSpacer');
    if (!mmTabsWrapEl) return;
    mmHeaderH = mmGetHeaderH();
    var th = mmTabsWrapEl.offsetHeight;
    document.documentElement.style.setProperty('--mm-scroll-margin', (mmHeaderH + th + 8) + 'px');
    var mmScroller = document.getElementById('MainContent') || window;
    mmScroller.addEventListener('scroll', mmUpdateFixed, { passive: true });
    window.addEventListener('resize', function () {
      mmHeaderH = mmGetHeaderH();
      document.documentElement.style.setProperty('--mm-scroll-margin', (mmHeaderH + mmTabsWrapEl.offsetHeight + 8) + 'px');
      if (mmTabsFixed) mmTabsWrapEl.style.top = mmHeaderH + 'px';
    }, { passive: true });
  }

  /* ── Category tab navigation ────────────────────────── */
  function mmInitTabs() {
    var tabs = document.querySelectorAll('.mm-tab');
    if (!tabs.length) return;

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var target = document.getElementById(tab.getAttribute('data-target'));
        if (!target) return;
        var offset = mmHeaderH + (mmTabsWrapEl ? mmTabsWrapEl.offsetHeight : 44) + 4;
        var scroller = document.getElementById('MainContent') || window;
        var scrollTop = scroller === window ? window.scrollY : scroller.scrollTop;
        scroller.scrollTo({ top: target.getBoundingClientRect().top + scrollTop - offset, behavior: 'smooth' });
      });
    });

    if (!('IntersectionObserver' in window)) return;
    var sections = [
      { id: 'mm-sec-special',  tabId: 'mm-tab-special'  },
      { id: 'mm-sec-milk',     tabId: 'mm-tab-milk'     },
      { id: 'mm-sec-fruit',    tabId: 'mm-tab-fruit'    },
      { id: 'mm-sec-smoothie', tabId: 'mm-tab-smoothie' },
      { id: 'mm-sec-toppings', tabId: 'mm-tab-toppings' },
      { id: 'mm-sec-others',   tabId: 'mm-tab-others'   }
    ];
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        sections.forEach(function (s) {
          var t = document.getElementById(s.tabId);
          if (!t) return;
          if (s.id === e.target.id) { t.classList.add('active'); t.scrollIntoView({ inline: 'nearest', block: 'nearest' }); }
          else t.classList.remove('active');
        });
      });
    }, { rootMargin: '-56px 0px -60% 0px', threshold: 0 });
    sections.forEach(function (s) { var el = document.getElementById(s.id); if (el) obs.observe(el); });
  }

  /* ── Event delegation ───────────────────────────────── */
  function mmBindCards() {
    var wrap = document.getElementById('mmWrap');
    if (!wrap) return;
    wrap.addEventListener('click', function (e) {
      var t = e.target;
      if (t.classList.contains('mm-add-btn') && !t.classList.contains('loading') && !t.classList.contains('success')) {
        var r = document.createElement('span'); r.className = 'mm-ripple';
        var rect = t.getBoundingClientRect();
        r.style.left = (e.clientX - rect.left) + 'px'; r.style.top = (e.clientY - rect.top) + 'px';
        t.appendChild(r); setTimeout(function () { r.remove(); }, 600);
        mmAddToCart(t.getAttribute('data-vid'), 1, t); return;
      }
      if (t.classList.contains('mm-stepper-minus') && !t.classList.contains('busy')) {
        var vid = t.getAttribute('data-vid');
        mmChangeQty(vid, Math.max(0, (mmCart[vid] || 0) - 1), t); return;
      }
      if (t.classList.contains('mm-stepper-plus') && !t.classList.contains('busy')) {
        var vid = t.getAttribute('data-vid');
        mmChangeQty(vid, (mmCart[vid] || 0) + 1, t);
      }
    });
  }

  /* ── Boot ───────────────────────────────────────────── */
  function mmInit() {
    mmBindCards();
    mmInitTabs();
    mmRestoreCart();
    requestAnimationFrame(function () { setTimeout(mmInitFixed, 300); });
  }

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', mmInit)
    : mmInit();

})();
</script>

