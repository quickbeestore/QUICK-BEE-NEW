}
html:not([data-theme="dark"]) .mm-section-head-inner::after {
  background: linear-gradient(90deg, rgba(124,58,237,0.35) 0%, transparent 100%);
}

/* Product image placeholder - violet tint on light */
html:not([data-theme="dark"]) .mm-img-wrap {
  background: linear-gradient(135deg, #EDE9FE, #FCE7F3);
  border-color: #DDD6FE;
  box-shadow: 0 3px 12px rgba(109,40,217,0.10);
}
html:not([data-theme="dark"]) .mm-img-fallback {
  background: linear-gradient(135deg, #EDE9FE, #FCE7F3);
  border-color: #DDD6FE;
}

/* Price gradient adjusted for light bg */
html:not([data-theme="dark"]) .mm-price {
  background: linear-gradient(90deg, #7C3AED, #DB2777);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Meta tags */
html:not([data-theme="dark"]) .mm-meta-tag {
  color: #7C3AED;
}

/* Inactive tab pill */
html:not([data-theme="dark"]) .mm-tab:not(.active) {
  background: #E0C4F8;
  color: #5C2888;
  border-color: transparent;
}
html:not([data-theme="dark"]) .mm-tab.active {
  box-shadow: 0 2px 14px rgba(130,32,196,0.45);
}

/* Ticker bar */
