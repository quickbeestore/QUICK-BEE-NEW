</div>

<script>
/* ── Countdown: 69 hours from first visit ── */
(function() {
  const EXPIRY_KEY = 'qb_49_expiry';
  const DURATION   = 69 * 60 * 60 * 1000; // 69 hours in ms

  let expiry = parseInt(localStorage.getItem(EXPIRY_KEY) || '0');
  if (!expiry || expiry < Date.now()) {
    expiry = Date.now() + DURATION;
    localStorage.setItem(EXPIRY_KEY, expiry);
  }

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    const diff = expiry - Date.now();
    if (diff <= 0) {
      // Lock everything
      document.getElementById('c49H').textContent = '00';
      document.getElementById('c49M').textContent = '00';
      document.getElementById('c49S').textContent = '00';
      lockPage();
      return;
    }
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const hEl = document.getElementById('c49H');
    const mEl = document.getElementById('c49M');
    const sEl = document.getElementById('c49S');
    if (hEl) hEl.textContent = pad(h);
    if (mEl) mEl.textContent = pad(m);
    if (sEl) sEl.textContent = pad(s);
    setTimeout(tick, 1000);
  }

  function lockPage() {
    // Hide hero content, steps, trust, show locked
    const hero = document.querySelector('.c49-hero');
    const steps = document.getElementById('c49StepsSection');
    const trust = document.querySelector('.c49-trust');
    const locked = document.getElementById('c49Locked');
    if (hero) hero.style.display = 'none';
    if (steps) steps.style.display = 'none';
    if (trust) trust.style.display = 'none';
    if (locked) locked.style.display = 'block';
  }

  tick();
})();
</script>

{%- if customer -%}
<script>
(function() {
  const CUSTOMER_ID = "gid://shopify/Customer/{{ customer.id }}";
  const CLAIMED_KEY = "qb_49_claimed_{{ customer.id }}";
  const API_BASE    = "https://quick-pay-beta-production.up.railway.app";

  // If already claimed this session, show success immediately
  if (localStorage.getItem(CLAIMED_KEY)) {
    showSuccess();
  }

  async function c49Claim() {
    const btn = document.getElementById('c49ClaimBtn');
    if (!btn) return;

    // Double-claim guard
    if (localStorage.getItem(CLAIMED_KEY)) { showSuccess(); return; }

    btn.disabled = true;
    btn.textContent = '⏳ Crediting...';

    try {
      const res = await fetch('/api/quickpay/add-credit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          customerId: CUSTOMER_ID,
          amount: 49,
          method: 'welcome_bonus',
          note: 'Rs 49 welcome bonus — claim page'
        })
      });

      const data = await res.json();

      if (res.ok && data.success !== false) {
        localStorage.setItem(CLAIMED_KEY, '1');
        showSuccess();
      } else {
        // If already credited or error
        const msg = data.message || data.error || '';
        if (msg.toLowerCase().includes('already') || msg.toLowerCase().includes('claimed')) {
          localStorage.setItem(CLAIMED_KEY, '1');
          showSuccess();
        } else {
          btn.disabled = false;
          btn.textContent = '💰 Claim Rs 49 Now';
          alert('Something went wrong. Please try again in a moment.');
        }
      }
    } catch (e) {
      btn.disabled = false;
      btn.textContent = '💰 Claim Rs 49 Now';
      alert('Network error. Please check your connection and try again.');
    }
  }

  function showSuccess() {
    const hero = document.querySelector('.c49-hero');
    const success = document.getElementById('c49Success');
    const steps = document.getElementById('c49StepsSection');
    if (hero) hero.style.display = 'none';
    if (success) success.style.display = 'block';
    if (steps) steps.style.display = 'none';
  }

  window.c49Claim = c49Claim;
})();
</script>
{%- endif -%}

