      {%- else -%}
        <a href="/account/register?return_to=/pages/claim-49" class="c49-cta-btn">
          🐝 Create Account &amp; Claim Rs 49
        </a>
        <p class="c49-cta-note">Already have an account? <a href="/account/login?return_to=/pages/claim-49" style="color:rgba(255,255,255,0.6);text-decoration:underline">Log in</a></p>
      {%- endif -%}
    </div>
  </div>

  <!-- ══ SUCCESS STATE (shown after claim) ══ -->
  <div class="c49-success" id="c49Success">
    <div class="c49-success-circle">🎉</div>
    <div class="c49-success-amount">Rs 49</div>
    <div class="c49-success-title">Bonus Credited!</div>
    <div class="c49-success-sub">Rs 49 has been added to your QuickPay wallet. Use it on any order — no minimum required.</div>
    <div class="c49-success-timer">⏱ Reflects in wallet within 10 minutes</div>
