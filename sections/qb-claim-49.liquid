{% comment %} sections/qb-claim-49.liquid — Claim Rs 49 Welcome Bonus {% endcomment %}

<style>
html:not([data-theme="dark"]) .c49-root {
  --c49-bg:       #F4F6FB;
  --c49-card:     #FFFFFF;
  --c49-text:     #0D0F1A;
  --c49-text2:    #5A6080;
  --c49-border:   rgba(0,0,0,0.07);
  --c49-gold:     #E6A800;
  --c49-gold2:    #F4B400;
  --c49-hero-from:#080E20;
  --c49-hero-to:  #0D1A3A;
  --c49-shadow:   0 4px 20px rgba(0,0,0,0.08);
}
html[data-theme="dark"] .c49-root {
  --c49-bg:       #0A0C14;
  --c49-card:     #141828;
  --c49-text:     #EEF0FF;
  --c49-text2:    #7880A0;
  --c49-border:   rgba(255,255,255,0.07);
  --c49-gold:     #F4B400;
  --c49-gold2:    #FFD040;
  --c49-hero-from:#060810;
  --c49-hero-to:  #0D1530;
  --c49-shadow:   0 4px 28px rgba(0,0,0,0.45);
}

.c49-root {
  background: var(--c49-bg);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: var(--c49-text);
  padding-bottom: 80px;
}
.c49-root *, .c49-root *::before, .c49-root *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── HERO ── */
.c49-hero {
  background: linear-gradient(160deg, var(--c49-hero-from) 0%, var(--c49-hero-to) 100%);
  position: relative;
  overflow: hidden;
  padding: 52px 20px 48px;
  text-align: center;
}
.c49-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% -20%, rgba(244,180,0,0.18) 0%, transparent 65%);
  pointer-events: none;
}
.c49-hero-dots {
  position: absolute; inset: 0; pointer-events: none;
  background-image: radial-gradient(rgba(255,255,255,0.035) 1px, transparent 1px);
  background-size: 26px 26px;
}
.c49-hero-inner { position: relative; z-index: 2; max-width: 480px; margin: 0 auto; }

.c49-badge {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(244,180,0,0.15);
  border: 1px solid rgba(244,180,0,0.35);
  color: #F4B400;
  font-size: 11px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase;
  padding: 6px 16px; border-radius: 999px; margin-bottom: 22px;
}
.c49-badge-dot {
  width: 6px; height: 6px; background: #4ADE80; border-radius: 50%;
  box-shadow: 0 0 6px rgba(74,222,128,0.7);
  animation: c49-pulse 1.8s ease-in-out infinite;
}
@keyframes c49-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.5)} }

.c49-amount {
  font-size: clamp(72px, 20vw, 120px);
  font-weight: 900;
  background: linear-gradient(135deg, #F4B400 0%, #FFE066 50%, #F4B400 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  letter-spacing: -0.04em;
  filter: drop-shadow(0 4px 24px rgba(244,180,0,0.4));
  animation: c49-glow 3s ease-in-out infinite;
}
@keyframes c49-glow {
  0%,100%{filter:drop-shadow(0 4px 24px rgba(244,180,0,0.4))}
  50%{filter:drop-shadow(0 4px 40px rgba(244,180,0,0.7))}
}
.c49-amount-label {
  font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.5);
  letter-spacing: 0.1em; text-transform: uppercase;
  margin-top: 4px; margin-bottom: 14px;
}
.c49-hero-title {
  font-size: clamp(22px, 6vw, 32px);
  font-weight: 900; color: #fff;
  line-height: 1.15; letter-spacing: -0.02em;
  margin-bottom: 10px;
}
.c49-hero-sub {
  font-size: 15px; color: rgba(255,255,255,0.6);
  line-height: 1.6; max-width: 360px; margin: 0 auto 28px;
}

/* ── CTA BUTTON ── */
.c49-cta-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  background: linear-gradient(135deg, #F4B400, #FFD040);
  color: #0A0C14; font-size: 17px; font-weight: 900;
  border: none; border-radius: 14px;
  padding: 17px 36px; cursor: pointer;
  box-shadow: 0 8px 32px rgba(244,180,0,0.45);
  transition: transform 0.15s, box-shadow 0.15s;
  text-decoration: none;
  width: 100%; max-width: 360px;
  letter-spacing: -0.01em;
}
.c49-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(244,180,0,0.6); }
.c49-cta-btn:active { transform: scale(0.97); }
.c49-cta-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

.c49-cta-note {
  font-size: 12px; color: rgba(255,255,255,0.4);
  margin-top: 12px;
}

/* ── STEPS ── */
.c49-steps-section {
  max-width: 480px; margin: 0 auto;
  padding: 32px 20px 0;
}
.c49-steps-title {
  font-size: 13px; font-weight: 800; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--c49-gold);
  margin-bottom: 16px; text-align: center;
}
.c49-steps {
  display: flex; flex-direction: column; gap: 0;
  background: var(--c49-card);
  border: 1px solid var(--c49-border);
  border-radius: 20px;
  overflow: hidden;
  box-shadow: var(--c49-shadow);
}
.c49-step {
  display: flex; align-items: center; gap: 16px;
  padding: 18px 20px;
  border-bottom: 1px solid var(--c49-border);
  transition: background 0.2s;
}
.c49-step:last-child { border-bottom: none; }
.c49-step-num {
  width: 40px; height: 40px; min-width: 40px;
  background: linear-gradient(135deg, #E6A800, #F4B400);
  color: #000; font-size: 15px; font-weight: 900;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 3px 10px rgba(244,180,0,0.3);
  flex-shrink: 0;
}
.c49-step-text { flex: 1; min-width: 0; }
.c49-step-title { font-size: 14px; font-weight: 800; color: var(--c49-text); margin-bottom: 2px; }
.c49-step-sub { font-size: 12px; color: var(--c49-text2); line-height: 1.4; }
.c49-step-icon { font-size: 24px; }

/* ── TRUST STRIP ── */
.c49-trust {
  display: flex; justify-content: center; gap: 24px; flex-wrap: wrap;
  max-width: 480px; margin: 24px auto 0;
  padding: 0 20px;
}
.c49-trust-item {
  display: flex; align-items: center; gap: 6px;
  font-size: 12px; font-weight: 600; color: var(--c49-text2);
}
.c49-trust-item span:first-child { font-size: 16px; }

/* ── ALREADY CLAIMED / LOGGED IN STATE ── */
.c49-state-card {
  max-width: 480px; margin: 32px auto 0;
  padding: 0 20px;
}
.c49-state-inner {
  background: var(--c49-card);
  border: 1px solid var(--c49-border);
  border-radius: 20px; padding: 28px 24px;
  text-align: center;
  box-shadow: var(--c49-shadow);
}
.c49-state-emoji { font-size: 44px; margin-bottom: 10px; }
.c49-state-title { font-size: 20px; font-weight: 900; color: var(--c49-text); margin-bottom: 6px; }
.c49-state-sub { font-size: 14px; color: var(--c49-text2); line-height: 1.6; margin-bottom: 20px; }
.c49-wallet-link {
  display: inline-flex; align-items: center; gap: 6px;
  background: linear-gradient(135deg, #F4B400, #FFD040);
  color: #0A0C14; font-size: 14px; font-weight: 800;
  border-radius: 12px; padding: 13px 28px;
  text-decoration: none;
  box-shadow: 0 6px 20px rgba(244,180,0,0.35);
  transition: transform 0.15s;
}
.c49-wallet-link:hover { transform: translateY(-2px); }

/* ── SUCCESS STATE ── */
.c49-success {
  display: none;
  max-width: 480px; margin: 0 auto;
  padding: 40px 20px;
  text-align: center;
}
.c49-success-circle {
  width: 88px; height: 88px;
  background: linear-gradient(135deg, rgba(244,180,0,0.15), rgba(244,180,0,0.05));
  border: 2px solid rgba(244,180,0,0.35);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 42px;
  margin: 0 auto 20px;
  animation: c49-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
}
@keyframes c49-pop { from{transform:scale(0);opacity:0} to{transform:scale(1);opacity:1} }
.c49-success-title { font-size: 26px; font-weight: 900; color: var(--c49-text); margin-bottom: 8px; }
.c49-success-sub { font-size: 15px; color: var(--c49-text2); line-height: 1.6; margin-bottom: 28px; }
.c49-success-amount {
  font-size: 48px; font-weight: 900;
  background: linear-gradient(135deg, #F4B400, #FFD040);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  margin-bottom: 6px;
}
.c49-success-timer { font-size: 13px; color: var(--c49-text2); margin-bottom: 24px; }
/* ── COUNTDOWN TIMER ── */
.c49-countdown-wrap {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  margin-bottom: 22px;
}
.c49-countdown-label {
  font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.45);
  text-transform: uppercase; letter-spacing: 0.1em;
}
.c49-countdown {
  display: flex; gap: 6px; align-items: center;
}
.c49-cd-block {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px; padding: 8px 10px;
  text-align: center; min-width: 48px;
}
.c49-cd-num {
  font-size: 22px; font-weight: 900; color: #F4B400;
  line-height: 1; letter-spacing: -0.02em;
  font-variant-numeric: tabular-nums;
}
.c49-cd-unit {
  font-size: 9px; font-weight: 700; color: rgba(255,255,255,0.4);
  text-transform: uppercase; letter-spacing: 0.08em; margin-top: 2px;
}
.c49-cd-sep { font-size: 20px; font-weight: 900; color: rgba(244,180,0,0.5); margin-top: -6px; }

/* ── LOCKED STATE ── */
.c49-locked {
  display: none;
  text-align: center; padding: 60px 20px;
  max-width: 400px; margin: 0 auto;
}
.c49-locked-icon { font-size: 56px; margin-bottom: 16px; }
.c49-locked-title { font-size: 24px; font-weight: 900; color: var(--c49-text); margin-bottom: 8px; }
.c49-locked-sub { font-size: 14px; color: var(--c49-text2); line-height: 1.6; }
</style>

<div class="c49-root">

  {%- assign claimed_key = 'qb_49_claimed_' | append: customer.id -%}

  <!-- ══ HERO ══ -->
  <div class="c49-hero">
    <div class="c49-hero-dots"></div>
    <div class="c49-hero-inner">
      <div class="c49-badge"><span class="c49-badge-dot"></span>Limited — Ends Soon</div>
