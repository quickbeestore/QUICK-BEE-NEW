                <span class="bq-stepper-count" data-vid="{{ vid }}">1</span>
                <button class="bq-stepper-btn bq-stepper-plus" data-vid="{{ vid }}">+</button>
              </div>
            </div>
          </div>
        {%- endunless -%}
      {%- endfor -%}
    </div>
    {%- endif -%}

  {%- endif -%}
</div>

<!-- Toast -->
<div class="bq-toast" id="bqToast"></div>

<script>
(function () {
  'use strict';

  var bqCart = {};

  /* ── Render a single variant's ADD/stepper state ─────── */
  function bqRenderVid(vid) {
    var qty  = bqCart[vid] || 0;
    var btns = document.querySelectorAll('.bq-add-btn[data-vid="' + vid + '"]');
    var stps = document.querySelectorAll('.bq-stepper[data-vid="' + vid + '"]');
    var cnts = document.querySelectorAll('.bq-stepper-count[data-vid="' + vid + '"]');
    btns.forEach(function (b) { b.style.display = qty > 0 ? 'none' : ''; });
    stps.forEach(function (s) {
      s.style.display = qty > 0 ? 'flex' : 'none';
      if (qty > 0) s.classList.add('visible');
      else         s.classList.remove('visible');
    });
    cnts.forEach(function (c) { c.textContent = qty; });
  }

  /* ── Update universal QB cart bar ───────────────────── */
  function bqUpdateBar() {
    var total = Object.values(bqCart).reduce(function (a, b) { return a + b; }, 0);
    var event = new CustomEvent('qb:cart:update', { detail: { count: total } });
    document.dispatchEvent(event);
  }

  /* ── Toast ───────────────────────────────────────────── */
  function bqShowToast(msg) {
    var t = document.getElementById('bqToast');
    if (!t) return;
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(t._bqTimer);
    t._bqTimer = setTimeout(function () { t.classList.remove('show'); }, 2000);
  }

  /* ── Add to cart ─────────────────────────────────────── */
  function bqAddToCart(vid, qty, btn) {
    if (!vid) return;
    if (btn) {
      btn.classList.add('loading');
      btn.setAttribute('disabled', '');
    }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: qty })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      bqCart[vid] = (bqCart[vid] || 0) + qty;
      if (btn) {
        btn.classList.remove('loading');
        btn.classList.add('success');
        btn.textContent = '✓';
        setTimeout(function () {
          bqRenderVid(vid);
          bqUpdateBar();
          bqShowToast('Added to cart 🌹');
        }, 320);
      } else {
        bqRenderVid(vid);
        bqUpdateBar();
        bqShowToast('Added to cart 🌹');
      }
    })
    .catch(function (e) {
      console.error('[BQCart] add error', e);
      if (btn) {
        btn.classList.remove('loading');
        btn.removeAttribute('disabled');
        btn.textContent = 'ADD';
      }
    });
  }

  /* ── Change quantity ─────────────────────────────────── */
  function bqChangeQty(vid, newQty, btn) {
    if (btn) btn.classList.add('busy');
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: newQty })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      if (newQty <= 0) delete bqCart[vid];
      else             bqCart[vid] = newQty;
      bqRenderVid(vid);
      bqUpdateBar();
    })
    .catch(function (e) {
      console.error('[BQCart] change error', e);
      if (btn) btn.classList.remove('busy');
    });
  }

  /* ── Restore cart on load ────────────────────────────── */
  function bqRestoreCart() {
    fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      bqCart = {};
      if (data && data.items) {
        data.items.forEach(function (item) {
          bqCart[String(item.variant_id)] = item.quantity;
        });
      }
      Object.keys(bqCart).forEach(function (vid) { bqRenderVid(vid); });
      bqUpdateBar();
    })
    .catch(function (e) { console.error('[BQCart] restore error', e); });
  }

  /* ── Category tabs: click + scroll-active ───────────── */
  var bqHeaderH    = 0;
  var bqTabsWrapEl = null;
  var bqTabsSpacerEl = null;
  var bqTabsFixed  = false;

  function bqGetHeaderH() {
    var hdr = document.querySelector('.qb-header');
    var ann = document.querySelector('.qb-announcement');
    var h = 0;
    if (hdr) h += hdr.offsetHeight;
    if (ann) h += ann.offsetHeight;
    return h > 20 ? h : 102;
  }

  function bqUpdateTabsFixed() {
    if (!bqTabsWrapEl) return;
    var tabsTop = bqTabsWrapEl.getBoundingClientRect().top;
    if (!bqTabsFixed) {
      if (tabsTop <= bqHeaderH) {
        bqTabsFixed = true;
        bqTabsWrapEl.classList.add('bq-tabs-fixed');
        bqTabsWrapEl.style.top = bqHeaderH + 'px';
        if (bqTabsSpacerEl) {
          bqTabsSpacerEl.style.height = bqTabsWrapEl.offsetHeight + 'px';
          bqTabsSpacerEl.classList.add('bq-tabs-spacer-active');
        }
      }
    } else {
      if (bqTabsSpacerEl) {
        var spacerTop = bqTabsSpacerEl.getBoundingClientRect().top;
        if (spacerTop > bqHeaderH) {
          bqTabsFixed = false;
          bqTabsWrapEl.classList.remove('bq-tabs-fixed');
          bqTabsWrapEl.style.top = '';
          bqTabsSpacerEl.classList.remove('bq-tabs-spacer-active');
        }
      }
    }
  }

  function bqInitFixed() {
    bqTabsWrapEl   = document.getElementById('bqTabsWrap');
    bqTabsSpacerEl = document.getElementById('bqTabsSpacer');
    if (!bqTabsWrapEl) return;
    bqHeaderH = bqGetHeaderH();
    var tabsH = bqTabsWrapEl.offsetHeight;
    document.documentElement.style.setProperty('--bq-scroll-margin', (bqHeaderH + tabsH + 8) + 'px');
    window.addEventListener('scroll', bqUpdateTabsFixed, { passive: true });
    window.addEventListener('resize', function () {
      bqHeaderH = bqGetHeaderH();
      var th = bqTabsWrapEl.offsetHeight;
      document.documentElement.style.setProperty('--bq-scroll-margin', (bqHeaderH + th + 8) + 'px');
      if (bqTabsFixed) bqTabsWrapEl.style.top = bqHeaderH + 'px';
    }, { passive: true });
  }

  function bqInitTabs() {
    var tabs = document.querySelectorAll('.bq-tab');
    if (!tabs.length) return;

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var targetId = tab.getAttribute('data-target');
        var target   = document.getElementById(targetId);
        if (!target) return;
        var tabsH  = bqTabsWrapEl ? bqTabsWrapEl.offsetHeight : 44;
        var offset = bqHeaderH + tabsH + 4;
        var top    = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top: top, behavior: 'smooth' });
      });
    });

    if (!('IntersectionObserver' in window)) return;

    var sections = [
      { id: 'bq-sec-roses',    tabId: 'bq-tab-roses'    },
      { id: 'bq-sec-bouquets', tabId: 'bq-tab-bouquets' },
      { id: 'bq-sec-seasonal', tabId: 'bq-tab-seasonal' },
      { id: 'bq-sec-gifts',    tabId: 'bq-tab-gifts'    },
      { id: 'bq-sec-stems',    tabId: 'bq-tab-stems'    },
      { id: 'bq-sec-others',   tabId: 'bq-tab-others'   }
    ];

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        var sid = entry.target.id;
        sections.forEach(function (s) {
          var tab = document.getElementById(s.tabId);
          if (!tab) return;
          if (s.id === sid) {
            tab.classList.add('active');
            tab.scrollIntoView({ inline: 'nearest', block: 'nearest' });
          } else {
            tab.classList.remove('active');
          }
        });
      });
    }, { rootMargin: '-56px 0px -60% 0px', threshold: 0 });

    sections.forEach(function (s) {
      var el = document.getElementById(s.id);
      if (el) observer.observe(el);
    });
  }

  /* ── Event delegation for ADD / stepper ─────────────── */
  function bqBindCards() {
    var wrap = document.getElementById('bqWrap');
    if (!wrap) return;
    wrap.addEventListener('click', function (e) {
      var t = e.target;

      if (t.classList.contains('bq-add-btn') && !t.classList.contains('loading') && !t.classList.contains('success')) {
        // Ripple
        var r = document.createElement('span');
        r.className = 'bq-ripple';
        var rect = t.getBoundingClientRect();
        r.style.left = (e.clientX - rect.left) + 'px';
        r.style.top  = (e.clientY - rect.top) + 'px';
        t.appendChild(r);
        setTimeout(function () { r.remove(); }, 600);
        bqAddToCart(t.getAttribute('data-vid'), 1, t);
        return;
      }

      if (t.classList.contains('bq-stepper-minus') && !t.classList.contains('busy')) {
        var vid = t.getAttribute('data-vid');
        bqChangeQty(vid, Math.max(0, (bqCart[vid] || 0) - 1), t);
        return;
      }

      if (t.classList.contains('bq-stepper-plus') && !t.classList.contains('busy')) {
        var vid = t.getAttribute('data-vid');
        bqChangeQty(vid, (bqCart[vid] || 0) + 1, t);
        return;
      }
    });
  }

  /* ── Boot ────────────────────────────────────────────── */
  function bqInit() {
    bqBindCards();
    bqInitTabs();
    bqRestoreCart();
    requestAnimationFrame(function () {
      setTimeout(bqInitFixed, 300);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bqInit);
  } else {
    bqInit();
  }

})();
</script>

{% schema %}
{ "name": "QB Bouquet Collection", "settings": [] }
{% endschema %}
